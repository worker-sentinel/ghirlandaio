[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;54r\u001b[H# HOOKS\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f1,1           68\u001b[H\u001b[?25h"]
