[0.035, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H##   NOTE: If you have /usr on a separate partition, you MUST include the\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f3,1            3%\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#    usr and fsck hooks.\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f4,1            6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1HHOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block filesystems fsck)\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f5,1           10\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f6,1           13\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# COMPRESSION\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f7,1           17\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# Use this to compress the initramfs image. By default, zstd compression\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f8,1           20\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# is used for Linux ≥\u001b[52;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f9,1           24\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# Use 'cat' to create an uncompressed image.\u001b[K\u001b[53;175H\u001b[0;10;7m\u000f60,1           27\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION=\"zstd\"\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f1,1           31\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION=\"gzip\"\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f2,1           34\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION=\"bzip2\"\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f3,1           37\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION=\"lzma\"\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f4,1           41\r\u001b[A\u001b[?25h"]
[0.865, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION=\"xz\"\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f5,1           44\r\u001b[A\u001b[?25h"]
[0.259, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION=\"lzop\"\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f6,1           48\r\u001b[A\u001b[?25h"]
