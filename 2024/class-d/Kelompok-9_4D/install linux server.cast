[0.035, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# COMPRESSION_OPTIONS\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f9,1           58\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# Additional options for the compressor\u001b[K\u001b[53;175H\u001b[0;10;7m\u000f70,1           62\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H#COMPRESSION_OPTIONS=()\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f1,1           65\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f2,1           68\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# MODULES_DECOMPRESS\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f3,1           72\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;54r\u001b[52;1H# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f4,1           75\r\u001b[A\u001b[?25h"]
