[0.258, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;54r\u001b[HBINARIES=()\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f4,1           44\u001b[H\u001b[?25h"]
[0.202, "o", "\u001b[?25l\u001b[1;52r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;54r\u001b[H# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\u001b[53;176H\u001b[0;10;7m\u000f3,1           41\u001b[H\u001b[?25h"]
