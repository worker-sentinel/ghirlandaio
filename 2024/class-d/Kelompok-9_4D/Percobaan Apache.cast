[0.006, "o", "\u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m memory-mapping or the sendfile syscall may be used to deliver\u001b[2;3Hfiles.  This usually improves server performance, but must\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[14X\u001b[3;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbe turned off when serving from networked-mounted \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[13X\u001b[4;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mfilesystems or if support for these functions is otherwise\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[11X\u001b[5;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbroken on your system.\u001b[6;3HDefaults: EnableMMAP On, EnableSendfile Off\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[15X\u001b[7;2H\u001b[50X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mEnableMMAP off\u001b[9;2HEnableSendfile on\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[49X\r\n\u001b[76X\u001b[11;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mSupplemental configuration\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[22X\u001b[13;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mThe configuration files in the conf/extra/ directory can be \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[10X\u001b[14;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mincluded to add extra features or to modify the default configuration of \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b[15;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mthe server, or you may simply copy their contents here and change as \u001b[16;3Hnecessary.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[60X\r\n\u001b[72X\u001b[18;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mServer-pool management (MPM specific)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[38X\r\n\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-mpm.conf\u001b[11X\u001b[21;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Multi-language error messages\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-multilang-errordoc.conf\u001b[20X\r\n\u001b[47X\u001b[24;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Fancy directory listings\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-autoindex.conf\u001b[29X\r\n\u001b[72X\u001b[27;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLanguage settings\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[57X\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-languages.conf\u001b[33X\r\n\u001b[16X\u001b[30;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m User home directories\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-userdir.conf\u001b[33;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Real-time info on requests and configuration\u001b[34;2H\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mconf/extra/httpd-info.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[36X\r\n\u001b[55X\u001b[36;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Virtual hosts\u001b[37;2H\u001b(B\u001b[m\u001b[38;2;238;241;248m\u0