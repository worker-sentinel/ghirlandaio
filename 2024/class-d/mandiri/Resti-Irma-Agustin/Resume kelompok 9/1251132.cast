[0.018, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.001, "o", "\u001b[?25l\u001b[m\u000f# Virtual Hosts\u001b[K\r\n#\u001b[K\r\n# Required modules: mod_log_config\u001b[K\r\n\u001b[K\n# If you want to maintain multiple domains/hostnames on your\u001b[K\r\n# machine you can setup VirtualHost containers for them. Most configurations\u001b[K\r\n# use only name-based virtual hosts so the server doesn't need to worry about\u001b[K\r\n# IP addresses. This is indicated by the asterisks in the directives below.\u001b[K\r\n#\u001b[K\r\n# Please see the documentation at \u001b[K\r\n# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\u001b[K\r\n# for further details before you try to setup virtual hosts.\u001b[K\r\n#\u001b[K\r\n# You may use the command line option '-S' to verify your virtual host\u001b[K\r\n# configuration.\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# VirtualHost example:\u001b[K\r\n# Almost any Apache directive may go into a VirtualHost container.\u001b[K\r\n# The first VirtualHost section is used for all requests that do not\u001b[K\r\n# match a ServerName or ServerAlias in any <VirtualHost> block.\u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<VirtualHost\u001b[m\u000f *:80\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerAdmin\u001b[m\u000f webmaster@dummy-host.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/etc/httpd/docs/dummy-host.example.com\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerName\u001b[m\u000f dummy-host.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mServerAlias\u001b[m\u000f www.dummy-host.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host.example.com-error_log\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mCustomLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host.example.com-access_log\"\u001b[m\u000f common\u001b[K\r\n\u001b[0;10;1m\u000f</VirtualHost>\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f<VirtualHost\u001b[m\u000f *:80\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerAdmin\u001b[m\u000f webmaster@dummy-host2.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/etc/httpd/docs/dummy-host2.example.com\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerName\u001b[m\u000f dummy-host2.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host2.example.com-error_log\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mCustomLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host2.example.com-access_log\"\u001b[m\u000f common\u001b[K\r\n\u001b[0;10;1m\u000f</VirtualHost>\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[K\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000f/etc/httpd/conf/extra/httpd-vhosts.conf                                                                                                                                                                                       1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H# Virtual Hosts\u001b[K\r\n#\u001b[K\r\n# Required modules: mod_log_config\u001b[K\r\n\u001b[K\n# If you want to maintain multiple domains/hostnames on your\u001b[K\r\n# machine you can setup VirtualHost containers for them. Most configurations\u001b[K\r\n# use only name-based virtual hosts so the server doesn't need to worry about\u001b[K\r\n# IP addresses. This is indicated by the asterisks in the directives below.\u001b[K\r\n#\u001b[K\r\n# Please see the documentation at \u001b[K\r\n# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\u001b[K\r\n# for further details before you try to setup virtual hosts.\u001b[K\r\n#\u001b[K\r\n# You may use the command line option '-S' to verify your virtual host\u001b[K\r\n# configuration.\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# VirtualHost example:\u001b[K\r\n# Almost any Apache directive may go into a VirtualHost container.\u001b[K\r\n# The first VirtualHost section is used for all requests that do not\u001b[K\r\n# match a ServerName or ServerAlias in any <VirtualHost> block.\u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<VirtualHost\u001b[m\u000f *:80\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerAdmin\u001b[m\u000f webmaster@dummy-host.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/etc/httpd/docs/dummy-host.example.com\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerName\u001b[m\u000f dummy-host.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mServerAlias\u001b[m\u000f www.dummy-host.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host.example.com-error_log\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mCustomLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host.example.com-access_log\"\u001b[m\u000f common\u001b[K\r\n\u001b[0;10;1m\u000f</VirtualHost>\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f<VirtualHost\u001b[m\u000f *:80\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerAdmin\u001b[m\u000f webmaster@dummy-host2.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/etc/httpd/docs/dummy-host2.example.com\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mServerName\u001b[m\u000f dummy-host2.\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n    \u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/"]
[0.000, "o", "var/log/httpd/dummy-host2.example.com-error_log\"\u001b[m\u000f\u001b[K\r\n    \u001b[96mCustomLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/dummy-host2.example.com-access_log\"\u001b[m\u000f common\u001b[K\r\n\u001b[0;10;1m\u000f</VirtualHost>\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[K\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000f/etc/httpd/conf/extra/httpd-vhosts.conf                                                                                                                                                                                       1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
