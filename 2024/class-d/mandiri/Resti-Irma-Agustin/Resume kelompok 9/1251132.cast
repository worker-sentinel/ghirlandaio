[0.006, "o", "\u001b[1;2H\u001b[52X\n If your host doesn't have a registered DNS name, enter its IP address here.\r\n#\u001b[47X\nServerName www.example.com:80\u001b[15X\r\n\u001b[53X\u001b[6;2H\u001b[52X\r\n# Deny access to the entirety of your server's filesystem. You must\r\n# explicitly permit access to web content directories in other \u001b[9;2H <Directory> blocks below.\u001b[24X\u001b[10;2H\u001b[44X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f /\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[48X\r\n    \u001b[96mAllowOverride\u001b[m\u000f none\u001b[31X\r\n    \u001b[96mRequire\u001b[m\u000f all denied\u001b[33X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[43X\r\n\u001b[55X\u001b[16;2H\u001b[56X\n Note that from this point forward you must specifically allow\r\n# particular features to be enabled - so if something's not working as\u001b[19;2H you might expect, make sure that you have specifically enabled it\u001b[20;2H below.\u001b[55X\u001b[21;2H\u001b[60X\r\n\u001b[59X\u001b[23;2H\u001b[48X\n DocumentRoot: The directory out of which you will serve your \u001b[25;2H documents. By default, all requests are taken from this directory, but\u001b[26;2H symbolic links and aliases may be used to point to other locations.\r\n#\u001b[55X\r\n\u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http\"\u001b[m\u000f\u001b[37X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[18X\r\n    #\u001b[42X\r\n    # Possible values for the Options directive are \"None\", \"All\",\r\n    # or any combination of:\u001b[29X\r\n    #   \u001b[30m\u001b[103mIn\u001b[m\u000fdexes \u001b[30m\u001b[103mIn\u001b[m\u000fcludes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\n    #\u001b[68X\r\n    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\n    # doesn't give it to you.\u001b[44X\r\n    #\u001b[66X\r\n    # The Options directive is both complicated and important.  Please see\r\n    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\n    # for more information.\u001b[32X\r\n    #\u001b[36X\r\n    \u001b[96mOptions\u001b[m\u000f \u001b[30m\u001b[103mIn\u001b[m\u000fdexes FollowSymLinks\u001b[12X\r\n\u001b[52X\n    #\u001b[38X\r\n    # AllowOverride controls what directives may be placed in .htaccess files.\r\n    # It can be \"All\", \"None\", or any combination of the keywords:\r\n    #   AllowOverride File\u001b[30m\u001b[103mIn\u001b[m\u000ffo AuthConfig Limit\u001b[48;5H#\u001b[46X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\r\n\u001b[29X\u001b[51;5H#\u001b[44X\r\n    # Controls who can get stuff from this server.\r\n    #\u001b[42X\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[28X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[45X\r\n\u001b[56X\n#\u001b[39X\n Directory\u001b[30m\u001b[103mIn\u001b[m\u000fdex: sets the file that Apache will serve if a directory\u001b[59;2H is requested.\u001b[34X\u001b[60;2H\u001b[48X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f dir_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[27X\r\n    \u001b[96mDirectory\u001b[m\u000f\u001b[30m\u001b[103mIn\u001b[m\u000f\u001b[96mdex\u001b[m\u000f index.html\u001b[15X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[37X\r\n\n#\u001b[22X\u001b[66;223H\u001b[0;10;7m\u000f260,9          47\u001b[67;4H\u001b[?25h"]
