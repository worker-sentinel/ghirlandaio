[0.005, "o", "\u001b[1;2H\u001b[m\u000fErrorDocument 404 /missing.html\u001b[2;2HErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\u001b[29X\u001b[3;2HErrorDocument 402 http://www.example.com/subscription_info.html\u001b[4;2H\u001b[29X\u001b[7;3HMaxRanges: Maximum number of Ranges in a request before\u001b[10X\u001b[8;3Hreturning the entire resource, or one of the special\u001b[9X\u001b[9;3Hvalues 'default', 'none' or 'unlimited'.\u001b[10;2H Default setting is to accept 200 Ranges.\r\n#MaxRanges unlimited\u001b[12;5H\u001b[18X\r\n#\u001b[21X\r\n# EnableMMAP and EnableSendfile: On systems that support it, \r\n# memory-mapping or the sendfile syscall may be used to deliver\u001b[16;2H files.  This usually improves server performance, but must\u001b[17;3Hbe turned off when serving from networked-mounted \u001b[11X\u001b[18;3Hfilesystems or if support for these functions is otherwise\u001b[10X\u001b[19;3Hbroken on your system.\u001b[43X\u001b[20;3HDefaults: EnableMMAP On, EnableSendfile Off\r\n\n#EnableMMAP off\u001b[23;2HEnableSendfile on\r\n\u001b[62X\u001b[25;3HSupplemental configuration\u001b[44X\u001b[26;2H\u001b[68X\n The configuration files in the conf/extra/ directory can be \r\n# included to add extra features or to modify the default configuration of \r\n# the server, or you may simply copy their contents here and change as \r\n# necessary.\r\n\u001b[66X\n# Server-pool management (MPM specific)\r\n\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-mpm.conf\u001b[46X\r\n\u001b[5X\n# Multi-language error messages\u001b[42X\r\n\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-multilang-errordoc.conf\r\n\u001b[5X\n# Fancy directory listings\u001b[48X\r\n\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-autoindex.conf\u001b[21X\r\n\u001b[27X\n# Language settings\r\n\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-languages.conf\r\n\n# User home directories\r\n\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-userdir.conf\u001b[41X\r\n\u001b[66X\n# Real-time info on requests and configuration \r\n#\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-info.conf\u001b[49;5H\u001b[18X\r\n# Virtual hosts\r\n#\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-vhosts.conf\r\n\u001b[50X\n# Local access to the Apache HTTP Server Manual\r\n#\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-manual.conf\r\n\u001b[12X\n# Distributed authoring and versioning (WebDAV)\u001b[57;2H\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-dav.conf\r\n\u001b[69X\u001b[59;3HVarious default settings\r\n\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/httpd-default.conf\r\n\u001b[21X\n# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[63;2H\u001b[0;10;1m\u000fIfModule\u001b[m\u000f proxy_html_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f\u001b[30m\u001b[103mInclude \u001b[m\u000fconf/extra/proxy-html.conf\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[66;223H\u001b[0;10;7m\u000f496,1          9\u001b[67;10H\u001b[?25h"]
