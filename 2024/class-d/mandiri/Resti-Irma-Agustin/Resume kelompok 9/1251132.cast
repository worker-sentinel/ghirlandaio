[0.006, "o", "\u001b[H#\u001b[59X\r\n# This is the main Apache HTTP server configuration file.  It contains the\u001b[3;2H configuration directives that give the server its instructions.\u001b[4;2H See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\u001b[5;2H In particular, see \u001b[38X\u001b[6;2H <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\u001b[7;2H for a discussion of each configuration directive.\u001b[8;2H\u001b[54X\n Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\u001b[10;2H what they do.  They're here only as hints or reminders.  If you are unsure\u001b[11;2H consult the online docs. You have been warned.  \u001b[7X\u001b[12;2H\u001b[66X\n Configuration and logfile names: If the filenames you specify for many\u001b[14;2H of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[15;2H server will use that explicit path.  If the filenames do *not* begin\u001b[16;2H with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\u001b[17;2H with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\u001b[18;2H server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \u001b[19;2H will be interpreted as '/logs/access_log'.   \r\n\u001b[43X\u001b[21;2H\u001b[52X\r\n# ServerRoot: The top of the directory tree under which the server's\u001b[23;2H configuration, error, and log files are kept.\u001b[8X\u001b[24;2H\u001b[48X\r\n# Do not add a slash at the end of the directory path.  If you point\r\n# ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[27;2H Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[28;2H same ServerRoot for multiple httpd daemons, you will need to change at\u001b[29;2H least PidFile.\u001b[25X\u001b[30;2H\u001b[58X\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[26X\r\n\u001b[49X\u001b[33;2H\u001b[54X\n Mutex: Allows you to set the mutex mechanism and mutex file directory\r\n# for individual mutexes, or change the global defaults\u001b[36;2H\u001b[42X\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[38;2H mutex file directory is not on a local disk or is not appropriate for some\u001b[39;2H other reason.\u001b[44X\u001b[40;2H\u001b[44X\n Mutex default:/run/httpd\u001b[15X\r\n\u001b[40X\u001b[43;2H\u001b[54X\n Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[45;2H ports, instead of the default. See also the <VirtualHost>\r\n# directive.\u001b[36X\u001b[47;2H\u001b[44X\n Change this to Listen on specific IP addresses as shown below to \u001b[49;2H prevent Apache from glomming onto all bound IP addresses.\r\n#\u001b[49X\r\n#Listen 12.34.56.78:80\u001b[26X\r\n\u001b[96mListen\u001b[m\u000f 80\u001b[42X\r\n\u001b[45X\u001b[54;2H\u001b[60X\n Dynamic Shared Object (DSO) Support\u001b[16X\u001b[56;2H\u001b[54X\n To be able to use the functionality of a module which was built as a DSO you\u001b[58;2H have to place corresponding `LoadModule' lines at this location so the\u001b[59;2H directives contained in it are actually available _before_ they are used.\u001b[60;2H Statically compiled modules (those listed by `httpd -l') do not need\u001b[61;2H to be loaded here.\u001b[43X\u001b[62;2H\u001b[52X\n Example:\u001b[53X\u001b[64;2H LoadModule foo_module modules/mod_foo.so\u001b[19X\u001b[65;2H\u001b[58X\u001b[66;224H\u001b[0;10;7m\u000f,1            Top\u001b[67;19H\u001b[?25h"]
[2.114, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.006, "o", "\u001b[H\u001b[96mLoadModule\u001b[m\u000f access_compat_module modules/mod_access_compat.so\r\n\u001b[96mLoadModule\u001b[m\u000f auth_basic_module modules/mod_auth_basic.so\u001b[20X\u001b[3;2HLoadModule auth_form_module modules/mod_auth_form.so\u001b[12X\u001b[4;2HLoadModule auth_digest_module modules/mod_auth_digest.so\u001b[14X\u001b[5;2HLoadModule allowmethods_module modules/mod_allowmethods.so\u001b[6;2HLoadModule file_cache_module modules/mod_file_cache.so\u001b[5X\u001b[7;2HLoadModule cache_module modules/mod_cache.so\u001b[6X\u001b[8;2HLoadModule cache_disk_module modules/mod_cache_disk.so\u001b[9;2HLoadModule cache_socache_module modules/mod_cache_socache.so\u001b[6X\u001b[10;2HLoadModule socache_shmcb_module modules/mod_socache_shmcb.so\u001b[15X\u001b[11;2HLoadModule socache_dbm_module modules/mod_socache_dbm.so\u001b[12;2HLoadModule socache_memcache_module modules/mod_socache_memcache.so\u001b[13;2HLoadModule socache_redis_module modules/mod_socache_redis.so\u001b[11X\u001b[14;2HLoadModule watchdog_module modules/mod_watchdog.so\u001b[25X\u001b[15;2HLoadModule macro_module modules/mod_macro.so\u001b[25X\u001b[16;2HLoadModule dbd_module modules/mod_dbd.so\u001b[31X\u001b[17;2HLoadModule dumpio_module modules/mod_dumpio.so\u001b[25X\u001b[18;2HLoadModule echo_module modules/mod_echo.so\u001b[34X\u001b[19;2HLoadModule buffer_module modules/mod_buffer.so\r\n#LoadModule data_module modules/mod_data.so\u001b[21;2HLoadModule ratelimit_module modules/mod_ratelimit.so\r\n\u001b[96mLoadModule\u001b[m\u000f reqtimeout_module modules/mod_reqtimeout.so\u001b[14X\u001b[23;2HLoadModule ext_filter_module modules/mod_ext_filter.so\u001b[24;2HLoadModule request_module modules/mod_request.so\r\n\u001b[96mLoadModule\u001b[m\u000f include_module modules/mod_include.so\u001b[20X\r\n\u001b[96mLoadModule\u001b[m\u000f filter_module modules/mod_filter.so\u001b[26X\u001b[27;2HLoadModule reflector_module modules/mod_reflector.so\u001b[23X\u001b[28;2HLoadModule subs