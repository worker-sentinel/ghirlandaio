[0.043, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##   NOTE: If you have /usr on a separate partition, you MUST include the\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           20\r\u001b[A\u001b[?25h"]
