[0.001, "o", "    Without root rights, log files will be in ~/.local/share/xorg/ directory.\r\n\r\n"]
[0.019, "o", "    Old behavior can be restored through Xorg.wrap config file.\r\n    See Xorg.wrap man page (man xorg.wrap).\r\n"]
