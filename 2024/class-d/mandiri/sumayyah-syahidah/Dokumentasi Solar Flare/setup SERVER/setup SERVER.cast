[0.045, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Interface for separate control program. If this is specified, hostapd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;196H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8,1  \r\u001b[A\u001b[?25h"]
[0.013, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# will create this directory and a UNIX domain socket for listening to requests\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;196H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# from external programs (CLI/GUI, etc.) for status information and\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;195H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m60\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# configuration. The socket file will be named based on the \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m name, so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;196H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m1\r\u001b[A\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# multiple hostapd processes/\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27ms can be run at the same time if more\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;196H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m2\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# than one \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m is used.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;196H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[50;202H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[50;202H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# /run/hostapd is the recommended directory for sockets and by default,\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[49;196H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?25h"]
