[0.005, "o", "\u001b[?25l\u001b[1;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mthe stations that do not support parsing of the Multiple BSSID element will\u001b[2;3Hnot be able to connect to the non-transmitting \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27ms.\u001b[4;3HEnhanced Multiple BSSID Advertisements (EMA)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[27X\u001b[5;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mWhen enabled, the non-transmitting \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27ms are split into multiple\u001b[6;3HBeacon frames. The number of Beacon frames required to cover all the\u001b[7;3Hnon-transmitting profiles is called the profile periodicity.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[8;2H\u001b[19X\u001b[9;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mRefer to IEEE Std 802.11-2020 for details regarding the procedure and\u001b[10;3Hrequired MAC address assignment.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[11;2H\u001b[18X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Following configuration is per radio.\u001b[13;3H0 = Disabled (default)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[19X\u001b[14;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m1 = Multiple BSSID advertisement enabled.\u001b[15;3H2 = Enhanced multiple BSSID advertisement enabled.\u001b[16;2Hmbssid=0\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\u001b[17;2H\u001b[18X\u001b[18;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mThe transmitting \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m should be added with the '\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m' option while\u001b[19;2H the non-transmitting \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27ms should be added using the 'bss' option.\r\n# Security configuration should be added separately per \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m, if required.\r\n#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Example:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[6X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#mbssid=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[12X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m=wlan2\u001b[25;2Hctrl_\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0minterface\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m=/run/hostapd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[43X\u001b[26;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_passphrase=0123456789\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[53X\u001b[27;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mieee80211w=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[54X\u001b[28;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27msae_pwe=1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[68X\u001b[29;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mauth_algs=1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[63X\u001b[30;2H\u0