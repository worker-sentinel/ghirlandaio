[0.005, "o", "Optional dependencies for python\r\n\u001b[0;1m   \u001b[0m python-setuptools: for building Python packages using tooling that is usually bundled with Python\r\n    python-pip: for installing Python packages using tooling that is usually bundled with Python\r\n    python-pipx: for installing Python software not packaged on Arch Linux\r\n    sqlite: for a default database integration [installed]\r\n    xz: for lzma [installed]\r\n    tk: for tkinter\r\n(180/191) installing python-dbus                                                                                                                 [----------------------------------------------------------------------------------------]   0%\r"]
[0.006, "o", "(180/191) installing python-dbus                                                                                                                 [########################################################################################] 100%\r\r\n"]
[0.001, "o", "Optional dependencies for python-dbus\r\n\u001b[0;1m   \u001b[0m python-gobject: D-Bus services via PyGI [pending]\r\n"]
