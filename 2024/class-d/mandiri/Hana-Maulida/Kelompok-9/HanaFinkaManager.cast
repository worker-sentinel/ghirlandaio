[0.002, "o", "Optional dependencies for python-gobject\r\n\u001b[0;1m   \u001b[0m python-cairo: Cairo bindings\r\n(184/191) installing python-firewall                                                                                                             [----------------------------------------------------------------------------------------]   0%\r"]
