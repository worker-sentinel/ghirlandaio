[0.000, "o", "\u001b[0;34mNext Steps:\u001b[0m\r\n"]
[0.000, "o", "1. Review and customize additional settings in .env if needed\r\n"]
[0.000, "o", "2. Run: \u001b[0;32mdocker-compose up -d --build\u001b[0m\r\n"]
[0.000, "o", "3. Access your application at: \u001b[0;32mhttp://localhost:8080\u001b[0m\r\n"]
[0.000, "o", "4. Login with username: \u001b[0;32madmin\u001b[0m and your generated password\r\n\r\n"]
[0.001, "o", "\u001b[0;32mSetup complete! 🚀\u001b[0m\r\n"]
