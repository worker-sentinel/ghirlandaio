[0.006, "o", "Copied \"/usr/lib/systemd/boot/efi/systemd-bootx64.efi\" to \"/boot/EFI/systemd/systemd-bootx64.efi\".\r\r\n"]
[0.005, "o", "Copied \"/usr/lib/systemd/boot/efi/systemd-bootx64.efi\" to \"/boot/EFI/BOOT/BOOTX64.EFI\".\r\r\n"]
[0.003, "o", "Random seed file /boot/loader/random-seed successfully refreshed (32 bytes).\r\r\n\u001b[0;1;39mNot booted with EFI or running in a container, skipping EFI variable modifications.\u001b[0m\r\r\n"]
