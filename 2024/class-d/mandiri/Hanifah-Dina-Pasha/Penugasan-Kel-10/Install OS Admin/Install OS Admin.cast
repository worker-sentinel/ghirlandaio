[0.001, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.d/default.conf'\u001b[m\u000f\r\n  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/kernel/vmlinuz-linux-lts -c /etc/mkinitcpio.d/default.conf -U /boot/efi/linux/arch-linux-lts.efi\u001b[m\u000f\r\n"]
[0.018, "o", "==> ERROR: Invalid option -k -- '/boot/kernel/vmlinuz-linux-lts' must be readable\r\n"]
