[0.021, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-hardened.preset: 'default'\u001b[m\u000f\r\n\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.conf'\u001b[m\u000f\r\n"]
[0.001, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux-hardened -c /etc/mkinitcpio.conf -U /boot/EFI/Linux/arch-linux-hardened.efi\u001b[m\u000f\r\n"]
[0.015, "o", "==> ERROR: Invalid option -U -- '/boot/EFI/Linux/arch-linux-hardened.efi' must be writable\r\n"]
[0.001, "o", "\u001b[?2004h[root@blackbird /]# "]
[58.952, "o", "mkinitcpio -P"]
[1.599, "o", "\r\n\u001b[?2004l\r"]
[0.025, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-hardened.preset: 'default'\u001b[m\u000f\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.conf'\u001b[m\u000f\r\n"]
[0.000, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux-hardened -c /etc/mkinitcpio.conf -U /boot/EFI/Linux/arch-linux-hardened.efi\u001b[m\u000f\r\n"]
[0.016, "o", "==> ERROR: Invalid option -U -- '/boot/EFI/Linux/arch-linux-hardened.efi' must be writable\r\n"]
[0.002, "o", "\u001b[?2004h[root@blackbird /]# "]
[1.682, "o", "mkinitcpio -P"]
