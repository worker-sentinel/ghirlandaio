[0.003, "o", "\u001b[?25l\u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m The UDP port number for the RADIUS authentication server\r\n#radius_server_auth_port=1812\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[69X\u001b[4;7H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mUDP port number for the RADIUS accounting server\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\u001b[5;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mCommenting this out or setting this to 0 can be used to disable RADIUS\u001b[6;3Haccounting while still enabling RADIUS authentication.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[21X\u001b[7;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mradius_server_acct_port=1813\u001b[9;3HUse IPv6 with RADIUS server (IPv4 will also be supported using IPv6 API)\u001b[10;2Hradius_server_ipv6=1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[15X\n\u001b[9X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m##### WPA/IEEE 802.11i configuration ##########################################\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[20X\u001b[15;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mEnable WPA. Setting this variable configures the AP to require WPA (either\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m   \u001b[16;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mWPA-PSK or WPA-RADIUS/EAP based on other configuration). For WPA-PSK, either\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b[17;4H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mpa_psk or wpa_passphrase must be set and wpa_key_mgmt must include WPA-PSK.\u001b[18;2H Instead of wpa_psk / wpa_passphrase, wpa_psk_radius might suffice.\r\n# For WPA-RADIUS/EAP, ieee8021x must be set (but without dynamic WEP keys),\u001b[20;2H RADIUS authentication server must be configured, and WPA-EAP must be included\r\n# in wpa_key_mgmt.\u001b[22;3HThis field is a bit field that can be used to enable WPA (IEEE 802.11i/D3.0)\u001b[23;2H and/or WPA2 (full IEEE 802.11i/RSN):\r\n# bit0 = WPA\u001b[25;3Hbit1 = IEEE 802.11i/RSN (WPA2) (dot11RSNAEnabled)\u001b[26;3HNote that WPA3 is also configured with bit1 since it uses RSN just like WPA2.\u001b[27;3HIn other words, for WPA3, wpa=2 is used the configuration (and\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[14X\u001b[28;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_key_mgmt=SAE for WPA3-Personal instead of wpa_key_mgmt=WPA-PSK).\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[7X\u001b[29;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[72X\r\n\u001b[68X\u001b[31;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mExtended Key ID support for Individually Addressed frames\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[9X\u001b[32;2H\u001b[33X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Extended Key ID allows to rekey PTK keys without the impacts the \"normal\"\r\n# PTK rekeying with only a single Key ID 0 has. It can only be used when the\u001b[35;3Hdriver supports it and RSN/WPA2 is used with a CCMP/GCMP pairwise cipher.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[36;2H\u001b[71X\u001b[37;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m0 = force off, i.e., use only Key ID 0 (default)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[27X\u001b[38;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m1 = enable and use Extended Key ID support when possible\u001b[39;2H 2 = identical to 1 but start with Key ID 1 when possible\u001b[40;3Hxtended_key_id=0\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[57X\u001b[42;4H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mPA pre-shared keys for WPA-PSK. This can be either entered as a 256-bit\u001b[43;3Hsecret in hex format (64 hex digits), wpa_psk, or as an ASCII passphrase\u001b[44;3H(8..63 characters) that will be converted to PSK. This conversion uses SSID\u001b[45;3Hso the PSK changes when ASCII passphrase is used and the SSID is changed.\u001b[46;2H wpa_psk (dot11RSNAConfigPSKValue)\u001b[47;2H wpa_passphrase (dot11RSNAConfigPSKPassPhrase)\u001b[48;2Hwpa_psk=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef\u001b[49;3Hpa_passphrase=secret passphrase\u001b[51;3HOptionally, WPA PSKs can be read from a separate text file (containing list\u001b[52;4Hf (PSK,MAC address) pairs. This allows more than one PSK to be configured.\r\n# Use absolute path name to make sure that the files can be read on SIGHUP\r\n# configuration reloads.\u001b[55;2Hwpa_psk_file=/etc/hostapd/hostapd.wpa_psk\u001b(B\u001b[m\u001b[38;2;2"]
[0.012, "o", "24;226;234m\u001b[48;2;20;22;27m\u001b[34X\r\n\u001b[20X\u001b[57;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mOptionally, WPA passphrase can be received from RADIUS authentication server\u001b[58;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m809,6         53\u001b[2 q\u001b[?1002h\u001b[?1006h\u001b[29;6H\u001b[?25h"]
