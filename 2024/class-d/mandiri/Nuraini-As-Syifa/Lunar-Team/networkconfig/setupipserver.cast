[0.000, "o", "\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H"]
[0.001, "o", "\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute       \u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.001, "o", "\r\u001b[2d##### hostapd configuration file ##############################################\u001b[3;3HEmpty lines and lines starting with # are ignored\r\u001b[4d\u001b[K\u001b[5d# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\u001b[6;3Hmanagement frames with the Host AP driver); wlan0 with many nl80211 drivers\r\u001b[7d# Note: This attribute can be overridden by the values supplied with the '-i'\r\u001b[8d# command line parameter.\r\u001b[9d\u001b[30m\u001b[43minterface=wlan0\u001b[39;49m\u001b[m\u000f\u001b[K\r\u001b[10d\u001b[K\u001b[11d# In case of atheros and nl80211 driver interfaces, an additional\r\u001b[12d# configuration parameter, bridge, may be used to notify hostapd if the\u001b[13;3Hinterface is included in a bridge. This parameter is not used with Host AP\u001b[14;3Hdriver. If the bridge parameter is not set, the drivers will automatically\u001b[15;3Hfigure out the bridge interface (assuming sysfs is enabled and mounted to\u001b[K\u001b[16;3H"]
[0.000, "o", "/sys) and this parameter may not be needed.\u001b[K\u001b[17;3H\u001b[K\u001b[18dFor nl80211, this parameter can be used to request the AP interface to be\r\u001b[19d# added to the bridge automatically (brctl may refuse to do this before hostapd\r\u001b[20d# has been started to change the interface mode). If needed, the bridge\r\u001b[21d# interface is also created.\r\u001b[22d#bridge=br0\u001b[K\r\u001b[23d\u001b[K\u001b[24d# "]
[0.001, "o", "Driver interface type (hostap/wired/none/nl80211/bsd);\r\u001b[25d# default: hostap). nl80211 is used with all Linux mac80211 drivers.\r\u001b[26d# Use driver=none if building hostapd as a standalone RADIUS server that does\u001b[27;3Hnot control any wireless/wired driver.\u001b[K\u001b[28;3Hdriver=hostap\u001b[K\r\u001b[29d\u001b[K\u001b[30d# Driver interface parameters (mainly for development testing use)\r\u001b[31d# driver_params=<params>\u001b[K\u001b[33;3Hhostapd event logger configuration\u001b[34;3H\u001b[K\u001b[35dTwo output method: syslog and stdout (only usable if not forking to\u001b[K\u001b[36;3Hbackground).\u001b[K\u001b[37;3H\u001b[K\u001b[38dModule bitfield (ORed bitfield of modules that will be logged; -1 = all\u001b[K\u001b[39;3Hmodules):\u001b[K\r\u001b[40d# bit 0 (1) = IEEE 802.11\u001b[K\r\u001b[41d# bit 1 (2) = IEEE 802.1X\u001b[42;3Hbit 2 (4) = RADIUS\u001b[K\u001b[43;3Hbit 3 (8) = WPA\u001b[K\u001b[44;3Hbit 4 (16) = driver interface\u001b[K\r\u001b[45d# bit 6 (64) = MLME\u001b[K\r\u001b[9d"]
[1.501, "o", "\u001b[?25h\u001b[?0cinterface=wlan0\r"]
