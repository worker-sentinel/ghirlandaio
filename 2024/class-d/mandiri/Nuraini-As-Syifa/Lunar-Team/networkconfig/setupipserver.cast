[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# The key length should be 5, 13, or 16 characters, or 10, 26, or 32\r"]
