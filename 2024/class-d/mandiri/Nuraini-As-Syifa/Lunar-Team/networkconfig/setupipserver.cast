[0.000, "o", "\r\u001b[2d"]
[0.000, "o", "##### hostapd configuration file ##############################################\r\u001b[3d# Empty lines and lines starting with # are ignored\r\u001b[5d# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\r\u001b[6d"]
[0.001, "o", "# management frames with the Host AP driver); wlan0 with many nl80211 drivers\r\u001b[7d# Note: This attribute can be overridden by the values supplied with the '-i'\r\u001b[8d# command line parameter.\r\u001b[9dinterface=wlan0\r\u001b[11d# In case of atheros and nl80211 driver interfaces, an additional\r\u001b[12d"]
[0.000, "o", "# configuration parameter, bridge, may be used to notify hostapd if the\r\u001b[13d"]
[0.000, "o", "# interface is included in a bridge. This parameter is not used with Host AP\r\u001b[14d# driver. If the bridge parameter is not set, the drivers will automatically\r\u001b[15d# figure out the bridge interface (assuming sysfs is enabled and mounted to\r\u001b[16d# /sys) and this parameter may not be needed.\r\u001b[17d"]
[0.000, "o", "#\u001b[18d\b"]
[0.000, "o", "# For nl80211, this parameter can be used to request the AP interface to be\r\u001b[19d# added to the bridge automatically (brctl may refuse to do this before hostapd\r\u001b[20d# has been started to change the interface mode). If needed, the bridge\r\u001b[21d# interface is also created.\r\u001b[22d#bridge=br0\r\u001b[24d# Driver interface type (hostap/wired/none/nl80211/bsd);\r\u001b[25d# default: hostap). nl80211 is used with all Linux mac80211 drivers.\r\u001b[26d# Use driver=none if building hostapd as a standalone RADIUS server that does\r\u001b[27d# not control any wireless/wired driver.\r\u001b[28d# driver=hostap\r\u001b[30d# Driver interface parameters (mainly for development testing use)\r\u001b[31d# driver_params=<params>\r\u001b[33d# hostapd event logger configuration\r\u001b[34d#\u001b[35d\b# Two output method: syslog and stdout (only usable if not forking to\r\u001b[36d# background).\r\u001b[37d#\u001b[38d\b# Module bitfield (ORed bitfield of modules that will be logged; -1 = all\r\u001b[39d# modules):\r\u001b[40d# bit 0 (1) = IEEE 802.11\r\u001b[41d# bit 1 (2) = IEEE 802.1X\r\u001b[42d# bit 2 (4) = RADIUS\r\u001b[43d# bit 3 (8) = WPA\r\u001b[44d# bit 4 (16) = driver interface\r\u001b[45d# bit 6 (64) = MLME\r\u001b[2d\u001b[?25h\u001b[?0c"]
