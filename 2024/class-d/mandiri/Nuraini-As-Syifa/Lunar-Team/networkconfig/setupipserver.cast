[0.820, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Annex E, Table E-4 (Global operating classes)\r"]
[0.306, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#country3=0x04\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Enable IEEE 802.11d. This advertises the country_code and the set of allowed\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# channels and transmit power levels based on the regulatory limits. The\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# country_code setting must be configured with the correct country for\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# IEEE 802.11d functions.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# (default: 0 = disabled)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#ieee80211d=1\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Enable IEEE 802.11h. This enables radar detection and DFS support if\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# available. DFS support is required on outdoor 5 GHz channels in most countries\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# of the world. This can be used only with ieee80211d=1.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# (default: 0 = disabled)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.002, "o", "\n\u001b[1;48r\u001b[45;1H#ieee80211h=1\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Add Power Constraint element to Beacon and Probe Response frames\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This config option adds Power Constraint element when applicable and Country\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# element is added. Power Constraint element is required by Transmit Power\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Control. This can be used only with ieee80211d=1.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Valid values are 0..255.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#local_pwr_constraint=3\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Set Spectrum Management subfield in the Capability Information field.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This config option forces the Spectrum Management bit to be set. When this\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# option is not set, the value of the Spectrum Management bit depends on whether\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# DFS or TPC is required by regulatory authorities. This can be used only with\r"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# ieee80211d=1 and local_pwr_constraint configured.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#spectrum_mgmt_required=1\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Operation mode (a = IEEE 802.11a (5 GHz), b = IEEE 802.11b (2.4 GHz),\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# g = IEEE 802.11g (2.4 GHz), ad = IEEE 802.11ad (60 GHz); a/g options are used\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# with IEEE 802.11n (HT), too, to specify band). For IEEE 802.11ac (VHT), this\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# needs to be set to hw_mode=a. For IEEE 802.11ax (HE) on 6 GHz this needs\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# to be set to hw_mode=a. When using ACS (see channel parameter), a\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# special value \"any\" can be used to indicate that any support band can be used.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This special case is currently supported only with drivers with which\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# offloaded ACS is used.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Default: IEEE 802.11b\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hhw_mode=g\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Channel number (IEEE 802.11)\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# (default: 0, i.e., not set)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Please note that some drivers do not use this value from hostapd and the\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# channel will need to be configured separately with iwconfig.\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#\b"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# If CONFIG_ACS build option is enabled, the channel can be selected\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# automatically at run time by setting channel=acs_survey or channel=0, both of\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# which will enable the ACS survey based algorithm.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hchannel=1\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Global operating class (IEEE 802.11, Annex E, Table E-4)\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This option allows hostapd to specify the operating class of the channel\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# configured with the channel parameter. channel and op_class together can\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# uniquely identify channels across different bands, including the 6 GHz band.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#op_class=131\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# ACS tuning - Automatic Channel Selection\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# See: https://wireless.wiki.kernel.org/en/users/documentation/acs\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.004, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#\b"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# You can customize the ACS survey algorithm with following variables:\r"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#\b"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# acs_num_scans requirement is 1..100 - number of scans to be performed that\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# are used to trigger survey data gathering of an underlying device driver.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Scans are passive and typically take a little over 100ms (depending on the\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# driver) on each available channel for given hw_mode. Increasing this value\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# means sacrificing startup time and gathering more data wrt channel\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# interference that may help choosing a better channel. This can also help fine\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# tune the ACS scan time in case a driver has different scan dwell times.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#\b"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# acs_chan_bias is a space-separated list of <channel>:<bias> pairs. It can be\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# used to increase (or decrease) the likelihood of a specific channel to be\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# selected by the ACS algorithm. The total interference factor for each channel\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# gets multiplied by the specified bias value before finding the channel with\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# the lowest value. In other words, values between 0.0 and 1.0 can be used to\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# make a channel more likely to be picked while values larger than 1.0 make the\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# specified channel less likely to be picked. This can be used, e.g., to prefer\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# the commonly used 2.4 GHz band channels 1, 6, and 11 (which is the default\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# behavior on 2.4 GHz band if no acs_chan_bias parameter is specified).\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#\b"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Defaults:\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#acs_num_scans=5\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#acs_chan_bias=1:0.8 6:0.8 11:0.8\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Channel list restriction. This option allows hostapd to select one of the\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# provided channels when a channel should be automatically selected.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Channel list can be provided as range using hyphen ('-') or individual\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# channels can be specified by space (' ') separated values\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Default: all channels allowed in selected hw_mode\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#chanlist=100 104 108 112 116\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#chanlist=1 6 11-13\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Frequency list restriction. This option allows hostapd to select one of the\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# provided frequencies when a frequency should be automatically selected.\r"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Frequency list can be provided as range using hyphen ('-') or individual\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# frequencies can be specified by comma (',') separated values\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Default: all frequencies allowed in selected hw_mode\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#freqlist=2437,5955,5975\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#freqlist=2437,5985-6105\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Exclude DFS channels from ACS\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This option can be used to exclude all DFS channels from the ACS channel list\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# in cases where the driver supports DFS channels.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#acs_exclude_dfs=1\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.686, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Include only preferred scan channels from 6 GHz band for ACS\r"]
[0.307, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This option can be used to include only preferred scan channels in the 6 GHz\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# band. This can be useful in particular for devices that operate only a 6 GHz\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.002, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# BSS without a collocated 2.4/5 GHz BSS.\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Default behavior is to include all PSC and non-PSC channels.\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#acs_exclude_6ghz_non_psc=1\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Enable background radar feature\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This feature allows CAC to be run on dedicated radio RF chains while the\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# radio(s) are otherwise running normal AP activities on other channels.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This requires that the driver and the radio support it before feature will\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.003, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# actually be enabled, i.e., this parameter value is ignored with drivers that\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# do not advertise support for the capability.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 0: Leave disabled (default)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 1: Enable it.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#enable_background_radar=1\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Set minimum permitted max TX power (in dBm) for ACS and DFS channel selection.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# (default 0, i.e., not constraint)\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.002, "o", "#min_tx_power=20\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Beacon interval in kus (1.024 ms) (default: 100; range 15..65535)\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hbeacon_int=100\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# DTIM (delivery traffic information message) period (range 1..255):\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c"]
[0.002, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# number of beacons between DTIMs (1 = every beacon includes DTIM element)\r"]
[2.860, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# (default: 2)\r"]
[0.308, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hdtim_period=2\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Maximum number of stations allowed in station table. New stations will be\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# rejected after the station table is full. IEEE 802.11 has a limit of 2007\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# different association IDs, so this number should not be larger than that.\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# (default: 2007)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hmax_num_sta=255\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c"]
[0.002, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# RTS/CTS threshold; -1 = disabled (default); range -1..65535\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# If this field is not included in hostapd.conf, hostapd will not control\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# RTS threshold and 'iwconfig wlan# rts <val>' can be used to set it.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hrts_threshold=-1\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Fragmentation threshold; -1 = disabled (default); range -1, 256..2346\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# If this field is not included in hostapd.conf, hostapd will not control\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# fragmentation threshold and 'iwconfig wlan# frag <val>' can be used to set\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# it.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hfragm_threshold=-1\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Rate configuration\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Default is to enable all rates supported by the hardware. This configuration\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# item allows this list be filtered so that only the listed rates will be left\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# in the list. If the list is empty, all rates are used. This list can have\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# entries that are not in the list of rates the hardware supports (such entries\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# are ignored). The entries in this list are in 100 kbps, i.e., 11 Mbps = 110.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# If this item is present, at least one rate have to be matching with the rates\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# hardware supports.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# default: use the most common supported rate setting for the selected\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# hw_mode (i.e., this line can be removed from configuration file in most\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# cases)\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#supported_rates=10 20 55 110 60 90 120 180 240 360 480 540\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.003, "o", "\n\u001b[1;48r\u001b[45;1H# Basic rate set configuration\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# List of rates (in 100 kbps) that are included in the basic rate set.\r"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# If this item is not included, usually reasonable default set is used.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#basic_rates=10 20\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#basic_rates=10 20 55 110\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#basic_rates=60 120 240\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Beacon frame TX rate configuration\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This sets the TX rate that is used to transmit Beacon frames. If this item is\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# not included, the driver default rate (likely lowest rate) is used.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Legacy (CCK/OFDM rates):\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#    beacon_rate=<legacy rate in 100 kbps>\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# HT:\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#    beacon_rate=ht:<HT MCS>\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c"]
[0.003, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# VHT:\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#    beacon_rate=vht:<VHT MCS>\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# HE:\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#    beacon_rate=he:<HE MCS>\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#\b"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# For example, beacon_rate=10 for 1 Mbps or beacon_rate=60 for 6 Mbps (OFDM).\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#beacon_rate=10\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Short Preamble\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This parameter can be used to enable optional use of short preamble for\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# frames sent at 2 Mbps, 5.5 Mbps, and 11 Mbps to improve network performance.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This applies only to IEEE 802.11b-compatible networks and this should only be\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# enabled if the local hardware supports use of short preamble. If any of the\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# associated STAs do not support short preamble, use of short preamble will be\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# disabled (and enabled when such STAs disassociate) dynamically.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 0 = do not allow use of short preamble (default)\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 1 = allow use of short preamble\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#preamble=1\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Station MAC address -based authentication\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Please note that this kind of access control requires a driver that uses\r"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# hostapd to take care of management frame processing and as such, this can be\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# used with driver=hostap or driver=nl80211, but not with driver=atheros.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H# 0 = accept unless in deny list\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 1 = deny unless in accept list\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 2 = use external RADIUS server (accept/deny lists are searched first)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hmacaddr_acl=0\r"]
[0.733, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.307, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Accept/deny lists are read from separate files (containing list of\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# MAC addresses, one per line). Use absolute path name to make sure that the\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# files can be read on SIGHUP configuration reloads.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#accept_mac_file=/etc/hostapd/hostapd.accept\r"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#deny_mac_file=/etc/hostapd/hostapd.deny\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# IEEE 802.11 specifies two authentication algorithms. hostapd can be\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# configured to allow both of these or only one. Open system authentication\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# should be used with IEEE 802.1X.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Bit fields of allowed authentication algorithms:\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# bit 0 = Open System Authentication\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# bit 1 = Shared Key Authentication (requires WEP)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hauth_algs=3\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Send empty SSID in beacons and ignore probe request frames that do not\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# specify full SSID, i.e., require stations to know SSID.\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# default: disabled (0)\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 1 = send empty (length=0) SSID in beacon and ignore probe request for\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#     broadcast SSID\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# 2 = clear SSID (ASCII 0), but keep the original length (this may be required\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#     with some clients that do not support empty SSID) and ignore probe\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#     requests for broadcast SSID\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1Hignore_broadcast_ssid=0\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Do not reply to broadcast Probe Request frames from unassociated STA if there\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# is no room for additional stations (max_num_sta). This can be used to\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# discourage a STA from trying to associate with this AP if the association\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# would be rejected due to maximum STA limit.\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Default: 0 (disabled)\r"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H#no_probe_resp_if_max_sta=0\r"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# Additional vendor specific elements for Beacon and Probe Response frames\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# This parameter can be used to add additional vendor specific element(s) into\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.002, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# the end of the Beacon and Probe Response frames. The format for these\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# element(s) is a hexdump of the raw information elements (id+len+payload for\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# one or more elements)\r"]
