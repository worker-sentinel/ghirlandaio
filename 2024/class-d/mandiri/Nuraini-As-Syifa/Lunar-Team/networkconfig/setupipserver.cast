[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#ieee80211d=1"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# (default: 0 = disabled)"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# IEEE 802.11d functions."]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# country_code setting must be configured with the correct country for\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# channels and transmit power levels based on the regulatory limits. The\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Enable IEEE 802.11d. This advertises the country_code and the set of allowed\u001b[2;30H"]
