[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1Hfragm_threshold=-1"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# it."]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# fragmentation threshold and 'iwconfig wlan# frag <val>' can be used to set\u001b[2;30H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# If this field is not included in hostapd.conf, hostapd will not control\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Fragmentation threshold; -1 = disabled (default); range -1, 256..2346\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1Hrts_threshold=-1"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# RTS threshold and 'iwconfig wlan# rts <val>' can be used to set it.\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# If this field is not included in hostapd.conf, hostapd will not control\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# RTS/CTS threshold; -1 = disabled (default); range -1..65535\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1Hmax_num_sta=255"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# (default: 2007)"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# different association IDs, so this number should not be larger than that.\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# rejected after the station table is full. IEEE 802.11 has a limit of 2007\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Maximum number of stations allowed in station table. New stations will be\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1Hdtim_period=2"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# (default: 2)"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# number of beacons between DTIMs (1 = every beacon includes DTIM element)\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# DTIM (delivery traffic information message) period (range 1..255):\u001b[2;30H"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1Hbeacon_int=100"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Beacon interval in kus (1.024 ms) (default: 100; range 15..65535)\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#min_tx_power=20"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# (default 0, i.e., not constraint)\u001b[30G"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Set minimum permitted max TX power (in dBm) for ACS and DFS channel selection.\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#enable_background_radar=1"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# 1: Enable it."]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# 0: Leave disabled (default)"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# do not advertise support for the capability.\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# actually be enabled, i.e., this parameter value is ignored with drivers that\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# This requires that the driver and the radio support it before feature will\u001b[2;30H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# radio(s) are otherwise running normal AP activities on other channels.\u001b[2;30H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# This feature allows CAC to be run on dedicated radio RF chains while the\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Enable background radar feature\b\b\b\b"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#acs_exclude_6ghz_non_psc=1"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Default behavior is to include all PSC and non-PSC channels.\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# BSS without a collocated 2.4/5 GHz BSS.\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# band. This can be useful in particular for devices that operate only a 6 GHz\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# This option can be used to include only preferred scan channels in the 6 GHz\u001b[2;30H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Include only preferred scan channels from 6 GHz band for ACS\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#acs_exclude_dfs=1"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# in cases where the driver supports DFS channels.\u001b[2;30H"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# This option can be used to exclude all DFS channels from the ACS channel list\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Exclude DFS channels from ACS\b\b"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#freqlist=2437,5985-6105"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H#freqlist=2437,5955,5975"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Default: all frequencies allowed in selected hw_mode\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# frequencies can be specified by comma (',') separated values\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Frequency list can be provided as range using hyphen ('-') or individual\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# provided frequencies when a frequency should be automatically selected.\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Frequency list restriction. This option allows hostapd to select one of the\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#chanlist=1 6 11-13"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H#chanlist=100 104 108 112 116"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Default: all channels allowed in selected hw_mode\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# channels can be specified by space (' ') separated values\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Channel list can be provided as range using hyphen ('-') or individual\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# provided channels when a channel should be automatically selected.\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Channel list restriction. This option allows hostapd to select one of the\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#acs_chan_bias=1:0.8 6:0.8 11:0.8\b\b\b\b"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H#acs_num_scans=5"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Defaults:"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H#"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H# behavior on 2.4 GHz band if no acs_chan_bias parameter is specified).\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# the commonly used 2.4 GHz band channels 1, 6, and 11 (which is the default\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# specified channel less likely to be picked. This can be used, e.g., to prefer\u001b[2;30H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# make a channel more likely to be picked while values larger than 1.0 make the\u001b[2;30H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# the lowest value. In other words, values between 0.0 and 1.0 can be used to\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# gets multiplied by the specified bias value before finding the channel with\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# selected by the ACS algorithm. The total interference factor for each channel\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# used to increase (or decrease) the likelihood of a specific channel to be\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# acs_chan_bias is a space-separated list of <channel>:<bias> pairs. It can be\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H#"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H# tune the ACS scan time in case a driver has different scan dwell times.\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# interference that may help choosing a better channel. This can also help fine\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r"]
[0.002, "o", "\u001bM\u001b[1;48r\u001b[2;1H# means sacrificing startup time and gathering more data wrt channel\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# driver) on each available channel for given hw_mode. Increasing this value\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Scans are passive and typically take a little over 100ms (depending on the\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# are used to trigger survey data gathering of an underlying device driver.\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# acs_num_scans requirement is 1..100 - number of scans to be performed that\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H#"]
