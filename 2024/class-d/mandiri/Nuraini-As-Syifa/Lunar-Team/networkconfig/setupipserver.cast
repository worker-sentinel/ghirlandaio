[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# (dot11CountryString)"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# These two octets are used as the first two octets of the Country String\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# This can limit available channels and transmit power.\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Set as needed to indicate country in which device is operating.\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Country code (ISO/IEC 3166-1). Used to set regulatory domain.\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#utf8_ssid=1"]
[0.038, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# UTF-8 SSID: Whether the SSID is to be interpreted using UTF-8 encoding\u001b[2;30H"]
