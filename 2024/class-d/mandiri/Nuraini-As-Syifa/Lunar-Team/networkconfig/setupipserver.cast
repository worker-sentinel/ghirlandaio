[0.951, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute       \u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d# VHT:\u001b[K\u001b[3;3H   beacon_rate=vht:<VHT MCS>\u001b[K\r\u001b[4d# HE:\u001b[5;3H   beacon_rate=he:<HE MCS>\u001b[K\u001b[6;3H\u001b[K\u001b[7dFor example, beacon_rate=10 for 1 Mbps or beacon_rate=60 for 6 Mbps (OFDM).\r\u001b[8d#beacon_rate=10\u001b[K\r\u001b[9d\u001b[K\u001b[10d# Short Preamble\u001b[11;3HThis parameter can be used to enable optional use of short preamble for\u001b[12;3Hframes sent at 2 Mbps, 5.5 Mbps, and 11 Mbps to improve network performance.\u001b[13;3HThis applies only to IEEE 802.11b-compatible networks and this should only be\u001b[14;3Henabled i\u001b[18Glocal hardware supports use of short preamble. If any of the\u001b[15;3Hassociated STAs do not support short preamble, use of short preamble will be\u001b[16;3Hdisabled (and enabled when such STAs disassociate) dynamically.\u001b[17;3H0 = do not allow use of short preamble (default)\u001b[18;3H1 = allow use of short preamble\u001b[K\r\u001b[19d#preamble=1\u001b[K\r\u001b[20d\u001b[K\u001b[21d# Station MAC address -based authentication\r\u001b[22d# Please note that this kind of access control requires a driver that uses\r\u001b[23d# hostapd to take care of management frame processing and as such, this can be\u001b[24;3Hused with driver=hostap or \u001b[30m\u001b[43mdriver=nl80211\u001b[39;49m\u001b[m\u000f, but not with driver=atheros.\u001b[25;3H0 = accept unless in deny list\u001b[K\u001b[26;3H1 = deny unless in accept list\u001b[K\u001b[27;3H2 = use external RADIUS server (accept/deny lists are searched first)\r\u001b[28dmacaddr_acl=0\u001b[K\u001b[30;3HAccept/deny lists are read from separate files (containing list of\u001b[31;3HMAC addresses, one per line). Use absolute path name to make sure that the\r\u001b[32d# files can be read on SIGHUP configuration reloads.\r\u001b[33d#accept_mac_file=/etc/hostapd/hostapd.accept\r\u001b[34d#deny_mac_file=/etc/hostapd/hostapd.deny\r\u001b[35d\u001b[K\u001b[36d# IEEE 802.11 specifies two authentication algorithms. hostapd can be\u001b[37;3Hconfigured to allow both of these or only one. Open system authentication\u001b[38;3Hshould be used with IEEE 802.1X.\u001b[K\u001b[39;3HBit fields of allowed authentication algorithms:\u001b[40;9H= Open System Authentication\u001b[41;9H= Shared Key Authentication (requires WEP)\r\u001b[42dauth_algs=3\u001b[K\r\u001b[43d\u001b[K\u001b[44d# Send empty SSID in beacons and ignore probe request frames that do not\u001b[45;3Hspecify full SSID, i.e., require stations to know SSID.\u001b[24;30H"]
[1.502, "o", "\u001b[?25h\u001b[?0cdriver=nl80211\u001b[24;74H"]
