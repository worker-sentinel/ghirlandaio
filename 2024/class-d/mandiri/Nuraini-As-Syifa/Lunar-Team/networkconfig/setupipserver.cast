[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Control. This can be used only with ieee80211d=1.\u001b[2;30H"]
