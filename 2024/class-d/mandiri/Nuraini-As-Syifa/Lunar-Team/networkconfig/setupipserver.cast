[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# to be set to hw_mode=a. When using ACS (see channel parameter), a\u001b[2;30H"]
