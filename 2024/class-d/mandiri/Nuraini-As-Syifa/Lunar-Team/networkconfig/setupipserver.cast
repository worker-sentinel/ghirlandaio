[0.000, "o", "# If this item is present, at least one rate have to be matching with the rates\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# are ignored). The entries in this list are in 100 kbps, i.e., 11 Mbps = 110.\u001b[2;30H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# entries that are not in the list of rates the hardware supports (such entries\u001b[2;30H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# in the list. If the list is empty, all rates are used. This list can have\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# item allows this list be filtered so that only the listed rates will be left\u001b[2;30H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H# Default is to enable all rates supported by the hardware. This configuration\u001b[2;30H"]
[0.037, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
