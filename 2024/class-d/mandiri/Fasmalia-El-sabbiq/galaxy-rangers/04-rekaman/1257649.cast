[0.287, "o", "\u001b[?25l\u001b[1;57r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[55;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# provide additional information corresponding to Venue Name information.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Each entry has a Venue Number value separated by colon from the Venue URL\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# string. Venue Number indicates the corresponding venue_name entry (1 = 1st\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[58;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m800,1  \u001b[H\u001b[?25h"]
