[0.005, "o", "\u001b[1;1H\u001b[1m\u001b[36m# /dev/mapper/proc-root\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m87fc217c-bf41-4ce2-be10-822e528b4d33\u001b[m\u000f       /               \u001b[1m\u001b[32mext4\u001b[m\u000f            \u001b[1m\u001b[32mrw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f     \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m1\u001b[m\u000f\u001b[2;100H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[1m\u001b[36m# /dev/nvme0n1p5 LABEL=BOOT\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m2740-B2E0\u001b[m\u000f\u001b[10C/boot\u001b[11C\u001b[1m\u001b[32mvfat\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[1m\u001b[33m,fmask=\u001b[m\u000f\u001b[1m\u001b[35m0077\u001b[m\u000f\u001b[1m\u001b[33m,dmask=\u001b[m\u000f\u001b[1m\u001b[35m0077\u001b[m\u000f\u001b[1m\u001b[33m,codepage=\u001b[m\u000f\u001b[1m\u001b[35m437\u001b[m\u000f\u001b[1m\u001b[33m,iocharset=\u001b[m\u000f\u001b[1m\u001b[35mascii\u001b[m\u000f\u001b[1m\u001b[33m,shortname=\u001b[m\u000f\u001b[1m\u001b[35mmixed\u001b[m\u000f\u001b[1m\u001b[33m,utf8,errors=\u001b[m\u000f\u001b[1m\u001b[35mremount-ro\u001b[m\u000f   \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vars\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35mf80c8343-4a9f-47b8-a6c1-20eb714fb9ba\u001b[m\u000f\u001b[7C/var\u001b[12C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vtmp\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35mc4fd6fa5-9707-4add-8992-af825497ef9f\u001b[m\u000f\u001b[7C/var/tmp\u001b[8C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vlog\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m3c2b98f8-b271-4626-9cc7-e92e9a230646\u001b[m\u000f\u001b[7C/var/log\u001b[8C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vaud\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35mc9b2177d-242f-4f1a-a18e-5bc1cfd801e1\u001b[m\u000f\u001b[7C/var/log/audit  \u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-dock\u001b[m\u000f\r\n\