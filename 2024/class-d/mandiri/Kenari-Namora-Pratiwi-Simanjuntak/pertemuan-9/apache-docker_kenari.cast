[0.030, "o", "\u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule macro_module modules/mod_macro.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[26X\u001b[2;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule dbd_module modules/mod_dbd.so\u001b[3;2HLoadModule dumpio_module modules/mod_dumpio.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[13X\u001b[4;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule echo_module modules/mod_echo.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[8X\u001b[5;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule buffer_module modules/mod_buffer.so\u001b[6;2HLoadModule data_module modules/mod_data.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[24X\u001b[7;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule ratelimit_module modules/mod_ratelimit.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[23X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m reqtimeout_module modules/mod_reqtimeout.so\u001b[9;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule ext_filter_module modules/mod_ext_filter.so\u001b[10;2HLoadModule request_module modules/mod_request.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[23X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m include_module modules/mod_include.so\u001b[28X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m filter_module modules/mod_filter.so\u001b[24X\u001b[13;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLoadModule reflector_module modules/mod_reflector.so\u001b(B\u