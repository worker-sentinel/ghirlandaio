[0.039, "o", "\u001b[1;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mother reason.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[16X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[47X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Mutex default:/run/httpd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[26X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[38X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[7;3Hports, instead of the default. See also the <VirtualHost>\r\n# directive.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[27X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b[10;3HChange this to Listen on specific IP addresses as shown below to \r\n# prevent Apache from glomming onto all bound IP addresses.\r\n#\nListen 12.34.56.78:80\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[24X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mListen\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m 80\u001b[26X\u001b[16;2H\u001b[14X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Dynamic Shared Object (DSO) Support\r\n#\u001b[19;3HTo be able to use the functionality of a module which was built as a DSO you\u001b[20;2H have to place corresponding `\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mLo\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27madModule' lines at this location so the\r\n# directives contained in it are actually available _before_ they are used.\u001b[22;3HStatically compiled modules (those listed by `httpd -l') do not need\u001b[23;2H to be loaded here.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[14X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b[25;3HExample:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[16X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLo\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27madModule foo_module modules/mod_foo.so\r\n#\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLo\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27madModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m mpm_event_module modules/mod_mpm_event.so \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2"]
