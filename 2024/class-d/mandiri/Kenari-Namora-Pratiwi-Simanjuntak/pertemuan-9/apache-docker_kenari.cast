lias_module modules/mod_vhost_alias.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m negotiation_module modules/mod_negotiation.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m dir_module modules/mod_dir.so \u001b[14;13H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mimagemap_module modules/mod_imagemap.so\u001b[15;13Hactions_module modules/mod_actions.so\u001b[16;13Hspeling_module modules/mod_speling.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m userdir_module modules/mod_userdir.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m alias_module modules/mod_alias.so\u001b[9X\u001b[19;14H\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mw\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mrite_module modules/mod_rewrite.so\u001b[6X\r\n\u001b[55X\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m unixd_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[26X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[47X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# If you wish httpd to run as a different user or group, you must run\u001b[24;2H httpd as root initially and it will switch.  \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[6X\u001b[25;2H\u001b[54X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m User/Group: The name (or #number) of the user/group to run httpd as.\u001b[27;2H It is usually good practice to create a dedicated user and group for\u001b[28;2H running httpd, as with most system services.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m   \u001b[29;2H\u001b[48X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mUser\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m http\u001b[46X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mGroup\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m http\u001b[37X\r\n\u001b[42X\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</IfModule>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[32X\r\n\u001b[54X\u001b[35;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m 'Main' server configuration\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[24X\u001b[36;2H\u001b[58X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m The directives in this section set up the values used by the 'main'\u001b[38;2H server, which responds to any requests that aren't handled by a\u001b[39;118H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m89,1          33\u001b[40;16H\u001b[?25h"]
