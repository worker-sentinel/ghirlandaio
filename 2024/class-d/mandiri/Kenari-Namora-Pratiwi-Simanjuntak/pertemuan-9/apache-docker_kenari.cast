[0.041, "o", "\u001b[1;38r\u001b[H\u001b[5M\u001b[r\u001b[3;34H\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mv\u001b[6;13Hv\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mer's control files begin with \"/\" (or \"dri\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mv\u001b[7;6Hv\u001b[8;17Hv\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27malue of Ser\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mv\u001b[9;11Hv\u001b[10;6Hv\u001b[14;6Hv\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27merRoot: The top of the directory tree under which the ser\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mv\u001b[18;6Hv\u001b[19;16Hv\u001b[20;11Hv\u001b[23;4Hv\u001b[27;11Hv\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\u001b[7B\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Listen: Allows you to bind Apache to specific IP addresses and/or\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# ports, instead of the default. See also the <VirtualHost>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# directi\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mv\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27me.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[39;117H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m46,10           1\u001b[40;3H\u001b[?25h"]
