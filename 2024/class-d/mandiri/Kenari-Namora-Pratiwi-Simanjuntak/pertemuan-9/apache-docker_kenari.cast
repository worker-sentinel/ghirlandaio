[0.038, "o", "\u001b[H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#LoadModule asis_module modules/mod_asis.so\r\n#LoadModule info_module modules/mod_info.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[8X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#LoadModule suexec_module modules/mod_suexec.so\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m !mpm_prefork_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m        #LoadModule cgid_module modules/mod_cgid.so\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</IfModule>\r\n<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m mpm_prefork_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[43X\u001b[8;5H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #LoadModule cgi_module modules/mod_cgi.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[22X\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</IfModule>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[56X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#LoadModule dav_fs_module modules/mod_dav_fs.so\r\n#LoadModule dav_lock_module modules/mod_dav_lock.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[5X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#LoadModule vhost_alias_module modules/mod_vhost_alias.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m negotiation_module modules/mod_negotiation.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m dir_module modules/mod_dir.so\u001b[24X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#LoadModule imagemap_module modules/mod_imagemap.so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[12X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#LoadModule actions_module modules/mod_actions.so\r\n#LoadModule speling_module modules/mod_speling.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m userdir_module modules/mod_userdir.so\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m alias_module modules/mod_alias.so\u001b[22X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLoadModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m rewrite_module modules/mod_rewrite.so\u001b[16X\r\n\u001b[62X\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m unixd_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m   \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\r\n# If you wish httpd to run as a different user or group, you must run\r\n# httpd as root initially and it will switch.  \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[28X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[67X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# User/Group: The name (or #number) of the user/group to run httpd as.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# It is usually good practice to create a dedicated user and group for\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[5X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# running httpd, as with most system services.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[23X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[28X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mUser\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m http\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mGroup\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m http\u001b[36X\r\n\n\n\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# 'Main' server configuration\r\n#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m    \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The directives in this section set up the values used by the 'main'\u001b[39;117H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m189,1          33\u001b[40;11H\u001b[?25h"]
