[0.032, "o", "\u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m ports, instead of the default. See also the <VirtualHost>\u001b[2;2H directive.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[29X\u001b[3;2H\u001b[46X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Change this to Listen on specific IP addresses as shown below to \u001b[5;2H prevent Apache from glomming onto all bound IP addresses.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[6;2H\u001b[42X\u001b[7;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27misten 12.34.56.78:80\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[31X\u001b[8;2H\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27misten\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m 80\u001b[45X\r\n\u001b[55X\u001b[10;2H\u001b[48X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Dynamic Shared Object (DSO) Support\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[11X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[45X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m To be able to use the functionality of a module which was built as a DSO you\u001b[14;2H have to place corresponding `LoadModule' lines at this location so the\u001b[15;2H directives contained in it are actually available _before_ they are used.\u001b[16;2H Statically compiled modules (those listed by `httpd -l') do not need\u001b[17;2H to be loaded here.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[29X\u001b[18;2H\u001b[48X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Example:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[45X\u001b[20;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mLoadModule \