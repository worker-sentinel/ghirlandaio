[0.028, "o", "\u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m The following lines prevent .htaccess and .htpasswd files from being \u001b[2;2H viewed by Web clients. \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[18X\u001b[3;2H\u001b[46X\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mFiles\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \".ht*\"\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[16X\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mRequire\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mall\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m denied\u001b[29X\u001b[6;3H\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mFiles>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m   \r\n\u001b[29X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[48X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# ErrorLog: The location of the error log file.\u001b[10;2H If you do not specify an ErrorLog directive within a <VirtualHost>\u001b[11;2H container, error messages relating to that virtual host will be\u001b[12;2H logged here.  If you *do* define an error logfile for a <VirtualHost>\r\n# container, that host's errors will be logged there and not here.\r\n#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[39X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mErrorLog\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/var/log/httpd/error_log\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[16X\r\n\u001b[49X\u001b[17;2H\u001b[48X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# LogLevel: Control the number of messages logged to the error_log.\r\n# Possible values \u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148minc\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mlude: debug, info, notice, warn, error, crit,\r\n# alert, emerg.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[33X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogLevel\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mwarn\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[10X\r\n \r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m log_config_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[41X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[42X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # The following directives define some format nicknames for use with\r\n    # a CustomLog directive (see below).\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[30X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[65X\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogFormat\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m combined\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogFormat\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"%h %l %u %t \\\"%r\\\" %>s %b\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m common\r\n\u001b[9X\n    \u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m logio_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m      # You need to enable mod_logio.c to use %I and %O\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m      \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogFormat\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m combinedio\u001b[35;5H\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</IfModule>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[29X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\r\n    # The location and format of the access logfile (Common Logfile Format).\u001b[39;117H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m311,19         57\u001b[40;5H\u001b[?25h"]
