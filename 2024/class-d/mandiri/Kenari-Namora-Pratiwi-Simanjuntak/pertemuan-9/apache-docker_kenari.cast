ns\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# use only name-based virtual hosts so the server doesn't need to worry about\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# IP addresses. This is indicated by the asterisks in the directives below.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Please see the documentation at \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# for further details before you try to setup virtual hosts.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# You may use the command line option '-S' to verify your virtual host\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# configuration.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m"]
[0.000, "o", "\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# VirtualHost example:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Almost any Apache directive may go into a VirtualHost container.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The first VirtualHost section is used for all requests that do not\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# match a ServerName or ServerAlias in any <VirtualHost> block.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<VirtualHost\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m *:80\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mServerAdmin\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m webmaster@dummy-host.\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mexample\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m.com\u001b[K\r\n    DoccumentRoot \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/etc/httpd/docs/dumy-host.example.com\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mServerName\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m dummy-host.\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mexample\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m.com\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mServerAlias\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m www.dummy-host.\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mexample\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m.com\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mErrorLog\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/var/log/httpd/dummy-host.example.com-error_log\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mCustomLog\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/var/log/httpd/dummy-host.example.com-access_log\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m common\u001b[K\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</VirtualHost>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<VirtualHost\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m *:80\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mServerAdmin\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m webmaster@dummy-host2.\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mexample\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m.com\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mDocumentRoot\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/etc/httpd/d