[0.026, "o", "\u001b[H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The following lines prevent .htaccess and .htpasswd files from being \r\n# viewed by Web clients. \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[26X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[10X\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<Files\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \".ht*\"\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mRequire\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mall\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m denied \r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</Files>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[72X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[70X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# ErrorLog: The location of the error log file.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# If you do not specify an ErrorLog directive within a <VirtualHost>\r\n# container, error messages relating to that virtual host will be\r\n# logged here.  If you *do* define an error logfile for a <VirtualHost>\r\n# container, that host's errors will be logged there and not here.\r\n#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[63X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mErrorLog\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/var/log/httpd/error_log\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[28X\r\n\u001b[14X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[41X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# LogLevel: Control the number of messages logged to the error_log.\r\n# Possible values \u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148minclude\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m: debug, info, notice, warn, error, crit,\r\n# alert, emerg.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[49X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[61X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogLevel\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mwarn\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[13X\r\n\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m log_config_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[25;6H\u001b[70X\u001b[26;7H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mThe following directives define some format nicknames for use with\u001b[27;7Ha CustomLog directive (see below).\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[31X\u001b[28;6H\u001b[70X\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogFormat\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m combined\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogFormat\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"%h %l %u %t \\\"%r\\\" %>s %b\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m common\r\n\u001b[5X\u001b[32;5H\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m logio_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[19X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m      # You need to enable mod_logio.c to use %I and %O\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m      \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mLogFormat\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m combinedio\u001b[35;5H\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</IfModule>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[22X\u001b[38;7H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mThe location and format of the access logfile (Common Logfile Format).\u001b[39;118H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m11,19         5\u001b[40;9H\u001b[?25h"]
