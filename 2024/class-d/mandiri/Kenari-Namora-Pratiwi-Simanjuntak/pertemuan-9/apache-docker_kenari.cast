[0.023, "o", "\u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Server-pool management (MPM specific)\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-mpm.conf\u001b[34X\r\n\u001b[76X\u001b[4;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mMulti-language error messages\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[19X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-multilang-errordoc.conf\r\n\u001b[72X\u001b[7;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mFancy directory listings\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[50X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-autoindex.conf\u001b[31X\r\n\u001b[72X\u001b[10;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLanguage settings\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[53X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-languages.conf\u001b[38X\r\n\u001b[44X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# User home directories\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-userdir.conf\r\n\u001b[68X\u001b[16;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mReal-time info on requests and configuration\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b[17;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mInclude conf/extra/httpd-info.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[68X\u001b[19;3H\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mVirtual \u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mhosts\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[57X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-vhosts.conf\u001b[40X\r\n\u001b[72X\u001b[22;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mLocal access to the Apache HTTP Server Manual\u001b[23;2HInclude conf/extra/httpd-manual.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[23X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Distributed authoring and versioning (WebDAV)\u001b[26;2HInclude conf/extra/httpd-dav.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[71X\u001b[28;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mVarious default settings\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[29X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/httpd-default.conf\r\n\u001b[78X\u001b[31;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mConfigure mod_proxy_html to understand HTML4/XHTML1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[23X\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<IfModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m proxy_html_module\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mInclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m conf/extra/proxy-html.conf\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</IfModule>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[15X\u001b[36;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Secure (SSL/TLS) connections\u001b[37;2HInclude conf/extra/httpd-ssl.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[33X\u001b[38;2H\u001b[58X\u001b[39;117H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m513,3          98\u001b[40;10H\u001b[?25h"]
