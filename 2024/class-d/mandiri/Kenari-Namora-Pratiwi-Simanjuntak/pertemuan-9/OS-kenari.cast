[0.005, "o", "\u001b[1;5H\u001b[30m\u001b[103mn\u001b[m\u000ffiguratio\u001b[30m\u001b[103mn\u001b[m\u000f file for locale-ge\u001b[30m\u001b[103mn\u001b[3;37Hn\u001b[m\u000ferated by the locale-ge\u001b[30m\u001b[103mn\u001b[m\u000f comma\u001b[30m\u001b[103mn\u001b[5;10Hn\u001b[9;23Hn\u001b[m\u000fe of the locales give\u001b[30m\u001b[103mn\u001b[m\u000f i\u001b[30m\u001b[103mn\u001b[m\u000f /usr/share/i18\u001b[30m\u001b[103mn\u001b[10;5Hn\u001b[m\u000fd <charset> is o\u001b[30m\u001b[103mn\u001b[m\u000fe of the character sets listed i\u001b[30m\u001b[103mn\u001b[m\u000f /usr/share/i18\u001b[30m\u001b[103mn\u001b[12;17Hn\u001b[m\u000f comma\u001b[30m\u001b[103mn\u001b[m\u000fd will ge\u001b[30m\u001b[103mn\u001b[13;9Hn\u001b[m\u000fg them i\u001b[30m\u001b[103mn\u001b[15;39Hn\u001b[m\u000f i\u001b[30m\u001b[103mn\u001b[m\u000f /usr/share/i18\u001b[30m\u001b[103mn\u001b[16;5Hn\u001b[m\u000fd is i\u001b[30m\u001b[103mn\u001b[m\u000fcluded i\u001b[30m\u001b[103mn\u001b[m\u000f this file. U\u001b[30m\u001b[103mn\u001b[m\u000fcomme\u001b[30m\u001b[103mn\u001b[m\u000ft the \u001b[30m\u001b[103mn\u001b[27;3Hn\u001b[28;3Hn\u001b[29;3Hn\u001b[47;155H\u001b[0;10;7m\u000f5\u001b[48;3H\u001b[?25h"]
[1.994, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[1;5Hnfiguration file for locale-gen\u001b[3;37Hnerated by the locale-gen comman\u001b[5;10Hn\u001b[9;23Hne of the locales given in /usr/share/i18n\u001b[10;5Hnd <charset> is one of the character sets listed in /usr/share/i18n\u001b[12;17Hn command will gen\u001b[13;9Hng them in\u001b[15;39Hn in /usr/share/i18n\u001b[16;5Hnd is included in this file. Uncomment the n\u001b[27;3Hn\u001b[28;3Hn\u001b[29;3Hn\u001b[47;155H\u001b[0;10;7m\u000f1\u001b[48;2H\u001b[?25h"]
