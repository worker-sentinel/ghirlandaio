[0.011, "o", "\u001b[3;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mMaxRanges: Maximum number of Ranges in a request before\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[10X\u001b[4;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mreturning the entire resource, or one of the special\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[9X\u001b[5;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mvalues 'default', 'none' or 'unlimited'.\u001b[6;2H Default setting is to accept 200 Ranges.\r\n#MaxRanges unlimited\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[8;5H\u001b[18X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[21X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# EnableMMAP and EnableSendfile: On systems that support it, \r\n# memory-mapping or the sendfile syscall may be used to deliver\u001b[12;2H files.  This usually improves server performance, but must\u001b[13;3Hbe turned off when serving from networked-mounted \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[11X\u001b[14;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mfilesystems or if support for these functions is otherwise\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[10X\u001b[15;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbroken on your system.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[43X\u001b[16;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mDefaults: EnableMMAP On, EnableSendfile Off\r\n\n#EnableMMAP off\u001b[19;2HEnableSendfile on\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[62X\u001b[21;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mSupplemental configuration\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[44X\u001b[22;2H\u001b[68X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m The configuration files in the conf/extra/ directory can be \r\n# included to add extra features or to modify the default configuration of \r\n# the server, or you may simply copy their contents here and change as \r\n# necessary.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[66X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Server-pool management (MPM specific)\r\n\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-mpm.conf\u001b[46X\r\n\u001b[5X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Multi-language error messages\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[42X\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-multilang-errordoc.conf\r\n\u001b[5X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Fancy directory listings\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[48X\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-autoindex.conf\u001b[21X\r\n\u001b[27X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Language settings\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-languages.conf\r\n\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# User home directories\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mconf/extra/httpd-userdir.conf\u001b[41X\r\n\u001b[66X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Real-time info on requests and configuration\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mconf/extra/httpd-info.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[45;5H\u001b[18X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Virtual hosts\r\n#\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mconf/extra/httpd-vhosts.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[50X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Local access to the Apache HTTP Server Manual\r\n#\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mconf/extra/httpd-manual.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[12X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Distributed authoring and versioning (WebDAV)\u001b[53;2H\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mInclude \u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mconf/extra/httpd-dav.conf\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[69X\u001b[55;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mVarious default settings\r\n\u001b(B\u001b[m\u001b[38;2;"]
