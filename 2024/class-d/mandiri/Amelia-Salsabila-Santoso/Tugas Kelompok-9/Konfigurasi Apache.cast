[0.016, "o", "\u001b[1;2H\u001b[51X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mServerRoot\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/etc/httpd\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[37X\r\n\u001b[24X\u001b[4;2H\u001b[44X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Mutex: Allows you to set the mutex mechanism and mutex file directory\u001b[6;2H for individual mutexes, or change the global defaults\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[7;2H\u001b[17X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Uncomment and change the directory if mutexes are file-based and the default\u001b[9;3Hmutex file directory is not on a local disk or is not appropriate for some\u001b[10;2H other reason.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[11;2H\u001b[61X\u001b[12;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mMutex default:/run/httpd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[49X\r\n\u001b[71X\u001b[14;2H\u001b[11X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[16;3Hports, instead of the default. See also the <VirtualHost>\r\n# directive.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[21X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b[19;3HChange this to Listen on specific IP addresses as shown below to \r\n# prevent Apache from glomming onto all bound IP addresses.\r\n#\nListen 12.34.56.78:80\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m    \r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mListen\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m 80\u001b[30X\u001b[25;2H\u001b[18X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Dynamic Shared Object (DSO) Support\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m  \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b[28;3HTo be able to use the functionality of a module which was built as a DSO you\r\n# have to place corresponding `\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mLoa\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mdModule' lines at this location so the\r\n# directives contained in it are actually available _before_ they are used.\u001b[31;3HStatically compiled modules (those listed by `httpd -l') do not need\u001b[32;2H to be loaded here.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[15X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b[34;3HExample:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[5X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# \u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLoa\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mdModule foo_module modules/mod_foo.so\r\n#\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLoa\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mdModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m mpm_event_module modules/mod_mpm_event.so\u001b[38;2H\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLoa\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mdModule mpm_prefork_module modules/mod_mpm_prefork.so\r\n#\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLoa\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mdModule mpm_worker_module modules/mod_mpm_worker.so\r\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mLoa\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mdModule\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m authn_file_module modules/mod_authn_file.so\u001b[41;2H\u001b(B\u001b[m\u001b[38;2;238;241;248m\u0