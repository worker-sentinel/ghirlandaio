[0.001, "o", "    1  echo asustama > /etc/hostname\r\n    2  In -sf /usr/share/zoneinfo/Asia/Jakarta /etc/localtime\r\n    3  ln -sf /usr/share/zoneinfo/Asia/Jakarta /etc/localtime\r\n    4  hwclock --systhoc\r\n    5  hwclock --systohc\r\n    6  nvim /etc/locale.gen\r\n    7  locale-gen\r\n    8  locale > /etc/locale.conf\r\n    9  nvim /etc/locale.conf\r\n   10  useradd -m tama\r\n   11  passwd tama\r\n   12  echo \"tama ALL=(ALL:ALL) ALL\" > /etc/sudoers.d/none\r\n   13  su tama\r\n   14  mkdir -p /etc/cmdline.d\r\n   15  touch /etc/cmdline.d/(01-boot.conf,02-misc.conf)\r\n   16  touch /etc/cmdline.d/{01-boot.conf,02-misc.conf}\r\n   17  echo \"rd.luks.name=$(blkid -s UUID -o value /dev/sda8)=vit root=/dev/tama/root\" > /etc/cmdline.d/01-boot.conf\r\n   18  cat /etc/cmdline.d/01-boot.conf\r\n   19  lsblk -o name,size,UUId\r\n   20  echo rw > /etc/cmdline.d/02-misc.conf \r\n   21  cd /boot\r\n   22  ls\r\n   23  mkdir -p /boot/efi /boot/efi/linux /boot/efi/systemd /boot/efi/boot /boot/kernel\r\n   24  ls\r\n   25  pacman -Rns amd-ucode\r\n   26  ls\r\n   27  pacman -S intel-ucode\r\n   28  ls /boot\r\n   29  mkinitcpio -p linux-hardened\r\n   30  ls\r\n   31  ls efi\r\n   32  mv intel-ucode.img vmlinuz-linux-hardened kernel\r\n   33  ls\r\n   34  ls kernel\r\n   35  mv /etc/mkinitcpio.conf /etc/mkinitcpio.d/dafault.conf\r\n   36  nvim /etc/mkinitcpio.d/default.conf\r\n   37  history\r\n"]
[0.016, "o", "\u001b[?2004h[root@blackbird boot]# "]
