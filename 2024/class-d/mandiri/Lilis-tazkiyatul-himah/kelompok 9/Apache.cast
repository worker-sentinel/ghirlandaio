[0.017, "o", "\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[6M\u001b[1;48r\u001b[40;32HLoadModule\r\n# directives contained in it are actually available _before_ they are used.\u001b[K\r\n# Statically compiled modules (those listed by `httpd -l') do not need\u001b[K\r\n# to be loaded here.\u001b[K\r\n#\u001b[K\r\n# Example:\u001b[K\r\n# \u001b[30m\u001b[103mLoadModule \u001b[m\u000ffoo_module modules/mod_foo.so\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f64,3            3\u001b[48;13H\u001b[?25h"]
