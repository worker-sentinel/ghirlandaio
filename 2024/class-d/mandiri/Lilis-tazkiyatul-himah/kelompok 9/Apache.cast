[0.019, "o", "\u001b[1;2H <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\u001b[2;2H for a discussion of each configuration directive.\u001b[3;2H\u001b[40X\r\n# Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\u001b[5;2H what they do.  They're here only as hints or reminders.  If you are unsure\u001b[6;2H consult the online docs. You have been warned.     \u001b[7;2H\u001b[48X\r\n# Configuration and logfile names: If the filenames you specify for many\u001b[9;2H of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[10;2H server will use that explicit path.  If the filenames do *not* begin\u001b[11;2H with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\n# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\n# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \u001b[14;2H will be interpreted as '/logs/access_log'.\u001b[7X\r\n\u001b[45X\u001b[16;2H\u001b[60X\n ServerRoot: The top of the directory tree under which the server's\u001b[18;2H configuration, error, and log files are kept.\u001b[8X\u001b[19;2H\u001b[54X\n Do not add a slash at the end of the directory path.  If you point\u001b[21;2H ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[22;2H Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[23;2H same ServerRoot for multiple httpd daemons, you will need to change at\u001b[24;2H least PidFile.\u001b[37X\u001b[25;2H\u001b[62X\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[38X\r\n\u001b[59X\u001b[28;2H\u001b[48X\n Mutex: Allows you to set the mutex mechanism and mutex file directory\u001b[30;2H for individual mutexes, or change the global defaults\u001b[8X\u001b[31;2H\u001b[56X\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[33;2H mutex file directory is not on a local disk or is not appropriate for some\u001b[34;2H other reason.\u001b[26X\u001b[35;2H\u001b[46X\n Mutex default:/run/httpd\u001b[19X\r\n\u001b[57X\u001b[38;2H\u001b[38X\n Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[6X\u001b[40;2H ports, instead of the default. See also the <VirtualHost>\u001b[12X\u001b[41;2H directive.\u001b[61X\u001b[42;2H\u001b[70X\r\n# Change this to Listen on specific IP addresses as shown below to \u001b[44;2H prevent Apache from glomming onto all bound IP addresses.\u001b[45;2H\u001b[58X\u001b[46;3Histen 12.34.56.78:80\u001b[19X\u001b[47;153H\u001b[0;10;7m\u000f51,1            1\u001b[48;28H\u001b[?25h"]
[2.288, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.024, "o", "\u001b[1;2HLoadModule log_forensic_module modules/mod_log_forensic.so \u001b[2;2HLoadModule logio_module modules/mod_logio.so\u001b[6X\u001b[3;2HLoadModule lua_module modules/mod_lua.so\r\n\u001b[96mLoadModule\u001b[m\u000f env_module modules/mod_env.so\u001b[27X\u001b[5;2HLoadModule mime_magic_module modules/mod_mime_magic.so\u001b[21X\u001b[6;2HLoadModule cern_meta_module modules/mod_cern_meta.so\u001b[7;2HLoadModule expires_module modules/mod_expires.so\r\n\u001b[96mLoadModule\u001b[m\u000f headers_module modules/mod_headers.so\u001b[24X\u001b[9;2HLoadModule ident_module modules/mod_ident.so\u001b[31X\u001b[10;2HLoadModule usertrack_module modules/mod_usertrack.so\u001b[17X\u001b[11;2HLoadModule unique_id_module modules/mod_unique_id.so\u001b[19X\r\n\u001b[96mLoadModule\u001b[m\u000f setenvif_module modules/mod_setenvif.so\u001b[22X\r\n\u001b[96mLoadModule\u001b[m\u000f version_module modules/mod_version.so\u001b[29X\u001b[14;2HLoadModule remoteip_module modules/mod_remoteip.so\r\n#LoadModule proxy_module modules/mod_proxy.so\u001b[16;2HLoadModule proxy_connect_module modules/mod_proxy_connect.so\u001b[17;2HLoadModule proxy_ftp_module modules/mod_proxy_ftp.so\u001b[15X\u001b[18;2HLoadModule proxy_http_module modules/mod_proxy_http.so\u001b[19;2HLoadModule proxy_fcgi_module modules/mod_proxy_fcgi.so\u001b[20;2HLoadModule proxy_scgi_module modules/mod_proxy_scgi.so\u001b[13X\u001b[21;2HLoadModule proxy_uwsgi_module modules/mod_proxy_uwsgi.so\u001b[15X\u001b[22;2HLoadModule proxy_fdpass_module modules/mod_proxy_fdpass.so\u001b[17X\u001b[23;2H\u001b[30m\u001b[103mLoadModule proxy_wstunnel\u001b[m\u000f_module modules/mod_proxy_wstunnel.so\u001b[9X\u001b[24;2HLoadModule proxy_ajp_module modules/mod_proxy_ajp.so\u001b[25;2HLoadModule proxy_balancer_module modules/mod_proxy_balancer.so\r\n#LoadModule proxy_express_module modules/mod_proxy_express.so\r\n#LoadModule proxy_hcheck_module modules/mod_proxy_hcheck.so\u001b[28;2HLoadModule session_module modules/mod_session.so\u001b[29;2HLoadModule session_cookie_module modules/mod_session_cookie.so\u001b[8X\u001b[30;2HLoadModule session_crypto_module modules/mod_session_crypto.so\u001b[31;2HLoadModule session_dbd_module modules/mod_session_dbd.so\r\n\u001b[96mLoadModule\u001b[m\u000f slotmem_shm_module modules/mod_slotmem_shm.so\u001b[22X\u001b[33;2HLoadModule slotmem_plain_module modules/mod_slotmem_plain.so\u001b[15X\u001b[34;2HLoadModule ssl_module modules/mod_ssl.so\u001b[35;2HLoadModule dialup_module modules/mod_dialup.so\u001b[36;2HLoadModule http2_module modules/mod_http2.so\r\n#LoadModule proxy_http2_module modules/mod_proxy_http2.so\u001b[38;2HLoadModule md_module modules/mod_md.so\u001b[39;2HLoadModule lbmethod_byrequests_module modules/mod_lbmethod_byrequests.so\u001b[40;2HLoadModule lbmethod_bytraffic_module modules/mod_lbmethod_bytraffic.so\u001b[41;2HLoadModule lbmethod_bybusyness_module modules/mod_lbmethod_bybusyness.so\u001b[42;2HLoadModule lbmethod_heartbeat_module modules/mod_lbmethod_heartbeat.so\r\n\u001b[96mLoadModule\u001b[m\u000f unixd_module modules/mod_unixd.so\u001b[23X\u001b[44;2HLoadModule heartbeat_module modules/mod_heartbeat.so\u001b[6X\u001b[45;2HLoadModule heartmonitor_module modules/mod_heartmonitor.so\u001b[46;3HoadModule dav_module modules/mod_dav.so\u001b[47;153H\u001b[0;10;7m\u000f144,2          24\u001b[48;27H\u001b[?25h"]
[8.688, "o", "\u001b[?25l\u001b[m\u000f\r\u001b[48;1H\u001b[26X\u001b[1;2H <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\u001b[2;2H for a discussion of each configuration directive.\u001b[3;2H\u001b[40X\r\n# Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\u001b[5;2H what they do.  They're here only as hints or reminders.  If you are unsure\u001b[6;2H consult the online docs. You have been warned.     \u001b[7;2H\u001b[48X\r\n# Configuration and logfile names: If the filenames you specify for many\u001b[9;2H of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[10;2H server will use that explicit path.  If the filenames do *not* begin\u001b[11;2H with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\n# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\n# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \u001b[14;2H will be interpreted as '/logs/access_log'.\u001b[7X\r\n\u001b[45X\u001b[16;2H\u001b[60X\n ServerRoot: The top of the directory tree under which the server's\u001b[18;2H configuration, error, and log files are kept.\u001b[8X\u001b[19;2H\u001b[54X\n Do not add a slash at the end of the directory path.  If you point\u001b[21;2H ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[22;2H Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[23;2H same ServerRoot for multiple httpd daemons, you will need to change at\u001b[24;2H least PidFile.\u001b[37X\u001b[25;2H\u001b[62X\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[38X\r\n\u001b[59X\u001b[28;2H\u001b[48X\n Mutex: Allows you to set the mutex mechanism and mutex file directory\u001b[30;2H for individual mutexes, or change the global defaults\u001b[8X\u001b[31;2H\u001b[56X\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[33;2H mutex file directory is not on a local disk or is not appropriate for some\u001b[34;2H other reason.\u001b[26X\u001b[35;2H\u001b[46X\n Mutex default:/run/httpd\u001b[19X\r\n\u001b[57X\u001b[38;2H\u001b[38X\n Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[6X\u001b[40;2H ports, instead of the default. See also the <VirtualHost>\u001b[12X\u001b[41;2H directive.\u001b[61X\u001b[42;2H\u001b[70X\r\n# Change this to Listen on specific IP addresses as shown below to \u001b[44;2H prevent Apache from glomming onto all bound IP addresses.\u001b[45;2H\u001b[58X\u001b[46;3Histen 12.34.56.78:80\u001b[19X\u001b[47;153H\u001b[0;10;7m\u000f51,1            1\u001b[?112c\u001b[?1002h\u001b[?1006h\r\u001b[A\u001b[?25h"]
