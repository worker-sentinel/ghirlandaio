[0.017, "o", "\u001b[H\u001b[0;10;1m\u000f<Directory\u001b[m\u000f /\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[50X\r\n    \u001b[96mAllowOverride\u001b[m\u000f none\u001b[39X\r\n    \u001b[96mRequire\u001b[m\u000f all denied\u001b[37X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[37X\r\n\u001b[63X\u001b[6;2H\u001b[62X\n Note that from this point forward you must specifically allow\r\n# particular features to be enabled - so if something's not working as\u001b[9;2H you might expect, make sure that you have specifically enabled it\u001b[10;2H below.\u001b[33X\u001b[11;2H\u001b[46X\r\n\u001b[45X\u001b[13;2H\u001b[56X\n DocumentRoot: The directory out of which you will serve your\u001b[15;2H documents. By default, all requests are taken from this directory, but \u001b[16;2H symbolic links and aliases may be used to point to other locations.  \u001b[17;2H\u001b[72X\r\n\u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http\"\u001b[m\u000f\u001b[47X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[21X\r\n    #\u001b[48X\r\n    # Possible values for the Options directive are \"None\", \"All\",\r\n    # or any combination of:\u001b[13X\r\n    #   \u001b[30m\u001b[103mIn\u001b[m\u000fdexes \u001b[30m\u001b[103mIn\u001b[m\u000fcludes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\n    #\u001b[47X\r\n    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\n    # doesn't give it to you.\u001b[14X\r\n    #\u001b[42X\r\n    # The Options directive is both complicated and important.  Please see\u001b[29;5H# http://httpd.apache.org/docs/2.4/mod/core.html#options\r\n    # for more information.\r\n    #\u001b[24X\r\n    \u001b[96mOptions\u001b[m\u000f \u001b[30m\u001b[103mIn\u001b[m\u000fdexes FollowSymLinks\u001b[15X\r\n\u001b[11X\n    #\u001b[42X\r\n    # AllowOverride controls what directives may be placed in .htaccess files.\r\n    # It can be \"All\", \"None\", or any combination of the keywords:\r\n    #   AllowOverride File\u001b[30m\u001b[103mIn\u001b[m\u000ffo AuthConfig Limit\u001b[9X\r\n    #\u001b[35X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\u001b[29X\r\n\u001b[49X\n    #\u001b[44X\r\n    # Controls who can get stuff from this server.\r\n    #\u001b[39X\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[25X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\r\n\u001b[23X\u001b[47;153H\u001b[0;10;7m\u000f260,9          47\u001b[48;4H\u001b[?25h"]
