[0.019, "o", "\u001b[1;46r\u001b[H\u001b[2M\u001b[1;48r\u001b[28;2H\u001b[0;10;1m\u000f\u001b[30m\u001b[103mI\n\nI\u001b[31;2HI\n\nI\r\u001b[11B\u001b[m\u000f\u001b[96mLoadModule\u001b[m\u000f rewrite\r\n\u001b[K\n\u001b[0;10;1m\u000f<\u001b[0;10;1m\u000f\u001b[30m\u001b[103mI\u001b[0;10;1m\u000ffModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f91,2          29\u001b[48;3H\u001b[?25h"]
