[0.001, "o", "\u001b[1;2H Configuration file for locale-g\u001b[30m\u001b[103men\u001b[m\u000f\u001b[2;2H\u001b[24X\n lists of locales that are to be g\u001b[30m\u001b[103men\u001b[m\u000ferated by the locale-g\u001b[30m\u001b[103men\u001b[m\u000f command.\u001b[4;2H\u001b[18X\n Each line is of the form:\u001b[6;2H\u001b[18X\n     <locale> <charset> \u001b[8;2H\u001b[19X\n  where <locale> is one of the locales giv\u001b[30m\u001b[103men\u001b[m\u000f in /usr/share/i18n/locales\u001b[10;2H  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\u001b[11;2H\u001b[19X\n  The locale-g\u001b[30m\u001b[103men\u001b[m\u000f command will g\u001b[30m\u001b[103men\u001b[m\u000ferate all the locales,\u001b[13;2H  placing them in /usr/lib/locale.\u001b[14;2H\u001b[14X\n  A list of supported locales is giv\u001b[30m\u001b[103men\u001b[m\u000f in /usr/share/i18n/SUPPORTED\u001b[16;2H  and is included in this file. Uncomm\u001b[30m\u001b[103men\u001b[m\u000ft the needed locales below.\u001b[17;2H\u001b[13X\naa_DJ\u001b[19;2Haa_DJ ISO-8859-1\u001b[20;2Haa_ER UTF-8  \u001b[10X\u001b[21;2Haa_ET UTF-8  \u001b[6X\u001b[22;2Haf_ZA.UTF-8 UTF-8  \u001b[23;2Haf_ZA ISO-8859-1  \u001b[24;2Hagr_PE UTF-8  \u001b[5X\u001b[25;2Hak_GH UTF-8  \u001b[5X\u001b[26;2Ham_ET UTF-8  \u001b[6X\u001b[27;2Han_ES.UTF-8 UTF-8  \u001b[28;2Han_ES ISO-8859-15\u001b[29;2Hanp_IN UTF-8      \u001b[30;2Har_AE\u001b[31;2Har_AE ISO-8859-6\u001b[32;2Har_BH\u001b[33;2Har_BH ISO-8859-6\u001b[34;2Har_DZ\u001b[35;2Har_DZ ISO-8859-6\u001b[36;2Har_EG\u001b[37;2Har_EG ISO-8859-6\u001b[38;2Har_IN UTF-8  \u001b[11X\u001b[39;2Har_IQ.UTF-8 UTF-8  \u001b[40;2Har_IQ ISO-8859-6  \u001b[41;2Har_JO.UTF-8 UTF-8  \u001b[42;2Har_JO ISO-8859-6   \u001b[43;2Har_KW.UTF-8 UTF-8  \u001b[44;2Har_KW ISO-8859-6   \u001b[45;2Har_LB.UTF-8 UTF-8  \u001b[46;2Har_LB ISO-8859-6   \u001b[47;154H\u001b[0;10;7m\u000f,34           Top\u001b[48;4H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.002, "o", "\u001b[1;20H\u001b[30m\u001b[103me\u001b[m\u000f for local\u001b[30m\u001b[103me\u001b[m\u000f-g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[3;17H\u001b[30m\u001b[103me\u001b[m\u000fs that ar\u001b[30m\u001b[103me\u001b[m\u000f to b\u001b[30m\u001b[103me\u001b[m\u000f g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[30m\u001b[103me\u001b[m\u000frat\u001b[30m\u001b[103me\u001b[m\u000fd by th\u001b[30m\u001b[103me\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[m\u000f-g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[5;11H\u001b[30m\u001b[103me\u001b[m\u000f is of th\u001b[30m\u001b[103me\u001b[7;13He\u001b[m\u000f> <chars\u001b[30m\u001b[103me\u001b[9;6He\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000f <local\u001b[30m\u001b[103me\u001b[m\u000f> is on\u001b[30m\u001b[103me\u001b[m\u000f of th\u001b[30m\u001b[103me\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[m\u000fs giv\u001b[30m\u001b[103me\u001b[m\u000fn in /usr/shar\u001b[30m\u001b[103me\u001b[m\u000f/i18n/local\u001b[30m\u001b[103me\u001b[10;14He\u001b[m\u000ft> is on\u001b[30m\u001b[103me\u001b[m\u000f of th\u001b[30m\u001b[103me\u001b[m\u000f charact\u001b[30m\u001b[103me\u001b[m\u000fr s\u001b[30m\u001b[103me\u001b[m\u000fts list\u001b[30m\u001b[103me\u001b[m\u000fd in /usr/shar\u001b[30m\u001b[103me\u001b[12;6He\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[m\u000f-g\u001b[30m\u001b[103me\u001b[m\u000fn command will g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[30m\u001b[103me\u001b[m\u000frat\u001b[30m\u001b[103me\u001b[m\u000f all th\u001b[30m\u001b[103me\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[13;14He\u001b[m\u000fm in /usr/lib/local\u001b[30m\u001b[103me\u001b[15;21He\u001b[m\u000fd local\u001b[30m\u001b[103me\u001b[m\u000fs is giv\u001b[30m\u001b[103me\u001b[m\u000fn in /usr/shar\u001b[30m\u001b[103me\u001b[16;17He\u001b[m\u000fd in this fil\u001b[30m\u001b[103me\u001b[m\u000f. Uncomm\u001b[30m\u001b[103me\u001b[m\u000fnt th\u001b[30m\u001b[103me\u001b[m\u000f n\u001b[30m\u001b[103mee\u001b[m\u000fd\u001b[30m\u001b[103me\u001b[m\u000fd local\u001b[30m\u001b[103me\u001b[m\u000fs b\u001b[30m\u001b[103me\u001b[47;155H\u001b[0;10;7m\u000f20\u001b[48;3H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[1;20He for locale-ge\u001b[3;17Hes that are to be generated by the locale-ge\u001b[5;11He is of the\u001b[7;13He> <charse\u001b[9;6Here <locale> is one of the locales given in /usr/share/i18n/locale\u001b[10;14Het> is one of the character sets listed in /usr/share\u001b[12;6He locale-gen command will generate all the locale\u001b[13;14Hem in /usr/lib/locale\u001b[15;21Hed locales is given in /usr/share\u001b[16;17Hed in this file. Uncomment the needed locales be\u001b[47;155H\u001b[0;10;7m\u000f1 \u001b[48;2H\u001b[?25h"]
