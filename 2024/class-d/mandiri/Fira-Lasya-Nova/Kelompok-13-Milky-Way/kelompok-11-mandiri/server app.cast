[0.296, "o", "resolving dependencies...\r\n"]
[0.009, "o", "\u001b[1;34m::\u001b[0;1m There are 2 providers available for libxtables.so=12-64:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mcore\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) iptables  2) iptables-legacy\r\n\r\nEnter a number (default=1): \r\n"]
[0.009, "o", "\u001b[1;34m::\u001b[0;1m There are 3 providers available for oci-runtime:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) crun  2) krun  3) runc\r\n\r\nEnter a number (default=1): \r\n"]
[0.003, "o", "looking for conflicting packages...\r\n"]
