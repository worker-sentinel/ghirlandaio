[0.007, "o", "\u001b[1;65r\u001b[H\u001b[52M\u001b[1;67r\u001b[H\u001b[96mLoadModule\u001b[m\u000f \r\n\u001b[96mLoadModule\u001b[m\u000f \u001b[3;2HLoadModule \u001b[4;2HLoadModule \u001b[5;2HLoadModule \u001b[6;2HLoadModule \u001b[7;2HLoadModule \u001b[8;2HLoadModule \u001b[9;2HLoadModule \u001b[10;2HLoadModule \u001b[11;2HLoadModule \u001b[12;2HLoadModule \u001b[13;2HLoadModule \r\n#LoadModule watchdog_module modules/mod_watchdog.so\u001b[K\r\n#LoadModule macro_module modules/mod_macro.so\u001b[K\r\n#LoadModule dbd_module modules/mod_dbd.so\u001b[K\r\n#LoadModule dumpio_module modules/mod_dumpio.so\u001b[K\r\n#LoadModule echo_module modules/mod_echo.so\u001b[K\r\n#LoadModule buffer_module modules/mod_buffer.so\u001b[K\r\n#LoadModule data_module modules/mod_data.so\u001b[K\r\n#LoadModule ratelimit_module modules/mod_ratelimit.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f reqtimeout_module modules/mod_reqtimeout.so\u001b[K\r\n#LoadModule ext_filter_module modules/mod_ext_filter.so\u001b[K\r\n#LoadModule request_module modules/mod_request.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f include_module modules/mod_include.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f filter_module modules/mod_filter.so\u001b[K\r\n#LoadModule reflector_module modules/mod_reflector.so\u001b[K\r\n#LoadModule substitute_module modules/mod_substitute.so\u001b[K\r\n#LoadModule sed_module modules/mod_sed.so\u001b[K\r\n#LoadModule charset_lite_module modules/mod_charset_lite.so\u001b[K\r\n#LoadModule deflate_module modules/mod_deflate.so\u001b[K\r\n#LoadModule xml2enc_module modules/mod_xml2enc.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_html_module modules/mod_proxy_html.so\u001b[K\r\n#LoadModule brotli_module modules/mod_brotli.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f mime_module modules/mod_mime.so\u001b[K\r\n#LoadModule ldap_module modules/mod_ldap.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f log_config_module modules/mod_log_config.so\u001b[K\r\n#LoadModule log_debug_module modules/mod_log_debug.so\u001b[K\r\n#LoadModule log_forensic_module modules/mod_log_forensic.so\u001b[K\r\n#LoadModule logio_module modules/mod_logio.so\u001b[K\r\n#LoadModule lua_module modules/mod_lua.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f env_module modules/mod_env.so\u001b[K\r\n#LoadModule mime_magic_module modules/mod_mime_magic.so\u001b[K\r\n#LoadModule cern_meta_module modules/mod_cern_meta.so\u001b[K\r\n#LoadModule expires_module modules/mod_expires.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f headers_module modules/mod_headers.so\u001b[K\r\n#LoadModule ident_module modules/mod_ident.so\u001b[K\r\n#LoadModule usertrack_module modules/mod_usertrack.so\u001b[K\r\n#LoadModule unique_id_module modules/mod_unique_id.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f setenvif_module modules/mod_setenvif.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f version_module modules/mod_version.so\u001b[K\r\n#LoadModule remoteip_module modules/mod_remoteip.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_module modules/mod_proxy.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_connect_module modules/mod_proxy_connect.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_ftp_module modules/mod_proxy_ftp.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_http_module modules/mod_proxy_http.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_fcgi_module modules/mod_proxy_fcgi.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_scgi_module modules/mod_proxy_scgi.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_uwsgi_module modules/mod_proxy_uwsgi.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_fdpass_module modules/mod_proxy_fdpass.so\u001b[K\r\n\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_wstunnel_module modules/mod_proxy_wstunnel.so\u001b[K\r\n#\u001b[30m\u001b[103mLoadModule p\u001b[m\u000froxy_ajp