[0.223, "o", "\u001b[?25la"]
[0.006, "o", "\u001b[1;2H ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[2;2H Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[3;2H same ServerRoot for multiple httpd daemons, you will need to change at\u001b[4;2H least PidFile.\r\n#\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\r\n\u001b[57X\u001b[8;2H\u001b[53X\u001b[9;3HMutex: Allows you to set the mutex mechanism and mutex file directory\u001b[10;3Hfor individual mutexes, or change the global defaults\u001b[11;2H\u001b[19X\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[13;2H mutex file directory is not on a local disk or is not appropriate for some\u001b[14;3Hother reason.\u001b[46X\u001b[15;2H\u001b[62X\u001b[16;3HMutex default:/run/httpd\u001b[34X\r\n\u001b[52X\u001b[18;2H\u001b[59X\u001b[19;3HListen: Allows you to bind Apache to specific IP addresses and/or\u001b[20;3Hports, instead of the default. See also the <VirtualHost>\u001b[21;2H directive.\u001b[22;2H\u001b[14X\n Change this to Listen on specific IP addresses as shown below to \r\n# prevent Apache from glomming onto all bound IP addresses.\u001b[25;2H\u001b[27X\nListen 12.34.56.78:80\r\n\u001b[96mListen\u001b[m\u000f 80\u001b[53X\r\n\u001b[75X\u001b[29;2H\u001b[70X\u001b[30;3HDynamic Shared Object (DSO) Support\r\n#\u001b[32;3HTo be able to use the functionality of a module which was built as a DSO you\r\n# have to place corresponding `\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule' lines at this location so the\r\n# directives contained in it are actually available _before_ they are used.\u001b[35;3HStatically compiled modules (those listed by `httpd -l') do not need\r\n# to be loaded here.\u001b[28X\r\n#\u001b[38;3HExample:\u001b[16X\r\n# \u001b[30m\u001b[103mLoa\u001b[m\u000fdModule foo_module modules/mod_foo.so\r\n#\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f mpm_event_module modules/mod_mpm_event.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule mpm_prefork_module modules/mod_mpm_prefork.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule mpm_worker_module modules/mod_mpm_worker.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f authn_file_module modules/mod_authn_file.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authn_dbm_module modules/mod_authn_dbm.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authn_anon_module modules/mod_authn_anon.so\u001b[47;2H\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authn_dbd_module modules/mod_authn_dbd.so\u001b[48;2H\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authn_socache_module modules/mod_authn_socache.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f authn_core_module modules/mod_authn_core.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f authz_host_module modules/mod_authz_host.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f authz_groupfile_module modules/mod_authz_groupfile.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f authz_user_module modules/mod_authz_user.so\u001b[53;2H\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authz_dbm_module modules/mod_authz_dbm.so\u001b[54;2H\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authz_owner_module modules/mod_authz_owner.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authz_dbd_module modules/mod_authz_dbd.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f authz_core_module modules/mod_authz_core.so\u001b[57;2H\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authnz_ldap_module modules/mod_authnz_ldap.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule authnz_fcgi_module modules/mod_authnz_fcgi.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f access_compat_module modules/mod_access_compat.so\r\n\u001b[30m\u001b[103mLoa\u001b[m\u000f\u001b[96mdModule\u001b[m\u000f auth_basic_module modules/mod_auth_basic.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule auth_form_module modules/mod_auth_form.so\u001b[62;2H\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule auth_digest_module modules/mod_auth_digest.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule allowmethods_module modules/mod_allowmethods.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule file_cache_module modules/mod_file_cache.so\r\n#\u001b[30m\u001b[103mLoa\u001b[m\u000fdModule cache_module modules/mod_cache.so\u001b[66;224H\u001b[0;10;7m\u000f8,32           5\u001b[67;5H\u001b[?25h"]
