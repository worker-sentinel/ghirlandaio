[0.054, "o", ":: Running post-transaction hooks...\r\n(1/6) Creating temporary files...\r\n"]
[0.066, "o", "(2/6) Reloading system manager configuration...\r\n"]
[0.284, "o", "(3/6) Reloading user manager configuration...\r\n"]
[0.234, "o", "(4/6) Arming ConditionNeedsUpdate...\r\n"]
[0.037, "o", "(5/6) Updating GIO module cache...\r\n"]
[0.054, "o", "(6/6) Compiling GSettings XML schema files...\r\n"]
