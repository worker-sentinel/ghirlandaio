[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hpgsql.log_notice = 0\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[96m[bcmath]\u001b[m\u000f\u001b[K\r\u001b[65;1H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mbcmath\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Number of decimal digits for all bcmath functions.\u001b[K\r\u001b[A\u001b[96m[bcmath]\u001b[66;225H\u001b[0;10;7m\u000f60\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/bcmath.scale\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1,1         66\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hbcmath.scale = 0\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[96m[browscap]\u001b[m\u000f\u001b[K\r\u001b[65;1H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mbrowscap\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/browscap\u001b[K\r\u001b[A\u001b[96m[browscap]\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;browscap = extra/browscap.ini\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[96m[Session]\u001b[m\u000f\u001b[K\r\u001b[65;1H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mSession\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Handler used to store/retrieve data.\u001b[K\r\u001b[A\u001b[96m[Session]\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.save-handler\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f70\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.save_handler =\u001b[92m files\u001b[m\u000f\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Argument passed to save_handler.  In the case of files, this is the path\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; where data files are stored. Note: Windows users have to change this\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; variable in order to use PHP's session functions.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; The path can be defined as:\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;     session.save_path = \"N;/path\"\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9,1         67\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f80\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; where N is an integer.  Instead of storing all the session files in\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; /path, what this will do is use subdirectories N-levels deep, and\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; store the session data in those directories.  This is useful if\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; your OS has problems with many files in one directory, and is\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; a more efficient layout for servers that handle many sessions.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; NOTE 1: PHP will not create this directory structure automatically.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;         You can use the script in the ext/session dir for that purpose.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; NOTE 2: See the section on garbage collection below if you choose to\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;         use subdirectories for session storage\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f90\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; The file storage module creates files using mode 600 by default.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; You can change that by using\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;     session.save_path = \"N;MODE;/path\"\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; where MODE is the octal representation of the mode. Note that this\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7,1         68\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; does not overwrite the process's umask.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.save-path\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;session.save_path = \"/tmp\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f300\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Whether to use strict session mode.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Strict session mode does not accept an uninitialized session ID, and\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; regenerates the session ID if the browser sends an uninitialized session ID.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Strict mode protects applications from session fixation via a session adoption\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; vulnerability. It is disabled by default for maximum compatibility, but\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; enabling it is encouraged.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://wiki.php.net/rfc/strict_sessions\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.use_strict_mode = 0\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f10\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Whether to use cookies.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.use-cookies\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.use_cookies = 1\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cookie-secure\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5,1         69\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;session.cookie_secure =\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cookie-partitioned\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;session.cookie_partitioned = 0\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f20\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; This option forces PHP to fetch and use a cookie for storing and maintaining\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; the session id. We encourage this operation as it's very helpful in combating\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; session hijacking when not specifying and managing your own session id. It is\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; not the be-all and end-all of session hijacking defense, but it's a good start.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[1.293, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.use-only-cookies\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.293, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.use_only_cookies = 1\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Name of the session (used as cookie name).\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.name\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.name =\u001b[92m PHPSESSID\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f30\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Initialize session on request startup.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.auto-start\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3,1         70\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.auto_start = 0\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Lifetime in seconds of cookie or, if 0, until browser is restarted.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cookie-lifetime\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cookie_lifetime = 0\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; The path for which the cookie is valid.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f40\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cookie-path\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cookie_path =\u001b[92m /\u001b[m\u000f\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; The domain for which the cookie is valid.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cookie-domain\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cookie_domain =\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Whether or not to add the httpOnly flag to the cookie, which makes it\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; inaccessible to browser scripting languages such as JavaScript.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cookie-httponly\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f50\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cookie_httponly =\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1,1         71\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Add SameSite attribute to cookie to help mitigate Cross-Site Request Forgery (CSRF/XSRF)\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Current valid values are \"Strict\", \"Lax\" or \"None\". When using \"None\",\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; make sure to include the quotes, as `none` is interpreted like `false` in ini files.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://tools.ietf.org/html/draft-west-first-party-cookies-07\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cookie_samesite =\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Handler used to serialize data. php is the standard serializer of PHP.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.serialize-handler\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f60\r\u001b[A\u001b[?25h"]
[0.287, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.serialize_handler =\u001b[92m php\u001b[m\u000f\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.290, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.246, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Defines the probability that the 'garbage collection' process is started on every\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.452, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; session initialization. The probability is calculated by using gc_probability/gc_divisor,\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.574, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; e.g. 1/100 means there is a 1% chance that the GC process starts on each request.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.307, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Default Value: 1\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.294, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Development Value: 1\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Production Value: 1\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.gc-probability\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9,1         72\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.gc_probability = 1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f70\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Defines the probability that the 'garbage collection' process is started on every\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; session initialization. The probability is calculated by using gc_probability/gc_divisor,\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; e.g. 1/100 means there is a 1% chance that the GC process starts on each request.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; For high volume production servers, using a value of 1000 is a more efficient approach.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Default Value: 100\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Development Value: 1000\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Production Value: 1000\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.gc-divisor\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.gc_divisor = 1000\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f80\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; After this number of seconds, stored data will be seen as 'garbage' and\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.361, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; cleaned up by the garbage collection process.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.290, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.gc-maxlifetime\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.gc_maxlifetime = 1440\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; NOTE: If you are using the subdirectory option for storing session files\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;       (see session.save_path above), then garbage collection does *not*\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8,1         73\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;       happen automatically.  You will need to do your own garbage\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.324, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;       collection through a shell script, cron entry, or some other method.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f90\r\u001b[A\u001b[?25h"]
[0.293, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;       For example, the following script is the equivalent of setting\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;       session.gc_maxlifetime to 1440 (1440 seconds = 24 minutes):\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;          find /path/to/sessions -cmin +24 -type f | xargs rm\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Check HTTP Referer to invalidate externally stored URLs containing ids.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; HTTP_REFERER has to contain this substring for the session to be\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; considered as valid.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.referer-check\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.referer_check =\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f400\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Set to {nocache,private,public,} to determine HTTP caching aspects\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.312, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; or leave this empty to avoid sending anti-caching headers.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.294, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cache-limiter\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cache_limiter =\u001b[92m nocache\u001b[m\u000f\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Document expires after n minutes.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6,1         74\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.cache-expire\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.cache_expire = 180\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; trans sid support is disabled by default.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f10\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Use of trans sid may risk your users' security.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Use this option with caution.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; - User may send URL contains active session ID\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;   to other person via. email/irc/etc.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; - URL that contains active session ID may be stored\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.540, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;   in publicly accessible computer.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.292, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; - User may access your site with the same session ID\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;   always using URL stored in browser's history or bookmarks.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.433, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/session.use-trans-sid\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.296, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.use_trans_sid = 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f20\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; The URL rewriter will look for URLs in a defined set of HTML tags.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; <form> is special; if you include them here, the rewriter will\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; add a hidden <input> field with the info which is otherwise appended\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4,1         75\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; to URLs. <form> tag's action attribute URL will not be modified\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; unless it is specified.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Note that all valid entries require a \"=\", even if no value follows.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Default Value: \"a=href,area=href,frame=src,form=\"\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[9.939, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Development Value: \"a=href,area=href,frame=src,form=\"\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.293, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Production Value: \"a=href,area=href,frame=src,form=\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f30\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/url-rewriter.tags\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[2.607, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hsession.trans_sid_tags =\u001b[92m \"a=href,area=href,frame=src,form=\"\u001b[m\u000f\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.859, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.295, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; URL rewriter does not rewrite absolute URLs by default.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; To enable rewrites for absolute paths, target hosts must be specified\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; at RUNTIME. i.e. use ini_set()\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; <form> tags is special. PHP will check action attribute's URL regardless\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; of session.trans_sid_tags setting.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; If no host is defined, HTTP_HOST will be used for allowed host.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Example value: php.net,www.php.net,wiki.php.net\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f40\r\u001b[A\u001b[?25h"]
