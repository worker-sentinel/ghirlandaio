[0.005, "o", "\u001b[H; Resource Limits ;\u001b[2;2H;;;;;;;;;;;;;;;;;;\u001b[17X\r\n\u001b[37X\n; Maximum execution time of each script, in seconds\r\n; https://php.net/max-execution-time\u001b[6;3HNote: This directive is hardcoded to 0 for the CLI SAPI\r\nmax_execution_time = 30\u001b[14X\r\n\u001b[21X\n; Maximum amount of time each script may spend parsing request data. It's a good\u001b[10;3Hidea to limit this time on productions servers in order to eliminate unexpectedly\u001b[11;3Hlong running scripts.\u001b[52X\u001b[12;3HNote: This directive is hardcoded to -1 for the CLI SAPI\u001b[17X\u001b[13;3HDefault Value: -1 (Unlimited)\u001b[47X\u001b[14;3HDevelopment Value: 60 (60 seconds)\u001b[15X\u001b[15;3HProduction Value: 60 (60 seconds)\r\n; https://php.net/max-input-time\r\nmax_input_time = 60\r\n\u001b[74X\u001b[19;3HMaximum input variable nesting level\u001b[30X\u001b[20;3Hhttps://php.net/max-input-nesting-level\u001b[21;3Hax_input_nesting_level = 64\u001b[9X\r\n\n; How many GET/POST/COOKIE input variables may be accepted\u001b[24;2Hmax_input_vars = 1000\u001b[53X\r\n\u001b[44X\n; How many multipart body parts (combined input variable and file uploads) may\r\n; be accepted.\u001b[28;3HDefault Value: -1 (Sum of max_input_vars and max_file_uploads)\u001b[16X\u001b[29;2Hmax_multipart_body_parts = 1500\u001b[12X\r\n\u001b[20X\u001b[31;3HMaximum amount of memory a script may consume\u001b[32;3Hhttps://php.net/memory-limit\r\n\u001b[30m\u001b[103mmemory_l\u001b[m\u000fimit =\u001b[92m 128M\u001b[m\u000f\u001b[20X\r\nmax_\u001b[30m\u001b[103mmemory_l\u001b[m\u000fimit =\u001b[92m -1\u001b[m\u000f\r\n\u001b[78X\u001b[36;2H;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[37;3HError handling and logging ; \u001b[38;2H;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[40;3HThis directive informs PHP of which errors, warnings and notices you would like\u001b[41;2H it to take action for. The recommended way of setting values for this\r\n; directive is through the use of the error level constants and bitwise\u001b[43;3Hoperators. The error level constants are below here for convenience as well as\u001b[44;2H some common settings and their meanings.\r\n; By default, PHP is set to take action on all errors, notices and warnings EXCEPT\u001b[46;3Hthose related to E_NOTICE, which together cover best practices and\u001b[10X\u001b[47;2H recommended coding standards in PHP. For performance reasons, this is the\r\n; recommend error reporting setting. Your production server shouldn't be wasting\u001b[49;3Hresources complaining about best practices and coding standards. That's what\u001b[50;3Hdevelopment servers and development settings are for.\u001b[51;2H Note: The php.ini-development file has this setting as E_ALL. This\r\n; means it pretty much reports everything which is exactly what you want during\u001b[53;3Hdevelopment and early testing.\u001b[10X\u001b[54;2H\u001b[35X\r\n; Error Level Constants:\u001b[56;3HE_ALL             - All errors and warnings\u001b[33X\u001b[57;3HE_ERROR           - fatal run-time errors\u001b[58;2H E_RECOVERABLE_ERROR  - almost fatal run-time errors\r\n; E_WARNING         - run-time warnings (non-fatal errors)\r\n; E_PARSE           - compile-time parse errors\u001b[61;3HE_NOTICE          - run-time notices (these are warnings which often result\u001b[62;3H                    from a bug in your code, but it's possible that it was\r\n;                     intentional (e.g., using an uninitialized variable and\r\n;                     relying on the fact it is automatically initialized to an\u001b[65;3H                    empty string)\u001b[24X\u001b[66;223H\u001b[0;10;7m\u000f430,1          21\u001b[67;10H\u001b[?25h"]
