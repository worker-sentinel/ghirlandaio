[0.005, "o", "\u001b[1;65r\u001b[H\u001b[6M\u001b[1;67r\u001b[27;9Hpost_\u001b[31;30Hpost_\r\n\n\u001b[30m\u001b[103mpost_m\r\u001b[27B\u001b[m\u000f; If empty, default_charset is used.\u001b[K\r\n; https://php.net/input-encoding\u001b[K\r\n;input_encoding =\u001b[K\r\n\u001b[K\n; PHP output character encoding is set to empty.\u001b[K\r\n; If empty, default_charset is used.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f93,1\u001b[67;8H\u001b[?25h"]
