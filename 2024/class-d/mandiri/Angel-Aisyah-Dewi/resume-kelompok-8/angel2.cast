[0.003, "o", "\u001b[1;65r\u001b[H\u001b[50M\u001b[1;67r\u001b[16;1H; is supported by Apache. When this option is set to 1, PHP will send\u001b[K\r\n; RFC2616 compliant header.\u001b[K\r\n; Default is zero.\u001b[K\r\n; https://php.net/cgi.rfc2616-headers\u001b[K\r\n;cgi.rfc2616_headers = 0\u001b[K\r\n\u001b[K\n; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\u001b[K\r\n; (shebang) at the top of the running script. This line might be needed if the\u001b[K\r\n; script support running both as stand-alone script and via PHP CGI<. PHP in CGI\u001b[K\r\n; mode skips this line and ignores its content if this directive is turned on.\u001b[K\r\n; https://php.net/cgi.check-shebang-line\u001b[K\r\n;cgi.check_shebang_line=1\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;\u001b[K\r\n; File Uploads ;\u001b[K\r\n;;;;;;;;;;;;;;;;\u001b[K\r\n\u001b[K\n; Whether to allow HTTP file \u001b[30m\u001b[103mupl\u001b[m\u000foads.\u001b[K\r\n; https://php.net/file-\u001b[30m\u001b[103mupl\u001b[m\u000foads\u001b[K\r\nfile_\u001b[30m\u001b[103mupl\u001b[m\u000foads =\u001b[92m On\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Temporary directory for HTTP \u001b[30m\u001b[103mupl\u001b[m\u000foaded files (will use system default if not\u001b[K\r\n; specified).\u001b[K\r\n; https://php.net/\u001b[30m\u001b[103mupl\u001b[m\u000foad-tmp-dir\u001b[K\r\n;\u001b[30m\u001b[103mupl\u001b[m\u000foad_tmp_dir =\u001b[K\r\n\u001b[K\n; Maximum allowed size for \u001b[30m\u001b[103mupl\u001b[m\u000foaded files.\u001b[K\r\n; https://php.net/\u001b[30m\u001b[103mupl\u001b[m\u000foad-max-filesize\u001b[K\r\n\u001b[30m\u001b[103mupl\u001b[m\u000foad_max_filesize =\u001b[92m 2M\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Maximum number of files that can be \u001b[30m\u001b[103mupl\u001b[m\u000foaded via a single request\u001b[K\r\nmax_file_\u001b[30m\u001b[103mupl\u001b[m\u000foads = 20\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;;;\u001b[K\r\n; Fopen wrappers ;\u001b[K\r\n;;;;;;;;;;;;;;;;;;\u001b[K\r\n\u001b[K\n; Whether to allow the treatment of URLs (like http:// or ftp://) as files.\u001b[K\r\n; https://php.net/allow-url-fopen\u001b[K\r\nallow_url_fopen =\u001b[92m On\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Whether to allow include/require to open URLs (like https:// or ftp://) as files.\u001b[K\r\n; https://php.net/allow-url-include\u001b[K\r\nallow_url_include =\u001b[92m Off\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Define the anonymous ftp password (your email address). PHP's default setting\u001b[K\r\n; for this is empty.\u001b[K\r\n; https://php.net/from\u001b[K\r\n;from=\"john@doe.com\"\u001b[K\r\n\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f840,30         44\u001b[67;5H\u001b[?25h"]
