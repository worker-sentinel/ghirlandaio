[0.005, "o", "\u001b[H\u001b[20X\n; Default socket name for local MySQL connects.  If empty, uses the built-in\u001b[3;3HMySQL defaults.\u001b[59X\u001b[4;3Hhttps://php.net/mysqli.default-socket\u001b[42X\r\nmysqli.default_socket =\u001b[46X\r\n\u001b[27X\u001b[7;11Hhost for mysqli_connect().\u001b[8;19Hmysqli.default-host\r\nmysqli.default_host =   \u001b[11;3HDefault user for mysqli_connect().\u001b[46X\u001b[12;3Hhttps://php.net/mysqli.default-user\u001b[41X\r\nmysqli.default_user =\u001b[59X\r\n\u001b[78X\u001b[15;3HDefault password for mysqli_connect().\u001b[16;2H Note that this is generally a *bad* idea to store passwords in this file.\r\n; *Any* user with PHP access can run 'echo get_cfg_var(\"mysqli.default_pw\")\u001b[18;2H and reveal this password!  And of course, any users with read access to this\u001b[19;3Hfile will be able to reveal the password as well.\u001b[20;2H https://php.net/mysqli.default-pw\r\nmysqli.default_pw =\r\n\u001b[37X\u001b[23;3HIf this option is enabled, closing a persistent connection will rollback\r\n; any pending transactions of this connection, before it is put back\r\n; into the persistent connection pool.\u001b[26;2Hmysqli.rollback_on_cached_plink = Off\u001b[39X\r\n\u001b[13X\n\u001b[96m[mysqlnd]\u001b[m\u000f\u001b[23X\u001b[29;2H Enable / Disable collection of general statistics by mysqlnd which can be\r\n; used to tune and monitor MySQL operations.\r\nmysqlnd.collect_statistics =\u001b[92m On\u001b[m\u000f\u001b[11X\r\n\u001b[37X\n; Enable / Disable collection of \u001b[30m\u001b[103mmem\u001b[m\u000fory usage statistics by mysqlnd which can be\r\n; used to tune and monitor MySQL operations.\u001b[35;3HDefault Value: Off\u001b[47X\r\n; Development Value: On\r\n; Production Value: Off\r\nmysqlnd.collect_\u001b[30m\u001b[103mmem\u001b[m\u000fory_statistics =\u001b[92m Off\u001b[m\u000f\r\n\u001b[18X\u001b[40;2H Records communication from all extensions using mysqlnd to the specified log\r\n; file.\u001b[42;3Hhttps://php.net/mysqlnd.debug\u001b[44X\u001b[43;2Hmysqlnd.debug =\u001b[17X\r\n\u001b[20X\n; Defines which queries will be logged.\u001b[46;2Hmysqlnd.log_mask = 0\u001b[62X\r\n\u001b[35X\n; Default size of the mysqlnd \u001b[30m\u001b[103mmem\u001b[m\u000fory pool, which is used by result sets.\r\n;mysqlnd.\u001b[30m\u001b[103mmem\u001b[m\u000fpool_default_size = 16000\r\n\u001b[79X\u001b[51;3HSize of a pre-allocated buffer used when sending commands to MySQL in bytes.\u001b[52;2Hmysqlnd.net_cmd_buffer_size = 2048\r\n\u001b[20X\n; Size of a pre-allocated buffer used for reading data sent by the server in\u001b[55;3Hbytes.\u001b[64X\u001b[56;2Hmysqlnd.net_read_buffer_size = 32768\r\n\u001b[17X\n; Timeout for network requests in seconds.\u001b[59;2Hmysqlnd.net_read_timeout = 31536000\u001b[16X\r\n\u001b[40X\n; SHA-256 Authentication Plugin related. File with the MySQL server public RSA\r\n; key.\u001b[63;2Hmysqlnd.sha256_server_public_key =\u001b[30X\r\n\u001b[62X\n\u001b[96m[PostgreSQL]\u001b[m\u000f\u001b[48X\u001b[66;223H\u001b[0;10;7m\u000f1199,34        64\u001b[67;5H\u001b[?25h"]
