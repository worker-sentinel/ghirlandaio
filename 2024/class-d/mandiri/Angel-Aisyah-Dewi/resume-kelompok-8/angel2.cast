[0.347, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f80\r\u001b[A\u001b[?25h"]
[0.292, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Default password for mysqli_connect().\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Note that this is generally a *bad* idea to store passwords in this file.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; *Any* user with PHP access can run 'echo get_cfg_var(\"mysqli.default_pw\")\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; and reveal this password!  And of course, any users with read access to this\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; file will be able to reveal the password as well.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/mysqli.default-pw\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hmysqli.default_pw =\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f8,1         62\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; If this option is enabled, closing a persistent connection will rollback\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; any pending transactions of this connection, before it is put back\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f90\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; into the persistent connection pool.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;mysqli.rollback_on_cached_plink = Off\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
