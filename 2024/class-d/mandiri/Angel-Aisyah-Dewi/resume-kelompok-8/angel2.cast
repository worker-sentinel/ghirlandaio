[0.033, "o", "\u001b[0;10;1m\u000fWelcome to the MariaDB monitor.  Commands end with ; or \\g.\r\n"]
[0.000, "o", "\u001b[m\u000f\u001b[0;10;1m\u000fYour MariaDB connection id is 10\r\nServer version: 12.3.2-MariaDB Arch Linux\r\n\r\n\u001b[m\u000f\u001b[0;10;1m\u000fCopyright (c) 2000, 2018, Oracle, MariaDB Corporation Ab and others.\r\n\r\n"]
