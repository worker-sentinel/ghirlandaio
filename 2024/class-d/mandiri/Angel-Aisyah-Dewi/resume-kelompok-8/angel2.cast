[0.295, "o", "\u001b[?25l\u001b[67;230H\u001b[m\u000f~@k\u001b[65;32H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[67;230H   \u001b[1;65r\u001b[H\u001b[M\u001b[1;67r\u001b[65;1H; to use SCRIPT_FILENAME rather than PATH_TRANSLATED.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[65;32H\u001b[?25h"]
