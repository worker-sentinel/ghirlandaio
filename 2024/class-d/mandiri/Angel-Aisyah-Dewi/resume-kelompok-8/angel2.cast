[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Unless pgsql.ignore_notice=0, module cannot log notice message.\u001b[K\u001b[66;226H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
