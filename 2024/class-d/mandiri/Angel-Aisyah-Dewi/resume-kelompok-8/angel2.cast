[0.004, "o", "\u001b[H; Whether to allow include/require to open URLs (like https:// or ftp://) as files.\r\n; https://php.net/allow-url-include\r\nallow_url_include =\u001b[92m Off\u001b[m\u000f\r\n\u001b[19X\u001b[5;2H Define the anonymous ftp password (your email address). PHP's default setting\u001b[6;3Hfor this is empty.\u001b[53X\u001b[7;3Hhttps://php.net/from\u001b[30X\r\n;from=\"john@doe.com\"\r\n\u001b[78X\u001b[10;3HDefine the User-Agent string. PHP's default setting for this is empty.\u001b[11;3Hhttps://php.net/user-agent\u001b[7X\u001b[12;2Huser_agent=\"PHP\"\u001b[19X\r\n\u001b[52X\u001b[14;3HDefault timeout for socket based streams (seconds)\u001b[15;3Hhttps://php.net/default-socket-timeout\u001b[31X\r\ndefault_socket_timeout = 60\r\n\u001b[79X\u001b[18;3HIf your scripts have to deal with files from Macintosh systems,\u001b[19;3Hor you are running on a Mac and need to deal with files from\u001b[20;3Hunix or win32 systems, setting this flag will cause PHP to\r\n; automatically detect the EOL character in those files so that\u001b[22;3Hfgets() and file() will work regardless of the source of the file.\u001b[23;3Hhttps://php.net/auto-detect-line-endings\u001b[34X\u001b[24;2Hauto_detect_line_endings = Off\u001b[38X\r\n\u001b[42X\n;;;;;;;;;;;;;;;;;;;;;;\u001b[27;4Hynamic Extensions ;\u001b[44X\u001b[28;2H;;;;;;;;;;;;;;;;;;;;;\u001b[40X\r\n\u001b[68X\u001b[30;3HIf you wish to have an extension loaded automatically, use the following\u001b[31;4Hyntax:\u001b[59X\u001b[32;2H\u001b[68X\u001b[33;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000fmodulename\u001b[34;2H\u001b[29X\r\n; For example:\u001b[36;2H\u001b[53X\u001b[37;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000fmysqli\u001b[38;2H\u001b[74X\u001b[39;3HWhen the extension library to load is not located in the default extension\u001b[40;3Hdirectory, You may specify an absolute path to the library file:\u001b[41;2H\u001b[78X\r\n;   \u001b[30m\u001b[103mextension=\u001b[m\u000f/path/to/extension/mysqli.so\u001b[43;2H\u001b[78X\u001b[44;3HNote : The syntax used in previous PHP versions ('\u001b[30m\u001b[103mextension=\u001b[m\u000f<ext>.so' and\u001b[5X\u001b[45;3H'\u001b[30m\u001b[103mextension=\u001b[m\u000f'php_<ext>.dll') is supported for legacy reasons and may be\u001b[46;3Hdeprecated in a future PHP major version. So, when it is possible, please\r\n; move to the new ('\u001b[30m\u001b[103mextension=\u001b[m\u000f<ext>) syntax.\u001b[48;2H\u001b[78X\n\u001b[30m\u001b[103mextension=\u001b[m\u000fbcmath\u001b[50;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fbz2  \u001b[51;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fcalendar\r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mcurl\u001b[m\u000f  \u001b[53;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fdba  \r\n;\u001b[30m\u001b[103mextension=\u001b[m\u000fenchant\r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mexif\u001b[m\u000f\u001b[55X\u001b[56;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fffi\u001b[48X\r\n;\u001b[30m\u001b[103mextension=\u001b[m\u000fftp\r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mgd\u001b[m\u000f\u001b[67X\u001b[59;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fgettext\u001b[19X\r\n;\u001b[30m\u001b[103mextension=\u001b[m\u000fgmp\u001b[61;2H\u001b[30m\u001b[103mextension=\u001b[m\u000ficonv\u001b[29X\u001b[62;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fintl\u001b[30X\u001b[63;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fldap\u001b[32X\r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mmysqli\u001b[65;2H\u001b[m\u000f\u001b[30m\u001b[103mextension=\u001b[m\u000fodbc\u001b[54X\u001b[66;223H\u001b[0;10;7m\u000f896,5          47%\u001b[67;12H\u001b[?25h"]
