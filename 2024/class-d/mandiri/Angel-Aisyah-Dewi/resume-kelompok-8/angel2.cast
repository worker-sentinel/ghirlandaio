[0.004, "o", "\u001b[6;13H\u001b[30m\u001b[103mm\u001b[12;57Hm\u001b[14;3Hm\u001b[26;5Hm\u001b[m\u000fporary directory for HTTP uploaded files (will use syste\u001b[30m\u001b[103mm\u001b[28;27Hm\u001b[29;10Hm\u001b[31;7Hm\u001b[m\u000fu\u001b[30m\u001b[103mm\u001b[32;26Hm\r\n\u001b[m\u000fupload_\u001b[30m\u001b[103mm\u001b[m\u000fax_\u001b[35;7H\u001b[30m\u001b[103mm\u001b[m\u000fu\u001b[30m\u001b[103mm\u001b[m\u000f nu\u001b[30m\u001b[103mm\r\nm\u001b[42;29Hm\u001b[50;19Hm\u001b[m\u000fous ftp password (your e\u001b[30m\u001b[103mm\u001b[51;16Hm\u001b[52;22Hm\u001b[53;5Hm\u001b[m\u000f=\"john@doe.co\u001b[30m\u001b[103mm\u001b[55;68Hm\u001b[59;13Hm\u001b[m\u000feout for socket based strea\u001b[30m\u001b[103mm\u001b[60;36Hm\u001b[61;18Hm\u001b[63;46Hm\u001b[m\u000f Macintosh syste\u001b[30m\u001b[103mm\u001b[64;62Hm\u001b[65;22Hm\u001b[66;225H\u001b[0;10;7m\u000f3,7 \u001b[67;3H\u001b[?25h"]
