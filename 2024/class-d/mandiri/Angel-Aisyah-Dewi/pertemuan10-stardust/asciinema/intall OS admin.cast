[1.096, "o", "\u001b[?2004l\u001b[75C\u001b[K\u001b[75D\r\r\n"]
[0.014, "o", "==> Creating install root at /mnt\r\n"]
[0.039, "o", "==> Installing packages to /mnt\r\n"]
[0.016, "o", "\u001b[?25l\u001b[1;34m::\u001b[0;1m Synchronizing package databases...\r\n\u001b[0m"]
[0.000, "o", " core\r\n extra\r\n"]
[0.086, "o", "\u001b[2F core is up to date\u001b[K"]
[0.236, "o", "\u001b[1E extra is up to date\u001b[K"]
[0.205, "o", "\u001b[1E"]
[0.206, "o", "resolving dependencies...\r\n"]
[0.010, "o", "\u001b[1;34m::\u001b[0;1m There are 2 providers available for jack:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) jack2  2) pipewire-jack\r\n\r\nEnter a number (default=1): \r\n"]
[0.010, "o", "looking for conflicting packages...\r\n"]
