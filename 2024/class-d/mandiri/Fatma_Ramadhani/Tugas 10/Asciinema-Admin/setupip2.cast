[0.003, "o", "\u001b[?25l\u001b[56;180H      \u001b[1;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m set which transmits the Beacon frames. The remaining interfaces are called\u001b[2;3Hthe non-transmitting profiles and these are advertised inside the Multiple\u001b[3;3HBSSID element in the Beacon and Probe Response frames from the first\u001b[4;3Hinterface.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[39X\u001b[5;2H\u001b[14X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m The transmitting interface is visible to all stations in the vicinity, however\u001b[7;3Hthe stations that do not support parsing of the Multiple BSSID element will\u001b[8;3Hnot be able to connect to the non-transmitting interfaces.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[7X\u001b[9;2H\u001b[58X\u001b[10;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mEnhanced Multiple BSSID Advertisements (EMA)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[31X\u001b[11;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mWhen enabled, the non-transmitting interfaces are split into multiple\u001b[12;3HBeacon frames. The number of Beacon frames required to cover all the\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[7X\u001b[13;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mnon-transmitting profiles is called the profile periodicity.\u001b[15;3HRefer to IEEE Std 802.11-2020 for details regarding the procedure and\u001b[16;3Hrequired MAC address assignment.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[44X\u001b[17;2H\u001b[7X\u001b[18;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mFollowing configuration is per radio.\u001b[19;3H0 = Disabled (default)\u001b[20;2H 1 = Multiple BSSID advertisement enabled.\u001b[21;3H2 = Enhanced multiple BSSID advertisement enabled.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[26X\u001b[22;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mmbssid=0\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[69X\u001b[23;2H\u001b[49X\u001b[24;7H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mtransmitting interface should be added with the 'interface' option while\u001b[25;3Hthe non-transmitting interfaces should be added using the 'bss' option.\u001b[26;2H Security configuration should be added separately per interface, if required.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[27;2H\u001b[65X\u001b[28;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mExample:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[67X\u001b[29;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mmbssid=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[9X\u001b[30;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27minterface=wlan2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[9X\u001b[31;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mctrl_interface=/run/hostapd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[38X\u001b[32;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_passphrase=0123456789\u001b[33;2Hieee80211w=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[52X\u001b[34;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27msae_pwe=1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[68X\u001b[35;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mauth_algs=1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[27X\u001b[36;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[28X\u001b[37;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_pairwise=CCMP\u001b[38;2Hssid=<SSID-0>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[40X\u001b[39;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbridge=br-lan\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[42X\u001b[40;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_key_mgmt=SAE\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[58X\u001b[41;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbssid=00:03:7f:12:84:84\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[54X\u001b[43;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbss=wlan2-1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[42X\u001b[44;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mctrl_interface=/run/hostapd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[28X\u001b[45;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_passphrase=0123456789\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[49X\u001b[46;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mieee80211w=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[65X\u001b[47;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27msae_pwe=1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[23X\u001b[48;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mauth_algs=1\u001b[49;2Hwpa=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[67X\u001b[50;2H\u001b(B\u001b[m\u001b[38;2"]
[0.000, "o", ";155;158;164m\u001b[48;2;20;22;27mwpa_pairwise=CCMP\r\n#ssid=<SSID-1>\u001b[52;2Hbridge=br-lan\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[28X\u001b[53;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mwpa_key_mgmt=SAE\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[9X\u001b[54;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbssid=00:03:7f:12:84:85\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m   \u001b[55;173H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3383,1         Bot\r\u001b[A\u001b[?25h"]
