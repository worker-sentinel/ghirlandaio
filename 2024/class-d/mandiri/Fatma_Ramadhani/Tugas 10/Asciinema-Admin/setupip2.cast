[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Access control for the control interface can be configured by setting the\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8,5  \u001b[54;5H\u001b[?25h"]
[0.049, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# directory to allow only members of a group to use sockets. This way, it is\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\u001b[54;5H\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# possible to run hostapd as root (since it needs to change network\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;173H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m70\u001b[54;5H\u001b[?25h"]
