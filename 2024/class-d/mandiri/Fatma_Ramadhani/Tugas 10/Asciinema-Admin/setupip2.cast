[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# configuration. The socket file will be named based on the interface name, so\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m1\u001b[54;5H\u001b[?25h"]
