[1.895, "o", "\u001b[37m\u001b[40m\u001b[20;32r\u001b[20;1H\u001b[6L\u001b[1;56r\u001b[5;108H\u001b[30m\u001b[47mDeactivate>\u001b[6;76H\u001b[37m\u001b[41m* enp62s0                \u001b[10;76H\u001b[30m\u001b[47m \u001b[11;76H* tronton            ▂▄▆█\u001b[12;103H▮\u001b[20;1H\u001b[97m\u001b[44m                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                            ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                            ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                            ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                            ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                            ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                            ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[6;76H"]
[2.872, "o", "\u001b[2;72H\u001b[K\u001b[3;72H\u001b[K\u001b[4;72H\u001b[K\u001b[5;72H\u001b[K\u001b[6;72H\u001b[K\u001b[7;72H\u001b[K\u001b[8;72H\u001b[K\u001b[9;72H\u001b[K\u001b[10;72H\u001b[K\u001b[11;72H\u001b[K\u001b[12;72H\u001b[K\u001b[13;72H\u001b[K\u001b[14;72H\u001b[K\u001b[15;72H\u001b[K\u001b[16;72H\u001b[K\u001b[17;72H\u001b[K\u001b[18;72H\u001b[K\u001b[19;72H\u001b[K\u001b[20;72H\u001b[K\u001b[21;72H\u001b[K\u001b[22;72H\u001b[K\u001b[23;72H           \u001b[30m\u001b[47m┌─┤ \u001b[31mNetworkManager TUI\u001b[30m ├──┐\u001b[97m\u001b[44m\u001b[K\u001b[24;72H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[25;72H           \u001b[30m\u001b[47m│ \u001b[34mPlease select an option\u001b[30m │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[26;72H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[27;72H           \u001b[30m\u001b[47m│ Edit a connection       │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[28;72H           \u001b[30m\u001b[47m│ \u001b[37m\u001b[41mActivate a connection  \u001b[30m\u001b[47m │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[29;72H           \u001b[30m\u001b[47m│ Set system hostname     │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[30;72H           \u001b[30m\u001b[47m│ Radio\u001b[13C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[31;72H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[32;72H           \u001b[30m\u001b[47m│ Quit\u001b[14C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[33;72H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[34;72H           \u001b[30m\u001b[47m│\u001b[19C <OK> │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[35;72H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[36;72H           \u001b[30m\u001b[47m└─────────────────────────┘\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001