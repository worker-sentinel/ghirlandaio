[0.000, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# configuration and open raw sockets) and still allow GUI/CLI components to be\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m1\u001b[54;5H\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# run as non-root users. However, since the control interface can be used to\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m2\u001b[54;5H\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# change the network configuration, this access needs to be protected in many\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\u001b[54;5H\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# cases. By default, hostapd is configured to use gid 0 (root). If you\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\u001b[54;5H\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# want to allow non-root users to use the control interface, add a new group\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\u001b[54;5H\u001b[?25h"]
[0.049, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# and change this value to match with that group. Add users that should have\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\u001b[54;5H\u001b[?25h"]
[0.048, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\u001b[54;5H\u001b[?25h"]
