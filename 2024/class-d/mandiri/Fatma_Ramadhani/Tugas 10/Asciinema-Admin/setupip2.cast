[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# interface.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;176H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?25h"]
[0.049, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;176H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.000, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The transmitting interface is visible to all stations in the vicinity, however\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;176H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\r\u001b[A\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.000, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# the stations that do not support parsing of the Multiple BSSID element will\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;176H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\r\u001b[A\u001b[?25h"]
[0.050, "o", "\u001b[?25l\u001b[56;180H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[56;180H   \u001b[1;54r\u001b[H\u001b[M\u001b[r\u001b[54;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# not be able to connect to the non-transmitting interfaces.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[55;176H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m7\r\u001b[A\u001b[?25h"]
