[0.747, "o", "\u001b[2;63H\u001b[30m\u001b[47m┌──────────────────────────────────────────┐\u001b[3;63H│                                          │\u001b[97m\u001b[40m \u001b[4;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m┌─────────────────────────┐\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[5;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m Wired                 ↑ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m <Activate>   │\u001b[97m\u001b[40m \u001b[6;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m \u001b[37m\u001b[41m  Wired connection 1\u001b[30m\u001b[47m  ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[7;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                       ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[8;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m Loopback              ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[9;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m * lo                  ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[10;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                       ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[11;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m Bridge (docker0)      ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[12;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m * docker0             ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[13;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                       ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[97m\u001b[40m \u001b[14;63H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u0