[0.001, "o", "\u001b[37m\u001b[40m\u001b[1;50r\u001b[H\u001b[2J\u001b[1;1H\u001b[97m\u001b[44m\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n                                                                       \u001b[30m\u001b[47m┌─┤ \u001b[31mNetworkManager TUI\u001b[30m ├──┐\u001b[97m\u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[34mPlease select an option\u001b[30m │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ \u001b[37m\u001b[41mEdit a connection      \u001b[30m\u001b[47m │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ Activate a connection   │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ Set system hostname     │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ Radio                   │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│ Quit                    │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│                    <OK> │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                       \u001b[30m\u001b[47m└─────────────────────────┘\u001b[97m\u001b[40m \u001b[44m\u001b[K\r\n                                                                        \u001b[40m                           \u001b[44m\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\n\u001b[K\u001b[24;74H"]
