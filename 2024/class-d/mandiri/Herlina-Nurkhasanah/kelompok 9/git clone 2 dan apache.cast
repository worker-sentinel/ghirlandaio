[0.004, "o", "\u001b[H \n\u001b[73X\u001b[3;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mNote that from this point forward you must specifically allow\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m  \u001b[4;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mparticular features to be enabled - so if something's not working as\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b[5;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27myou might expect, make sure that you have specifically enabled it\u001b[6;3Hbelow.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[52X\u001b[7;2H\u001b[50X\r\n \n\u001b[66X\u001b[10;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mDocumentRoot: The directory out of which you will serve your\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[14X\u001b[11;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mdocuments. By default, all requests are taken from this directory, but\u001b[12;2H symbolic links and aliases may be used to point to other locations.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[13;2H\u001b[71X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mDocumentRoot\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/srv/http\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[52X\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<Directory\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \"/srv/http\"\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[47X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[67X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # Possible values for the Options directive are \"None\", \"All\",\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[6X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # or any combination of:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[49X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #   Indexes \u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mInc\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mludes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\n    #\r\n    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\n    # doesn't give it to you.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[39X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[42X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # The Options directive is both complicated and important.  Please see\r\n    # http://httpd.apache.org/docs/2.4/mod/core.html#options\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[8X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # for more information.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[45X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[71X\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mOptions\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mIndexes\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mFollowSymLinks\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[38X\r\n\u001b[16X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\r\n    # AllowOverride controls what d