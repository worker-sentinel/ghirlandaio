[0.000, "o", "\u001b[?25l\u001b[59;180H   \u001b[1;57r\u001b[H\u001b[M\u001b[r\u001b[57;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# directives contained in it are actually available _before_ they are used.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[58;174H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\r\u001b[A\u001b[?25h"]
