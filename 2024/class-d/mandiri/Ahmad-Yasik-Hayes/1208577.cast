[0.001, "o", "\u001b[1;3H  Production Value: Off\u001b[37X\u001b[3;3Houtput_buffering\u001b[61X\u001b[4;3H  Default Value: Off\u001b[15X\r\n;   Development Value: 4096\u001b[6;3H  Production Value: 4096\u001b[19X\r\n\u001b[45X\u001b[8;3Hrequest_order\u001b[32X\r\n;   Default Value: None\u001b[10;3H  Development Value: \"GP\"\u001b[42X\u001b[11;3H  Production Value: \"GP\"\u001b[50X\r\n\u001b[77X\n; session.gc_divisor\u001b[14;2H   Default Value: 100\u001b[15;3H  Development Value: 1000\u001b[16;2H   Production Value: 1000\r\n\u001b[75X\u001b[18;3Hshort_open_tag\u001b[54X\u001b[19;3H  Default Value: On\u001b[6X\r\n;   Development Value: Off\u001b[21;3H  Production Value: Off\u001b[50X\r\n\u001b[75X\u001b[23;3Hvariables_order\u001b[53X\u001b[24;3H  Default Value: \"EGPCS\"\u001b[53X\r\n;   Development Value: \"GPCS\"\u001b[26;3H  Production Value: \"GPCS\"\u001b[49X\r\n\u001b[67X\u001b[28;3Hzend.assertions\u001b[57X\u001b[29;3H  Default Value: 1\u001b[52X\r\n;   Development Value: 1\u001b[31;3H  Production Value: -1\u001b[18X\u001b[33;2H zend.\u001b[30m\u001b[103mex\u001b[m\u000fception_ignore_args\u001b[34;3H  Default Value: Off\u001b[35;2H   Development Value: Off\r\n;   Production Value: On\r\n\u001b[81X\u001b[38;3Hzend.\u001b[30m\u001b[103mex\u001b[m\u000fception_string_param_max_len\u001b[40X\u001b[39;3H  Default Value: 15\u001b[60X\u001b[40;3H  Development Value: 15\u001b[22X\r\n;   Production Value: 0\r\n\u001b[16X\u001b[43;2H;;;;;;;;;;;;;;;;;;; \u001b[44;3Hphp.ini Options  ;\u001b[5X\u001b[45;2H;;;;;;;;;;;;;;;;;;;\u001b[5X\r\n; Name for user-defined php.ini (.htaccess) files. Default is \".user.ini\"\u001b[47;2Huser_ini.filename = \".user.ini\"\r\n\u001b[21X\u001b[49;3HTo disable this feature set this option to an empty value\u001b[50;2Huser_ini.filename =\u001b[5X\u001b[52;3HTTL for user-defined php.ini files (time-to-live) in seconds. Default is 300 seconds (5 minutes)\u001b[53;2Huser_ini.cache_ttl = 300\r\n\u001b[28X\u001b[55;2H;;;;;;;;;;;;;;;;;;;\u001b[23X\r\n; Language Options ;\u001b[57;2H;;;;;;;;;;;;;;;;;;;\r\n\u001b[22X\u001b[59;3HEnable the PHP scripting language engine under Apache.\u001b[60;3Hhttps://php.net/engine\r\nengine =\u001b[92m On\u001b[m\u000f\r\n\u001b[16X\u001b[63;3HThis directive determines whether or not PHP will recognize code between\u001b[64;3H<? and ?> tags as PHP source which should be processed as such. It is\u001b[65;3Hgenerally recommended that <?php and ?> should be used and that this feature\u001b[66;224H\u001b[0;10;7m\u000f57,8           6\u001b[67;4H\u001b[?25h"]
[0.419, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.001, "o", "\u001b[1;2Hhighlight.string  = #DD0000\r\n;highlight.comment = #FF9900\u001b[3;2Hhighlight.keyword = #007700\u001b[4;2Hhighlight.default = #0000BB\u001b[5;2Hhighlight.html    = #000000\r\n\u001b[26X\n; If enabled, the request will be allowed to complete even if the user aborts\u001b[8;3Hthe request. Consider enabling it if executing long requests, which may end up\u001b[9;3Hbeing interrupted by the user or a browser timing out. PHP's default behavior\u001b[10;3His to disable this feature.\u001b[11;3Hhttps://php.net/ignore-user-abort\r\n;ignore_user_abort = On\r\n\u001b[20X\u001b[14;3HDetermines the size of the realpath cache to be used by PHP. This value should\u001b[15;3Hbe increased on systems where PHP opens many files to reflect the quantity of\u001b[16;3Hthe file operations performed.\r\n; Note: if open_basedir is set, the cache is disabled\u001b[18;3Hhttps://php.net/realpath-cache-size\u001b[19;2Hrealpath_cache_size = 4096k\r\n\u001b[26X\u001b[21;3HDuration of time, in seconds for which to cache realpath information for a given\r\n; file or directory. For systems with rarely changing files, consider increasing this\u001b[23;5Hlue.\u001b[9X\u001b[24;3Hhttps://php.net/realpath-cache-ttl\u001b[25;2Hrealpath_cache_ttl = 120    \r\n\u001b[28X\n; Enables or disables the circular reference collector.\u001b[28;3Hhttps://php.net/zend.enable-gc\r\nzend.enable_gc =\u001b[92m On\u001b[m\u000f \r\n\u001b[24X\u001b[31;3HIf enabled, scripts may be written in encodings that are incompatible with\r\n; the scanner.  CP936, Big5, CP949 and Shift_JIS are the examples of such\u001b[33;3Hencodings.  To use this feature, mbstring \u001b[30m\u001b[103mext\u001b[m\u000fension must be enabled.\u001b[34;2Hzend.multibyte = Off \r\n\u001b[26X\u001b[36;3HAllows to set the default encoding for the scripts.  This value will be used\r\n; unless \"declare(encoding=...)\" directive appears at the top of the script.\u001b[38;3HOnly affects if zend.multibyte is set.\u001b[39;2Hzend.script_encoding =\r\n\u001b[25X\u001b[41;3HAllows to include or exclude arguments from stack traces generated for exceptions.\r\n; In production, it is recommended to turn this setting on to prohibit the output\u001b[43;2H of sensitive information in stack traces\u001b[44;3HDefault Value: Off\u001b[45;2H Development Value: Off\u001b[46;3HProduction Value: On\u001b[51X\r\nzend.exception_ignore_args =\u001b[92m On\u001b[m\u000f \u001b[49;3HAllows setting the maximum string length in an argument of a stringified stack trace\u001b[50;2H to a value between 0 and 1000000.\r\n; This has no effect when zend.exception_ignore_args is enabled.\u001b[52;3HDefault Value: 15\u001b[79X\u001b[53;2H Development Value: 15  \r\n; Production Value: 0\u001b[55;2H In production, it is recommended to set this to 0 to reduce the output\u001b[56;3Hof sensitive information in stack traces.\r\nzend.exception_string_param_max_len = 0\u001b[59;2H;;;;;;;;;;;;;;;;\u001b[39X\u001b[60;3HMiscellaneous ;\u001b[7X\r\n;;;;;;;;;;;;;;;;;\u001b[63;3HDecides whether PHP may expose the fact that it is installed on the server\u001b[64;3H(e.g. by adding its signature to the Web server header).  It is no security\u001b[65;3Hthreat in any way, but it makes it possible to determine whether you use PHP\u001b[66;223H\u001b[0;10;7m\u000f360,45         18\u001b[67;5H\u001b[?25h"]
