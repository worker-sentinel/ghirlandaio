[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Use this to compress the initramfs image. By default, zstd compression\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           34\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# is used for Linux ≥\u001b[46;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           37\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Use 'cat' to create an uncompressed image.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f60,1           40\r\u001b[A\u001b[?25h"]
