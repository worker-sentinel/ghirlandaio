[0.030, "o", "\u001b[1m\u001b[33m==> WARNING:\u001b[m\u000f \u001b[1mPreset file '/etc/mkinitcpio.d/Linux-hardened.preset' is empty or does not contain any presets.\u001b[m\u000f\r\n"]
