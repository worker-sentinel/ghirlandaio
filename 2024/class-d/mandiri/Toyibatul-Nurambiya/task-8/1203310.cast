[0.032, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H#    HOOKS=(base)\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           91\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H##   No RAID, lvm2, or encrypted root is needed.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           88\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H##   This setup specifies all modules in the MODULES setting above.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           85\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# Examples:\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f0,1           82\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f29,1           80\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# 'udev' is _required_ in order to automatically load modules\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           77\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1           74\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# help on a given hook.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           71\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           68\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# Order is important, and it is recommended that you do not change the\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1           65\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# modules and scripts added to the image, and what happens at boot time.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           62\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# This is the most important setting in this file.  The HOOKS control the\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           60\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# HOOKS\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           57\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f0,1           54\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[HFILES=()\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f19,1           51\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           48\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# This setting is similar to BINARIES above, however, files are added\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1           45\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H# FILES\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           42\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;48r\u001b[H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           40\u001b[H\u001b[?25h"]
