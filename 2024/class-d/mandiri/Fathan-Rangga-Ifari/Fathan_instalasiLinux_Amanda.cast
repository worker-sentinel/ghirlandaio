[0.031, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f4,1           81\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# creation. Switch (yes/no).\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f5,1           84\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# Enable to allow further decreasing image size when using high compression\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f6,1           86\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# (e.g. xz -9e or zstd --long --ultra -22) at the expense of increased RAM usage\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f7,1           89\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# at early boot.\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f8,1           92\r\u001b[A\u001b[?25h"]
[0.055, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# Note that any compressed files will be placed in the uncompressed early CPIO\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f9,1           94\r\u001b[A\u001b[?25h"]
[0.021, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# to avoid double compression.\u001b[K\u001b[44;143H\u001b[0;10;7m\u000f80,1           97\r\u001b[A\u001b[?25h"]
