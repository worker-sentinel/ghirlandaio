[0.032, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# COMPRESSION_OPTIONS\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f9,1           68\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H# Additional options for the compressor\u001b[K\u001b[44;143H\u001b[0;10;7m\u000f70,1           71\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H#COMPRESSION_OPTIONS=()\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f1,1           73\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f2,1           76\r\u001b[A\u001b[?25h"]
