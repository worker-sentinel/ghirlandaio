[0.002, "o", "\u001b[1;1H\u001b[1m\u001b[36m# /dev/mapper/ondut-root\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m7d8382da-47b4-414b-ae01-33cac22883fe\u001b[m\u000f       /               \u001b[1m\u001b[32mext4\u001b[m\u000f            \u001b[1m\u001b[32mrw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f     \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m1\u001b[m\u000f\u001b[2;100H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[1m\u001b[36m# /dev/nvme0n1p5 LABEL=BOOT\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35mC9DB-CD21\u001b[m\u000f\u001b[10C/boot\u001b[11C\u001b[1m\u001b[32mvfat\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[1m\u001b[33m,fmask=\u001b[m\u000f\u001b[1m\u001b[35m0077\u001b[m\u000f\u001b[1m\u001b[33m,dmask=\u001b[m\u000f\u001b[1m\u001b[35m0077\u001b[m\u000f\u001b[1m\u001b[33m,codepage=\u001b[m\u000f\u001b[1m\u001b[35m437\u001b[m\u000f\u001b[1m\u001b[33m,iocharset=\u001b[m\u000f\u001b[1m\u001b[35mascii\u001b[m\u000f\u001b[1m\u001b[33m,shortname=\u001b[m\u000f\u001b[1m\u001b[35mmixed\u001b[m\u000f\u001b[1m\u001b[33m,utf8,errors=\u001b[m\u000f\u001b[1m\u001b[35mremount-ro\u001b[m\u000f    \u001b[6;1H\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/ondut-vars\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m79625b00-4141-4a4e-8890-a48c9458bed5\u001b[m\u000f\u001b[7C/var\u001b[12C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b