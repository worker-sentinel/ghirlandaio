[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H##   Note: See 'mkinitcpio -H mdadm_udev' for more information on RAID devices.\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f4,1            2%\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H#    HOOKS=(base udev microcode modconf keyboard keymap consolefont block mdadm_udev encrypt filesystems fsck)\u001b[K\u001b[44;144H\u001b[0;10;7m\u000f5,1            5\r\u001b[A\u001b[?25h"]
