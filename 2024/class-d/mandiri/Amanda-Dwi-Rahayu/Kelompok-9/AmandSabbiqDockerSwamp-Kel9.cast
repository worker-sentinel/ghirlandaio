[0.001, "o", "Optional dependencies for cockpit\r\n    cockpit-storaged: manage storage\r\n    cockpit-packagekit: manage packaged\r\n    cockpit-podman: user interface for managing podman containers\r\n    cockpit-machines: user interface for managing virtual machines\r\n    pcp: reading performance metrics\r\n    polkit: elevate privileges\r\n    sudo: elevate privileges [installed]\r\n    networkmanager: manage network connections\r\n    sssd: authentication\r\n    sscg: generate self-signed certificate\r\n"]
[0.056, "o", ":: Running post-transaction hooks...\r\n(1/6) Creating temporary files...\r\n"]
[0.080, "o", "(2/6) Reloading system manager configuration...\r\n"]
[0.313, "o", "(3/6) Reloading user manager configuration...\r\n"]
[0.274, "o", "(4/6) Arming ConditionNeedsUpdate...\r\n"]
[0.041, "o", "(5/6) Updating GIO module cache...\r\n"]
[0.056, "o", "(6/6) Compiling GSettings XML schema files...\r\n"]
