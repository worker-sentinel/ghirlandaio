[0.022, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-lts.preset: 'default'\u001b[m\u000f\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.conf'\u001b[m\u000f\r\n  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux-lts -c /etc/mkinitcpio.conf -U boot/EFI/Linux/arch-linux-lts.efi\u001b[m\u000f\r\n"]
[0.013, "o", "==> ERROR: Invalid option -U -- '/boot/EFI/Linux/arch-linux-lts.efi' must be writable\r\n"]
