[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##   This setup loads an lvm2 volume group.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1            2%\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#    HOOKS=(base udev microcode modconf block lvm2 filesystems fsck)\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1            5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1            8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##   This will create a systemd based initramfs which loads an encrypted root filesystem.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f50,1           11\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#    HOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block sd-encrypt filesystems fsck)\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           14\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           17\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##   NOTE: If you have /usr on a separate partition, you MUST include the\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           20\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#    usr and fsck hooks.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1           22\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1HHOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block filesystems fsck)\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           25\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           28\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# COMPRESSION\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1           31\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Use this to compress the initramfs image. By default, zstd compression\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           34\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# is used for Linux ≥\u001b[46;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           37\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Use 'cat' to create an uncompressed image.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f60,1           40\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"zstd\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           42\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"gzip\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           45\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"bzip2\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           48\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"lzma\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1           51\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"xz\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           54\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"lzop\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           57\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"lz4\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1           60\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           62\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# COMPRESSION_OPTIONS\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           65\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Additional options for the compressor\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f70,1           68\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION_OPTIONS=()\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           71\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           74\r\u001b[A\u001b[?25h"]
