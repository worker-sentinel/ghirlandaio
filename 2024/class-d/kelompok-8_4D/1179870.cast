[0.130, "o", ":: Install your bootloader and generate configuration with:\r\n"]
[0.001, "o", "     # grub-install ...\r\n     # grub-mkconfig -o /boot/grub/grub.cfg\r\nOptional dependencies for grub\r\n\u001b[0;1m   \u001b[0m dosfstools: For grub-mkrescue FAT FS and EFI support\r\n    efibootmgr: For grub-install EFI support [installed]\r\n    freetype2: For grub-mkfont usage\r\n    fuse3: For grub-mount usage\r\n    libisoburn: Provides xorriso for generating grub rescue iso using grub-mkrescue\r\n"]
[0.005, "o", "    libusb: For grub-emu USB support\r\n    lzop: For grub-mkrescue LZO support\r\n    mtools: For grub-mkrescue FAT FS support\r\n    os-prober: To detect other OSes when generating grub.cfg in BIOS systems [pending]\r\n    sdl: For grub-emu SDL support\r\n(7/7) installing os-prober                                                                                                                       [----------------------------------------------------------------------------------------]   0%\r(7/7) installing os-prober                                                                                                                       [########################################################################################] 100%\r\r\n"]
