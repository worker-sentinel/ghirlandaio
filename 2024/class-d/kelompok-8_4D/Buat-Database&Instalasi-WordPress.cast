[0.025, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.003, "o", "\u001b[?25l\u001b[m\u000f; Start a new pool named 'www'.\u001b[K\r\n; the variable $pool can be used in any directive and will be replaced by the\u001b[K\r\n; pool name ('www' here)\u001b[K\r\n\u001b[96m[www]\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Per pool prefix\u001b[K\r\n; It only applies on the following directives:\u001b[K\r\n; - 'access.log'\u001b[K\r\n; - 'slowlog'\u001b[K\r\n; - 'listen' (unixsocket)\u001b[K\r\n; - 'chroot'\u001b[K\r\n; - 'chdir'\u001b[K\r\n; - 'php_values'\u001b[K\r\n; - 'php_admin_values'\u001b[K\r\n; When not set, the global prefix (or /usr) applies instead.\u001b[K\r\n; Note: This directive can also be relative to the global prefix.\u001b[K\r\n; Default Value: none\u001b[K\r\n;prefix = /path/to/pools/$pool\u001b[K\r\n\u001b[K\n; Unix user/group of the child processes. This can be used only if the master\u001b[K\r\n; process running user is root. It is set after the child process is created.\u001b[K\r\n; The user and group can be specified either by their name or by their numeric\u001b[K\r\n; IDs.\u001b[K\r\n; Note: If the user is root, the executable needs to be started with\u001b[K\r\n;       --allow-to-run-as-root option to work.\u001b[K\r\n; Default Values: The user is set to master process running user by default.\u001b[K\r\n;                 If the group is not set, the user's group is used.\u001b[K\r\nuser =\u001b[92m http\u001b[m\u000f\u001b[K\r\ngroup =\u001b[92m http\u001b[m\u000f\u001b[K\r\n\u001b[K\n; The address on which to accept FastCGI requests.\u001b[K\r\n; Valid syntaxes are:\u001b[K\r\n;   'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   'port'                 - to listen on a TCP socket to all addresses\u001b[K\r\n;                            (IPv6 and IPv4-mapped) on a specific port;\u001b[K\r\n;   '/path/to/unix/socket' - to listen on a unix socket.\u001b[K\r\n; Note: This value is mandatory.\u001b[K\r\nlisten =\u001b[92m /run/php-fpm/php-fpm.sock\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Set listen(2) backlog.\u001b[K\r\n; Default Value: 511 (-1 on Linux, FreeBSD and OpenBSD)\u001b[K\r\n;listen.backlog = 511\u001b[K\r\n\u001b[K\n; Set permissions for unix socket, if one is used. In Linux, read/write\u001b[K\r\n; permissions must be set in order to allow connections from a web server. Many\u001b[K\r\n; BSD-derived systems allow connections regardless of permissions. The owner\u001b[K\r\n; and group can be specified either by name or by their numeric IDs.\u001b[K\r\n; Default Values: Owner is set to the master process running user. If the group\u001b[K\r\n;                 is not set, the owner's group is used. Mode is set to 0660.\u001b[K\r\nlisten.owner =\u001b[92m http\u001b[m\u000f\u001b[K\r\nlisten.group =\u001b[92m http\u001b[m\u000f\u001b[K\r\n;listen.mode = 0660\u001b[K\r\n\u001b[K\n; When POSIX Access Control Lists are supported you can set them using\u001b[K\r\n; these options, value is a comma separated list of user/group names.\u001b[K\r\n; When set, listen.owner and listen.group are ignored\u001b[K\r\n;listen.acl_users =\u001b[K\r\n;listen.acl_groups =\u001b[K\r\n\u001b[K\n; List of addresses (IPv4/IPv6) of FastCGI clients which are allowed to connect.\u001b[K\r\n; Equivalent to the FCGI_WEB_SERVER_ADDRS environment variable in the original\u001b[K\r\n; PHP FCGI (5.2.2+). Makes sense only with a tcp listening socket. Each address\u001b[K\r\n\u001b[0;10;7m\u000f/etc/php/php-fpm.d/www.conf                                                                                                                                                                                                   1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H; Start a new pool named 'www'.\u001b[K\r\n; the variable $pool can be used in any directive and will be replaced by the\u001b[K\r\n; pool name ('www' here)\u001b[K\r\n\u001b[96m[www]\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Per pool prefix\u001b[K\r\n; It only applies on the following directives:\u001b[K\r\n; - 'access.log'\u001b[K\r\n; - 'slowlog'\u001b[K\r\n; - 'listen' (unixsocket)\u001b[K\r\n; - 'chroot'\u001b[K\r\n; - 'chdir'\u001b[K\r\n; - 'php_values'\u001b[K\r\n; - 'php_admin_values'\u001b[K\r\n; When not set, the global prefix (or /usr) applies instead.\u001b[K\r\n; Note: This directive can also be relative to the global prefix.\u001b[K\r\n; Default Value: none\u001b[K\r\n;prefix = /path/to/pools/$pool\u001b[K\r\n\u001b[K\n; Unix user/group of the child processes. This can be used only if the master\u001b[K\r\n; process running user is root. It is set after the child process is created.\u001b[K\r\n; "]
[0.000, "o", "The user and group can be specified either by their name or by their numeric\u001b[K\r\n; IDs.\u001b[K\r\n; Note: If the user is root, the executable needs to be started with\u001b[K\r\n;       --allow-to-run-as-root option to work.\u001b[K\r\n; Default Values: The user is set to master process running user by default.\u001b[K\r\n;                 If the group is not set, the user's group is used.\u001b[K\r\nuser =\u001b[92m http\u001b[m\u000f\u001b[K\r\ngroup =\u001b[92m http\u001b[m\u000f\u001b[K\r\n\u001b[K\n; The address on which to accept FastCGI requests.\u001b[K\r\n; Valid syntaxes are:\u001b[K\r\n;   'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   'port'                 - to listen on a TCP socket to all addresses\u001b[K\r\n;                            (IPv6 and IPv4-mapped) on a specific port;\u001b[K\r\n;   '/path/to/unix/socket' - to listen on a unix socket.\u001b[K\r\n; Note: This value is mandatory.\u001b[K\r\nlisten =\u001b[92m /run/php-fpm/php-fpm.sock\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Set listen(2) backlog.\u001b[K\r\n; Default Value: 511 (-1 on Linux, FreeBSD and OpenBSD)\u001b[K\r\n;listen.backlog = 511\u001b[K\r\n\u001b[K\n; Set permissions for unix socket, if one is used. In Linux, read/write\u001b[K\r\n; permissions must be set in order to allow connections from a web server. Many\u001b[K\r\n; BSD-derived systems allow connections regardless of permissions. The owner\u001b[K\r\n; and group can be specified either by name or by their numeric IDs.\u001b[K\r\n; Default Values: Owner is set to the master process running user. If the group\u001b[K\r\n;                 is not set, the owner's group is used. Mode is set to 0660.\u001b[K\r\nlisten.owner =\u001b[92m http\u001b[m\u000f\u001b[K\r\nlisten.group =\u001b[92m http\u001b[m\u000f\u001b[K\r\n;listen.mode = 0660\u001b[K\r\n\u001b[K\n; When POSIX Access Control Lists are supported you can set them using\u001b[K\r\n; these options, value is a comma separated list of user/group names.\u001b[K\r\n; When set, listen.owner and listen.group are ignored\u001b[K\r\n;listen.acl_users =\u001b[K\r\n;listen.acl_groups =\u001b[K\r\n\u001b[K\n; List of addresses (IPv4/IPv6) of FastCGI clients which are allowed to connect.\u001b[K\r\n; Equivalent to the FCGI_WEB_SERVER_ADDRS environment variable in the original\u001b[K\r\n; PHP FCGI (5.2.2+). Makes sense only with a tcp listening socket. Each address\u001b[K\r\n\u001b[0;10;7m\u000f/etc/php/php-fpm.d/www.conf                                                                                                                                                                                                   1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
