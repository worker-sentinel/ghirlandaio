an \u001b[30m\u001b[103me\u001b[m\u000fxp\u001b[30m\u001b[103me\u001b[m\u000fct\u001b[30m\u001b[103me\u001b[m\u000fd\u001b[40;6H\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f b\u001b[30m\u001b[103me\u001b[m\u000fcaus\u001b[30m\u001b[103me\u001b[m\u000f it is not s\u001b[30m\u001b[103me\u001b[m\u000ft or is mistyp\u001b[30m\u001b[103me\u001b[m\u000fd, a d\u001b[30m\u001b[103me\u001b[m\u000ffault valu\u001b[30m\u001b[103me\u001b[m\u000f will b\u001b[30m\u001b[103me\u001b[m\u000f us\u001b[30m\u001b[103me\u001b[m\u000fd\u001b[42;5H\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000f can b\u001b[30m\u001b[103me\u001b[m\u000f a string, a numb\u001b[30m\u001b[103me\u001b[m\u000fr, a PHP constant (\u001b[30m\u001b[103me\u001b[m\u000f.g. E_ALL or M_PI), on\u001b[30m\u001b[103me\u001b[43;8He\u001b[m\u000f INI constants (On, Off, Tru\u001b[30m\u001b[103me\u001b[m\u000f, Fals\u001b[30m\u001b[103me\u001b[m\u000f, Y\u001b[30m\u001b[103me\u001b[m\u000fs, No and Non\u001b[30m\u001b[103me\u001b[m\u000f) or an \u001b[30m\u001b[103me\u001b[m\u000fxpr\u001b[30m\u001b[103me\u001b[44;4He\u001b[m\u000f.g. E_ALL & ~E_NOTICE), a quot\u001b[30m\u001b[103me\u001b[m\u000fd string (\"bar\"), or a r\u001b[30m\u001b[103me\u001b[m\u000ff\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[45;5He\u001b[m\u000fviously s\u001b[30m\u001b[103me\u001b"]
[0.001, "o", "[m\u000ft variabl\u001b[30m\u001b[103me\u001b[m\u000f or dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f (\u001b[30m\u001b[103me\u001b[47;7He\u001b[m\u000fssions in th\u001b[30m\u001b[103me\u001b[m\u000f INI fil\u001b[30m\u001b[103me\u001b[m\u000f ar\u001b[30m\u001b[103me\u001b[m\u000f limit\u001b[30m\u001b[103me\u001b[m\u000fd to bitwis\u001b[30m\u001b[103me\u001b[m\u000f op\u001b[30m\u001b[103me\u001b[m\u000frators and par\u001b[30m\u001b[103me\u001b[m\u000fnth\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[48;12He\u001b[49;12He\u001b[50;12He\u001b[51;12He\u001b[52;10He\u001b[54;7He\u001b[m\u000fan flags can b\u001b[30m\u001b[103me\u001b[m\u000f turn\u001b[30m\u001b[103me\u001b[m\u000fd on using th\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000fs 1, On, Tru\u001b[30m\u001b[103me\u001b[m\u000f or Y\u001b[30m\u001b[103me\u001b[55;5He\u001b[m\u000fy can b\u001b[30m\u001b[103me\u001b[m\u000f turn\u001b[30m\u001b[103me\u001b[m\u000fd off using th\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000fs 0, Off, Fals\u001b[30m\u001b[103me\u001b[57;6He\u001b[m\u000fmpty string can b\u001b[30m\u001b[103me\u001b[m\u000f d\u001b[30m\u001b[103me\u001b[m\u000fnot\u001b[30m\u001b[103me\u001b[m\u000fd by simply not writing anything aft\u001b[30m\u001b[103me\u001b[m\u000fr th\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[58;23He\u001b[m\u000f Non\u001b[30m\u001b[103me\u001b[m\u000f k\u001b[30m\u001b[103me\u001b[60;20He\u001b[m\u000fts foo to an \u001b[30m\u001b[103me\u001b[61;12He\u001b[m\u000f    ; s\u001b[30m\u001b[103me\u001b[m\u000fts foo to an \u001b[30m\u001b[103me\u001b[62;13He\u001b[m\u000f\"  ; s\u001b[30m\u001b[103me\u001b[m\u000fts foo to th\u001b[30m\u001b[103me\u001b[m\u000f string 'Non\u001b[30m\u001b[103me\u001b[64;12He\u001b[m\u000f constants in your valu\u001b[30m\u001b[103me\u001b[m\u000f, and th\u001b[30m\u001b[103me\u001b[m\u000f