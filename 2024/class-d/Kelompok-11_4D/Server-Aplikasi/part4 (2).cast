[0.001, "o", "\u001b[2;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mAll of these directives may appear inside <VirtualHost> containers,\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[5X\u001b[3;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27min which case these default settings will be overridden for the\u001b[4;3Hvirtual host being defined.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[42X\u001b[5;2H\u001b[20X\r\n\u001b[60X\u001b[7;2H\u001b[50X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m ServerAdmin: Your address, where problems with the server should be\u001b[9;3He-mailed.  This address appears on some server-generated pages, such\u001b[10;3Has error documents.  e.g. admin@your-domain.com\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[27X\u001b[11;2H\u001b[49X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mServerAdmin\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m you@\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mexample\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m.com\r\n\u001b[72X\u001b[14;2H\u001b[75X\u001b[15;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mServerName gives the name and port that the server uses to identify itself.\u001b[16;3HThis can often be determined automatically, but we recommend you specify\u001b[17;3Hit explicitly to prevent problems during startup.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[21X\u001b[18;2H\u001b[76X\u001b[19;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mIf your host doesn't have a registered DNS name, enter its IP address here.\r\n#\nServerName www.example.com:80\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[68X\u001b[23;2H\u001b[46X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m Deny access to the entirety of your server's filesystem. You must\u001b[25;3Hexplicitly permit access to web content directories in other \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[5X\u001b[26;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m<Directory> blocks below.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[45X\u001b[27;2H\u001b[75X\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<Directory\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m /\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[59X\r\n    \u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mAllowO\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mverride\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mRequire\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mall\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m denied\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m</Directory>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[11X\u001b[34;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mNote that from this point forward you must specifically allow\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[8X\u001b[35;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mparticular features to be enabled - so if something's not working as\u001b[36;2H you might expect, make sure that you have specifically enabled it\u001b[37;3Hbelow.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[70X\u001b[38;2H\u001b[75X\r\n\u001b[15X\u001b[41;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mDocumentRoot: The directory out of which you will serve your\r\n# documents. By default, all requests are taken from this directory, but\u001b[43;2H symbolic links and aliases may be used to point to other locations.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[44;2H\u001b[66X\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mDocumentRoot\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/srv/http\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[35X\r\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m<Directory\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \"/srv/http\"\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m>\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #\r\n    # Possible values for the Options directive are \"None\", \"All\",\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # or any combination of:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[31X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\n    #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[17X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\n    # doesn't give it to you.\r\n    #\r\n    # The Options "]
