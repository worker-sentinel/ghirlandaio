[0.080, "o", "2026-06-23  3:13:15 0 [Warning] mariadbd: io_uring_queue_init() failed with EPERM: sysctl kernel.io_uring_disabled has the value 2, or 1 and the user of the process is not a member of sysctl kernel.io_uring_group. (see man 2 io_uring_setup).\r\ncreate_uring failed: falling back to libaio\r\n2026-06-23  3:13:15 0 [Warning] InnoDB: native AIO failed: falling back to innodb_use_native_aio=OFF\r\n"]
[0.029, "o", "/usr/bin/mariadbd: Too many arguments (first extra is '==basedir=/usr').\r\n2026-06-23  3:13:15 0 [ERROR] Aborting\r\n"]
[0.022, "o", "\r\nInstallation of system tables failed!  Examine the logs in\r\n/var/lib/mysql for more information.\r\n\r\nThe problem could be conflicting information in an external\r\nmy.cnf files. You can ignore these by doing:\r\n"]
[0.000, "o", "\r\n    shell> /usr/bin/mariadb-install-db --defaults-file=~/.my.cnf\r\n\r\n"]
[0.000, "o", "You can also try to start the mariadbd daemon with:\r\n\r\n"]
[0.000, "o", "    shell> /usr/bin/mariadbd --skip-grant-tables --general-log &\r\n\r\nand use the command line tool /usr/bin/mariadb\r\nto connect to the mysql database and look at the grant tables:\r\n\r\n    shell> /usr/bin/mariadb -u root mysql\r\n    MariaDB> show tables;\r\n"]
[0.000, "o", "\r\nTry '/usr/bin/mariadbd --help' if you have problems with paths.  Using\r\n--general-log gives you a log in /var/lib/mysql that may be helpful.\r\n"]
[0.000, "o", "\r\nThe latest information about mariadb-install-db is available at\r\n"]
[0.000, "o", "https://mariadb.com/kb/en/installing-system-tables-mysql_install_db\r\n"]
[0.000, "o", "You can find the latest source at https://downloads.mariadb.org and\r\n"]
[0.000, "o", "the MariaDB discuss email list at https://lists.mariadb.org/postorius/lists/discuss.lists.mariadb.org/\r\n\r\n"]
[0.000, "o", "Please check all of the above before submitting a bug report\r\nat https://mariadb.org/jira\r\n\r\n"]
[0.000, "o", "\u001b]0;root@khai:/home/khairunnisa\u0007"]
[0.000, "o", "\u001b[?2004h[root@khai khairunnisa]# "]
[8.784, "o", "mariadb-install-db --user=mysql ==basedir=/usr --datadir=/var/lib/mysql"]
