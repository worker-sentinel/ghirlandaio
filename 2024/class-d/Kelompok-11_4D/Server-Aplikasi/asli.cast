\u001b[48;2;20;22;27merialize_pre\u001b[28;5H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27men_basedir, if set, limits all file operations to the d\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mef\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mined dire\u001b[29;8Helow.  This directive makes most sense if used in a per-dire\u001b[30;7Her-virtualhost web server configuration file\u001b[31;6He: disables the realpath cache\u001b[32;16Het/open-base\u001b[33;4Hen_base\n\nective allows you to disable ce\u001b[36;7Heceives a comma-delimited list of function name\u001b[37;16Het/disable\u001b[38;7H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27me\u001b[40;37H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27me.  Anything that's acceptable\u001b[41;13He\u001b[42;16He\u001b[44;16He\u001b[45;13He\n\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mf\u001b[49;6H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27menabled, the request will be allowed to complete even if the use\u001b[50;5He request. Consider enabling it if executing long requests, which may e\u001b[51;4Heing interrupted by the user or a browser timing out. PHP's d\u001b(B\u001b[m\u001b[38;2;238;241;248m\u001b[48;2;107;83;0mef\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mault be\u001b[52;15He this feature\u001b[53;16Het/ignore-use\u001b[54;7He_use\u001b[56;4Hetermines the size of the realpath cache to be used by PHP. This value\u001b[57;4He increased on systems where PHP opens many files to r\u001b(B\u001b[m\u001b[38;2;7;8;13m\u001b[48;2;252;224;148mef\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mlect the\u001b[58;177H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m58\u001b[59;4H\u001b[?25h"]
