[0.005, "o", "\u001b[1;4H\u001b[30m\u001b[103me\u001b[m\u000fqu\u001b[30m\u001b[103me\u001b[m\u000fst_ord\u001b[30m\u001b[103me\u001b[2;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[m\u000f: Non\u001b[30m\u001b[103me\u001b[3;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[4;20He\u001b[6;4He\u001b[7;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[8;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[9;20He\u001b[11;11He\u001b[12;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[13;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[14;20He\u001b[16;10He\u001b[m\u000fs_ord\u001b[30m\u001b[103me\u001b[17;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[18;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[19;20He\u001b[21;4He\u001b[m\u000fnd.ass\u001b[30m\u001b[103me\u001b[22;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[23;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[24;20He\u001b[26;4He\u001b[m\u000fnd.\u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[m\u000fption_ignor\u001b[30m\u001b[103me\u001b[27;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[28;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[29;20He\u001b[31;4He\u001b[m\u000fnd.\u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[m\u000fption_string_param_max_l\u001b[30m\u001b[103me\u001b[32;6He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[33;6He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[34;20He\u001b[39;6He\u001b[m\u000f for us\u001b[30m\u001b[103me\u001b[m\u000fr-d\u001b[30m\u001b[103me\u001b[m\u000ffin\u001b[30m\u001b[103me\u001b[m\u000fd php.ini (.htacc\u001b[30m\u001b[103me\u001b[m\u000fss) fil\u001b[30m\u001b[103me\u001b[m\u000fs. D\u001b[30m\u001b[103me\u001b[m\u000ffault is \".us\u001b[30m\u001b[103me\u001b[40;4He\u001b[m\u000fr_ini.fil\u001b[30m\u001b[103me\u001b[m\u000fnam\u001b[30m\u001b[103me\u001b[m\u000f = \".us\u001b[30m\u001b[103me\u001b[42;12He\u001b[m\u000f this f\u001b[30m\u001b[103me\u001b[m\u000fatur\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000ft this option to an \u001b[30m\u001b[103me\u001b[m\u000fmpty valu\u001b[30m\u001b[103me\u001b[43;4He\u001b[m\u000fr_ini.fil\u001b[30m\u001b[103me\u001b[m\u000fnam\u001b[30m\u001b[103me\u001b[45;13He\u001b[m\u000fr-d\u001b[30m\u001b[103me\u001b[m\u000ffin\u001b[30m\u001b[103me\u001b[m\u000fd php.ini fil\u001b[30m\u001b[103me\u001b[m\u000fs (tim\u001b[30m\u001b[103me\u001b[m\u000f-to-liv\u001b[30m\u001b[103me\u001b[m\u000f) in s\u001b[30m\u001b[103me\u001b[m\u000fconds. D\u001b[30m\u001b[103me\u001b[m\u000ffault is 300 s\u001b[30m\u001b[103me\u001b[m\u000fconds (5 minut\u001b[30m\u001b[103me\u001b[46;4He\u001b[m\u000fr_ini.cach\u001b[30m\u001b[103me\u001b[47;157H\u001b[0;10;7m\u000f4\u001b[48;3H\u001b[?25h"]
[0.257, "o", "\u001b[?25l\u001b[m\u000fx"]
[0.007, "o", "\u001b[H\u001b[15X\u001b[2;3HEnable the PHP scripting language engine under Apache.\u001b[3;3Hhttps://php.net/engine   \r\nengine =\u001b[92m On\u001b[m\u000f\u001b[15X\u001b[6;3HThis directive determines whether or not PHP will recognize code between\u001b[7;3H<? and ?> tags as PHP source which should be processed as such. It is\u001b[8;3Hgenerally recommended that <?php and ?> should be used and that this feature\u001b[9;3Hshould be disabled, as enabling it may result in issues when generating XML\r\n; documents, however this remains supported for backward compatibility reasons.\u001b[11;3HNote that this directive does not control the <?= shorthand tag, which can be\u001b[12;3Hused regardless of this directive.\u001b[13;3HDefault Value: On\u001b[7X\u001b[14;3HDevelopment Value: Off \r\n; Production Value: Off\u001b[16;3Hhttps://php.net/short-open-tag\r\nshort_open_tag =\u001b[92m Off\u001b[m\u000f\u001b[6X\r\n\u001b[29X\u001b[19;3HThe number of significant digits displayed in floating point numbers.\r\n; https://php.net/precision\r\nprecision = 14   \r\n\u001b[20X\u001b[23;3HOutput buffering is a mechanism for controlling how much output data\u001b[24;3H(\u001b[30m\u001b[103mex\u001b[m\u000fcluding headers and cookies) PHP should keep internally before pushing that\r\n; data to the client. If your application's output \u001b[30m\u001b[103mex\u001b[m\u000fceeds this setting, PHP\u001b[26;3Hwill send that data in chunks of roughly the size you specify.\u001b[27;3HTurning on this setting and managing its maximum buffer size can yield some\u001b[28;3Hinteresting side-effects depending on your application and web server.\u001b[29;3HYou may be able to send headers and cookies after you've already sent output\r\n; through print or echo. You also may see performance benefits if your server is\u001b[31;3Hemitting less packets due to buffered output versus PHP streaming the output\u001b[32;3Has it gets it. On production servers, 4096 bytes is a good setting for performance\u001b[33;3Hreasons.\u001b[15X\u001b[34;3HNote: Output buffering can also be controlled via Output Buffering Control\r\n;   functions.\u001b[36;2H Possible Values:  \u001b[37;3H  On = Enabled and buffer is unlimited. (Use with caution)\u001b[38;2H   Off = Disabled  \u001b[39;3H  Integer = Enables the buffer and sets its maximum size in bytes.\u001b[5X\u001b[40;2H Note: This directive is hardcoded to Off for the CLI SAPI\r\n; Default Value: Off\u001b[42;3HDevelopment Value: 4096\u001b[34X\u001b[43;2H Production Value: 4096\r\n; https://php.net/output-buffering\r\noutput_buffering = 4096\u001b[75X\r\n\u001b[25X\u001b[47;153H\u001b[0;10;7m\u000f205,4           9\u001b[48;4H\u001b[?25h"]
[0.202, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.006, "o", "\u001b[H; https://php.net/ignore-user-abort\u001b[2;2Hignore_user_abort = On\u001b[33X\r\n\u001b[24X\n; Determines the size of the realpath cache to be used by PHP. This value should\r\n; be increased on systems where PHP opens many files to reflect the quantity of\u001b[6;3Hthe file operations performed.\u001b[42X\u001b[7;3HNote: if open_basedir is set, the cache is disabled\u001b[18X\u001b[8;3Hhttps://php.net/realpath-cache-size\u001b[41X\u001b[9;2Hrealpath_cache_size = 4096k\u001b[49X\r\n\u001b[79X\u001b[11;3HDuration of time, in seconds for which to cache realpath information for a given\u001b[12;3Hfile or directory. For systems with rarely changing files, consider increasing this\u001b[13;3Hvalue.\u001b[11X\u001b[14;3Hhttps://php.net/realpath-cache-ttl\u001b[15;2Hrealpath_cache_ttl = 120\r\n\u001b[32X\n; Enables or disables the circular reference collector.\r\n; https://php.net/zend.enable-gc\r\nzend.enable_gc =\u001b[92m On\u001b[m\u000f\u001b[52X\r\n\u001b[27X\n; If enabled, scripts may be written in encodings that are incompatible with\r\n; the scanner.  CP936, Big5, CP949 and Shift_JIS are the examples of such\u001b[23;3Hencodings.  To use this feature, mbstring \u001b[30m\u001b[103mext\u001b[m\u000fension must be enabled.\u001b[24;2Hzend.multibyte = Off\u001b[59X\r\n\u001b[76X\u001b[26;3HAllows to set the default encoding for the scripts.  This value will be used\u001b[27;3Hunless \"declare(encoding=...)\" directive appears at the top of the script. \u001b[28;3HOnly affects if zend.multibyte is set.\u001b[32X\u001b[29;2Hzend.script_encoding =\u001b[55X\r\n\u001b[80X\u001b[31;3HAllows to include or exclude arguments from stack traces generated for exceptions.\u001b[32;3HIn production, it is recommended to turn this setting on to prohibit the output   \u001b[33;3Hof sensitive information in stack traces\u001b[34;3HDefault Value: Off\u001b[56X\u001b[35;3HDevelopment Value: Off\u001b[36;4Hroduction Value: On\r\nzend.exception_ignore_args =\u001b[92m On\u001b[m\u000f\u001b[29X\r\n\u001b[18X\u001b[39;3HAllows setting the maximum string length in an argument of a stringified stack trace\u001b[40;3Hto a value between 0 and 1000000.\u001b[24X\u001b[41;3HThis has no effect when zend.exception_ignore_args is enabled.\u001b[42;5Hfault Value: 15\u001b[6X\u001b[43;3HDevelopment Value: 15 \u001b[44;3HProduction Value: 0\u001b[13X\r\n; In production, it is recommended to set this to 0 to reduce the output\r\n; of sensitive information in stack traces.\u001b[47;153H\u001b[0;10;7m\u000f360,45         18\u001b[48;5H\u001b[?25h"]
