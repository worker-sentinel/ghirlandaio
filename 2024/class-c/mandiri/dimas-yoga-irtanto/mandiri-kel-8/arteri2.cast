[0.006, "o", "\u001b[1;3Hrequest_order\u001b[20X\u001b[2;2H   Default Value: None\r\n;   Development Value: \"GP\"\u001b[4;3H  Production Value: \"GP\"\u001b[54X\r\n\u001b[79X\u001b[6;3Hsession.gc_divisor\u001b[12X\u001b[7;3H  Default Value: 100\u001b[31X\u001b[8;3H  Development Value: 1000\u001b[10X\u001b[9;2H   Production Value: 1000  \u001b[11;3Hshort_open_tag\u001b[66X\u001b[12;3H  Default Value: On\u001b[64X\u001b[13;3H  Development Value: Off\u001b[14;3H  Production Value: Off\u001b[11X\r\n\u001b[25X\n; variables_order\u001b[17;3H  Default Value: \"EGPCS\"\u001b[29X\u001b[18;3H  Development Value: \"GPCS\"   \r\n;   Production Value: \"GPCS\"\u001b[21;3Hzend.assertions\u001b[59X\u001b[22;3H  Default Value: 1\u001b[53X\u001b[23;3H  Development Value: 1\u001b[46X\u001b[24;2H   Production Value: -1\u001b[26;3Hzend.exception_ignore_args\u001b[50X\u001b[27;3H  Default Value: Off\u001b[54X\u001b[28;3H  Development Value: Off\u001b[14X\u001b[29;2H   Production Value: On\u001b[31;3Hzend.exception_string_param_max_len\u001b[47X\u001b[32;3H  Default Value: 15\u001b[60X\u001b[33;3H  Development Value: 15\u001b[17X\u001b[34;3H  Production Value: 0\r\n\u001b[24X\u001b[36;2H;;;;;;;;;;;;;;;;;;;  \r\n; php.ini Options  ;\u001b[11X\r\n;;;;;;;;;;;;;;;;;;;;\u001b[39;3HName for user-defined php.ini (.htaccess) files. Default is \".user.ini\"\u001b[13X\u001b[40;2Huser_ini.filename = \".user.ini\"   \r\n\u001b[64X\u001b[42;3HTo disable this feature set this option to an empty value\u001b[43;2Huser_ini.filename =   \r\n\u001b[21X\u001b[45;3HTTL for user-defined php.ini files (time-to-live) in seconds. Default is 300 seconds (5 minutes)\u001b[46;2Huser_ini.cache_ttl = 300\u001b[18X\u001b[47;153H\u001b[0;10;7m\u000f177,1           7\u001b[48;8H\u001b[?25h"]
