[0.007, "o", "\u001b[1;16H\u001b[30m\u001b[103me\u001b[m\u000ft/ignor\u001b[30m\u001b[103me\u001b[m\u000f-us\u001b[30m\u001b[103me\u001b[2;7He\u001b[m\u000f_us\u001b[30m\u001b[103me\u001b[4;4He\u001b[m\u000ft\u001b[30m\u001b[103me\u001b[m\u000frmin\u001b[30m\u001b[103me\u001b[m\u000fs th\u001b[30m\u001b[103me\u001b[m\u000f siz\u001b[30m\u001b[103me\u001b[m\u000f of th\u001b[30m\u001b[103me\u001b[m\u000f r\u001b[30m\u001b[103me\u001b[m\u000falpath cach\u001b[30m\u001b[103me\u001b[m\u000f to b\u001b[30m\u001b[103me\u001b[m\u000f us\u001b[30m\u001b[103me\u001b[m\u000fd by PHP. This valu\u001b[30m\u001b[103me\u001b[5;4He\u001b[m\u000f incr\u001b[30m\u001b[103me\u001b[m\u000fas\u001b[30m\u001b[103me\u001b[m\u000fd on syst\u001b[30m\u001b[103me\u001b[m\u000fms wh\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000f PHP op\u001b[30m\u001b[103me\u001b[m\u000fns many fil\u001b[30m\u001b[103me\u001b[m\u000fs to r\u001b[30m\u001b[103me\u001b[m\u000ffl\u001b[30m\u001b[103me\u001b[m\u000fct th\u001b[30m\u001b[103me\u001b[6;5He\u001b[m\u000f fil\u001b[30m\u001b[103me\u001b[m\u000f op\u001b[30m\u001b[103me\u001b[m\u000frations p\u001b[30m\u001b[103me\u001b[m\u000frform\u001b[30m\u001b[103me\u001b[7;6He\u001b[m\u000f: if op\u001b[30m\u001b[103me\u001b[m\u000fn_bas\u001b[30m\u001b[103me\u001b[m\u000fdir is s\u001b[30m\u001b[103me\u001b[m\u000ft, th\u001b[30m\u001b[103me\u001b[m\u000f cach\u001b[30m\u001b[103me\u001b[m\u000f is disabl\u001b[30m\u001b[103me\u001b[8;16He\u001b[m\u000ft/r\u001b[30m\u001b[103me\u001b[m\u000falpath-cach\u001b[30m\u001b[103me\u001b[m\u000f-siz\u001b[30m\u001b[103me\u001b[9;3He\u001b[m\u000falpath_cach\u001b[30m\u001b[103me\u001b[m\u000f_siz\u001b[30m\u001b[103me\u001b[11;18He\u001b[m\u000f, in s\u001b[30m\u001b[103me\u001b[m\u000fconds for which to cach\u001b[30m\u001b[103me\u001b[m\u000f r\u001b[30m\u001b[103me\u001b[m\u000falpath information for a giv\u001b[30m\u001b[103me\u001b[12;6He\u001b[m\u000f or dir\u001b[30m\u001b[103me\u001b[m\u000fctory. For syst\u001b[30m\u001b[103me\u001b[m\u000fms with rar\u001b[30m\u001b[103me\u001b[m\u000fly changing fil\u001b[30m\u001b[103me\u001b[m\u000fs, consid\u001b[30m\u001b[103me\u001b[m\u000fr incr\u001b[30m\u001b[103me\u001b[13;7He\u001b[14;16He\u001b[m\u000ft/r\u001b[30m\u001b[103me\u001b[m\u000falpath-cach\u001b[30m\u001b[103me\u001b[15;3He\u001b[m\u000falpath_cach\u001b[30m\u001b[103me\u001b[17;8He\u001b[m\u000fs or disabl\u001b[30m\u001b[103me\u001b[m\u000fs th\u001b[30m\u001b[103me\u001b[m\u000f circular r\u001b[30m\u001b[103me\u001b[m\u000ff\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[m\u000f coll\u001b[30m\u001b[103me\u001b[18;16He\u001b[m\u000ft/z\u001b[30m\u001b[103me\u001b[m\u000fnd.\u001b[30m\u001b[103me\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[19;2He\u001b[m\u000fnd.\u001b[30m\u001b[103me\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[21;6He\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[m\u000fd, scripts may b\u001b[30m\u001b[103me\u001b[m\u000f writt\u001b[30m\u001b[103me\u001b[m\u000fn in \u001b[30m\u001b[103me\u001b[m\u000fncodings that ar\u001b[30m\u001b[103me\u001b[m\u000f incompatibl\u001b[30m\u001b[103me\u001b[22;5He\u001b[m\u000f scann\u001b[30m\u001b[103me\u001b[m\u000fr.  CP936, Big5, CP949 and Shift_JIS ar\u001b[30m\u001b[103me\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[m\u000fxampl\u001b[30m\u001b[103me\u001b[23;3He\u001b[m\u000fncodings.  To us\u001b[30m\u001b[103me\u001b[m\u000f this f\u001b[30m\u001b[103me\u001b[m\u000fatur\u001b[30m\u001b[103me\u001b[m\u000f, mbstring \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion must b\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[24;3He\u001b[m\u000fnd.multibyt\u001b[30m\u001b[103me\u001b[26;14He\u001b[m\u000ft th\u001b[30m\u001b[103me\u001b[m\u000f d\u001b[30m\u001b[103me\u001b[m\u000ffault \u001b[30m\u001b[103me\u001b[m\u000fncoding for th\u001b[30m\u001b[103me\u001b[m\u000f scripts.  This valu\u001b[30m\u001b[103me\u001b[m\u000f will b\u001b[30m\u001b[103me\u001b[m\u000f us\u001b[30m\u001b[103me\u001b[27;6He\u001b[m\u000fss \"d\u001b[30m\u001b[103me\u001b[m\u000fclar\u001b[30m\u001b[103me\u001b[m\u000f(\u001b[30m\u001b[103me\u001b[m\u000fncoding=...)\" dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f app\u001b[30m\u001b[103me\u001b[m\u000fars at th\u001b[30m\u001b[103me\u001b[m\u000f top of th\u001b[30m\u001b[103me\u001b[28;11He\u001b[m\u000fcts if z\u001b[30m\u001b[103me\u001b[m\u000fnd.multibyt\u001b[30m\u001b[103me\u001b[m\u000f is s\u001b[30m\u001b[103me\u001b[29;3He\u001b[m\u000fnd.script_\u001b[30m\u001b[103me\u001b[31;19He\u001b[m\u000f or \u001b[30m\u001b[103me\u001b[m\u000fxclud\u001b[30m\u001b[103me\u001b[m\u000f argum\u001b[30m\u001b[103me\u001b[m\u000fnts from stack trac\u001b[30m\u001b[103me\u001b[m\u000fs g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[30m\u001b[103me\u001b[m\u000frat\u001b[30m\u001b[103me\u001b[m\u000fd for \u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[32;25He\u001b[m\u000fcomm\u001b[30m\u001b[103me\u001b[m\u000fnd\u001b[30m\u001b[103me\u001b[m\u000fd to turn this s\u001b[30m\u001b[103me\u001b[m\u000ftting on to prohibit th\u001b[30m\u001b[103me\u001b[33;7He\u001b[m\u000fnsitiv\u001b[30m\u001b[103me\u001b[m\u000f information in stack trac\u001b[30m\u001b[103me\u001b[34;4He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[35;4He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[36;18He\u001b[37;2He\u001b[m\u000fnd.\u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[m\u000fption_ignor\u001b[30m\u001b[103me\u001b[39;11He\u001b[m\u000ftting th\u001b[30m\u001b[103me\u001b[m\u000f maximum string l\u001b[30m\u001b[103me\u001b[m\u000fngth in an argum\u001b[30m\u001b[103me\u001b[m\u000fnt of a stringifi\u001b[30m\u001b[103me\u001b[m\u000fd stack trac\u001b[30m\u001b[103me\u001b[40;12He\u001b[m\u000f b\u001b[30m\u001b[103me\u001b[m\u000ftw\u001b[30m\u001b[103mee\u001b[41;15He\u001b[m\u000fff\u001b[30m\u001b[103me\u001b[m\u000fct wh\u001b[30m\u001b[103me\u001b[m\u000fn z\u001b[30m\u001b[103me\u001b[m\u000fnd.\u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[m\u000fption_ignor\u001b[30m\u001b[103me\u001b[m\u000f_args is \u001b[30m\u001b[103me\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[42;4He\u001b[m\u000ffault Valu\u001b[30m\u001b[103me\u001b[43;4He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt Valu\u001b[30m\u001b[103me\u001b[44;18He\u001b[45;25He\u001b[m\u000fcomm\u001b[30m\u001b[103me\u001b[m\u000fnd\u001b[30m\u001b[103me\u001b[m\u000fd to s\u001b[30m\u001b[103me\u001b[m\u000ft this to 0 to r\u001b[30m\u001b[103me\u001b[m\u000fduc\u001b[30m\u001b[103me\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[46;7He\u001b[m\u000fnsitiv\u001b[30m\u001b[103me\u001b[m\u000f information in stack trac\u001b[30m\u001b[103me\u001b[47;155H\u001b[0;10;7m\u000f3,14\u001b[48;3H\u001b[?25h"]
