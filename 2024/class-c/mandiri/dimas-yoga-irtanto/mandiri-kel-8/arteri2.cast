dex\u001b[m\u000f.php \u001b[96mindex\u001b[m\u000f.html \u001b[96mindex\u001b[m\u000f.htm;\u001b[K\r\n\u001b[K\n    \u001b[96mcharset\u001b[m\u000f utf-8;\u001b[K\r\n\u001b[K\n    \u001b[0;10;1m\u000flocation\u001b[m\u000f / {\u001b[K\r\n        try_files \u001b[94m$uri\u001b[m\u000f \u001b[94m$uri\u001b[m\u000f/ /\u001b[96mindex\u001b[m\u000f.php?\u001b[94m$query_string\u001b[m\u000f;\u001b[K\r\n    }\u001b[K\r\n    \u001b[0;10;1m\u000flocation\u001b[m\u000f ~ \\.php$ {\u001b[K\r\n        include fastcgi_params;\u001b[K\r\n        fastcgi_pass unix:/run/php-fpm/php-fpm.sock;\u001b[K\r\n        \u001b[96mfastcgi_index\u001b[m\u000f \u001b[96mindex\u001b[m\u000f.php;\u001b[K\r\n        \u001b[96mfastcgi_param\u001b[m\u000f SCRIPT_FILENAME \u001b[94m$document_root$fastcgi_script_name\u001b[m\u000f;\u001b[K\r\n\u001b[K\n    }\u001b[K\r\n\u001b[K\n}\u001b[K\r\n\u001b[K\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000f/etc/nginx/sites-enabled/arteri.conf                                                                                                                    1,1        "]
