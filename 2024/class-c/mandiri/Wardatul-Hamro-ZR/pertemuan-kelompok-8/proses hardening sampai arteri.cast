[0.077, "o", "\u001b[?25l\u001b[48;160H \u001b[H|                               'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\r\n|                               'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\r\n|\r\n|       ['compress'] Whether or not to use client compression (MySQL only)\u001b[5;3H      ['stricton'] TRUE/FALSE - forces 'Strict Mode' connections   \u001b[6;3H                                                      - good for ensuring strict SQL while developing\u001b[7;3H      ['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\u001b[8;3H      ['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[9;2H       ['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[10;3H                              NOTE: Disabling this will also effectively disable both\u001b[11;3H                              $this->db->last_query() and profiling of DB queries.\u001b[12;2H                               When you run a query, with this setting set to TRUE (default),\u001b[13;3H                              CodeIgniter will store the SQL statement for debugging purposes.\u001b[14;3H                              However, this may cause high memory usage, especially if you run\u001b[15;3H                              a lot of SQL queries ... disable this to avoid that problem.\u001b[17;3HThe $active_group variable lets you choose which connection group to\u001b[9X\u001b[18;3Hmake active.  By default there is only one group (the 'default' group).\u001b[19;2H\u001b[28X\u001b[20;3HThe $query_builder variables lets you determine whether or not to load\u001b[21;3Hthe query builder class.   \r\n*/\u001b[53X\r\n$\u001b[94mactive_group\u001b[m\u000f = \u001b[92m'default'\u001b[m\u000f;\u001b[18X\r\n$\u001b[94mquery_builder\u001b[m\u000f = TRUE;\u001b[53X\r\n\u001b[76X\n$\u001b[94mdb\u001b[m\u000f[\u001b[92m'default'\u001b[m\u000f] = array\u001b[0;10;4;1m\u000f(\u001b[m\u000f\u001b[49X\r\n        \u001b[92m'dsn'\u001b[m\u000f   => \u001b[92m''\u001b[m\u000f,\u001b[64X\r\n        \u001b[92m'hostname'\u001b[m\u000f => \u001b[92m'localhost'\u001b[m\u000f,\u001b[38X\r\n        \u001b[92m'username'\u001b[m\u000f => \u001b[92m'root'\u001b[m\u000f,\u001b[49X\r\n        \u001b[92m'password'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[39X\r\n        \u001b[92m'database'\u001b[m\u000f => \u001b[92m'arteri'\u001b[m\u000f,\u001b[47X\r\n        \u001b[92m'dbdriver'\u001b[m\u000f => \u001b[92m'mysqli'\u001b[m\u000f,\u001b[47X\r\n        \u001b[92m'dbprefix'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[59X\r\n        \u001b[92m'pconnect'\u001b[m\u000f => FALSE,\u001b[68X\r\n        \u001b[92m'db_debug'\u001b[m\u000f => (ENVIRONMENT \u001b[0;10;1m\u000f!==\u001b[m\u000f \u001b[92m'production'\u001b[m\u000f),\u001b[46X\r\n        \u001b[92m'cache_on'\u001b[m\u000f => FALSE,\u001b[56X\r\n        \u001b[92m'cachedir'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[80X\r\n        \u001b[92m'char_set'\u001b[m\u000f => \u001b[92m'utf8'\u001b[m\u000f,\u001b[69X\r\n        \u001b[92m'dbcollat'\u001b[m\u000f => \u001b[92m'utf8_unicode_ci'\u001b[m\u000f,\u001b[60X\r\n        \u001b[92m'swap_pre'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[89X\r\n        \u001b[92m'encrypt'\u001b[m\u000f => FALSE,\u001b[57X\r\n        \u001b[92m'compress'\u001b[m\u000f => FALSE,\u001b[39X\r\n        \u001b[92m'stricton'\u001b[m\u000f => FALSE,\r\n        \u001b[92m'failover'\u001b[m\u000f => array(),\u001b[67X\r\n        \u001b[92m'save_queries'\u001b[m\u000f => TRUE\u001b[70X\r\n\u001b[0;10;4;1m\u000f)\u001b[m\u000f;\u001b[47;153H\u001b[0;10;7m\u000f96,1           Bot\r\u001b[A\u001b[?25h"]
