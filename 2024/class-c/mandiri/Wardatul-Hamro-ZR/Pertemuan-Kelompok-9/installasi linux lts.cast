[0.003, "o", "\u001b[1;20H\u001b[30m\u001b[103me\u001b[m\u000f for local\u001b[30m\u001b[103me\u001b[m\u000f-g\u001b[30m\u001b[103me\u001b[3;17He\u001b[m\u000fs that ar\u001b[30m\u001b[103me\u001b[m\u000f to b\u001b[30m\u001b[103me\u001b[m\u000f g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[30m\u001b[103me\u001b[m\u000frat\u001b[30m\u001b[103me\u001b[m\u000fd by th\u001b[30m\u001b[103me\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[m\u000f-g\u001b[30m\u001b[103me\u001b[5;11He\u001b[m\u000f is of th\u001b[30m\u001b[103me\u001b[7;13He\u001b[m\u000f> <chars\u001b[30m\u001b[103me\u001b[9;6He\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000f <local\u001b[30m\u001b[103me\u001b[m\u000f> is on\u001b[30m\u001b[103me\u001b[m\u000f of th\u001b[30m\u001b[103me\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[m\u000fs giv\u001b[30m\u001b[103me\u001b[m\u000fn in /usr/shar\u001b[30m\u001b[103me\u001b[m\u000f/i18n/local\u001b[30m\u001b[103me\u001b[10;14He\u001b[m\u000ft> is on\u001b[30m\u001b[103me\u001b[m\u000f of th\u001b[30m\u001b[103me\u001b[m\u000f charact\u001b[30m\u001b[103me\u001b[m\u000fr s\u001b[30m\u001b[103me\u001b[m\u000fts list\u001b[30m\u001b[103me\u001b[m\u000fd in /usr/shar\u001b[30m\u001b[103me\u001b[12;6He\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[m\u000f-g\u001b[30m\u001b[103me\u001b[m\u000fn command will g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[30m\u001b[103me\u001b[m\u000frat\u001b[30m\u001b[103me\u001b[m\u000f all th\u001b[30m\u001b[103me\u001b[m\u000f local\u001b[30m\u001b[103me\u001b[13;14He\u001b[m\u000fm in /usr/lib/local\u001b[30m\u001b[103me\u001b[15;21He\u001b[m\u000fd local\u001b[30m\u001b[103me\u001b[m\u000fs is giv\u001b[30m\u001b[103me\u001b[m\u000fn in /usr/shar\u001b[30m\u001b[103me\u001b[16;17He\u001b[m\u000fd in this fil\u001b[30m\u001b[103me\u001b[m\u000f. Uncomm\u001b[30m\u001b[103me\u001b[m\u000fnt th\u001b[30m\u001b[103me\u001b[m\u000f n\u001b[30m\u001b[103mee\u001b[m\u000fd\u001b[30m\u001b[103me\u001b[m\u000fd local\u001b[30m\u0