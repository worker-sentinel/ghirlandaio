[0.000, "o", "\u001b[2d\u001b[K\u001b[3;4HUncomment to allow members of group wheel to execute any command\r\u001b[4d# %wheel ALL=(ALL:ALL) ALL\u001b[K\r\u001b[5d\u001b[K\u001b[6;4HSame thing without a password\r\u001b[7d# %wheel ALL=(ALL:ALL) NOPASSWD: ALL\r\u001b[8d\u001b[K\u001b[9;4HUncomment to allow members of group sudo to execute any command\r\u001b[10d# %sudo ALL=(ALL:ALL) ALL\u001b[K\r\u001b[11d\u001b[K\u001b[12;4HUncomment to allow any user to run sudo if they know the password\u001b[13;4Hof the user they are running the command as (root by default).\u001b[K\r\u001b[14d# Defaults targetpw  # Ask for the password of the target user\u001b[K\u001b[15;3HALL ALL=(ALL:ALL) ALL  # WARNING: only use this together with 'Defaults targetpw'\r\u001b[16d\u001b[K\u001b[17;4H"]
[0.001, "o", "Read drop-in files from /etc/sudoers.d\u001b[K\r\u001b[18d@includedir /etc/sudoers.d\u001b[K\r\u001b[19d\u001b[K\u001b[20d\u001b[K\u001b[21d\u001b[K\u001b[22d\u001b[K\u001b[23d\u001b[K\u001b[24d\u001b[K\u001b[25d\u001b[K\u001b[26d\u001b[K\u001b[27d\u001b[K\u001b[28d\u001b[K\u001b[29d\u001b[K\u001b[30d\u001b[K\u001b[31d\u001b[K\u001b[32d\u001b[K\u001b[33d\u001b[K\u001b[34d\u001b[K\u001b[35d\u001b[K\u001b[36d\u001b[K\u001b[37d\u001b[K\u001b[38d\u001b[K\u001b[39d\u001b[K\u001b[40d\u001b[K\u001b[41d\u001b[K\u001b[42d\u001b[K\u001b[43d\u001b[K\u001b[44d\u001b[K\u001b[45d\u001b[K\u001b[46d\u001b[K\u001b[47d\u001b[K\u001b[48d\u001b[K\u001b[49d\u001b[K\u001b[50d\u001b[K\u001b[51d\u001b[K\u001b[52d\u001b[K\u001b[53d\u001b[K\u001b[55d\u001b[K\u001b[56d\u001b[K\u001b[57d\u001b[K\u001b[59d\u001b[K\u001b[60d\u001b[K\u001b[61d\u001b[K\u001b[62d\u001b[K\u001b[64d\u001b[K\u001b[18d\u001b[?25h\u001b[?0c"]
