[0.003, "o", "\u001b[1;7H\u001b[30m\u001b[103ms\u001b[m\u000fet ft=\u001b[30m\u001b[103ms\u001b[3;23Hs\u001b[m\u000f are loaded before any boot hook\u001b[30m\u001b[103ms\u001b[4;19Hs\u001b[m\u000fer\u001b[30m\u001b[103ms\u001b[m\u000f may wi\u001b[30m\u001b[103ms\u001b[m\u000fh to \u001b[30m\u001b[103ms\u001b[m\u000fpecify all \u001b[30m\u001b[103ms\u001b[m\u000fy\u001b[30m\u001b[103ms\u001b[m\u000ftem module\u001b[30m\u001b[103ms\u001b[5;9Hs\u001b[m\u000f array.  For in\u001b[30m\u001b[103ms\u001b[6;17Hs\u001b[10;6Hs\u001b[m\u000f \u001b[30m\u001b[103ms\u001b[m\u000fetting include\u001b[30m\u001b[103ms\u001b[m\u000f any additional binarie\u001b[30m\u001b[103ms\u001b[m\u000f a given u\u001b[30m\u001b[103ms\u001b[11;5Hs\u001b[m\u000fh into the CPIO image.  Thi\u001b[30m\u001b[103ms\u001b[m\u000f i\u001b[30m\u001b[103ms\u001b[m\u000f run la\u001b[30m\u001b[103ms\u001b[m\u000ft, \u001b[30m\u001b[103ms\u001b[m\u000fo it may be u\u001b[30m\u001b[103ms\u001b[12;30Hs\u001b[13;30Hs\u001b[m\u000fed, \u001b[30m\u001b[103ms\u001b[m\u000fo you may \u001b[30m\u001b[103ms\u001b[m\u000fafely ignore librarie\u001b[30m\u001b[103ms\u001b[17;6Hs\u001b[m\u000f \u001b[30m\u001b[103ms\u001b[m\u000fetting i\u001b[30m\u001b[103ms\u001b[m\u000f \u001b[30m\u001b[103ms\u001b[m\u000fimilar to BINARIES above, however, file\u001b[30m\u001b[103ms\u001b[18;4Hs\u001b[m\u000f-i\u001b[30m\u001b[103ms\u001b[m\u000f and are not par\u001b[30m\u001b[103ms\u001b[m\u000fed in any way.  Thi\u001b[30m\u001b[103ms\u001b[m\u000f i\u001b[30m\u001b[103ms\u001b[m\u000f u\u001b[30m\u001b[103ms\u001b[m\u000feful for config file\u001b[30m\u001b[103ms\u001b[22;6Hs\u001b[m\u000f i\u001b[30m\u001b[103ms\u001b[m\u000f the mo\u001b[30m\u001b[103ms\u001b[m\u000ft important \u001b[30m\u001b[103ms\u001b[m\u000fetting in thi\u001b[30m\u001b[103ms\u001b[23;9Hs\u001b[m\u000f and \u001b[30m\u001b[103ms\u001b[m\u000fcript\u001b[30m\u001b[103ms\u001b[m\u000f added to the image, and what happen\u001b[30m\u001b[103ms\u001b[24;10Hs