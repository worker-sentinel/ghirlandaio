[0.094, "o", "\r\n:: The firewallD components & utilities have now been split into different packages:\r\n\r\n   - firewalld: Firewall daemon with D-Bus interface \r\n   - python-firewall: Python bindings for firewallD\r\n"]
[0.000, "o", "   - firewall-config: Graphical user interface for firewallD\r\n   - firewall-applet: Systray applet for firewallD\r\n"]
[0.000, "o", "   - firewalld-test: FirewallD test suite\r\n\r\n   Make sure to install the ones you may want / need.\r\n\r\n"]
[0.001, "o", "Optional dependencies for firewalld\r\n    bash-completion: bash completion\r\n"]
[0.000, "o", "    networkmanager: NetworkManager support [installed]\r\n    polkit: privileged actions [installed]\r\n"]
[0.000, "o", "    firewall-config: Graphical user interface for firewallD configuration\r\n    firewall-applet: Systray applet for firewallD\r\n    firewalld-test: firewallD test suite\r\n"]
