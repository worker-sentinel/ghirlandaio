[0.020, "o", "\u001b[?25l\u001b[67;230H \u001b[1;65r\u001b[H\u001b[31M\u001b[1;67r\u001b[35;1H|\u001b[K\r\n| The $active_group variable lets you choose which connection group to\u001b[K\r\n| make active.  By default there is only one group (the 'default' group).\u001b[K\r\n|\u001b[K\r\n| The $query_builder variables lets you determine whether or not to load\u001b[K\r\n| the query builder class.\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mactive_group\u001b[m\u000f = \u001b[92m'default'\u001b[m\u000f;\u001b[K\r\n$\u001b[94mquery_builder\u001b[m\u000f = TRUE;\u001b[K\r\n\u001b[K\n$\u001b[94mdb\u001b[m\u000f[\u001b[92m'default'\u001b[m\u000f] = array\u001b[0;10;4;1m\u000f(\u001b[m\u000f\u001b[K\r\n        \u001b[92m'dsn'\u001b[m\u000f   => \u001b[92m''\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'hostname'\u001b[m\u000f => \u001b[92m'localhost'\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'username'\u001b[m\u000f => \u001b[92m'root'\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'password'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'database'\u001b[m\u000f => \u001b[92m'arteri'\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'dbdriver'\u001b[m\u000f => \u001b[92m'mysqli'\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'dbprefix'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'pconnect'\u001b[m\u000f => FALSE,\u001b[K\r\n        \u001b[92m'db_debug'\u001b[m\u000f => (ENVIRONMENT \u001b[0;10;1m\u000f!==\u001b[m\u000f \u001b[92m'production'\u001b[m\u000f),\u001b[K\r\n        \u001b[92m'cache_on'\u001b[m\u000f => FALSE,\u001b[K\r\n        \u001b[92m'cachedir'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'char_set'\u001b[m\u000f => \u001b[92m'utf8'\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'dbcollat'\u001b[m\u000f => \u001b[92m'utf8_unicode_ci'\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'swap_pre'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[K\r\n        \u001b[92m'encrypt'\u001b[m\u000f => FALSE,\u001b[K\r\n        \u001b[92m'compress'\u001b[m\u000f => FALSE,\u001b[K\r\n        \u001b[92m'stricton'\u001b[m\u000f => FALSE,\u001b[K\r\n        \u001b[92m'failover'\u001b[m\u000f => array(),\u001b[K\r\n        \u001b[92m'save_queries'\u001b[m\u000f => TRUE\u001b[K\r\n\u001b[0;10;4;1m\u000f)\u001b[m\u000f;\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f96,1           Bot\r\u001b[A\u001b[?25h"]
