[0.001, "o", "(181/188) installing python                                                                                                                      [----------------------------------------------------------------------------------------]   0%\r(181/188) installing python                                                                                                                      [----------------------------------------------------------------------------------------]   0%\r(181/188) installing python                                                                                                                      [----------------------------------------------------------------------------------------]   0%\r"]
[0.199, "o", "(181/188) installing python                                                                                                                      [###############################################################-------------------------]  72%\r"]
[0.090, "o", "(181/188) installing python                                                                                                                      [########################################################################################] 100%\r\r\n"]
[0.001, "o", "Optional dependencies for python\r\n\u001b[0;1m   \u001b[0m python-setuptools: for building Python packages using tooling that is usually bundled with Python\r\n"]
[0.001, "o", "    python-pip: for installing Python packages using tooling that is usually bundled with Python\r\n    python-pipx: for installing Python software not packaged on Arch Linux\r\n    sqlite: for a default database integration [installed]\r\n    xz: for lzma [installed]\r\n    tk: for tkinter\r\n(182/188) installing python-dbus                                                                                                                 [----------------------------------------------------------------------------------------]   0%\r"]
[0.005, "o", "(182/188) installing python-dbus                                                                                                                 [########################################################################################] 100%\r\r\n"]
[0.001, "o", "Optional dependencies for python-dbus\r\n\u001b[0;1m   \u001b[0m python-gobject: D-Bus services via PyGI [pending]\r\n"]
[0.000, "o", "(183/188) installing libgirepository                                                                                                             [----------------------------------------------------------------------------------------]   0%\r"]
[0.005, "o", "(183/188) installing libgirepository                                                                                                             [########################################################################################] 100%\r\r\n"]
[0.001, "o", "(184/188) installing gobject-introspection-runtime                                                                                               [----------------------------------------------------------------------------------------]   0%\r"]
[0.000, "o", "(184/188) installing gobject-introspection-runtime                                                                                               [########################################################################################] 100%\r\r\n"]
[0.001, "o", "(185/188) installing python-gobject                                                                                                              [----------------------------------------------------------------------------------------]   0%\r"]
[0.008, "o", "(185/188) installing python-gobject                                                                                                              [########################################################################################] 100%\r\r\n"]
[0.001, "o", "Optional dependencies for python-gobject\r\n\u001b[0;1m   \u001b[0m python-cairo: Cairo bindings\r\n"]
[0.001, "o", "(186/188) installing python-firewall                                                                                                             [----------------------------------------------------------------------------------------]   0%\r"]
[0.014, "o", "(186/188) installing python-firewall                                                                                                             [########################################################################################] 100%\r\r\n"]
[0.001, "o", "(187/188) installing python-capng                                                                                                                [----------------------------------------------------------------------------------------]   0%\r"]
[0.001, "o", "(187/188) installing python-capng                                                                                                                [########################################################################################] 100%\r\r\n"]
[0.000, "o", "(188/188) installing firewalld                                                                                                                   [----------------------------------------------------------------------------------------]   0%\r"]
[0.030, "o", "(188/188) installing firewalld                                                                                                                   [########################################################################################] 100%\r\r\n"]
[0.063, "o", "\r\n:: The firewallD components & utilities have now been split into different packages:\r\n\r\n"]
[0.000, "o", "   - firewalld: Firewall daemon with D-Bus interface \r\n   - python-firewall: Python bindings for firewallD\r\n   - firewall-config: Graphical user interface for firewallD\r\n   - firewall-applet: Systray applet for firewallD\r\n   - firewalld-test: FirewallD test suite\r\n"]
[0.003, "o", "\r\n   Make sure to install the ones you may want / need.\r\n\r\nOptional dependencies for firewalld\r\n\u001b[0;1m   \u001b[0m bash-completion: bash completion\r\n    networkmanager: NetworkManager support\r\n    polkit: privileged actions\r\n    firewall-config: Graphical user interface for firewallD configuration\r\n    firewall-applet: Systray applet for firewallD\r\n    firewalld-test: firewallD test suite\r\n"]
