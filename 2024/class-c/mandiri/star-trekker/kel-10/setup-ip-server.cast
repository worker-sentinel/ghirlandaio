[0.014, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# directory to allow only members of a group to use sockets. This way, it is\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[42;177H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\r\u001b[A\u001b[?25h"]
[0.042, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# possible to run hostapd as root (since it needs to change network\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[42;176H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m70\r\u001b[A\u001b[?25h"]
