[0.020, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.005, "o", "\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# change the network configuration, this access needs to be protected in many\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[42;177H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# cases. By default, hostapd is configured to use gid 0 (root). If you\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[42;177H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# want to allow non-root users to use the control interface, add a new group\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[42;177H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5,1            1\r\u001b[A\u001b[?25h"]
[0.044, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.002, "o", "\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# and change this value to match with that group. Add users that should have\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[42;177H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\r\u001b[A\u001b[?25h"]
