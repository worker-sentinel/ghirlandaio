[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; If empty, default_charset is used.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP internal character encoding is set to empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hdefault_charset =\u001b[92m \"UTF-8\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/default-charset\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP's default character set is set to UTF-8.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f09\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hdefault_mimetype =\u001b[92m \"text/html\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/default-mimetype\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP's built-in default media type is set to text/html.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6,1          38\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; disable this, simply set it to be empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; By default, PHP will output a media type using the Content-Type header. To\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hauto_append_file =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/auto-append-file\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Automatically add files after PHP document.\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f699\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hauto_prepend_file =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/auto-prepend-file\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Automatically add files before PHP document.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hpost_max_size =\u001b[92m 8M\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/post-max-size\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; is disabled through enable_post_data_reading.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Its value may be 0 to disable the limit. It is ignored if POST data reading\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Maximum size of POST data that PHP will accept.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f89\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,1          37\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;enable_post_data_reading = Off\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/enable-post-data-reading\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; to proxy requests or to process the POST data in a memory efficient fashion.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; POST data will be through the php://input stream wrapper. This can be useful\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; and $_FILES to always be empty; the only way you will be able to read the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Most likely, you won't want to disable this option globally. It causes $_POST\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This option is enabled by default.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Whether PHP will read the POST data.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f79\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hauto_globals_jit =\u001b[92m On\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/auto-globals-jit\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; for this directive to have any effect.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; in a performance gain. The PHP directive register_argc_argv must be disabled\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; variables are not used within a script, having this directive on will result\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.017, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; first used (Just In Time) instead of when the script starts. If these\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; When enabled, the ENV, REQUEST and SERVER variables are created when they're\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;register_argc_argv = Off\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0,1          36\u001b[H\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/register-argc-argv\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f69\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This directive is deprecated.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Note: This directive is ignored for the CLI SAPI\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; for non-CLI SAPIs.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; a script is executed. For security reasons, this feature should be disabled\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; enabled, registering these variables consumes CPU cycles and memory each time\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; useful when running scripts from the command line. When this directive is\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; that were passed when the script was invoked. These arrays are extremely\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; is invoked. $argc contains an integer representing the number of arguments\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; runs. $argv contains an array of all the arguments passed to PHP when a script\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This directive determines whether PHP registers $argv & $argc each time it\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f59\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hrequest_order =\u001b[92m \"GP\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/request-order\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Production Value: \"GP\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.044, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Development Value: \"GP\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Default Value: None\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; globals array REQUEST empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,1          35\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; in the variables_order directive. It does not mean it will leave the super\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; EXCEPT one. Leaving this value empty will cause PHP to use the value set\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; are specified in the same manner as the variables_order directive,\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f49\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; the order in which that data is registered. The values for this directive\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; registered into the super global array REQUEST. If so, it also determines\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This directive determines which super global data (G,P & C) should be\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hvariables_order =\u001b[92m \"GPCS\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/variables-order\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Production Value: \"GPCS\";\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Development Value: \"GPCS\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Default Value: \"EGPCS\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; need to.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f39\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; can still get access to the environment variables through getenv() should you\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; used as the others, ENV is not recommended on productions servers. You\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; paid for the registration of these arrays and because ENV is not as commonly\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; globals: GET, POST, COOKIE, ENV and SERVER. There is a performance penalty\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; starts up. G,P,C,E & S are abbreviations for the following respective super\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,1          34\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This directive determines which super global arrays are registered when PHP\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;arg_separator.input = \";&\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/arg-separator.input\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f29\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; NOTE: Every character in this directive is considered as separator!\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP's default setting is \"&\".\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; List of separator(s) used by PHP to parse input URLs into variables.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;arg_separator.output = \"&amp;\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/arg-separator.output\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP's default setting is \"&\".\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; The separator used in PHP generated URLs to separate arguments.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f19\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;;;;;;;;;;;;;;;;;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Data Handling ;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;;;;;;;;;;;;;;;;;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6,1          33\u001b[H\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;fatal_error_backtraces = On\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Production Value: On\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.021, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Development Value: On\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Default Value: On\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This directive controls whether PHP will output the backtrace of fatal errors.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f09\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Production value: 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
