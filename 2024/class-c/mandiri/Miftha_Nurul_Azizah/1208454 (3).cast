[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Directory in which the loadable extensions (modules) reside.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/extension-dir\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hextension_dir =\u001b[92m \"/usr/lib/php/modules/\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; On windows:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;extension_dir = \"ext\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f60\r\u001b[A\u001b[?25h"]
