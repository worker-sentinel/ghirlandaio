[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/user-dir\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; if nonempty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; The directory under which PHP opens the script using /~username used only\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hdoc_root =\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f49\u001b[H\u001b[?25h"]
[0.024, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/doc-root\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; cgi.force_redirect configuration below\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; see documentation for security issues.  The alternate is to use the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; if you are running php as a CGI under any web server (other than IIS)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; if PHP was not compiled with FORCE_REDIRECT, you SHOULD set doc_root\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; The root of the PHP pages, used only if nonempty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          40\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/include-path\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP's default setting for include_path is \".;/path/to/php/pear\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f39\u001b[H\u001b[?25h"]
