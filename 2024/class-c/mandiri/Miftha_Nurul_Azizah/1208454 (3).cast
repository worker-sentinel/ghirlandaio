[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; If empty, default_charset is used.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP output character encoding is set to empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,1          39\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
