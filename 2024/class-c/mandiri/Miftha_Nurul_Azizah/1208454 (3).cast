[0.020, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Default value: 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;windows.show_crt_warning\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;syslog.filter = ascii\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/syslog.filter\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;   raw (like \"all\", but messages are not split at newlines)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;   all (all characters)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;   no-ctrl (all characters except control characters)\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f599\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;   ascii (all printable ASCII characters and NL)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,1          32\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Allowed values are:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; is needed at all.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; control characters. If your logger accepts everything, then no filtering\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Some loggers only accept NVT-ASCII, others accept anything that's not\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Set this to disable filtering control characters (the default).\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;syslog.facility = user\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; the message. Only used when error_log is set to syslog.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; The syslog facility is used to specify what type of program is logging\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f89\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.044, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;syslog.ident = php\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; to syslog. Only used when error_log is set to syslog.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; The syslog ident is a string which is prepended to every message logged\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;error_log = syslog\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Log errors to syslog (Event Log on Windows).\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;error_log = php_errors.log\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0,1          31\u001b[H\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/error-log\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f79\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Log errors to specified file. PHP's default behavior is to leave this value\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;error_append_string = \"</span>\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/error-append-string\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; this setting blank.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; String to output after an error message. PHP's default behavior is to leave\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;error_prepend_string = \"<span style='color: #ff0000'>\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f69\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/error-prepend-string\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; this setting blank.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; String to output before an error message. PHP's default behavior is to leave\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;docref_ext = .html\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/docref-ext\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,1          30\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;docref_root = \"/phpmanual/\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Examples\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f59\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/docref-root\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Note: Never use this feature for production boxes.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; case no links to documentation are generated.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; the dot. PHP's default behavior is to leave these settings empty, in which\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; leading '/'. You must also specify the file extension being used including\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; and change docref_root to the base URL of your local copy including the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; You can download a copy of the PHP manual from https://php.net/docs\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; or function causing the error in detail.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; produces clickable error messages that direct to a page describing the error\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; If html_errors is set to On *and* docref_root is not empty, then PHP\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f49\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;html_errors = On\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.024, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/html-errors\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Note: This directive is hardcoded to Off for the CLI SAPI\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; the error message is formatted as HTML or not.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; error message as HTML for easier reading. This directive controls whether\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          29\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; When PHP displays or logs an error, it has the capability of formatting the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;xmlrpc_error_number = 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; An XML-RPC faultCode\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f39\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;xmlrpc_errors = 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/xmlrpc-errors\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Turn off normal error reporting and emit XML-RPC error XML\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;report_zend_debug = 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; This setting is off by default.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
