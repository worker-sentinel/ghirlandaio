[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Directory where the temporary files should be placed.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Defaults to the system default (see sys_get_temp_dir)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;sys_temp_dir = \"/tmp\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Whether or not to enable the dl() function.  The dl() function does NOT work\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; properly in multithreaded servers, such as IIS or Zeus, and is automatically\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; disabled on them.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/enable-dl\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Henable_dl =\u001b[92m Off\u001b[m\u000f\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f70\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,1          39\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; cgi.force_redirect is necessary to provide security running PHP as a CGI under\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; most web servers.  Left undefined, PHP turns this on by default.  You can\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; turn it off here AT YOUR OWN RISK\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; **You CAN safely turn this off for IIS, in fact, you MUST.**\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/cgi.force-redirect\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;cgi.force_redirect = 1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; if cgi.nph is enabled it will force cgi to always sent Status: 200 with\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; every request. PHP's default behavior is to disable this feature.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f80\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;cgi.nph = 1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.021, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; if cgi.force_redirect is turned on, and you are not running under Apache or Netscape\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; (iPlanet) web servers, you MAY need to set an environment variable name that PHP\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; will look for to know it is OK to continue execution.  Setting this variable MAY\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; cause security issues, KNOW WHAT YOU ARE DOING FIRST.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/cgi.redirect-status-env\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;cgi.redirect_status_env =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9,1          40\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; cgi.fix_pathinfo provides *real* PATH_INFO/PATH_TRANSLATED support for CGI.  PHP's\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f90\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; previous behaviour was to set PATH_TRANSLATED to SCRIPT_FILENAME, and to not grok\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; what PATH_INFO is.  For more information on PATH_INFO, see the cgi specs.  Setting\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.023, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; this to 1 will cause PHP CGI to fix its paths to conform to the spec.  A setting\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; of zero causes PHP to behave as before.  Default is 1.  You should fix your scripts\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; to use SCRIPT_FILENAME rather than PATH_TRANSLATED.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.046, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/cgi.fix-pathinfo\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.016, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;cgi.fix_pathinfo=1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; if cgi.discard_path is enabled, the PHP CGI binary can safely be placed outside\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; of the web tree and people will not be able to circumvent .htaccess security.\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f800\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;cgi.discard_path=1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; FastCGI under IIS supports the ability to impersonate\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; security tokens of the calling client.  This allows IIS to define the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; security context that the request runs under.  mod_fastcgi under Apache\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; does not currently support this feature (03/17/2002)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Set to 1 if running under IIS.  Default is zero.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/fastcgi.impersonate\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,1          41\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;fastcgi.impersonate = 1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f10\r\u001b[A\u001b[?25h"]
