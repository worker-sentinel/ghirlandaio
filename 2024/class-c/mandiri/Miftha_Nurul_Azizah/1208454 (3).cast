[0.116, "o", "(5/5) installing mariadb                                                                                                                         [########################################################################################] 100%\r\r\n"]
[0.054, "o", ":: You need to initialize the MariaDB data directory prior to starting\r\n   the service. This can be done with mariadb-install-db command, e.g.:\r\n     # mariadb-install-db --user=mysql --basedir=/usr --datadir=/var/lib/mysql\r\n"]
[0.000, "o", "Optional dependencies for mariadb\r\n    cracklib: for cracklib plugin\r\n    curl: for ha_s3 plugin [installed]\r\n    galera: for MariaDB cluster with Galera WSREP\r\n    judy: for Open Query GRAPH (OQGraph) computation engine\r\n"]
[0.000, "o", "    mariadb-pam: for PAM authentication\r\n"]
[0.000, "o", "    perl-dbd-mariadb: for mariadb-hotcopy, mariadb-convert-table-format and mariadb-setpermission\r\n"]
[0.000, "o", "    python-mysqlclient: for myrocks_hotbackup\r\n    xz: lzma provider [installed]\r\n"]
[0.075, "o", ":: Running post-transaction hooks...\r\n(1/4) Creating system user accounts...\r\n"]
[0.053, "o", "Creating group 'mysql' with GID 968.\r\n"]
[0.000, "o", "Creating user 'mysql' (MariaDB) with UID 968 and GID 968.\r\n"]
[0.006, "o", "(2/4) Creating temporary files...\r\n"]
[0.090, "o", "(3/4) Reloading system manager configuration...\r\n"]
