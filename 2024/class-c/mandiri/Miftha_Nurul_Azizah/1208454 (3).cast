[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.check_shebang_line=1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/cgi.check-shebang-line\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          45\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; mode skips this line and ignores its content if this directive is turned on.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; script support running both as stand-alone script and via PHP CGI<. PHP in CGI\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; (shebang) at the top of the running script. This line might be needed if the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f29\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.rfc2616_headers = 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/cgi.rfc2616-headers\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Default is zero.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; RFC2616 compliant header.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; is supported by Apache. When this option is set to 1, PHP will send\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; use when sending HTTP response code. If set to 0, PHP sends Status: header that\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; cgi.rfc2616_headers configuration option tells PHP what type of headers to\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;fastcgi.logging = 0\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f19\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; this feature.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Disable logging through FastCGI connection. PHP's default behavior is to enable\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;fastcgi.script_path_encoded = 0\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,1          44\u001b[H\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Default is 1.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; in an encoded format on the file system.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; ProxyPassMatch. This should be used if script file paths are not stored\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Prevent decoding of SCRIPT_FILENAME when using Apache ProxyPass or\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;fastcgi.impersonate = 1\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f09\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/fastcgi.impersonate\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Set to 1 if running under IIS.  Default is zero.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; does not currently support this feature (03/17/2002)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; security context that the request runs under.  mod_fastcgi under Apache\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; security tokens of the calling client.  This allows IIS to define the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; FastCGI under IIS supports the ability to impersonate\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.024, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.discard_path=1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; of the web tree and people will not be able to circumvent .htaccess security.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; if cgi.discard_path is enabled, the PHP CGI binary can safely be placed outside\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f799\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.fix_pathinfo=1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,1          43\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/cgi.fix-pathinfo\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; to use SCRIPT_FILENAME rather than PATH_TRANSLATED.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; of zero causes PHP to behave as before.  Default is 1.  You should fix your scripts\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.021, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; this to 1 will cause PHP CGI to fix its paths to conform to the spec.  A setting\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; what PATH_INFO is.  For more information on PATH_INFO, see the cgi specs.  Setting\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; previous behaviour was to set PATH_TRANSLATED to SCRIPT_FILENAME, and to not grok\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; cgi.fix_pathinfo provides *real* PATH_INFO/PATH_TRANSLATED support for CGI.  PHP's\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f89\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.redirect_status_env =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.047, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/cgi.redirect-status-env\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.014, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; cause security issues, KNOW WHAT YOU ARE DOING FIRST.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; will look for to know it is OK to continue execution.  Setting this variable MAY\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; (iPlanet) web servers, you MAY need to set an environment variable name that PHP\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; if cgi.force_redirect is turned on, and you are not running under Apache or Netscape\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.nph = 1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; every request. PHP's default behavior is to disable this feature.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; if cgi.nph is enabled it will force cgi to always sent Status: 200 with\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f79,1          42\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;cgi.force_redirect = 1\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/cgi.force-redirect\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; **You CAN safely turn this off for IIS, in fact, you MUST.**\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; turn it off here AT YOUR OWN RISK\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; most web servers.  Left undefined, PHP turns this on by default.  You can\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; cgi.force_redirect is necessary to provide security running PHP as a CGI under\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Henable_dl =\u001b[92m Off\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/enable-dl\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f69\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; disabled on them.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; properly in multithreaded servers, such as IIS or Zeus, and is automatically\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Whether or not to enable the dl() function.  The dl() function does NOT work\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;sys_temp_dir = \"/tmp\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Defaults to the system default (see sys_get_temp_dir)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Directory where the temporary files should be placed.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,1          41\u001b[H\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H;extension_dir = \"ext\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; On windows:\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f59\u001b[H\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[Hextension_dir =\u001b[92m \"/usr/lib/php/modules/\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/extension-dir\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Directory in which the loadable extensions (modules) reside.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
