[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; Windows: \"\\path1;\\path2\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
