[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; List of separator(s) used by PHP to parse input URLs into variables.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP's default setting is \"&\".\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,1          31\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; NOTE: Every character in this directive is considered as separator!\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/arg-separator.input\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Example:\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f30\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;arg_separator.input = \";&\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; This directive determines which super global arrays are registered when PHP\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; starts up. G,P,C,E & S are abbreviations for the following respective super\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; globals: GET, POST, COOKIE, ENV and SERVER. There is a performance penalty\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; paid for the registration of these arrays and because ENV is not as commonly\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; used as the others, ENV is not recommended on productions servers. You\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; can still get access to the environment variables through getenv() should you\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; need to.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Default Value: \"EGPCS\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f40\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Development Value: \"GPCS\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Production Value: \"GPCS\";\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/variables-order\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hvariables_order =\u001b[92m \"GPCS\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,1          32\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; This directive determines which super global data (G,P & C) should be\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; registered into the super global array REQUEST. If so, it also determines\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; the order in which that data is registered. The values for this directive\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; are specified in the same manner as the variables_order directive,\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; EXCEPT one. Leaving this value empty will cause PHP to use the value set\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f50\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; in the variables_order directive. It does not mean it will leave the super\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; globals array REQUEST empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Default Value: None\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Development Value: \"GP\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Production Value: \"GP\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/request-order\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hrequest_order =\u001b[92m \"GP\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; This directive determines whether PHP registers $argv & $argc each time it\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; runs. $argv contains an array of all the arguments passed to PHP when a script\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f60\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; is invoked. $argc contains an integer representing the number of arguments\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; that were passed when the script was invoked. These arrays are extremely\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; useful when running scripts from the command line. When this directive is\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          33\r\u001b[A\u001b[?25h"]
[0.017, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; enabled, registering these variables consumes CPU cycles and memory each time\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; a script is executed. For security reasons, this feature should be disabled\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; for non-CLI SAPIs.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Note: This directive is ignored for the CLI SAPI\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; This directive is deprecated.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/register-argc-argv\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;register_argc_argv = Off\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f70\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; When enabled, the ENV, REQUEST and SERVER variables are created when they're\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; first used (Just In Time) instead of when the script starts. If these\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; variables are not used within a script, having this directive on will result\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; in a performance gain. The PHP directive register_argc_argv must be disabled\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; for this directive to have any effect.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/auto-globals-jit\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hauto_globals_jit =\u001b[92m On\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Whether PHP will read the POST data.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f80\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; This option is enabled by default.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,1          34\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Most likely, you won't want to disable this option globally. It causes $_POST\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; and $_FILES to always be empty; the only way you will be able to read the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; POST data will be through the php://input stream wrapper. This can be useful\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; to proxy requests or to process the POST data in a memory efficient fashion.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/enable-post-data-reading\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;enable_post_data_reading = Off\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Maximum size of POST data that PHP will accept.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Its value may be 0 to disable the limit. It is ignored if POST data reading\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f90\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; is disabled through enable_post_data_reading.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/post-max-size\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hpost_max_size =\u001b[92m 8M\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Automatically add files before PHP document.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/auto-prepend-file\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hauto_prepend_file =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Automatically add files after PHP document.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9,1          35\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/auto-append-file\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f700\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hauto_append_file =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; By default, PHP will output a media type using the Content-Type header. To\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; disable this, simply set it to be empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP's built-in default media type is set to text/html.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/default-mimetype\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.027, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hdefault_mimetype =\u001b[92m \"text/html\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP's default character set is set to UTF-8.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f10\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/default-charset\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hdefault_charset =\u001b[92m \"UTF-8\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP internal character encoding is set to empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; If empty, default_charset is used.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/internal-encoding\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;internal_encoding =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,1          36\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP input character encoding is set to empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; If empty, default_charset is used.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f20\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/input-encoding\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.020, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;input_encoding =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP output character encoding is set to empty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; If empty, default_charset is used.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; See also output_buffer.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/output-encoding\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;output_encoding =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.048, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.014, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f30\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Paths and Directories ;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.043, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; UNIX: \"/path1:/path2\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;include_path = \".:/php/includes\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,1          37\r\u001b[A\u001b[?25h"]
[0.018, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; Windows: \"\\path1;\\path2\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.036, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;include_path = \".;c:\\php\\includes\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H;\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; PHP's default setting for include_path is \".;/path/to/php/pear\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f40\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/include-path\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; The root of the PHP pages, used only if nonempty.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; if PHP was not compiled with FORCE_REDIRECT, you SHOULD set doc_root\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; if you are running php as a CGI under any web server (other than IIS)\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; see documentation for security issues.  The alternate is to use the\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.020, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; cgi.force_redirect configuration below\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H; https://php.net/doc-root\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1Hdoc_root =\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f50\r\u001b[A\u001b[?25h"]
