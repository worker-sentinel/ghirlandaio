[0.038, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; https://php.net/input-encoding\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\u001b[H\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; If empty, default_charset is used.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f0\u001b[H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H; PHP input character encoding is set to empty.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f19\u001b[H\u001b[?25h"]
