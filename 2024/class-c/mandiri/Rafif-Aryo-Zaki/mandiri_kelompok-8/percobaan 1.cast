[0.002, "o", "\u001b[1;2H\u001b[1m\u001b[36m Configuration file for locale-gen\u001b[m\u000f\u001b[2;2H\u001b[K\u001b[3;2H\u001b[1m\u001b[36m lists of locales that are to be generated by the locale-gen command.\u001b[m\u000f\u001b[4;2H\u001b[K\u001b[5;2H\u001b[1m\u001b[36m Each line is of the form:\u001b[m\u000f\u001b[6;2H\u001b[K\u001b[7;2H\u001b[1m\u001b[36m     <locale> <charset>\u001b[m\u000f\u001b[8;2H\u001b[K\u001b[9;2H\u001b[1m\u001b[36m  where <locale> is one of the locales given in /usr/share/i18n/locales\r\n#  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\u001b[m\u000f\u001b[11;2H\u001b[K\u001b[12;2H\u001b[1m\u001b[36m  The locale-gen command will generate all the locales,\r\n#  placing them in /usr/lib/locale.\u001b[m\u000f\u001b[14;2H\u001b[K\u001b[15;2H\u001b[1m\u001b[36m  A list of supported locales is given in /usr/share/i18n/SUPPORTED\r\n#  and is included in this file. Uncomment the needed locales below.\u001b[m\u000f\u001b[17;2H\u001b[K\u001b[18;2H\u001b[1m\u001b[36maa_DJ\r\n#aa_DJ ISO-8859-1 \u001b[m\u000f\u001b[19;20H\u001b[K\u001b[20;2H\u001b[1m\u001b[36maa_ER UTF-8  \u001b[m\u000f\u001b[20;15H\u001b[K\u001b[21;2H\u001b[1m\u001b[36maa_ET UTF-8  \u001b[m\u000f\u001b[21;15H\u001b[K\u001b[22;2H\u001b[1m\u001b[36maf_ZA\r\n#af_ZA\r\n#agr_PE UTF-8  \u001b[m\u000f\u001b[24;16H\u001b[K\u001b[25;2H\u001b[1m\u001b[36mak_GH UTF-8  \u001b[m\u000f\u001b[25;15H\u001b[K\u001b[26;2H\u001b[1m\u001b[36mam_ET\r\n#an_ES\r\n#an_ES\u001b[11C5  \r\n#anp_IN UTF-8  \r\n#ar_AE\r\n#ar_AE\u001b[10C6\r\n#ar_BH\r\n#ar_BH\u001b[10C6\r\n#ar_DZ\r\n#ar_DZ\u001b[10C6\r\n#ar_EG\r\n#ar_EG\u001b[10C6\r\n#ar_IN UTF-8  \u001b[m\u000f\u001b[38;15H\u001b[K\u001b[39;2H\u001b[1m\u001b[36mar_IQ.UTF-8 UTF-8  \r\n#ar_IQ ISO-8859-6  \r\n#ar_J\r\n#ar_J\u001b[11C6\r\n#ar_KW\r\n#ar_KW\u001b[10C6\u001b[m\u000f\u001b[45;143H1,1\u001b[11CTop\u001b[?25h\u001b[?0c\u001b[?25l\u001b[?1c\u001b[45;143H\u001b[K\u001b[45;8H\u001b[?25h\u001b[?0c"]
