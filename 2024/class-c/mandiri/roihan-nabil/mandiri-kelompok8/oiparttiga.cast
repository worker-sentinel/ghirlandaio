[4.726, "o", "\u001b[?25l\r\u001b[K\u001b[52;17H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut          \u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute      \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\u001b[53;2H\u001b(B\u001b[0;7mX\u001b(B\u001b[m Exit  \u001b[17G\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace      \u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste        \u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[81G\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line\r\u001b[2d\u001b[K\u001b[3d# Set this to 'yes' to enable PAM authentication, account processing,\r\u001b[4d# and session processing. If this is enabled, PAM authentication will\u001b[5;3Hbe allowed through the KbdInteractiveAuthentication and\u001b[K\u001b[6;3HPasswordAuthentication.  Depending on your PAM configuration,\r\u001b[7d# PAM authentication via KbdInteractiveAuthentication may bypass\u001b[8;3Hthe setting of \"PermitRootLogin prohibit-password\".\u001b[K\r\u001b[9d# If you just want the PAM account and session checks to run without\u001b[10;3HPAM authentication, then enable this but set PasswordAuthentication\u001b[K\u001b[11;3Hand KbdInteractiveAuthentication to 'no'.\u001b[K\r\u001b[12d#UsePAM no\u001b[K\r\u001b[13d\u001b[K\u001b[14d#AllowAgentForwarding yes\r\u001b[15d#AllowTcpForwarding yes\r\u001b[16d#GatewayPorts no\u001b[K\r\u001b[17d#X11Forwarding no\u001b[K\r\u001b[18d#X11DisplayOffset 10\r\u001b[19d#X11UseLocalhost yes\r\u001b[20d#PermitTTY yes\u001b[K\r\u001b[21d#PrintMotd yes\u001b[K\r\u001b[22d#PrintLastLog yes\u001b[K\r\u001b[23d#TCPKeepAlive yes\r\u001b[24d#PermitUserEnvironment no\r\u001b[25d#Compression delayed\u001b[K\r\u001b[26d#\u001b[30m\u001b[103mClientAliveInterval\u001b[39;49m\u001b(B\u001b[m 0\r\u001b[27d#ClientAliveCountMax 3\r\u001b[28d#UseDNS no\u001b[K\r\u001b[29d#PidFile /run/sshd.pid\r\u001b[30d#MaxStartups 10:30:100\r\u001b[31d#PermitTunnel no\u001b[K\r\u001b[32d#ChrootDirectory none\r\u001b[33d#VersionAddendum none\r\u001b[34d\u001b[K\u001b[35d# no default banner path\r\u001b[36d#Banner none\u001b[K\r\u001b[37d\u001b[K\u001b[38d# override default of no subsystems\r\u001b[39dSubsystem       sftp    /usr/lib/ssh/sftp-server\u001b[41;3HExample of overriding settings on a per-user basis\u001b[K\r\u001b[42d#Match User anoncvs\u001b[K\r\u001b[43d#       X11Forwarding no\u001b[K\r\u001b[44d#\u001b[9GAllowTcpForwarding no\r\u001b[45d#       PermitTTY no\u001b[K\r\u001b[46d#\u001b[9GForceCommand cvs server\r\u001b[47d\u001b[K\u001b[48d\u001b[K\u001b[50d\u001b[K\u001b[26d#"]
