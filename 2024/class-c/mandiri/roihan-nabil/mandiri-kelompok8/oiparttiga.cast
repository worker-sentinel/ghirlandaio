[0.002, "o", "\u001b(B\u001b[0;7m[ Search Wrapped ]\u001b(B\u001b[m\u001b[K\u001b[52;17H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut          \u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute      \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\u001b[53;2H\u001b(B\u001b[0;7mX\u001b(B\u001b[m Exit  \u001b[17G\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace      \u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste        \u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[81G\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line\r\u001b[2dLogLevel INFO\u001b[K\r\u001b[3d\u001b[K\u001b[4d# Authentication:\u001b[K\r\u001b[5d\u001b[K\u001b[6dLoginGraceTime 60\u001b[K\r\u001b[7dPermitRootLogin no\u001b[K\r\u001b[8d#StrictModes yes\u001b[K\r\u001b[9dMaxAuthTries 4\r\u001b[10d#MaxSessions 10\r\u001b[11d\u001b[K\u001b[12d#PubkeyAuthentication yes\r\u001b[13d\u001b[K\u001b[14d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\r\u001b[15d# but this is overridden so installations will only check .ssh/authorized_keys\r\u001b[16dAuthorizedKeysFile      .ssh/authorized_keys\r\u001b[17d\u001b[K\u001b[18d#AuthorizedPrincipalsFile none\r\u001b[19d\u001b[K\u001b[20d#AuthorizedKeysCommand none\r\u001b[21d#AuthorizedKeysCommandUser nobody\r\u001b[22d\u001b[K\u001b[23d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\r\u001b[24d# no\u001b[K\r\u001b[25d#"]
[0.001, "o", " Change to yes if you don't trust ~/.ssh/known_hosts for\r\u001b[26d\u001b[30m\u001b[103mHostbased\u001b[39;49m\u001b(B\u001b[mAuthetication no\r\u001b[27d#IgnoreUserKnownHosts no\r\u001b[28d# Don't read the user's ~/.rhosts and ~/.shosts files\r\u001b[29dIgnoreRhosts yes\u001b[K\r\u001b[30d\u001b[K\u001b[31d"]
[0.000, "o", "# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[32d#PasswordAuthentication yes\r\u001b[33dPermitEmptyPasswords no\u001b[35;3HChange to \"no\" to disable keyboard-interactive authentication.  Depending on\r\u001b[36d# the system's configuration, this may involve passwords, challenge-response,\r\u001b[37d# one-time passwords or some combination of these and other methods.\r\u001b[38d#KbdInteractiveAuthentication yes\u001b[K\r\u001b[39d\u001b[K\u001b[40d# Kerberos options\u001b[K\r\u001b[41d#KerberosAuthentication no\u001b[K\r\u001b[42d#KerberosOrLocalPasswd yes\r\u001b[43d#KerberosTicketCleanup yes\u001b[K\r\u001b[44d#KerberosGetAFSToken no\r\u001b[45d\u001b[K\u001b[46d# GSSAPI options\u001b[K\r\u001b[47d#GSSAPIAuthentication no\u001b[K\r\u001b[48d#GSSAPICleanupCredentials yes\r\u001b[50d# Set this to 'yes' to enable PAM authentication, account processing,\r\u001b[26d"]
