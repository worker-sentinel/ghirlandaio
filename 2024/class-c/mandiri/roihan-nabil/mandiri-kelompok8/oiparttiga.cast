[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H"]
[0.050, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# GSSAPI options\r"]
[0.050, "o", "\u001b[?25l"]
