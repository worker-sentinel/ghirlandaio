[0.001, "o", "\r\u001b[2d\u001b[K\u001b[3dLoginGraceTime 60\u001b[K\r\u001b[4dPermitRootLogin no\r\u001b[5d#StrictModes yes\u001b[K\r\u001b[6dMaxAuthTries 4\u001b[K\r\u001b[7d#MaxSessions 10\r\u001b[8d\u001b[K\u001b[9d#PubkeyAuthentication yes\r\u001b[10d\u001b[K\u001b[11d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\u001b[12;3Hbut this is overridden so installations will only check .ssh/authorized_keys\r\u001b[13dAuthorizedKeysFile\u001b[25G.ssh/authorized_keys\r\u001b[15d#AuthorizedPrincipalsFile none\r\u001b[16d\u001b[K\u001b[17d#AuthorizedKeysCommand none\r\u001b[18d#AuthorizedKeysCommandUser nobody\r\u001b[20d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\u001b[21;6HbasedAuthentication no\u001b[K\r\u001b[22d# Change to yes if you don't trust ~/.ssh/known_hosts for\r\u001b[23d# HostbasedAuthentication\r\u001b[24d#IgnoreUserKnownHosts no\r\u001b[25d# Don't read the user's ~/.rhosts and ~/.shosts files\r\u001b[26d#\u001b[30m\u001b[103mIgnoreRhosts\u001b[39;49m\u001b(B\u001b[m yes\r\u001b[27d\u001b[K\u001b[28d# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[29d#PasswordAuthentication yes\r\u001b[30d#PermitEmptyPasswords no\r\u001b[31d\u001b[K\u001b[32d# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\r\u001b[33d# the system's configuration, this may involve passwords, challenge-response,\r\u001b[34d# one-time passwords or some combination of these and other methods.\r\u001b[35d#KbdInteractiveAuthentication yes\r\u001b[36d\u001b[K\u001b[37d# Kerberos options\r\u001b[38d#KerberosAuthentication no\r\u001b[39d#KerberosOrLocalPasswd yes\r\u001b[40d#KerberosTicketCleanup yes\r\u001b[41d#KerberosGetAFSToken no\u001b[K\r\u001b[42d\u001b[K\u001b[43d# GSSAPI options\u001b[K\r\u001b[44d#GSSAPIAuthentication no\r\u001b[45d#GSSAPICleanupCredentials yes\u001b[K\r\u001b[47d# Set this to 'yes' to enable PAM authentication, account processing,\r\u001b[48d# and session processing. If this is enabled, PAM authentication will\r\u001b[49d# be allowed through the KbdInteractiveAuthentication and\u001b[50;3HPasswordAuthentication.  Depending on your PAM configuration,\u001b[K\u001b[51;9H\u001b(B\u001b[0;7mthis instance?     \r\u001b[52d Y\u001b(B\u001b[m Yes \u001b[52;17H\u001b(B\u001b[0;7m A\u001b(B\u001b[m All\u001b[K\r\u001b[53d\u001b(B\u001b[0;7m N\u001b(B\u001b[m No    \u001b[17G\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Cancel\u001b[K\u001b[51;23H"]
