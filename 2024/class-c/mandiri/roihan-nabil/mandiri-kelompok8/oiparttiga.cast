[0.921, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Cnano /etc/ssh/sshd_config\r\n\u001b[?2004l\r"]
[0.012, "o", "\u001b[?2004h"]
[0.000, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[1;53r\u001b(B\u001b[m\u001b[4l\u001b[?7h\u001b[39;49m\u001b[?1h\u001b=\u001b[?1h\u001b=\u001b[?25l"]
[0.001, "o", "\u001b[39;49m\u001b(B\u001b[m\u001b[H\u001b[2J\u001b[51;42H\u001b(B\u001b[0;7m[ Reading... ]\u001b(B\u001b[m"]
[0.000, "o", "\u001b[51;40H\u001b(B\u001b[0;7m[ Read 119 lines ]\u001b(B\u001b[m"]
[0.000, "o", "\u001b[H\u001b(B\u001b[0;7m  GNU nano 9.0                          /etc/ssh/sshd_config                                     \u001b[1;96H\u001b(B\u001b[m"]
[0.000, "o", "\r\u001b[52d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[52;17H"]
[0.000, "o", "\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut\u001b[52;65H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute\u001b[81G\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\r\u001b[53d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Exit\u001b[53;17H"]
[0.000, "o", "\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[49G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste\u001b[53;65H\u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[81G\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line"]
[0.001, "o", "\r\u001b[2d# Include drop-in configurations\r\u001b[3d"]
[0.000, "o", "Include /etc/ssh/sshd_config.d/*.conf\r\u001b[5d# This is the sshd server system-wide configuration file.  See\r\u001b[6d# sshd_config(5) for more information.\r\u001b[8d# This sshd was compiled with PATH=/usr/local/sbin:/usr/local/bin:/usr/bin\r\u001b[10d# The strategy used for options in the default sshd_config shipped with\r\u001b[11d"]
[0.000, "o", "# OpenSSH is to specify options with their default value where\r\u001b[12d# possible, but leave them commented.  Uncommented options override the\r\u001b[13d# default value.\r\u001b[15d#Port 22\r\u001b[16d#AddressFamily any\r\u001b[17d#ListenAddress 0.0.0.0\r\u001b[18d"]
[0.000, "o", "#ListenAddress ::\r\u001b[20d#HostKey /etc/ssh/ssh_host_rsa_key\r\u001b[21d#HostKey /etc/ssh/ssh_host_ecdsa_key\r\u001b[22d#HostKey /etc/ssh/ssh_host_ed25519_key\r\u001b[24d# Ciphers and keying\r\u001b[25d#RekeyLimit default none\r\u001b[27d# Logging\r\u001b[28d#SyslogFacility AUTH\r\u001b[29d#LogLevel INFO\r\u001b[31d# Authentication:\r\u001b[33d#LoginGraceTime 2m\r\u001b[34d#PermitRootLogin prohibit-password\r\u001b[35d#StrictModes yes\r\u001b[36d"]
[0.000, "o", "#MaxAuthTries 6\r\u001b[37d#MaxSessions 10\r\u001b[39d#PubkeyAuthentication yes\r\u001b[41d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\r\u001b[42d# but this is overridden so installations will only check .ssh/authorized_keys\r\u001b[43dAuthorizedKeysFile\u001b[25G.ssh/authorized_keys\r\u001b[45d"]
[0.000, "o", "#AuthorizedPrincipalsFile none\r\u001b[47d#AuthorizedKeysCommand none\r\u001b[48d#AuthorizedKeysCommandUser nobody\r\u001b[50d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\r\u001b[2d\u001b[?12l\u001b[?25h"]
