[0.002, "o", "\u001b(B\u001b[0;7m[ Replaced 0 occurrences ]\u001b(B\u001b[m\u001b[K\r\u001b[52d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[52;17H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut\u001b[52;65H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute\u001b[81G\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\r\u001b[53d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Exit\u001b[53;18H\u001b(B\u001b[0;7mR\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[49G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste\u001b[53;65H\u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[81G\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line\r\u001b[2d# Include drop-in configurations\r\u001b[3dInclude /etc/ssh/sshd_config.d/*.conf\r\u001b[4d\u001b[K\u001b[5d# This is the sshd server system-wide configuration file.  See\r\u001b[6d# sshd_config(5) for more information.\r\u001b[7d\u001b[K\u001b[8d# This sshd was compiled with PATH=/usr/local/sbin:/usr/local/bin:/usr/bin\r\u001b[9d\u001b[K\u001b[10d# The strategy used for options in the default sshd_config shipped with\u001b[11;3HOpenSSH is to specify options with their default value where\u001b[K\u001b[12;3Hpossible, but leave them commented.  Uncommented options override the\u001b[K\r\u001b[13d# default value.\u001b[K\r\u001b[15d#Port 22\u001b[K\r\u001b[16d#AddressFamily any\r\u001b[17d#ListenAddress 0.0.0.0\u001b[K\r\u001b[18d#ListenAddress ::\u001b[K\r\u001b[20d#HostKey /etc/ssh/ssh_host_rsa_key\u001b[K\u001b[21;6HKey /etc/ssh/ssh_host_ecdsa_key\r\u001b[22d#HostKey /etc/ssh/ssh_host_ed25519_key\u001b[K\r\u001b[23d\u001b[K\u001b[24d# Ciphers and keying\u001b[K\r\u001b[25d#RekeyLimit default none\u001b[K\r\u001b[26d\u001b[K\u001b[27d# Logging\r\u001b[28d#SyslogFacility AUTH\u001b[K\r\u001b[29dLogLevel INFO\u001b[K\r\u001b[30d\u001b[K\u001b[31d# Authentication:\r\u001b[32d\u001b[K\u001b[33dLoginGraceTime 60\u001b[K\r\u001b[34dPermitRootLogin no\u001b[K\r\u001b[35d#StrictModes yes\u001b[K\r\u001b[36dMaxAuthTries 4\r\u001b[37d#MaxSessions 10\u001b[K\r\u001b[38d\u001b[K\u001b[39d#PubkeyAuthentication yes\u001b[K\r\u001b[40d\u001b[K\u001b[41d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\r\u001b[42d# but this is overridden so installations will only check .ssh/authorized_keys\r\u001b[43dAuthorizedKeysFile\u001b[25G.ssh/authorized_keys\r\u001b[44d\u001b[K\u001b[45d#AuthorizedPrincipalsFile none\r\u001b[47d#AuthorizedKeysCommand none\u001b[K\r\u001b[48d#AuthorizedKeysCommandUser nobody\u001b[K\r\u001b[49d\u001b[K\u001b[50d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\u001b[8;22H\u001b[?12l\u001b[?25h"]
