[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# and session processing. If this is enabled, PAM authentication will\r"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# be allowed through the KbdInteractiveAuthentication and\r"]
[0.049, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# PasswordAuthentication.  Depending on your PAM configuration,\r"]
[0.049, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# PAM authentication via KbdInteractiveAuthentication may bypass\r"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# the setting of \"PermitRootLogin prohibit-password\".\r"]
[0.051, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# If you just want the PAM account and session checks to run without\r"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# PAM authentication, then enable this but set PasswordAuthentication\r"]
