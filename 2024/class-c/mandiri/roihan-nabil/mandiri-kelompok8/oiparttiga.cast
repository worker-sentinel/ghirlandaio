[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[3T\u001b[1;53r\u001b[2;1H#KerberosTicketCleanup yes\r\u001b[3d"]
[0.001, "o", "#KerberosGetAFSToken no\r\u001b[A"]
[0.005, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[2T\u001b[1;53r\u001b[2;1H#KerberosAuthentication no\r\u001b[3d"]
[0.000, "o", "#KerberosOrLocalPasswd yes\r\u001b[A"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[3T\u001b[1;53r\u001b[2;1H#KbdInteractiveAuthentication yes\r\u001b[4d"]
[0.001, "o", "# Kerberos options\r\u001b[2d"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[3T\u001b[1;53r\u001b[2;1H# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\r\u001b[3d# the system's configuration, this may involve passwords, challenge-response,\r\u001b[4d# one-time passwords or some combination of these and other methods.\r\u001b[2d"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[4T\u001b[1;53r\u001b[2;1H# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[3d#PasswordAuthentication yes\r\u001b[4d#PermitEmptyPasswords no\r\u001b[2d"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[5T\u001b[1;53r\u001b[2;1H# HostbasedAuthentication\r\u001b[3d#IgnoreUserKnownHosts no\r\u001b[4d# Don't read the user's ~/.rhosts and ~/.shosts files\r\u001b[5d#IgnoreRhosts yes\r\u001b[2d"]
[0.010, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[4T\u001b[1;53r\u001b[3;1H# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\r\u001b[4d#HostbasedAuthentication no\r\u001b[5d# Change to yes if you don't trust ~/.ssh/known_hosts for\r\u001b[2d"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[5T\u001b[1;53r\u001b[3;1H#AuthorizedPrincipalsFile none\r\u001b[5d#AuthorizedKeysCommand none\r\u001b[6d#AuthorizedKeysCommandUser nobody\r\u001b[2d"]
[0.005, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[5T\u001b[1;53r\u001b[2;1H#PubkeyAuthentication yes\r\u001b[4d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\r\u001b[5d# but this is overridden so installations will only check .ssh/authorized_keys\r\u001b[6dAuthorizedKeysFile\u001b[25G.ssh/authorized_keys\r\u001b[2d"]
[0.008, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[4T\u001b[1;53r\u001b[2;1H#StrictModes yes\r\u001b[3d#MaxAuthTries 6\r\u001b[4d#MaxSessions 10\r\u001b[2d"]
[0.007, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[5T\u001b[1;53r\u001b[3;1H"]
[0.000, "o", "# Authentication:\r\u001b[5d#LoginGraceTime 2m\r\u001b[6d#PermitRootLogin prohibit-password\r\u001b[2d"]
[0.006, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;50r\u001b8\u001b[8T\u001b[1;53r\u001b[2;1H#HostKey /etc/ssh/ssh_host_ed25519_key\r\u001b[4d# Ciphers and keying\r\u001b[5d#RekeyLimit default none\r\u001b[7d# Logging\r\u001b[8d#SyslogFacility AUTH\r\u001b[9d#LogLevel INFO\r\u001b[2d"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001bM\u001b[1;53r\u001b[2;1H#HostKey /etc/ssh/ssh_host_ecdsa_key\r\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001bM\u001b[1;53r\u001b[2;1H#HostKey /etc/ssh/ssh_host_rsa_key\r"]
[0.000, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;50r\u001b8\u001b[4T\u001b[1;53r\u001b[2;1H#AddressFamily any\r\u001b[3d#ListenAddress 0.0.0.0\r\u001b[4d"]
[0.001, "o", "#ListenAddress ::\r\u001b[2d"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[5T\u001b[1;53r\u001b[2;1H# OpenSSH is to specify options with their default value where\r\u001b[3d# possible, but leave them commented.  Uncommented options override the\r\u001b[4d# default value.\r\u001b[6d#Port 22\r\u001b[2d"]
[0.403, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[5T\u001b[1;53r\u001b[2;1H# sshd_config(5) for more information.\r\u001b[4d# This sshd was compiled with PATH=/usr/local/sbin:/usr/local/bin:/usr/bin\r\u001b[6d# The strategy used for options in the default sshd_config shipped with\r\u001b[2d"]
[0.008, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;50r\u001b8\u001b[4T\u001b[1;53r\u001b[2;1H# Include drop-in configurations\r\u001b[3d"]
