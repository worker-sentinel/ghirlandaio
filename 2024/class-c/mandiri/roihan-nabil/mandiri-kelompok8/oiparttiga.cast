[0.007, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h\u001b[50d"]
[0.014, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H#HostbasedAuthentication no\r"]
[0.006, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# Change to yes if you don't trust ~/.ssh/known_hosts for\r"]
[0.009, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# HostbasedAuthentication\r"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H#IgnoreUserKnownHosts no\r"]
[0.006, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H# Don't read the user's ~/.rhosts and ~/.shosts files\r"]
[0.007, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H#IgnoreRhosts yes\r\u001b[50d"]
[0.007, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[50d#PasswordAuthentication yes\r"]
[0.008, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H#PermitEmptyPasswords no\r"]
[0.005, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[50;1H# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\r"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\u001b[2S\u001b[1;53r\u001b[49;1H# the system's configuration, this may involve passwords, challenge-response,\r\u001b[50d"]
[0.000, "o", "# one-time passwords or some combination of these and other methods.\r"]
[0.008, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H#KbdInteractiveAuthentication yes\r\u001b[50d"]
[0.005, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H# Kerberos options\r"]
[0.007, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.001, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H#KerberosAuthentication no\r\u001b[50d#KerberosOrLocalPasswd yes\r"]
[0.006, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H#KerberosTicketCleanup yes\r"]
[0.014, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H#KerberosGetAFSToken no\r"]
[0.014, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H# GSSAPI options\r"]
[0.014, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H#GSSAPIAuthentication no\r"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H#GSSAPICleanupCredentials yes\r\u001b[50d"]
[0.008, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# Set this to 'yes' to enable PAM authentication, account processing,\r"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H"]
[0.000, "o", "# and session processing. If this is enabled, PAM authentication will\r\u001b[50d"]
[0.000, "o", "# be allowed through the KbdInteractiveAuthentication and\r"]
[0.695, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H# PasswordAuthentication.  Depending on your PAM configuration,\r"]
[0.008, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H# PAM authentication via KbdInteractiveAuthentication may bypass\r"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\u001b[2S\u001b[1;53r\u001b[49;1H# the setting of \"PermitRootLogin prohibit-password\".\r\u001b[50d"]
[0.000, "o", "# If you just want the PAM account and session checks to run without\r"]
[0.007, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H"]
[0.000, "o", "# PAM authentication, then enable this but set PasswordAuthentication\r"]
[0.006, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\u001b[2S\u001b[1;53r\u001b[49;1H# and KbdInteractiveAuthentication to 'no'.\r\u001b[50d#UsePAM no\r"]
[0.009, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d\u001b[2S\u001b[1;53r\u001b[50;1H#AllowAgentForwarding yes\r"]
[0.005, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\n\u001b[1;53r\u001b[50;1H#AllowTcpForwarding yes\r"]
[0.007, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;51r\u001b8\u001b[51d"]
[0.000, "o", "\u001b[2S\u001b[1;53r\u001b[49;1H#GatewayPorts no\r\u001b[50d#X11Forwarding no\r"]
[0.008, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d\n\u001b[1;53r\u001b[50;1H#X11DisplayOffset 10\r"]
[0.005, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;51r\u001b8\u001b[51d"]
