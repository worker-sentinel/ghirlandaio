ault_socket_timeout = 60\u001b[K\r\u001b[13d\u001b[K\u001b[14d; If your scripts have to deal with files from Macintosh systems,\r\u001b[15d; or you are running on a Mac and need to deal with files from\u001b[16;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[K\u001b[17;3Hautomatically detect the EOL character in those files so that\u001b[K\u001b[18;3Hfgets() and file() will work regardless of the source of the file.\u001b[K\r\u001b[19d; https://php.net/auto-detect-line-endings\r\u001b[20d;auto_detect_line_endings = Off\r\u001b[21d\u001b[K\u001b[22d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[23d; Dynamic Extensions ;\r\u001b[24d;;;;;;;;;;;;;;;;;;;;;;\r\u001b[25d\u001b[K\u001b[26d; If you wish to have an extension loaded automatically, use the following\r\u001b[27d; syntax:\u001b[K\r\u001b[28d;\u001b[29d\b;   extension=modulename\u001b[30;3H\u001b[K\u001b[31dFor example:\u001b[K\u001b[32;3H\u001b[K\u001b[33d  \u001b[30m\u001b[43mextension=mysqli\u001b[39;49m\u001b[m\u000f\u001b[K\u001b[34;3H\u001b[K\u001b[35dWhen the extension library to load is not located in the default extension\r\u001b[36d; directory, You may specify an absolute path to the library file:\r\u001b[37d;\u001b[38d   extension=/path/to/extension/mysqli.so\u001b[K\u001b[39;3H\u001b[K\u001b[40dNote : The syntax used in previous PHP versions ('extension=<ext>.so' and\u001b[41;3H'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[42;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[43;3Hmove to the new ('extension=<ext>) syntax.\u001b[K\u001b[44;3H\u001b[K\u001b[45d\bextension=bcmath\r\u001b[46d;extension=bz2\r\u001b[47d;extension=calendar\u001b[K\r\u001b[48dextension=curl\u001b[K\r\u001b[49d;extension=dba\u001b[K\r\u001b[50d;extension=enchant\u001b[K\r\u001b[51d;extension=exif\u001b[K\r\u001b[52d;extension=ffi\u001b[K\r\u001b[53d;extension=ftp\u001b[K\r\u001b[54dextension=gd\r\u001b[55d;extension=gettext\r\u001b[56d;extension=gmp\u001b[K\r\u001b[57d;extension=iconv\u001b[K\r\u001b[58dextension=intl\u001b[K\r\u001b[59d;extension=ldap\u001b[K\r\u001b[60dextension=mysqli\u001b[K\r\u001b[61d;extension=odbc\r\u001b[62d;extension=pdo_dblib\u001b[K\r\u001b[63dextension=pdo_mysql\r\u001b[64d;extension=pdo_odbc\u001b[33;5H"]
