[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; query string will also return status for each pool process.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Example:\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   http://www.foo.bar/status?full\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   http://www.foo.bar/status?json&full\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   http://www.foo.bar/status?html&full\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   http://www.foo.bar/status?xml&full\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; The Full status returns for each process:\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   pid\u001b[64;26H- the PID of the process;\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   state\u001b[64;26H- the state of the process (Idle, Running, ...);\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d\b"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;   start time\u001b[64;26H- the date and time the process has started;\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   start since\u001b[64;26H- the number of seconds since the process has started;\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   requests\u001b[64;26H- the number of requests the process has served;\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   request duration     - the duration in µs of the requests;\r;"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   request method\u001b[26G- the request method (GET, POST, ...);\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   request URI\u001b[64;26H- the request URI with the query string;\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   content length\u001b[26G- the content length of the request (only with POST);\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   user\u001b[64;26H- the user (PHP_AUTH_USER) (or '-' if not set);\r;"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;   script\u001b[64;26H- the main script called (or '-' if not set);\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   last request cpu     - the %cpu the last request consumed\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hit's always 0 if the process is not in Idle state\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hbecause CPU calculation is done when the request\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hprocessing has terminated;\r;"]
[0.960, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d\b"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.001, "o", ";   last request memory  - the max amount of memory the last request consumed\r;"]
[0.249, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hit's always 0 if the process is not in Idle state\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hbecause memory calculation is done when the request\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hprocessing has terminated;\r;"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; If the process is in Idle state, then information is related to the\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; last request the process has served. Otherwise information is related to\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; the current request being served.\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Example output:\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   ************************\r;"]
