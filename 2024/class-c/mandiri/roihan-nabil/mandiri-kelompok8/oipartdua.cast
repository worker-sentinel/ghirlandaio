[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.001, "o", ";   php_admin_value/php_admin_flag - these directives won't be overwritten by\r;"]
[0.023, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;\u001b[64;39HPHP call 'ini_set'\r;"]
