[0.003, "o", "\u001b[65;112H\u001b[0;10;7m\u000f[ Read 489 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                              /etc/php/php-fpm.d/www.conf                                                                                                         \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d; Start a new pool named 'www'.\r\u001b[3d; the variable $pool can be used in any directive and will be replaced by the\r\u001b[4d; pool name ('www' here)\r\u001b[5d[www]\r\u001b[7d; Per pool prefix\r\u001b[8d; It only applies on the following directives:\r\u001b[9d; - 'access.log'\r\u001b[10d; - 'slowlog'\r\u001b[11d; - 'listen' (unixsocket)\r\u001b[12d; - 'chroot'\r\u001b[13d; - 'chdir'\r\u001b[14d; - 'php_values'\r\u001b[15d; - 'php_admin_values'\r\u001b[16d; When not set, the global prefix (or /usr) applies instead.\r\u001b[17d; Note: This directive can also be relative to the global prefix.\r\u001b[18d; Default Value: none\r\u001b[19d;prefix = /path/to/pools/$pool\r\u001b[21d; Unix user/group of the child processes. This can be used only if the master\r\u001b[22d; process running user is root. It is set after the child process is created.\r\u001b[23d; The user and group can be specified either by their name or by their numeric\r\u001b[24d; IDs.\r\u001b[25d; Note: If the user is root, the executable needs to be started with\r\u001b[26d;\u001b[9G--allow-to-run-as-root option to work.\r\u001b[27d; Default Values: The user is set to master process running user by default.\r\u001b[28d;\u001b[28;19HIf the group is not set, the user's group is used.\r\u001b[29duser = http\r\u001b[30dgroup = http\r\u001b[32d; The address on which to accept FastCGI requests.\r\u001b[33d; Valid syntaxes are:\r\u001b[34d;   'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\r\u001b[35d;\u001b[35;30Ha specific port;\r\u001b[36d;   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\r\u001b[37d;\u001b[37;30Ha specific port;\r\u001b[38d;   'port'\u001b[38;28H- to listen on a TCP socket to all addresses\r\u001b[39d;\u001b[39;30H(IPv6 and IPv4-mapped) on a specific port;\r\u001b[40d;   '/path/to/unix/socket' - to listen on a unix socket.\r\u001b[41d; Note: This value is mandatory.\r\u001b[42dlisten = /run/php-fpm/php-fpm.sock\r\u001b[44d; Set listen(2) backlog.\r\u001b[45d; Default Value: 511 (-1 on Linux, FreeBSD and OpenBSD)\r\u001b[46d;listen.backlog = 511\r\u001b[48d; Set permissions for unix socket, if one is used. In Linux, read/write\r\u001b[49d; permissions must be set in order to allow connections from a web server. Many\r\u001b[50d; BSD-derived systems allow connections regardless of permissions. The owner\r\u001b[51d; and group can be specified either by name or by their numeric IDs.\r\u001b[52d; Default Values: Owner is set to the master process running user. If the group\r\u001b[53d;\u001b[53;19His not set, the owner's group is used. Mode is set to 0660.\r\u001b[54dlisten.owner = http\r\u001b[55dlisten.group = http\r\u001b[56d;listen.mode = 0660\r\u001b[58d; When POSIX Access Control Lists are supported you can set them using\r\u001b[59d; these options, value is a comma separated list of user/group names.\r\u001b[60d; When set, listen.owner and listen.group are ignored\r\u001b[61d;listen.acl_users =\r\u001b[62d;listen.acl_groups =\r\u001b[64d; List of addresses (IPv4/IPv6) of FastCGI clients which are allowed to connect.\r\u001b[2d\u001b[?25h\u001b[?0c"]
