[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; The precedence is: default_charset < output_encoding < iconv.output_encoding\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; To use an output encoding conversion, iconv's output handler must be set\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; otherwise output encoding conversion cannot be performed.\r"]
