[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Development Value: Off\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Default Value: On\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; used regardless of this directive.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Note that this directive does not control the <?= shorthand tag, which can be\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; documents, however this remains supported for backward compatibility reasons.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; should be disabled, as enabling it may result in issues when generating XML\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; generally recommended that <?php and ?> should be used and that this feature\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; <? and ?> tags as PHP source which should be processed as such. It is\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; This directive determines whether or not PHP will recognize code between\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hengine = On\re"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; https://php.net/engine\r;"]
