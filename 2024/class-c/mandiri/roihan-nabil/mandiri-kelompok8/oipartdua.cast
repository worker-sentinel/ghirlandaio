[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; recommending using the production ini in production and testing environments.\u001b[64;57H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; php.ini-development is very similar to its production variant, except it is\u001b[64;57H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; much more verbose when it comes to errors. We recommend using the\u001b[64;57H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; development version only in development environments, as errors shown to\u001b[64;57H"]
