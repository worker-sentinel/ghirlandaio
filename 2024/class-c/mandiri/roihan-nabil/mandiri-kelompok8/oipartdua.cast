[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; happens within intl functions. The value is the level of the error produced.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; Default is 0, which does not produce any errors.\r"]
