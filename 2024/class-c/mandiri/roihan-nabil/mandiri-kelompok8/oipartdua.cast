[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.002, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; protects from caching of incompletely updated files. In case all file updates\r"]
