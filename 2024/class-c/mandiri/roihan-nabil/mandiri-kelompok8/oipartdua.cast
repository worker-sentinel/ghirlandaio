[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; Defines which queries will be logged.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H;mysqlnd.log_mask = 0\r"]
