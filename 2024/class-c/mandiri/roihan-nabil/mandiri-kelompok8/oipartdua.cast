[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;;;;;;;;;;;;;;;;;;;\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Quick Reference ;\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H;;;;;;;;;;;;;;;;;;;\r;"]
