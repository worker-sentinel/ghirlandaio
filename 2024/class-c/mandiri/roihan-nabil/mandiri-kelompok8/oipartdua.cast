[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Development Value: 4096\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Default Value: Off\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Note: This directive is hardcoded to Off for the CLI SAPI\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H;   Integer = Enables the buffer and sets its maximum size in bytes.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H;   Off = Disabled\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H;   On = Enabled and buffer is unlimited. (Use with caution)\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Possible Values:\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H;   functions.\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Note: Output buffering can also be controlled via Output Buffering Control\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; reasons.\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; as it gets it. On production servers, 4096 bytes is a good setting for performance\r;"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; emitting less packets due to buffered output versus PHP streaming the output\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; through print or echo. You also may see performance benefits if your server is\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; You may be able to send headers and cookies after you've already sent output\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; interesting side-effects depending on your application and web server.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Turning on this setting and managing its maximum buffer size can yield some\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; will send that data in chunks of roughly the size you specify.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; data to the client. If your application's output exceeds this setting, PHP\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; (excluding headers and cookies) PHP should keep internally before pushing that\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; Output buffering is a mechanism for controlling how much output data\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hprecision = 14\rp"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; https://php.net/precision\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; The number of significant digits displayed in floating point numbers.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hshort_open_tag = Off\rs"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; https://php.net/short-open-tag\r;"]
