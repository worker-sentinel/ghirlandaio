[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;rlimit_core = 0\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Chroot to this directory at the start. This value must be defined as an\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; absolute path. When this value is not set, chroot is not used.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Note: you can prefix with '$prefix' to chroot to the pool prefix or one\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; of its subdirectories. If the pool prefix is not set, the global prefix\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; will be used instead.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Note: chrooting is a great security feature and should be used whenever\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.002, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[9Gpossible. However, all PHP paths will be relative to the chroot\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[9G(error_log, sessions.save_path, ...).\r;"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Default Value: not set\r;"]
