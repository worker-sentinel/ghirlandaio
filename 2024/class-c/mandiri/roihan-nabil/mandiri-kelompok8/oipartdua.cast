[0.000, "o", "\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[2;3HStart a new pool named 'www'"]
[0.000, "o", ".\u001b[K\u001b[3;3Hthe variable $pool can be used in any directive and will be replaced by the\u001b[4;4Hool name ('www' here)\u001b[K\r\u001b[5d[www]\u001b[K\r\u001b[6d\u001b[K\u001b[7d"]
[0.000, "o", "; Per pool prefix\u001b[8;3HIt only applies on the following directives:\u001b[K\u001b[9;3H- 'access.log'\u001b[K\u001b[10;3H- 'slowlog'\u001b[K\u001b[11;3H- 'listen' (unixsocket)\u001b[K\u001b[12;3H- 'chroot'\u001b[K\r\u001b[13d; - 'chdir'\u001b[K\r\u001b[14d; - 'php_values'\u001b[15;3H- 'php_admin_values'\u001b[K\u001b[16;3HWhen not set, the global prefix (or /usr) applies instead.\u001b[K\u001b[17;3HNote: This directive can also be relative to the global prefix.\u001b[K\u001b[18;3HDefault Value: none\u001b[K\r\u001b[19d;prefix = /path/to/pools/$pool\u001b[K\r\u001b[20d\u001b[K\u001b[21d; "]
[0.000, "o", "Unix user/group of the child processes. This can be used only if the master\r\u001b[22d;"]
[0.001, "o", " process running user is root. It is set after the child process is created.\r\u001b[23d; The user and group can be specified either by their name or by their numeric\u001b[24;3HIDs.\u001b[K\u001b[25;3HNote: If the user is root, the executable needs to be started with\u001b[K\u001b[26;3H      --allow-to-run-as-root option to work.\u001b[K\u001b[27;3HDefault Values: The user is set to master process running user by default.\u001b[28;3H\u001b[16X\u001b[28;19HIf the group is not set, the user's group is used.\r\u001b[29d\u001b[30m\u001b[43muser = http\u001b[39;49m\u001b[m\u000f\u001b[K\r\u001b[30dgroup = http\u001b[K\u001b[32;3HThe address on which to accept FastCGI requests.\u001b[K\u001b[33;3HValid syntaxes are:\u001b[K\u001b[34;3H  'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\r\u001b[35d;\u001b[28X\u001b[35;30Ha specific port;\r\u001b[36d;   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\r\u001b[37d;\u001b[15X\u001b[37;30Ha specific port;\r\u001b[38d;   'port'         \u001b[38;28H- to listen on a TCP socket to all addresses\r\u001b[39d;\u001b[16X\u001b[39;30H(IPv6 and IPv4-mapped) on a specific port;\r\u001b[40d;   '/path/to/unix/socket' - to listen on a unix socket.\u001b[41;3HNote: This value is mandatory.\u001b[K\r\u001b[42dlisten = /run/php-fpm/php-fpm.sock\u001b[K\r\u001b[43d\u001b[K\u001b[44d; Set listen(2) backlog.\u001b[K\u001b[45;3HDefault Value: 511 (-1 on Linux, FreeBSD and OpenBSD)\u001b[K\r\u001b[46d;listen.backlog = 511\u001b[K\r\u001b[47d\u001b[K\u001b[48d; Set permissions for unix socket, if one is used. In Linux, read/write\u001b[K\r\u001b[49d; permissions must be set in order to allow connections from a web server. Many\u001b[50;3HBSD-derived systems allow connections regardless of permissions. The owner\u001b[51;3H"]
[0.001, "o", "and group can be specified either by name or by their numeric IDs.\u001b[K\u001b[52;3HDefault Values: Owner is set to the master process running user. If the group\r\u001b[53d;\u001b[53;19His not set, the owner's group is used. Mode is set to 0660.\r\u001b[54dlisten.owner = http\u001b[K\r\u001b[55dlisten.group = http\u001b[K\r\u001b[56d;listen.mode = 0660\r\u001b[57d\u001b[K\u001b[58d; When POSIX Access Control Lists are supported you can set them using\r\u001b[59d; these options, value is a comma separated list of user/group names.\u001b[K\r\u001b[60d; When set, listen.owner and listen.group are ignored\r\u001b[61d;listen.acl_users =\u001b[K\r\u001b[62d;listen.acl_groups =\u001b[K\r\u001b[63d\u001b[K\u001b[64d; List of addresses (IPv4/IPv6) of FastCGI clients which are allowed to connect.\r\u001b[29d"]
