[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[2;38H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; An empty string can be denoted by simply not writing anything after the equal\u001b[2;57H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; They can be turned off using the values 0, Off, False or No.\u001b[57G"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; Boolean flags can be turned on using the values 1, On, True or Yes.\u001b[2;57H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; !  boolean NOT"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; ~  bitwise NOT"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; &  bitwise AND"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; ^  bitwise XOR"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; |  bitwise OR"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[2;57H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.028, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8"]
[0.002, "o", "\u001bM\u001b[1;67r\u001b[2;1H; previously set variable or directive (e.g. ${foo})"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[2;57H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[2;57H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[2;57H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; directive because it is not set or is mistyped, a default value will be used.\u001b[2;57H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; There is no name validation.  If PHP can't find an expected\u001b[57G"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; Directives are variables used to configure PHP or PHP extensions.\u001b[2;57H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[2;57H"]
