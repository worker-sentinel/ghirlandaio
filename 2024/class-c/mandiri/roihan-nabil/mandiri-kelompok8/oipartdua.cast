[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Default Value: 32\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;pm.max_spawn_rate = 32\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; The number of seconds after which an idle process will be killed.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Note: Used only when pm is set to 'ondemand'\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Default Value: 10s\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;pm.process_idle_timeout = 10s;\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; The number of requests each child process should execute before respawning.\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; This can be useful to work around memory leaks in 3rd party libraries. For\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; endless request processing specify '0'. Equivalent to PHP_FCGI_MAX_REQUESTS.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; Default Value: 0\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;pm.max_requests = 500\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; The URI to view the FPM status page. If this value is not set, no URI will be\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H; recognized as a status page. It shows the following information:\r;"]
[1.618, "o", "\u001b[?25l\u001b[?1c"]
[0.002, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   pool\u001b[64;26H- the name of the pool;\r;"]
[0.250, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   process manager\u001b[26G- static, dynamic or ondemand;\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   start time\u001b[64;26H- the date and time FPM has started;\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   start since\u001b[64;26H- number of seconds since FPM has started;\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   accepted conn\u001b[64;26H- the number of request accepted by the pool;\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   listen queue\u001b[64;26H- the number of request in the queue of pending\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hconnections (see backlog in listen(2));\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b"]
[0.002, "o", "\n\u001b[1;67r\u001b[64;1H;   max listen queue     - the maximum number of requests in the queue\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hof pending connections since FPM has started;\r;"]
[0.025, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d\b"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H;   listen queue len     - the size of the socket queue of pending connections;\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   idle processes\u001b[26G- the number of idle processes;\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   active processes     - the number of active processes;\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   total processes\u001b[26G- the number of idle + active processes;\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   max active processes - the maximum number of active processes since FPM\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hhas started;\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;   max children reached - number of times, the process limit has been reached,\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28Hwhen pm tries to start more children (works only for\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d\b\n\u001b[1;67r\u001b[64;1H;\u001b[64;28H"]
[0.001, "o", "pm 'dynamic' and 'ondemand');\r;"]
