[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; The following are all the settings which are different in either the production\r;"]
