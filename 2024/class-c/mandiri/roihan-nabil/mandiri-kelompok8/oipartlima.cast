[0.000, "o", "\r\u001b[2d|\u001b[K\u001b[3d\b|       For the 'database' driver, it's a table name.\u001b[K\r\u001b[4d|\u001b[9GPlease read up the manual for the format with other session drivers.\r\u001b[5d|\u001b[K\u001b[6d       IMPORTANT: You are REQUIRED to set a valid save path!\u001b[K\u001b[7;3H\u001b[K\u001b[8d\b 'sess_match_ip'\u001b[K\u001b[10;3H"]
[0.001, "o", "      Whether to match the user's IP address when reading the session data.\u001b[11;3H\u001b[K\u001b[12;9H"]
[0.000, "o", "WARNING: If you're using the database driver, don't forget to update\u001b[13;9H         your session table's PRIMARY KEY when changing this setting.\u001b[15;3H"]
[0.000, "o", "'sess_time_to_update'\u001b[K\u001b[17;3H      How many seconds between CI regenerating the session ID.\u001b[K\u001b[18;3H\u001b[K\u001b[19d'sess_regenerate_destroy'\u001b[K\u001b[20;3H\u001b[K\u001b[21d      Whether to destroy session data associated with the old session ID\u001b[22;9Hwhen auto-regenerating the session ID. When set to FALSE, the data\u001b[23;3H      will be later deleted by the garbage collector.\u001b[K\u001b[24;3H\u001b[K\u001b[25dOther session cookie settings are shared with the rest of the application,\r\u001b[26d| except for 'cookie_prefix' and 'cookie_httponly', which are ignored here.\r\u001b[27d|\u001b[K\u001b[28d\b*/\r\u001b[29d"]
[0.001, "o", "\u001b[30m\u001b[103m$config['sess\u001b[39;49m\u001b(B\u001b[m_driver'] = 'files';\r\u001b[30d$config['sess_cookie_name'] = 'arteri';\u001b[K\r\u001b[31d$config['sess_expiration'] = 7200;\r\u001b[32d$config['sess_save_path'] = sys_get_temp_dir();\u001b[K\r\u001b[33d$config['sess_match_ip'] = FALSE;\r\u001b[34d$config['sess_time_to_update'] = 300;\u001b[K\r\u001b[35d$config['sess_regenerate_destroy'] = FALSE;\u001b[K\r\u001b[36d\u001b[K\u001b[37d/*\r\u001b[38d|--------------------------------------------------------------------------\r\u001b[39d| Cookie Related Variables\u001b[K\r\u001b[40d|--------------------------------------------------------------------------\r\u001b[41d|\u001b[K\u001b[42d 'cookie_prefix'   = Set a cookie name prefix if you need to avoid collisions\u001b[43;3H'cookie_domain'   = Set to .your-domain.com for site-wide cookies\r\u001b[44d| 'cookie_path'     = Typically will be a forward slash\u001b[K\u001b[45;3H'cookie_secure'   = Cookie will only be set if a secure HTTPS connection exists.\u001b[46;3H'cookie_httponly' = Cookie will only be accessible via HTTP(S) (no javascript)\u001b[47;3H\u001b[K\u001b[48dNote: These settings (with the exception of 'cookie_prefix' and\u001b[K\u001b[49;9H'cookie_httponly') will also affect sessions.\u001b[50;3H\u001b[K\r\u001b[51d"]
[0.000, "o", "*/\u001b[K\r\u001b[52d"]
[0.000, "o", "$config['cookie_prefix']        = '';\u001b[K\r\u001b[53d$config['cookie_domain']\u001b[53;33H= '';\r\u001b[54d$config['cookie_path']          = '/';\u001b[K\r\u001b[55d$config['cookie_secure']\u001b[55;33H"]
[0.000, "o", "= FALSE;\u001b[56;10Hcookie_httponly']      = FALSE\r\u001b[29d"]
