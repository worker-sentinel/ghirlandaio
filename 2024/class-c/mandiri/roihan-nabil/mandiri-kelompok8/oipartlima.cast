ample.com/\r\u001b[14d|\u001b[15d\b| WARNING: You MUST set this value!\r\u001b[16d|\u001b[17d\b| If it is not set, then CodeIgniter will try guess the protocol and path\r\u001b[18d| your installation, but due to security concerns the hostname will be set\r\u001b[19d| to $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\r\u001b[20d| The auto-detection mechanism exists only for convenience during\r\u001b[21d| development and MUST NOT be used in production!\r\u001b[22d|\u001b[23d\b| If you need to allow multiple domains, remember that this file is still\r\u001b[24d| a PHP script and you can easily do that on your own.\r\u001b[25d|\u001b[26d\b*/\r\u001b[27d$config['base_url'] = (isset($_SERVER['HTTPS']) ? \"https://\" : \"http://\") . $_SERVER['HTTP_HOST'] . ROOT;\r\u001b[29d/*\r\u001b[30d|--------------------------------------------------------------------------\r\u001b[31d| Index File\r\u001b[32d|--------------------------------------------------------------------------\r\u001b[33d|\u001b[34d\b| Typically this will be your index.php file, unless you've renamed it to\r\u001b[35d| something else. If you are using mod_rewrite to remove the page set this\r\u001b[36d| variable so that it is blank.\r\u001b[37d|\u001b[38d\b*/\r\u001b[39d$config['index_page'] = 'index.php';\r\u001b[41d/*\r\u001b[42d|--------------------------------------------------------------------------\r\u001b[43d| URI PROTOCOL\r\u001b[44d|--------------------------------------------------------------------------\r\u001b[45d|\u001b[46d\b| This item determines which server global should be used to retrieve the\r\u001b[47d| URI string.  The default setting of 'REQUEST_URI' works for most servers.\r\u001b[48d| If your links do not seem to work, try one of the other delicious flavors:\r\u001b[49d|\u001b[50d\b| 'REQUEST_URI'    Uses $_SERVER['REQUEST_URI']\r\u001b[51d| 'QUERY_STRING'   Uses $_SERVER['QUERY_STRING']\r\u001b[52d| 'PATH_INFO'\u001b[20GUses $_SERVER['PATH_INFO']\r\u001b[53d|\u001b[54d\b| WARNING: If you set this to 'PATH_INFO', URIs will always be URL-decoded!\r\u001b[55d*/\r\u001b[56d$config['uri_protocol'] = 'REQUEST_URI';\r\u001b[2d\u001b[?12l\u001b[?25h"]
