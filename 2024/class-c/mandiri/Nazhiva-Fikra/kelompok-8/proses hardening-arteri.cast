[0.022, "o", "\u001b[?25l\u001b[48;160H \r\u001b[46A        # deny access to .htaccess files, if Apache's document root\r\n        # concurs with nginx's one\r\n        #\r\n        #location ~ /\\.ht {\r\n        #    deny  all;\u001b[12X\r\n        #}\u001b[23X\u001b[8;5H}\r\n\u001b[27X\n\n    # another virtual host using mix of IP-, name-, and port-based configuration\r\n    #\u001b[23X\r\n    #server {\u001b[12X\r\n    #    listen       8000;\r\n    #    listen       somename:8080;\r\n    #    server_name  somename  alias  another.alias;\r\n \r\n    #    location / {\r\n    #        root   html;\r\n    #        index  index.html index.htm;\r\n    #    }\u001b[19X\r\n    #}\u001b[37X\r\n\n\u001b[78X\u001b[25;7HHTTPS server\u001b[48X\u001b[26;6H\u001b[63X\r\n    #server {\u001b[28;6H    listen       443 ssl;\u001b[9X\r\n    #    server_name  localhost;\u001b[30;5H\u001b[19X\u001b[31;6H    ssl_certificate      cert.pem;\r\n    #    ssl_certificate_key  cert.key;\r\n\u001b[26X\n    #    ssl_session_cache    shared:SSL:1m;\r\n    #    ssl_session_timeout  5m;\r\n\u001b[14X\n    #    ssl_ciphers  HIGH:!aNULL:!MD5;\r\n    #    ssl_prefer_server_ciphers  on;\u001b[39;9H\u001b[16X\r\n    #    location / {\u001b[10X\r\n    #        root   html;\u001b[42;5H#        index  index.html index.htm;\u001b[7X\r\n    #    }\r\n    #}\u001b[14X\u001b[45;13H\u001b[29X\r\n}\u001b[39X\u001b[47;154H\u001b[0;10;7m\u000f18,1          Bot\r\u001b[A\u001b[?25h"]
