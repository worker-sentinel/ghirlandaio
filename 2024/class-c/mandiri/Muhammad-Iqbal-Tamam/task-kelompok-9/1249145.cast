[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#COMPRESSION_OPTIONS=()\u001b[K\b\b\u001b[0;10;4;1m\u000f()\u001b[66;224H\u001b[0;10;7m\u000f1,24          37\u001b[65;24H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[64;22H()\u001b[66;224H\u001b[0;10;7m\u000f2,1           43\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# MODULES_DECOMPRESS\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,21          50\u001b[65;21H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,73          56\u001b[65;73H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# creation. Switch (yes/no).\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f5,29          62\u001b[65;29H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Enable to allow further decreasing image size when using high compression\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,76          68\u001b[65;76H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# (e.g. xz -9e or zstd --long --ultra -22) at the expense of increased RAM usage\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,81          75\u001b[65;81H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# at early boot.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,17          81\u001b[65;17H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Note that any compressed files will be placed in the uncompressed early CPIO\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,79          87\u001b[65;79H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# to avoid double compression.\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f80,31          93\u001b[65;31H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#MODULES_DECOMPRESS=\"no\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,25          Bot\u001b[65;25H\u001b[?25h"]
