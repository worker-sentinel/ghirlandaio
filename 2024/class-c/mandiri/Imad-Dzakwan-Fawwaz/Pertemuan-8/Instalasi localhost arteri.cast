[0.000, "o", "#error_log  logs/error.log  info;\r\u001b[10d#pid\u001b[10;13Hlogs/nginx.pid;\r\u001b[13d# Load all installed modules\r\u001b[14dinclude modules.d/*.conf;\r\u001b[16devents {\u001b[17;5Hworker_connections  1024;\r\u001b[18d}\u001b[21d\bhttp {\u001b[22d\b\binclude\u001b[19Gmime.types;\u001b[23;5Hdefault_type  application/octet-stream;\u001b[25;5H"]
[0.000, "o", "#log_format  main  '$remote_addr - $remote_user [$time_local] \"$request\" '\u001b[26;5H#\u001b[26;24H'$status $body_bytes_sent \"$http_referer\" '\u001b[27;5H#\u001b[27;24H'\"$http_user_agent\" \"$http_x_forwarded_for\"';\u001b[29;5H"]
[0.000, "o", "#access_log  logs/access.log  main;\u001b[31;5Hsendfile\u001b[31;21Hon;\u001b[32;5H"]
