[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; will send that data in chunks of roughly the size you specify.\u001b[45;57H"]
