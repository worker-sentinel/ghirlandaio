[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; as it gets it. On production servers, 4096 bytes is a good setting for performance\u001b[45;57H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
