[0.001, "o", "\u001b[46;77H\u001b[0;10;7m\u000f[ Read 139 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                 /etc/sudoers.tmp                                                                           \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d## sudoers file.\r\u001b[3d##\r\u001b[4d## This file MUST be edited with the 'visudo' command as root.\r\u001b[5d## Failure to use 'visudo' may result in syntax or file permission errors\r\u001b[6d## that prevent sudo from running.\r\u001b[7d##\r\u001b[8d## See the sudoers man page for the details on how to write a sudoers file.\r\u001b[9d##\r\u001b[11d##\r\u001b[12d## Host alias specification\r\u001b[13d##\r\u001b[14d## Groups of machines. These may include host names (optionally with wildcards),\r\u001b[15d## IP addresses, network numbers or netgroups.\r\u001b[16d# Host_Alias    WEBSERVERS = www1, www2, www3\r\u001b[18d##\r\u001b[19d## User alias specification\r\u001b[20d##\r\u001b[21d## Groups of users.  These may consist of user names, uids, Unix groups,\r\u001b[22d## or netgroups.\r\u001b[23d# User_Alias    ADMINS = millert, dowdy, mikef\r\u001b[25d##\r\u001b[26d## Cmnd alias specification\r\u001b[27d##\r\u001b[28d## Groups of commands.  Often used to group related commands together.\r\u001b[29d# Cmnd_Alias    PROCESSES = /usr/bin/nice, /bin/kill, /usr/bin/renice, \\\r\u001b[30d#\u001b[30;29H/usr/bin/pkill, /usr/bin/top\r\u001b[31d#\u001b[32d\b# Cmnd_Alias    REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff\r\u001b[33d#\u001b[34d\b# Cmnd_Alias    DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bin/strace, \\\r\u001b[35d#\u001b[35;29H/usr/bin/truss, /usr/bin/bpftrace, \\\r\u001b[36d#\u001b[36;29H/usr/bin/dtrace, /usr/bin/dtruss\r\u001b[37d#\u001b[38d\b# Cmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \\\r\u001b[39d#\u001b[39;26H/usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \\\r\u001b[40d#\u001b[40;26H/usr/bin/pacman\r\u001b[42d##\r\u001b[43d## Defaults specification\r\u001b[44d##\r\u001b[45d## Preserve editor environment variables for visudo.\r\u001b[2d\u001b[?25h\u001b[?0c"]
[1.883, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "## \u001b[K\u001b[3dPreserve editor environment variables for visudo.\u001b[4;5Ho preserve these for all commands, remove the \"!visudo\" qualifier.\r\u001b[5dDefaults!/usr/bin/visudo env_keep += \"SUDO_EDITOR EDITOR VISUAL\"\u001b[K\u001b[6;4H\u001b[K\u001b[7dUse a hard-coded PATH instead of the user's to find commands.\u001b[8;4H"]
[0.000, "o", "This also helps prevent poorly written scripts from running\u001b[K\u001b[9;4Harbitrary commands under sudo.\r\u001b[10dDefaults secure_path=\"/usr/local/sbin:/usr/local/bin:/usr/bin\"\u001b[12;4HYou may wish to keep some of the following environment variables\u001b[13;4Hwhen running commands via sudo.\u001b[14;4H\u001b[K\u001b[15dLocale settings\u001b[K\u001b[16;3HDefaults env_keep += \"LANG LANGUAGE LINGUAS LC_* _XKB_CHARSET\"\r\u001b[17d##\u001b[18d Run X applications through sudo; HOME is used to find the\u001b[19;4H.Xauthority file.  Note that other programs use HOME to find\u001b[20;4Hconfiguration files and this may lead to privilege escalation!\r\u001b[21d# Defaults env_keep += \"HOME\"\u001b[K\u001b[22;4H\u001b[K\u001b[23d\b\b"]
[0.001, "o", "# X11 resource path settings\u001b[K\r\u001b[24d# Defaults env_keep += \"XAPPLRESDIR XFILESEARCHPATH XUSERFILESEARCHPATH\"\u001b[26;4HDesktop path settings\u001b[K\r\u001b[27d# Defaults env_keep += \"QTDIR KDEDIR\"\u001b[28;4H\u001b[K\u001b[29d\b\b# Allow sudo-run commands to inherit the callers' ConsoleKit session\u001b[K\u001b[30;3HDefaults env_keep += \"XDG_SESSION_COOKIE\"\u001b[K\r\u001b[31d##\u001b[32d\b# Uncomment to enable special input methods.  Care should be taken as\r\u001b[33d## this may allow users to subvert the command being run via sudo.\u001b[34;3HDefaults env_keep += \"XMODIFIERS GTK_IM_MODULE QT_IM_MODULE QT_IM_SWITCHER\"\r\u001b[35d##\u001b[K\u001b[36d\b# Uncomment to disable \"use_pty\" when running commands as root.\r\u001b[37d## Commands run as non-root users will run in a pseudo-terminal,\r\u001b[38d## not the user's own terminal, to prevent command injection.\u001b[K\u001b[39;3HDefaults>root !use_pty\u001b[K\r\u001b[40d##\u001b[K\r\u001b[41d## Uncomment to run commands in the background by default.\u001b[42;4HThis can be used to prevent sudo from consuming user input while\u001b[43;4Ha non-interactive command runs if \"use_pty\" or I/O logging are\u001b[44;4Henabled.  Some commands may not run properly in the background.\r\u001b[45d# Defaults exec_background\u001b[K\r\u001b[2d"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.276, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "## enabled.  Some commands may not run properly in the background.\r\u001b[3d# Defaults exec_background\u001b[K\u001b[4;4H\u001b[K\r\u001b[5d## Uncomment to send mail if the user does not enter the correct password.\r\u001b[6d# Defaults mail_badpass\u001b[7;4H\u001b[K\u001b[8dUncomment to enable logging of a command's output, except for\u001b[9;4Hsudoreplay and reboot.  Use sudoreplay to play back logged sessions.\r\u001b[10d"]
[0.000, "o", "## Sudo will create up to 2,176,782,336 I/O logs before recycling them.\u001b[11;4HSet maxseq to a smaller number if you don't have unlimited disk space.\r\u001b[12d# Defaults log_output\u001b[K\r\u001b[13d# Defaults!/usr/bin/sudoreplay !log_output\r\u001b[14d# Defaults!/usr/local/bin/sudoreplay !log_output\r\u001b[15d# Defaults!REBOOT !log_output\u001b[16;12Hmaxseq = 1000\u001b[K\u001b[18;4HUncomment to disable intercept and log_subcmds for debuggers and\u001b[19;4Htracers.  Otherwise, anything that uses ptrace(2) will be unable\u001b[20;4Hto run under sudo if intercept_type is set to \"trace\".\u001b[K\u001b[21;11H!DEBUGGERS !intercept, !log_subcmds\u001b[23;4HUncomment to disable intercept and log_subcmds for package managers.\r\u001b[24d## Some package scripts run a huge number of commands, which is made\u001b[K\u001b[25;4Hslower by these options and also can clutter up the logs.\r\u001b[26d# Defaults!PKGMAN !intercept, !log_subcmds\r\u001b[27d##\u001b[K\u001b[28d "]
[0.001, "o", "Uncomment to disable PAM silent mode.  Otherwise messages by PAM\u001b[29;4Hmodules such as pam_faillock will not be printed.\u001b[K\u001b[30;12H!pam_silent\u001b[K\r\u001b[31d\u001b[K\u001b[32;4H\u001b[K\u001b[33dRunas alias specification\u001b[K\r\u001b[34d##\u001b[K\r\u001b[35d\u001b[K\u001b[36;4H\u001b[K\u001b[37dUser privilege specification\u001b[K\u001b[38;4H\u001b[K\r\u001b[39droot ALL=(ALL:ALL) ALL\u001b[K\r\u001b[40d\u001b[K\u001b[41;17Hallow members of group wheel to execute any command\r\u001b[42d# %wheel ALL=(ALL:ALL) ALL\u001b[K\r\u001b[43d\u001b[K\u001b[44;4HSame thing without a password\u001b[K\u001b[45;3H%wheel ALL=(ALL:ALL) NOPASSWD: ALL\r\u001b[2d\u001b[?25h\u001b[?0c"]
[0.028, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "## Same thing without a password\u001b[K\u001b[3;3H%wheel ALL=(ALL:ALL) NOPASSWD: ALL\r\u001b[4d\u001b[K\u001b[5;17Hallow members of group sudo to execute any command\u001b[K\u001b[6;3H%sudo ALL=(ALL:ALL) ALL\r\u001b[7d\u001b[K\u001b[8;17Hallow any user to run sudo if they know the password\u001b[9;4Hof the user they are running the command as (root by default).\u001b[K\r\u001b[10d#"]
[0.000, "o", " Defaults targetpw  # Ask for the password of the target user\u001b[K\r\u001b[11d#"]
[0.000, "o", " ALL ALL=(ALL:ALL) ALL  # WARNING: only use this together with 'Defaults targetpw'\r\u001b[12d\u001b[K\u001b[13d## Read drop-in files from /etc/sudoers.d\u001b[K\r\u001b[14d@includedir /etc/sudoers.d\u001b[K\r\u001b[15d\u001b[K\u001b[16d\u001b[K\u001b[17d"]
