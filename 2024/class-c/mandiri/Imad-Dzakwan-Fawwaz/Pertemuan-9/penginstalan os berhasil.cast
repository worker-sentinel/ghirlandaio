[0.000, "o", "\u001b)0\u001b[1;48r\u001b[m\u000f\u001b[4l\u001b[?7h\u001b[39;49m\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[39;49m\u001b[m\u000f\u001b[H\u001b[J\u001b[46;79H\u001b[0;10;7m\u000f[ Reading... ]\u001b[m\u000f"]
[0.000, "o", "\u001b[46;77H\u001b[0;10;7m\u000f[ Read 64 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                /etc/default/grub                                                                           \u001b[1;169H\u001b[m\u000f"]
[0.001, "o", "\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d# GRUB boot loader configuration\r\u001b[4dGRUB_DEFAULT=0\r\u001b[5dGRUB_TIMEOUT=5\r\u001b[6dGRUB_DISTRIBUTOR=\"Arch\"\r\u001b[7dGRUB_CMDLINE_LINUX_DEFAULT=\"loglevel=3 quiet\"\r\u001b[8dGRUB_CMDLINE_LINUX=\"\"\r\u001b[10d# Preload both GPT and MBR modules so that they are not missed\r\u001b[11dGRUB_PRELOAD_MODULES=\"part_gpt part_msdos\"\r\u001b[13d# Uncomment to enable booting from LUKS encrypted devices\r\u001b[14d#GRUB_ENABLE_CRYPTODISK=y\r\u001b[16d# Set to 'countdown' or 'hidden' to change timeout behavior,\r\u001b[17d# press ESC key to display menu.\r\u001b[18dGRUB_TIMEOUT_STYLE=menu\r\u001b[20d# Uncomment to use basic console\r\u001b[21dGRUB_TERMINAL_INPUT=console\r\u001b[23d# Uncomment to disable graphical terminal\r\u001b[24d#GRUB_TERMINAL_OUTPUT=console\r\u001b[26d# The resolution used on graphical terminal\r\u001b[27d# note that you can use only modes which your graphic card supports via VBE\r\u001b[28d# you can see them in real GRUB with the command `videoinfo'\r\u001b[29dGRUB_GFXMODE=auto\r\u001b[31d# Uncomment to allow the kernel use the same resolution used by grub\r\u001b[32dGRUB_GFXPAYLOAD_LINUX=keep\r\u001b[34d# Uncomment if you want GRUB to pass to the Linux kernel the old parameter\r\u001b[35d# format \"root=/dev/xxx\" instead of \"root=/dev/disk/by-uuid/xxx\"\r\u001b[36d#GRUB_DISABLE_LINUX_UUID=true\r\u001b[38d# Uncomment to disable generation of recovery mode menu entries\r\u001b[39dGRUB_DISABLE_RECOVERY=true\r\u001b[41d# Uncomment and set to the desired menu colors.  Used by normal and wallpaper\r\u001b[42d# modes only.  Entries specified as foreground/background.\r\u001b[43d#GRUB_COLOR_NORMAL=\"light-blue/black\"\r\u001b[44d#GRUB_COLOR_HIGHLIGHT=\"light-cyan/blue\"\r\u001b[2d\u001b[?25h\u001b[?0c"]
[1.104, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[3d"]
