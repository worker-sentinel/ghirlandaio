[0.523, "o", "\u001b[?25l\u001b[?1c\u001b[1;161H\u001b[0;10;7m\u000fModified\u001b[m\u000f"]
[0.001, "o", "\r\u001b[14d\u001b[1P\u001b[?25h\u001b[?0c"]
[0.541, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[15d"]
[0.278, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b[16d"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[17d"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[18d"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[19d"]
[0.314, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[2d#GRUB_COLOR_HIGHLIGHT=\"light-cyan/blue\"\r\u001b[4d# Uncomment one of them for the gfx desired, a image background or a gfxtheme\r\u001b[5d#GRUB_BACKGROUND=\"/path/to/wallpaper\"\r\u001b[6d#GRUB_THEME=\"/path/to/gfxtheme\"\r\u001b[7d\u001b[K\u001b[8d# Uncomment to get a beep at GRUB start\r\u001b[9d#GRUB_INIT_TUNE=\"480 440 1\"\r\u001b[10d\u001b[K\u001b[11d"]
[0.000, "o", "# Uncomment to make GRUB remember the last selection. This requires\r\u001b[12d# setting 'GRUB_DEFAULT=saved' above.\r\u001b[13d#GRUB_SAVEDEFAULT=true\u001b[K\r\u001b[14d\u001b[K\u001b[15d# Uncomment to disable submenus in boot menu\r\u001b[16d#GRUB_DISABLE_SUBMENU=y\u001b[K\r\u001b[17d\u001b[K\u001b[18d# Probing for other operating systems is disabled for security reasons. Read\r\u001b[19d# documentation on GRUB_DISABLE_OS_PROBER, if still want to enable this\u001b[20;3Hfunctionality install os-prober and uncomment to detect and include other\r\u001b[21d# operating systems.\u001b[K\r\u001b[22d"]
[0.000, "o", "#GRUB_DISABLE_OS_PROBER=false\r\u001b[23d"]
