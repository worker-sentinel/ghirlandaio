[0.000, "o", "\u001b[?25l\u001b[m\u000f<?php\u001b[K\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| DATABASE CONNECTIVITY SETTINGS\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| This file will contain the settings needed to access your database.\u001b[K\r\n|\u001b[K\r\n| For complete instructions please consult the 'Database Connection'\u001b[K\r\n| page of the User Guide.\u001b[K\r\n|\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| EXPLANATION OF VARIABLES\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n|       ['dsn']      The full DSN string describe a connection to the database.\u001b[K\r\n|       ['hostname'] The hostname of your database server.\u001b[K\r\n|       ['username'] 'arteri'\u001b[K\r\n|       ['password'] '1234'\u001b[K\r\n|       ['database'] 'arteri'\u001b[K\r\n|       ['dbdriver'] The database driver. e.g.: mysqli.\u001b[K\r\n|                       Currently supported:\u001b[K\r\n|                                cubrid, ibase, mssql, mysql, mysqli, oci8,\u001b[K\r\n|                                odbc, pdo, postgre, sqlite, sqlite3, sqlsrv\u001b[K\r\n|       ['dbprefix'] You can add an optional prefix, which will be added\u001b[K\r\n|                                to the table name when using the  Query Builder class\u001b[K\r\n|       ['pconnect'] TRUE/FALSE - Whether to use a persistent connection\u001b[K\r\n|       ['db_debug'] TRUE/FALSE - Whether database errors should be displayed.\u001b[K\r\n|       ['cache_on'] TRUE/FALSE - Enables/disables query caching\u001b[K\r\n|       ['cachedir'] The path to the folder where cache files should be stored\u001b[K\r\n|       ['char_set'] The character set used in communicating with the database\u001b[K\r\n|       ['dbcollat'] The character collation used in communicating with the database\u001b[K\r\n|                                NOTE: For MySQL and MySQLi databases, this setting is only used\u001b[K\r\n|                                as a backup if your server is running PHP < 5.2.3 or MySQL < 5.0.7\u001b[K\r\n|                                (and in table creation queries made with DB Forge).\u001b[K\r\n|                                There is an incompatibility in PHP with mysql_real_escape_string() which\u001b[K\r\n|                                can make your site vulnerable to SQL injection if you are using a\u001b[K\r\n|                                multi-byte character set and are running versions lower than these.\u001b[K\r\n|                                Sites using Latin-1 or UTF-8 database character set and collation are unaffected.\u001b[K\r\n|       ['swap_pre'] A default table prefix that should be swapped with the dbprefix\u001b[K\r\n|       ['encrypt']  Whether or not to use an encrypted connection.\u001b[K\r\n|\u001b[K\r\n|                       'mysql' (deprecated), 'sqlsrv' and 'pdo/sqlsrv' drivers accept TRUE/FALSE\u001b[K\r\n|                       'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\u001b[K\r\n|\u001b[K\r\n\u001b[0;10;7m\u000f/usr/share/nginx/html/arteri/application/config/database.php                                                                                            1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H<?php\u001b[K\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| DATABASE CONNECTIVITY SETTINGS\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| This file will contain the settings needed to access your database.\u001b[K\r\n|\u001b[K\r\n| For complete instructions please consult the 'Database Connection'\u001b[K\r\n| page of the User Guide.\u001b[K\r\n|\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| EXPLANATION OF VARIABLES\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n|       ['dsn']      The full DSN string describe a connection to the database.\u001b[K\r\n|       ['hostname'] The hostname of your database server.\u001b[K\r\n|       ['username'] 'arteri'\u001b[K\r\n|       ['password'] '1234'\u001b[K\r\n|       "]
[0.000, "o", "['database'] 'arteri'\u001b[K\r\n|       ['dbdriver'] The database driver. e.g.: mysqli.\u001b[K\r\n|                       Currently supported:\u001b[K\r\n|                                cubrid, ibase, mssql, mysql, mysqli, oci8,\u001b[K\r\n|                                odbc, pdo, postgre, sqlite, sqlite3, sqlsrv\u001b[K\r\n|       ['dbprefix'] You can add an optional prefix, which will be added\u001b[K\r\n|                                to the table name when using the  Query Builder class\u001b[K\r\n|       ['pconnect'] TRUE/FALSE - Whether to use a persistent connection\u001b[K\r\n|       ['db_debug'] TRUE/FALSE - Whether database errors should be displayed.\u001b[K\r\n|       ['cache_on'] TRUE/FALSE - Enables/disables query caching\u001b[K\r\n|       ['cachedir'] The path to the folder where cache files should be stored\u001b[K\r\n|       ['char_set'] The character set used in communicating with the database\u001b[K\r\n|       ['dbcollat'] The character collation used in communicating with the database\u001b[K\r\n|                                NOTE: For MySQL and MySQLi databases, this setting is only used\u001b[K\r\n|                                as a backup if your server is running PHP < 5.2.3 or MySQL < 5.0.7\u001b[K\r\n|                                (and in table creation queries made with DB Forge).\u001b[K\r\n|                                There is an incompatibility in PHP with mysql_real_escape_string() which\u001b[K\r\n|                                can make your site vulnerable to SQL injection if you are using a\u001b[K\r\n|                                multi-byte character set and are running versions lower than these.\u001b[K\r\n|                                Sites using Latin-1 or UTF-8 database character set and collation are unaffected.\u001b[K\r\n|       ['swap_pre'] A default table prefix that should be swapped with the dbprefix\u001b[K\r\n|       ['encrypt']  Whether or not to use an encrypted connection.\u001b[K\r\n|\u001b[K\r\n|                       'mysql' (deprecated), 'sqlsrv' and 'pdo/sqlsrv' drivers accept TRUE/FALSE\u001b[K\r\n|                       'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\u001b[K\r\n|\u001b[K\r\n\u001b[0;10;7m\u000f/usr/share/nginx/html/arteri/application/config/database.php                                                                                            1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
[0.066, "o", "\u001b[?25l\u001b[?1004h\u001b[?25h"]
[21.358, "o", "\u001b[?25l\u001b[48;160HG\u001b[H\u001b[?25h"]
[0.013, "o", "\u001b[?25l\u001b[48;160H \u001b[H|                               'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\r\n|                               'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\r\n|\r\n|       ['compress'] Whether or not to use client compression (MySQL only)\u001b[5;3H      ['stricton'] TRUE/FALSE - forces 'Strict Mode' connections   \u001b[6;3H                                                      - good for ensuring strict SQL while developing\u001b[7;3H      ['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\u001b[8;3H      ['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[9;2H       ['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[10;3H                              NOTE: Disabling this will also effectively disable both\u001b[11;3H                              $this->db->last_query() and profiling of DB queries.\u001b[12;2H                               When you run a query, with this setting set to TRUE (default),\u001b[13;3H                              CodeIgniter will store the SQL statement for debugging purposes.\u001b[14;3H                              However, this may cause high memory usage, especially if you run\u001b[15;3H                              a lot of SQL queries ... disable this to avoid that problem.\u001b[17;3HThe $active_group variable lets you choose which connection group to\u001b[9X\u001b[18;3Hmake active.  By default there is only one group (the 'default' group).\u001b[19;2H\u001b[28X\u001b[20;3HThe $query_builder variables lets you determine whether or not to load\u001b[21;3Hthe query builder class.   \r\n*/\u001b[53X\r\n$\u001b[94mactive_group\u001b[m\u000f = \u001b[92m'default'\u001b[m\u000f;\u001b[18X\r\n$\u001b[94mquery_builder\u001b[m\u000f = TRUE;\u001b[53X\r\n\u001b[76X\n$\u001b[94mdb\u001b[m\u000f[\u001b[92m'default'\u001b[m\u000f] = array\u001b[0;10;4;1m\u000f(\u001b[m\u000f\u001b[49X\r\n        \u001b[92m'dsn'\u001b[m\u000f   => \u001b[92m''\u001b[m\u000f,\u001b[64X\r\n        \u001b[92m'hostname'\u001b[m\u000f => \u001b[92m'localhost'\u001b[m\u000f,\u001b[38X\r\n        \u001b[92m'username'\u001b[m\u000f => \u001b[92m'root'\u001b[m\u000f,\u001b[49X\r\n        \u001b[92m'password'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[39X\r\n        \u001b[92m'database'\u001b[m\u000f => \u001b[92m'arteri'\u001b[m\u000f,\u001b[47X\r\n        \u001b[92m'dbdriver'\u001b[m\u000f => \u001b[92m'mysqli'\u001b[m\u000f,\u001b[47X\r\n        \u001b[92m'dbprefix'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[59X\r\n        \u001b[92m'pconnect'\u001b[m\u000f => FALSE,\u001b[68X\r\n        \u001b[92m'db_debug'\u001b[m\u000f => (ENVIRONMENT \u001b[0;10;1m\u000f!==\u001b[m\u000f \u001b[92m'production'\u001b[m\u000f),\u001b[46X\r\n        \u001b[92m'cache_on'\u001b[m\u000f => FALSE,\u001b[56X\r\n        \u001b[92m'cachedir'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[80X\r\n        \u001b[92m'char_set'\u001b[m\u000f => \u001b[92m'utf8'\u001b[m\u000f,\u001b[69X\r\n        \u001b[92m'dbcollat'\u001b[m\u000f => \u001b[92m'utf8_unicode_ci'\u001b[m\u000f,\u001b[60X\r\n        \u001b[92m'swap_pre'\u001b[m\u000f => \u001b[92m''\u001b[m\u000f,\u001b[89X\r\n        \u001b[92m'encrypt'\u001b[m\u000f => FALSE,\u001b[57X\r\n        \u001b[92m'compress'\u001b[m\u000f => FALSE,\u001b[39X\r\n        \u001b[92m'stricton'\u001b[m\u000f => FALSE,\r\n        \u001b[92m'failover'\u001b[m\u000f => array(),\u001b[67X\r\n        \u001b[92m'save_queries'\u001b[m\u000f => TRUE\u001b[70X\r\n\u001b[0;10;4;1m\u000f)\u001b[m\u000f;\u001b[47;153H\u001b[0;10;7m\u000f96,1           Bot\r\u001b[A\u001b[?25h"]
