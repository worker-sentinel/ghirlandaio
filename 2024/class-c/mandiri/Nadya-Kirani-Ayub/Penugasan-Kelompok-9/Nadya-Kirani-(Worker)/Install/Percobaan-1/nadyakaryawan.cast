[0.004, "o", "\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m      Network name                      Security            Signal\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K  \u001b[1;90m> \u001b[0m  Kelawai Ciputat 01                psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Target Sales_5G                   psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      DIRECT-NA-SW-22AE NF              psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Warkop Kelawai                    psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Warkop Kelawai - 5G               psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Rokets                            psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Egie                              psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      realme C71                        psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      pledis                            psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Paja                              psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Aww                               psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Galaxy A35 5G 33E1                psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Infinix NOTE 10                   psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Office Only                       psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      apansi                            psk                 ***\u001b[1;90m*\u0