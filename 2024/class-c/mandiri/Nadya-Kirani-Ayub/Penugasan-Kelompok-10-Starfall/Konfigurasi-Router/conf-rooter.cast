[0.043, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# interface.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                         \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?2026l"]
[0.041, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                                    \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?2026l"]
[0.065, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l"]
[0.002, "o", "\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The transmitting interface is visible to all stations in the vicinity, however\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                     \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\r\u001b[A\u001b[?2026l"]
[0.018, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# the stations that do not support parsing of the Multiple BSSID element will\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                        \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\r\u001b[A\u001b[?2026l"]
[0.022, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l"]
[0.001, "o", "\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# not be able to connect to the non-transmitting interfaces.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                         \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m7\r\u001b[A\u001b[?2026l"]
[0.043, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                                    \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8\r\u001b[A\u001b[?2026l"]
[0.042, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Enhanced Multiple BSSID Advertisements (EMA)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                       \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\r\u001b[A\u001b[?2026l"]
[0.042, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# When enabled, the non-transmitting interfaces are split into multiple\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                              \u001b[48;198H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m40\r\u001b[A\u001b[?2026l"]
[0.041, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Beacon frames. The number of Beacon frames required to cover all the\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                               \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m1\r\u001b[A\u001b[?2026l"]
[0.042, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# non-transmitting profiles is called the profile periodicity.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                       \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m2\r\u001b[A\u001b[?2026l"]
[0.052, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l"]
[0.001, "o", "\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                                    \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?2026l"]
[0.033, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l"]
[0.000, "o", "\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Refer to IEEE Std 802.11-2020 for details regarding the procedure and\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                              \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?2026l"]
