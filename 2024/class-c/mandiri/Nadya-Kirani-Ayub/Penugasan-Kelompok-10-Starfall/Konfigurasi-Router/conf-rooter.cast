[0.038, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# interfaces). Other BSSIDs can be added by using separator 'bss' with\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                               \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\r\u001b[A\u001b[?2026l"]
[0.021, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# default interface name to be allocated for the data packets of the new BSS.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                        \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\r\u001b[A\u001b[?2026l"]
