[0.071, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l"]
[0.002, "o", "\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# not the case, the MAC address of the radio must be changed before starting\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                         \u001b[48;198H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m90\r\u001b[A\u001b[?2026l"]
[0.013, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# hostapd (ifconfig wlan0 hw ether <MAC addr>). If a BSSID is configured for\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                         \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m1\r\u001b[A\u001b[?2026l"]
[0.044, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# every secondary BSS, this limitation is not applied at hostapd and other\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                           \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m2\r\u001b[A\u001b[?2026l"]
[0.041, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# masks may be used if the driver supports them (e.g., swap the locally\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                              \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?2026l"]
[0.021, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# administered bit)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                  \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?2026l"]
[0.042, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                                    \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\r\u001b[A\u001b[?2026l"]
[0.042, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# BSSIDs are assigned in order to each BSS, unless an explicit BSSID is\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                              \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\r\u001b[A\u001b[?2026l"]
[0.042, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# specified using the 'bssid' parameter.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                             \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m7\r\u001b[A\u001b[?2026l"]
[0.054, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# If an explicit BSSID is specified, it must be chosen such that it:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                 \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8\r\u001b[A\u001b[?2026l"]
[0.032, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# - results in a valid MASK that covers it and the dev_addr\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                          \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\r\u001b[A\u001b[?2026l"]
[0.041, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# - is not the same as the MAC address of the radio\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                  \u001b[48;197H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m300\r\u001b[A\u001b[?2026l"]
