[0.048, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# hostapd will generate BSSID mask based on the BSSIDs that are\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                      \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8\r\u001b[A\u001b[?2026l"]
