[0.032, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                                                                    \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?2026l"]
[0.045, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Multiple BSSID Advertisement in IEEE 802.11ax\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                                                      \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\r\u001b[A\u001b[?2026l"]
[0.041, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# IEEE Std 802.11ax-2021 added a feature where instead of multiple interfaces\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                        \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\r\u001b[A\u001b[?2026l"]
[0.078, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# on a common radio transmitting individual Beacon frames, those interfaces can\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                      \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m7\r\u001b[A\u001b[?2026l"]
[0.005, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l"]
[0.002, "o", "\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# form a set with a common Beacon frame transmitted for all. The interface\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                           \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8\r\u001b[A\u001b[?2026l"]
[0.019, "o", "\u001b[?2026h\u001b[49;203H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?2026l\u001b[?2026h\u001b[49;203H   \u001b[1;47r\u001b[H\u001b[M\u001b[r\u001b[47;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# which is brought up first is called the transmitting profile of the MBSSID\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m                                                                                                                                         \u001b[48;199H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\r\u001b[A\u001b[?2026l"]
