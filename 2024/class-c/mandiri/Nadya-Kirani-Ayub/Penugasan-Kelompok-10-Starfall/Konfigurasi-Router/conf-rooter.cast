[0.025, "o", "\u001b]11;?\u0007\u001b[5n\u001b[?25l\u001b(B\u001b[m\u001b[H                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                       "]
