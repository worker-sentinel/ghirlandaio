[0.024, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# at early boot.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           91\r\u001b[A\u001b[?25h"]
