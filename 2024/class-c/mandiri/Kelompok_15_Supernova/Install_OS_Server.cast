[0.025, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1           80\r\u001b[A\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# creation. Switch (yes/no).\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           82\r\u001b[A\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Enable to allow further decreasing image size when using high compression\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           85\r\u001b[A\u001b[?25h"]
