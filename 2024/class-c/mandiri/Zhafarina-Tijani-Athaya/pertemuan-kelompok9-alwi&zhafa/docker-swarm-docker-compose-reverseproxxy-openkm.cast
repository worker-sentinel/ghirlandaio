[0.003, "o", "\u001b[?25l\u001b[?2031h\u001b[>4;2m\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#user http;\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mworker_processes\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m  \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m;\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#error_log  logs/error.log;\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#error_log  logs/error.log  notice;\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#error_log  logs/error.log  info;\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#pid        logs/nginx.pid;\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Load all installed modules\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27minclude\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m modules.d/*.conf;\u001b[K\r\n\u001b[K\n\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mevents\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m {\u001b[K\r\n    \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mworker_connections\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m  \u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m1024\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m;\u001b[K\r\