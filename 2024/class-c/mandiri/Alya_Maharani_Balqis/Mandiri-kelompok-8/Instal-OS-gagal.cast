[0.002, "o", "\u001b[?25l\u001b[32;103H   \u001b[1;30r\u001b[H\u001b[M\u001b[1;32r\u001b[30;1H##   This setup specifies all modules in the MODULES setting above.\u001b[K\u001b[31;97H\u001b[0;10;7m\u000f1,1            1%\r\u001b[A\u001b[?25h"]
