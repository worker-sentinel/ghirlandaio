[0.006, "o", "\rSystem:\u001b[0m\u001b[m\r\nNot booted with EFI\u001b[m\r\n\u001b[m\r\nAvailable Boot Loaders on ESP:\u001b[0m\u001b[m\r\n          ESP: /boot\u001b[m\r\n         File: ├─\u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/systemd/systemd-bootx64.efi (\u001b[0;1;39msystemd-boot 260.2-2-arch\u001b[0m)\u001b[m\r\n               └─\u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/BOOT/BOOTX64.EFI (\u001b[0;1;39msystemd-boot 260.2-2-arch\u001b[0m)\u001b[m\r\n\u001b[m\r\nBoot Loader Entry Locations:\u001b[0m\u001b[m\r\n          ESP: /boot (\u001b[0;32m$BOOT\u001b[0m)\u001b[m\r\n       config: \u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/loader/loader.conf\u001b[m\r\n        token: arch\u001b[m\r\n\u001b[m\r\nDefault Boot Loader Entry:\u001b[0m\u001b[m\r\n         type: Boot Loader Specification Type #2 (UKI, .efi)\u001b[m\r\n        title: \u001b[0;1;39mArch Linux\u001b[0m\u001b[m\r\n           id: arch-linux-hardened.efi\u001b[m\r\n       source: \u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/Linux/arch-linux-hardened.efi (on the EFI System Partition)\u001b[m\r\n     sort-key: arch\u001b[m\r\n      version: 7.0.10-hardened1-1-hardened\u001b[m\r\n        linux: \u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/Linux/arch-linux-hardened.efi\u001b[m\r\n      profile: 0\u001b[m\r\n      options: rd.luks.name=f2889ac8-c902-4e35-a3bb-73e6e426668c=delapan root=/dev/agoy/root rw\u001b[m\r\n\r\u001b[K"]
