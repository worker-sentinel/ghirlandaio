[0.030, "o", "\b\b\b\b\bn -sf /usr/share/zoneinfo/Asia/Jakarta /etc/localtime"]
[0.030, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[34Pnvim /etc/locale.gen"]
