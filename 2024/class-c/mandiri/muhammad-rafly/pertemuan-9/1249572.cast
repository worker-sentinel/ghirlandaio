[0.004, "o", "\u001b[01m\u001b[Kmlock.c:\u001b[m\u001b[K In function ‘\u001b[01m\u001b[Kmain\u001b[m\u001b[K’:\r\n\u001b[01m\u001b[Kmlock.c:75:31:\u001b[m\u001b[K \u001b[01;35m\u001b[Kwarning: \u001b[m\u001b[Kimplicit declaration of function ‘\u001b[01m\u001b[Kgetegid\u001b[m\u001b[K’; did you mean ‘\u001b[01m\u001b[Kgetgrgid\u001b[m\u001b[K’? [\u001b[01;35m\u001b[K-Wimplicit-function-declaration\u001b[m\u001b[K]\r\n   75 |   if (!grp || (grp->gr_gid != \u001b[01;35m\u001b[Kgetegid\u001b[m\u001b[K ()))\r\n      |                               \u001b[01;35m\u001b[K^~~~~~~\u001b[m\u001b[K\r\n      |                               \u001b[32m\u001b[Kgetgrgid\u001b[m\u001b[K\r\n\u001b[01m\u001b[Kmlock.c:94:3:\u001b[m\u001b[K \u001b[01;35m\u001b[Kwarning: \u001b[m\u001b[Kimplicit declaration of function ‘\u001b[01m\u001b[Kchdir\u001b[m\u001b[K’ [\u001b[01;35m\u001b[K-Wimplicit-function-declaration\u001b[m\u001b[K]\r\n   94 |   \u001b[01;35m\u001b[Kchdir\u001b[m\u001b[K (dir);\r\n      |   \u001b[01;35m\u001b[K^~~~~\u001b[m\u001b[K\r\n\u001b[01m\u001b[Kmlock.c:113:30:\u001b[m\u001b[K \u001b[01;35m\u001b[Kwarning: \u001b[m\u001b[Kimplicit declaration of function ‘\u001b[01m\u001b[Ktime\u001b[m\u001b[K’ [\u001b[01;35m\u001b[K-Wimplicit-function-declaration\u001b[m\u001b[K]\r\n  113 |     if (!stat (lock,&sb) && (\u001b[01;35m\u001b[Ktime\u001b[m\u001b[K (0) > (sb.st_ctime + LOCKTIMEOUT * 60)))\r\n      |                              \u001b[01;35m\u001b[K^~~~\u001b[m\u001b[K\r\n\u001b[01m\u001b[Kmlock.c:43:1:\u001b[m\u001b[K \u001b[01;36m\u001b[Knote: \u001b[m\u001b[K‘\u001b[01m\u001b[Ktime\u001b[m\u001b[K’ is defined in header ‘\u001b[01m\u001b[K<time.h>\u001b[m\u001b[K’; this is probably fixable by adding ‘\u001b[01m\u001b[K#include <time.h>\u001b[m\u001b[K’\r\n   42 | #include <string.h>\r\n  +++ |+\u001b[32m\u001b[K#include <time.h>\u001b[m\u001b[K\r\n   43 | \r\n"]
