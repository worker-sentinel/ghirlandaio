[0.024, "o", "/usr/bin/mysql_secure_installation: Deprecated program name. It will be removed in a future release, use 'mariadb-secure-installation' instead\r\n"]
[0.008, "o", "\r\nNOTE: MariaDB is secure by default. Running this script is mostly\r\n"]
[0.000, "o", "      unecessary and it will likely be removed in a future release,\r\n      but it is for now preserved for backwards compatibility.\r\n\r\nEnter root user password or leave blank:\r\n\r\n"]
[0.011, "o", "Enter current password for root (enter for none): "]
[1.192, "o", "\r\n"]
[0.070, "o", "OK, successfully used password, moving on...\r\n\r\nSetting the root password or using the unix_socket ensures that nobody\r\ncan log into the MariaDB root user without the proper authorisation.\r\n\r\n"]
[0.001, "o", "You already have your root account protected, so you can safely answer 'n'.\r\n\r\nSwitch to unix_socket authentication [Y/n] "]
[2.963, "o", "Y"]
[0.706, "o", "\r\n"]
[0.044, "o", "Enabled successfully (or at least no errors was emitted)!\r\nReloading privilege tables..\r\n"]
[0.032, "o", " ... Success!\r\n\r\n\r\nYou already have your root account protected, so you can safely answer 'n'.\r\n\r\nChange the root password? [Y/n] "]
[43.377, "o", "^C"]
[0.000, "o", "\r\nAborting!\r\n\r\nCleaning up...\r\n"]
[0.013, "o", "\u001b[?2004h[root@lenovo baihaqi]# "]
[2.317, "o", "sudo mysql_secure_installation"]
[2.341, "o", "\r\n\u001b[?2004l\r"]
[0.025, "o", "/usr/bin/mysql_secure_installation: Deprecated program name. It will be removed in a future release, use 'mariadb-secure-installation' instead\r\n"]
[0.007, "o", "\r\nNOTE: MariaDB is secure by default. Running this script is mostly\r\n      unecessary and it will likely be removed in a future release,\r\n      but it is for now preserved for backwards compatibility.\r\n\r\nEnter root user password or leave blank:\r\n\r\n"]
