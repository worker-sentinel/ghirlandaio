[0.004, "o", "\u001b[1;2H size of the optimized code.\r\n;opcache.save_comments=1\r\n\u001b[72X\u001b[4;3HIf enabled, compilation warnings (including notices and deprecations) will\u001b[5;3Hbe recorded and replayed each time a file is included. Otherwise, compilation\u001b[6;3Hwarnings will only be emitted when the file is first cached.\u001b[7;10Hrecord_warnings=0\u001b[9;3HAllow file \u001b[30m\u001b[103mex\u001b[m\u000fistence override (file_\u001b[30m\u001b[103mex\u001b[m\u000fists, etc.) performance feature.\u001b[5X\u001b[10;2Hopcache.enable_file_override=0\u001b[39X\r\n\u001b[18X\n; A bitmask, where each bit enables or disables the appropriate OPcache\u001b[13;3Hpasses\u001b[44X\u001b[14;2Hopcache.optimization_level=0x7FFFBFFF\u001b[39X\r\n\u001b[56X\u001b[16;10Hdups_fix=0 \u001b[18;3HThe location of the OPcache blacklist file (wildcards allowed).\u001b[9X\u001b[19;3HEach OPcache blacklist file is a t\u001b[30m\u001b[103mex\u001b[m\u000ft file that holds the names of files\u001b[20;3Hthat should not be accelerated. The file format is to add each filename\u001b[21;3Hto a new line. The filename may be a full path or just a file prefix\u001b[12X\u001b[22;3H(i.e., /var/www/x  blacklists all the files and directories in /var/www\u001b[23;3Hthat start with 'x'). Line starting with a ; are ignored (comments).\u001b[9X\u001b[24;2Hopcache.blacklist_filename=\u001b[52X\r\n\u001b[31X\n; Allows \u001b[30m\u001b[103mex\u001b[m\u000fclusion of large files from being cached. By default all files\u001b[27;3Hare cached.\u001b[41X\u001b[28;10Hmax_file_size=0  \u001b[30;3HHow long to wait (in seconds) for a scheduled restart to begin if the cache\u001b[31;2H is not being accessed.\u001b[16X\r\n;opcache.force_restart_timeout=180\r\n\u001b[72X\u001b[34;3HOPcache error_log file name. Empty string assumes \"stderr\".\u001b[14X\u001b[35;2Hopcache.error_log= \r\n\u001b[30X\n; All OPcache errors go to the Web server log.\u001b[38;3HBy default, only fatal errors (level 0) or errors (level 1) are logged\u001b[39;3HYou can also enable warnings (level 2), info messages (level 3) or \u001b[40;3Hdebug messages (level 4).\u001b[41X\u001b[41;2Hopcache.log_verbosity_level=1\u001b[45X\r\n\u001b[69X\u001b[43;3HPreferred Shared Memory back-end. Leave empty and let the system decide.\u001b[44;2Hopcache.preferred_memory_model=\u001b[8X\r\n\u001b[26X\n; Protect the shared memory from un\u001b[30m\u001b[103mex\u001b[m\u000fpected writing during script \u001b[30m\u001b[103mex\u001b[m\u000fecution.\u001b[47;155H\u001b[0;10;7m\u000f56,36        93\u001b[48;4H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.004, "o", "\u001b[1;46r\u001b[H\u001b[14L\u001b[1;48r\u001b[H\u001b[K\n; Wh\u001b[30m\u001b[103me\u001b[m\u000fn disabl\u001b[30m\u001b[103me\u001b[m\u000fd, you must r\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[m\u000ft th\u001b[30m\u001b[103me\u001b[m\u000f OPcach\u001b[30m\u001b[103me\u001b[m\u000f manually or r\u001b[30m\u001b[103me\u001b[m\u000fstart th\u001b[30m\u001b[103me\u001b[m\u000f\u001b[K\r\n; w\u001b[30m\u001b[103me\u001b[m\u000fbs\u001b[30m\u001b[103me\u001b[m\u000frv\u001b[30m\u001b[103me\u001b[m\u000fr for chang\u001b[30m\u001b[103me\u001b[m\u000fs to th\u001b[30m\u001b[103me\u001b[m\u000f fil\u001b[30m\u001b[103me\u001b[m\u000fsyst\u001b[30m\u001b[103me\u001b[m\u000fm to tak\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[m\u000fff\u001b[30m\u001b[103me\u001b[m\u000fct.\u001b[K\r\n;opcach\u001b[30m\u001b[103me\u001b[m\u000f.validat\u001b[30m\u001b[103me\u001b[m\u000f_tim\u001b[30m\u001b[103me\u001b[m\u000fstamps=1\u001b[K\r\n\u001b[K\n; How oft\u001b[30m\u001b[103me\u001b[m\u000fn (in s\u001b[30m\u001b[103me\u001b[m\u000fconds) to ch\u001b[30m\u001b[103me\u001b[m\u000fck fil\u001b[30m\u001b[103me\u001b[m\u000f tim\u001b[30m\u001b[103me\u001b[m\u000fstamps for chang\u001b[30m\u001b[103me\u001b[m\u000fs to th\u001b[30m\u001b[103me\u001b[m\u000f shar\u001b[30m\u001b[103me\u001b[m\u000fd\u001b[K\r\n; m\u001b[30m\u001b[103me\u001b[m\u000fmory storag\u001b[30m\u001b[103me\u001b[m\u000f allocation. (\"1\" m\u001b[30m\u001b[103me\u001b[m\u000fans validat\u001b[30m\u001b[103me\u001b[m\u000f onc\u001b[30m\u001b[103me\u001b[m\u000f p\u001b[30m\u001b[103me\u001b[m\u000fr s\u001b[30m\u001b[103me\u001b[m\u000fcond, but only\u001b[K\r\n; onc\u001b[30m\u001b[103me\u001b[m\u000f p\u001b[30m\u001b[103me\u001b[m\u000fr r\u001b[30m\u001b[103me\u001b[m\u000fqu\u001b[30m\u001b[103me\u001b[m\u000fst. \"0\" m\u001b[30m\u001b[103me\u001b[m\u000fans always validat\u001b[30m\u001b[103me\u001b[m\u000f)\u001b[K\r\n;opcach\u001b[30m\u001b[103me\u001b[m\u000f.r\u001b[30m\u001b[103me\u001b[m\u000fvalidat\u001b[30m\u001b[103me\u001b[m\u000f_fr\u001b[30m\u001b[103me\u001b[m\u000fq=2\u001b[K\r\n\u001b[K\n; Enabl\u001b[30m\u001b[103me\u001b[m\u000fs or disabl\u001b[30m\u001b[103me\u001b[m\u000fs fil\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000farch in includ\u001b[30m\u001b[103me\u001b[m\u000f_path optimization\u001b[K\r\n;opcach\u001b[30m\u001b[103me\u001b[m\u000f.r\u001b[30m\u001b[103me\u001b[m\u000fvalidat\u001b[30m\u001b[103me\u001b[m\u000f_path=0\u001b[K\r\n\u001b[K\n; If disabl\u001b[30m\u001b[103me\u001b[m\u000fd, all PHPDoc comm\u001b[30m\u001b[103me\u001b[m\u000fnts ar\u001b[30m\u001b[103me\u001b[m\u000f dropp\u001b[30m\u001b[103me\u001b[m\u000fd from th\u001b[30m\u001b[103me\u001b[m\u000f cod\u001b[30m\u001b[103me\u001b[m\u000f to r\u001b[30m\u001b[103me\u001b[m\u000fduc\u001b[30m\u001b[103me\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[m\u000f\u001b[K\u001b[15;6H\u001b[30m\u001b[103me\u001b[m\u000f of th\u001b[30m\u001b[103me\u001b[m\u000f optimiz\u001b[30m\u001b[103me\u001b[m\u000fd cod\u001b[30m\u001b[103me\u001b[16;8He\u001b[m\u000f.sav\u001b[30m\u001b[103me\u001b[m\u000f_comm\u001b[30m\u001b[103me\u001b[18;6He\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[m\u000fd, compilation warnings (including notic\u001b[30m\u001b[103me\u001b[m\u000fs and d\u001b[30m\u001b[103me\u001b[m\u000fpr\u001b[30m\u001b[103me\u001b[19;4He\u001b[m\u000f r\u001b[30m\u001b[103me\u001b[m\u000fcord\u001b[30m\u001b[103me\u001b[m\u000fd and r\u001b[30m\u001b[103me\u001b[m\u000fplay\u001b[30m\u001b[103me\u001b[m\u000fd \u001b[30m\u001b[103me\u001b[m\u000fach tim\u001b[30m\u001b[103me\u001b[m\u000f a fil\u001b[30m\u001b[103me\u001b[m\u000f is includ\u001b[30m\u001b[103me\u001b[m\u000fd. Oth\u001b[30m\u001b[103me\u001b[m\u000frwis\u001b[30m\u001b[103me\u001b[20;23He\u001b[m\u000f \u001b[30m\u001b[103me\u001b[m\u000fmitt\u001b[30m\u001b[103me\u001b[m\u000fd wh\u001b[30m\u001b[103me\u001b[m\u000