[1.306, "o", "In file included from \u001b[01m\u001b[Kosdep.c:54\u001b[m\u001b[K:\r\n\u001b[01m\u001b[Ktcp_unix.c:\u001b[m\u001b[K In function ‘\u001b[01m\u001b[Ktcp_name\u001b[m\u001b[K’:\r\n\u001b[01m\u001b[Ktcp_unix.c:953:44:\u001b[m\u001b[K \u001b[01;35m\u001b[Kwarning: \u001b[m\u001b[K‘\u001b[01m\u001b[K%s\u001b[m\u001b[K’ directive writing up to 1023 bytes into a region of size 1001 [\u001b[01;35m\u001b[K-Wformat-overflow=\u001b[m\u001b[K]\r\n  953 |       sprintf (tmp,\"Reverse DNS resolution \u001b[01;32m\u001b[K%s\u001b[m\u001b[K\",\u001b[01;34m\u001b[Kadr\u001b[m\u001b[K);\r\n      |                                            \u001b[01;32m\u001b[K^~\u001b[m\u001b[K  \u001b[01;34m\u001b[K~~~\u001b[m\u001b[K\r\nIn file included from \u001b[01m\u001b[K/usr/include/stdio.h:974\u001b[m\u001b[K,\r\n                 from \u001b[01m\u001b[Kosdep.c:32\u001b[m\u001b[K:\r\nIn function ‘\u001b[01m\u001b[Ksprintf\u001b[m\u001b[K’,\r\n    inlined from ‘\u001b[01m\u001b[Ktcp_name\u001b[m\u001b[K’ at \u001b[01m\u001b[Ktcp_unix.c:953:7\u001b[m\u001b[K:\r\n"]
