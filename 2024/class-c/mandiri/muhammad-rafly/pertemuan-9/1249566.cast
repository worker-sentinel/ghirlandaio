[16.733, "o", "\r\n\u001b[?2004l\r"]
[0.187, "o", "2026-06-07 20:34:53 0 [Warning] mariadbd: io_uring_queue_init() failed with EPERM: sysctl kernel.io_uring_disabled has the value 2, or 1 and the user of the process is not a member of sysctl kernel.io_uring_group. (see man 2 io_uring_setup).\r\n"]
[0.001, "o", "create_uring failed: falling back to libaio\r\n2026-06-07 20:34:53 0 [Warning] InnoDB: native AIO failed: falling back to innodb_use_native_aio=OFF\r\n"]
[2.885, "o", "\r\n\r\nTwo all-privilege accounts were created.\r\nOne is root@localhost, it has no password, but you need to\r\nbe system 'root' user to connect. Use, for example, sudo mariadb\r\nThe second is mysql@localhost, it has no password either, but\r\nyou need to be the system 'mysql' user to connect.\r\nAfter connecting you can set the password, if you would need to be\r\nable to connect as any of these users with a password and without sudo\r\n\r\nSee the MariaDB Knowledgebase at https://mariadb.com/kb\r\n\r\nPlease report any problems at https://mariadb.org/jira\r\n\r\n"]
[0.004, "o", "The latest information about MariaDB is available at https://mariadb.org/.\r\n\r\nConsider joining MariaDB's strong and vibrant community:\r\nhttps://mariadb.org/get-involved/\r\n\r\n\u001b[?2004h[baihaqi@lenovo ~]$ "]
[23.495, "o", "sudo mariadb-install-db --user=mysql --basedir=/usr --datadir=/var/lib/mysql"]
[63.129, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Csystemctl start httpd\u001b[K"]
[0.630, "o", "\b\b\b\b\b\b\b\b\b\b\b\u001b[1@enable\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C"]
[0.301, "o", "\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bpacman -S apache mariadb php php-fpm unzip php-apache php-intl imagemagick"]
[0.297, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Csystemctl enable httpd\u001b[K"]
