[0.003, "o", "\u001b[?25l\u001b[m\u000f#\u001b[K\r\n# This is the main Apache HTTP server configuration file.  It contains the\u001b[K\r\n# configuration directives that give the server its instructions.\u001b[K\r\n# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\u001b[K\r\n# In particular, see \u001b[K\r\n# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\u001b[K\r\n# for a discussion of each configuration directive.\u001b[K\r\n#\u001b[K\r\n# Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\u001b[K\r\n# what they do.  They're here only as hints or reminders.  If you are unsure\u001b[K\r\n# consult the online docs. You have been warned.  \u001b[K\r\n#\u001b[K\r\n# Configuration and logfile names: If the filenames you specify for many\u001b[K\r\n# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[K\r\n# server will use that explicit path.  If the filenames do *not* begin\u001b[K\r\n# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\u001b[K\r\n# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\u001b[K\r\n# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \u001b[K\r\n# will be interpreted as '/logs/access_log'.\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# ServerRoot: The top of the directory tree under which the server's\u001b[K\r\n# configuration, error, and log files are kept.\u001b[K\r\n#\u001b[K\r\n# Do not add a slash at the end of the directory path.  If you point\u001b[K\r\n# ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[K\r\n# Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[K\r\n# same ServerRoot for multiple httpd daemons, you will need to change at\u001b[K\r\n# least PidFile.\u001b[K\r\n#\u001b[K\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Mutex: Allows you to set the mutex mechanism and mutex file directory\u001b[K\r\n# for individual mutexes, or change the global defaults\u001b[K\r\n#\u001b[K\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[K\r\n# mutex file directory is not on a local disk or is not appropriate for some\u001b[K\r\n# other reason.\u001b[K\r\n#\u001b[K\r\n# Mutex default:/run/httpd\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[K\r\n# ports, instead of the default. See also the <VirtualHost>\u001b[K\r\n# directive.\u001b[K\r\n\u001b[0;10;7m\u000f/etc/httpd/conf/httpd.conf                                                                                                                              1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H#\u001b[K\r\n# This is the main Apache HTTP server configuration file.  It contains the\u001b[K\r\n# configuration directives that give the server its instructions.\u001b[K\r\n# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\u001b[K\r\n# In particular, see \u001b[K\r\n# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\u001b[K\r\n# for a discussion of each configuration directive.\u001b[K\r\n#\u001b[K\r\n# Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\u001b[K\r\n# what they do.  They're here only as hints or reminders.  If you are unsure\u001b[K\r\n# consult the online docs. You have been warned.  \u001b[K\r\n#\u001b[K\r\n# Configuration and logfile names: If the filenames you specify for many\u001b[K\r\n# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[K\r\n# server will use that explicit path.  If the filenames do *not* begin\u001b[K\r\n# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\u001b[K\r\n# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\u001b[K\r\n# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \u001b[K\r\n# will be interpreted as '/logs/access_log'.\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# ServerRoot: The top of the directory tree under which the server's\u001b[K\r\n# configuration, error, and log files are kept.\u001b[K\r\n#\u001b[K\r\n# Do not add a slash at the end of the directory path.  If you point\u001b[K\r\n# ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[K\r\n# Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[K\r\n# same ServerRoot for multiple httpd daemons, you will need to change at\u001b[K\r\n# least PidFile.\u001b[K\r\n#\u001b[K\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Mutex: Allows you to set th"]
[0.001, "o", "e mutex mechanism and mutex file directory\u001b[K\r\n# for individual mutexes, or change the global defaults\u001b[K\r\n#\u001b[K\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[K\r\n# mutex file directory is not on a local disk or is not appropriate for some\u001b[K\r\n# other reason.\u001b[K\r\n#\u001b[K\r\n# Mutex default:/run/httpd\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[K\r\n# ports, instead of the default. See also the <VirtualHost>\u001b[K\r\n# directive.\u001b[K\r\n\u001b[0;10;7m\u000f/etc/httpd/conf/httpd.conf                                                                                                                              1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
