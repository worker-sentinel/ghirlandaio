[0.418, "o", " kernel"]
[0.428, "o", "\b\b\b\b\b\b\b\b\b\u001b[71@mkdir -p /boot/efi /boot/efi/linux /boot/efi/systemd /boot/efi/boot /boot/\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C"]
[0.240, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Cls\u001b[K"]
[0.286, "o", " efi"]
[0.201, "o", "\b\b\b\b\b\bmv intel-ucode.img vmlinuz-linux-hardened kernel"]
[0.187, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Cls\u001b[K"]
