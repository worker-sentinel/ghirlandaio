[0.089, "o", "\rSystem:\u001b[0m\u001b[m\r\n      Firmware: \u001b[0;1;39mUEFI 2.60 (INSYDE Corp. 22534.8227)\u001b[0m\u001b[m\r\n Firmware Arch: x64\u001b[m\r\n   Secure Boot: \u001b[0mdisabled\u001b[0m\u001b[m\r\n  TPM2 Support: \u001b[0;1;32myes\u001b[0m\u001b[m\r\n  Measured UKI: no\u001b[m\r\n  Boot into FW: supported\u001b[m\r\n\u001b[m\r\nCurrent Boot Loader:\u001b[0m\u001b[m\r\n       Product: \u001b[0;1;39msystemd-boot 260.1-2-arch\u001b[0m\u001b[m\r\n     Features: \u001b[0;1;32m✓\u001b[0m Boot counting\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Menu timeout control\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m One-shot menu timeout control\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Default entry control\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m One-shot entry control\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support for XBOOTLDR partition\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support for passing random seed to OS\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Load drop-in drivers\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 sort-key field\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support @saved pseudo-entry\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 devicetree field\u001b[m\r\n               \u001b[0;1;32m"]
[0.000, "o", "✓\u001b[0m Enroll SecureBoot keys\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Retain SHIM protocols\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Menu can be disabled\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Multi-Profile UKIs are supported\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Loader reports network boot URL\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 uki field\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 uki-url field\u001b[m\r\n               \u001b[0;1;32m✓\u001b[0m Loader reports active TPM2 PCR banks\u001b[m\r\n     Partition: /dev/disk/by-partuuid/54fc8745-7a85-47d9-8c6c-8e498b32b5a4\u001b[m\r\n        Loader: └─\u001b[0;90m\u001b[0;38:5:245m(null)/\u001b[0m/EFI/BOOT/BOOTX64.EFI\u001b[m\r\n Current Entry: 01-blacker-linux.conf\u001b[m\r\n\u001b[m\r\nRandom Seed:\u001b[0m\u001b[m\r\n System Token: set\u001b[m\r\n\u001b[m\r\nBoot Loaders Listed in EFI Variables:\u001b[0m\u001b[m\r\n        Title: \u001b[0;1;39mWindows Boot Manager\u001b[0m\u001b[m\r\n           ID: 0x0000\u001b[m\r\n       Status: active, boot-order\u001b[m\r\n    Partition: /dev/disk/by-partuuid/dcda3a9f-1f72-48aa-b1d9-783c66631905\u001b[m\r\n         File: └─\u001b[0;90m\u001b[0;38:5:245m(null)/\u001b[0m/EFI/Micro"]
