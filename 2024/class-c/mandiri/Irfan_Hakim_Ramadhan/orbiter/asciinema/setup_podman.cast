[0.184, "o", "\u001b]3008;start=5646c2c531f142869b21c5f45b8202a9;user=server;hostname=orbiters;machineid=5719e3f373074a6884a8e2a50cd83341;bootid=912f55c59fd5477ca41cbd6c2464d6c5;pid=6250;pidfdid=6251;comm=sudo;targetuser=root;type=session\u001b\\\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\u001b[H\u001b[2J\u001b[?2004h\u001b[?69$p\u001b[?2026$p\u001b[?2027$p\u001b[?2031$p\u001b[?2048$p\u001b[0m\u001b[4:3m\u001bP$qm\u001b\\\u001b[?u\u001b[c\u001b]11;?\u0007\u001b[5n\u001b[?25h\u001b]11;?\u0007\u001b[5n\u001b[?25l\u001b(B\u001b[m\u001b[H                                                                                                                                                                                              \r\n                                                                                                                                                                                              \r\n                                                                                                                                                                                              \r\n                                                                                                                                                                                              \r\n                                                                                                                                                                                              \r\n                                                                                                                                                                                              \r\n                                                                                                                                                                                              \r\n                                                                                                     