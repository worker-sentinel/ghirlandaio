[0.001, "o", "\r\u001b[K            IPv4 address          192.168.1.6                                      \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            IPv6 address          2001:448a:2082:564c:8af4:daff:fe89:cdc1          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            ConnectedBss          3c:a7:ae:3b:fc:b6                                \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            Frequency             2452                                             \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            Channel               9                                                \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            Security              WPA2-Personal                                    \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            RSSI                  -56 dBm                                          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            AverageRSSI           -57 dBm                                          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            RxMode                802.11n                                          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            RxMCS                 15                                               \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            TxMode                802.11n                                          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            TxMCS                 11                                               \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            TxBitrate             52000 Kbit/s                                     \r\n"]
[0.002, "o", "\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            RxBitrate             130000 Kbit/s                                    \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            InactiveTime          4730 ms                                          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K            ConnectedTime         44 s                                             \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network\r\u001b[K\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/network"]
