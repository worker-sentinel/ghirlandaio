[0.002, "o", "\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/n\r\u001b[K            Connected network     Emi                                              \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/n\r\u001b[K            IPv4 address          192.168.1.6                                      \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/n\r\u001b[K            IPv6 address          2001:448a:2082:564c:8af4:daff:fe89:cdc1          \r\n\u001b[32m[iwd]\u001b[0m# nvim /etc/systemd/n"]
