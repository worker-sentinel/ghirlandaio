[0.171, "o", "\r\n\u001b[?2004l\r                                 Station: wlan1\u001b[1;90m                                \u001b[0m\r\n\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[1;90m  Settable  Property              Value                                          \r\n\u001b[0m\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m            Scanning              no                                               \r\n            State                 connected                                        \r\n            Connected network     Emi                                              \r\n"]
[0.008, "o", "            IPv4 address          192.168.1.6                                      \r\n            IPv6 address          2001:448a:2082:564c:8af4:daff:fe89:cdc1          \r\n\u001b[?2004h\u001b[32m[iwd]\u001b[0m# \r\u001b[K            ConnectedBss          3c:a7:ae:3b:fc:b6                                \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Frequency             2452                                             \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Channel               9                                                \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Security              WPA2-Personal                                    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RSSI                  -56 dBm                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            AverageRSSI           -58 dBm                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RxMode                802.11n                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RxMCS                 15                                               \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            TxMode                802.11n                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            TxMCS                 11                                               \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            TxBitrate             52000 Kbit/s                                     \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RxBitrate             130000 Kbit/s                                    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            InactiveTime          114 ms                                           \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            ConnectedTime         20 s                                             \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[32m[iwd]\u001b[0m# "]
[0.994, "o", "\r\u001b[K\u001b[24A                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n\u001b[24A\u001b[32m[iwd]\u001b[0m# \r\u001b[K                                 Station: wlan1\u001b[1;90m                               *\u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m  Settable  Property              Value                                          \r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Scanning              no                                               \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            State                 connected                                        \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Connected network     Emi                                              \r\n\u001b[32m[iwd]\u001b[0m# "]
[0.002, "o", "\r\u001b[K            IPv4 address          192.168.1.6                                      \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            IPv6 address          2001:448a:2082:564c:8af4:daff:fe89:cdc1          \r\n\u001b[32m[iwd]\u001b[0m# "]
[0.001, "o", "\r\u001b[K            ConnectedBss          3c:a7:ae:3b:fc:b6                                \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Frequency             2452                                             \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Channel               9                                                \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            Security              WPA2-Personal                                    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RSSI                  -56 dBm                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            AverageRSSI           -57 dBm                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RxMode                802.11n                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RxMCS                 15                                               \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            TxMode                802.11n                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            TxMCS                 11                                               \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            TxBitrate             52000 Kbit/s                                     \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            RxBitrate             130000 Kbit/s                                    \r\n"]
[0.000, "o", "\u001b[32m[iwd]\u001b[0m# \r\u001b[K            InactiveTime          1117 ms                                          \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K            ConnectedTime         21 s                                             \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# "]
