[0.035, "o", "creating gd.la\r\n"]
[0.007, "o", "(cd .libs && rm -f gd.la && ln -s ../gd.la gd.la)\r\n"]
[0.002, "o", "/bin/bash /usr/src/php/ext/gd/libtool --tag=CC --mode=install cp ./gd.la /usr/src/php/ext/gd/modules\r\n"]
[0.026, "o", "cp ./.libs/gd.so /usr/src/php/ext/gd/modules/gd.so\r\n"]
[0.003, "o", "cp ./.libs/gd.lai /usr/src/php/ext/gd/modules/gd.la\r\n"]
[0.018, "o", "PATH=\"$PATH:/sbin\" ldconfig -n /usr/src/php/ext/gd/modules\r\n"]
[0.002, "o", "----------------------------------------------------------------------\r\n"]
[0.002, "o", "Libraries have been installed in:\r\n   /usr/src/php/ext/gd/modules\r\n\r\nIf you ever happen to want to link against installed libraries\r\nin a given directory, LIBDIR, you must either use libtool, and\r\nspecify the full pathname of the library, or use the `-LLIBDIR'\r\nflag during linking and do at least one of the following:\r\n   - add LIBDIR to the `LD_LIBRARY_PATH' environment variable\r\n     during execution\r\n   - add LIBDIR to the `LD_RUN_PATH' environment variable\r\n     during linking\r\n   - use the `-Wl,--rpath -Wl,LIBDIR' linker flag\r\n   - have your system administrator add LIBDIR to `/etc/ld.so.conf'\r\n\r\nSee any operating system documentation about shared libraries for\r\nmore information, such as the ld(1) and ld.so(8) manual pages.\r\n"]
[0.024, "o", "----------------------------------------------------------------------\r\n\r\nBuild complete.\r\nDon't forget to run 'make test'.\r\n\r\n"]
[0.005, "o", "+ strip --strip-all modules/gd.so\r\n"]
[0.032, "o", "Installing shared extensions:     /usr/local/lib/php/extensions/no-debug-non-zts-20230831/\r\n"]
[0.047, "o", "Installing header files:          /usr/local/include/php/\r\n"]
[0.432, "o", "find . -name \\*.gcno -o -name \\*.gcda | xargs rm -f\r\n"]
[0.004, "o", "find . -name \\*.lo -o -name \\*.o -o -name \\*.dep | xargs rm -f\r\n"]
