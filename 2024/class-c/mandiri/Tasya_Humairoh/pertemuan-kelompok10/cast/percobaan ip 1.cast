[0.000, "o", "                                     \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[41mEdit a connection      \u001b[30m\u001b[47m │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                                         \u001b[33;1H                                                                                                           \u001b[m\u000f\u001b[30m\u001b[47m│ Activate a connection   │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                                         \u001b[34;1H                                                                                                           \u001b[m\u000f\u001b[30m\u001b[47m│ Set system hostname     │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                                         \u001b[35;1H                                                                                                           \u001b[m\u000f\u001b[30m\u001b[47m│ Radio                   │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                                         \u001b[36;1H                                                                                                           \u001b[m\u000f\u001b[30m\u001b[47m│                         │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                                         \u001b[37;1H                                                                                                           \u001b[m\u000f\u001b[30m\u001b[47m│ Quit                    │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                                         \u001b[38;1H                                                                  