[0.352, "o", "\u001b[2;106H\u001b[1m\u001b[37m\u001b[44m                                \u001b[3;106H                                 \u001b[4;106H                                 \u001b[5;106H                                 \u001b[6;106H                                 \u001b[7;106H                                 \u001b[8;106H                                 \u001b[9;106H                                 \u001b[10;106H                                 \u001b[11;106H                                 \u001b[12;106H                                 \u001b[13;106H                                 \u001b[14;106H                                 \u001b[15;106H                                 \u001b[16;106H                                 \u001b[17;106H                                 \u001b[18;106H                                 \u001b[19;106H                                 \u001b[20;106H                                 \u001b[21;106H                                 \u001b[22;106H                                 \u001b[23;106H                                 \u001b[24;106H                                 \u001b[25;106H                                 \u001b[26;106H                                 \u001b[27;106H                                 \u001b[28;106H  \u001b[m\u000f\u001b[30m\u001b[47m┌─┤ \u001b[31mNetworkManager TUI\u001b[30m ├──┐\u001b[1m\u001b[37m\u001b[44m    \u001b[29;106H  \u001b[12C\u001b[m\u000f\u001b[30m\u001b[47m   \u001b[11C│\u001b[1m\u001b[37m\u001b[40m \u001b[44m   \u001b[30;106H  \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[34mPlease select an option\u001b[30m │\u001b[1m\u001b[37m\u001b[40m \u001b[44m   \u001b[31;106H  \u001b[12C\u001b[m\u000f\u001b[30m\u001b[47m   \u001b[11C│\u001b[1m\u001b[37m\u001b[40m \u001b[44m   \u001b[32;106H  \u001b[m\u000f\u001b[30m\u001b[47m│ Edit a connection\u001b[7C│\u001b[1m\u001b[37m\u001b[40m \u001b[44m   \u001b[33;106H  \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[41mActivate a connection  \u001b[30m\u001b[47m │\