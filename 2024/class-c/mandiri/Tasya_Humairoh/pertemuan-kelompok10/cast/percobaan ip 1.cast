[1.468, "o", "\u001b[4;108H\u001b[m\u000f\u001b[30m\u001b[47m┌─────────────┐\u001b[5;108H│\u001b[13C│ \u001b[37m\u001b[41m<Deactivate>\u001b[6;108H\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m* lo    \u001b[30m\u001b[47m  ▒ │\u001b[7;108H│\u001b[13C│\u001b[8;108H│\u001b[13C│\u001b[9;108H│\u001b[13C│\u001b[10;108H│\u001b[13C│\u001b[11;108H│\u001b[13C│\u001b[12;108H│\u001b[13C│\u001b[13;108H│\u001b[13C│\u001b[14;108H│\u001b[13C│\u001b[15;108H│\u001b[13C│\u001b[16;108H│\u001b[13C│\u001b[17;108H│\u001b[13C│\u001b[18;108H│\u001b[13C│\u001b[19;108H│\u001b[13C│\u001b[20;108H│\u001b[13C│\u001b[21;108H│\u001b[13C│\u001b[22;108H│\u001b[13C│\u001b[23;108H│\u001b[13C│\u001b[24;108H│\u001b[13C│\u001b[25;108H│\u001b[13C│\u001b[26;108H│\u001b[13C│\u001b[27;108H│\u001b[13C│\u001b[28;108H│\u001b[13C│\u001b[29;108H│\u001b[13C│\u001b[30;108H│\u001b[13C│\u001b[31;108H│\u001b[13C│\u001b[32;108H│\u001b[13C│\u001b[33;108H│\u001b[13C│\u001b[34;108H│\u001b[13C│\u001b[35;108H│\u001b[13C│\u001b[36;108H│\u001b[13C│\u001b[37;108H│\u001b[13C│\u001b[38;108H│\u001b[13C│\u001b[39;108H│\u001b[13C│\u001b[40;108H│\u001b[13C│\u001b[41;108H│\u001b[13C│\u001b[42;108H│\u001b[13C│\u001b[43;108H│\u001b[13C│\u001b[44;108H│\u001b[13C│\u001b[45;108H│\u001b[13C│\u001b[46;108H│\u001b[13C│\u001b[47;108H│\u001b[13C│\u001b[48;108H│\u001b[13C│\u001b[49;108H│\u001b[13C│\u001b[50;108H│\u001b[13C│\u001b[51;108H│\u001b[13C│\u001b[52;108H│\u001b[13C│\u001b[53;108H│\u001b[13C│\u001b[54;108H│\u001b[13C│\u001b[55;108H│\u001b[13C│\u001b[56;108H│\u001b[13C│\u001b[57;108H│\u001b[13C│\u001b[58;108H│\u001b[13C│\u001b[59;108H│\u001b[13C│\u001b[60;108H│\u001b[13C│\u001b[61;108H│\u001b[13C│\u001b[62;108H│\u001b[13C│\u001b[63;108H│\u001b[13C│\u001b[64;108H└─────────────┘\u001b[5;125H"]
