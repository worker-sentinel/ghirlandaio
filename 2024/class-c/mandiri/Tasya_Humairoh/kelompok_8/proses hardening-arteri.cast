[0.018, "o", "\u001b[?25l\u001b[67;230H \u001b[1;65r\u001b[H\u001b[53M\u001b[1;67r\u001b[13;1H        #location ~ \\.php$ {\u001b[K\r\n        #    root           html;\u001b[K\r\n        #    fastcgi_pass   127.0.0.1:9000;\u001b[K\r\n        #    fastcgi_index  index.php;\u001b[K\r\n        #    fastcgi_param  SCRIPT_FILENAME  /scripts$fastcgi_script_name;\u001b[K\r\n        #    include        fastcgi_params;\u001b[K\r\n        #}\u001b[K\r\n\u001b[K\n        # deny access to .htaccess files, if Apache's document root\u001b[K\r\n        # concurs with nginx's one\u001b[K\r\n        #\u001b[K\r\n        #location ~ /\\.ht {\u001b[K\r\n        #    deny  all;\u001b[K\r\n        #}\u001b[K\r\n    }\u001b[K\r\n\u001b[K\n\u001b[K\n    # another virtual host using mix of IP-, name-, and port-based configuration\u001b[K\r\n    #\u001b[K\r\n    #server {\u001b[K\r\n    #    listen       8000;\u001b[K\r\n    #    listen       somename:8080;\u001b[K\r\n    #    server_name  somename  alias  another.alias;\u001b[K\r\n\u001b[K\n    #    location / {\u001b[K\r\n    #        root   html;\u001b[K\r\n    #        index  index.html index.htm;\u001b[K\r\n    #    }\u001b[K\r\n    #}\u001b[K\r\n\u001b[K\n\u001b[K\n    # HTTPS server\u001b[K\r\n    #\u001b[K\r\n    #server {\u001b[K\r\n    #    listen       443 ssl;\u001b[K\r\n    #    server_name  localhost;\u001b[K\r\n\u001b[K\n    #    ssl_certificate      cert.pem;\u001b[K\r\n    #    ssl_certificate_key  cert.key;\u001b[K\r\n\u001b[K\n    #    ssl_session_cache    shared:SSL:1m;\u001b[K\r\n    #    ssl_session_timeout  5m;\u001b[K\r\n\u001b[K\n    #    ssl_ciphers  HIGH:!aNULL:!MD5;\u001b[K\r\n    #    ssl_prefer_server_ciphers  on;\u001b[K\r\n\u001b[K\n    #    location / {\u001b[K\r\n    #        root   html;\u001b[K\r\n    #        index  index.html index.htm;\u001b[K\r\n    #    }\u001b[K\r\n    #}\u001b[K\r\n\u001b[K\n}\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f18,1          Bot\r\u001b[A\u001b[?25h"]
