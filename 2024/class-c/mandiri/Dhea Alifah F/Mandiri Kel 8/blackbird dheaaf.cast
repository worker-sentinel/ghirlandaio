[0.035, "o", "\u001b[?25l\u001b[1;43r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;45r\u001b[43;1H##   This will create a systemd based initramfs which loads an encrypted root filesystem.\u001b[K\u001b[44;143H\u001b[0;10;7m\u000f50,1           18\r\u001b[A\u001b[?25h"]
