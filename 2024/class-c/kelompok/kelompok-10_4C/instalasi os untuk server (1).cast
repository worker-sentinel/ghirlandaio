[0.000, "o", "\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d# Configuration file for locale-gen\r\u001b[3d"]
[0.000, "o", "#\u001b[4d\b# lists of locales that are to be generated by the locale-gen command.\r\u001b[5d"]
[0.000, "o", "#\u001b[6d\b"]
[0.000, "o", "# Each line is of the form:\r\u001b[7d#\u001b[8d\b"]
[0.000, "o", "#     <locale> <charset>\r\u001b[9d"]
[0.000, "o", "#\u001b[10d\b"]
[0.000, "o", "#  where <locale> is one of the locales given in /usr/share/i18n/locales\r\u001b[11d#  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\r\u001b[12d"]
[0.000, "o", "#\u001b[13d\b#  The locale-gen command will generate all the locales,\r\u001b[14d#  placing them in /usr/lib/locale.\r\u001b[15d#\u001b[16d\b"]
[0.000, "o", "#  A list of supported locales is given in /usr/share/i18n/SUPPORTED\r\u001b[17d"]
[0.000, "o", "#  and is included in this file. Uncomment the needed locales below.\r\u001b[18d#\u001b[19d\b#aa_DJ.UTF-8 UTF-8\r\u001b[20d"]
[0.000, "o", "#aa_DJ ISO-8859-1\r\u001b[21d"]
[0.000, "o", "#aa_ER UTF-8\r\u001b[22d#aa_ET UTF-8\r\u001b[23d#af_ZA.UTF-8 UTF-8\r\u001b[24d"]
