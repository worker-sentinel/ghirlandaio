[0.021, "o", "\u001b[c"]
[0.001, "o", "\u001b[?25l\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# mkinitcpio preset file for the 'linux-lts' package\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\nALL_config=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/etc/mkinitcpio.conf\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\nALL_kver=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/boot/vmlinuz-linux-lts\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\nALL_kerneldest=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/boot/vmlinuz-linux-lts\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\nPRESETS=(\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m'default'\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m)\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#PRESETS=('default' 'fallback')\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#default_config=\"/etc/mkinitcpio.conf\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#default_image=\"/boot/initramfs-linux-lts.img\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\ndefault_uki=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"/boot/EFI/Linux/arch-linux-lts.efi\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#fallback_config=\"/etc/mkinitcpio.conf\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[