[0.000, "o", "Optional dependencies for linux-hardened\r\n"]
[0.000, "o", "    linux-hardened-headers: headers and scripts for building modules [pending]\r\n"]
[0.000, "o", "    linux-firmware: firmware images needed for some devices [installed]\r\n    scx-scheds: to use sched-ext schedulers\r\n"]
