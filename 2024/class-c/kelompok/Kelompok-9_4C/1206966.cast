[0.015, "o", "\u001b[1;34m::\u001b[0;1m There are 2 providers available for libxtables.so=12-64:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mcore\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) iptables  2) iptables-legacy\r\n\r\nEnter a number (default=1): \r\n"]
[0.011, "o", "\u001b[1;34m::\u001b[0;1m There are 2 providers available for jack:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) jack2  2) pipewire-jack\r\n\r\nEnter a number (default=1): \r\n"]
[0.026, "o", "\u001b[1;34m::\u001b[0;1m There are 11 providers available for ttf-font:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mextra\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) gnu-free-fonts  2) noto-fonts  3) ttf-bitstream-vera  4) ttf-croscore  5) ttf-dejavu  6) ttf-droid  7) ttf-ibm-plex  8) ttf-input  9) ttf-input-nerd  10) ttf-liberation  11) ttf-roboto\r\n\r\nEnter a number (default=1): \r\n"]
