[0.000, "o", "\u001b[0;32m✓ .env file created successfully!\u001b[0m\r\n\r\n\u001b[0;34mGenerated Configuration Summary:\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;34m===============================\u001b[0m\r\n"]
[0.000, "o", "Database Name: \u001b[0;32mcipdocman\u001b[0m\r\n"]
