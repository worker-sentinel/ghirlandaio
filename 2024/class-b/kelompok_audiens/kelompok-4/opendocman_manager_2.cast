[0.000, "o", "Email: \u001b[0;32madmin@odm.server\u001b[0m\r\n"]
[0.000, "o", "Timezone: \u001b[0;32mUTC\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1;33mImportant Notes:\u001b[0m\r\n"]
[0.000, "o", "• Your .env file contains sensitive information - do not commit it to version control\r\n"]
[0.000, "o", "• Make sure to add .env to your .gitignore file\r\n"]
[0.000, "o", "• Keep a secure backup of your .env file\r\n"]
[0.000, "o", "• The admin username will be 'admin' with the generated/custom password\r\n\r\n"]
[0.000, "o", "\u001b[0;34mNext Steps:\u001b[0m\r\n"]
[0.000, "o", "1. Review and customize additional settings in .env if needed\r\n"]
[0.000, "o", "2. Run: \u001b[0;32mdocker-compose up -d --build\u001b[0m\r\n"]
[0.000, "o", "3. Access your application at: \u001b[0;32mhttp://localhost:8080\u001b[0m\r\n"]
[0.001, "o", "4. Login with username: \u001b[0;32madmin\u001b[0m and your generated password\r\n\r\n"]
[0.000, "o", "\u001b[0;32mSetup complete! 🚀\u001b[0m\r\n"]
