[0.000, "o", "Database Password: \u001b[0;32m[Generated - 24 chars]\u001b[0m\r\nRoot Password: \u001b[0;32m[Generated - 32 chars]\u001b[0m\r\nAdmin Password: \u001b[0;32m[Generated/Custom - 9 chars]\u001b[0m\r\n"]
