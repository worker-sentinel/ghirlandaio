[0.000, "o", "\u001b[1;33mImportant Notes:\u001b[0m\r\n"]
[0.000, "o", "• Your .env file contains sensitive information - do not commit it to version control\r\n"]
[0.000, "o", "• Make sure to add .env to your .gitignore file\r\n"]
[0.000, "o", "• Keep a secure backup of your .env file\r\n"]
[0.000, "o", "• The admin username will be 'admin' with the generated/custom password\r\n\r\n"]
[0.000, "o", "\u001b[0;34mNext Steps:\u001b[0m\r\n"]
