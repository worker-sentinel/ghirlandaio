[0.001, "o", "\u001b[?25l\u001b[m\u000f# OpenDocMan Docker Environment Configuration\u001b[K\r\n# Copy this file to .env and customize the values for your installation\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# DATABASE CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# MySQL/MariaDB Database Settings\u001b[K\r\n\u001b[94mMYSQL_DATABASE\u001b[m\u000f=\u001b[92mperpus-rebecca\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_USER\u001b[m\u000f=\u001b[92mjurbec\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_PASSWORD\u001b[m\u000f=\u001b[92mRRHuZE4Uk6k25MbeiCxpLOVb\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_ROOT_PASSWORD\u001b[m\u000f=\u001b[92mgoawRsRR1oWcSel7bU2dQ04J579EjyYs\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Database Connection Settings (used by OpenDocMan app)\u001b[K\r\n\u001b[94mAPP_DB_HOST\u001b[m\u000f=\u001b[92mdb\u001b[m\u000f\u001b[K\r\n\u001b[94mDB_PORT\u001b[m\u000f=\u001b[92m3306\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_NAME\u001b[m\u000f=\u001b[92mperpus-rebecca\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_USER\u001b[m\u000f=\u001b[92mjurbec\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_PASS\u001b[m\u000f=\u001b[92mRRHuZE4Uk6k25MbeiCxpLOVb\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# APPLICATION CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# OpenDocMan Data Directory (inside container)\u001b[K\r\n\u001b[94mODM_DATA_DIR\u001b[m\u000f=\u001b[92m/var/www/document_repository\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Docker Environment Flag\u001b[K\r\n\u001b[94mIS_DOCKER\u001b[m\u000f=\u001b[92mtrue\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Application Hostname\u001b[K\r\n# This must match the exact domain:port you are using to access the site.\u001b[K\r\n# Format: HOSTNAME:{optional: SERVICE_PORT}\u001b[K\r\n# Ex. http://localhost:8080 would be \"localhost:8080\".\u001b[K\r\n\u001b[94mODM_HOSTNAME\u001b[m\u000f=\u001b[92modm.local\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# PORT CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# External ports that will be mapped to the host\u001b[K\r\n# Format: HOST_PORT:CONTAINER_PORT\u001b[K\r\n\u001b[K\n# Database Port (MySQL/MariaDB)\u001b[K\r\n\u001b[94mDB_EXTERNAL_PORT\u001b[m\u000f=\u001b[92m3306\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Web Server Ports\u001b[K\r\n\u001b[94mHTTP_PORT\u001b[m\u000f=\u001b[92m8080\u001b[m\u000f\u001b[K\r\n\u001b[94mHTTPS_PORT\u001b[m\u000f=\u001b[92m443\u001b[m\u000f\u001b[K\r\n\u001b[94mPHP_FPM_PORT\u001b[m\u000f=\u001b[92m9000\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# SECURITY CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# Admin Password for Initial Installation\u001b[K\r\n# This will be used to create the default admin user during installation\u001b[K\r\n\u001b[94mADMIN_PASSWORD\u001b[m\u000f=\u001b[92mchipsmutia\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Session Secret (used for session encryption)\u001b[K\r\n\u001b[94mSESSION_SECRET\u001b[m\u000f=\u001b[92mefd8a9ee6174ec7e693759a54f0fef9491003387bb0ac92e42e3604f53dffe98\u001b[m\u000f\u001b[K\r\n\u001b[K\n# File Upload Settings\u001b[K\r\n\u001b[94mMAX_FILE_SIZE\u001b[m\u000f=\u001b[92m50M\u001b[m\u000f\u001b[K\r\n\u001b[94mUPLOAD_MAX_FILESIZE\u001b[m\u000f=\u001b[92m50M\u001b[m\u000f\u001b[K\r\n\u001b[0;10;7m\u000f.env                                                                                                                                                                                             