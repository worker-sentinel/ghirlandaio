[0.001, "o", "\u001b[?25l\u001b[m\u000f\u001b[94mversion\u001b[m\u000f\u001b[96m:\u001b[m\u000f \u001b[92m\"3.9\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[94mservices\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n\u001b[K\n  \u001b[94mdb\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f mariadb:10.11\u001b[K\r\n\u001b[K\n    \u001b[94menv_file\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f .env\u001b[K\r\n\u001b[K\n    \u001b[94mcommand\u001b[m\u000f\u001b[96m:\u001b[m\u000f --innodb-use-native-aio=0\u001b[K\r\n\u001b[K\n    \u001b[94mvolumes\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f /srv/opendocman/mysql:/var/lib/mysql\u001b[K\r\n\u001b[K\n    \u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f opendocman\u001b[K\r\n\u001b[K\n    \u001b[94mdeploy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mreplicas\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1\u001b[K\r\n      \u001b[94mplacement\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mconstraints\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n          \u001b[0;10;1m\u000f-\u001b[m\u000f node.labels.role == cipt \u001b[K\r\n\u001b[K\n  \u001b[94mopendocman\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f opendocman:patched\u001b[K\r\n\u001b[K\n    \u001b[94menv_file\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f .env\u001b[K\r\n\u001b[K\n    \u001b[94mvolumes\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f /srv/opendocman/files:/var/www/html/files-data\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f /srv/opendocman/config:/var/www/html/docker-configs\u001b[K\r\n\u001b[K\n    \u001b[94mports\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[94mtarget\u001b[m\u000f\u001b[96m:\u001b[m\u000f 80\u001b[K\r\n        \u001b[94mpublished\u001b[m\u000f\u001b[96m:\u001b[m\u000f 8080\u001b[K\r\n        \u001b[94mprotocol\u001b[m\u000f\u001b[96m:\u001b[m\u000f tcp\u001b[K\r\n        \u001b[94mmode\u001b[m\u000f\u001b[96m:\u001b[m\u000f ingress\u001b[K\r\n\u001b[K\n    \u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f opendocman\u001b[K\r\n\u001b[K\n    \u001b[94mdeploy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mreplicas\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1\u001b[K\r\n      \u001b[94mplacement\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mconstraints\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n          \u001b[0;10;1m\u000f-\u001b[m\u000f node.labels.role == cipmut\u001b[K\r\n\u001b[K\n\u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n  \u001b[94mopendocman\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mexternal\u001b[m\u000f\u001b[96m:\u001b[m\u000f true\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000fstack.yml                                                                                                                                                                                                                     1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H\u001b[94mversion\u001b[m\u000f\u001b[96m:\u001b[m\u000f \u001b[92m\"3.9\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[94mservices\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n\u001b[K\n  \u001b[94mdb\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f mariadb:10.11\u001b[K\r\n\u001b[K\n    \u001b[