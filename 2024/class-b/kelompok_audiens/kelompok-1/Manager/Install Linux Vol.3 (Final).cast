[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f2,1           21\r\u001b[A\u001b[?25h"]
