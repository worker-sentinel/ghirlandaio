[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f6,1            7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# COMPRESSION\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f7,1           11\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Use this to compress the initramfs image. By default, zstd compression\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f8,1           14\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# is used for Linux ≥\u001b[54;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f9,1           18\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Use 'cat' to create an uncompressed image.\u001b[K\u001b[55;163H\u001b[0;10;7m\u000f60,1           22\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"zstd\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f1,1           25\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"gzip\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f2,1           29\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"bzip2\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f3,1           33\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"lzma\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f4,1           37\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"xz\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f5,1           40\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"lzop\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f6,1           44\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION=\"lz4\"\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f7,1           48\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f8,1           51\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# COMPRESSION_OPTIONS\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f9,1           55\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Additional options for the compressor\u001b[K\u001b[55;163H\u001b[0;10;7m\u000f70,1           59\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H#COMPRESSION_OPTIONS=()\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f1,1           62\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f2,1           66\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# MODULES_DECOMPRESS\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f3,1           70\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f4,1           74\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# creation. Switch (yes/no).\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f5,1           77\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Enable to allow further decreasing image size when using high compression\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f6,1           81\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# (e.g. xz -9e or zstd --long --ultra -22) at the expense of increased RAM usage\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f7,1           85\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# at early boot.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f8,1           88\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Note that any compressed files will be placed in the uncompressed early CPIO\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f9,1           92\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# to avoid double compression.\u001b[K\u001b[55;163H\u001b[0;10;7m\u000f80,1           96\r\u001b[A\u001b[?25h"]
