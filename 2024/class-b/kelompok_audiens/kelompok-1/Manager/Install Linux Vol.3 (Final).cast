[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to disable \"use_pty\" when running commands as root.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f7,1           27\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Commands run as non-root users will run in a pseudo-terminal,\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f8,1           28\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## not the user's own terminal, to prevent command injection.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f9,1           29\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults>root !use_pty\u001b[K\u001b[55;163H\u001b[0;10;7m\u000f80,1           30\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f1,1           31\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to run commands in the background by default.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f2,1           32\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## This can be used to prevent sudo from consuming user input while\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f3,1           34\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## a non-interactive command runs if \"use_pty\" or I/O logging are\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f4,1           35\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## enabled.  Some commands may not run properly in the background.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f5,1           36\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults exec_background\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f6,1           37\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f7,1           38\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to send mail if the user does not enter the correct password.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f8,1           40\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults mail_badpass\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f9,1           41\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;163H\u001b[0;10;7m\u000f90,1           42\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to enable logging of a command's output, except for\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f1,1           43\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## sudoreplay and reboot.  Use sudoreplay to play back logged sessions.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f2,1           44\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Sudo will create up to 2,176,782,336 I/O logs before recycling them.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f3,1           45\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Set maxseq to a smaller number if you don't have unlimited disk space.\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f4,1           47\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults log_output\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f5,1           48\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults!/usr/bin/sudoreplay !log_output\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f6,1           49\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults!/usr/local/bin/sudoreplay !log_output\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f7,1           50\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults!REBOOT !log_output\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f8,1           51\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults maxseq = 1000\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f9,1           52\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;163H\u001b[0;10;7m\u000f100,1          54\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to disable intercept and log_subcmds for debuggers and\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f1,1          55\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## tracers.  Otherwise, anything that uses ptrace(2) will be unable\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f2,1          56\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## to run under sudo if intercept_type is set to \"trace\".\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f3,1          57\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults!DEBUGGERS !intercept, !log_subcmds\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f4,1          58\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f5,1          60\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to disable intercept and log_subcmds for package managers.\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f6,1          61\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Some package scripts run a huge number of commands, which is made\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f7,1          62\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## slower by these options and also can clutter up the logs.\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f8,1          63\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults!PKGMAN !intercept, !log_subcmds\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f9,1          64\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f10,1          65\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to disable PAM silent mode.  Otherwise messages by PAM\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f1,1          67\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## modules such as pam_faillock will not be printed.\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f2,1          68\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# Defaults !pam_silent\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f3,1          69\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f4,1          70\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H##\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f5,1          71\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Runas alias specification\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f6,1          72\r\u001b[A\u001b[?25h"]
