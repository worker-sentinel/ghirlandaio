[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[92mroot\u001b[m\u000f \u001b[96mALL\u001b[m\u000f=(\u001b[96mALL\u001b[m\u000f:\u001b[96mALL\u001b[m\u000f) \u001b[96mALL\u001b[m\u000f\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f2,1          80\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f3,1          81\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to allow members of group wheel to execute any command\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f4,1          82\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# %wheel ALL=(ALL:ALL) ALL\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f5,1          83\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f6,1          84\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Same thing without a password\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f7,1          85\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# %wheel ALL=(ALL:ALL) NOPASSWD: ALL\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f8,1          87\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f9,1          88\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to allow members of group sudo to execute any command\u001b[K\u001b[55;164H\u001b[0;10;7m\u000f30,1          89\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H# %sudo ALL=(ALL:ALL) ALL\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f1,1          90\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f2,1          91\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## Uncomment to allow any user to run sudo if they know the password\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f3,1          92\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;54r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;56r\u001b[54;1H## of the user they are running the command as (root by default).\u001b[K\u001b[55;165H\u001b[0;10;7m\u000f4,1          94\r\u001b[A\u001b[?25h"]
