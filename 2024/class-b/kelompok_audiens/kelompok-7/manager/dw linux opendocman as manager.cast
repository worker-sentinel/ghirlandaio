[0.586, "o", "\r\n\u001b[?2004l\r"]
[0.005, "o", "\u001b[0;34mOpenDocMan Environment Secrets Generator\u001b[0m\r\n\u001b[0;34m=========================================\u001b[0m\r\n\r\n"]
[0.001, "o", "\u001b[0;34mGenerating secure passwords and secrets...\u001b[0m\r\n\r\n"]
[0.060, "o", "\u001b[1;33mPlease provide some basic configuration:\u001b[0m\r\n\r\nDatabase name [opendocman]: "]
[99.809, "o", "d"]
[0.126, "o", "o"]
[0.108, "o", "d"]
[0.062, "o", "o"]
[0.820, "o", "l"]
[4.484, "o", "-"]
[0.971, "o", "g"]
[0.295, "o", "a"]
[0.270, "o", "r"]
[0.175, "o", "u"]
[0.130, "o", "t"]
[4.294, "o", "\r\n"]
[0.002, "o", "Database username [opendocman]: "]
[26.613, "o", "d"]
[0.161, "o", "u"]
[0.877, "o", "o"]
[0.390, "o", "i"]
[0.201, "o", "m"]
[0.169, "o", "u"]
[0.145, "o", "t"]
[10.855, "o", "\r\n"]
[0.000, "o", "Application hostname [odm.local]: "]
[13.213, "o", "\r\n"]
[0.000, "o", "HTTP port [8080]: "]
[7.015, "o", "\r\n"]
[0.002, "o", "HTTPS port [443]: "]
[4.063, "o", "\r\n"]
[0.000, "o", "Database external port [3306]: "]
[4.354, "o", "\r\n"]
[0.000, "o", "Email address for notifications [admin@odm.local]: "]
[4.183, "o", "\r\n"]
[0.000, "o", "Timezone [UTC]: "]
[2.856, "o", "\r\n"]
[0.001, "o", "\r\nDo you want to use custom admin password? (y/n) [n]: "]
[3.063, "o", "y"]
[0.711, "o", "\r\n"]
[0.000, "o", "Enter admin password (min 8 characters): "]
[40.302, "o", "\r\nConfirm admin password: "]
[6.953, "o", "\r\n"]
[0.067, "o", "\r\n\u001b[0;32m✓ .env file created successfully!\u001b[0m\r\n\r\n\u001b[0;34mGenerated Configuration Summary:\u001b[0m\r\n\u001b[0;34m===============================\u001b[0m\r\nDatabase Name: \u001b[0;32mdodol-garut\u001b[0m\r\nDatabase User: \u001b[0;32mduoimut\u001b[0m\r\nDatabase Password: \u001b[0;32m[Generated - 24 chars]\u001b[0m\r\nRoot Password: \u001b[0;32m[Generated - 32 chars]\u001b[0m\r\n"]
[0.000, "o", "Admin Password: \u001b[0;32m[Generated/Custom - 10 chars]\u001b[0m\r\nSession Secret: \u001b[0;32m[Generated - 64 chars]\u001b[0m\r\nHostname: \u001b[0;32modm.local\u001b[0m\r\nHTTP Port: \u001b[0;32m8080\u001b[0m\r\nHTTPS Port: \u001b[0;32m443\u001b[0m\r\n"]
[0.000, "o", "Database Port: \u001b[0;32m3306\u001b[0m\r\n"]
[0.000, "o", "Email: \u001b[0;32madmin@odm.local\u001b[0m\r\n"]
[0.000, "o", "Timezone: \u001b[0;32mUTC\u001b[0m\r\n\r\n\u001b[1;33mImportant Notes:\u001b[0m\r\n• Your .env file contains sensitive information - do not commit it to version control\r\n• Make sure to add .env to your .gitignore file\r\n"]
[0.000, "o", "• Keep a secure backup of your .env file\r\n"]
[0.000, "o", "• The admin username will be 'admin' with the generated/custom password\r\n\r\n"]
[0.000, "o", "\u001b[0;34mNext Steps:\u001b[0m\r\n"]
[0.000, "o", "1. Review and customize additional settings in .env if needed\r\n2. Run: \u001b[0;32mdocker-compose up -d --build\u001b[0m\r\n3. Access your application at: \u001b[0;32mhttp://localhost:8080\u001b[0m\r\n4. Login with username: \u001b[0;32madmin\u001b[0m and your generated password\r\n\r\n\u001b[0;32mSetup complete! 🚀\u001b[0m\r\n"]
