[0.007, "o", "\u001b[0;1;39mNot booted with EFI or running in a container, skipping EFI variable modifications.\u001b[0m\r\r\n\u001b[0;1;31mFailed to check file system type of \"/install\": No such file or directory\u001b[0m\r\r\n"]
[0.008, "o", "\rsystemd-boot not installed in ESP.\u001b[m\r\nNo default/fallback boot loader installed in ESP.\u001b[m\r\nSystem:\u001b[0m\u001b[m\r\nNot booted with EFI\u001b[m\r\n\u001b[m\r\nAvailable Boot Loaders on ESP:\u001b[0m\u001b[m\r\n          ESP: /install\u001b[m\r\n\u001b[m\r\nBoot Loader Entry Locations:\u001b[0m\u001b[m\r\n          ESP: /install\u001b[m\r\n       config: \u001b[0;90m\u001b[0;38:5:245m/install/\u001b[0m/loader/loader.conf: \u001b[0;90m\u001b[0;38:5:245mNo such file or directory\u001b[0m\u001b[m\r\n     XBOOTLDR: /boot (\u001b[0;32m$BOOT\u001b[0m)\u001b[m\r\n        token: arch\u001b[m\r\n\u001b[m\r\n0 entries, no entry could be determined as default.\u001b[m\r\n\r\u001b[K"]
