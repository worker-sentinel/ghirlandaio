[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# COMPRESSION_OPTIONS\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           65\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Additional options for the compressor\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f70,1           68\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION_OPTIONS=()\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           71\r\u001b[A\u001b[?25h"]
