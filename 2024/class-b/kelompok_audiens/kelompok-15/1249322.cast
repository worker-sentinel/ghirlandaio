[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           28\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# COMPRESSION\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1           31\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Use this to compress the initramfs image. By default, zstd compression\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           34\r\u001b[A\u001b[?25h"]
[0.028, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# is used for Linux ≥\u001b[46;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           37\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Use 'cat' to create an uncompressed image.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f60,1           40\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"zstd\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           42\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"gzip\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           45\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"bzip2\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           48\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"lzma\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1           51\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#COMPRESSION=\"xz\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           54\r\u001b[A\u001b[?25h"]
