[1.717, "o", "\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bconf\u001b[K"]
[0.597, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Crm -fr /boot/initramfs-linux-lts.img"]
