[0.525, "o", "\r\n\u001b[?2004l\r"]
[0.035, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-lts.preset: 'default'\u001b[m\u000f\r\n\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.d/default.conf'\u001b[m\u000f\r\n"]
[0.000, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux-lts -c /etc/mkinitcpio.d/default.conf -U /boot/EFI/linux/arch-linux-lts.efi\u001b[m\u000f\r\n"]
[0.023, "o", "==> ERROR: Invalid option -c -- '/etc/mkinitcpio.d/default.conf' must be readable\r\n"]
[0.002, "o", "\u001b[?2004h[root@blackbird /]# "]
[247.491, "o", "mkinitcpio -P"]
