[0.010, "o", "NAME              MAJ:MIN RM   SIZE RO TYPE  MOUNTPOINTS\r\nloop0               7:0    0 979.8M  1 loop  \r\nsda                 8:0    1  14.9G  0 disk  \r\n├─sda1              8:1    1   1.2G  0 part  \r\n└─sda2              8:2    1   257M  0 part  \r\nnvme0n1           259:0    0 476.9G  0 disk  \r\n├─nvme0n1p1       259:8    0   260M  0 part  \r\n├─nvme0n1p2       259:9    0    16M  0 part  \r\n├─nvme0n1p3       259:10   0   172G  0 part  \r\n├─nvme0n1p4       259:11   0 252.7G  0 part  \r\n├─nvme0n1p5       259:12   0     2G  0 part  \r\n├─nvme0n1p6       259:13   0     2G  0 part  /boot\r\n└─nvme0n1p7       259:14   0    48G  0 part  \r\n  └─zia           253:0    0    48G  0 crypt \r\n    ├─sistem-root 253:1    0     7G  0 lvm   /\r\n    ├─sistem-vars 253:2    0     5G  0 lvm   /var\r\n    ├─sistem-vlog 253:3    0     1G  0 lvm   /var/log\r\n    ├─sistem-vaud 253:4    0     1G  0 lvm   /var/log/audit\r\n    ├─sistem-vtmp 253:5    0     1G  0 lvm   /var/tmp\r\n    ├─sistem-home 253:6    0     1G  0 lvm   /home\r\n    └─sistem-dock 253:7    0    32G  0 lvm   /var/lib/docker\r\n"]
