[0.004, "o", "(181/191) installing libgirepository                                                                                                             [########################################################################################] 100%\r\r\n"]
[0.001, "o", "(182/191) installing gobject-introspection-runtime                                                                                               [----------------------------------------------------------------------------------------]   0%\r"]
[0.001, "o", "(182/191) installing gobject-introspection-runtime                                                                                               [########################################################################################] 100%\r\r\n"]
