[0.002, "o", "\u001b[3;49H\u001b[30m\u001b[103mmm\u001b[4;28Hm\u001b[m\u000fay result in syntax or file per\u001b[30m\u001b[103mm\u001b[5;25Hm\u001b[7;20Hm\u001b[13;14Hm\u001b[m\u000fachines. These \u001b[30m\u001b[103mm\u001b[m\u000fay include host na\u001b[30m\u001b[103mm\u001b[14;28Hm\u001b[20;28Hm\u001b[m\u000fay consist of user na\u001b[30m\u001b[103mm\u001b[22;26Hm\u001b[m\u000fillert, dowdy, \u001b[30m\u001b[103mm\u001b[25;5Hm\u001b[27;16Hmm\u001b[m\u000fands.  Often used to group related co\u001b[30m\u001b[103mmm\u001b[28;4Hm\u001b[31;4Hm\u001b[33;4Hm\u001b[37;4Hm\u001b[m\u000fnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rp\u001b[30m\u001b[103mm\u001b[38;37Hm\nm\u001b[44;27Hm\u001b[45;32Hmm\u001b[m\u000fands, re\u001b[30m\u001b[103mm\u001b[48;58Hmm\u001b[49;54Hm\u001b[50;16Hmm\u001b[53;8Hm\u001b[m\u000fay wish to keep so\u001b[30m\u001b[103mm\u001b[m\u000fe of the following environ\u001b[30m\u001b[103mm\u001b[54;19Hmm\u001b[60;45Hm\u001b[61;33Hm\u001b[66;223H\u001b[0;10;7m\u000f3,49\u001b[67;3H\u001b[?25h"]
[0.268, "o", "\u001b[?25l\u001b[m\u000fn"]
[0.002, "o", "\u001b[3;49Hmm\u001b[4;28Hmay result in syntax or file perm\u001b[5;25Hm\u001b[7;20Hm\u001b[13;14Hmachines. These may include host nam\u001b[14;28Hm\u001b[20;28Hmay consist of user nam\u001b[22;26Hmillert, dowdy, m\u001b[25;5H\u001b[30m\u001b[103mmn\u001b[27;16H\u001b[m\u000fmmands.  Often used to group related comm\u001b[28;5H\u001b[30m\u001b[103mn\u001b[31;5Hn\u001b[33;5Hn\u001b[37;5Hn\u001b[m\u000fd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm\u001b[38;37Hm\nm\u001b[44;27Hm\u001b[45;32Hmmands, rem\u001b[48;58Hmm\u001b[49;54Hm\u001b[50;16Hmm\u001b[53;8Hmay wish to keep some of the following environm\u001b[54;19Hmm\u001b[60;45Hm\u001b[61;33Hm\u001b[66;223H\u001b[0;10;7m\u000f25,5\u001b[67;4H\u001b[?25h"]
[0.602, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.003, "o", "\u001b[3;49H\u001b[30m\u001b[103mmm\u001b[4;28Hm\u001b[m\u000fay result in syntax or file per\u001b[30m\u001b[103mm\u001b[5;25Hm\u001b[7;20Hm\u001b[13;14Hm\u001b[m\u000fachines. These \u001b[30m\u001b[103mm\u001b[m\u000fay include host na\u001b[30m\u001b[103mm\u001b[14;28Hm\u001b[20;28Hm\u001b[m\u000fay consist of user na\u001b[30m\u001b[103mm\u001b[22;26Hm\u001b[m\u000fillert, dowdy, \u001b[30m\u001b[103mm\u001b[25;5Hm\u001b[m\u000fn\u001b[27;16H\u001b[30m\u001b[103mmm\u001b[m\u000fands.  Often used to group related co\u001b[30m\u001b[103mmm\u001b[28;5H\u001b[m\u000fn\u001b[31;5Hn\u001b[33;5Hn\u001b[37;5Hnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rp\u001b[30m\u001b[103mm\u001b[38;37Hm\nm\u001b[44;27Hm\u001b[45;32Hmm\u001b[m\u000fands, re\u001b[30m\u001b[103mm\u001b[48;58Hmm\u001b[49;54Hm\u001b[50;16Hmm\u001b[53;8Hm\u001b[m\u000fay wish to keep so\u001b[30m\u001b[103mm\u001b[m\u000fe of the following environ\u001b[30m\u001b[103mm\u001b[54;19Hmm\u001b[60;45Hm\u001b[61;33Hm\u001b[66;223H\u001b[0;10;7m\u000f3,49\u001b[67;3H\u001b[?25h"]
[0.199, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[3;49Hmm\u001b[4;28Hmay result in syntax or file perm\u001b[5;25Hm\u001b[7;20Hm\u001b[13;14Hmachines. These may include host nam\u001b[14;28Hm\u001b[20;28Hmay consist of user nam\u001b[22;26Hmillert, dowdy, m\u001b[25;5Hm\u001b[27;16Hmmands.  Often used to group related comm\u001b[28;4Hm\u001b[31;4Hm\u001b[33;4Hm\u001b[37;4Hmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm\u001b[38;37Hm\nm\u001b[44;27Hm\u001b[45;32Hmmands, rem\u001b[48;58Hmm\u001b[49;54Hm\u001b[50;16Hmm\u001b[53;8Hmay wish to keep some of the following environm\u001b[54;19Hmm\u001b[60;45Hm\u001b[61;33Hm\u001b[66;223H\u001b[0;10;7m\u000f1,1 \u001b[67;2H\u001b[?25h"]
[0.882, "o", "\u001b[?25l\u001b[m\u000fA"]
[0.003, "o", "\u001b[15;8H\u001b[30m\u001b[103mA\u001b[22;8HA\u001b[m\u000flias    \u001b[30m\u001b[103mA\u001b[28;8HA\u001b[31;8HA\u001b[33;8HA\u001b[37;8HA\u001b[m\u000flias    PKGM\u001b[30m\u001b[103mA\u001b[46;62HA\u001b[48;22HA\u001b[57;26HA\u001b[m\u000fNG L\u001b[30m\u001b[103mA\u001b[m\u000fNGU\u001b[30m\u001b[103mA\u001b[m\u000fGE LINGU\u001b[30m\u001b[103mA\u001b[m\u000fS LC_* _XKB_CH\u001b[30m\u001b[103mA\u001b[65;26HA\u001b[m\u000fPPLRESDIR XFILESE\u001b[30m\u001b[103mA\u001b[m\u000fRCHP\u001b[30m\u001b[103mA\u001b[m\u000fTH XUSERFILESE\u001b[30m\u001b[103mA\u001b[m\u000fRCHP\u001b[30m\u001b[103mA\u001b[66;224H\u001b[0;10;7m\u000f5,8\u001b[67;3H\u001b[?25h"]
[0.142, "o", "\u001b[?25l\u001b[m\u000fL"]
[0.002, "o", "\u001b[15;8HA\u001b[22;8HAlias    A\u001b[28;8HA\u001b[31;8HA\u001b[33;8HA\u001b[37;8HAlias    PKGMA\u001b[46;62H\u001b[30m\u001b[103mAL\u001b[48;22H\u001b[m\u000fA\u001b[57;26HANG LANGUAGE LINGUAS LC_* _XKB_CHA\u001b[65;26HAPPLRESDIR XFILESEARCHPATH XUSERFILESEARCHPA\u001b[66;223H\u001b[0;10;7m\u000f46,62\u001b[67;4H\u001b[?25h"]
[0.153, "o", "\u001b[?25l\u001b[m\u000fL"]
[0.003, "o", "\u001b[1;2H Defaults env_keep += \"XMODIFIERS GTK_IM_MODULE QT_IM_MODULE QT_IM_SWITCHER\"\u001b[3;4HUncomment to disable \"use_pty\" when running commands as root.\u001b[4;4HCommands run as non-root users will run in a pseudo-terminal,\u001b[9X\u001b[5;4Hnot the user's own terminal, to prevent command injection.\u001b[6;2H Defaults>root !use_pty\u001b[7;3H\u001b[73X\n Uncomment to run commands in the background by default.\r\n## This can be used to prevent sudo from consuming user input while\u001b[10;3H a non-interactive command runs if \"use_pty\" or I/O logging are\u001b[11;4Henabled.  Some commands may not run properly in the background.\u001b[12;2H Defaults exec_background\u001b[13;3H\u001b[78X\u001b[14;4HUncomment to send mail if the user does not enter the correct password.\u001b[15;3HDefaults mail_badpass\u001b[22X\r\n##\n Uncomment to enable logging of a command's output, except for\u001b[18;4Hsudoreplay and reboot.  Use sudoreplay to play back logged sessions.\u001b[19;3H Sudo will create up to 2,176,782,336 I/O logs before recycling them.\u001b[20;4HSet maxseq to a smaller number if you don't have unlimited disk space.\u001b[21;2H Defaults log_output\u001b[22;3HDefaults!/usr/bin/sudoreplay !log_output    \r\n# Defaults!/usr/local/bin/sudoreplay !log_output\u001b[24;2H Defaults!REBOOT !log_output\u001b[25;2H Defaults maxseq = 1000   \u001b[27;4HUncomment to disable intercept and log_subcmds for debuggers and   \u001b[28;2H# tracers.  Otherwise, anything that uses ptrace(2) will be unable\u001b[5X\u001b[29;2H# to run under sudo if intercept_type is set to \"trace\".\u001b[30;2H Defaults!DEBUGGERS !intercept, !log_subcmds\u001b[31;2H#\u001b[63X\u001b[32;2H# Uncomment to disable intercept and log_subcmds for package managers.\u001b[33;2H# Some package scripts run a huge number of commands, which is made\u001b[7X\u001b[34;2H# slower by these options and also can clutter up the logs.    \u001b[35;3HDefaults!PKGMAN !intercept, !log_subcmds\u001b[18X\u001b[36;2H#\u001b[37;2H# Uncomment to disable PAM silent mode.  Otherwise messages by PAM  \u001b[38;2H# modules such as pam_faillock will not be printed.\u001b[20X\u001b[39;3HDefaults !pam_silent\u001b[18X\u001b[42;4HRunas alias specification\r\n\n\u001b[52X\u001b[45;3H\u001b[68X\r\n## User privilege specification\u001b[33X\r\n\n\u001b[92mroot\u001b[m\u000f \u001b[30m\u001b[103mALL\u001b[m\u000f=(\u001b[30m\u001b[103mALL\u001b[m\u000f:\u001b[30m\u001b[103mALL\u001b[m\u000f) \u001b[30m\u001b[103mALL\u001b[m\u000f\u001b[42X\r\n\u001b[62X\u001b[50;4HUncomment to allow members of group wheel to execute any command\r\n# %wheel \u001b[30m\u001b[103mALL\u001b[m\u000f=(\u001b[30m\u001b[103mALL\u001b[m\u000f:\u001b[30m\u001b[103mALL\u001b[m\u000f) \u001b[30m\u001b[103mALL\u001b[m\u000f\u001b[36X\r\n  \u001b[53;4HSame thing without a password\u001b[35X\u001b[54;2H %wheel \u001b[30m\u001b[103mALL\u001b[m\u000f=(\u001b[30m\u001b[103mALL\u001b[m\u000f:\u001b[30m\u001b[103mALL\u001b[m\u000f) NOPASSWD: \u001b[30m\u001b[103mALL\u001b[m\u000f\r\n  \u001b[56;4HUncomment to allow members of group sudo to execute any command\u001b[57;3H%sudo \u001b[30m\u001b[103mALL\u001b[m\u000f=(\u001b[30m\u001b[103mALL\u001b[m\u000f:\u001b[30m\u001b[103mALL\u001b[m\u000f) \u001b[30m\u001b[103mALL\u001b[m\u000f\u001b[39X\r\n  \u001b[59;4HUncomment to allow any user to run sudo if they know the password\u001b[60;4Hof the user they are running the command as (root by default). \u001b[61;2H Defaults targetpw  # Ask for the password of the target user   \u001b[62;3H\u001b[30m\u001b[103mALL\u001b[m\u000f \u001b[30m\u001b[103mALL\u001b[m\u000f=(\u001b[30m\u001b[103mALL\u001b[m\u000f:\u001b[30m\u001b[103mALL\u001b[m\u000f) \u001b[30m\u001b[103mALL\u001b[m\u000f  # WARNING: only use this together with 'Defaults targetpw'\r\n  \u001b[64;4HRead drop-in files from /etc/sudoers.d\r\n\u001b[0;10;1m\u000f@includedir /etc/sudoers.d\u001b[m\u000f\u001b[46X\u001b[66;223H\u001b[0;10;7m\u000f122,6          Bot\u001b[67;5H\u001b[?25h"]
