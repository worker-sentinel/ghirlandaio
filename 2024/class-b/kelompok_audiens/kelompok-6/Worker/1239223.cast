[0.002, "o", "\u001b[1;46r\u001b[H\u001b[27M\u001b[1;48r\u001b[1;2Hen_\u001b[2;2Hen_\u001b[3;2Hen_\u001b[4;2Hen_\u001b[5;2Hen_\u001b[6;2Hen_\u001b[7;2Hen_\u001b[8;2Hen_\u001b[9;2Hen_\u001b[10;2Hen_\u001b[11;2Hen_\u001b[12;2Hen_\u001b[13;2Hen_\u001b[14;2Hen_\u001b[15;2Hen_\u001b[16;2Hen_\u001b[17;2Hen_\u001b[18;2Hen_\u001b[19;2Hen_\r\n#en_SE.UTF-8 UTF-8  \u001b[K\r\n#en_SG.UTF-8 UTF-8  \u001b[K\r\n#en_SG ISO-8859-1  \u001b[K\r\n#\u001b[30m\u001b[103men_U\u001b[m\u000fS.UTF-8 UTF-8  \u001b[K\r\n#\u001b[30m\u001b[103men_U\u001b[m\u000fS ISO-8859-1  \u001b[K\r\n#en_ZA.UTF-8 UTF-8  \u001b[K\r\n#en_ZA ISO-8859-1  \u001b[K\r\n#en_ZM UTF-8  \u001b[K\r\n#en_ZW.UTF-8 UTF-8  \u001b[K\r\n#en_ZW ISO-8859-1  \u001b[K\r\n#eo UTF-8  \u001b[K\r\n#es_AR.UTF-8 UTF-8  \u001b[K\r\n#es_AR ISO-8859-1  \u001b[K\r\n#es_BO.UTF-8 UTF-8  \u001b[K\r\n#es_BO ISO-8859-1  \u001b[K\r\n#es_CL.UTF-8 UTF-8  \u001b[K\r\n#es_CL ISO-8859-1  \u001b[K\r\n#es_CO.UTF-8 UTF-8  \u001b[K\r\n#es_CO ISO-8859-1  \u001b[K\r\n#es_CR.UTF-8 UTF-8  \u001b[K\r\n#es_CR ISO-8859-1  \u001b[K\r\n#es_CU UTF-8  \u001b[K\r\n#es_DO.UTF-8 UTF-8  \u001b[K\r\n#es_DO ISO-8859-1  \u001b[K\r\n#es_EC.UTF-8 UTF-8  \u001b[K\r\n#es_EC ISO-8859-1  \u001b[K\r\n#es_ES.UTF-8 UTF-8  \u001b[K\u001b[47;154H\u001b[0;10;7m\u000f72,2          31\u001b[48;6H\u001b[?25h"]
