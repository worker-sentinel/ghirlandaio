[0.018, "o", "\u001b[1;13Hheartmonitor_module modules/mod_heartmonitor.so\u001b[2;13Hdav_module modules/mod_dav.so\u001b[8X\r\n\u001b[96mLoadModule\u001b[m\u000f status_module modules/mod_status.so\u001b[9X\r\n\u001b[96mLoadModule\u001b[m\u000f autoindex_module modules/mod_autoindex.so\r\n#LoadModule asis_module modules/mod_asis.so\u001b[6;13Hinfo_module modules/mod_info\r\n#LoadModule suexec_module modules/mod_suexec.so\u001b[7X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f !mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[23X\r\n        #LoadModule cgid_module modules/mod_cgid.so\u001b[8X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[34X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[12X\r\n        #LoadModule cgi_module modules/mod_cgi.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[44X\u001b[14;13Hdav_fs_module modules/mod_dav_fs.so\u001b[6X\u001b[15;13Hdav_lock_module modules/mod_dav_lock.so\r\n#LoadModule vhost_alias_module modules/mod_vhost_alias.so\r\n\u001b[96mLoadModule\u001b[m\u000f negotiation_module modules/mod_negotiation.so\r\n\u001b[96mLoadModule\u001b[m\u000f dir_module modules/mod_dir.so\u001b[13X\u001b[19;13Himagemap_module modules/mod_imagemap.so  \r\n#LoadModule actions_module modules/mod_actions.so \r\n#LoadModule speling_module modules/mod_speling.so\r\n\u001b[96mLoadModule\u001b[m\u000f userdir_module modules/mod_userdir.so   \u001b[23;12Halias_module modules/mod_alias\u001b[24;13H\u001b[30m\u001b[103mrew\u001b[m\u000frite_module modules/mod_\u001b[30m\u001b[103mrew\u001b[m\u000frite.so\u001b[12X\r\n\u001b[53X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[31X\u001b[27;2H\u001b[54X\n If you wish httpd to run as a different user or group, you must run\u001b[29;2H httpd as root initially and it will switch.  \u001b[10X\u001b[30;2H\u001b[58X\n User/Group: The name (or #number) of the user/group to run httpd as.\u001b[32;2H It is usually good practice to create a dedicated user and group for\u001b[33;2H running httpd, as with most system services.\u001b[17X\u001b[34;2H\u001b[60X\r\n\u001b[96mUser\u001b[m\u000f http\u001b[50X\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[39X\r\n\u001b[63X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[52X\r\n\u001b[57X\n# 'Main' server configuration\u001b[27X\u001b[41;2H\u001b[60X\n The directives in this section set up the values used by the 'main'\u001b[43;2H server, which responds to any requests that aren't handled by a\u001b[44;2H <VirtualHost> definition.  These values also provide defaults for\u001b[45;2H any <VirtualHost> containers you may define later in the file.\u001b[46;2H\u001b[38X\u001b[47;154H\u001b[0;10;7m\u000f89,13         33\u001b[48;5H\u001b[?25h"]
