[0.010, "o", "\u001b[H    \u001b[96mScriptAlias\u001b[m\u000f /cgi-bin/ \u001b[92m\"/srv/http/cgi-bin/\"\u001b[m\u000f\r\n\u001b[43X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[43X\r\n\u001b[53X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f cgid_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[37X\r\n    #\u001b[40X\r\n    # ScriptSock: On threaded servers, designate the path to the UNIX\r\n    # socket used to communicate with the CGI daemon of mod_cgid.\r\n    #\u001b[50X\r\n    #Scriptsock cgisock\u001b[30X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[38X\r\n\u001b[48X\u001b[13;2H\u001b[44X\n \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\u001b[15;2H CGI directory exists, if you have that configured. \r\n#\u001b[49X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/cgi-bin\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[17X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\u001b[29X\r\n    \u001b[96mOptions\u001b[m\u000f None\u001b[28X\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[38X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[41X\r\n\u001b[54X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f \u001b[30m\u001b[103mhead\u001b[m\u000fers_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[30X\r\n    #\u001b[50X\r\n    # Avoid passing HTTP_PROXY environment to CGI's on this or any proxied\r\n    # backend servers which have lingering \"httpoxy\" defects.\r\n    # 'Proxy' request \u001b[30m\u001b[103mhead\u001b[m\u000fer is undefined by the IETF, not listed by IANA\r\n    #\u001b[48X\r\n    \u001b[96mRequestHeader\u001b[m\u000f unset Proxy early\u001b[28X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[50X\r\n\u001b[59X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mime_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[27X\r\n    #\u001b[58X\r\n    # TypesConfig points to the file containing the list of mappings from\r\n    # filename extension to MIME-type.\u001b[19X\r\n    #\u001b[51X\r\n    \u001b[96mTypesConfig\u001b[m\u000f conf/mime.types\u001b[30X\r\n\u001b[41X\n    #\u001b[42X\r\n    # AddType allows you to add to or override the MIME configuration\r\n    # file specified in TypesConfig for specific file types.\r\n    #\u001b[34X\r\n    #AddType application/x-gzip .tgz\u001b[37X\r\n    #\u001b[66X\r\n    # AddEncoding allows you to have certain browsers uncompress\u001b[9X\r\n    # information on the fly. Note: Not all browsers support this.\u001b[5X\u001b[47;153H\u001b[0;10;7m\u000f394,11         74\u001b[48;6H\u001b[?25h"]
