[0.551, "o", "\r\n\u001b[?2004l\r"]
[0.010, "o", "\u001b[0;34mOpenDocMan Environment Secrets Generator\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;34m=========================================\u001b[0m\r\n\r\n\u001b[1;33mWarning: .env file already exists!\u001b[0m\r\nDo you want to backup the existing .env file? (y/n): "]
