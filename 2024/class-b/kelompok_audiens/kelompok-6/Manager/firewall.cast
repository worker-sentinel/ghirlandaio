[0.170, "o", "\r\n\u001b[?2004l\r"]
[0.009, "o", "# OpenDocMan Docker Environment Configuration\r\n# Copy this file to .env and customize the values for your installation\r\n\r\n# =============================================================================\r\n# DATABASE CONFIGURATION\r\n# =============================================================================\r\n\r\n# MySQL/MariaDB Database Settings\r\nMYSQL_DATABASE=perpus-tj\r\nMYSQL_USER=tikajua\r\nMYSQL_PASSWORD=pRM2UXB2z7xJMZXFiuIa8KHq\r\nMYSQL_ROOT_PASSWORD=NmLVgNAE1mEde2EYhFr25biNnIplgCLT\r\n\r\n# Database Connection Settings (used by OpenDocMan app)\r\nAPP_DB_HOST=db\r\nDB_PORT=3306\r\nAPP_DB_NAME=perpus-tj\r\nAPP_DB_USER=tikajua\r\nAPP_DB_PASS=pRM2UXB2z7xJMZXFiuIa8KHq\r\n\r\n# =============================================================================\r\n# APPLICATION CONFIGURATION\r\n# =============================================================================\r\n\r\n# OpenDocMan Data Directory (inside container)\r\nODM_DATA_DIR=/var/www/document_repository\r\n\r\n# Docker Environment Flag\r\nIS_DOCKER=true\r\n\r\n# Application Hostname\r\n# This must match the exact domain:port you are using to access the site.\r\n# Format: HOSTNAME:{optional: SERVICE_PORT}\r\n# Ex. http://localhost:8080 would be \"localhost:8080\".\r\nODM_HOSTNAME=odm.local\r\n\r\n# =============================================================================\r\n# PORT CONFIGURATION\r\n# =============================================================================\r\n\r\n# External ports that will be mapped to the host\r\n# Format: HOST_PORT:CONTAINER_PORT\r\n\r\n# Database Port (MySQL/MariaDB)\r\nDB_EXTERNAL_PORT=3306\r\n\r\n# Web Server Ports\r\nHTTP_PORT=8080\r\nHTTPS_PORT=443\r\nPHP_FPM_PORT=9000\r\n\r\n# =============================================================================\r\n# SECURITY CONFIGURATION\r\n# =============================================================================\r\n\r\n# Admin Password for Initial Installation\r\n# This will be used to create the default admin user during installation\r\nADMIN_PASSWORD=tikajuacantik\r\n\r\n# Session Secret (used for session encryption)\r\nSESSION_SECRET=bc7a75829a111484d62e9967d6436db716c8f52e05bf8f92e50185603a6cb7f8\r\n\r\n# File Upload Settings\r\nMAX_FILE_SIZE=50M\r\nUPLOAD_MAX_FILESIZE=50M\r\nPOST_MAX_SIZE=120M\r\n\r\n# =============================================================================\r\n# EMAIL CONFIGURATION\r\n# =============================================================================\r\n\r\n# SMTP Settings for email notifications\r\nSMTP_HOST=localhost\r\nSMTP_PORT=587\r\nSMTP_USERNAME=\r\nSMTP_PASSWORD=\r\nSMTP_ENCRYPTION=tls\r\nMAIL_FROM_ADDRESS=admin@odm.local\r\nMAIL_FROM_NAME=OpenDocMan\r\n\r\n# =============================================================================\r\n# BACKUP CONFIGURATION\r\n# =============================================================================\r\n\r\n# Backup schedule (cron format)\r\nBACKUP_SCHEDULE=0 2 * * *\r\n\r\n# Backup retention (days)\r\nBACKUP_RETENTION=30\r\n\r\n# =============================================================================\r\n# DEVELOPMENT/DEBUG SETTINGS\r\n# =============================================================================\r\n\r\n# Enable/Disable debug mode\r\nDEBUG_MODE=false\r\n\r\n# PHP Error Reporting Level\r\nPHP_ERROR_REPORTING=E_ALL & ~E_NOTICE & ~E_STRICT & ~E_DEPRECATED\r\n\r\n# Log Level (error, warning, info, debug)\r\nLOG_LEVEL=warning\r\n\r\n# =============================================================================\r\n# SSL/TLS CONFIGURATION\r\n# =============================================================================\r\n\r\n# SSL Certificate paths (if using custom certificates)\r\nSSL_CERT_PATH=/etc/ssl/certs/odm.crt\r\nSSL_KEY_PATH=/etc/ssl/private/odm.key\r\n\r\n# Enable/Disable SSL\r\nSSL_ENABLED=false\r\n\r\n# =============================================================================\r\n# VOLUME MOUNT PATHS\r\n# =============================================================================\r\n\r\n# Host paths for persistent data (optional - leave empty to use Docker volumes)\r\n# If specified, these paths on the host will be mounted instead of using named volumes\r\n\r\n# Host path for document storage\r\nHOST_DATA_PATH=\r\n\r\n# Host path for database storage\r\nHOST_DB_PATH=\r\n"]
[0.001, "o", "\r\n# Host path for configuration files\r\nHOST_CONFIG_PATH=\r\n\r\n# =============================================================================\r\n# ADDITIONAL ENVIRONMENT VARIABLES\r\n# =============================================================================\r\n\r\n# Timezone setting\r\nTZ=UTC\r\n\r\n# Memory limits\r\nPHP_MEMORY_LIMIT=512M\r\n\r\n# Execution time limits\r\nPHP_MAX_EXECUTION_TIME=300\r\n\r\n# Database table prefix\r\nDB_PREFIX=odm_\r\n\r\n# Default language\r\nDEFAULT_LANGUAGE=english\r\n\r\n# Default theme\r\nDEFAULT_THEME=tweeter\r\n"]
