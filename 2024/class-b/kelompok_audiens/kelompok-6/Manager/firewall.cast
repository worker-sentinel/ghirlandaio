[0.002, "o", "\u001b[?25l\u001b[m\u000f# OpenDocMan Docker Environment Configuration\u001b[K\r\n# Copy this file to .env and customize the values for your installation\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# DATABASE CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# MySQL/MariaDB Database Settings\u001b[K\r\n\u001b[94mMYSQL_DATABASE\u001b[m\u000f=\u001b[92mperpus-tj\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_USER\u001b[m\u000f=\u001b[92mtikajua\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_PASSWORD\u001b[m\u000f=\u001b[92mA44UoRnIXGbIgbAbIeYuuxKM\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_ROOT_PASSWORD\u001b[m\u000f=\u001b[92mr94WloByy6Wea425BWCUx5YCwsiTWwMO\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Database Connection Settings (used by OpenDocMan app)\u001b[K\r\n\u001b[94mAPP_DB_HOST\u001b[m\u000f=\u001b[92mdb\u001b[m\u000f\u001b[K\r\n\u001b[94mDB_PORT\u001b[m\u000f=\u001b[92m3306\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_NAME\u001b[m\u000f=\u001b[92mperpus-tj\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_USER\u001b[m\u000f=\u001b[92mtikajua\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_PASS\u001b[m\u000f=\u001b[92mA44UoRnIXGbIgbAbIeYuuxKM\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# APPLICATION CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# OpenDocMan Data Directory (inside container)\u001b[K\r\n\u001b[94mODM_DATA_DIR\u001b[m\u000f=\u001b[92m/var/www/document_repository\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Docker Environment Flag\u001b[K\r\n\u001b[94mIS_DOCKER\u001b[m\u000f=\u001b[92mtrue\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Application Hostname\u001b[K\r\n# This must match the exact domain:port you are using to access the site.\u001b[K\r\n# Format: HOSTNAME:{optional: SERVICE_PORT}\u001b[K\r\n# Ex. http://localhost:8080 would be \"localhost:8080\".\u001b[K\r\n\u001b[94mODM_HOSTNAME\u001b[m\u000f=\u001b[92modm.local\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# PORT CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# External ports that will be mapped to the host\u001b[K\r\n# Format: HOST_PORT:CONTAINER_PORT\u001b[K\r\n\u001b[K\n# Database Port (MySQL/MariaDB)\u001b[K\r\n\u001b[94mDB_EXTERNAL_PORT\u001b[m\u000f=\u001b[92m3306\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[0;10;7m\u000f.env                                                                                                                                                    1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H# OpenDocMan Docker Environment Configuration\u001b[K\r\n# Copy this file to .env and customize the values for your installation\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# DATABASE CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# MySQL/MariaDB Database Settings\u001b[K\r\n\u001b[94mMYSQL_DATABASE\u001b[m\u000f=\u001b[92mperpus-tj\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_USER\u001b[m\u000f=\u001b[92mtikajua\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_PASSWORD\u001b[m\u000f=\u001b[92mA44UoRnIXGbIgbAbIeYuuxKM\u001b[m\u000f\u001b[K\r\n\u001b[94mMYSQL_ROOT_PASSWORD\u001b[m\u000f=\u001b[92mr94WloByy6Wea425BWCUx5YCwsiTWwMO\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Database Connection Settings (used by OpenDocMan app)\u001b[K\r\n\u001b[94mAPP_DB_HOST\u001b[m\u000f=\u001b[92mdb\u001b[m\u000f\u001b[K\r\n\u001b[94mDB_PORT\u001b[m\u000f=\u001b[92m3306\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_NAME\u001b[m\u000f=\u001b[92mperpus-tj\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_USER\u001b[m\u000f=\u001b[92mtikajua\u001b[m\u000f\u001b[K\r\n\u001b[94mAPP_DB_PASS\u001b[m\u000f=\u001b[92mA44UoRnIXGbIgbAbIeYuuxKM\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# APPLICATION CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# OpenDocMan Data Directory (inside container)\u001b[K\r\n\u001b[94mODM_DATA_DIR\u001b[m\u000f=\u001b[92m/var/www/document_repository\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Docker Environment Flag\u001b[K\r\n\u001b[94mIS_DOCKER\u001b[m\u000f=\u001b[92mtrue\u001b[m\u000f\u001b[K\r\n\u001b[K\n# Application Hostname\u001b[K\r\n# This must match the exact domain:port you are using to access the site.\u001b[K\r\n# Format: HOSTNAME:{optional: SERVICE_PORT}\u001b[K\r\n# Ex. http://localhost:8080 would be \"localhost:8080\".\u001b[K\r\n\u001b[94mODM_HOSTNAME\u001b[m\u000f=\u001b[92modm.local\u001b[m\u000f\u001b[K\r\n\u001b[K\n# =============================================================================\u001b[K\r\n# PORT CONFIGURATION\u001b[K\r\n# =============================================================================\u001b[K\r\n\u001b[K\n# External ports that will be mapped to the host\u001b[K\r\n# Format: HOST_PORT:CONTAINER_PORT\u001b[K\r\n\u001b[K\n# Database Port (MySQL/MariaDB)\u001b[K\r\n\u001b[94mDB_EXTERNAL_PORT\u001b[m\u000f=\u001b[92m3306\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[0;10;7m\u000f.env                                           "]
