[0.024, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.005, "o", "\u001b[?25l\u001b[?2031h\u001b[>4;2m\u001b(B\u001b[m# For more information on this configuration file, see containers-registries.conf(5).\u001b[K\r\n#\u001b[K\r\n# NOTE: RISK OF USING UNQUALIFIED IMAGE NAMES\u001b[K\r\n# We recommend always using fully qualified image names including the registry\u001b[K\r\n# server (full dns name), namespace, image name, and tag\u001b[K\r\n# (e.g., registry.redhat.io/ubi8/ubi:latest). Pulling by digest (i.e.,\u001b[K\r\n# quay.io/repository/name@digest) further eliminates the ambiguity of tags.\u001b[K\r\n# When using short names, there is always an inherent risk that the image being\u001b[K\r\n# pulled could be spoofed. For example, a user wants to pull an image named\u001b[K\r\n# `foobar` from a registry and expects it to come from myregistry.com. If\u001b[K\r\n# myregistry.com is not first in the search list, an attacker could place a\u001b[K\r\n# different `foobar` image at a registry earlier in the search list. The user\u001b[K\r\n# would accidentally pull and run the attacker's image and code rather than the\u001b[K\r\n# intended content. We recommend only adding registries which are completely\u001b[K\r\n# trusted (i.e., registries which don't allow unknown or anonymous users to\u001b[K\r\n# create accounts with arbitrary names). This will prevent an image from being\u001b[K\r\n# spoofed, squatted or otherwise made insecure.  If it is necessary to use one\u001b[K\r\n# of these registries, it should be added at the end of the list.\u001b[K\r\n#\u001b[K\r\n# # An array of host[:port] registries to try when pulling an unqualified image, in order.\u001b[K\r\n# unqualified-search-registries = [\"example.com\"]\u001b[K\r\n#\u001b[K\r\n# [[registry]]\u001b[K\r\n# # The \"prefix\" field is used to choose the relevant [[registry]] TOML table;\u001b[K\r\n# # (only) the TOML table with the longest match for the input image name\u001b[K\r\n# # (taking into account namespace/repo/tag/digest separators) is used.\u001b[K\r\n# #\u001b[K\r\n# # The prefix can also be of the form: *.example.com for wildcard subdomain\u001b[K\r\n# # matching.\u001b[K\r\n# #\u001b[K\r\n# # If the prefix field is missing, it defaults to be the same as the \"location\" field.\u001b[K\r\n# prefix = \"example.com/foo\"\u001b[K\r\n#\u001b[K\r\n# # If true, unencrypted HTTP as well as TLS connections with untrusted\u001b[K\r\n# # certificates are allowed.\u001b[K\r\n# insecure = false\u001b[K\r\n#\u001b[K\r\n# # If true, pulling images with matching names is forbidden.\u001b[K\r\n# blocked = false\u001b[K\r\n#\u001b[K\r\n# # The physical location of the \"prefix\"-rooted namespace.\u001b[K\r\n# #\u001b[K\r\n# # By default, this is equal to \"prefix\" (in which case \"prefix\" can be omitted\u001b[K\r\n# # and the [[registry]] TOML table can only specify \"location\").\u001b[K\r\n# #\u001b[K\r\n# # Example: Given\u001b[K\r\n# #   prefix = \"example.com/foo\"\u001b[K\r\n# #   location = \"internal-registry-for-example.com/bar\"\u001b[K\r\n# # requests for the image example.com/foo/myimage:latest will actually work with the\u001b[K\r\n# # internal-registry-for-example.com/bar/myimage:latest image.\u001b[K\r\n#\u001b[K\r\n# # The location can be empty if prefix is in a\u001b[K\r\n# # wildcarded format: \"*.example.com\". In this case, the input reference will\u001b[K\r\n# # be used as-is without any rewrite.\u001b[K\r\n# location = internal-registry-for-example.com/bar\"\u001b[K\r\n#\u001b[K\r\n# # (Possibly-partial) mirrors for the \"prefix\"-rooted namespace.\u001b[K\r\n\u001b(B\u001b[0;7m/etc/containers/registries.conf                                                                                                                                             1,1            Top\u001b(B\u001b[m\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# For more information on this configuration file, see containers-registries.conf(5).\u001b[K\r\n#\u001b[K\r\n# NOTE: RISK OF USING UNQUALIFIED IMAGE NAMES\u001b[K\r\n# We recommend always using fully qualified image names including the registry\u001b[K\r\n# server (full dns name), namespace, image name, and tag\u001b[K\r\n# (e.g., registry.redhat.io/ubi8/ubi:latest). Pulling by digest (i.e.,\u001b[K\r\n# quay.io/repository/name@digest) further eliminates the ambiguity of tags.\u001b[K\r\n# When using short names, there is always an inherent risk that the image being\u001b[K\r\n# pulled could be spoofed. For example, a user wants to pull an image named\u001b[K\r\n# `foobar` from a registry and expects it to come from myregistry.com. If\u001b[K\r\n# myregistry.com is not first in the search list, an attacker could place a\u001b[K\r\n# different `foobar` i"]
[0.001, "o", "mage at a registry earlier in the search list. The user\u001b[K\r\n# would accidentally pull and run the attacker's image and code rather than the\u001b[K\r\n# intended content. We recommend only adding registries which are completely\u001b[K\r\n# trusted (i.e., registries which don't allow unknown or anonymous users to\u001b[K\r\n# create accounts with arbitrary names). This will prevent an image from being\u001b[K\r\n# spoofed, squatted or otherwise made insecure.  If it is necessary to use one\u001b[K\r\n# of these registries, it should be added at the end of the list.\u001b[K\r\n#\u001b[K\r\n# # An array of host[:port] registries to try when pulling an unqualified image, in order.\u001b[K\r\n# unqualified-search-registries = [\"example.com\"]\u001b[K\r\n#\u001b[K\r\n# [[registry]]\u001b[K\r\n# # The \"prefix\" field is used to choose the relevant [[registry]] TOML table;\u001b[K\r\n# # (only) the TOML table with the longest match for the input image name\u001b[K\r\n# # (taking into account namespace/repo/tag/digest separators) is used.\u001b[K\r\n# #\u001b[K\r\n# # The prefix can also be of the form: *.example.com for wildcard subdomain\u001b[K\r\n# # matching.\u001b[K\r\n# #\u001b[K\r\n# # If the prefix field is missing, it defaults to be the same as the \"location\" field.\u001b[K\r\n# prefix = \"example.com/foo\"\u001b[K\r\n#\u001b[K\r\n# # If true, unencrypted HTTP as well as TLS connections with untrusted\u001b[K\r\n# # certificates are allowed.\u001b[K\r\n# insecure = false\u001b[K\r\n#\u001b[K\r\n# # If true, pulling images with matching names is forbidden.\u001b[K\r\n# blocked = false\u001b[K\r\n#\u001b[K\r\n# # The physical location of the \"prefix\"-rooted namespace.\u001b[K\r\n# #\u001b[K\r\n# # By default, this is equal to \"prefix\" (in which case \"prefix\" can be omitted\u001b[K\r\n# # and the [[registry]] TOML table can only specify \"location\").\u001b[K\r\n# #\u001b[K\r\n# # Example: Given\u001b[K\r\n# #   prefix = \"example.com/foo\"\u001b[K\r\n# #   location = \"internal-registry-for-example.com/bar\"\u001b[K\r\n# # requests for the image example.com/foo/myimage:latest will actually work with the\u001b[K\r\n# # internal-registry-for-example.com/bar/myimage:latest image.\u001b[K\r\n#\u001b[K\r\n# # The location can be empty if prefix is in a\u001b[K\r\n# # wildcarded format: \"*.example.com\". In this case, the input reference will\u001b[K\r\n# # be used as-is without any rewrite.\u001b[K\r\n# location = internal-registry-for-example.com/bar\"\u001b[K\r\n#\u001b[K\r\n# # (Possibly-partial) mirrors for the \"prefix\"-rooted namespace.\u001b[K\r\n\u001b(B\u001b[0;7m/etc/containers/registries.conf                                                                                                                                             1,1            Top\u001b(B\u001b[m\r\n\u001b[J\u001b[H\u001b[?25h"]
