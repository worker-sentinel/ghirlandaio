[0.001, "o", "\u001b[?25l\u001b[m\u000f## sudoers file.\u001b[K\r\n##\u001b[K\r\n## This file MUST be edited with the 'visudo' command as root.\u001b[K\r\n## Failure to use 'visudo' may result in syntax or file permission errors\u001b[K\r\n## that prevent sudo from running.\u001b[K\r\n##\u001b[K\r\n## See the sudoers man page for the details on how to write a sudoers file.\u001b[K\r\n##\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## Host alias specification\u001b[K\r\n##\u001b[K\r\n## Groups of machines. These may include host names (optionally with wildcards),\u001b[K\r\n## IP addresses, network numbers or netgroups.\u001b[K\r\n# Host_Alias    WEBSERVERS = www1, www2, www3\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## User alias specification\u001b[K\r\n##\u001b[K\r\n## Groups of users.  These may consist of user names, uids, Unix groups,\u001b[K\r\n## or netgroups.\u001b[K\r\n# User_Alias    ADMINS = millert, dowdy, mikef\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## Cmnd alias specification\u001b[K\r\n##\u001b[K\r\n## Groups of commands.  Often used to group related commands together.\u001b[K\r\n# Cmnd_Alias    PROCESSES = /usr/bin/nice, /bin/kill, /usr/bin/renice, \\\u001b[K\r\n#                           /usr/bin/pkill, /usr/bin/top\u001b[K\r\n#\u001b[K\r\n# Cmnd_Alias    REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff\u001b[K\r\n#\u001b[K\r\n# Cmnd_Alias    DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bin/strace, \\\u001b[K\r\n#                           /usr/bin/truss, /usr/bin/bpftrace, \\\u001b[K\r\n#                           /usr/bin/dtrace, /usr/bin/dtruss\u001b[K\r\n#\u001b[K\r\n# Cmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \\\u001b[K\r\n#                        /usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \\\u001b[K\r\n#                        /usr/bin/pacman\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## Defaults specification\u001b[K\r\n##\u001b[K\r\n## Preserve editor environment variables for visudo.\u001b[K\r\n## To preserve these for all commands, remove the \"!visudo\" qualifier.\u001b[K\r\n\u001b[0;10;1m\u000fDefaults\u001b[m\u000f\u001b[96m!\u001b[m\u000f\u001b[92m/usr/bin/visudo\u001b[m\u000f \u001b[94menv_keep\u001b[m\u000f += \u001b[92m\"SUDO_EDITOR EDITOR VISUAL\"\u001b[m\u000f\u001b[K\r\n##\u001b[K\r\n## Use a hard-coded PATH instead of the user's to find commands.\u001b[K\r\n## This also helps prevent poorly written scripts from running\u001b[K\r\n## arbitrary commands under sudo.\u001b[K\r\n\u001b[0;10;1m\u000fDefaults\u001b[m\u000f \u001b[94msecure_path\u001b[m\u000f=\u001b[92m\"/usr/local/sbin:/usr/local/bin:/usr/bin\"\u001b[m\u000f\u001b[K\r\n##\u001b[K\r\n## You may wish to keep some of the following environment variables\u001b[K\r\n## when running commands via sudo.\u001b[K\r\n##\u001b[K\r\n## Locale settings\u001b[K\r\n# Defaults env_keep += \"LANG LANGUAGE LINGUAS LC_* _XKB_CHARSET\"\u001b[K\r\n##\u001b[K\r\n## Run X applications through sudo; HOME is used to find the\u001b[K\r\n## .Xauthority file.  Note that other programs use HOME to find   \u001b[K\r\n## configuration files and this may lead to privilege escalation!\u001b[K\r\n# Defaults env_keep += \"HOME\"\u001b[K\r\n##\u001b[K\r\n## X11 resource path settings\u001b[K\r\n# Defaults env_keep += \"XAPPLRESDIR XFILESEARCHPATH XUSERFILESEARCHPATH\"\u001b[K\r\n\u001b[0;10;7m\u000fetc/sudoers [RO]                                                                                                                                                                                                              1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H## sudoers file.\u001b[K\r\n##\u001b[K\r\n## This file MUST be edited with the 'visudo' command as root.\u001b[K\r\n## Failure to use 'visudo' may result in syntax or file permission errors\u001b[K\r\n## that prevent sudo from running.\u001b[K\r\n##\u001b[K\r\n## See the sudoers man page for the details on how to write a sudoers file.\u001b[K\r\n##\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## Host alias specification\u001b[K\r\n##\u001b[K\r\n## Groups of machines. These may include host names (optionally with wildcards),\u001b[K\r\n## IP addresses, network numbers or netgroups.\u001b[K\r\n# Host_Alias    WEBSERVERS = www1, www2, www3\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## User alias specification\u001b[K\r\n##\u001b[K\r\n## Groups of users.  These may consist of user names, uids, Unix groups,\u001b[K\r\n## or netgroups.\u001b[K\r\n# User_Alias    ADMINS = millert, dowdy, mikef\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## Cmnd alias specification\u001b[K\r\n##\u001b[K\r\n## Groups of commands.  Often used to group related commands together.\u001b[K\r\n# Cmnd_Alias    PROCESSES = /usr/bin/nice, /bin/kill, /usr/bin/renice, \\\u001b[K\r\n#                           /usr/bin/pkill, /usr/bin/top\u001b[K\r\n#\u001b[K\r\n# Cmnd_Alias    REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff\u001b[K\r\n#\u001b[K\r\n# Cmnd_Alias    DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bi"]
[0.000, "o", "n/strace, \\\u001b[K\r\n#                           /usr/bin/truss, /usr/bin/bpftrace, \\\u001b[K\r\n#                           /usr/bin/dtrace, /usr/bin/dtruss\u001b[K\r\n#\u001b[K\r\n# Cmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \\\u001b[K\r\n#                        /usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \\\u001b[K\r\n#                        /usr/bin/pacman\u001b[K\r\n\u001b[K\n##\u001b[K\r\n## Defaults specification\u001b[K\r\n##\u001b[K\r\n## Preserve editor environment variables for visudo.\u001b[K\r\n## To preserve these for all commands, remove the \"!visudo\" qualifier.\u001b[K\r\n\u001b[0;10;1m\u000fDefaults\u001b[m\u000f\u001b[96m!\u001b[m\u000f\u001b[92m/usr/bin/visudo\u001b[m\u000f \u001b[94menv_keep\u001b[m\u000f += \u001b[92m\"SUDO_EDITOR EDITOR VISUAL\"\u001b[m\u000f\u001b[K\r\n##\u001b[K\r\n## Use a hard-coded PATH instead of the user's to find commands.\u001b[K\r\n## This also helps prevent poorly written scripts from running\u001b[K\r\n## arbitrary commands under sudo.\u001b[K\r\n\u001b[0;10;1m\u000fDefaults\u001b[m\u000f \u001b[94msecure_path\u001b[m\u000f=\u001b[92m\"/usr/local/sbin:/usr/local/bin:/usr/bin\"\u001b[m\u000f\u001b[K\r\n##\u001b[K\r\n## You may wish to keep some of the following environment variables\u001b[K\r\n## when running commands via sudo.\u001b[K\r\n##\u001b[K\r\n## Locale settings\u001b[K\r\n# Defaults env_keep += \"LANG LANGUAGE LINGUAS LC_* _XKB_CHARSET\"\u001b[K\r\n##\u001b[K\r\n## Run X applications through sudo; HOME is used to find the\u001b[K\r\n## .Xauthority file.  Note that other programs use HOME to find   \u001b[K\r\n## configuration files and this may lead to privilege escalation!\u001b[K\r\n# Defaults env_keep += \"HOME\"\u001b[K\r\n##\u001b[K\r\n## X11 resource path settings\u001b[K\r\n# Defaults env_keep += \"XAPPLRESDIR XFILESEARCHPATH XUSERFILESEARCHPATH\"\u001b[K\r\n\u001b[0;10;7m\u000fetc/sudoers [RO]                                                                                                                                                                                                              1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
