[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1            1%\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Desktop path settings\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1            2\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults env_keep += \"QTDIR KDEDIR\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1            4\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1            5\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Allow sudo-run commands to inherit the callers' ConsoleKit session\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f70,1            6\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults env_keep += \"XDG_SESSION_COOKIE\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,1            8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f2,1            9\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to enable special input methods.  Care should be taken as\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,1           10\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## this may allow users to subvert the command being run via sudo.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,1           12\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults env_keep += \"XMODIFIERS GTK_IM_MODULE QT_IM_MODULE QT_IM_SWITCHER\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f5,1           13\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1           14\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to disable \"use_pty\" when running commands as root.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1           16\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Commands run as non-root users will run in a pseudo-terminal,\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1           17\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## not the user's own terminal, to prevent command injection.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1           18\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults>root !use_pty\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f80,1           20\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,1           21\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to run commands in the background by default.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f2,1           22\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## This can be used to prevent sudo from consuming user input while\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,1           24\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## a non-interactive command runs if \"use_pty\" or I/O logging are\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,1           25\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## enabled.  Some commands may not run properly in the background.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f5,1           27\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults exec_background\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1           28\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1           29\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to send mail if the user does not enter the correct password.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1           31\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults mail_badpass\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1           32\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f90,1           33\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to enable logging of a command's output, except for\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,1           35\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## sudoreplay and reboot.  Use sudoreplay to play back logged sessions.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f2,1           36\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Sudo will create up to 2,176,782,336 I/O logs before recycling them.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,1           37\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Set maxseq to a smaller number if you don't have unlimited disk space.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,1           39\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults log_output\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f5,1           40\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults!/usr/bin/sudoreplay !log_output\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1           41\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults!/usr/local/bin/sudoreplay !log_output\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1           43\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults!REBOOT !log_output\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1           44\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults maxseq = 1000\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1           45\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f100,1          47\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to disable intercept and log_subcmds for debuggers and\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,1          48\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## tracers.  Otherwise, anything that uses ptrace(2) will be unable\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,1          50\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## to run under sudo if intercept_type is set to \"trace\".\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          51\r\u001b[A\u001b[?25h"]
