[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#COMPRESSION=\"lzop\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1            6%\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#COMPRESSION=\"lz4\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1           12\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1           18\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# COMPRESSION_OPTIONS\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1           25\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Additional options for the compressor\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f70,1           31\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#COMPRESSION_OPTIONS=()\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,1           37\r\u001b[A\u001b[?25h"]
[0.255, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f2,1           43\r\u001b[A\u001b[?25h"]
[0.251, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# MODULES_DECOMPRESS\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,1           50\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,1           56\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# creation. Switch (yes/no).\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f5,1           62\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Enable to allow further decreasing image size when using high compression\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1           68\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# (e.g. xz -9e or zstd --long --ultra -22) at the expense of increased RAM usage\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1           75\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# at early boot.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1           81\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Note that any compressed files will be placed in the uncompressed early CPIO\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1           87\r\u001b[A\u001b[?25h"]
