[0.003, "o", "(183/191) installing python-gobject                                                                                                              [########################################################################################] 100%\r\r\n"]
[0.001, "o", "Optional dependencies for python-gobject\r\n\u001b[0;1m   \u001b[0m python-cairo: Cairo bindings\r\n(184/191) installing python-firewall                                                                                                             [----------------------------------------------------------------------------------------]   0%\r"]
[0.008, "o", "(184/191) installing python-firewall                                                                                                             [########################################################################################] 100%\r\r\n"]
