[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1            1%\r\u001b[A\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## Use a hard-coded PATH instead of the user's to find commands.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1            2\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## This also helps prevent poorly written scripts from running\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1            3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## arbitrary commands under sudo.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f50,1            4\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[0;10;1m\u000fDefaults\u001b[m\u000f \u001b[94msecure_path\u001b[m\u000f=\u001b[92m\"/usr/local/sbin:/usr/local/bin:/usr/bin\"\u001b[m\u000f\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1            5\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1            6\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## You may wish to keep some of the following environment variables\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1            7\r\u001b[A\u001b[?25h"]
