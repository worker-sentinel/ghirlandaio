[0.017, "o", "\u001b[1;38H\u001b[30m\u001b[103mu\u001b[4;23Hu\u001b[m\u000fsing f\u001b[30m\u001b[103mu\u001b[m\u000flly q\u001b[30m\u001b[103mu\u001b[m\u000falified image names incl\u001b[30m\u001b[103mu\u001b[5;12Hu\u001b[6;29Hu\u001b[m\u000fbi8/\u001b[30m\u001b[103mu\u001b[m\u000fbi:latest). P\u001b[30m\u001b[103mu\u001b[7;4Hu\u001b[m\u000fay.io/repository/name@digest) f\u001b[30m\u001b[103mu\u001b[m\u000frther eliminates the ambig\u001b[30m\u001b[103mu\u001b[8;8Hu\u001b[9;4Hu\u001b[m\u000flled co\u001b[30m\u001b[103mu\u001b[m\u000fld be spoofed. For example, a \u001b[30m\u001b[103mu\u001b[m\u000fser wants to p\u001b[30m\u001b[103mu\u001b[11;65Hu\u001b[12;74Hu\u001b[13;5Hu\u001b[m\u000fld accidentally p\u001b[30m\u001b[103mu\u001b[m\u000fll and r\u001b[30m\u001b[103mu\u001b[15;5Hu\u001b[m\u000fsted (i.e., registries which don't allow \u001b[30m\u001b[103mu\u001b[m\u000fnknown or anonymo\u001b[30m\u001b[103mu\u001b[m\u000fs \u001b[30m\u001b[103mu\u001b[16;14Hu\u001b[17;14Hu\u001b[m\u000fatted or otherwise made insec\u001b[30m\u001b[103mu\u001b[m\u000fre.  If it is necessary to \u001b[30m\u001b[103mu\u001b[18;30Hu\u001b[20;53Hu\u001b[m\u000flling an \u001b[30m\u001b[103mu\u001b[m\u000fnq\u001b[30m\u001b[103mu\u001b[21;3Hu\u001b[m\u000fnq\u001b[30m\u001b[103mu\u001b[24;27Hu\u001b[25;61Hu\u001b[26;22Hu\u001b[m\u000fnt namespace/repo/tag/digest separators) is \u001b[30m\u001b[103mu\u001b[28;69Hu\u001b[31;44Hu\u001b[34;10Hu\u001b[m\u000fe, \u001b[30m\u001b[103mu\u001b[m\u000fnencrypted HTTP as well as TLS connections with \u001b[30m\u001b[103mu\u001b[m\u000fntr\u001b[30m\u001b[103mu\u001b[36;8Hu\u001b[38;10Hu\u001b[m\u000fe, p\u001b[30m\u001b[103mu\u001b[43;12Hu\u001b[m\u000flt, this is eq\u001b[30m\u001b[103mu\u001b[47;155H\u001b[0;10;7m\u000f38\u001b[48;3H\u001b[?25h"]
