[0.001, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.conf'\u001b[m\u000f\r\n"]
[0.000, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/kernel/vmlinuz-linux-lts -c /etc/mkinitcpio.conf -U boot/efi/linux/arch-linux-lts.efi\u001b[m\u000f\r\n"]
[0.029, "o", "==> ERROR: Invalid option -U -- '/home/force/boot/efi/linux/arch-linux-lts.efi' must be writable\r\n"]
[0.002, "o", "\u001b[?2004h[root@archlinux force]# "]
[22.868, "o", "mkinitcpio -P"]
