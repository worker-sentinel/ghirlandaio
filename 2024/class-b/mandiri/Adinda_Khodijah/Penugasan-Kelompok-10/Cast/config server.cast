[0.018, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.001, "o", "\u001b[?25l\u001b[m\u000f##### hostapd configuration file ##############################################\u001b[K\r\n# Empty lines and lines starting with # are ignored\u001b[K\r\n\u001b[K\n# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\u001b[K\r\n# management frames with the Host AP driver); wlan0 with many nl80211 drivers\u001b[K\r\n# Note: This attribute can be overridden by the values supplied with the '-i'\u001b[K\r\n# command line parameter.\u001b[K\r\ninterface=wlan0\u001b[K\r\n\u001b[K\n# In case of atheros and nl80211 driver interfaces, an additional\u001b[K\r\n# configuration parameter, bridge, may be used to notify hostapd if the\u001b[K\r\n# interface is included in a bridge. This parameter is not used with Host AP\u001b[K\r\n# driver. If the bridge parameter is not set, the drivers will automatically\u001b[K\r\n# figure out the bridge interface (assuming sysfs is enabled and mounted to\u001b[K\r\n# /sys) and this parameter may not be needed.\u001b[K\r\n#\u001b[K\r\n# For nl80211, this parameter can be used to request the AP interface to be\u001b[K\r\n# added to the bridge automatically (brctl may refuse to do this before hostapd\u001b[K\r\n# has been started to change the interface mode). If needed, the bridge\u001b[K\r\n# interface is also created.\u001b[K\r\n#bridge=br0\u001b[K\r\n\u001b[K\n# Driver interface type (hostap/wired/none/nl80211/bsd);\u001b[K\r\n# default: hostap). nl80211 is used with all Linux mac80211 drivers.\u001b[K\r\n# Use driver=none if building hostapd as a standalone RADIUS server that does\u001b[K\r\n# not control any wireless/wired driver.\u001b[K\r\n# driver=hostap\u001b[K\r\n\u001b[K\n# Driver interface parameters (mainly for development testing use)\u001b[K\r\n# driver_params=<params>\u001b[K\r\n\u001b[K\n# hostapd event logger configuration\u001b[K\r\n#\u001b[K\r\n# Two output method: syslog and stdout (only usable if not forking to\u001b[K\r\n# background).\u001b[K\r\n#\u001b[K\r\n# Module bitfield (ORed bitfield of modules that will be logged; -1 = all\u001b[K\r\n# modules):\u001b[K\r\n# bit 0 (1) = IEEE 802.11\u001b[K\r\n# bit 1 (2) = IEEE 802.1X\u001b[K\r\n# bit 2 (4) = RADIUS\u001b[K\r\n# bit 3 (8) = WPA\u001b[K\r\n# bit 4 (16) = driver interface\u001b[K\r\n# bit 6 (64) = MLME\u001b[K\r\n#\u001b[K\r\n# Levels (minimum value for logged events):\u001b[K\r\n#  0 = verbose debugging\u001b[K\r\n#  1 = debugging\u001b[K\r\n#  2 = informational messages\u001b[K\r\n#  3 = notification\u001b[K\r\n#  4 = warning\u001b[K\r\n#\u001b[K\r\nlogger_syslog=-1\u001b[K\r\nlogger_syslog_level=2\u001b[K\r\nlogger_stdout=-1\u001b[K\r\nlogger_stdout_level=2\u001b[K\r\n\u001b[K\n# Interface for separate control program. If this is specified, hostapd\u001b[K\r\n# will create this directory and a UNIX domain socket for listening to requests\u001b[K\r\n# from external programs (CLI/GUI, etc.) for status information and\u001b[K\r\n# configuration. The socket file will be named based on the interface name, so\u001b[K\r\n# multiple hostapd processes/interfaces can be run at the same time if more\u001b[K\r\n# than one interface is used.\u001b[K\r\n# /run/hostapd is the recommended directory for sockets and by default,\u001b[K\r\n# hostapd_cli will use it when trying to connect with hostapd.\u001b[K\r\n\u001b[0;10;7m\u000f/etc/hostapd/hostapd.conf                                                                                                                                                                                                     1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H##### hostapd configuration file ##############################################\u001b[K\r\n# Empty lines and lines starting with # are ignored\u001b[K\r\n\u001b[K\n# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\u001b[K\r\n# management frames with the Host AP driver); wlan0 with many nl80211 drivers\u001b[K\r\n# Note: This attribute can be overridden by the values supplied with the '-i'\u001b[K\r\n# command line parameter.\u001b[K\r\ninterface=wlan0\u001b[K\r\n\u001b[K\n# In case of atheros and nl80211 driver interfaces, an additional\u001b[K\r\n# configuration parameter, bridge, may be used to notify hostapd if the\u001b[K\r\n# interface is included in a bridge. This parameter is not used with Host AP\u001b[K\r\n# driver. If the bridge parameter is not set, the drivers will automatically\u001b[K\r\n# figure out the bridge interface (assuming sysfs is enabled and mounted to\u001b[K\r\n# /sys) and this parameter may not be needed.\u001b[K\r\n#\u001b[K\r\n# For nl80211, this parameter can be used to request the AP interface to be\u001b[K\r\n# added to the brid"]
[0.000, "o", "ge automatically (brctl may refuse to do this before hostapd\u001b[K\r\n# has been started to change the interface mode). If needed, the bridge\u001b[K\r\n# interface is also created.\u001b[K\r\n#bridge=br0\u001b[K\r\n\u001b[K\n# Driver interface type (hostap/wired/none/nl80211/bsd);\u001b[K\r\n# default: hostap). nl80211 is used with all Linux mac80211 drivers.\u001b[K\r\n# Use driver=none if building hostapd as a standalone RADIUS server that does\u001b[K\r\n# not control any wireless/wired driver.\u001b[K\r\n# driver=hostap\u001b[K\r\n\u001b[K\n# Driver interface parameters (mainly for development testing use)\u001b[K\r\n# driver_params=<params>\u001b[K\r\n\u001b[K\n# hostapd event logger configuration\u001b[K\r\n#\u001b[K\r\n# Two output method: syslog and stdout (only usable if not forking to\u001b[K\r\n# background).\u001b[K\r\n#\u001b[K\r\n# Module bitfield (ORed bitfield of modules that will be logged; -1 = all\u001b[K\r\n# modules):\u001b[K\r\n# bit 0 (1) = IEEE 802.11\u001b[K\r\n# bit 1 (2) = IEEE 802.1X\u001b[K\r\n# bit 2 (4) = RADIUS\u001b[K\r\n# bit 3 (8) = WPA\u001b[K\r\n# bit 4 (16) = driver interface\u001b[K\r\n# bit 6 (64) = MLME\u001b[K\r\n#\u001b[K\r\n# Levels (minimum value for logged events):\u001b[K\r\n#  0 = verbose debugging\u001b[K\r\n#  1 = debugging\u001b[K\r\n#  2 = informational messages\u001b[K\r\n#  3 = notification\u001b[K\r\n#  4 = warning\u001b[K\r\n#\u001b[K\r\nlogger_syslog=-1\u001b[K\r\nlogger_syslog_level=2\u001b[K\r\nlogger_stdout=-1\u001b[K\r\nlogger_stdout_level=2\u001b[K\r\n\u001b[K\n# Interface for separate control program. If this is specified, hostapd\u001b[K\r\n# will create this directory and a UNIX domain socket for listening to requests\u001b[K\r\n# from external programs (CLI/GUI, etc.) for status information and\u001b[K\r\n# configuration. The socket file will be named based on the interface name, so\u001b[K\r\n# multiple hostapd processes/interfaces can be run at the same time if more\u001b[K\r\n# than one interface is used.\u001b[K\r\n# /run/hostapd is the recommended directory for sockets and by default,\u001b[K\r\n# hostapd_cli will use it when trying to connect with hostapd.\u001b[K\r\n\u001b[0;10;7m\u000f/etc/hostapd/hostapd.conf                                                                                                                                                                                                     1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
