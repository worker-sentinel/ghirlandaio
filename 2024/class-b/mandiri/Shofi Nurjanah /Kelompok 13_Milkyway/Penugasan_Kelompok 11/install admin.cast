[0.006, "o", "version: \"3.7\"\r\nservices: \r\n    db:\r\n        image: mysql:5.7\r\n        restart: always\r\n        networks: \r\n            slims-net:\r\n                ipv4_address: 172.18.1.3\r\n        container_name: slims-db\r\n        env_file: \r\n            - db_default.env\r\n        command: --sql_mode=STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION --max_allowed_packet=1024M\r\n        volumes:\r\n            - \"./dbdata:/var/lib/mysql\"\r\n        #ports:\r\n        #    - \"3306:3306\"\r\n    app01:\r\n        image: slimsofficial/slims:latest\r\n        restart: always\r\n        networks: \r\n            slims-net:\r\n                ipv4_address: 172.18.1.11\r\n        container_name: slims-app\r\n        ports:\r\n            - \"80:80\"\r\n            - \"443:443\"\r\n        volumes:\r\n            - \"./app:/var/www/html\"\r\nnetworks: \r\n    slims-net:\r\n        name: slims-net\r\n        ipam:\r\n            driver: default\r\n            config:\r\n              - subnet: \"172.18.1.0/24\"\r\n"]
