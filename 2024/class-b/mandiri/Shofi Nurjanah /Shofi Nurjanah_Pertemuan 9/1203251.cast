[0.002, "o", "\u001b[1;5H\u001b[30m\u001b[103mi\u001b[m\u000fn\u001b[30m\u001b[103mi\u001b[m\u000ftcp\u001b[30m\u001b[103mi\u001b[m\u000fo preset f\u001b[30m\u001b[103mi\u001b[m\u000fle for the 'l\u001b[30m\u001b[103mi\u001b[3;9Hi\u001b[m\u000fg=\u001b[92m\"/etc/mk\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mn\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mtcp\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[4;20Hi\u001b[m\u000f\u001b[92mnuz-l\u001b[m\u000f\u001b[30m\u001b[103mi\ni\u001b[m\u000fnuz-l\u001b[30m\u001b[103mi\u001b[10;14Hi\u001b[m\u000fg=\"/etc/mk\u001b[30m\u001b[103mi\u001b[m\u000fn\u001b[30m\u001b[103mi\u001b[m\u000ftcp\u001b[30m\u001b[103mi\u001b[11;9Hi\u001b[m\u000fmage=\u001b[92m\"/boot/\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mn\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mtramfs-l\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mnux-hardened.\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[12;11Hi\u001b[m\u000f=\u001b[92m\"boot/ef\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92m/L\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mnux/arch-l\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mnux-hardened.ef\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[13;12Hi\u001b[m\u000fons=\u001b[92m\"--cmdl\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[m\u000f\u001b[92mne /etc/cmdl\u001b[m\u000f\u001b[30m\u001b[103mi\u001b[15;15Hi\u001b[m\u000fg=\"/etc/mk\u001b[30m\u001b[103mi\u001b[m\u000fn\u001b[30m\u001b[103mi\u001b[m\u000ftcp\u001b[30m\u001b[103mi\u001b[16;11Hi\u001b[m\u000fmage=\"/boot/\u001b[30m\u001b[103mi\u001b[m\u000fn\u001b[30m\u001b[103mi\u001b[m\u000ftramfs-l\u001b[30m\u001b[103mi\u001b[m\u000fnux-hardened-fallback.\u001b[30m\u001b[103mi\u001b[17;13Hi\u001b[m\u000f=\"/ef\u001b[30m\u001b[103mi\u001b[m\u000f/EFI/L\u001b[30m\u001b[103mi\u001b[m\u000fnux/arch-l\u001b[30m\u001b[103mi\u001b[m\u000fnux-hardened-fallback.ef\u001b[30m\u001b[103mi\u001b[18;14Hi\u001b[66;225H\u001b[0;10;7m\u000f20\u001b[67;3H\u001b[?25h"]
