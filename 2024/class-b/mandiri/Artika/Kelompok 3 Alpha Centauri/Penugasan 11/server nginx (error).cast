[0.000, "o", "\u001b[1;90m      Network name                      Security            Signal\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K  \u001b[1;90m> \u001b[0m  TP-Link_6B8E                      psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      gapunya kuota                     psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      nastar                            psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      artika                            psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      videl                             psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      Koskosan atas_EXT                 psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      riskhuu                           psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      Galaxy                            psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      DIGITALmedia                      psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K      Admin_staff                       psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode\r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# device wlan0 set-property Mode"]
