[0.012, "o", "\u001b[c\u001b[?25l\u001b[m\u000f# mkinitcpio preset file for the 'linux-hardened' package\u001b[K\r\n\u001b[K\n#ALL_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\nALL_kver=\u001b[92m\"/boot/vmlinuz-linux-hardened\"\u001b[m\u000f\u001b[K\r\n#ALL_kerneldest=\"/boot/vmlinuz-linux-hardened\"\u001b[K\r\n\u001b[K\nPRESETS=(\u001b[92m'default'\u001b[m\u000f)\u001b[K\r\n#PRESETS=('default' 'fallback')\u001b[K\r\n\u001b[K\n#default_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\ndefault_image=\u001b[92m\"/boot/initramfs-linux-hardened.img\"\u001b[m\u000f\u001b[K\r\n#default_uki=\"/efi/EFI/Linux/arch-linux-hardened.efi\"\u001b[K\r\n#default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\u001b[K\r\n\u001b[K\n#fallback_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#fallback_image=\"/boot/initramfs-linux-hardened-fallback.img\"\u001b[K\r\n#fallback_uki=\"/efi/EFI/Linux/arch-linux-hardened-fallback.efi\"\u001b[K\r\n#fallback_options=\"-S autodetect\"\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000fetc/mkinitcpio.d/linux-hardened.preset                                                                                                                                                                                        1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# mkinitcpio preset file for the 'linux-hardened' package\u001b[K\r\n\u001b[K\n#ALL_config=\"