[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults env_keep += \"XDG_SESSION_COOKIE\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,1            8\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f2,1            9\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to enable special input methods.  Care should be taken as\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,1           10\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## this may allow users to subvert the command being run via sudo.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,1           12\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults env_keep += \"XMODIFIERS GTK_IM_MODULE QT_IM_MODULE QT_IM_SWITCHER\"\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f5,1           13\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f6,1           14\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to disable \"use_pty\" when running commands as root.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7,1           16\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Commands run as non-root users will run in a pseudo-terminal,\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f8,1           17\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## not the user's own terminal, to prevent command injection.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f9,1           18\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Defaults>root !use_pty\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f80,1           20\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H##\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f1,1           21\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## Uncomment to run commands in the background by default.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f2,1           22\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## This can be used to prevent sudo from consuming user input while\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f3,1           24\r\u001b[A\u001b[?25h"]
[0.033, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H## a non-interactive command runs if \"use_pty\" or I/O logging are\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f4,1           25\r\u001b[A\u001b[?25h"]
