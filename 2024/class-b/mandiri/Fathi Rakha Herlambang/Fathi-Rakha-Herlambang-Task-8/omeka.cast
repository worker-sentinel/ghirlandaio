[1533.921011, "o", "\u001b[6;27H\u001b[30m\u001b[103me\u001b[m\u000f, g\u001b[30m\u001b[103me\u001b[m\u000fn\u001b[30m\u001b[103me\u001b[m\u000frally call\u001b[30m\u001b[103me\u001b[m\u000fd php.ini, is r\u001b[30m\u001b[103me\u001b[m\u000fsponsibl\u001b[30m\u001b[103me\u001b[7;25He\u001b[m\u000f asp\u001b[30m\u001b[103me\u001b[m\u000fcts of PHP's b\u001b[30m\u001b[103me\u001b[9;10He\u001b[m\u000fmpts to find and load this configuration from a numb\u001b[30m\u001b[103me\u001b[10;5He\u001b[m\u000f following is a summary of its s\u001b[30m\u001b[103me\u001b[m\u000farch ord\u001b[30m\u001b[103me\u001b[11;16He\u001b[m\u000f sp\u001b[30m\u001b[103me\u001b[12;8He\u001b[m\u000f PHPRC \u001b[30m\u001b[103me\u001b[m\u000fnvironm\u001b[30m\u001b[103me\u001b[m\u000fnt variabl\u001b[30m\u001b[103me\u001b[13;12He\u001b[m\u000fr of pr\u001b[30m\u001b[103me\u001b[m\u000fd\u001b[30m\u001b[103me\u001b[m\u000ffin\u001b[30m\u001b[103me\u001b[m\u000fd r\u001b[30m\u001b[103me\u001b[m\u000fgistry k\u001b[30m\u001b[103me\u001b[14;10He\u001b[m\u000fnt working dir\u001b[30m\u001b[103me\u001b[m\u000fctory (\u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[15;8He\u001b[m\u000f w\u001b[30m\u001b[103me\u001b[m\u000fb s\u001b[30m\u001b[103me\u001b[m\u000frv\u001b[30m\u001b[103me\u001b[m\u000fr's dir\u001b[30m\u001b[103me\u001b[m\u000fctory (for SAPI modul\u001b[30m\u001b[103me\u001b[m\u000fs), or dir\u001b[30m\u001b[103me\u001b[16;7He\u001b[m\u000frwis\u001b[30m\u001b[103me\u001b[17;8He\u001b[m\u000f dir\u001b[30m\u001b[103me\u001b[m\u000fctory from th\u001b[30m\u001b[103me\u001b[m\u000f --with-config-fil\u001b[30m\u001b[103me\u001b[m\u000f-path compil\u001b[30m\u001b[103me\u001b[m\u000f tim\u001b[30m\u001b[103me\u001b[m\u000f option, or th\u001b[30m\u001b[103me\u001b[18;14He\u001b[19;4Hee\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[m\u000f PHP docs for mor\u001b[30m\u001b[103me\u001b[m\u000f sp\u001b[30m\u001b[103me\u001b[20;16He\u001b[m\u000ft/configuration.fil\u001b[30m\u001b[103me\u001b[22;5He\u001b[m\u000f syntax of th\u001b[30m\u001b[103me\u001b[m\u000f fil\u001b[30m\u001b[103me\u001b[m\u000f is \u001b[30m\u001b[103me\u001b[m\u000fxtr\u001b[30m\u001b[103me\u001b[m\u000fm\u001b[30m\u001b[103me\u001b[m\u000fly simpl\u001b[30m\u001b[103me\u001b[m\u000f.  Whit\u001b[30m\u001b[103me\u001b[m\u000fspac\u001b[30m\u001b[103me\u001b[m\u000f and lin\u001b[30m\u001b[103me\u001b[23;4He\u001b[m\u000fginning with a s\u001b[30m\u001b[103me\u001b[m\u000fmicolon ar\u001b[30m\u001b[103me\u001b[m\u000f sil\u001b[30m\u001b[103me\u001b[m\u000fntly ignor\u001b[30m\u001b[103me\u001b[m\u000fd (as you probably gu\u001b[30m\u001b[103me\u001b[m\u000fss\u001b[30m\u001b[103me\u001b[24;4He\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fad\u001b[30m\u001b[103me\u001b[m\u000frs (\u001b[30m\u001b[103me\u001b[m\u000f.g. [Foo]) ar\u001b[30m\u001b[103me\u001b[m\u000f also sil\u001b[30m\u001b[103me\u001b[m\u000fntly ignor\u001b[30m\u001b[103me\u001b[m\u000fd, \u001b[30m\u001b[103me\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[25;5He\u001b[m\u000fy might m\u001b[30m\u001b[103me\u001b[m\u000fan som\u001b[30m\u001b[103me\u001b[m\u000fthing in th\u001b[30m\u001b[103me\u001b[m\u000f futur\u001b[30m\u001b[103me\u001b[27;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000fs following th\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fading [PATH=/www/mysit\u001b[30m\u001b[103me\u001b[28;19He\u001b[m\u000fs in th\u001b[30m\u001b[103me\u001b[m\u000f /www/mysit\u001b[30m\u001b[103me\u001b[m\u000f dir\u001b[30m\u001b[103me\u001b[m\u000fctory.  Dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[29;15He\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fading [HOST=www.\u001b[30m\u001b[103me\u001b[m\u000fxampl\u001b[30m\u001b[103me\u001b[30;10He\u001b[m\u000fs s\u001b[30m\u001b[103me\u001b[m\u000frv\u001b[30m\u001b[103me\u001b[m\u000fd from