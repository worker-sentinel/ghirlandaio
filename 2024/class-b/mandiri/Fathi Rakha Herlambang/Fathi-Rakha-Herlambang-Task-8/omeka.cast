[1538.874895, "o", "\u001b[1;65r\u001b[H\u001b[25M\u001b[1;67r\u001b[8;5Hextension=\u001b[12;5Hextension=\u001b[17;5Hextension=\u001b[19;53Hextension=\u001b[20;4Hextension=\u001b[22;21Hextension=\u001b[24;2Hextension=\u001b[25;2Hextension=\u001b[26;2Hextension=\r\nextension=\u001b[28;2Hextension=\u001b[29;2Hextension=\u001b[30;2Hextension=\u001b[31;2Hextension=\u001b[32;2Hextension=\u001b[33;2H\u001b[30m\u001b[103mextension=g\u001b[34;12Hg\u001b[35;12Hg\u001b[36;2H\u001b[m\u000fextension=\u001b[37;2Hextension=\u001b[38;2Hextension=\u001b[39;2Hextension=\u001b[40;2Hextension=\r\n;extension=pdo_dblib\u001b[K\r\n;extension=pdo_mysql\u001b[K\r\n;extension=pdo_odbc\u001b[K\r\n;extension=pdo_pgsql\u001b[K\r\n;extension=pdo_sqlite\u001b[K\r\n;extension=pgsql\u001b[K\r\n;extension=shmop\u001b[K\r\n;extension=snmp\u001b[K\r\n;extension=soap\u001b[K\r\n;extension=sockets\u001b[K\r\n;extension=sodium\u001b[K\r\n;extension=sqlite3\u001b[K\r\n;extension=sysvmsg\u001b[K\r\n;extension=sysvsem\u001b[K\r\n;extension=sysvshm\u001b[K\r\n;extension=tidy\u001b[K\r\n;extension=xsl\u001b[K\r\nextension=\u001b[92mzip\u001b[m\u000f\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; Module Settings ;\u001b[K\r\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n\u001b[K\n\u001b[96m[CLI Server]\u001b[m\u000f\u001b[K\r\n; Whether the CLI web server uses ANSI color coding in its terminal output.\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f921,2          49\u001b[67;13H\u001b[?25h"]
