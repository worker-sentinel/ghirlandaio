[1233.160504, "o", "\u001b[H#LoadModule http2_module modules/mod_http2.so\u001b[2;2HLoadModule proxy_http2_module modules/mod_proxy_http2.so\u001b[3;2HLoadModule md_module modules/mod_md.so\u001b[32X\u001b[4;2HLoadModule lbmethod_byrequests_module modules/mod_lbmethod_byrequests.so\u001b[5;2HLoadModule lbmethod_bytraffic_module modules/mod_lbmethod_bytraffic.so\u001b[6;2HLoadModule lbmethod_bybusyness_module modules/mod_lbmethod_bybusyness.so\u001b[5X\u001b[7;2HLoadModule lbmethod_heartbeat_module modules/mod_lbmethod_heartbeat.so\u001b[5X\r\n\u001b[96mLoadModule\u001b[m\u000f unixd_module modules/mod_unixd.so\u001b[9;2HLoadModule heartbeat_module modules/mod_heartbeat.so\u001b[10;2HLoadModule heartmonitor_module modules/mod_heartmonitor.so\r\n#LoadModule dav_module modules/mod_dav.so\r\n\u001b[96mLoadModule\u001b[m\u000f status_module modules/mod_status.so\r\n\u001b[96mLoadModule\u001b[m\u000f autoindex_module modules/mod_autoindex.so\u001b[15X\u001b[14;2HLoadModule asis_module modules/mod_asis.so\u001b[16X\u001b[15;2HLoadModule info_module modules/mod_info.so\u001b[16;2HLoadModule suexec_module modules/mod_suexec.so\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f !mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[37X\r\n        #LoadModule cgid_module modules/mod_cgid.so\u001b[8X\r\n\u001b[0;10;1m\u000f</IfModule>\r\n<IfModule\u001b[m\u000f mpm_prefork_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f        #LoadModule cgi_module modules/mod_cgi.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[23;2H\u001b[m\u000fLoadModule dav_fs_module modules/mod_dav_fs.so\u001b[24;2HLoadModule dav_lock_module modules/mod_dav_lock.so\u001b[25;2HLoadModule vhost_alias_module modules/mod_vhost_alias.so\r\n\u001b[96mLoadModule\u001b[m\u000f negotiation_module modules/mod_negotiation.so\u001b[22X\r\n\u001b[96mLoadModule\u001b[m\u000f dir_module modules/mod_dir.so\u001b[32X\u001b[28;2HLoadModule imagemap_module modules/mod_imagemap.so\u001b[24X\u001b[29;2HLoadModule actions_module modules/mod_actions.so\u001b[21X\u001b[30;2HLoadModule speling_module modules/mod_speling.so\r\n\u001b[96mLoadModule\u001b[m\u000f userdir_module modules/mod_userdir.so\r\n\u001b[96mLoadModule\u001b[m\u000f alias_module modules/mod_alias.so\u001b[33;2HLoadModule \u001b[30m\u001b[103mrew\u001b[m\u000frite_module modules/mod_\u001b[30m\u001b[103mrew\u001b[m\u000frite.so\r\n \r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[29X\u001b[36;2H\u001b[56X\n If you wish httpd to run as a different user or group, you must run\r\n# httpd as root initially and it will switch.  \u001b[7X\u001b[39;2H\u001b[52X\n User/Group: The name (or #number) of the user/group to run httpd as.\u001b[41;2H It is usually good practice to create a dedicated user and group for\u001b[42;2H running httpd, as with most system services.\u001b[15X\r\n#\u001b[53X\r\n\u001b[96mUser\u001b[m\u000f http\u001b[45X\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[54X\r\n\u001b[54X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[42X\r\n\u001b[57X\u001b[49;2H 'Main' server configuration\u001b[24X\r\n#\u001b[53X\n The directives in this section set up the values used by the 'main'\u001b[52;2H server, which responds to any requests that aren't handled by a\r\n# <VirtualHost> definition.  These values also provide defaults for\r\n# any <VirtualHost> containers you may define later in the file.\u001b[55;2H\u001b[52X\n All of these directives may appear inside <VirtualHost> containers,\u001b[57;2H in which case these default settings will be overridden for the\u001b[58;2H virtual host being defined.\u001b[26X\u001b[59;2H\u001b[44X\r\n\u001b[55X\u001b[61;2H\u001b[60X\n ServerAdmin: Your address, where problems with the server should be\u001b[63;2H e-mailed.  This address appears on some server-generated pages, such\u001b[64;2H as error documents.  e.g. admin@your-domain.com\u001b[18X\u001b[65;2H\u001b[60X\u001b[66;223H\u001b[0;10;7m\u000f189,13         32\u001b[67;5H\u001b[?25h"]
