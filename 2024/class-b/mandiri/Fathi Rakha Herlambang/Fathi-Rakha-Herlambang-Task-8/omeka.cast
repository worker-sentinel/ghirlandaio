[1252.840237, "o", "\u001b[1;24H\u001b[30m\u001b[103me\u001b[67;14H\u001b[?25h"]
[1253.571019, "o", "\u001b[?25l\u001b[m\u000fs"]
[1253.576515, "o", "\u001b[1;65r\u001b[H\u001b[21M\u001b[1;67r\u001b[45;1H\u001b[96mGroup\u001b[m\u000f http\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[K\r\n\u001b[K\n# 'Main' server configuration\u001b[K\r\n#\u001b[K\r\n# The directives in this section set up the values used by the 'main'\u001b[K\r\n# server, which responds to any requests that aren't handled by a\u001b[K\r\n# <VirtualHost> definition.  These values also provide defaults for\u001b[K\r\n# any <VirtualHost> containers you may define later in the file.\u001b[K\r\n#\u001b[K\r\n# All of these directives may appear inside <VirtualHost> containers,\u001b[K\r\n# in which case these default settings will be overridden for the\u001b[K\r\n# virtual host being defined.\u001b[K\r\n#\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# ServerAdmin: Your address, where problems with the server should be\u001b[K\r\n# e-mailed.  This address appears on some server-generated pages, such\u001b[K\r\n# as error documents.  e.g. admin@your-domain.com\u001b[K\r\n#\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f89,1          32\u001b[67;15H\u001b[?25h"]
