[1250.07085, "o", "\u001b[?25l\u001b[m\u000fx"]
[1250.076883, "o", "\u001b[H    #\u001b[40X\r\n    # ScriptAlias: This controls which directories contain server scripts. \r\n    # ScriptAliases are essentially the same as Aliases, except that\r\n    # documents in the target directory are treated as applications and  \r\n    # run by the server when requested rather than as documents sent to the\r\n    # client.  The same rules about trailing \"/\" apply to ScriptAlias    \r\n    # directives as to Alias.\u001b[42X\r\n    #\u001b[39X\r\n    \u001b[96mScriptAlias\u001b[m\u000f /cgi-bin/ \u001b[92m\"/srv/http/cgi-bin/\"\u001b[m\u000f\u001b[7X\r\n\u001b[59X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[30X\r\n\u001b[46X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f cgid_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[30X\r\n    #\u001b[38X\r\n    # ScriptSock: On threaded servers, designate the path to the UNIX\r\n    # socket used to communicate with the CGI daemon of mod_cgid.\r\n    #\u001b[25X\u001b[18;5H#Scriptsock cgisock\u001b[28X\r\n\n\u001b[29X\n#\u001b[48X\r\n# \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\u001b[23;2H CGI directory exists, if you have that configured.\u001b[24;2H\u001b[50X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/cgi-bin\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[26X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\u001b[34X\r\n    \u001b[96mOptions\u001b[m\u000f None\u001b[24X\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[28X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[37X\r\n\u001b[49X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f headers_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[23X\r\n    #\u001b[39X\r\n    # Avoid passing HTTP_PROXY environment to CGI's on this or any \u001b[30m\u001b[103mprox\u001b[m\u000fied\r\n    # backend servers which have lingering \"httpoxy\" defects.\r\n    # 'Proxy' request header is undefined by the IETF, not listed by IANA\r\n    #\r\n    \u001b[96mRequestHeader\u001b[m\u000f unset Proxy early\u001b[34X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[36X\r\n \r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mime_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[48X\r\n    #\u001b[65X\r\n    # TypesConfig points to the file containing the list of mappings from\r\n    # filename extension to MIME-type.\r\n    #    \r\n    \u001b[96mTypesConfig\u001b[m\u000f conf/mime.types\r\n\n    #\u001b[6X\r\n    # AddType allows you to add to or override the MIME configuration\r\n    # file specified in TypesConfig for specific file types.\r\n    #\r\n    #AddType application/x-gzip .tgz\u001b[33X\r\n    #\u001b[60X\r\n    # AddEncoding allows you to have certain browsers uncompress   \r\n    # information on the fly. Note: Not all browsers support this.\r\n    #\r\n    #AddEncoding x-compress .Z\u001b[39X\r\n    #AddEncoding x-gzip .gz .tgz\u001b[33X\r\n    #\u001b[24X\r\n    # If the AddEncoding directives above are commented-out, then you\r\n    # probably should define those extensions to indicate media types:\r\n    #\r\n    \u001b[96mAddType\u001b[m\u000f application/x-compress .Z\u001b[32X\r\n    \u001b[96mAddType\u001b[m\u000f application/x-gzip .gz .tgz\u001b[31X\r\n\u001b[49X\n    #\u001b[66;223H\u001b[0;10;7m\u000f396,68         76\u001b[67;6H\u001b[?25h"]
[1250.25189, "o", "\u001b[?25l\u001b[m\u000fy"]
[1250.257603, "o", "\u001b[H# memory-mapping or the sendfile syscall may be used to deliver\r\n# files.  This usually improves server performance, but must\u001b[15X\r\n# be turned off when serving from networked-mounted \u001b[16X\r\n# filesystems or if support for these functions is otherwise\u001b[11X\r\n# broken on your system.\u001b[51X\r\n# Defaults: EnableMMAP On, EnableSendfile Off\u001b[24X\r\n#\u001b[28X\r\n#EnableMMAP off\r\n#EnableSendfile on\u001b[28X\r\n\n# Supplemental configuration\r\n#\r\n# The configuration files in the conf/extra/ directory can be \r\n# included to add extra features or to modify the default configuration of \r\n# the server, or you may simply copy their contents here and change as \r\n# necessary.\u001b[53X\r\n\u001b[5X\n# Server-pool management (MPM specific)\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-mpm.conf\u001b[21;2H Multi-language error messages\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-multilang-errordoc.conf\u001b[22X\r\n\u001b[52X\u001b[24;2H Fancy directory listings\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-autoindex.conf\u001b[26;5H\u001b[18X\r\n# Language settings\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-languages.conf\r\n\u001b[12X\n# User home directories\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-userdir.conf\r\n\u001b[5X\n# Real-time info on requests and configuration\u001b[28X\r\n#Include conf/extra/httpd-info.conf\u001b[26X\r\n\u001b[73X\n# Virtual hosts\r\n#Include conf/extra/httpd-vhosts.conf\r\n\u001b[11X\n# Local access to the Apache HTTP Server Manual\r\n#Include conf/extra/httpd-manual.conf\r\n\u001b[5X\n# Distributed authoring and versioning (WebDAV)\u001b[26X\r\n#Include conf/extra/httpd-dav.conf    \r\n\u001b[5X\n# Various default settings\u001b[5X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-default.conf\r\n\u001b[5X\n# Configure mod_\u001b[30m\u001b[103mproxy\u001b[m\u000f_html to understand HTML4/XHTML1\u001b[16X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f \u001b[30m\u001b[103mproxy\u001b[m\u000f_html_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[32X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/\u001b[30m\u001b[103mproxy\u001b[m\u000f-html.conf\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[25X\r\n\u001b[5X\n# Secure (SSL/TLS) connections\u001b[34X\r\n#Include conf/extra/httpd-ssl.conf\u001b[32X\r\n#    \r\n# Note: The following must be present to support\r\n#       starting without SSL on platforms with no /dev/random equivalent\r\n#       but a statically compiled-in mod_ssl.\r\n#\u001b[68X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f ssl_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[49X\r\n\u001b[96mSSLRandomSeed\u001b[m\u000f startup builtin\r\n\u001b[96mSSLRandomSeed\u001b[m\u000f connect builtin\u001b[8X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[28X\r\n\nIncludeOptional conf/conf.d/*.conf\u001b[66;223H\u001b[0;10;7m\u000f525,17         Bot\u001b[67;7H\u001b[?25h"]
[1251.852065, "o", "\u001b[?25l\u001b[m\u000f_"]
[1251.857881, "o", "\u001b[48;22H\u001b[30m\u001b[103m_\u001b[49;16H_\u001b[50;20H\u001b[m\u000fproxy\u001b[67;8H\u001b[?25h"]
