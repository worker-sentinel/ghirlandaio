is no nam\u001b[30m\u001b[103me\u001b[m\u000f validation.  If PHP can't find an \u001b[30m\u001b[103me\u001b[m\u000fxp\u001b[30m\u001b[103me\u001b[m\u000fct\u001b[30m\u001b[103me\u001b[41;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f b\u001b[30m\u001b[103me\u001b[m\u000fcaus\u001b[30m\u001b[103me\u001b[m\u000f it is not s\u001b[30m\u001b[103me\u001b[m\u000ft or is mistyp\u001b[30m\u001b[103me\u001b[m\u000fd, a d\u001b[30m\u001b[103me\u001b[m\u000ffault valu\u001b[30m\u001b[103me\u001b[m\u000f will b\u001b[30m\u001b[103me\u001b[m\u000f us\u001b[30m\u001b[103me\u001b[43;5He\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000f can b\u001b[30m\u001b[103me\u001b[m\u000f a string, a numb\u001b[30m\u001b[103me\u001b[m\u000fr, a PHP constant (\u001b[30m\u001b[103me\u001b[m\u000f.g. E_ALL or M_PI), on\u001b[30m\u001b[103me\u001b[44;8He\u001b[m\u000f INI constants (On, Off, Tru\u001b[30m\u001b[103me\u001b[m\u000f, Fals\u001b[30m\u001b[103me\u001b[m\u000f, Y\u001b[30m\u001b[103me\u001b[m\u000fs, No and Non\u001b[30m\u001b[103me\u001b[m\u000f) or an \u001b[30m\u001b[103me\u001b[m\u000fxpr\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[45;4H\u001b[30m\u001b[103me\u001b[m\u000f.g. E_ALL & ~E_NOTICE), a quot\u001b[30m\u001b[103me\u001b[m\u000fd string (\"bar\"), or a r\u001b[30m\u001b[103me\u001b[m\u000ff\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[46;5He\u001b[m\u000fviously"]
