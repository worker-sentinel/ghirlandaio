[1252.143752, "o", "\u001b[1;2HLoadModule \u001b[30m\u001b[103mproxy_m\u001b[m\u000fodule modules/mod_proxy.so\u001b[18X\u001b[2;2HLoadModule proxy_connect_module modules/mod_proxy_connect.so\u001b[3;2HLoadModule proxy_ftp_module modules/mod_proxy_ftp.so\u001b[4;2HLoadModule proxy_http_module modules/mod_proxy_http.so\u001b[5X\u001b[5;2HLoadModule proxy_fcgi_module modules/mod_proxy_fcgi.so\u001b[6;2HLoadModule proxy_scgi_module modules/mod_proxy_scgi.so\u001b[7;2HLoadModule proxy_uwsgi_module modules/mod_proxy_uwsgi.so\u001b[8;2HLoadModule proxy_fdpass_module modules/mod_proxy_fdpass.so\u001b[9;2HLoadModule proxy_wstunnel_module modules/mod_proxy_wstunnel.so\r\n#LoadModule proxy_ajp_module modules/mod_proxy_ajp.so\u001b[11;2HLoadModule proxy_balancer_module modules/mod_proxy_balancer.so\u001b[12;2HLoadModule proxy_express_module modules/mod_proxy_express.so\u001b[13;2HLoadModule proxy_hcheck_module modules/mod_proxy_hcheck.so   \u001b[14;2HLoadModule session_module modules/mod_session.so\u001b[26X\u001b[15;2HLoadModule session_cookie_module modules/mod_session_cookie.so\u001b[8X\u001b[16;2HLoadModule session_crypto_module modules/mod_session_crypto.so\r\n#LoadModule session_dbd_module modules/mod_session_dbd.so\r\n\u001b[96mLoadModule\u001b[m\u000f slotmem_shm_module modules/mod_slotmem_shm.so\r\n#LoadModule slotmem_plain_module modules/mod_slotmem_plain.so\r\n#LoadModule ssl_module modules/mod_ssl.so\u001b[21;2HLoadModule dialup_module modules/mod_dialup.so\r\n#LoadModule http2_module modules/mod_http2.so   \r\n#LoadModule proxy_http2_module modules/mod_proxy_http2.so\u001b[24;2HLoadModule md_module modules/mod_md.so\r\n#LoadModule lbmethod_byrequests_module modules/mod_lbmethod_byrequests.so\r\n#LoadModule lbmethod_bytraffic_module modules/mod_lbmethod_bytraffic.so\u001b[27;2HLoadModule lbmethod_bybusyness_module modules/mod_lbmethod_bybusyness.so\r\n#LoadModule lbmethod_heartbeat_module modules/mod_lbmethod_heartbeat.so\r\n\u001b[96mLoadModule\u001b[m\u000f unixd_module modules/mod_unixd.so\u001b[30;2HLoadModule heartbeat_module modules/mod_heartbeat.so\r\n#LoadModule heartmonitor_module modules/mod_heartmonitor.so\r\n#LoadModule dav_module modules/mod_dav.so\r\n\u001b[96mLoadModule\u001b[m\u000f status_module modules/mod_status.so\r\n\u001b[96mLoadModule\u001b[m\u000f autoindex_module modules/mod_autoindex.so\r\n#LoadModule asis_module modules/mod_asis.so\u001b[36;2HLoadModule info_module modules/mod_info.so\u001b[37;2HLoadModule suexec_module modules/mod_suexec.so\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f !mpm_prefork_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f        #LoadModule cgid_module modules/mod_cgid.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[26X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mpm_prefork_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f        #LoadModule cgi_module modules/mod_cgi.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[23X\r\n#LoadModule dav_fs_module modules/mod_dav_fs.so\u001b[45;2HLoadModule dav_lock_module modules/mod_dav_lock.so\r\n#LoadModule vhost_alias_module modules/mod_vhost_alias.so\r\n\u001b[96mLoadModule\u001b[m\u000f negotiation_module modules/mod_negotiation.so\r\n\u001b[96mLoadModule\u001b[m\u000f dir_module modules/mod_dir.so\u001b[13X\r\n#LoadModule imagemap_module modules/mod_imagemap.so\r\n#LoadModule actions_module modules/mod_actions.so\r\n#LoadModule speling_module modules/mod_speling.so\r\n\u001b[96mLoadModule\u001b[m\u000f userdir_module modules/mod_userdir.so\r\n\u001b[96mLoadModule\u001b[m\u000f alias_module modules/mod_alias.so\r\n\u001b[96mLoadModule\u001b[m\u000f rewrite_module modules/mod_rewrite.so\r\n \r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[25X\u001b[57;2H\u001b[71X\u001b[58;3HIf you wish httpd to run as a different user or group, you must run\u001b[59;2H httpd as root initially and it will switch.  \r\n#\u001b[20X\r\n# User/Group: The name (or #number) of the user/group to run httpd as.\r\n# It is usually good practice to create a dedicated user and group for\r\n# running httpd, as with most system services.\r\n#\r\n\u001b[96mUser\u001b[m\u000f http\u001b[25X\u001b[66;223H\u001b[0;10;7m\u000f136,13         28%\u001b[67;9H\u001b[?25h"]
