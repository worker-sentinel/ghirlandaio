[2.406, "o", "\r\n\u001b[?2004l\r"]
[0.049, "o", "\r\nWe trust you have received the usual lecture from the local System\r\nAdministrator. It usually boils down to these three things:\r\n\r\n    #1) Respect the privacy of others.\r\n    #2) Think before you type.\r\n    #3) With great power comes great responsibility.\r\n\r\nFor security reasons, the password you type will not be visible.\r\n\r\n[sudo] password for operator: "]
[4.599, "o", "\r\n"]
[0.046, "o", "operator is not in the sudoers file.\r\n"]
[0.001, "o", "\u001b]0;operator@comet:~\u0007\u001b[?2004h"]
[0.000, "o", "[operator@comet ~]$ "]
[179.662, "o", "sudo nmcli connection add type ethernet ifname enp3s0f4u2c2 con-name \"operator-connection\" ipv4.method manual ipv4.addresses 10.10.10.11/24 ipv4 gateway 10.10.10.1 ipv4.dns 8.8.8.8"]
