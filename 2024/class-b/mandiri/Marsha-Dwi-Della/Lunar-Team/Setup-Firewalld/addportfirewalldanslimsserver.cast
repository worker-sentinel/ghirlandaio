[0.469, "o", "\u001b[1;34musage: \u001b[0m\u001b[1;35mpodman-compose\u001b[0m [\u001b[32m-h\u001b[0m] [\u001b[32m-v\u001b[0m] [\u001b[36m--in-pod \u001b[33min_pod\u001b[0m] [\u001b[36m--pod-args \u001b[33mpod_args\u001b[0m] [\u001b[36m--env-file \u001b[33menv_file\u001b[0m] [\u001b[32m-f \u001b[33mfile\u001b[0m] [\u001b[36m--profile \u001b[33mprofile\u001b[0m] [\u001b[32m-p \u001b[33mPROJECT_NAME\u001b[0m] [\u001b[36m--podman-path \u001b[33mPODMAN_PATH\u001b[0m]\r\n                      [\u001b[36m--podman-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-pull-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-push-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-build-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-inspect-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-run-args \u001b[33margs\u001b[0m]\r\n                      [\u001b[36m--podman-start-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-stop-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-rm-args \u001b[33margs\u001b[0m] [\u001b[36m--podman-volume-args \u001b[33margs\u001b[0m] [\u001b[36m--no-ansi\u001b[0m] [\u001b[36m--no-cleanup\u001b[0m] [\u001b[36m--dry-run\u001b[0m] [\u001b[36m--parallel \u001b[33mPARALLEL\u001b[0m]\r\n                      [\u001b[36m--verbose\u001b[0m]\r\n                      \u001b[32m{help,version,wait,systemd,pull,push,build,up,down,ps,run,exec,start,stop,restart,logs,config,port,pause,unpause,kill,stats,images} ...\u001b[0m\r\n"]
