[0.003, "o", "\r\u001b[2dversion: \"3.7\"\r\u001b[3dservices:\u001b[4;5Hdb:\u001b[5d image: mysql:5.7\u001b[6;9Hrestart: always\u001b[7;9Hnetworks:\u001b[8;13H- slims-net\u001b[9;9Hcontainer_name: slims_db\u001b[10;9Henv_file:\u001b[11;13H- db_default.env\u001b[12;9Hcommand: --sql_mode=STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION --max_allowed_packet=1024M\u001b[13;9Hvolumes:\u001b[14;13H- \"./dbdata:/var/lib/mysql\"\u001b[15;9Hports:\u001b[16;11H- \"127.0.0.1:3306:3306\"\u001b[17;5Hredis:\u001b[18d\b\bimage: redis:latest\u001b[19;9Hrestart: always\u001b[20;9Hnetworks:\u001b[21;13H- slims-net\u001b[22;9Hcontainer_name: redis\u001b[23;9Hports:\u001b[24;11H- \"127.0.0.1:6379:6379\"\u001b[25;5Happ01:\u001b[26d\b\bimage: slimsofficial/slims:latest\u001b[27;9Hrestart: always\u001b[28;9Hnetworks:\u001b[29;13H- slims-net\u001b[30;9Hcontainer_name: slims-app\u001b[31;9Hports:\u001b[32d\b\b- \"80:80\"\u001b[33;13H- \"443:443\"\u001b[34;9Hvolumes:\u001b[35;13H- \"./app:/var/www/html\"\u001b[36;13H- \"./conf/php/php.ini:/usr/local/etc/php/conf.d/php.ini\"\r\u001b[37dnetworks:\u001b[38;5Hslims-net:\u001b[39;9Hname: slims-net\u001b[40;9Hipam:\u001b[41d\bdriver: default\r\u001b[2d\u001b[?12l\u001b[?25h"]
