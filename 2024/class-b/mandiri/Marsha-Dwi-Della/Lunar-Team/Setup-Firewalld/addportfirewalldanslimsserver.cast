[0.009, "o", "\u001b[H\u001b(B\u001b[0;7m  GNU nano 9.0                                                                   /etc/containers/registries.conf                                                                              \u001b[1;189H\u001b(B\u001b[m\r\u001b[58d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[58;18H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out     \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is\u001b[52G\u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut\u001b[58;69H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute\u001b[86G\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\u001b[103G\u001b(B\u001b[0;7mM-U\u001b(B\u001b[m Undo\u001b[58;120H\u001b(B\u001b[0;7mM-A\u001b(B\u001b[m Set Mark     \u001b(B\u001b[0;7mM-]\u001b(B\u001b[m To Bracket   \u001b(B\u001b[0;7mM-B\u001b(B\u001b[m Previous     \u001b(B\u001b[0;7m◂\u001b(B\u001b[m Back\r\u001b[59d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Exit\u001b[59;18H\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File     \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[52G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste\u001b[59;69H\u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[86G\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line    \u001b(B\u001b[0;7mM-E\u001b(B\u001b[m Redo\u001b[59;120H\u001b(B\u001b[0;7mM-6\u001b(B\u001b[m Copy\u001b[59;137H\u001b(B\u001b[0;7m^B\u001b(B\u001b[m Where Was     \u001b(B\u001b[0;7mM-F\u001b(B\u001b[m Next\u001b[59;171H\u001b(B\u001b[0;7m▸\u001b(B\u001b[m Forward\r\u001b[2d# For more information on this configuration file, see containers-registries.conf(5).\r\u001b[3d#\u001b[4d\b# NOTE: RISK OF USING UNQUALIFIED IMAGE NAMES\r\u001b[5d# We recommend always using fully qualified image names including the registry\r\u001b[6d# server (full dns name), namespace, image name, and tag\r\u001b[7d# (e.g., registry.redhat.io/ubi8/ubi:latest). Pulling by digest (i.e.,\r\u001b[8d# quay.io/repository/name@digest) further eliminates the ambiguity of tags.\r\u001b[9d# When using short names, there is always an inherent risk that the image being\r\u001b[10d# pulled could be spoofed. For example, a user wants to pull an image named\r\u001b[11d# `foobar` from a registry and expects it to come from myregistry.com. If\r\u001b[12d# myregistry.com is not first in the search list, an attacker could place a\r\u001b[13d# different `foobar` image at a registry earlier in the search list. The user\r\u001b[14d# would accidentally pull and run the attacker's image and code rather than the\r\u001b[15d# intended content. We recommend only adding registries which are completely\r\u001b[16d# trusted (i.e., registries which don't allow unknown or anonymous users to\r\u001b[17d# create accounts with arbitrary names). This will prevent an image from being\r\u001b[18d# spoofed, squatted or otherwise made insecure.  If it is necessary to use one\r\u001b[19d# of these registries, it should be added at the end of the list.\r\u001b[20d#\u001b[21d\b# # An array of host[:port] registries to try when pulling an unqualified image, in order.\r\u001b[22d# unqualified-search-registries = [\"example.com\"]\r\u001b[23d#\u001b[24d\b# [[registry]]\r\u001b[25d# # The \"prefix\" field is used to choose the relevant [[registry]] TOML table;\r\u001b[26d# # (only) the TOML table with the longest match for the input image name\r\u001b[27d# # (taking into account namespace/repo/tag/digest separators) is used.\r\u001b[28d# #\r\u001b[29d# # The prefix can also be of the form: *.example.com for wildcard subdomain\r\u001b[30d# # matching.\r\u001b[31d# #\r\u001b[32d# # If the prefix field is missing, it defaults to be the same as the \"location\" field.\r\u001b[33d# prefix = \"example.com/foo\"\r\u001b[34d#\u001b[35d\b# # If true, unencrypted HTTP as well as TLS connections with untrusted\r\u001b[36d# # certificates are allowed.\r\u001b[37d# insecure = false\r\u001b[38d#\u001b[39d\b# # If true, pulling images with matching names is forbidden.\r\u001b[40d# blocked = false\r\u001b[41d#\u001b[42d\b# # The physical location of the \"prefix\"-rooted namespace.\r\u001b[43d# #\r\u001b[44d# # By default, this is equal to \"prefix\" (in which case \"prefix\" can be omitted\r\u001b[45d# # and the [[registry]] TOML table can only specify \"location\").\r\u001b[46d# #\r\u001b[47d# # Example: Given\r\u001b[48d# #   prefix = \"example.com/foo\"\r\u001b[49d# #   location = \"internal-registry-for-example.com/bar\"\r\u001b[50d# # requests for the image example.com/foo/myimage:latest will actually work with the\r\u001b[51d# # internal-registry-for-example.com/bar/myimage:latest image.\r\u001b[52d#\u001b[53d\b# # The location can be empty if prefix is in a\r\u001b[54d# # wildcarded format: \"*.example.com\". In this case, the input reference will\r\u001b[55d# # be used as-is without any rewrite.\r\u001b[56d# location = internal-registry-for-example.com/bar\"\r\u001b[2d\u001b[?12l\u001b[?25h"]
