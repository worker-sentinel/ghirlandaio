[0.003, "o", "\u001b[?25l\u001b[41;125H      \u001b[1;7H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mMultiple BSSID support ####\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[2;2H\u001b[50X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Above configuration is using the default interface (wlan#, or multi-SSID VLAN\u001b[4;3Hinterfaces). Other BSSIDs can be added by using separator 'bss' with\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m \u001b[5;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mdefault interface name to be allocated for the data packets of the new BSS.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[6;2H\u001b[76X\u001b[7;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mhostapd will generate BSSID mask based on the BSSIDs that are\r\n# configured. hostapd will verify that dev_addr & MASK == dev_addr. If this is\r\n# not the case, the MAC address of the radio must be changed before starting\u001b[10;3Hhostapd (ifconfig wlan0 hw ether <MAC addr>). If a BSSID is configured for\u001b[11;3Hevery secondary BSS, this limitation is not applied at hostapd and other\u001b[12;3Hmasks may be used if the driver supports them (e.g., swap the locally\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[5X\u001b[13;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27madministered bit)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[57X\u001b[14;2H\u001b[74X\u001b[15;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mBSSIDs are assigned in order to each BSS, unless an explicit BSSID is\u001b[16;2H specified using the 'bssid' parameter.\u001b[17;3HIf an explicit BSSID is specified, it must be chosen such that it:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[7X\u001b[18;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m- results in a valid MASK that covers it and the dev_addr\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\u001b[19;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m- is not the same as the MAC address of the radio\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\u001b[20;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m- is not the same as any other explicitly specified BSSID\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[21;2H\u001b[10X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Alternatively, the 'use_driver_iface_addr' parameter can be used to request\u001b[23;3Hhostapd to use the driver auto-generated interface address (e.g., to use the\u001b[24;3Hexact MAC addresses allocated to the device).\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[21X\u001b[25;2H\u001b[76X\u001b[26;3H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mNot all drivers support multiple BSSes. The exact mechanism for determining\u001b[27;3Hthe driver capabilities is driver specific. With the current (i.e., a recent\r\n# kernel) drivers using nl80211, this information can be checked with \"iw list\"\u001b[29;3H(search for \"valid interface combinations\").\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[20X\u001b[30;2H\u001b[23X\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Please note that hostapd uses some of the values configured for the first BSS\u001b[32;3Has the defaults for the following BSSes. However, it is recommended that all\u001b[33;2H BSSes include explicit configuration of all relevant configuration items.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[34;2H\u001b[68X\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mbss=wlan0_0\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m  \u001b[36;2H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27mssid=test2\u001b[37;3Hmost of the above items can be used here (apart from radio interface specific\u001b[38;3Hitems, like channel)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[25X\u001b[40;118H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3301,1         98%\r\u001b[20A\u001b[?25h"]
[5.500, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#bss=wlan0_1\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#bssid=00:13:10:95:fe:0b\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# ...\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\u001b[22A\u001b[?25h"]
[0.021, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Multiple BSSID Advertisement in IEEE 802.11ax\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# IEEE Std 802.11ax-2021 added a feature where instead of multiple interfaces\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\u001b[25A\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# on a common radio transmitting individual Beacon frames, those interfaces can\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# form a set with a common Beacon frame transmitted for all. The interface\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# which is brought up first is called the transmitting profile of the MBSSID\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\u001b[28A\u001b[?25h"]
[0.023, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# set which transmits the Beacon frames. The remaining interfaces are called\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# the non-transmitting profiles and these are advertised inside the Multiple\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# BSSID element in the Beacon and Probe Response frames from the first\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[1;39r\u001b[H\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# interface.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The transmitting interface is visible to all stations in the vicinity, however\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\u001b[34A\u001b[?25h"]
[0.019, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# the stations that do not support parsing of the Multiple BSSID element will\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# not be able to connect to the non-transmitting interfaces.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\u001b[37A\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Enhanced Multiple BSSID Advertisements (EMA)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# When enabled, the non-transmitting interfaces are split into multiple\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Beacon frames. The number of Beacon frames required to cover all the\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;121H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# non-transmitting profiles is called the profile periodicity.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Refer to IEEE Std 802.11-2020 for details regarding the procedure and\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;121H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m6\u001b[H\u001b[?25h"]
[0.044, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# required MAC address assignment.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Following configuration is per radio.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;121H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# 0 = Disabled (default)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# 1 = Multiple BSSID advertisement enabled.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# 2 = Enhanced multiple BSSID advertisement enabled.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;120H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m12,1         99\u001b[H\u001b[?25h"]
[0.043, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#mbssid=0\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The transmitting interface should be added with the 'interface' option while\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;121H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m5\u001b[H\u001b[?25h"]
[0.063, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# the non-transmitting interfaces should be added using the 'bss' option.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Security configuration should be added separately per interface, if required.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;121H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m8\u001b[H\u001b[?25h"]
[0.207, "o", "\u001b[?25l\u001b[1;39r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[37;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Example:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#mbssid=2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#interface=wlan2\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[40;120H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m21\u001b[H\u001b[?25h"]
