[0.037, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.002, "o", "\u001b[?25l\u001b[?2031h\u001b[>4;2m\u001b(B\u001b[m##### hostapd configuration file ##############################################\u001b[K\r\n# Empty lines and lines starting with # are ignored\u001b[K\r\n\u001b[K\n# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\u001b[K\r\n# management frames with the Host AP driver); wlan0 with many nl80211 drivers\u001b[K\r\n# Note: This attribute can be overridden by the values supplied with the '-i'\u001b[K\r\n# command line parameter.\u001b[K\r\ninterface=wlan0\u001b[K\r\n\u001b[K\n# In case of atheros and nl80211 driver interfaces, an additional\u001b[K\r\n# configuration parameter, bridge, may be used to notify hostapd if the\u001b[K\r\n# interface is included in a bridge. This parameter is not used with Host AP\u001b[K\r\n# driver. If the bridge parameter is not set, the drivers will automatically\u001b[K\r\n# figure out the bridge interface (assuming sysfs is enabled and mounted to\u001b[K\r\n# /sys) and this parameter may not be needed.\u001b[K\r\n#\u001b[K\r\n# For nl80211, this parameter can be used to request the AP interface to be\u001b[K\r\n# added to the bridge automatically (brctl may refuse to do this before hostapd\u001b[K\r\n# has been started to change the interface mode). If needed, the bridge\u001b[K\r\n# interface is also created.\u001b[K\r\n#bridge=br0\u001b[K\r\n\u001b[K\n# Driver interface type (hostap/wired/none/nl80211/bsd);\u001b[K\r\n# default: hostap). nl80211 is used with all Linux mac80211 drivers.\u001b[K\r\n# Use driver=none if building hostapd as a standalone RADIUS server that does\u001b[K\r\n# not control any wireless/wired driver.\u001b[K\r\n# driver=hostap\u001b[K\r\n\u001b[K\n# Driver interface parameters (mainly for development testing use)\u001b[K\r\n# driver_params=<params>\u001b[K\r\n\u001b[K\n# hostapd event logger configuration\u001b[K\r\n#\u001b[K\r\n# Two output method: syslog and stdout (only usable if not forking to\u001b[K\r\n# background).\u001b[K\r\n#\u001b[K\r\n# Module bitfield (ORed bitfield of modules that will be logged; -1 = all\u001b[K\r\n# modules):\u001b[K\r\n# bit 0 (1) = IEEE 802.11\u001b[K\r\n\u001b(B\u001b[0;7m/etc/hostapd/hostapd.conf                                                                                            1,1            Top\u001b(B\u001b[m\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H##### hostapd configuration file ##############################################\u001b[K\r\n# Empty lines and lines starting with # are ignored\u001b[K\r\n\u001b[K\n# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\u001b[K\r\n# management frames with the Host AP driver); wlan0 with many nl80211 drivers\u001b[K\r\n# Note: This attribute can be overridden by the values supplied with the '-i'\u001b[K\r\n# command line parameter.\u001b[K\r\ninterface=wlan0\u001b[K\r\n\u001b[K\n# In case of atheros and nl80211 driver interfaces, an additional\u001b[K\r\n# configuration parameter, bridge, may be used to notify hostapd if the\u001b[K\r\n# interface is included in a bridge. This parameter is not used with Host AP\u001b[K\r\n# driver. If the bridge parameter is not set, the drivers will automatically\u001b[K\r\n# figure out the bridge interface (assuming sysfs is enabled and mounted to\u001b[K\r\n# /sys) and this parameter may not be needed.\u001b[K\r\n#\u001b[K\r\n# For nl80211, this parameter can be used to request the AP interface to be\u001b[K\r\n# added to the bridge automatically (brctl may refuse to do this before hostapd\u001b[K\r\n# has been started to change the interface mode). If needed, the bridge\u001b[K\r\n# interface is also created.\u001b[K\r\n#bridge=br0\u001b[K\r\n\u001b[K\n# Driver interface type (hostap/wired/none/nl80211/bsd);\u001b[K\r\n# default: hostap). nl80211 is used with all Linux mac80211 drivers.\u001b[K\r\n# Use driver=none if building hostapd as a standalone RADIUS server that does\u001b[K\r\n# not control any wireless/wired driver.\u001b[K\r\n# driver=hostap\u001b[K\r\n\u001b[K\n# Driver interface parameters (mainly for development testing use)\u001b[K\r\n# driver_params=<params>\u001b[K\r\n\u001b[K\n# hostapd event logger configuration\u001b[K\r\n#\u001b[K\r\n# Two output method: syslog and stdout (only usable if not forking to\u001b[K\r\n# background).\u001b[K\r\n#\u001b[K\r\n# Module bitfield (ORed bitfield of modules that will be logged; -1 = all\u001b[K\r\n# modules):\u001b[K\r\n# bit 0 (1) = IEEE 802.11\u001b[K\r\n\u001b(B\u001b[0;7m/etc/hostapd/hostapd.conf                                                                                            1,1            Top\u001b(B\u001b[m\r\n\u001b[J\u001b[H\u001b[?25h"]
[0.026, "o", "\u001bP+q4D73\u001b\\"]
[0.001, "o", "\u001b[?25l\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m##### hostapd configuration file ##############################################\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Empty lines and lines starting with # are ignored\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# AP netdevice name (without 'ap' postfix, i.e., wlan0 uses wlan0ap for\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# management frames with the Host AP driver); wlan0 with many nl80211 drivers\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Note: This attribute can be overridden by the values supplied with the '-i'\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# command line parameter.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\ninterface=wlan0\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# In case of atheros and nl80211 driver interfaces, an additional\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# configuration parameter, bridge, may be used to notify hostapd if the\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# interface is included in a bridge. This parameter is not used with Host AP\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# driver. If the bridge parameter is not set, the drivers will automatically\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# figure out the bridge interface (assuming sysfs is enabled and mounted to\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# /sys) and this parameter may not be needed.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# For nl80211, this parameter can be used to request the AP interface to be\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# added to the bridge automatically (brctl may refuse to do this before hostapd\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# has been started to change the interface mode). If needed, the bridge\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# interface is also created.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#bridge=br0\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Driver interface type (hostap/wired/none/nl80211/bsd);\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# default: hostap). nl80211 is used with all Linux mac80211 drivers.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Use driver=none if building hostapd as a standalone RADIUS server that does\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# not control any wireless/wired driver.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# driver=hostap\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Driver interface parameters (mainly for development testing use)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# driver_params=<params>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# hostapd event logger configuration\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Two output method: syslog and stdout (only usable if not forking to\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# background).\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;"]
[0.000, "o", "155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Module bitfield (ORed bitfield of modules that will be logged; -1 = all\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# modules):\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# bit 0 (1) = IEEE 802.11\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m/etc/hostapd/hostapd.conf                                                                                            1,1            Top\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[J\u001b[H\u001b[?25h"]
