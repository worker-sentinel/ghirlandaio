[0.007, "o", "\u001b[23;63H\u001b[30m\u001b[103mi\u001b[48;9H\u001b[?25h"]
[0.283, "o", "\u001b[?25l\u001b[m\u000fo"]
[0.005, "o", "\u001b[23;64H\u001b[30m\u001b[103mo\u001b[48;10H\u001b[?25h"]
[0.287, "o", "\u001b[?25l\u001b[m\u000fn"]
[0.007, "o", "\u001b[23;65H\u001b[30m\u001b[103mn\u001b[48;11H\u001b[?25h"]
