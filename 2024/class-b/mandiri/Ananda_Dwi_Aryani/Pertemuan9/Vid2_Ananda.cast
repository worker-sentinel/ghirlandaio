[0.007, "o", "\u001b[1;14H\u001b[30m\u001b[103me\u001b[m\u000f ar\u001b[30m\u001b[103me\u001b[m\u000f atomic, you may incr\u001b[30m\u001b[103me\u001b[m\u000fas\u001b[30m\u001b[103me\u001b[m\u000f p\u001b[30m\u001b[103me\u001b[m\u000frformanc\u001b[30m\u001b[103me\u001b[m\u000f by s\u001b[30m\u001b[103me\u001b[2;8He\u001b[m\u000f.fil\u001b[30m\u001b[103me\u001b[m\u000f_updat\u001b[30m\u001b[103me\u001b[m\u000f_prot\u001b[30m\u001b[103me\u001b[4;10He\u001b[m\u000f path us\u001b[30m\u001b[103me\u001b[m\u000fd to stor\u001b[30m\u001b[103me\u001b[m\u000f shar\u001b[30m\u001b[103me\u001b[m\u000fd lockfil\u001b[30m\u001b[103me\u001b[5;8He\u001b[m\u000f.lockfil\u001b[30m\u001b[103me\u001b[8;6He\u001b[m\u000ffault valu\u001b[30m\u001b[103me\u001b[m\u000f for th\u001b[30m\u001b[103me\u001b[m\u000f CURLOPT_CAINFO option. This is r\u001b[30m\u001b[103me\u001b[m\u000fquir\u001b[30m\u001b[103me\u001b[m\u000fd to b\u001b[30m\u001b[103me\u001b[9;10He\u001b[12;4He\ne\u001b[m\u000f location of a C\u001b[30m\u001b[103me\u001b[m\u000frtificat\u001b[30m\u001b[103me\u001b[m\u000f Authority (CA) fil\u001b[30m\u001b[103me\u001b[m\u000f on th\u001b[30m\u001b[103me\u001b[m\u000f local fil\u001b[30m\u001b[103me\u001b[m\u000fsyst\u001b[30m\u001b[103me\u001b[14;8He\u001b[m\u000f wh\u001b[30m\u001b[103me\u001b[m\u000fn v\u001b[30m\u001b[103me\u001b[m\u000frifying th\u001b[30m\u001b[103me\u001b[m\u000f id\u001b[30m\u001b[103me\u001b[m\u000fntity of SSL/TLS p\u001b[30m\u001b[103mee\u001b[m\u000frs. Most us\u001b[30m\u001b[103me\u001b[15;9He\u001b[m\u000fcify a valu\u001b[30m\u001b[103me\u001b[m\u000f for this dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f as PHP will att\u001b[30m\u001b[103me\u001b[m\u000fmpt to us\u001b[30m\u001b[103me\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[16;11He\u001b[m\u000fd c\u001b[30m\u001b[103me\u001b[m\u000frt stor\u001b[30m\u001b[103me\u001b[m\u000fs in its abs\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[m\u000f. If sp\u001b[30m\u001b[103me\u001b[m\u000fcifi\u001b[30m\u001b[103me\u001b[m\u000fd, this valu\u001b[30m\u001b[103me\u001b[17;4He\u001b[m\u000f ov\u001b[30m\u001b[103me\u001b[m\u000frridd\u001b[30m\u001b[103me\u001b[m\u000fn on a p\u001b[30m\u001b[103me\u001b[m\u000fr-str\u001b[30m\u001b[103me\u001b[m\u000fam basis via th\u001b[30m\u001b[103me\u001b[m\u000f \"cafil\u001b[30m\u001b[103me\u001b[m\u000f\" SSL str\u001b[30m\u001b[103me\u001b[m\u000fam cont\u001b[30m\u001b[103me\u001b[19;4He\u001b[m\u000fnssl.cafil\u001b[30m\u001b[103me\u001b[21;8He\u001b[m\u000fnssl.cafil\u001b[30m\u001b[103me\u001b[m\u000f is not sp\u001b[30m\u001b[103me\u001b[m\u000fcifi\u001b[30m\u001b[103me\u001b[m\u000fd or if th\u001b[30m\u001b[103me\u001b[m\u000f CA fil\u001b[30m\u001b[103me\u001b[m\u000f is not found, th\u001b[30m\u001b[103me\u001b[22;6He\u001b[m\u000fctory point\u001b[30m\u001b[103me\u001b[m\u000fd to by op\u001b[30m\u001b[103me\u001b[m\u000fnssl.capath is s\u001b[30m\u001b[103me\u001b[m\u000farch\u001b[30m\u001b[103me\u001b[m\u000fd for a suitabl\u001b[30m\u001b[103me\u001b[23;4He\u001b[m\u000frtificat\u001b[30m\u001b[103me\u001b[m\u000f. This valu\u001b[30m\u001b[103me\u001b[m\u000f must b\u001b[30m\u001b[103me\u001b[m\u000f a corr\u001b[30m\u001b[103me\u001b[m\u000fctly hash\u001b[30m\u001b[103me\u001b[m\u000fd c\u001b[30m\u001b[103me\u001b[m\u000frtificat\u001b[30m\u001b[103me\u001b[m\u000f dir\u001b[30m\u001b[103me\u001b[24;10He\u001b[m\u000frs should not sp\u001b[30m\u001b[103me\u001b[m\u000fcify a valu\u001b[30m\u001b[103me\u001b[m\u000f for this dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[25;6He\u001b[m\u000fmpt to us\u001b[30m\u001b[103me\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[m\u000f OS-manag\u001b[30m\u001b[103me\u001b[m\u000fd c\u001b[30m\u001b[103me\u001b[m\u000frt stor\u001b[30m\u001b[103me\u001b[m\u000fs in its abs\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[m\u000f. If sp\u001b[30m\u001b[103me\u001b[m\u000fcifi\u001b[30m\u001b[103me\u001b[26;12He\u001b[m\u000f may still b\u001b[30m\u001b[103me\u001b[m\u000f ov\u001b[30m\u001b[103me\u001b[m\u000frridd\u001b[30m\u001b[103me\u001b[m\u000fn on a p\u001b[30m\u001b[103me\u001b[m\u000fr-str\u001b[30m\u001b[103me\u001b[m\u000fam basis via th\u001b[30m\u001b[103me\u001b[27;10He\u001b[m\u000fam cont\u001b[30m\u001b[103me\u001b[28;4He\n\ne\u001b[m\u000f libctx is an Op\u001b[30m\u001b[103me\u001b[m\u000fnSSL library cont\u001b[30m\u001b[103me\u001b[m\u000fxt. Op\u001b[30m\u001b[103me\u001b[m\u000fnSSL d\u001b[30m\u001b[103me\u001b[m\u000ffin\u001b[30m\u001b[103me\u001b[m\u000fs a d\u001b[30m\u001b[103me\u001b[31;7He\u001b[m\u000fxt, but PHP Op\u001b[30m\u001b[103me\u001b[m\u000fnSSL also d\u001b[30m\u001b[103me\u001b[m\u000ffin\u001b[30m\u001b[103me\u001b[m\u000fs its own library cont\u001b[30m\u001b[103me\u001b[32;6He\u001b[m\u000frf\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[m\u000f with oth\u001b[30m\u001b[103me\u001b[m\u000fr librari\u001b[30m\u001b[103me\u001b[m\u000fs using Op\u001b[30m\u001b[103me\u001b[m\u000fnSSL and to provid\u001b[30m\u001b[103me\u001b[m\u000f an ind\u001b[30m\u001b[103me\u001b[m\u000fp\u001b[30m\u001b[103me\u001b[m\u000fnd\u001b[30m\u001b[103me\u001b[33;7He\u001b[m\u000fxt for \u001b[30m\u001b[103me\u001b[m\u000fach thr\u001b[30m\u001b[103me\u001b[m\u000fad in ZTS. Possibl\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[34;18He\u001b[m\u000f a custom library cont\u001b[30m\u001b[103me\u001b[m\u000fxt (d\u001b[30m\u001b[103me\u001b[35;6He\u001b[m\u000ffault\" - us\u001b[30m\u001b[103me\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[m\u000f d\u001b[30m\u001b[103me\u001b[m\u000ffault Op\u001b[30m\u001b[103me\u001b[m\u000fnSSL library cont\u001b[30m\u001b[103me\u001b[36;4He\u001b[39;12He\u001b[m\u000fstriction. Possibl\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[40;6He\u001b[m\u000fload\" - \u001b[30m\u001b[103me\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[m\u000fd in CLI scripts and pr\u001b[30m\u001b[103me\u001b[m\u000fload\u001b[30m\u001b[103me\u001b[m\u000fd fil\u001b[30m\u001b[103me\u001b[m\u000fs (d\u001b[30m\u001b[103me\u001b[41;8He\u001b[m\u000f\"   - always disabl\u001b[30m\u001b[103me\u001b[42;7He\u001b[m\u000f\"    - always \u001b[30m\u001b[103me\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[43;6He\u001b[m\u000fnabl\u001b[30m\u001b[103me\u001b[m\u000f=pr\u001b[30m\u001b[103me\u001b[45;12He\u001b[m\u000fad\u001b[30m\u001b[103me\u001b[m\u000frs fil\u001b[30m\u001b[103me\u001b[m\u000fs to pr\u001b[30m\u001b[103me\u001b[m\u000fload, wildcard patt\u001b[30m\u001b[103me\u001b[m\u000frns allow\u001b[30m\u001b[103me\u001b[46;8He\u001b[47;158H\u001b[0;10;7m\u000f8\u001b[48;3H\u001b[?25h"]
[0.524, "o", "\u001b[?25l\u001b[m\u000fx"]
[0.008, "o", "\u001b[H\u001b[96m[PHP]\u001b[m\u000f\u001b[72X\r\n\u001b[33X\n;;;;;;;;;;;;;;;;;;;\u001b[4;5Hout php.ini   ;\u001b[44X\u001b[5;2H;;;;;;;;;;;;;;;;;;\u001b[8X\r\n; PHP's initialization file, generally called php.ini, is responsible for\r\n; configuring many of the aspects of PHP's behavior.\r\n\u001b[74X\u001b[9;3HPHP attempts to find and load this configuration from a number of locations.\u001b[10;2H The following is a summary of its search order:\r\n; 1. SAPI module specific location.\r\n; 2. The PHPRC environment variable.\u001b[13;3H3. A number of predefined registry keys on Windows\u001b[23X\u001b[14;3H4. Current working directory (\u001b[30m\u001b[103mex\u001b[m\u000fcept CLI)\u001b[29X\u001b[15;3H5. The web server's directory (for SAPI modules), or directory of PHP\u001b[16;3H(otherwise in Windows)\u001b[51X\u001b[17;3H6. The directory from the --with-config-file-path compile time option, or the\u001b[18;3HWindows directory (usually C:\\windows)\u001b[19;2H See the PHP docs for more specific information.\r\n; https://php.net/configuration.file\r\n\u001b[72X\u001b[22;3HThe syntax of the file is \u001b[30m\u001b[103mex\u001b[m\u000ftremely simple.  Whitespace and lines\u001b[23;3Hbeginning with a semicolon are silently ignored (as you probably guessed).\u001b[24;3HSection headers (e.g. [Foo]) are also silently ignored, even though \u001b[25;3Hthey might mean something in the future.\u001b[31X\r\n\u001b[75X\u001b[27;3HDirectives following the section heading [PATH=/www/mysite] only\u001b[28;2H apply to PHP files in the /www/mysite directory.  Directives\r\n; following the section heading [HOST=www.\u001b[30m\u001b[103mex\u001b[m\u000fample.com] only apply to\u001b[30;3HPHP files served from www.\u001b[30m\u001b[103mex\u001b[m\u000fample.com.  Directives set in these\u001b[12X\u001b[31;3Hspecial sections cannot be overridden by user-defined INI files or    \u001b[32;3Hat runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[10X\u001b[33;3HCGI/FastCGI.\u001b[36X\u001b[34;3Hhttps://php.net/ini.sections\u001b[23X\r\n\u001b[54X\u001b[36;2H Directives are specified using the following syntax:\r\n; directive = value\r\n; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[39;3HDirectives are variables used to configure PHP or PHP \u001b[30m\u001b[103mex\u001b[m\u000ftensions.\u001b[40;3HThere is no name validation.  If PHP can't find an \u001b[30m\u001b[103mex\u001b[m\u000fpected\u001b[5X\u001b[41;3Hdirective because it is not set or is mistyped, a default value will be used.\r\n\u001b[28X\u001b[43;2H The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\r\n; of the INI constants (On, Off, True, False, Yes, No and None) or an \u001b[30m\u001b[103mex\u001b[m\u000fpression\u001b[45;3H(e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[46;2H previously set variable or directive (e.g. ${foo})\u001b[47;154H\u001b[0;10;7m\u000f4,33          Top\u001b[48;4H\u001b[?25h"]
[0.239, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.005, "o", "\u001b[14;33Hex\u001b[22;29H\u001b[30m\u001b[103mext\u001b[29;43H\u001b[m\u000fex\u001b[30;29Hex\u001b[39;59H\u001b[30m\u001b[103mt\u001b[40;54H\u001b[m\u000fex\u001b[44;71Hex\u001b[47;153H\u001b[0;10;7m\u000f22,29\u001b[48;5H\u001b[?25h"]
[0.514, "o", "\u001b[?25l\u001b[m\u000fe"]
[0.006, "o", "\u001b[1;46r\u001b[H\u001b[16M\u001b[1;48r\u001b[6;29Hext\u001b[23;57H\u001b[30m\u001b[103mexte\u001b[m\u000f\r\u001b[8B\u001b[K\n; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[K\r\n; |  bitwise OR\u001b[K\r\n; ^  bitwise XOR\u001b[K\r\n; &  bitwise AND\u001b[K\r\n; ~  bitwise NOT\u001b[K\r\n; !  boolean NOT\u001b[K\r\n\u001b[K\n; Boolean flags can be turned on using the values 1, On, True or Yes.\u001b[K\r\n; They can be turned off using the values 0, Off, False or No.\u001b[K\r\n\u001b[K\n; An empty string can be denoted by simply not writing anything after the equal\u001b[K\r\n; sign, or by using the None keyword:\u001b[K\r\n\u001b[K\n; foo =         ; sets foo to an empty string\u001b[K\r\n; foo = None    ; sets foo to an empty string\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f39,57           0%\u001b[48;6H\u001b[?25h"]
[0.166, "o", "\u001b[?25l\u001b[m\u000fn"]
[0.006, "o", "\u001b[23;61H\u001b[30m\u001b[103mn\u001b[48;7H\u001b[?25h"]
[0.329, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.010, "o", "\u001b[1;3Hon your site are atomic, you may increase performance by setting it to \"0\".  \u001b[2;2Hopcache.file_update_protection=2\u001b[7X\r\n\u001b[49X\u001b[4;3HAbsolute path used to store shared lockfiles (for *nix only).\r\n;opcache.lockfile_path=/tmp\r\n\u001b[67X\n\u001b[96m[curl]\u001b[m\u000f\u001b[70X\u001b[8;3HA default value for the CURLOPT_CAINFO option. This is required to be an\u001b[9;3Habsolute path.\u001b[26X\r\n;curl.cainfo =\r\n\u001b[66X\n\u001b[96m[openssl]\u001b[m\u000f\u001b[53X\u001b[13;3HThe location of a Certificate Authority (CA) file on the local filesystem\u001b[14;3Hto use when verifying the identity of SSL/TLS peers. Most users should\u001b[15;3Hnot specify a value for this directive as PHP will attempt to use the\u001b[16;3HOS-managed cert stores in its absence. If specified, this value may still\u001b[17;3Hbe overridden on a per-stream basis via the \"cafile\" SSL stream context\u001b[18;3Hoption.\u001b[21X\r\n;openssl.cafile=\r\n\u001b[54X\u001b[21;3HIf openssl.cafile is not specified or if the CA file is not found, the\u001b[22;3Hdirectory pointed to by openssl.capath is searched for a suitable\u001b[8X\u001b[23;3Hcertificate. This value must be a correctly hashed certificate directory.\u001b[24;3HMost users should not specify a value for this directive as PHP will\u001b[25;3Hattempt to use the OS-managed cert stores in its absence. If specified,\u001b[6X\r\n; this value may still be overridden on a per-stream basis via the \"capath\"\u001b[27;3HSSL stream context option.\u001b[51X\u001b[28;2Hopenssl.capath=\u001b[64X\r\n\u001b[72X\u001b[30;3HThe libctx is an OpenSSL library context. OpenSSL defines a default library\r\n; context, but PHP OpenSSL also defines its own library context to avoid\u001b[32;3Hinterference with other libraries using OpenSSL and to provide an independent\u001b[33;3Hcontext for each thread in ZTS. Possible values:\u001b[34;3H \"custom\"  - use a custom library context (default)\u001b[35;3H \"default\" - use the default OpenSSL library context\u001b[36;2Hopenssl.libctx=custom\r\n\u001b[16X\n\u001b[96m[ffi]\u001b[39;3H\u001b[m\u000fFFI API restriction. Possible values:\u001b[30X\u001b[40;3H\"preload\" - enabled in CLI scripts and preloaded files (default)\r\n; \"false\"   - always disabled\u001b[42;3H\"true\"    - always enabled\u001b[51X\u001b[43;2Hffi.enable=preload\u001b[18X\u001b[45;3HList of headers files to preload, wildcard patterns allowed.\u001b[46;2Hffi.preload=\u001b[32X\u001b[47;153H\u001b[0;10;7m\u000f1875,1         Bot\u001b[48;8H\u001b[?25h"]
[1.494, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.007, "o", "\u001b[1;3H6. The directory from the --with-config-file-path compile time option, or the\u001b[2;2H Windows directory (usually C:\\windows)\r\n; See the PHP docs for more specific information.\u001b[4;3Hhttps://php.net/configuration.file\u001b[27X\r\n\u001b[27X\n; The syntax of the file is extremely simple.  Whitespace and lines\r\n; beginning with a semicolon are silently ignored (as you probably guessed).\u001b[8;3HSection headers (e.g. [Foo]) are also silently ignored, even though\u001b[5X\u001b[9;3Hthey might mean something in the future.\r\n\u001b[14X\n; Directives following the section heading [PATH=/www/mysite] only\r\n; apply to PHP files in the /www/mysite directory.  Directives\u001b[13;3Hfollowing the section heading [HOST=www.example.com] only apply to\u001b[7X\u001b[14;3HPHP files served from www.example.com.  Directives set in these\u001b[7X\u001b[15;3Hspecial sections cannot be overridden by user-defined INI files or   \u001b[16;3Hat runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[6X\u001b[17;3HCGI/FastCGI.\u001b[59X\u001b[18;3Hhttps://php.net/ini.sections\r\n\u001b[16X\n; Directives are specified using the following syntax:\u001b[21;3Hdirective = value\u001b[53X\u001b[22;3HDirective names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[23;3HDirectives are variables used to configure PHP or PHP \u001b[30m\u001b[103mexten\u001b[m\u000fsions.\u001b[8X\u001b[24;3HThere is no name validation.  If PHP can't find an expected\u001b[9X\u001b[25;3Hdirective because it is not set or is mistyped, a default value will be used.\r\n\u001b[75X\u001b[27;3HThe value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[28;2H of the INI constants (On, Off, True, False, Yes, No and None) or an expression\r\n; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[30;3Hpreviously set variable or directive (e.g. ${foo})\u001b[25X\r\n\u001b[72X\u001b[32;3HExpressions in the INI file are limited to bitwise operators and parentheses:\u001b[33;3H|  bitwise OR\u001b[35X\u001b[34;3H^  bitwise XOR\u001b[37X\u001b[35;3H&  bitwise AND\u001b[38X\u001b[36;2H ~  bitwise NOT\u001b[6X\r\n; !  boolean NOT\r\n\u001b[5X\u001b[39;3HBoolean flags can be turned on using the values 1, On, True or Yes.\u001b[40;3HThey can be turned off using the values 0, Off, False or No.    \r\n\u001b[29X\u001b[42;3HAn empty string can be denoted by simply not writing anything after the equal\u001b[43;2H sign, or by using the None keyword:\u001b[45;3Hfoo =         ; sets foo to an empty string\u001b[17X\u001b[46;2H foo = None    ; sets foo to an empty string\u001b[47;153H\u001b[0;10;7m\u000f39,57           0%\u001b[48;7H\u001b[?25h"]
