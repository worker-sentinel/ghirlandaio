[0.003, "o", "\r\u001b[K                               Available networks\u001b[1;90m                              \u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m      Network name                      Security            Signal\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K  \u001b[1;90m> \u001b[0m  nandaa                            psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      rogerlab                          psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      intern                            psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      01                                psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      syew                              psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      samsungA56                        psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Aisha                             psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      115 muhamad                       psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u0001\u001b[32m\u0002[iwd]\u0001\u001b[0m\u0002# station wlan0 connect nandaa \r\nType the network passphrase for nandaa psk.\r\n\u001b[94mPassphrase: \u001b[0m**********\r\n\u001b[0;91mOperation failed\r\n\u001b[0m\u0001\u001b[32m\u0002[iwd]\u0001\u001b[0m\u0002# station wlan0 connect nandaa \r\nType the network passphrase for nandaa psk.\r\n\u001b[94mPassphrase: \u001b[0m**********\r\n\u001b[0;91mOperation failed\r\