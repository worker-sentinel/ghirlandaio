[0.004, "o", "Copied \"/usr/lib/systemd/boot/efi/systemd-bootx64.efi\" to \"/boot/EFI/BOOT/BOOTX64.EFI\".\r\r\n"]
[0.000, "o", "\u001b[0;1;31m Mount point '/boot' which backs the random seed file is world accessible, which is a security hole! \u001b[0m\r\r\n\u001b[0;1;31mRandom seed file '/boot/loader/random-seed' is world accessible, which is a security hole!\u001b[0m\r\r\n"]
[0.003, "o", "Random seed file /boot/loader/random-seed successfully refreshed (32 bytes).\r\r\n\u001b[0;1;39mNot booted with EFI or running in a container, skipping EFI variable modifications.\u001b[0m\r\r\n"]
[0.001, "o", "\u001b[?2004h[root@blackbird /]# "]
[4.330, "o", "bootctl --path=/boot install"]
