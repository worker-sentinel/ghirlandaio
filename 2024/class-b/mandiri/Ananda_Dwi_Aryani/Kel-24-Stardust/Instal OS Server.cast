[0.001, "o", "\u001b[?25l\u001b[m\u000f# mkinitcpio preset file for the 'linux-lts' package\u001b[K\r\n\u001b[K\nALL_config=\u001b[92m\"/etc/mkinitcpio.d/default.conf\"\u001b[m\u000f\u001b[K\r\nALL_kver=\u001b[92m\"/boot/kernel/vmlinuz-linux-lts\"\u001b[m\u000f\u001b[K\r\nALL_kerneldest=\u001b[92m\"/boot/kernel/vmlinuz-linux-lts\"\u001b[m\u000f\u001b[K\r\n\u001b[K\nPRESETS=(\u001b[92m'default'\u001b[m\u000f)\u001b[K\r\n#PRESETS=('default' 'fallback')\u001b[K\r\n\u001b[K\n#default_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#default_image=\"/boot/initramfs-linux-lts.img\"\u001b[K\r\ndefault_uki=\u001b[92m\"/boot/efi/linux/arch-linux-lts.efi\"\u001b[m\u000f\u001b[K\r\n#default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\u001b[K\r\n\u001b[K\n#fallback_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#fallback_image=\"/boot/initramfs-linux-lts-fallback.img\"\u001b[K\r\n#fallback_uki=\"/efi/EFI/Linux/arch-linux-lts-fallback.efi\"\u001b[K\r\n#fallback_options=\"-S autodetect\"\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000fetc/mkinitcpio.d/linux-lts.preset                                                                                                                       1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# mkinitcpio preset file for the 'linux-lts' package\u001b[K\r\n\u001b[K\nALL_config=\u001b[92m\"/etc/mkinitcpio.d/default.conf\"\u001b[m\u000f\u001b[K\r\nALL_kver=\u001b[92m\"/boot/kernel/vmlinuz-linux-lts\"\u001b[m\u000f\u001b[K\r\nALL_kerneldest=\u001b[92m\"/boot/kernel/vmlinuz-linux-lts\"\u001b[m\u000f\u001b[K\r\n\u001b[K\nPRESETS=(\u001b[92m'default'\u001b[m\u000f)\u001b[K\r