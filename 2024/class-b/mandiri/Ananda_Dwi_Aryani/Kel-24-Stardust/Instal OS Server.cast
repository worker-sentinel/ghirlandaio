[0.729, "o", "\r\n\u001b[?2004l\r    1  echo stardust > etc/hostname\r\n    2  ln -fs /usr/share/zoneinfo/Asia/Jakarta /etc/localtime\r\n    3  hwclock --systohc\r\n    4  nvim /etc/locale.gen\r\n    5  locale-gen\r\n    6  locale > /etc/locale.conf\r\n    7  nvim /etc/locale.conf\r\n    8  useradd -m stardust\r\n    9  passwd stardust\r\n   10  echo \"stardust ALL=(ALL:ALL) ALL\" >> /etc/sudoers.d/stardust\r\n   11  mkdir /etc/cmdline.d\r\n   12  touch /etc/cmdline.d/{01-boot.conf,06-misc.conf}\r\n   13  echo \"rd.luks.name=$(blkid -s UUID -o value /dev/nvme0n1p7)=stardust root=/dev/system/root\" > /etc/cmdline.d/01-boot.conf\r\n   14  echo \"rw\" > /etc/cmdline.d/06-misc.conf\r\n   15  cd /boot\r\n   16  mkdir kernel efi\r\n   17  cd efi\r\n   18  mkdir linux\r\n   19  cd ..\r\n   20  mv vmlinuz-* intel-* kernel\r\n   21  ls\r\n   22  rm -fr initramfs-linux-lts.img\r\n   23  ls\r\n   24  ls efi/\r\n   25  ls kernel/\r\n   26  mv /etc/mkinitcpio.conf /etc/mkinitcpio.d/default.conf\r\n   27  nvim /etc/mkinitcpio.d/default.conf\r\n   28  nvim /etc/mkinitcpio.d/linux-lts-preset\r\n   29  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   30  bootctl --path=/boot install\r\n   31  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   32  bootctl --path=/boot install\r\n   33  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   34  bootctl --path=/boot install\r\n   35  exit\r\n   36  bootctl --path=/boot install\r\n   37  mkinitcpio -P\r\n   38  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   39  mkinitcpio -P\r\n   40* \r\n   41  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   42  bootctl --path=/boot install\r\n   43  bootctl --path=/boot install\r\n   44  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   45  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   46  mkinitcpio -P\r\n   47  ls\r\n   48  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   49  mkinitcpio -P\r\n   50  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   51  ls-l /etc/mkinitcpio.d/default.conf\r\n   52  ls -l /etc/mkinitcpio.d/default.conf\r\n   53  ls -d /lib/modules/*lts*\r\n   54  ls -la /boot/efi/linux/\r\n   55  nvim /etc/mkinitcpio.d/linux-lts.preset\r\n   56  history\r\n\u001b[?2004h[root@blackbird /]# "]
