[0.001, "o", "\r\u001b[2d; https://php.net/allow-url-include\r\u001b[3dallow_url_include = Off\r\u001b[4d\u001b[K\u001b[5d; Define the anonymous ftp password (your email address). PHP's default setting\r\u001b[6d; for this is empty.\u001b[7;3Hhttps://php.net/from\u001b[K\r\u001b[8d;from=\"john@doe.com\"\u001b[K\u001b[10;3HDefine the User-Agent string. PHP's default setting for this is empty.\u001b[K\u001b[11;3Hhttps://php.net/user-agent\u001b[K\r\u001b[12d;"]
[0.000, "o", "user_agent=\"PHP\"\u001b[K\r\u001b[13d\u001b[K\u001b[14d; Default timeout for socket based streams (seconds)\u001b[15;3Hhttps://php.net/default-socket-timeout\u001b[K\r\u001b[16ddefault_socket_timeout = 60\u001b[K\r\u001b[17d\u001b[K\u001b[18d; If your scripts have to deal with files from Macintosh systems,\u001b[K\u001b[19;3Hor you are running on a Mac and need to deal with files from\u001b[20;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[21;3Hautomatically detect the EOL character in those files so that\r\u001b[22d; fgets() and file() will work regardless of the source of the file.\u001b[23;3Hhttps://php.net/auto-detect-line-endings\u001b[K\r\u001b[24d;auto_detect_line_endings = Off\u001b[K\r\u001b[25d\u001b[K\u001b[26d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[27d; Dynamic Extensions ;\r\u001b[28d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[29d\u001b[K\u001b[30d; If you wish to have an extension loaded automatically, use the following\u001b[31;3Hsyntax:\u001b[K\u001b[32;3H\u001b[K\u001b[33d  \u001b[30m\u001b[43mextension=\u001b[39;49m\u001b[m\u000fmodulename\u001b[K\u001b[34;3H\u001b[K\u001b[35dFor example:\u001b[K\r\u001b[36d;\u001b[37d   extension=mysqli\u001b[K\u001b[38;3H\u001b[K\u001b[39dWhen the extension library to load is not located in the default extension\u001b[40;3Hdirectory, You may specify an absolute path to the library file:\u001b[K\u001b[41;3H\u001b[K\u001b[42d  extension=/path/to/extension/mysqli.so\u001b[K\r\u001b[43d;\u001b[44d "]
[0.001, "o", "Note : The syntax used in previous PHP versions ('extension=<ext>.so' and\u001b[K\u001b[45;3H'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[K\u001b[46;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[47;3Hmove to the new ('extension=<ext>) syntax.\u001b[K\r\u001b[48d;\u001b[49dextension=bcmath\u001b[K\r\u001b[50d;extension=bz2\u001b[K\r\u001b[51d;extension=calendar\r\u001b[52dextension=curl\u001b[K\r\u001b[53d;extension=dba\u001b[K\r\u001b[54d;extension=enchant\r\u001b[55d;extension=exif\r\u001b[56d;extension=ffi\u001b[K\r\u001b[57d;extension=ftp\u001b[K\r\u001b[58d;extension=gd\r\u001b[59d;extension=gettext\u001b[K\r\u001b[60d;extension=gmp\u001b[K\r\u001b[61d;extension=iconv\r\u001b[62d;extension=intl\u001b[K\r\u001b[63d;extension=ldap\u001b[K\r\u001b[64d;extension=mysqli\u001b[K\u001b[33;5H"]
