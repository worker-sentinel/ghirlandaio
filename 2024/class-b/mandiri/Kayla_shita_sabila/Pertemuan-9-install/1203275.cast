[0.000, "o", "\r\u001b[2d\u001b[K\u001b[3d# This is the sshd server system-wide configuration file.  See\u001b[4;3Hsshd_config(5) for more information.\u001b[K\r\u001b[5d\u001b[K\u001b[6d# This sshd was compiled with PATH=/usr/local/sbin:/usr/local/bin:/usr/bin\r\u001b[7d\u001b[K\u001b[8d# The strategy used for options in the default sshd_config shipped with\u001b[9;3HOpenSSH is to specify options with their default value where\r\u001b[10d#"]
[0.001, "o", " possible, but leave them commented.  Uncommented options override the\r\u001b[11d# default value.\u001b[K\r\u001b[12d\u001b[K\u001b[13d#Port 22\u001b[K\r\u001b[14d#AddressFamily any\r\u001b[15d#ListenAddress 0.0.0.0\r\u001b[16d#ListenAddress ::\u001b[K\r\u001b[17d\u001b[K\u001b[18d#HostKey /etc/ssh/ssh_host_rsa_key\r\u001b[19d#HostKey /etc/ssh/ssh_host_ecdsa_key\u001b[K\r\u001b[20d#HostKey /etc/ssh/ssh_host_ed25519_key\u001b[K\r\u001b[21d\u001b[K\u001b[22d# Ciphers and keying\u001b[K\r\u001b[23d#RekeyLimit default none\u001b[K\r\u001b[24d\u001b[K\u001b[25dProtocol 2\u001b[K\r\u001b[26d\u001b[K\u001b[27d# Logging\u001b[K\r\u001b[28d#SyslogFacility AUTH\r\u001b[29dLogLevel VERBOSE\r\u001b[30d\u001b[K\u001b[31d# Authentication:\u001b[K\r\u001b[32d\u001b[K\u001b[33d#\u001b[30m\u001b[43mLoginG\u001b[39;49m\u001b[m\u000fraceTime 2m\r\u001b[34dPermitRootLogin no\u001b[K\r\u001b[35d#StrictModes yes\u001b[K\r\u001b[36dMaxAuthTries 4\r\u001b[37dMaxSessions 10\r\u001b[38d\u001b[K\u001b[39d#PubkeyAuthentication yes\r\u001b[40d\u001b[K\u001b[41d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\r\u001b[42d# but this is overridden so installations will only check .ssh/authorized_keys\r\u001b[43dAuthorizedKeysFile      .ssh/authorized_keys\r\u001b[44d\u001b[K\u001b[45d#AuthorizedPrincipalsFile none\r\u001b[46d"]
[0.001, "o", "\u001b[K\u001b[47d#AuthorizedKeysCommand none\r\u001b[48d#AuthorizedKeysCommandUser nobody\r\u001b[49d\u001b[K\u001b[50d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\r\u001b[51dHostbasedAuthentication no\r\u001b[52d# Change to yes if you don't trust ~/.ssh/known_hosts for\r\u001b[53d# HostbasedAuthentication\r\u001b[54d#IgnoreUserKnownHosts no\u001b[K\r\u001b[55d# Don't read the user's ~/.rhosts and ~/.shosts files\r\u001b[56dIgnoreRhosts yes\r\u001b[57d\u001b[K\u001b[58d# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[59d#PasswordAuthentication yes\r\u001b[60dPermitEmptyPasswords no\u001b[K\r\u001b[61d\u001b[K\u001b[62d# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\r\u001b[63d# the system's configuration, this may involve passwords, challenge-response,\r\u001b[64d# one-time passwords or some combination of these and other methods.\r\u001b[33d#"]
