[0.001, "o", "\u001b[2;3HKerberos options\u001b[K\r\u001b[3d#KerberosAuthentication no\r\u001b[4d#KerberosOrLocalPasswd yes\u001b[K\r\u001b[5d#KerberosTicketCleanup yes\r\u001b[6d#KerberosGetAFSToken no\u001b[K\r\u001b[7d\u001b[K\u001b[8d# GSSAPI options\u001b[K\r\u001b[9d#GSSAPIAuthentication no\r\u001b[10d#GSSAPICleanupCredentials yes\r\u001b[11d\u001b[K\u001b[12d#"]
[0.000, "o", " Set this to 'yes' to enable PAM authentication, account processing,\r\u001b[13d# and session processing. If this is enabled, PAM authentication will\r\u001b[14d# be allowed through the KbdInteractiveAuthentication and\r\u001b[15d# PasswordAuthentication.  Depending on your PAM configuration,\r\u001b[16d# PAM authentication via KbdInteractiveAuthentication may bypass\r\u001b[17d# the setting of \"PermitRootLogin prohibit-password\".\r\u001b[18d# If you just want the PAM account and session checks to run without\r\u001b[19d# PAM authentication, then enable this but set PasswordAuthentication\u001b[20;3Hand KbdInteractiveAuthentication to 'no'.\r\u001b[21d#UsePAM no\u001b[K\r\u001b[23d#AllowAgentForwarding yes\r\u001b[24d#AllowTcpForwarding yes\r\u001b[25d#GatewayPorts no\r\u001b[26d#X11Forwarding no\u001b[K\r\u001b[27d#X11DisplayOffset 10\r\u001b[28d#X11UseLocalhost yes\r\u001b[29d#PermitTTY yes\u001b[K\r\u001b[30d#PrintMotd yes\r\u001b[31d#PrintLastLog yes\u001b[K\r\u001b[32d#TCPKeepAlive yes\u001b[K\r\u001b[33d#\u001b[30m\u001b[43mPermitUser\u001b[39;49m\u001b[m\u000fEnvironment no\r\u001b[34d#Compression delayed\r\u001b[35d#ClientAliveInterval 0\r\u001b[36d#ClientAliveCountMax 3\r\u001b[37d#UseDNS no\u001b[K\r\u001b[38d#PidFile /run/sshd.pid\r\u001b[39d#MaxStartups 10:30:100\u001b[K\r\u001b[40d#PermitTunnel no\u001b[K\r\u001b[41d#ChrootDirectory none\u001b[K\r\u001b[42d#VersionAddendum none\r\u001b[43d\u001b[K\u001b[44d"]
[0.000, "o", "# no default banner path\r\u001b[45d#Banner none\u001b[K\r\u001b[46d\u001b[K\u001b[47d# override default of no subsystems\r\u001b[48d"]
[0.001, "o", "Subsystem       sftp    /usr/lib/ssh/sftp-server\u001b[K\r\u001b[49d\u001b[K\u001b[50d# Example of overriding settings on a per-user basis\u001b[K\r\u001b[51d#Match User anoncvs\u001b[K\r\u001b[52d#       X11Forwarding\u001b[53;3H      AllowTcpForwarding no\u001b[K\r\u001b[54d#       PermitTTY no\r\u001b[55d#\u001b[9GForceCommand cvs server\r\u001b[56d\u001b[K\u001b[57d\u001b[K\u001b[58d\u001b[K\u001b[60d\u001b[K\u001b[61d\u001b[K\u001b[62d\u001b[K\u001b[63d\u001b[K\u001b[33d#"]
