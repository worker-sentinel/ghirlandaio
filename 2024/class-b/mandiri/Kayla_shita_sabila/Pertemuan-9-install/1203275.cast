[0.000, "o", "\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\r\u001b[2d#\u001b[K\u001b[3d\bDocumentRoot \"/srv/http\"\u001b[K\r\u001b[4d<Directory \"/srv/http\">\u001b[K\r\u001b[5d    #\u001b[K\r\u001b[6d    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[7d    # or any combination of:\u001b[K\r\u001b[8d    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\u001b[9d    #\u001b[K\r\u001b[10d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[11d    # doesn't give it to you.\u001b[K\r\u001b[12d    #\u001b[K\r\u001b[13d"]
[0.001, "o", "    # The Options directive is both complicated and important.  Please see\r\u001b[14d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[15d    # for more information.\u001b[K\r\u001b[16d    #\u001b[K\r\u001b[17d    Options Indexes FollowSymLinks\u001b[K\r\u001b[18d\u001b[K\u001b[19d    #\u001b[K\r\u001b[20d    # AllowOverride controls what directives may be placed in .htaccess files.\r\u001b[21d    # It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[22d    #   AllowOverride FileInfo AuthConfig Limit\r\u001b[23d    #\u001b[K\r\u001b[24d    AllowOverride None\u001b[K\r\u001b[25d\u001b[K\u001b[26d    #\u001b[K\r\u001b[27d    # Controls who can get stuff from this server.\r\u001b[28d    #\u001b[K\r\u001b[29d    Require all granted\u001b[K\r\u001b[30d</Directory>\u001b[K\r\u001b[31d\u001b[K\u001b[32d#\u001b[K\u001b[33d\b# \u001b[30m\u001b[43mDirectoryIndex\u001b[39;49m\u001b[m\u000f: sets the file that Apache will serve if a directory\r\u001b[34d# is requested.\u001b[K\r\u001b[35d#\u001b[K\u001b[36d\b<IfModule dir_module>\u001b[K\r\u001b[37d    DirectoryIndex index.html\u001b[K\r\u001b[38d</IfModule>\u001b[K\r\u001b[39d\u001b[K\u001b[40d#\u001b[K\u001b[41d The following lines prevent .htaccess and .htpasswd files from being\r\u001b[42d# viewed by Web clients.\u001b[K\r\u001b[43d#\u001b[K\u001b[44d\b<Files \".ht*\">\u001b[K\r\u001b[45d    Require all denied\u001b[K\r\u001b[46d</Files>\u001b[K\r\u001b[47d\u001b[K\u001b[48d#\u001b[K\u001b[49d ErrorLog: The location of the error log file.\u001b[K\r\u001b[50d# If you do not specify an ErrorLog directive within a <VirtualHost>\r\u001b[51d# container, error messages relating to that virtual host will be\r\u001b[52d# logged here.  If you *do* define an error logfile for a <VirtualHost>\r\u001b[53d# container, that host's errors will be logged there and not here.\r\u001b[54d#\u001b[K\u001b[55d\bErrorLog \"/var/log/httpd/error_log\"\u001b[K\r\u001b[56d\u001b[K\u001b[57d#\u001b[K\u001b[58d"]
[0.001, "o", " LogLevel: Control the number of messages logged to the error_log.\u001b[K\r\u001b[59d# Possible values include: debug, info, notice, warn, error, crit,\u001b[K\r\u001b[60d# alert, emerg.\u001b[K\r\u001b[61d#\u001b[K\u001b[62d\bLogLevel warn\u001b[K\r\u001b[63d\u001b[K\u001b[64d<IfModule log_config_module>\u001b[K\u001b[33;3H"]
