[0.001, "o", "\r\u001b[2d#LoadModule proxy_http2_module modules/mod_proxy_http2.so\r\u001b[3d#LoadModule md_module modules/mod_md.so\u001b[K\r\u001b[4d#LoadModule lbmethod_byrequests_module modules/mod_lbmethod_byrequests.so\r\u001b[5d#LoadModule lbmethod_bytraffic_module modules/mod_lbmethod_bytraffic.so\r\u001b[6d#"]
[0.000, "o", "LoadModule lbmethod_bybusyness_module modules/mod_lbmethod_bybusyness.so\r\u001b[7d#LoadModule lbmethod_heartbeat_module modules/mod_lbmethod_heartbeat.so\r\u001b[8dLoadModule unixd_module modules/mod_unixd.so\u001b[K\r\u001b[9d#LoadModule heartbeat_module modules/mod_heartbeat.so\r\u001b[10d#LoadModule heartmonitor_module modules/mod_heartmonitor.so\u001b[K\r\u001b[11d#LoadModule dav_module modules/mod_dav.so\u001b[K\r\u001b[12dLoadModule status_module modules/mod_status.so\u001b[K\r\u001b[13dLoadModule autoindex_module modules/mod_autoindex.so\r\u001b[14d#LoadModule asis_module modules/mod_asis.so\u001b[K\r\u001b[15d#LoadModule info_module modules/mod_info.so\u001b[K\r\u001b[16d#LoadModule suexec_module modules/mod_suexec.so\u001b[K\r\u001b[17d<IfModule !mpm_prefork_module>\u001b[K\u001b[18;8H\u001b[1K #LoadModule cgid_module modules/mod_cgid.so\u001b[K\r\u001b[19d</IfModule>\u001b[K\r\u001b[20d<IfModule mpm_prefork_module>\u001b[K\u001b[21;9H#LoadModule cgi_module modules/mod_cgi.so\r\u001b[22d</IfModule>\r\u001b[23d#"]
[0.000, "o", "LoadModule dav_fs_module modules/mod_dav_fs.so\u001b[K\r\u001b[24d#LoadModule dav_lock_module modules/mod_dav_lock.so\r\u001b[25d#LoadModule vhost_alias_module modules/mod_vhost_alias.so\r\u001b[26dLoadModule negotiation_module modules/mod_negotiation.so\u001b[K\r\u001b[27dLoadModule dir_module modules/mod_dir.so\u001b[K\r\u001b[28d#LoadModule imagemap_module modules/mod_imagemap.so\u001b[K\r\u001b[29d#LoadModule actions_module modules/mod_actions.so\u001b[K\r\u001b[30d#LoadModule speling_module modules/mod_speling.so\r\u001b[31dLoadModule userdir_module modules/mod_userdir.so\r\u001b[32dLoadModule alias_module modules/mod_alias.so\r\u001b[33d#\u001b[30m\u001b[43mLoadModule rewr\u001b[39;49m\u001b[m\u000fite_module modules/mod_rewrite.so\r\u001b[34d\u001b[K\u001b[35d<IfModule unixd_module>\u001b[K\u001b[36;3H\u001b[K\u001b[37dIf you wish httpd to run as a different user or group, you must run\u001b[38;3Hhttpd as root initially and it will switch.\u001b[K\u001b[39;3H\u001b[K\u001b[40dUser/Group: The name (or #number) of the user/group to run httpd as.\u001b[41;3HIt is usually good practice to create a dedicated user and group for\u001b[42;3Hrunning httpd, as with most system services.\r\u001b[43d#\u001b[44d\bUser http\r\u001b[45dGroup http\u001b[K\r\u001b[46d\u001b[K\u001b[47d</IfModule>\u001b[K\r\u001b[48d\u001b[K\u001b[49d# 'Main' server configuration\u001b[K\u001b[50;3H\u001b[K\u001b[51dThe directives in this section set up the values used by the 'main'\r\u001b[52d# server, which responds to any requests that aren't handled by a\r\u001b[53d# <VirtualHost> definition.  These values also provide defaults for\r\u001b[54d# any <VirtualHost> containers you may define later in the file.\u001b[56;3HAll of these directives may appear inside <VirtualHost> containers,\u001b[57;3Hin which case these default settings will be overridden for the\u001b[58;3Hvirtual host being defined.\u001b[K\u001b[59;3H\u001b[K\r\u001b[60d\u001b[K\u001b[61d# \u001b[K\u001b[62dServerAdmin: Your address, where problems with the server should be\u001b[63;3He-mailed.  This address appears on some server-generated pages, such\u001b[64;3Has error documents.  e.g. admin@your-domain.com\r\u001b[33d#"]
