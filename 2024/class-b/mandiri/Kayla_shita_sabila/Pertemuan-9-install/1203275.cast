[0.000, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G"]
[0.001, "o", "\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\r\u001b[2dPermitEmptyPasswords no\u001b[K\r\u001b[3d\u001b[K\u001b[4d# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\u001b[5;3Hthe system's configuration, this may involve passwords, challenge-response,\u001b[6;3Hone-time passwords or some combination of these and other methods.\r\u001b[7d#KbdInteractiveAuthentication yes\r\u001b[8d"]
[0.000, "o", "\u001b[K\u001b[9d# Kerberos options\r\u001b[10d#KerberosAuthentication no\u001b[K\r\u001b[11d#KerberosOrLocalPasswd yes\u001b[K\r\u001b[12d#KerberosTicketCleanup yes\u001b[K\r\u001b[13d#KerberosGetAFSToken no\r\u001b[15d# GSSAPI options\r\u001b[16d#GSSAPIAuthentication no\r\u001b[17d#GSSAPICleanupCredentials yes\r\u001b[18d\u001b[K\u001b[19d# Set this to 'yes' to enable PAM authentication, account processing,\r\u001b[20d# and session processing. If this is enabled, PAM authentication will\r\u001b[21d# be allowed through the KbdInteractiveAuthentication and\r\u001b[22d# PasswordAuthentication.  Depending on your PAM configuration,\r\u001b[23d# PAM authentication via KbdInteractiveAuthentication may bypass\u001b[24;3Hthe setting of \"PermitRootLogin prohibit-password\".\r\u001b[25d# If you just want the PAM account and session checks to run without\r\u001b[26d# PAM authentication, then enable this but set PasswordAuthentication\r\u001b[27d# and KbdInteractiveAuthentication to 'no'.\r\u001b[28d"]
[0.001, "o", "UsePAM yes\r\u001b[29d\u001b[K\u001b[30d#AllowAgentForwarding yes\r\u001b[31d#AllowTcpForwarding yes\r\u001b[32d#GatewayPorts no\r\u001b[33d#\u001b[30m\u001b[43mX11\u001b[39;49m\u001b[m\u000fForwarding no\r\u001b[34d#X11DisplayOffset 10\r\u001b[35d#X11UseLocalhost yes\r\u001b[36d#PermitTTY yes\u001b[K\r\u001b[37d#PrintMotd yes\u001b[K\r\u001b[38d#PrintLastLog yes\r\u001b[39d#TCPKeepAlive yes\r\u001b[40dPermitUserEnvironment no\r\u001b[41d#Compression delayed\u001b[K\r\u001b[42d#ClientAliveInterval 0\r\u001b[43d#ClientAliveCountMax 3\u001b[K\r\u001b[44d#UseDNS no\u001b[K\r\u001b[45d#PidFile /run/sshd.pid\u001b[K\r\u001b[46d#MaxStartups 10:30:100\r\u001b[47d#PermitTunnel no\u001b[K\r\u001b[48d#ChrootDirectory none\r\u001b[49d#VersionAddendum none\u001b[K\r\u001b[50d\u001b[K\u001b[51d# no default banner path\r\u001b[52d#Banner none\u001b[K\r\u001b[53d\u001b[K\u001b[54d# override default of no subsystems\u001b[K\r\u001b[55dSubsystem       sftp    /usr/lib/ssh/sftp-server\r\u001b[56d\u001b[K\u001b[57d# Example of overriding settings on a per-user basis\u001b[K\r\u001b[58d#Match User anoncvs\r\u001b[59d#\u001b[9GX11Forwarding no\u001b[60;3H      AllowTcpForwarding no\u001b[K\r\u001b[61d#       PermitTTY no\u001b[K\r\u001b[62d#       ForceCommand cvs server\r\u001b[64d\u001b[K\u001b[33d#"]
