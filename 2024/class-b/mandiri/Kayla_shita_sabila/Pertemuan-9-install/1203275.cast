[0.002, "o", "\u001b[65;98H\u001b[0;10;1m\u000f\u001b[37m\u001b[41m[ File '/etc/ssh/sshd_config' is unwritable ]\u001b[39;49m\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                                  /etc/ssh/sshd_config                                                                                                            \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d# Include drop-in configurations\r\u001b[3dInclude /etc/ssh/sshd_config.d/*.conf\r\u001b[5d# This is the sshd server system-wide configuration file.  See\r\u001b[6d# sshd_config(5) for more information.\r\u001b[8d# This sshd was compiled with PATH=/usr/local/sbin:/usr/local/bin:/usr/bin\r\u001b[10d# The strategy used for options in the default sshd_config shipped with\r\u001b[11d# OpenSSH is to specify options with their default value where\r\u001b[12d# possible, but leave them commented.  Uncommented options override the\r\u001b[13d# default value.\r\u001b[15d#Port 22\r\u001b[16d#AddressFamily any\r\u001b[17d#ListenAddress 0.0.0.0\r\u001b[18d#ListenAddress ::\r\u001b[20d#HostKey /etc/ssh/ssh_host_rsa_key\r\u001b[21d#HostKey /etc/ssh/ssh_host_ecdsa_key\r\u001b[22d#HostKey /etc/ssh/ssh_host_ed25519_key\r\u001b[24d# Ciphers and keying\r\u001b[25d#RekeyLimit default none\r\u001b[27d# Logging\r\u001b[28d#SyslogFacility AUTH\r\u001b[29d#LogLevel INFO\r\u001b[31d# Authentication:\r\u001b[33d#LoginGraceTime 2m\r\u001b[34d#PermitRootLogin prohibit-password\r\u001b[35d#StrictModes yes\r\u001b[36d#MaxAuthTries 6\r\u001b[37d#MaxSessions 10\r\u001b[39d#PubkeyAuthentication yes\r\u001b[41d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\r\u001b[42d# but this is overridden so installations will only check .ssh/authorized_keys\r\u001b[43dAuthorizedKeysFile\u001b[25G.ssh/authorized_keys\r\u001b[45d#AuthorizedPrincipalsFile none\r\u001b[47d#AuthorizedKeysCommand none\r\u001b[48d#AuthorizedKeysCommandUser nobody\r\u001b[50d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\r\u001b[51d#HostbasedAuthentication no\r\u001b[52d# Change to yes if you don't trust ~/.ssh/known_hosts for\r\u001b[53d# HostbasedAuthentication\r\u001b[54d#IgnoreUserKnownHosts no\r\u001b[55d# Don't read the user's ~/.rhosts and ~/.shosts files\r\u001b[56d#IgnoreRhosts yes\r\u001b[58d# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[59d#PasswordAuthentication yes\r\u001b[60d#PermitEmptyPasswords no\r\u001b[62d# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\r\u001b[63d# the system's configuration, this may involve passwords, challenge-response,\r\u001b[64d# one-time passwords or some combination of these and other methods.\r\u001b[2d\u001b[?25h\u001b[?0c"]
