[0.000, "o", "\r\u001b[2dProtocol 2\u001b[K\r\u001b[3d\u001b[K\u001b[4d# Logging\u001b[K\r\u001b[5d#SyslogFacility AUTH\u001b[K\r\u001b[6dLogLevel VERBOSE\u001b[K\u001b[8;3H"]
[0.000, "o", "Authentication:\r\u001b[9d\u001b[K\u001b[10d#LoginGraceTime 2m\u001b[K\r\u001b[11dPermitRootLogin no\r\u001b[12d#StrictModes yes\u001b[K\r\u001b[13dMaxAuthTries 4\u001b[K\r\u001b[14dMaxSessions 10\u001b[K\r\u001b[15d\u001b[K\u001b[16d#PubkeyAuthentication yes\u001b[K\r\u001b[17d\u001b[K\u001b[18d# The default is to check both .ssh/authorized_keys and .ssh/authorized_keys2\u001b[19;3Hbut this is overridden so installations will only check .ssh/authorized_keys\r\u001b[20dAuthorizedKeysFile      .ssh/authorized_keys\r\u001b[21d\u001b[K\u001b[22d#AuthorizedPrincipalsFile none\r\u001b[23d\u001b[K\u001b[24d#AuthorizedKeysCommand none\r\u001b[25d#AuthorizedKeysCommandUser nobody\r\u001b[26d\u001b[K\u001b[27d# For this to work you will also need host keys in /etc/ssh/ssh_known_hosts\r\u001b[28d#HostbasedAuthentication no\r\u001b[29d#"]
[0.000, "o", " Change to yes if you don't trust ~/.ssh/known_hosts for\r\u001b[30d# HostbasedAuthentication\r\u001b[31d#IgnoreUserKnownHosts no\r\u001b[32d# Don't read th"]
[0.001, "o", "e user's ~/.rhosts and ~/.shosts files\r\u001b[33d#\u001b[30m\u001b[43mIgnoreR\u001b[39;49m\u001b[m\u000fhosts yes\u001b[K\r\u001b[34d\u001b[K\u001b[35d# To disable tunneled clear text passwords, change to \"no\" here!\r\u001b[36d#PasswordAuthentication yes\r\u001b[37dPermitEmptyPasswords no\r\u001b[38d\u001b[K\u001b[39d# Change to \"no\" to disable keyboard-interactive authentication.  Depending on\r\u001b[40d# the system's configuration, this may involve passwords, challenge-response,\r\u001b[41d# one-time passwords or some combination of these and other methods.\r\u001b[42d#KbdInteractiveAuthentication yes\u001b[44;3HKerberos options\u001b[K\r\u001b[45d#KerberosAuthentication no\r\u001b[46d#KerberosOrLocalPasswd yes\r\u001b[47d#KerberosTicketCleanup yes\u001b[K\r\u001b[48d#KerberosGetAFSToken no\u001b[K\u001b[50;3HGSSAPI options\u001b[K\r\u001b[51d#GSSAPIAuthentication no\r\u001b[52d#GSSAPICleanupCredentials yes\r\u001b[53d\u001b[K\u001b[54d# Set this to 'yes' to enable PAM authentication, account processing,\u001b[55;3Hand session processing. If this is enabled, PAM authentication will\r\u001b[56d# be allowed through the KbdInteractiveAuthentication and\r\u001b[57d# PasswordAuthentication.  Depending on your PAM configuration,\r\u001b[58d# PAM authentication via KbdInteractiveAuthentication may bypass\r\u001b[59d# the setting of \"PermitRootLogin prohibit-password\".\r\u001b[60d# If you just want the PAM account and session checks to run without\r\u001b[61d# PAM authentication, then enable this but set PasswordAuthentication\r\u001b[62d# and KbdInteractiveAuthentication to 'no'.\r\u001b[63d#UsePAM no\r\u001b[33d#"]
