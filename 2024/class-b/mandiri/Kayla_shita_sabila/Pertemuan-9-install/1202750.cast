[1.001, "o", "\r\u001b[K\u001b[6A                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n\u001b[6A\u001b[32m[iwd]\u001b[0m# \r\u001b[K                                    Devices\u001b[1;90m                                   *\u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m  Name                  Address               Powered     Adapter     Mode      \r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K  wlan0                 70:08:94:a2:c1:f5     off         phy0        station     \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[32m[iwd]\u001b[0m# "]
[1.000, "o", "\r\u001b[K\u001b[6A                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n\u001b[6A\u001b[32m[iwd]\u001b[0m# \r\u001b[K                                    Devices\u001b[1;90m                                    \u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m  Name                  Address               Powered     Adapter     Mode      \r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K  wlan0                 70:08:94:a2:c1:f5     off         phy0        station     \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[32m[iwd]\u001b[0m# "]
