[0.000, "o", "\u001b[1;1H\u001b[K\u001b[4mMOUNT\u001b[24m(8)                                                                                                     System Administration                                                                                                     \u001b[4mMOUNT\u001b[24m(8)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K     mount - mount a filesystem\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-h\u001b[22m|\u001b[1m-V\u001b[22m]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-l\u001b[22m] [\u001b[1m-t \u001b[4m\u001b[22mfstype\u001b[24m]\u001b[m\r\n\u001b[10;1H\u001b[K\u001b[m\r\n\u001b[11;1H\u001b[K     \u001b[1mmount -a \u001b[22m[\u001b[1m-F\u001b[22m] [\u001b[1m-fnrsvw\u001b[22m] [\u001b[1m-t \u001b[4m\u001b[22mfstype\u001b[24m] [\u001b[1m-O \u001b[4m\u001b[22moptlist\u001b[24m]\u001b[m\r\n\u001b[12;1H\u001b[K\u001b[m\r\n\u001b[13;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-fnrsvw\u001b[22m] [\u001b[1m-o \u001b[4m\u001b[22moptions\u001b[24m] \u001b[4mdevice\u001b[24m|\u001b[4mmountpoint\u001b[0m\u001b[m\r\n\u001b[14;1H\u001b[K\u001b[m\r\n\u001b[15;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-fnrsvw\u001b[22m] [\u001b[1m-o \u001b[4m\u001b[22moptions\u001b[24m] [\u001b[1m-t \u001b[4m\u001b[22mfstype\u001b[24m] \u001b[4mdevice\u001b[24m \u001b[4mmountpoint\u001b[0m\u001b[m\r\n\u001b[16;1H\u001b[K\u001b[m\r\n\u001b[17;1H\u001b[K     \u001b[1mmount --bin"]
[0.001, "o", "d\u001b[22m|\u001b[1m--rbind\u001b[22m|\u001b[1m--move \u001b[4m\u001b[22molddir\u001b[24m \u001b[4mnewdir\u001b[0m\u001b[m\r\n\u001b[18;1H\u001b[K\u001b[m\r\n\u001b[19;1H\u001b[K     \u001b[1mmount --make-\u001b[22m[\u001b[1mr\u001b[22m]{\u001b[1mshared\u001b[22m|\u001b[1mslave\u001b[22m|\u001b[1mprivate\u001b[22m|\u001b[1munbindable\u001b[22m} \u001b[4mmountpoint\u001b[0m\u001b[m\r\n\u001b[20;1H\u001b[K\u001b[m\r\n\u001b[21;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[22;1H\u001b[K     All files accessible in a Unix system are arranged in one big tree, the file hierarchy, rooted at \u001b[4m/\u001b[24m. These files can be spread out over several devices. The \u001b[1mmount \u001b[22mcommand serves to attach the filesystem found on some device to the big\u001b[m\r\n\u001b[23;1H\u001b[K     file tree. Conversely, the \u001b[1mumount\u001b[22m(8) command will detach it again. The filesystem is used to control how data is stored on the device or provided in a virtual way by network or other services.\u001b[m\r\n\u001b[24;1H\u001b[K\u001b[m\r\n\u001b[25;1H\u001b[K     The standard form of the \u001b[1mmount \u001b[22mcommand is:\u001b[m\r\n\u001b[26;1H\u001b[K\u001b[m\r\n\u001b[27;1H\u001b[K        \u001b[1mmount -t \u001b[4m\u001b[22mtype\u001b[24m \u001b[4mdevice\u001b[24m \u001b[4mdir\u001b[0m\u001b[m\r\n\u001b[28;1H\u001b[K\u001b[m\r\n\u001b[29;1H\u001b[K     This  tells the kernel to attach the filesystem found on \u001b[4mdevice\u001b[24m (which is of type \u001b[4mtype\u001b[24m) at the directory \u001b[4mdir\u001b[24m. The option \u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m is optional. The \u001b[1mmount \u001b[22mcommand is usually able to detect a filesystem. The root permissions are necessary\u001b[m\r\n\u001b[30;1H\u001b[K     to mount a filesystem by default. See section \"Non-superuser mounts\" below for more details. The previous contents (if any) and owner and mode of \u001b[4mdir\u001b[24m become invisible, and as long as this filesystem remains mounted, the  pathname  \u001b[4mdir\u001b[0m\u001b[m\r\n\u001b[31;1H\u001b[K     refers to the root of the filesystem on \u001b[4mdevice\u001b[24m.\u001b[m\r\n\u001b[32;1H\u001b[K\u001b[m\r\n\u001b[33;1H\u001b[K     If only the directory or the device is given, for example:\u001b[m\r\n\u001b[34;1H\u001b[K\u001b[m\r\n\u001b[35;1H\u001b[K        \u001b[1mmount \u001b[4m\u001b[22m/dir\u001b[0m\u001b[m\r\n\u001b[36;1H\u001b[K\u001b[m\r\n\u001b[37;1H\u001b[K     then \u001b[1mmount \u001b[22mlooks for a mountpoint (and if not found then for a device) in the \u001b[4m/etc/fstab\u001b[24m file. It’s possible to use the \u001b[1m--target \u001b[22mor \u001b[1m--source \u001b[22moptions to avoid ambiguous interpretation of the given argument. For example:\u001b[m\r\n\u001b[38;1H\u001b[K\u001b[m\r\n\u001b[39;1H\u001b[K        \u001b[1mmount --target \u001b[4m\u001b[22m/mountpoint\u001b[0m\u001b[m\r\n\u001b[40;1H\u001b[K\u001b[m\r\n\u001b[41;1H\u001b[K     The same filesystem may be mounted more than once, and in some cases (e.g., network filesystems) the same filesystem may be mounted on the same mountpoint multiple times. The \u001b[1mmount \u001b[22mcommand does not implement any policy to control this\u001b[m\r\n\u001b[42;1H\u001b[K     behavior. All behavior is controlled by the kernel and it is usually specific to the filesystem driver. The exception is \u001b[1m--all\u001b[22m, in this case already mounted filesystems are ignored (see \u001b[1m--all \u001b[22mbelow for more details).\u001b[m\r\n\u001b[43;1H\u001b[K\u001b[m\r\n\u001b[44;1H\u001b[K   \u001b[1mListing the mounts\u001b[0m\u001b[m\r\n\u001b[45;1H\u001b[K     The listing mode is maintained for backward compatibility only.\u001b[m\r\n\u001b[46;1H\u001b[K\u001b[m\r\n\u001b[47;1H\u001b[K     For more robust and customizable output use \u001b[1mfindmnt\u001b[22m(8), \u001b[1mespecially in your scripts\u001b[22m. Note that control characters in the mountpoint name are replaced with '?'.\u001b[m\r\n\u001b[48;1H\u001b[K\u001b[m\r\n\u001b[49;1H\u001b[K     The following command lists all mounted filesystems (of type \u001b[4mtype\u001b[24m):\u001b[m\r\n\u001b[50;1H\u001b[K\u001b[m\r\n\u001b[51;1H\u001b[K        \u001b[1mmount \u001b[22m[\u001b[1m-l\u001b[22m] [\u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m]\u001b[m\r\n\u001b[52;1H\u001b[K\u001b[m\r\n\u001b[53;1H\u001b[K     The option \u001b[1m-l \u001b[22madds labels to this listing. See below.\u001b[m\r\n\u001b[54;1H\u001b[K\u001b[m\r\n\u001b[55;1H\u001b[K   \u001b[1mIndicating the device and filesystem\u001b[0m\u001b[m\r\n\u001b[56;1H\u001b[K     Most devices are indicated by a filename (of a block special device), like \u001b[4m/dev/sda1\u001b[24m, but there are other possibilities. For example, in the case of an NFS mount, \u001b[4mdevice\u001b[24m may look like \u001b[4mknuth.cwi.nl:/dir\u001b[24m.\u001b[m\r\n\u001b[57;1H\u001b[K\u001b[m\r\n\u001b[58;1H\u001b[K     The  device  names of disk partitions are unstable; hardware reconfiguration, and adding or removing a device can cause changes in names. This is the reason why it’s strongly recommended to use filesystem or partition identifiers like\u001b[m\r\n\u001b[59;1H\u001b[K     UUID or LABEL. Currently supported identifiers (tags):\u001b[m\r\n\u001b[60;1H\u001b[K\u001b[m\r\n\u001b[61;1H\u001b[K     LABEL=\u001b[4mlabel\u001b[0m\u001b[m\r\n\u001b[62;1H\u001b[K         Human r"]
[0.002, "o", "eadable filesystem identifier. See also \u001b[1m-L\u001b[22m.\u001b[m\r\n\u001b[63;1H\u001b[K\u001b[m\r\n\u001b[64;1H\u001b[K     UUID=\u001b[4muuid\u001b[0m\u001b[m\r\n\u001b[65;1H\u001b[K         Filesystem universally unique identifier. The format of the UUID is usually a series of hex digits separated by hyphens. See also \u001b[1m-U\u001b[22m.\u001b[m\r\n\u001b[66;1H\u001b[K\u001b[m\r\n\u001b[67;1H\u001b[1;1H\u001b[K\u001b[4mMOUNT\u001b[24m(8)                                                                                                     System Administration                                                                                                     \u001b[4mMOUNT\u001b[24m(8)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K     mount - mount a filesystem\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-h\u001b[22m|\u001b[1m-V\u001b[22m]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-l\u001b[22m] [\u001b[1m-t \u001b[4m\u001b[22mfstype\u001b[24m]\u001b[m\r\n\u001b[10;1H\u001b[K\u001b[m\r\n\u001b[11;1H\u001b[K     \u001b[1mmount -a \u001b[22m[\u001b[1m-F\u001b[22m] [\u001b[1m-fnrsvw\u001b[22m] [\u001b[1m-t \u001b[4m\u001b[22mfstype\u001b[24m] [\u001b[1m-O \u001b[4m\u001b[22moptlist\u001b[24m]\u001b[m\r\n\u001b[12;1H\u001b[K\u001b[m\r\n\u001b[13;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-fnrsvw\u001b[22m] [\u001b[1m-o \u001b[4m\u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[1m\u001b[4m\u001b[22ms\u001b[24m] \u001b[4mdevice\u001b[24m|\u001b[4mmountpoint\u001b[0m\u001b[m\r\n\u001b[14;1H\u001b[K\u001b[m\r\n\u001b[15;1H\u001b[K     \u001b[1mmount \u001b[22m[\u001b[1m-fnrsvw\u001b[22m] [\u001b[1m-o \u001b[4m\u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[1m\u001b[4m\u001b[22ms\u001b[24m] [\u001b[1m-t \u001b[4m\u001b[22mfstype\u001b[24m] \u001b[4mdevice\u001b[24m \u001b[4mmountpoint\u001b[0m\u001b[m\r\n\u001b[16;1H\u001b[K\u001b[m\r\n\u001b[17;1H\u001b[K     \u001b[1mmount --bind\u001b[22m|\u001b[1m--rbind\u001b[22m|\u001b[1m--move \u001b[4m\u001b[22molddir\u001b[24m \u001b[4mnewdir\u001b[0m\u001b[m\r\n\u001b[18;1H\u001b[K\u001b[m\r\n\u001b[19;1H\u001b[K     \u001b[1mmount --make-\u001b[22m[\u001b[1mr\u001b[22m]{\u001b[1mshared\u001b[22m|\u001b[1mslave\u001b[22m|\u001b[1mprivate\u001b[22m|\u001b[1munbindable\u001b[22m} \u001b[4mmountpoint\u001b[0m\u001b[m\r\n\u001b[20;1H\u001b[K\u001b[m\r\n\u001b[21;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[22;1H\u001b[K     All files accessible in a Unix system are arranged in one big tree, the file hierarchy, rooted at \u001b[4m/\u001b[24m. These files can be spread out over several devices. The \u001b[1mmount \u001b[22mcommand serves to attach the filesystem found on some device to the big\u001b[m\r\n\u001b[23;1H\u001b[K     file tree. Conversely, the \u001b[1mumount\u001b[22m(8) command will detach it again. The filesystem is used to control how data is stored on the device or provided in a virtual way by network or other services.\u001b[m\r\n\u001b[24;1H\u001b[K\u001b[m\r\n\u001b[25;1H\u001b[K     The standard form of the \u001b[1mmount \u001b[22mcommand is:\u001b[m\r\n\u001b[26;1H\u001b[K\u001b[m\r\n\u001b[27;1H\u001b[K        \u001b[1mmount -t \u001b[4m\u001b[22mtype\u001b[24m \u001b[4mdevice\u001b[24m \u001b[4mdir\u001b[0m\u001b[m\r\n\u001b[28;1H\u001b[K\u001b[m\r\n\u001b[29;1H\u001b[K     This  tells the kernel to attach the filesystem found on \u001b[4mdevice\u001b[24m (which is of type \u001b[4mtype\u001b[24m) at the directory \u001b[4mdir\u001b[24m. The \u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[4m\u001b[24m \u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m is \u001b[01;44;33moption\u001b[0m\u001b[4m\u001b[22m\u001b[24mal. The \u001b[1mmount \u001b[22mcommand is usually able to detect a filesystem. The root permissions are necessary\u001b[m\r\n\u001b[30;1H\u001b[K     to mount a filesystem by default. See section \"Non-superuser mounts\" below for more details. The previous contents (if any) and owner and mode of \u001b[4mdir\u001b[24m become invisible, and as long as this filesystem remains mounted, the  pathname  \u001b[4mdir\u001b[0m\u001b[m\r\n\u001b[31;1H\u001b[K     refers to the root of the filesystem on \u001b[4mdevice\u001b[24m.\u001b[m\r\n\u001b[32;1H\u001b[K\u001b[m\r\n\u001b[33;1H\u001b[K     If only the directory or the device is given, for example:\u001b[m\r\n\u001b[34;1H\u001b[K\u001b[m\r\n\u001b[35;1H\u001b[K        \u001b[1mmount \u001b[4m\u001b[22m/dir\u001b[0m\u001b[m\r\n\u001b[36;1H\u001b[K\u001b[m\r\n\u001b[37;1H\u001b[K     then \u001b[1mmount \u001b[22mlooks for a mountpoint (and if not found then for a device) in the \u001b[4m/etc/fstab\u001b[24m file. It’s possible to use the \u001b[1m--target \u001b[22mor \u001b[1m--source \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[22m\u001b[1m\u001b[22ms to avoid ambiguous interpretation of the given argument. For example:\u001b[m\r\n\u001b[38;1H\u001b[K\u001b[m\r\n\u001b[39;1H\u001b[K        \u001b[1mmount --target \u001b[4m\u001b[22m/mountpoint\u001b[0m\u001b[m\r\n\u001b[40;1H\u001b[K\u001b[m\r\n\u001b[41;1H\u001b[K     The same filesystem may be mounted more than once, and in some cases (e.g., network filesystems) the same filesystem may be mounted on the same mountpoint multiple times. The \u001b[1mmount \u001b[22mcommand does not implement any policy to control this\u001b[m\r\n\u001b[42;1H\u001b[K     behavior. All behavior is controlled by the kernel and it is usually specific to the filesystem driver. The exception is \u001b[1m--all\u001b[22m, in this case already mounted "]
[0.002, "o", "filesystems are ignored (see \u001b[1m--all \u001b[22mbelow for more details).\u001b[m\r\n\u001b[43;1H\u001b[K\u001b[m\r\n\u001b[44;1H\u001b[K   \u001b[1mListing the mounts\u001b[0m\u001b[m\r\n\u001b[45;1H\u001b[K     The listing mode is maintained for backward compatibility only.\u001b[m\r\n\u001b[46;1H\u001b[K\u001b[m\r\n\u001b[47;1H\u001b[K     For more robust and customizable output use \u001b[1mfindmnt\u001b[22m(8), \u001b[1mespecially in your scripts\u001b[22m. Note that control characters in the mountpoint name are replaced with '?'.\u001b[m\r\n\u001b[48;1H\u001b[K\u001b[m\r\n\u001b[49;1H\u001b[K     The following command lists all mounted filesystems (of type \u001b[4mtype\u001b[24m):\u001b[m\r\n\u001b[50;1H\u001b[K\u001b[m\r\n\u001b[51;1H\u001b[K        \u001b[1mmount \u001b[22m[\u001b[1m-l\u001b[22m] [\u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m]\u001b[m\r\n\u001b[52;1H\u001b[K\u001b[m\r\n\u001b[53;1H\u001b[K     The \u001b[01;44;33moption\u001b[0m \u001b[1m-l \u001b[22madds labels to this listing. See below.\u001b[m\r\n\u001b[54;1H\u001b[K\u001b[m\r\n\u001b[55;1H\u001b[K   \u001b[1mIndicating the device and filesystem\u001b[0m\u001b[m\r\n\u001b[56;1H\u001b[K     Most devices are indicated by a filename (of a block special device), like \u001b[4m/dev/sda1\u001b[24m, but there are other possibilities. For example, in the case of an NFS mount, \u001b[4mdevice\u001b[24m may look like \u001b[4mknuth.cwi.nl:/dir\u001b[24m.\u001b[m\r\n\u001b[57;1H\u001b[K\u001b[m\r\n\u001b[58;1H\u001b[K     The  device  names of disk partitions are unstable; hardware reconfiguration, and adding or removing a device can cause changes in names. This is the reason why it’s strongly recommended to use filesystem or partition identifiers like\u001b[m\r\n\u001b[59;1H\u001b[K     UUID or LABEL. Currently supported identifiers (tags):\u001b[m\r\n\u001b[60;1H\u001b[K\u001b[m\r\n\u001b[61;1H\u001b[K     LABEL=\u001b[4mlabel\u001b[0m\u001b[m\r\n\u001b[62;1H\u001b[K         Human readable filesystem identifier. See also \u001b[1m-L\u001b[22m.\u001b[m\r\n\u001b[63;1H\u001b[K\u001b[m\r\n\u001b[64;1H\u001b[K     UUID=\u001b[4muuid\u001b[0m\u001b[m\r\n\u001b[65;1H\u001b[K         Filesystem universally unique identifier. The format of the UUID is usually a series of hex digits separated by hyphens. See also \u001b[1m-U\u001b[22m.\u001b[m\r\n\u001b[66;1H\u001b[K\u001b[m\r\n\u001b[67;1H         Note that \u001b[1mmount \u001b[22muses UUIDs as strings. The UUIDs from the command line or from \u001b[1mfstab\u001b[22m(5) are not converted to internal binary representation. The string representation of the UUID should be based on lower case characters.\u001b[m\r\n\u001b[m\r\n     PARTLABEL=\u001b[4mlabel\u001b[0m\u001b[m\r\n         Human readable partition identifier. This identifier is independent on filesystem and does not change by \u001b[1mmkfs \u001b[22mor \u001b[1mmkswap \u001b[22moperations. It’s supported for example for GUID Partition Tables (GPT).\u001b[m\r\n\u001b[m\r\n     PARTUUID=\u001b[4muuid\u001b[0m\u001b[m\r\n         Partition universally unique identifier. This identifier is independent on filesystem and does not change by \u001b[1mmkfs \u001b[22mor \u001b[1mmkswap \u001b[22moperations. It’s supported for example for GUID Partition Tables (GPT).\u001b[m\r\n\u001b[m\r\n     ID=\u001b[4mid\u001b[0m\u001b[m\r\n         Hardware block device ID as generated by udevd. This identifier is usually based on WWN (unique storage identifier) and assigned by the hardware manufacturer. See \u001b[1mls /dev/disk/by-id \u001b[22mfor more details,  this  directory  and  running\u001b[m\r\n         udevd is required. This identifier is not recommended for generic use as the identifier is not strictly defined and it depends on udev, udev rules and hardware.\u001b[m\r\n\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 13/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[5.744, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The command \u001b[1mlsblk --fs \u001b[22mprovides an overview of filesystems, LABELs and UUIDs on available block devices. The command \u001b[1mblkid -p <device> \u001b[22mprovides details about a filesystem on the specified device.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 14/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.261, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 15/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     Don’t forget that there is no guarantee that UUIDs and labels are really unique, especially if you move, share or copy the device. Use \u001b[1mlsblk -o +UUID,PARTUUID \u001b[22mto verify that the UUIDs are really unique in your system.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 16/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 17/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The  recommended setup is to use tags (e.g. \u001b[1mUUID\u001b[22m=\u001b[4muuid\u001b[24m) rather than \u001b[4m/dev/disk/by-{label,uuid,id,partuuid,partlabel}\u001b[24m udev symlinks in the \u001b[4m/etc/fstab\u001b[24m file. Tags are more readable, robust and portable. The \u001b[1mmount\u001b[22m(8) command internally uses\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 18/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.029, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     udev symlinks, so the use of symlinks in \u001b[4m/etc/fstab\u001b[24m has no advantage over tags. For more details see \u001b[1mlibblkid\u001b[22m(3).\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 19/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 20/1746 5% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The \u001b[4mproc\u001b[24m filesystem is not associated with a special device, and when mounting it, an arbitrary keyword - for example, \u001b[4mproc\u001b[24m - can be used instead of a device specification. (The customary choice \u001b[4mnone\u001b[24m is less fortunate: the error  mes‐\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 21/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.029, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     sage 'none already mounted' from \u001b[1mmount \u001b[22mcan be confusing.)\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 22/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.031, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 23/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "   \u001b[1mThe files /etc/fstab, /etc/mtab and /proc/mounts\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 24/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.035, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The  file  \u001b[4m/etc/fstab\u001b[24m (see \u001b[1mfstab\u001b[22m(5)), may contain lines describing what devices are usually mounted where, using which \u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[1m\u001b[22ms. The default location of the \u001b[1mfstab\u001b[22m(5) file can be overridden with the \u001b[1m--fstab \u001b[4m\u001b[22mpath\u001b[24m command-line \u001b[01;44;33moption\u001b[0m\u001b[4m\u001b[22m\u001b[24m (see\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 25/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     below for more details).\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 26/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 27/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The command\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 28/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.031, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 29/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.028, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "        \u001b[1mmount -a \u001b[22m[\u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m] [\u001b[1m-O \u001b[4m\u001b[22moptlist\u001b[24m]\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 30/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 31/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     (usually given in a bootscript) causes all filesystems mentioned in \u001b[4mfstab\u001b[24m (of the proper type and/or having or not having the proper \u001b[01;44;33moption\u001b[0m\u001b[4m\u001b[24ms) to be mounted as indicated, except for those whose line contains the \u001b[1mnoauto \u001b[22mkeyword.  Adding\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 32/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     the \u001b[1m-F \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[1m\u001b[22m will make \u001b[1mmount \u001b[22mfork, so that the filesystems are mounted in parallel.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 33/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 34/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     When mounting a filesystem mentioned in \u001b[4mfstab\u001b[24m or \u001b[4mmtab\u001b[24m, it suffices to specify on the command line only the device, or only the mount point.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 35/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.036, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 36/1746 6% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.366, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The  programs  \u001b[1mmount \u001b[22mand \u001b[1mumount\u001b[22m(8) traditionally maintained a list of currently mounted filesystems in the file \u001b[4m/etc/mtab\u001b[24m. The support for regular classic \u001b[4m/etc/mtab\u001b[24m is completely disabled at compile time by default, because on current\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 37/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.250, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     Linux systems it is better to make \u001b[4m/etc/mtab\u001b[24m a symlink to \u001b[4m/proc/mounts\u001b[24m instead. The regular \u001b[4mmtab\u001b[24m file maintained in userspace cannot reliably work with namespaces, containers and other advanced Linux features. If the regular \u001b[4mmtab\u001b[24m sup‐\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 38/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     port is enabled, then it’s possible to use the file as well as the symlink.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 39/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.037, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 40/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     If no arguments are given to \u001b[1mmount\u001b[22m, the list of mounted filesystems is printed.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 41/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 42/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     If you want to override mount \u001b[01;44;33moption\u001b[0ms from \u001b[4m/etc/fstab\u001b[24m, you have to use the \u001b[1m-o \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[1m\u001b[22m:\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 43/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.027, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 44/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.033, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "        \u001b[1mmount \u001b[4m\u001b[22mdevice\u001b[24m|\u001b[4mdir\u001b[24m \u001b[1m-o \u001b[4m\u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[1m\u001b[4m\u001b[22ms\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 45/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 46/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     and then the mount \u001b[01;44;33moption\u001b[0ms from the command line will be appended to the list of \u001b[01;44;33moption\u001b[0ms from \u001b[4m/etc/fstab\u001b[24m. This default behaviour can be changed using the \u001b[1m--\u001b[01;44;33moption\u001b[0m\u001b[4m\u001b[24m\u001b[1ms-mode \u001b[22mcommand-line \u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[1m\u001b[22m. The usual behavior is that the  last  \u001b[01;44;33moption\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 47/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     wins if there are conflicting ones.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 48/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[7.201, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 49/1746 7% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.263, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The \u001b[1mmount \u001b[22mprogram does not read the \u001b[4m/etc/fstab\u001b[24m file if both \u001b[4mdevice\u001b[24m (or LABEL, UUID, ID, PARTUUID or PARTLABEL) and \u001b[4mdir\u001b[24m are specified. For example, to mount device \u001b[1mfoo \u001b[22mat \u001b[1m/dir\u001b[22m:\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 50/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 51/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "        \u001b[1mmount /dev/foo /dir\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 52/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.031, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 53/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     This default behaviour can be changed by using the \u001b[1m--\u001b[01;44;33moption\u001b[0m\u001b[1ms-source-force \u001b[22mcommand-line \u001b[01;44;33moption\u001b[0m\u001b[1m\u001b[22m to always read configuration from \u001b[4mfstab\u001b[24m. For non-root users \u001b[1mmount \u001b[22malways reads the \u001b[4mfstab\u001b[24m configuration.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 54/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.026, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 55/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.033, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "   \u001b[1mNon-superuser mounts\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 56/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     Normally, only the superuser can mount filesystems. However, when \u001b[4mfstab\u001b[24m contains the \u001b[1muser \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[1m\u001b[22m on a line, anybody can mount the corresponding filesystem.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 57/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 58/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     Thus, given a line\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 59/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.033, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 60/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "        \u001b[1m/dev/cdrom /cd iso9660 ro,user,noauto,unhide\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 61/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 62/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     any user can mount the iso9660 filesystem found on an inserted CDROM using the command:\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 63/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 64/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "        \u001b[1mmount /cd\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 65/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 66/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     Note  that  \u001b[1mmount \u001b[22mis very strict about non-root users and all paths specified on command line are verified before \u001b[4mfstab\u001b[24m is parsed or a helper program is executed. It’s strongly recommended to use a valid mountpoint to specify filesys‐\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 67/1746 8% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.029, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     tem, otherwise \u001b[1mmount \u001b[22mmay fail. For example it’s a bad idea to use NFS or CIFS source on command line.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 68/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 69/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     Since util-linux 2.35, \u001b[1mmount \u001b[22mdoes not exit when user permissions are inadequate according to libmount’s internal security rules. Instead, it drops suid permissions and  continues  as  regular  non-root  user.  This  behavior  supports\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 70/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.036, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     use-cases where root permissions are not necessary (e.g., fuse filesystems, user namespaces, etc).\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 71/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 72/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     For  more details, see \u001b[1mfstab\u001b[22m(5). Only the user that mounted a filesystem can unmount it again. If any user should be able to unmount it, then use \u001b[1musers \u001b[22minstead of \u001b[1muser \u001b[22min the \u001b[4mfstab\u001b[24m line. The \u001b[1mowner \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[1m\u001b[22m is similar to the \u001b[1muser \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[22m\u001b[1m\u001b[22m,\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 73/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     with the restriction that the user must be the owner of the special file. This may be useful e.g. for \u001b[4m/dev/fd\u001b[24m if a login script makes the console user owner of this device. The \u001b[1mgroup \u001b[22m\u001b[01;44;33moption\u001b[0m\u001b[24m\u001b[1m\u001b[22m is similar, with the  restriction  that  the\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 74/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     user must be a member of the group of the special file.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 75/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.365, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 76/1746 9% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.256, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     The  \u001b[1muser  \u001b[22mmount  \u001b[01;44;33moption\u001b[0m\u001b[1m\u001b[22m  is accepted if no username is specified. If used in the format \u001b[1muser=someone\u001b[22m, the \u001b[01;44;33moption\u001b[0m\u001b[22m\u001b[1m\u001b[22m is silently ignored and visible only for external mount helpers (/sbin/mount.<type>) for compatibility with some network\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 77/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     filesystems.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 78/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.029, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 79/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "   \u001b[1mBind mount operation\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 80/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     Remount part of the file hierarchy somewhere else. The call is:\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 81/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 82/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "        \u001b[1mmount --bind \u001b[4m\u001b[22molddir\u001b[24m \u001b[4mnewdir\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 83/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.031, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 84/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.037, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     or by using this \u001b[4mfstab\u001b[24m entry:\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 85/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.027, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 86/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b["]
[0.000, "o", "\u001b[KB\bB\r\u001b[K        \u001b[1m/\u001b[4m\u001b[22molddir\u001b[24m \u001b[1m/\u001b[4m\u001b[22mnewdir\u001b[24m \u001b[1mnone bind\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 87/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.027, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 88/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.033, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     After this call the same contents are accessible in two places.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 89/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 90/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.026, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     It is important to understand that \"bind\" does not create any second-class or special node in the kernel VFS. The \"bind\" is just another operation to attach a filesystem. There is nowhere stored information  that  the  filesystem  has\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 91/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.034, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     been attached by a \"bind\" operation. The \u001b[4molddir\u001b[24m and \u001b[4mnewdir\u001b[24m are independent and the \u001b[4molddir\u001b[24m may be unmounted.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 92/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.029, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 93/1746 10% (press h for help or q to quit)\u001b[0m\u001b[K"]
[1.071, "o", "\r\u001b[K/"]
[0.335, "o", "\u001b[Kg\bg"]
[0.372, "o", "\u001b[Ki\bi"]
[0.207, "o", "\u001b[Kd\bd"]
[0.265, "o", "\r\u001b[K"]
[0.000, "o", "\u001b[1;1H\u001b[K     The command\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K        \u001b[1mmount -a \u001b[22m[\u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m] [\u001b[1m-O \u001b[4m\u001b[22moptlist\u001b[24m]\u001b[m\r\n\u001b[4;1H\u001b[K\u001b[m\r\n\u001b[5;1H\u001b[K     (usually given in a bootscript) causes all filesystems mentioned in \u001b[4mfstab\u001b[24m (of the proper type and/or having or not having the proper options) to be mounted as indicated, except for those whose line contains the \u001b[1mnoauto \u001b[22mkeyword.  Adding\u001b[m\r\n\u001b[6;1H\u001b[K     the \u001b[1m-F \u001b[22moption will make \u001b[1mmount \u001b[22mfork, so that the filesystems are mounted in parallel.\u001b[m\r\n\u001b[7;1H\u001b[K\u001b[m\r\n\u001b[8;1H\u001b[K     When mounting a filesystem mentioned in \u001b[4mfstab\u001b[24m or \u001b[4mmtab\u001b[24m, it suffices to specify on the command line only the device, or only the mount point.\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[m\r\n\u001b[10;1H\u001b[K     The  programs  \u001b[1mmount \u001b[22mand \u001b[1mumount\u001b[22m(8) traditionally maintained a list of currently mounted filesystems in the file \u001b[4m/etc/mtab\u001b[24m. The support for regular classic \u001b[4m/etc/mtab\u001b[24m is completely disabled at compile time by default, because on cu"]
[0.001, "o", "rrent\u001b[m\r\n\u001b[11;1H\u001b[K     Linux systems it is better to make \u001b[4m/etc/mtab\u001b[24m a symlink to \u001b[4m/proc/mounts\u001b[24m instead. The regular \u001b[4mmtab\u001b[24m file maintained in userspace cannot reliably work with namespaces, containers and other advanced Linux features. If the regular \u001b[4mmtab\u001b[24m sup‐\u001b[m\r\n\u001b[12;1H\u001b[K     port is enabled, then it’s possible to use the file as well as the symlink.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K     If no arguments are given to \u001b[1mmount\u001b[22m, the list of mounted filesystems is printed.\u001b[m\r\n\u001b[15;1H\u001b[K\u001b[m\r\n\u001b[16;1H\u001b[K     If you want to override mount options from \u001b[4m/etc/fstab\u001b[24m, you have to use the \u001b[1m-o \u001b[22moption:\u001b[m\r\n\u001b[17;1H\u001b[K\u001b[m\r\n\u001b[18;1H\u001b[K        \u001b[1mmount \u001b[4m\u001b[22mdevice\u001b[24m|\u001b[4mdir\u001b[24m \u001b[1m-o \u001b[4m\u001b[22moptions\u001b[0m\u001b[m\r\n\u001b[19;1H\u001b[K\u001b[m\r\n\u001b[20;1H\u001b[K     and then the mount options from the command line will be appended to the list of options from \u001b[4m/etc/fstab\u001b[24m. This default behaviour can be changed using the \u001b[1m--options-mode \u001b[22mcommand-line option. The usual behavior is that the  last  option\u001b[m\r\n\u001b[21;1H\u001b[K     wins if there are conflicting ones.\u001b[m\r\n\u001b[22;1H\u001b[K\u001b[m\r\n\u001b[23;1H\u001b[K     The \u001b[1mmount \u001b[22mprogram does not read the \u001b[4m/etc/fstab\u001b[24m file if both \u001b[4mdevice\u001b[24m (or LABEL, UUID, ID, PARTUUID or PARTLABEL) and \u001b[4mdir\u001b[24m are specified. For example, to mount device \u001b[1mfoo \u001b[22mat \u001b[1m/dir\u001b[22m:\u001b[m\r\n\u001b[24;1H\u001b[K\u001b[m\r\n\u001b[25;1H\u001b[K        \u001b[1mmount /dev/foo /dir\u001b[0m\u001b[m\r\n\u001b[26;1H\u001b[K\u001b[m\r\n\u001b[27;1H\u001b[K     This default behaviour can be changed by using the \u001b[1m--options-source-force \u001b[22mcommand-line option to always read configuration from \u001b[4mfstab\u001b[24m. For non-root users \u001b[1mmount \u001b[22malways reads the \u001b[4mfstab\u001b[24m configuration.\u001b[m\r\n\u001b[28;1H\u001b[K\u001b[m\r\n\u001b[29;1H\u001b[K   \u001b[1mNon-superuser mounts\u001b[0m\u001b[m\r\n\u001b[30;1H\u001b[K     Normally, only the superuser can mount filesystems. However, when \u001b[4mfstab\u001b[24m contains the \u001b[1muser \u001b[22moption on a line, anybody can mount the corresponding filesystem.\u001b[m\r\n\u001b[31;1H\u001b[K\u001b[m\r\n\u001b[32;1H\u001b[K     Thus, given a line\u001b[m\r\n\u001b[33;1H\u001b[K\u001b[m\r\n\u001b[34;1H\u001b[K        \u001b[1m/dev/cdrom /cd iso"]
[0.001, "o", "9660 ro,user,noauto,unhide\u001b[0m\u001b[m\r\n\u001b[35;1H\u001b[K\u001b[m\r\n\u001b[36;1H\u001b[K     any user can mount the iso9660 filesystem found on an inserted CDROM using the command:\u001b[m\r\n\u001b[37;1H\u001b[K\u001b[m\r\n\u001b[38;1H\u001b[K        \u001b[1mmount /cd\u001b[0m\u001b[m\r\n\u001b[39;1H\u001b[K\u001b[m\r\n\u001b[40;1H\u001b[K     Note  that  \u001b[1mmount \u001b[22mis very strict about non-root users and all paths specified on command line are verified before \u001b[4mfstab\u001b[24m is parsed or a helper program is executed. It’s strongly recommended to use a valid mountpoint to specify filesys‐\u001b[m\r\n\u001b[41;1H\u001b[K     tem, otherwise \u001b[1mmount \u001b[22mmay fail. For example it’s a bad idea to use NFS or CIFS source on command line.\u001b[m\r\n\u001b[42;1H\u001b[K\u001b[m\r\n\u001b[43;1H\u001b[K     Since util-linux 2.35, \u001b[1mmount \u001b[22mdoes not exit when user permissions are inadequate according to libmount’s internal security rules. Instead, it drops suid permissions and  continues  as  regular  non-root  user.  This  behavior  supports\u001b[m\r\n\u001b[44;1H\u001b[K     use-cases where root permissions are not necessary (e.g., fuse filesystems, user namespaces, etc).\u001b[m\r\n\u001b[45;1H\u001b[K\u001b[m\r\n\u001b[46;1H\u001b[K     For  more details, see \u001b[1mfstab\u001b[22m(5). Only the user that mounted a filesystem can unmount it again. If any user should be able to unmount it, then use \u001b[1musers \u001b[22minstead of \u001b[1muser \u001b[22min the \u001b[4mfstab\u001b[24m line. The \u001b[1mowner \u001b[22moption is similar to the \u001b[1muser \u001b[22moption,\u001b[m\r\n\u001b[47;1H\u001b[K     with the restriction that the user must be the owner of the special file. This may be useful e.g. for \u001b[4m/dev/fd\u001b[24m if a login script makes the console user owner of this device. The \u001b[1mgroup \u001b[22moption is similar, with the  restriction  that  the\u001b[m\r\n\u001b[48;1H\u001b[K     user must be a member of the group of the special file.\u001b[m\r\n\u001b[49;1H\u001b[K\u001b[m\r\n\u001b[50;1H\u001b[K     The  \u001b[1muser  \u001b[22mmount  option  is accepted if no username is specified. If used in the format \u001b[1muser=someone\u001b[22m, the option is silently ignored and visible only for external mount helpers (/sbin/mount.<type>) for compatibility with some network\u001b[m\r\n\u001b[51;1H\u001b[K     filesystems.\u001b[m\r\n\u001b[52;1H\u001b[K\u001b[m\r\n\u001b[53;1H\u001b[K   \u001b[1mBind mount operation\u001b[0m\u001b[m\r\n\u001b[54;1H\u001b[K     Remount part of the file hierarchy somewhere else. The call is:\u001b[m\r\n\u001b[55;1H\u001b[K\u001b[m\r\n\u001b[56;1H\u001b[K        \u001b[1mmount --bind \u001b[4m\u001b[22molddir\u001b[24m \u001b[4mnewdir\u001b[0m\u001b[m\r\n\u001b[57;1H\u001b[K\u001b[m\r\n\u001b[58;1H\u001b[K     or by using this \u001b[4mfstab\u001b[24m entry:\u001b[m\r\n\u001b[59;1H\u001b[K\u001b[m\r\n\u001b[60;1H\u001b[K        \u001b[1m/\u001b[4m\u001b[22molddir\u001b[24m \u001b[1m/\u001b[4m\u001b[22mnewdir\u001b[24m \u001b[1mnone bind\u001b[0m\u001b[m\r\n\u001b[61;1H\u001b[K\u001b[m\r\n\u001b[62;1H\u001b[K     After this call the same contents are accessible in two places.\u001b[m\r\n\u001b[63;1H\u001b[K\u001b[m\r\n\u001b[64;1H\u001b[K     It is important to understand that \"bind\" does not create any second-class or special node in the kernel VFS. The \"bind\" is just another operation to attach a filesystem. There is nowhere stored information  that  the  filesystem  has\u001b[m\r\n\u001b[65;1H\u001b[K     been attached by a \"bind\" operation. The \u001b[4molddir\u001b[24m and \u001b[4mnewdir\u001b[24m are independent and the \u001b[4molddir\u001b[24m may be unmounted.\u001b[m\r\n\u001b[66;1H\u001b[K\u001b[m\r\n\u001b[67;1H\u001b[1;1H\u001b[K     The command\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K        \u001b[1mmount -a \u001b[22m[\u001b[1m-t \u001b[4m\u001b[22mtype\u001b[24m] [\u001b[1m-O \u001b[4m\u001b[22moptlist\u001b[24m]\u001b[m\r\n\u001b[4;1H\u001b[K\u001b[m\r\n\u001b[5;1H\u001b[K     (usually given in a bootscript) causes all filesystems mentioned in \u001b[4mfstab\u001b[24m (of the proper type and/or having or not having the proper options) to be mounted as indicated, except for those whose line contains the \u001b[1mnoauto \u001b[22mkeyword.  Adding\u001b[m\r\n\u001b[6;1H\u001b[K     the \u001b[1m-F \u001b[22moption will make \u001b[1mmount \u001b[22mfork, so that the filesystems are mounted in parallel.\u001b[m\r\n\u001b[7;1H\u001b[K\u001b[m\r\n\u001b[8;1H\u001b[K     When mounting a filesystem mentioned in \u001b[4mfstab\u001b[24m or \u001b[4mmtab\u001b[24m, it suffices to specify on the command line only the device, or only the mount point.\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[m\r\n\u001b[10;1H\u001b[K     The  programs  \u001b[1mmount \u001b[22mand \u001b[1mumount\u001b[22m(8) traditionally maintained a list of currently mounted filesystems in the file \u001b[4m/etc/mtab\u001b[24m. The support for regular classic \u001b[4m/etc/mtab\u001b[24m is completely disabled at compile time by default, because on current\u001b[m\r\n\u001b[11;1H\u001b[K     Linux systems it is better to make \u001b[4m/etc/mtab\u001b[24m a sym"]
[0.000, "o", "link to \u001b[4m/proc/mounts\u001b[24m instead. The regular \u001b[4mmtab\u001b[24m file maintained in userspace cannot reliably work with namespaces, containers and other advanced Linux features. If the regular \u001b[4mmtab\u001b[24m sup‐\u001b[m\r\n\u001b[12;1H\u001b[K     port is enabled, then it’s possible to use the file as well as the symlink.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K     If no arguments are given to \u001b[1mmount\u001b[22m, the list of mounted filesystems is printed.\u001b[m\r\n\u001b[15;1H\u001b[K\u001b[m\r\n\u001b[16;1H\u001b[K     If you want to override mount options from \u001b[4m/etc/fstab\u001b[24m, you have to use the \u001b[1m-o \u001b[22moption:\u001b[m\r\n\u001b[17;1H\u001b[K\u001b[m\r\n\u001b[18;1H\u001b[K        \u001b[1mmount \u001b[4m\u001b[22mdevice\u001b[24m|\u001b[4mdir\u001b[24m \u001b[1m-o \u001b[4m\u001b[22moptions\u001b[0m\u001b[m\r\n\u001b[19;1H\u001b[K\u001b[m\r\n\u001b[20;1H\u001b[K     and then the mount options from the command line will be appended to the list of options from \u001b[4m/etc/fstab\u001b[24m. This default behaviour can be changed using the \u001b[1m--options-mode \u001b[22mcommand-line option. The usual behavior is that"]
[0.003, "o", " the  last  option\u001b[m\r\n\u001b[21;1H\u001b[K     wins if there are conflicting ones.\u001b[m\r\n\u001b[22;1H\u001b[K\u001b[m\r\n\u001b[23;1H\u001b[K     The \u001b[1mmount \u001b[22mprogram does not read the \u001b[4m/etc/fstab\u001b[24m file if both \u001b[4mdevice\u001b[24m (or LABEL, UUID, ID, PARTUUID or PARTLABEL) and \u001b[4mdir\u001b[24m are specified. For example, to mount device \u001b[1mfoo \u001b[22mat \u001b[1m/dir\u001b[22m:\u001b[m\r\n\u001b[24;1H\u001b[K\u001b[m\r\n\u001b[25;1H\u001b[K        \u001b[1mmount /dev/foo /dir\u001b[0m\u001b[m\r\n\u001b[26;1H\u001b[K\u001b[m\r\n\u001b[27;1H\u001b[K     This default behaviour can be changed by using the \u001b[1m--options-source-force \u001b[22mcommand-line option to always read configuration from \u001b[4mfstab\u001b[24m. For non-root users \u001b[1mmount \u001b[22malways reads the \u001b[4mfstab\u001b[24m configuration.\u001b[m\r\n\u001b[28;1H\u001b[K\u001b[m\r\n\u001b[29;1H\u001b[K   \u001b[1mNon-superuser mounts\u001b[0m\u001b[m\r\n\u001b[30;1H\u001b[K     Normally, only the superuser can mount filesystems. However, when \u001b[4mfstab\u001b[24m contains the \u001b[1muser \u001b[22moption on a line, anybody can mount the corresponding filesystem.\u001b[m\r\n\u001b[31;1H\u001b[K\u001b[m\r\n\u001b[32;1H\u001b[K     Thus, given a line\u001b[m\r\n\u001b[33;1H\u001b[K\u001b[m\r\n\u001b[34;1H\u001b[K        \u001b[1m/dev/cdrom /cd iso9660 ro,user,noauto,unhide\u001b[0m\u001b[m\r\n\u001b[35;1H\u001b[K\u001b[m\r\n\u001b[36;1H\u001b[K     any user can mount the iso9660 filesystem found on an inserted CDROM using the command:\u001b[m\r\n\u001b[37;1H\u001b[K\u001b[m\r\n\u001b[38;1H\u001b[K        \u001b[1mmount /cd\u001b[0m\u001b[m\r\n\u001b[39;1H\u001b[K\u001b[m\r\n\u001b[40;1H\u001b[K     Note  that  \u001b[1mmount \u001b[22mis very strict about non-root users and all paths specified on command line are verified before \u001b[4mfstab\u001b[24m is parsed or a helper program is executed. It’s strongly recommended to use a valid mountpoint to specify filesys‐\u001b[m\r\n\u001b[41;1H\u001b[K     tem, otherwise \u001b[1mmount \u001b[22mmay fail. For example it’s a bad idea to use NFS or CIFS source on command line.\u001b[m\r\n\u001b[42;1H\u001b[K\u001b[m\r\n\u001b[43;1H\u001b[K     Since util-linux 2.35, \u001b[1mmount \u001b[22mdoes not exit when user permissions are inadequate according to libmount’s internal security rules. Instead, it drops suid permissions and  continues  as  regular  non-root  user.  This  behavior  supports\u001b[m\r\n\u001b[44;1H\u001b[K     use-cases where root permissions are not necessary (e.g., fuse filesystems, user namespaces, etc).\u001b[m\r\n\u001b[45;1H\u001b[K\u001b[m\r\n\u001b[46;1H\u001b[K     For  more details, see \u001b[1mfstab\u001b[22m(5). Only the user that mounted a filesystem can unmount it again. If any user should be able to unmount it, then use \u001b[1musers \u001b[22minstead of \u001b[1muser \u001b[22min the \u001b[4mfstab\u001b[24m line. The \u001b[1mowner \u001b[22moption is similar to the \u001b[1muser \u001b[22moption,\u001b[m\r\n\u001b[47;1H\u001b[K     with the restriction that the user must be the owner of the special file. This may be useful e.g. for \u001b[4m/dev/fd\u001b[24m if a login script makes the console user owner of this device. The \u001b[1mgroup \u001b[22moption is similar, with the  restriction  that  the\u001b[m\r\n\u001b[48;1H\u001b[K     user must be a member of the group of the special file.\u001b[m\r\n\u001b[49;1H\u001b[K\u001b[m\r\n\u001b[50;1H\u001b[K     The  \u001b[1muser  \u001b[22mmount  option  is accepted if no username is specified. If used in the format \u001b[1muser=someone\u001b[22m, the option is silently ignored and visible only for external mount helpers (/sbin/mount.<type>) for compatibility with some network\u001b[m\r\n\u001b[51;1H\u001b[K     filesystems.\u001b[m\r\n\u001b[52;1H\u001b[K\u001b[m\r\n\u001b[53;1H\u001b[K   \u001b[1mBind mount operation\u001b[0m\u001b[m\r\n\u001b[54;1H\u001b[K     Remount part of the file hierarchy somewhere else. The call is:\u001b[m\r\n\u001b[55;1H\u001b[K\u001b[m\r\n\u001b[56;1H\u001b[K        \u001b[1mmount --bind \u001b[4m\u001b[22molddir\u001b[24m \u001b[4mnewdir\u001b[0m\u001b[m\r\n\u001b[57;1H\u001b[K\u001b[m\r\n\u001b[58;1H\u001b[K     or by using this \u001b[4mfstab\u001b[24m entry:\u001b[m\r\n\u001b[59;1H\u001b[K\u001b[m\r\n\u001b[60;1H\u001b[K        \u001b[1m/\u001b[4m\u001b[22molddir\u001b[24m \u001b[1m/\u001b[4m\u001b[22mnewdir\u001b[24m \u001b[1mnone bind\u001b[0m\u001b[m\r\n\u001b[61;1H\u001b[K\u001b[m\r\n\u001b[62;1H\u001b[K     After this call the same contents are accessible in two places.\u001b[m\r\n\u001b[63;1H\u001b[K\u001b[m\r\n\u001b[64;1H\u001b[K     It is important to understand that \"bind\" does not create any second-class or special node in the kernel VFS. The \"bind\" is just another operation to attach a filesystem. There is nowhere stored information  that  the  filesystem  has\u001b[m\r\n\u001b[65;1H\u001b[K     been attached by a \"bind\" operation. The \u001b[4molddir\u001b[24m and \u001b[4mnewdir\u001b[24m are independent and the \u001b[4molddir\u001b[24m may be unmounted.\u001b[m\r\n\u001b[66;1H\u001b[K\u001b[m\r\n\u001b[67;1H...skipping...\r\n     \u001b[1mX-mount.owner\u001b[22m=\u001b[4musername\u001b[24m|\u001b[4mUID\u001b[24m, \u001b[1mX-mount.group\u001b[22m=\u001b[4mgroup\u001b[24m|\u001b[4m\u001b[01;44;33mGID\u001b[0m\u001b[4m\u001b[24m\u001b[4m\u001b[0m\u001b[m\r\n         Set \u001b[4mmountpoint\u001b[24m's ownership after mounting. Names resolved in the target mount namespace, see \u001b[1m-N\u001b[22m.\u001b[m\r\n\u001b[m\r\n     \u001b[1mX-mount.mode\u001b[22m=\u001b[4mmode\u001b[0m\u001b[m\r\n         Set \u001b[4mmountpoint\u001b[24m's mode after mounting.\u001b[m\r\n\u001b[m\r\n     \u001b[1mX-mount.idmap\u001b[22m=\u001b[4mid-type\u001b[24m:\u001b[4mid-mount\u001b[24m:\u001b[4mid-host\u001b[24m:\u001b[4mid-range\u001b[24m [\u001b[4mid-type\u001b[24m:\u001b[4mid-mount\u001b[24m:\u001b[4mid-host\u001b[24m:\u001b[4mid-range\u001b[24m], \u001b[1mX-mount.idmap\u001b[22m=\u001b[4mfile\u001b[0m\u001b[m\r\n         Use  this  option to create an idmapped mount. An idmapped mount allows to change ownership of all files located under a mount according to the ID-mapping associated with a user namespace. The ownership change is tied to the life‐\u001b[m\r\n         time and localized to the relevant mount. The relevant ID-mapping can be specified in two ways:\u001b[m\r\n\u001b[m\r\n         •   A user can specify the ID-mapping directly.\u001b[m\r\n\u001b[m\r\n             The ID-mapping must be specified using the syntax \u001b[4mid-type\u001b[24m:\u001b[4mid-mount\u001b[24m:\u001b[4mid-host\u001b[24m:\u001b[4mid-range\u001b[24m. Specifying \u001b[1mu \u001b[22mas the \u001b[4mid-type\u001b[24m prefix creates a UID-mapping, \u001b[1mg \u001b[22mcreates a \u001b[01;44;33mGID\u001b[0m\u001b[24m\u001b[1m\u001b[22m-mapping and omitting \u001b[4mid-type\u001b[24m or specifying \u001b[1mb \u001b[22mcreates  both  a  UID-\u001b[m\r\n             and  \u001b[01;44;33mGID\u001b[0m-mapping. The \u001b[4mid-mount\u001b[24m parameter indicates the starting ID in the new mount. The \u001b[4mid-host\u001b[24m parameter indicates the starting ID in the filesystem. The \u001b[4mid-range\u001b[24m parameter indicates how many IDs are to be mapped. It is pos‐\u001b[m\r\n             sible to specify multiple ID-mappings.\u001b[m\r\n\u001b[m\r\n             The individual ID mappings must be separated by spaces. Please note that in the \u001b[4m/etc/fstab\u001b[24m file, spaces are  interpreted  as  separators  between  fields.  To  avoid  this,  you  must  escape  them  using  \\040.  For  example,\u001b[m\r\n             X-mount.idmap=0:0:1\\040500:1000:1.\u001b[m\r\n\u001b[m\r\n             For example, the ID-mapping \u001b[1mX-mount.idmap=u:1000:0:1 g:1001:1:2 5000:1000:2 \u001b[22mcreates an idmapped mount where UID 0 is mapped to UID 1000, \u001b[01;44;33mGID\u001b[0m\u001b[1m\u001b[22m 1 is mapped to GUID 1001, \u001b[01;44;33mGID\u001b[0m\u001b[1m\u001b[22m 2 is mapped to \u001b[01;44;33mGID\u001b[0m\u001b[1m\u001b[22m 1002, UID and \u001b[01;44;33mGID\u001b[0m\u001b[1m\u001b[22m 1000 are mapped to\u001b[m\r\n             5000, and UID and \u001b[01;44;33mGID\u001b[0m 1001 are mapped to 5001 in the mount.\u001b[m\r\n\u001b[m\r\n             When an ID-mapping is specified directly a new user namespace will be allocated with the requested ID-mapping. The newly created user namespace will be attached to the mount.\u001b[m\r\n\u001b[m\r\n         •   A user can specify a user namespace file.\u001b[m\r\n\u001b[m\r\n             The user namespace will then be attached to the mount and the ID-mapping of the user namespace will become the ID-mapping of the mount.\u001b[m\r\n\u001b[m\r\n             For example, \u001b[1mX-mount.idmap=/proc/PID/ns/user \u001b[22mwill attach the user namespace of the process PID to the mount.\u001b[m\r\n\u001b[m\r\n     \u001b[1mnosymfollow\u001b[0m\u001b[m\r\n         Do not follow symlinks when resolving paths. Symlinks can still be created, and \u001b[1mreadlink\u001b[22m(1), \u001b[1mreadlink\u001b[22m(2), \u001b[1mrealpath\u001b[22m(1), and \u001b[1mrealpath\u001b[22m(3) all still work properly.\u001b[m\r\n\u001b[m\r\n\u001b[1mFILESYSTEM-SPECIFIC MOUNT OPTIONS\u001b[0m\u001b[m\r\n"]
[0.000, "o", "     This section lists options that are specific to particular filesystems. Where possible, you should first consult filesystem-specific manual pages for details. Some of those pages are listed in the following table.\u001b[m\r\n     ┌──────────────────┬───────────────┐\u001b[m\r\n"]
[0.051, "o", "     │                  │               │\u001b[m\r\n     │ \u001b[1mFilesystem(s)    \u001b[22m│ \u001b[1mManual page   \u001b[22m│\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ btrfs            │ \u001b[1mbtrfs\u001b[22m(5)      │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ cephfs           │ \u001b[1mmount.ceph\u001b[22m(8) │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ cifs             │ \u001b[1mmount.cifs\u001b[22m(8) │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ ext2, ext3, ext4 │ \u001b[1mext4\u001b[22m(5)       │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ fuse             │ \u001b[1mfuse\u001b[22m(8)       │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ nfs              │ \u001b[1mnfs\u001b[22m(5)        │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ tmpfs            │ \u001b[1mtmpfs\u001b[22m(5)      │\u001b[m\r\n     ├──────────────────┼───────────────┤\u001b[m\r\n     │                  │               │\u001b[m\r\n     │ xfs              │ \u001b[1mxfs\u001b[22m(5)        │\u001b[m\r\n     └──────────────────┴───────────────┘\u001b[m\r\n\u001b[m\r\n     Note that some of the pages listed above might be available only after you install the respective userland tools.\u001b[m\r\n\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 737/1746 52% (press h for help or q to quit)\u001b[0m\u001b[K"]
[7.338, "o", "\r\u001b[K/\r\u001b[K"]
[0.000, "o", "     The following options apply only to certain filesystems. We sort them by filesystem. All options follow the \u001b[1m-o \u001b[22mflag.\u001b[m\r\n\u001b[m\r\n"]
[0.003, "o", "     What options are supported depends a bit on the running kernel. Further information may be available in filesystem-specific files in the kernel source subdirectory \u001b[4mDocumentation/filesystems\u001b[24m.\u001b[m\r\n\u001b[m\r\n   \u001b[1mMount options for adfs\u001b[0m\u001b[m\r\n     \u001b[1muid=\u001b[4m\u001b[22mvalue\u001b[24m and \u001b[1m\u001b[01;44;33mgid\u001b[0m\u001b[22m\u001b[24m\u001b[1m=\u001b[4m\u001b[22mvalue\u001b[0m\u001b[m\r\n         Set the owner and group of the files in the filesystem (default: uid=\u001b[01;44;33mgid\u001b[0m=0).\u001b[m\r\n\u001b[m\r\n     \u001b[1mownmask=\u001b[4m\u001b[22mvalue\u001b[24m and \u001b[1mothmask=\u001b[4m\u001b[22mvalue\u001b[0m\u001b[m\r\n         Set the permission mask for ADFS 'owner' permissions and 'other' permissions, respectively (default: 0700 and 0077, respectively). See also \u001b[4m/usr/src/linux/Documentation/filesystems/adfs.rst\u001b[24m.\u001b[m\r\n\u001b[m\r\n   \u001b[1mMount options for affs\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 749/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[2.006, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     \u001b[1muid=\u001b[4m\u001b[22mvalue\u001b[24m and \u001b[1m\u001b[01;44;33mgid\u001b[0m\u001b[22m\u001b[24m\u001b[1m=\u001b[4m\u001b[22mvalue\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 750/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.257, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "         Set the owner and group of the root of the filesystem (default: uid=\u001b[01;44;33mgid\u001b[0m=0, but with option \u001b[1muid \u001b[22mor \u001b[1m\u001b[01;44;33mgid\u001b[0m\u001b[1m\u001b[22m\u001b[1m \u001b[22mwithout specified value, the UID and \u001b[01;44;33mGID\u001b[0m\u001b[22m\u001b[1m\u001b[22m of the current process are taken).\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 751/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 752/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.026, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     \u001b[1msetuid=\u001b[4m\u001b[22mvalue\u001b[24m and \u001b[1mset\u001b[01;44;33mgid\u001b[0m\u001b[22m\u001b[24m\u001b[1m=\u001b[4m\u001b[22mvalue\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 753/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "         Set the owner and group of all files.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 754/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 755/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.033, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     \u001b[1mmode=\u001b[4m\u001b[22mvalue\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 756/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.027, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "         Set the mode of all files to \u001b[4mvalue\u001b[24m & 0777 disregarding the original permissions. Add search permission to directories that have read permission. The value is given in octal.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 757/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 758/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "     \u001b[1mprotect\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 759/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.033, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "         Do not allow any changes to the protection bits on the filesystem.\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 760/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.026, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 761/1746 53% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.001, "o", "     \u001b[1musemp\u001b[0m\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 762/1746 54% (press h for help or q to quit)\u001b[0m\u001b[K"]
[0.030, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[K[\b[\u001b[KB\bB\r\u001b[K"]
[0.000, "o", "         Set UID and \u001b[01;44;33mGID\u001b[0m of the root of the filesystem to the UID and \u001b[01;44;33mGID\u001b[0m of the mount point upon the first sync or umount, and then clear this option. Strange...\u001b[m\r\n\u001b[01;44;33m Manual page mount(8) line 763/1746 54% (press h for help or q to quit)\u001b[0m\u001b[K"]
