[0.015, "o", "\u001b[1;3HoadModule dav_module modules/mod_dav.so\u001b[2;2H\u001b[96moadModule\u001b[m\u000f status_module modules/mod_status.so\r\n\u001b[96mLoadModule\u001b[m\u000f autoindex_module modules/mod_autoindex.so\u001b[4;2HLoadModule asis_module modules/mod_asis.so\u001b[5;2HLoadModule info_module modules/mod_info.so\u001b[6;2HLoadModule suexec_module modules/mod_suexec.so\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f !mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[48X\r\n        #LoadModule cgid_module modules/mod_cgid.so\u001b[21X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[64X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[41X\r\n        #LoadModule cgi_module modules/mod_cgi.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[13;2H\u001b[m\u000fLoadModule dav_fs_module modules/mod_dav_fs.so\u001b[14;2HLoadModule dav_lock_module modules/mod_dav_lock.so\u001b[15;2HLoadModule vhost_alias_module modules/mod_vhost_alias.so\u001b[16;12Hnegotiation_module modules/mod_negotiation.so\r\n\u001b[96mLoadModule\u001b[m\u000f dir_module modules/mod_dir.so\u001b[17X\u001b[18;13Himagemap_module modules/mod_imagemap.so    \r\n#LoadModule actions_module modules/mod_actions.so\u001b[5X\u001b[20;13Hspeling_module modules/mod_speling.so    \r\n\u001b[96mLoadModule\u001b[m\u000f userdir_module modules/mod_userdir.so\u001b[7X\r\n\u001b[96mLoadModule\u001b[m\u000f alias_module modules/mod_alias.so\u001b[9X\r\n\u001b[96mLoadModule\u001b[m\u000f \u001b[30m\u001b[103mrew\u001b[m\u000frite_module modules/mod_\u001b[30m\u001b[103mrew\u001b[m\u000frite.so\u001b[13X\r\n\u001b[54X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[31X\r\n#\u001b[63X\r\n# If you wish httpd to run as a different user or group, you must run\u001b[28;2H httpd as root initially and it will switch.  \u001b[6X\u001b[29;2H\u001b[56X\n User/Group: The name (or #number) of the user/group to run httpd as.\r\n# It is usually good practice to create a dedicated user and group for\u001b[32;2H running httpd, as with most system services.\u001b[11X\u001b[33;2H\u001b[56X\r\n\u001b[96mUser\u001b[m\u000f http\u001b[51X\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[44X\r\n\u001b[53X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[46X\r\n\u001b[59X\u001b[39;2H 'Main' server configuration\u001b[26X\u001b[40;2H\u001b[44X\n The directives in this section set up the values used by the 'main'\u001b[42;2H server, which responds to any requests that aren't handled by a\u001b[43;2H <VirtualHost> definition.  These values also provide defaults for\u001b[44;2H any <VirtualHost> containers you may define later in the file.\u001b[45;2H\u001b[66X\n All of these directives may appear inside <VirtualHost> containers,\u001b[47;153H\u001b[0;10;7m\u000f189,12         33\u001b[48;5H\u001b[?25h"]
