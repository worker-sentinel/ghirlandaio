[0.016, "o", "\u001b[1;2H directive.\u001b[29X\r\n#\u001b[45X\r\n# Change this to Listen on specific IP addresses as shown below to \u001b[4;2H prevent Apache from glomming onto all bound IP addresses.\u001b[5;2H\u001b[42X\u001b[6;3Histen 12.34.56.78:80\u001b[25X\r\n\u001b[96mListen\u001b[m\u000f 80\u001b[21X\r\n\u001b[51X\n#\u001b[10X\r\n# Dynamic Shared Object (DSO) Support\r\n#\u001b[48X\r\n# To be able to use the functionality of a module which was built as a DSO you\u001b[13;2H have to place corresponding `LoadModule' lines at this location so the\u001b[14;2H directives contained in it are actually available _before_ they are used.\u001b[15;2H Statically compiled modules (those listed by `httpd -l') do not need\r\n# to be loaded here.\u001b[36X\r\n#\u001b[39X\n Example:\u001b[41X\u001b[19;2H LoadModule foo_module modules/mod_foo.so\u001b[7X\u001b[20;2H\u001b[48X\u001b[21;12Hmpm_event_module modules/mod_mpm_event.so\r\n#LoadModule mpm_prefork_module modules/mod_mpm_prefork.so\r\n#LoadModule mpm_worker_module modules/mod_mpm_worker.so\r\n\u001b[96mLoadModule\u001b[m\u000f authn_file_module modules/mod_authn_file.so\r\n#LoadModule authn_dbm_module modules/mod_authn_dbm.so\u001b[26;2HLoadModule authn_anon_module modules/mod_authn_anon.so\u001b[27;2HLoadModule authn_dbd_module modules/mod_authn_dbd.so\u001b[16X\u001b[28;2HLoadModule authn_socache_module modules/mod_authn_socache.so\r\n\u001b[96mLoadModule\u001b[m\u000f authn_core_module modules/mod_authn_core.so\r\n\u001b[96mLoadModule\u001b[m\u000f authz_host_module modules/mod_authz_host.so\u001b[16X\r\n\u001b[96mLoadModule\u001b[m\u000f authz_groupfile_module modules/mod_authz_groupfile.so\u001b[6X\r\n\u001b[96mLoadModule\u001b[m\u000f authz_user_module modules/mod_authz_user.so\u001b[33;2HLoadModule authz_dbm_module modules/mod_authz_dbm.so\r\n#LoadModule authz_owner_module modules/mod_authz_owner.so\r\n#LoadModule authz_dbd_module modules/mod_authz_dbd.so\r\n\u001b[96mLoadModule\u001b[m\u000f authz_core_module modules/mod_authz_core.so\r\n#LoadModule authnz_ldap_module modules/mod_authnz_ldap.so\r\n#LoadModule authnz_fcgi_module modules/mod_authnz_fcgi.so\r\n\u001b[96mLoadModule\u001b[m\u000f access_compat_module modules/mod_access_compat.so\r\n\u001b[96mLoadModule\u001b[m\u000f auth_basic_module modules/mod_auth_basic.so\u001b[41;2HLoadModule auth_form_module modules/mod_auth_form.so\u001b[16X\u001b[42;2HLoadModul"]
