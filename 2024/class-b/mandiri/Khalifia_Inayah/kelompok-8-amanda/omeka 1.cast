[0.011, "o", "\u001b[H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mPHP\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[m\u000f\r\n\u001b[20X\u001b[3;2H;;;;;;;;;;;;;;;;;;\u001b[4;3HAbout php.ini   ;\u001b[57X\u001b[5;2H;;;;;;;;;;;;;;;;;;\u001b[47X\u001b[6;2H PHP's initialization file, generally called php.ini, is responsible for\u001b[7;3Hconfiguring many of the aspects of PHP's behavior.\r\n \u001b[9;3HPHP attempts to find and load this configuration from a number of locations.\u001b[10;3HThe following is a summary of its search order:\u001b[23X\u001b[11;3H1. SAPI module specific location.\u001b[40X\u001b[12;3H2. The PHPRC environment variable.\u001b[8X\u001b[13;2H 3. A number of predefined registry keys on Windows\u001b[14;2H 4. Current working directory (except CLI)\u001b[15;2H 5. The web server's directory (for SAPI modules), or directory of PHP\u001b[16;2H (otherwise in Windows)\r\n; 6. The directory from the --with-config-file-path compile time option, or the\u001b[18;2H Windows directory (usually C:\\windows)\u001b[19;2H See the PHP docs for more specific information.\u001b[20;2H https://php.net/configuration.file\r\n\u001b[14X\u001b[22;2H The syntax of the file is extremely simple.  Whitespace and lines\u001b[23;2H beginning with a semicolon are silently ignored (as you probably guessed).\u001b[24;2H Section headers (e.g. [Foo]) are also silently ignored, even though\u001b[25;2H they might mean something in the future.\r\n\u001b[16X\u001b[27;2H Directives following the section heading [PATH=/www/mysite] only\u001b[28;2H apply to PHP files in the /www/mysite directory.  Directives\u001b[29;2H following the section heading [HOST=www.example.com] only apply to\u001b[30;2H PHP files served from www.example.com.  Directives set in these\u001b[31;2H special sections cannot be overridden by user-defined INI files or\u001b[32;2H at runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[33;2H CGI/FastCGI.\u001b[5X\u001b[34;2H https://php.net/ini.sections\r\n\u001b[21X\u001b[36;2H Directives are specified using the following syntax:\u001b[37;2H directive = value\u001b[38;2H Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[39;2H Directives are variables used to configure PHP or PHP extensions.\u001b[40;2H There is no name validation.  If PHP can't find an expected\u001b[41;2H directive because it is not set or is mistyped, a default value will be used.\r\n\u001b[18X\u001b[43;2H The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[44;2H of the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[45;2H (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[46;2H previously set variable or directive (e.g. ${foo})\u001b[47;153H\u001b[0;10;7m\u000f1,1            Top\u001b[48;15H\u001b[?25h"]
[1.601, "o", "\u001b[?25l\b\u001b[m\u000f \b"]
[0.007, "o", "\u001b[H;    \r\n;   extension=mysqli\u001b[3;2H\u001b[18X\u001b[4;3HWhen the extension library to load is not located in the default extension\u001b[5;2H directory, You may specify an absolute path to the library file:\u001b[6;2H\u001b[72X\u001b[7;3H  extension=/path/to/extension/mysqli.so\u001b[10X\r\n;\u001b[9;3HNote : The syntax used in previous PHP versions ('extension=<ext>.so' and   \u001b[10;3H'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[11;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[12;3Hmove to the new ('extension=<ext>) syntax.\u001b[13;2H\u001b[51X\nextension=bcmath\u001b[26X\u001b[15;2Hextension=bz2\u001b[57X\u001b[16;2Hextension=calendar\u001b[5X\r\nextension=\u001b[92mcurl\u001b[m\u000f\u001b[65X\u001b[18;2Hextension=dba\u001b[26X\u001b[19;2Hextension=enchant\u001b[31X\u001b[20;2Hextension=exif\u001b[21X\r\n;extension=ffi\u001b[22;2Hextension=ftp\u001b[53X\u001b[23;2H\u001b[30m\u001b[103mextension=gd\u001b[m\u000f\u001b[63X\u001b[24;2Hextension=gettext\u001b[51X\u001b[25;2Hextension=gmp\u001b[28X\r\n;extension=iconv\u001b[27;2Hextension=intl\u001b[51X\u001b[28;2Hextension=ldap\u001b[47X\u001b[29;2Hextension=mysqli\u001b[51X\u001b[30;2Hextension=odbc\u001b[50X\u001b[31;2Hextension=pdo_dblib\u001b[48X\u001b[32;2Hextension=pdo_mysql\u001b[49X\u001b[33;2Hextension=pdo_odbc\u001b[34;2Hextension=pdo_pgsql\u001b[10X\r\n;extension=pdo_sqlite\u001b[36;2Hextension=pgsql\u001b[38X\u001b[37;2Hextension=shmop   \u001b[38;2Hextension=snmp\u001b[60X\u001b[39;2Hextension=soap\u001b[52X\u001b[40;2Hextension=sockets\u001b[43X\u001b[41;2Hextension=sodium\u001b[62X\r\n;extension=sqlite3\u001b[43;2Hextension=sysvmsg\u001b[61X\u001b[44;2Hextension=sysvsem\u001b[62X\u001b[45;2Hextension=sysvshm\u001b[54X\u001b[46;2Hextension=tidy\u001b[37X\u001b[47;153H\u001b[0;10;7m\u000f921,2          49%\u001b[48;14H\u001b[?25h"]
