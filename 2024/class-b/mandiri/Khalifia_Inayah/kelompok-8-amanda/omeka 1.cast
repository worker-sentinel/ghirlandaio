[0.017, "o", "\u001b[1;2HLoadModule dav_module modules/mod_dav.so\r\n\u001b[96mLoadModule\u001b[m\u000f status_module modules/mod_status.so\r\n\u001b[96mLoadModule\u001b[m\u000f autoindex_module modules/mod_autoindex.so\u001b[15X\u001b[4;2HLoadModule asis_module modules/mod_asis.so\u001b[16X\u001b[5;2HLoadModule info_module modules/mod_info.so\u001b[6;3HoadModule suexec_module modules/mod_suexec.so\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f !mpm_prefork_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f        #LoadModule cgid_module modules/mod_cgid.so\r\n\u001b[0;10;1m\u000f</IfModule>\r\n<IfModule\u001b[m\u000f mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[8X\r\n        #LoadModule cgi_module modules/mod_cgi.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[67X\u001b[13;2HLoadModule dav_fs_module modules/mod_dav_fs.so\u001b[25X\u001b[14;2HLoadModule dav_lock_module modules/mod_dav_lock.so\u001b[24X\u001b[15;2HLoadModule vhost_alias_module modules/mod_vhost_alias.so\u001b[13X\r\n\u001b[96mLoadModule\u001b[m\u000f negotiation_module modules/mod_negotiation.so\r\n\u001b[96mLoadModule\u001b[m\u000f dir_module modules/mod_dir.so\u001b[18;2HLoadModule imagemap_module modules/mod_imagemap.so\u001b[19;2HLoadModule actions_module modules/mod_actions.so\u001b[20;2HLoadModule speling_module modules/mod_speling.so\u001b[21;12Huserdir_module modules/mod_userdir.so    \r\n\u001b[96mLoadModule\u001b[m\u000f alias_module modules/mod_alias.so\u001b[13X\r\n\u001b[96mLoadModule\u001b[m\u000f \u001b[30m\u001b[103mrewri\u001b[m\u000fte_module modules/mod_\u001b[30m\u001b[103mrewri\u001b[m\u000fte.so\u001b[7X\r\n\u001b[54X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[30X\u001b[26;2H\u001b[54X\n If you wish httpd to run as a different user or group, you must run\u001b[28;2H httpd as root initially and it will switch.  \u001b[14X\r\n#\u001b[53X\r\n# User/Group: The name (or #number) of the user/group to run httpd as.\r\n# It is usually good practice to create a dedicated user and group for\r\n# running httpd, as with most system services.\u001b[8X\u001b[33;2H\u001b[52X\r\n\u001b[96mUser\u001b[m\u000f http\u001b[48X\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[43X\r\n\u001b[54X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[46X\r\n\u001b[57X\n# 'Main' server configuration\u001b[31X\r\n#\u001b[53X\n The directives in this section set up the values used by the 'main'\u001b[42;2H server, which responds to any requests that aren't handled by a\u001b[43;2H <VirtualHost> definition.  These values also provide defaults for\u001b[44;2H any <VirtualHost> containers you may define later in the file.\u001b[45;2H\u001b[44X\n All of these directives may appear inside <VirtualHost> containers,\u001b[47;153H\u001b[0;10;7m\u000f189,12         33\u001b[48;7H\u001b[?25h"]
