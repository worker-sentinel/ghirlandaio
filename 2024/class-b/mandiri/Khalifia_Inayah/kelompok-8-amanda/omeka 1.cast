[0.007, "o", "\u001b[H; https://php.net/user-agent\r\n;user_agent=\"PHP\"\r\n\u001b[19X\u001b[4;3HDefault timeout for socket based streams (seconds)\u001b[5;2H https://php.net/default-socket-timeout\r\ndefault_socket_timeout = 60\u001b[46X\r\n\u001b[52X\n; If your scripts have to deal with files from Macintosh systems,\u001b[9;3Hor you are running on a Mac and need to deal with files from\u001b[16X\u001b[10;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[11;3Hautomatically detect the EOL character in those files so that\u001b[12;3Hfgets() and file() will work regardless of the source of the file.\u001b[13;3Hhttps://php.net/auto-detect-line-endings\u001b[10X\u001b[14;2Hauto_detect_line_endings = Off\u001b[12X\r\n\u001b[71X\u001b[16;2H;;;;;;;;;;;;;;;;;;;;;  \u001b[17;3HDynamic Extensions ;\u001b[57X\u001b[18;2H;;;;;;;;;;;;;;;;;;;;;\u001b[18X\r\n\u001b[49X\u001b[20;3HIf you wish to have an extension loaded automatically, use the following\r\n; syntax:\u001b[22;2H\u001b[66X\u001b[23;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000fmodulename\u001b[52X\u001b[24;2H\u001b[68X\u001b[25;3HFor example:\u001b[28X\r\n;\u001b[27;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000fmysqli\u001b[46X\u001b[28;2H\u001b[61X\u001b[29;3HWhen the extension library to load is not located in the default extension\u001b[30;3Hdirectory, You may specify an absolute path to the library file:\u001b[31;2H\u001b[67X\u001b[32;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000f/path/to/extension/mysqli.so\u001b[27X\u001b[33;2H\u001b[13X\u001b[34;3HNote : The syntax used in previous PHP versions ('\u001b[30m\u001b[103mextension=\u001b[m\u000f<ext>.so' and\r\n; '\u001b[30m\u001b[103mextension=\u001b[m\u000f'php_<ext>.dll') is supported for legacy reasons and may be\u001b[36;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[37;3Hmove to the new ('\u001b[30m\u001b[103mextension=\u001b[m\u000f<ext>) syntax.\u001b[38;2H\u001b[74X\n\u001b[30m\u001b[103mextension=\u001b[m\u000fbcmath\u001b[50X\u001b[40;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fbz2\u001b[47X\u001b[41;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fcalendar\u001b[60X\r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mcurl\u001b[43;2H\u001b[m\u000f\u001b[30m\u001b[103mextension=\u001b[m\u000fdba\u001b[65X\u001b[44;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fenchant\u001b[62X\u001b[45;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fexif\u001b[57X\u001b[46;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fffi\u001b[38X\u001b[47;153H\u001b[0;10;7m\u000f896,5          47%\u001b[48;12H\u001b[?25h"]
