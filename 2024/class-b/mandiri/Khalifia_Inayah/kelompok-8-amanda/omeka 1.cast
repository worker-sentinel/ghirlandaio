me\u001b[22;5He\u001b[m\u000f syntax of th\u001b[30m\u001b[103me\u001b[m\u000f fil\u001b[30m\u001b[103me\u001b[m\u000f is \u001b[30m\u001b[103me\u001b[m\u000fxtr\u001b[30m\u001b[103me\u001b[m\u000fm\u001b[30m\u001b[103me\u001b[m\u000fly simpl\u001b[30m\u001b[103me\u001b[m\u000f.  Whit\u001b[30m\u001b[103me\u001b[m\u000fspac\u001b[30m\u001b[103me\u001b[m\u000f and lin\u001b[30m\u001b[103me\u001b[23;4He\u001b[m\u000fginning with a s\u001b[30m\u001b[103me\u001b[m\u000fmicolon ar\u001b[30m\u001b[103me\u001b[m\u000f sil\u001b[30m\u001b[103me\u001b[m\u000fntly ignor\u001b[30m\u001b[103me\u001b[m\u000fd (as you probably gu\u001b[30m\u001b[103me\u001b[m\u000fss\u001b[30m\u001b[103me\u001b[24;4He\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fad\u001b[30m\u001b[103me\u001b[m\u000frs (\u001b[30m\u001b[103me\u001b[m\u000f.g. [Foo]) ar\u001b[30m\u001b[103me\u001b[m\u000f also sil\u001b[30m\u001b[103me\u001b[m\u000fntly ignor\u001b[30m\u001b[103me\u001b[m\u000fd, \u001b[30m\u001b[103me\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[25;5He\u001b[m\u000fy might m\u001b[30m\u001b[103me\u001b[m\u000fan som\u001b[30m\u001b[103me\u001b[m\u000fthing in th\u001b[30m\u001b[103me\u001b[m\u000f futur\u001b[30m\u001b[103me\u001b[27;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000fs following th\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fading [PATH=/www/mysit\u001b[30m\u001b[103me\u001b[28;19He\u001b[m\u000fs in th\u001b[30m\u001b[103me\u001b[m\u000f /www/mysit\u001b[30m\u001b[103me\u001b[m\u000f dir\u001b[30m\u001b[103me\u001b[m\u000fctory.  Dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[29;15He\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fading [HOST=www.\u001b[30m\u001b[103me\u001b[m\u000fxampl\u001b[30m\u001b[103me\u001b[30;10He\u001b[m\u000fs s\u001b[30m\u001b[103me\u001b[m\u000frv\u001b[30m\u001b[103me\u001b[m\u000fd from www.\u001b[30m\u001b[103me\u001b[m\u000fxampl\u001b[30m\u001b[103me\u001b[m\u000f.com.  Dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000fs s\u001b[30m\u001b[103me\u001b[m\u000ft in th\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[31;5He\u001b[m\u000fcial s\u001b[30m\u001b[103me\u001b[m\u000fctions cannot b\u001b[30m\u001b[103me\u001b[m\u000f ov\u001b[30m\u001b[103me\u001b[m\u000frridd\u001b[30m\u001b[103me\u001b[m\u000fn by us\u001b[30m\u001b[103me\u001b[m\u000fr-d\u001b[30m\u001b[103me\u001b[m\u000ffin\u001b[30m\u001b[103me\u001b[m\u000fd INI fil\u001b[30m\u001b[103me\u001b[32;12He\u001b[m\u000f. Curr\u001b[30m\u001b[103me\u001b[m\u000fntly, [PATH=] and [HOST=] s\u001b[30m\u001b[103me\u001b[m\u000fctions only work und\u001b[30m\u001b[103me\u001b[34;16He\u001b[m\u000ft/ini.s\u001b[30m\u001b[103me\u001b[36;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000fs ar\u001b[30m\u001b[103me\u001b[m\u000f sp\u001b[30m\u001b[103me\u001b[m\u000fcifi\u001b[30m\u001b[103me\u001b[m\u000fd using th\u001b[30m\u001b[103me\u001b[37;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f = valu\u001b[30m\u001b[103me\u001b[38;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f nam\u001b[30m\u001b[103me\u001b[m\u000fs ar\u001b[30m\u001b[103me\u001b[m\u000f *cas\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fnsitiv\u001b[30m\u001b[103me\u001b[m\u000f* - foo=bar is diff\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[39;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000fs ar\u001b[30m\u001b[103me\u001b[m\u000f variabl\u001b[30m\u001b[103me\u001b[m\u000fs us\u001b[30m\u001b[103me\u001b[m\u000fd to configur\u001b[30m\u001b[103me\u001b[m\u000f PHP or PHP \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[40;5He\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000f is no nam\u001b[30m\u001b[103me\u001b[m\u000f validation.  If PHP can't find an \u001b[30m\u001b[103me\u001b[m\u