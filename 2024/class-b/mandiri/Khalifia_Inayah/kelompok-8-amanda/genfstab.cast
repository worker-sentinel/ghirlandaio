[0.015, "o", "\u001b[1;1H\u001b[1m\u001b[36m# /dev/mapper/proc-root\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35md13846b7-73d1-48c2-9268-863962cf4460\u001b[m\u000f       /               \u001b[1m\u001b[32mext4\u001b[m\u000f            \u001b[1m\u001b[32mrw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f     \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m1\u001b[m\u000f\u001b[2;100H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[1m\u001b[36m# /dev/sda1 LABEL=boot\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35mDBD0-B802\u001b[m\u000f\u001b[10C/boot\u001b[11C\u001b[1m\u001b[32mvfat\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[1m\u001b[33m,fmask=\u001b[m\u000f\u001b[1m\u001b[35m0077\u001b[m\u000f\u001b[1m\u001b[33m,dmask=\u001b[m\u000f\u001b[1m\u001b[35m0077\u001b[m\u000f\u001b[1m\u001b[33m,codepage=\u001b[m\u000f\u001b[1m\u001b[35m437\u001b[m\u000f\u001b[1m\u001b[33m,iocharset=\u001b[m\u000f\u001b[1m\u001b[35mascii\u001b[m\u000f\u001b[1m\u001b[33m,shortname=\u001b[m\u000f\u001b[1m\u001b[35mmixed\u001b[m\u000f\u001b[1m\u001b[33m,utf8,errors=\u001b[m\u000f\u001b[1m\u001b[35mremount-ro\u001b[m\u000f   \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vars\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m225600f5-9125-4db3-8b17-57b8bed873af\u001b[m\u000f\u001b[7C/vars\u001b[11C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vtmp\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35mc666eaff-d40f-45fd-96a4-e6dd2edcce5e\u001b[m\u000f\u001b[7C/var/tmp\u001b[8C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vlog\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m3e3947e2-c00b-41a6-9dfe-ba7cdd62ea78\u001b[m\u000f\u001b[7C/var/log\u001b[8C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vaud\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35me7597805-eefa-49c2-b4a9-90e4f376cd2f\u001b[m\u000f\u001b[7C/var/log/audit  \u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-home\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m4798981b-5bfc-487c-92d4-71c51f1ca40c\u001b[m\u000f\u001b[7C/home\u001b[11C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-dock\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m7379f232-01cd-462a-8ae0-7b5f73287dfc\u001b[m\u000f\u001b[7C/var/lib/docker \u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[8C\u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36mtmpfs\u001b[m\u000f /tmp \u001b[1m\u001b[32mtmpfs\u001b[m\u000f \u001b[1m\u001b[32mdefaults\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f\u001b[1m\u001b[33m,size=\u001b[m\u000f\u001b[1m\u001b[35m1G\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f\r\n\u001b[1m\u001b[34m~                                                                                                                                                                         \u001b[27;1H~                                                                                                                                                                         \u001b[28;1H~                                                                                   