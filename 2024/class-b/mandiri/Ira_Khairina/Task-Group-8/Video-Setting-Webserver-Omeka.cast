[0.040, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f1,2\u001b[46;2H\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# LogLevel: Control the number of messages logged to the error_log.\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f2,22\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Possible values include: debug, info, notice, warn, error, crit,\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f3\u001b[46;22H\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# alert, emerg.\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f4,16\u001b[46;16H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f5,2          54\u001b[46;2H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[96mLogLevel\u001b[m\u000f warn\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f6,14\u001b[46;14H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f7,1 \r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f log_config_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f8,22\u001b[46;22H\u001b[?25h"]
[0.042, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    #\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f9,6 \u001b[46;6H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # The following directives define some format nicknames for use with\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f20,22         55\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # a CustomLog directive (see below).\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f1\u001b[46;22H\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    #\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f2,6 \u001b[46;6H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\"\u001b[m\u000f combined\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f3,22\u001b[46;22H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b\"\u001b[m\u000f common\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f4\u001b[46;22H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f5,1          56\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    \u001b[0;10;1m\u000f<IfModule\u001b[m\u000f logio_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f6,22\u001b[46;22H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H      # You need to enable mod_logio.c to use %I and %O\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f7\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H      \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\"\u001b[m\u000f combinedio\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f8\u001b[46;22H\u001b[?25h"]
[0.042, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    \u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f9,16\u001b[46;16H\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f30,1          57\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    #\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f1,6\u001b[46;6H\u001b[?25h"]
[0.042, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # The location and format of the access logfile (Common Logfile Format).\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f2,22\u001b[46;22H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # If you do not define any access logfiles within a <VirtualHost>\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f3\u001b[46;22H\u001b[?25h"]
[0.048, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # container, they will be logged here.  Contrariwise, if you *do*\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f4\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # define per-<VirtualHost> access logfiles, transactions will be\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f5,22         58\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    # logged therein and *not* in this file.\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f6\u001b[46;22H\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H    #\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f7,6 \u001b[46;6H\u001b[?25h"]
