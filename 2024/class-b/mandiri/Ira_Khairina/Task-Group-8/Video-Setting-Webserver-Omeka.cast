[0.005, "o", "\u001b[1;8H\u001b[30m\u001b[103me\u001b[m\u000f INI constants (On, Off, Tru\u001b[30m\u001b[103me\u001b[m\u000f, Fals\u001b[30m\u001b[103me\u001b[m\u000f, Y\u001b[30m\u001b[103me\u001b[m\u000fs, No and Non\u001b[30m\u001b[103me\u001b[m\u000f) or an \u001b[30m\u001b[103me\u001b[m\u000fxpr\u001b[30m\u001b[103me\u001b[2;4He\u001b[m\u000f.g. E_ALL & ~E_NOTICE), a quot\u001b[30m\u001b[103me\u001b[m\u000fd string (\"bar\"), or a r\u001b[30m\u001b[103me\u001b[m\u000ff\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[3;5He\u001b[m\u000fviously s\u001b[30m\u001b[103me\u001b[m\u000ft variabl\u001b[30m\u001b[103me\u001b[m\u000f or dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f (\u001b[30m\u001b[103me\u001b[5;7He\u001b[m\u000fssions in th\u001b[30m\u001b[103me\u001b[m\u000f INI fil\u001b[30m\u001b[103me\u001b[m\u000f ar\u001b[30m\u001b[103me\u001b[m\u000f limit\u001b[30m\u001b[103me\u001b[m\u000fd to bitwis\u001b[30m\u001b[103me\u001b[m\u000f op\u001b[30m\u001b[103me\u001b[m\u000frators and par\u001b[30m\u001b[103me\u001b[m\u000fnth\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[6;12He\u001b[7;12He\u001b[8;12He\u001b[9;12He\u001b[10;10He\u001b[12;7He\u001b[m\u000fan flags can b\u001b[30m\u001b[103me\u001b[m\u000f turn\u001b[30m\u001b[103me\u001b[m\u000fd on using th\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000fs 1, On, Tru\u001b[30m\u001b[103me\u001b[m\u000f or Y\u001b[30m\u001b[103me\u001b[13;5He\u001b[m\u000fy can b\u001b[30m\u001b[103me\u001b[m\u000f turn\u001b[30m\u001b[103me\u001b[m\u000fd off using th\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000fs 0, Off, Fals\u001b[30m\u001b[103me\u001b[15;6He\u001b[m\u000fmpty string can b\u001b[30m\u001b[103me\u001b[m\u000f d\u001b[30m\u001b[103me\u001b[m\u000fnot\u001b[30m\u001b[103me\u001b[m\u000fd by simply not writing anything aft\u001b[30m\u001b[103me\u001b[m\u000fr th\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[16;23He\u001b[m\u000f Non\u001b[30m\u001b[103me\u001b[m\u000f k\u001b[30m\u001b[103me\u001b[18;20He\u001b[m\u000fts foo to an \u001b[30m\u001b[103me\u001b[19;12He\u001b[m\u000f    ; s\u001b[30m\u001b[103me\u001b[m\u000fts foo to an \u001b[30m\u001b[103me\u001b[20;13He\u001b[m\u000f\"  ; s\u001b[30m\u001b[103me\u001b[m\u000fts foo to th\u001b[30m\u001b[103me\u001b[m\u000f string 'Non\u001b[30m\u001b[103me\u001b[22;12He\u001b[m\u000f constants in your valu\u001b[30m\u001b[103me\u001b[m\u000f, and th\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[m\u000f constants b\u001b[30m\u001b[103me\u001b[23;19He\u001b[m\u000fd \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion (\u001b[30m\u001b[103me\u001b[m\u000fith\u001b[30m\u001b[103me\u001b[m\u000fr a PHP \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion or a Z\u001b[30m\u001b[103me\u001b[m\u000fnd \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[24;18He\u001b[m\u000f th\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[m\u000f constants *aft\u001b[30m\u001b[103me\u001b[m\u000fr* th\u001b[30m\u001b[103me\u001b[m\u000f lin\u001b[30m\u001b[103me\u001b[m\u000f that loads th\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[27;17He\u001b[29;10He\u001b[m\u000fs packag\u001b[30m\u001b[103me\u001b[m\u000fd with two INI fil\u001b[30m\u001b[103me\u001b[m\u000fs. On\u001b[30m\u001b[103me\u001b[m\u000f that is r\u001b[30m\u001b[103me\u001b[m\u000fcomm\u001b[30m\u001b[103me\u001b[m\u000fnd\u001b[30m\u001b[103me\u001b[m\u000fd to b\u001b[30m\u001b[103me\u001b[m\u000f us\u001b[30m\u001b[103me\u001b[30;17He\u001b[m\u000fnvironm\u001b[30m\u001b[103me\u001b[m\u000fnts and on\u001b[30m\u001b[103me\u001b[m\u000f that is r\u001b[30m\u001b[103me\u001b[m\u000fcomm\u001b[30m\u001b[103me\u001b[m\u000fnd\u001b[30m\u001b[103me\u001b[m\u000fd to b\u001b[30m\u001b[103me\u001b[m\u000f us\u001b[30m\u001b[103me\u001b[31;4He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt \u001b[30m\u001b[103me\u001b[m\u000fnvironm\u001b[30m\u001b[103me\u001b[33;32He\u001b[m\u000fttings which hold s\u001b[30m\u001b[103me\u001b[m\u000fcurity, p\u001b[30m\u001b[103me\u001b[m\u000frformanc\u001b[30m\u001b[103me\u001b[34;4He\u001b[m\u000fst practic\u001b[30m\u001b[103me\u001b[m\u000fs at its cor\u001b[30m\u001b[103me\u001b[m\u000f. But pl\u001b[30m\u001b[103me\u001b[m\u000fas\u001b[30m\u001b[103me\u001b[m\u000f b\u001b[30m\u001b[103me\u001b[m\u000f awar\u001b[30m\u001b[103me\u001b[m\u000f, th\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fttings may br\u001b[30m\u001b[103me\u001b[35;25He\u001b[m\u000fr or l\u001b[30m\u001b[103me\u001b[m\u000fss s\u001b[30m\u001b[103me\u001b[m\u000fcurity-conscious applications. W\u001b[30m\u001b[103me\u001b[36;4He\u001b[m\u000fcomm\u001b[30m\u001b[103me\u001b[m\u000fnding using th\u001b[30m\u001b[103me\u001b[m\u000f production ini in production and t\u001b[30m\u001b[103me\u001b[m\u000fsting \u001b[30m\u001b[103me\u001b[m\u000fnvironm\u001b[30m\u001b[103me\u001b[38;12He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt is v\u001b[30m\u001b[103me\u001b[m\u000fry similar to its production variant, \u001b[30m\u001b[103me\u001b[m\u000fxc\u001b[30m\u001b[103me\u001b[39;11He\u001b[m\u000f v\u001b[30m\u001b[103me\u001b[m\u000frbos\u001b[30m\u001b[103me\u001b[m\u000f wh\u001b[30m\u001b[103me\u001b[m\u000fn it com\u001b[30m\u001b[103me\u001b[m\u000fs to \u001b[30m\u001b[103me\u001b[m\u000frrors. W\u001b[30m\u001b[103me\u001b[m\u000f r\u001b[30m\u001b[103me\u001b[m\u000fcomm\u001b[30m\u001b[103me\u001b[m\u000fnd using th\u001b[30m\u001b[103me\u001b[40;4He\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt v\u001b[30m\u001b[103me\u001b[m\u000frsion only in d\u001b[30m\u001b[103me\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[m\u000flopm\u001b[30m\u001b[103me\u001b[m\u000fnt \u001b[30m\u001b[103me\u001b[m\u000fnvironm\u001b[30m\u001b[103me\u001b[m\u000fnts, as \u001b[30m\u001b[103me\u001b[41;17He\u001b[m\u000frs can inadv\u001b[30m\u001b[103me\u001b[m\u000frt\u001b[30m\u001b[103me\u001b[m\u000fntly l\u001b[30m\u001b[103me\u001b[m\u000fak oth\u001b[30m\u001b[103me\u001b[m\u000frwis\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fcur\u001b[30m\u001b[103me\u001b[43;13He\u001b[m\u000f php.ini-production INI fil\u001b[30m\u001b[103me\u001b[46;10He\u001b[m\u000ff\u001b[30m\u001b[103me\u001b[m\u000fr\u001b[30m\u001b[103me\u001b[m\u000fnc\u001b[30m\u001b[103me\u001b[47;156H\u001b[0;10;7m\u000f25\u001b[48;3H\u001b[?25h"]
