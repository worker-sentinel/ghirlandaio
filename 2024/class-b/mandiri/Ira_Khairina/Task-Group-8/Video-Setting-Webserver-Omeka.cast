[0.332, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f2,2\u001b[46;2H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# ErrorLog: The location of the error log file.\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f3,22\u001b[46;22H\u001b[?25h"]
[0.041, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# If you do not specify an ErrorLog directive within a <VirtualHost>\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f4\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# container, error messages relating to that virtual host will be\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f5,22         52\u001b[46;22H\u001b[?25h"]
[0.040, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# logged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f6\u001b[46;22H\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# container, that host's errors will be logged there and not here.\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f7\u001b[46;22H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H#\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f8,2 \u001b[46;2H\u001b[?25h"]
[0.042, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H\u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/error_log\"\u001b[m\u000f\u001b[K\u001b[47;155H\u001b[0;10;7m\u000f9,22\u001b[46;22H\u001b[?25h"]
