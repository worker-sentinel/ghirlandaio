[0.003, "o", "                        \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \r\n                                                                                                                                                                                                                     \u001b[H\u001b(B\u001b[0;1m\u001b[38;2;140;248;247m\u001b[48;2;79;82;88m[\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mMatch\u001b(B\u001b[0;1m\u001b[38;2;140;248;247m\u001b[48;2;79;82;88m]\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mType\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27mether\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# Exclude virtual Ethernet interfaces\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mKind\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m!*\r\n\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27m[Link]\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mRequiredForOnline\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27mroutable\r\n\n\u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27m[Network]\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mAddress\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m=\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m199.19.9.8/24\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mGateway\u001b(B\u001b[m\u0