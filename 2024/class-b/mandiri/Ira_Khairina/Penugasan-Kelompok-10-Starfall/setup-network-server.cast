[0.055, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c\u001b[?2026h\u001b[?2031h\u001b[?2048h\u001b[>3u\u001b(B\u001b[0;1;4m\u001b[96m[\u001b(B\u001b[m\u001b[96mMatch\u001b(B\u001b[0;1;4m\u001b[96m]\u001b(B\u001b[m\u001b[K\r\nType=\u001b[92mether\u001b(B\u001b[m\u001b[K\r\n# Exclude virtual Ethernet interfaces\u001b[K\r\nKind=\u001b[92m!*\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[96m[Link]\u001b(B\u001b[m\u001b[K\r\nRequiredForOnline=\u001b[92mroutable\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[96m[Network]\u001b(B\u001b[m\u001b[K\r\nAddress=\u001b[92m199.19.9.8/24\u001b(B\u001b[m\u001b[K\r\nGateway=\u001b[92m199.19.9.1\u001b(B\u001b[m\u001b[K\r\nDNS=\u001b[92m1.1.1.1 8.8.8.8\u001b(B\u001b[m\u001b[K\r\nMulticastDNS=\u001b[92myes\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n# systemd-networkd does not set per-interface-type default route metrics\u001b[K\r\n# https://github.com/systemd/systemd/issues/17698\u001b[K\r\n# Explicitly set route metric, so that Ethernet is preferred over Wi-Fi and Wi-Fi is preferred over mobile broadband.\u001b[K\r\n# Use values from NetworkManager. From nm_device_get_route_metric_default in\u001b[K\r\n# https://gitlab.freedesktop.org/NetworkManager/NetworkManager/-/blob/main/src/core/devices/nm-device.c\u001b[K\r\n\u001b[96m[DHCPv4]\u001b(B\u001b[m\u001b[K\r\nRouteMetric=100\u001b[K\r\n\u001b[K\n\u001b[96m[IPv6AcceptRA]\u001b(B\u001b[m\u001b[K\r\nRouteMetric=100\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b(B\u001b[0;7m/etc/systemd/network/20-ethernet.network                                                                                                                                                           1,1            All\u001b(B\u001b[m\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H\u001b(B\u001b[0;1;4m\u001b[96m[\u001b(B\u001b[m\u001b[96mMatch\u001b(B\u001b[0;1;4m\u001b[96m]\u001b(B\u001b[m\u001b[K\r\nType=\u001b[92mether\u001b(B\u001b[m\u001b[K\r\n# Exclude virtual Ethernet interfaces\u001b[K\r\nKind=\u001b[92m!*\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[96m[Link]\u001b(B\u001b[m\u001b[K\r\nRequiredForOnline=\u001b[92mroutable\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[96m[Network]\u001b(B\u001b[m\u001b[K\r\nAddress=\u001b[92m199.19.9.8/24\u001b(B\u001b[m\u001b[K\r\nGateway=\u001b[92m199.19.9.1\u001b(B\u001b[m\u001b[K\r\nDNS=\u001b[92m1.1.1.1 8.8.8.8\u001b(B\u001b[m\u001b[K\r\nMulticastDNS=\u001b[92myes\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n# systemd-networkd does not set per-interface-type default route metrics\u001b[K\r\n# https://github.com/systemd/systemd/issues/17698\u001b[K\r\n# Explicitly set route metric, so that Ethernet is preferred over Wi-Fi and Wi-Fi is preferred over mobile broadband.\u001b[K\r\n# Use values from NetworkManager. From nm_device_get_route_metric_default in\u001b[K\r\n# https://gitlab.freedesktop.org/NetworkManager/NetworkManager/-/blob/main/src/core/devices/nm-device.c\u001b[K\r\n\u001b[96m[DHCPv4]\u001b(B\u001b[m\u001b[K\r\nRouteMetric=100\u001b[K\r\n\u001b[K\n\u001b[96m[IPv6AcceptRA]\u001b(B\u001b[m\u001b[K\r\nRouteMetric=100\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b(B\u001b[0;7m/etc/systemd/network/20-ethernet.network                                                                                                                                                           1,1            All\u001b(B\u001b[m\r\n\u001b[J\u001b[H\u001b[?2026l"]
