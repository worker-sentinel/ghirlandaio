[0.005, "o", "1: \u001b[1;36mlo: \u001b[0m<LOOPBACK,UP,LOWER_UP> mtu 65536 qdisc noqueue state UNKNOWN group default qlen 1000\r\n    link/loopback \u001b[1;33m00:00:00:00:00:00\u001b[0m brd \u001b[1;33m00:00:00:00:00:00\u001b[0m\r\n    inet \u001b[1;35m127.0.0.1\u001b[0m/8 scope host lo\r\n       valid_lft forever preferred_lft forever\r\n    inet6 \u001b[1;94m::1\u001b[0m/128 scope host noprefixroute \r\n       valid_lft forever preferred_lft forever\r\n2: \u001b[1;36menp2s0: \u001b[0m<NO-CARRIER,BROADCAST,MULTICAST,UP> mtu 1500 qdisc fq_codel state \u001b[1;31mDOWN \u001b[0mgroup default qlen 1000\r\n    link/ether \u001b[1;33m98:29:a6:63:bf:a1\u001b[0m brd \u001b[1;33mff:ff:ff:ff:ff:ff\u001b[0m\r\n    altname enx9829a663bfa1\r\n6: \u001b[1;36mwlan0: \u001b[0m<BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc noqueue state \u001b[1;32mUP \u001b[0mgroup default qlen 1000\r\n    link/ether \u001b[1;33m30:d1:6b:fe:b9:5d\u001b[0m brd \u001b[1;33mff:ff:ff:ff:ff:ff\u001b[0m\r\n    inet \u001b[1;35m172.20.10.2\u001b[0m/28 metric 600 brd \u001b[1;35m172.20.10.15 \u001b[0mscope global dynamic wlan0\r\n       valid_lft 3596sec preferred_lft 3596sec\r\n    inet6 \u001b[1;94m2404:c0:20b5:5849:32d1:6bff:fefe:b95d\u001b[0m/64 scope global mngtmpaddr noprefixroute \r\n       valid_lft forever preferred_lft forever\r\n    inet6 \u001b[1;94mfe80::32d1:6bff:fefe:b95d\u001b[0m/64 scope link proto kernel_ll \r\n       valid_lft forever preferred_lft forever\r\n\u001b]0;root@archlinux:/home/starfall\u0007[root@archlinux starfall]# "]
