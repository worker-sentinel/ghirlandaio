[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# ErrorLog: The location of the error log file.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,22\u001b[65;22H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# If you do not specify an ErrorLog directive within a <VirtualHost>\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,22         50\u001b[65;22H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# container, error messages relating to that virtual host will be\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[65;22H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# logged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[65;22H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# container, that host's errors will be logged there and not here.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[65;22H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9,2 \u001b[65;2H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/error_log\"\u001b[m\u000f\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f10,22         51\u001b[65;22H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,1 \r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,2\u001b[65;2H\u001b[?25h"]
