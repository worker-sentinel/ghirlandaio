[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# explicitly permit access to web content directories in other \u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# <Directory> blocks below.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,1          36\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[0;10;1m\u000f<Directory\u001b[m\u000f /\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f40\r\u001b[A\u001b[?25h"]
[0.280, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    \u001b[96mAllowOverride\u001b[m\u000f none\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.250, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    \u001b[96mRequire\u001b[m\u000f all denied\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          37\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
