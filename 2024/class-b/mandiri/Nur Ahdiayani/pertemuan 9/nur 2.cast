me\u001b[22;5He\u001b[m\u000f syntax of th\u001b[30m\u001b[103me\u001b[m\u000f fil\u001b[30m\u001b[103me\u001b[m\u000f is \u001b[30m\u001b[103me\u001b[m\u000fxtr\u001b[30m\u001b[103me\u001b[m\u000fm\u001b[30m\u001b[103me\u001b[m\u000fly simpl\u001b[30m\u001b[103me\u001b[m\u000f.  Whit\u001b[30m\u001b[103me\u001b[m\u000fspac\u001b[30m\u001b[103me\u001b[m\u000f and lin\u001b[30m\u001b[103me\u001b[23;4He\u001b[m\u000fginning with a s\u001b[30m\u001b[103me\u001b[m\u000fmicolon ar\u001b[30m\u001b[103me\u001b[m\u000f sil\u001b[30m\u001b[103me\u001b[m\u000fntly ignor\u001b[30m\u001b[103me\u001b[m\u000fd (as you probably gu\u001b[30m\u001b[103me\u001b[m\u000fss\u001b[30m\u001b[103me\u001b[24;4He\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fad\u001b[30m\u001b[103me\u001b[m\u000frs (\u001b[30m\u001b[103me\u001b[m\u000f.g. [Foo]) ar\u001b[30m\u001b[103me\u001b[m\u000f also sil\u001b[30m\u001b[103me\u001b[m\u000fntly ignor\u001b[30m\u001b[103me\u001b[m\u000fd, \u001b[30m\u001b[103me\u001b[m\u000fv\u001b[30m\u001b[103me\u001b[25;5He\u001b[m\u000fy might m\u001b[30m\u001b[103me\u001b[m\u000fan som\u001b[30m\u001b[103me\u001b[m\u000fthing in th\u001b[30m\u001b[103me\u001b[m\u000f futur\u001b[30m\u001b[103me\u001b[27;6He\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000fs following th\u001b[30m\u001b[103me\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fading [PATH=/www/mysit\u001b[30m\u001b[103me\u001b[28;19He\u001b[m\u000fs in th\u001b[30m\u001b[103me\u001b[m\u000f /www/mysit\u001b[30m\u001b[103me\u001b[m\u000f dir\u001b[30m\u001b[103me\u001b[m\u000fctory.  Dir\u001b[30m\u001b[103me\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[29;15He\u001b[m\u000f s\u001b[30m\u001b[103me\u001b[m\u000fction h\u001b[30m\u001b[103me\u001b[m\u000fading [HOST=www.\u001b[30m\u001b[103me\u001b[m\u000fxampl\u001b[30m\u001b[103me\u001b[30;10He\u001b[m\u000fs s\u001b[30m\u001b[103me\u001b[m\u000frv\u001b[30m\u001b[103me\u001b[m\u000fd from www.\