[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Possible values include: debug, info, notice, warn, error, crit,\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\u001b[65;22H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# alert, emerg.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,16         52\u001b[65;16H\u001b[?25h"]
