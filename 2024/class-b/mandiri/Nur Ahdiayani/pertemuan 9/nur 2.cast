[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f20,6          53\u001b[65;6H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # The following directives define some format nicknames for use with\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,22\u001b[65;22H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # a CustomLog directive (see below).\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\u001b[65;22H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,6 \u001b[65;6H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\"\u001b[m\u000f combined\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,22\u001b[65;22H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b\"\u001b[m\u000f common\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,22         54\u001b[65;22H\u001b[?25h"]
