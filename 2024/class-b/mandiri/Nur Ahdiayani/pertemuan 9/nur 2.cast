[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[96mLogLevel\u001b[m\u000f warn\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,14\u001b[65;14H\u001b[?25h"]
