[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6,2\u001b[65;2H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Deny access to the entirety of your server's filesystem. You must\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,21\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# explicitly permit access to web content directories in other \u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,21         36\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# <Directory> blocks below.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f40,2 \u001b[65;2H\u001b[?25h"]
[0.162, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[5M\u001b[1;67r\u001b[61;1H\u001b[0;10;1m\u000f<Directory\u001b[m\u000f /\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mAllowOverride\u001b[m\u000f none\u001b[K\r\n    \u001b[96mRequire\u001b[m\u000f all denied\u001b[K\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\r\n\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,1          37\r\u001b[A\u001b[?25h"]
[0.017, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6,2\u001b[65;2H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# Note that from this point forward you must specifically allow\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,21\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# particular features to be enabled - so if something's not working as\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,21         38\u001b[65;21H\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# you might expect, make sure that you have specifically enabled it\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# below.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f50,9 \u001b[65;9H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,2\u001b[65;2H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,1\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,2          39\u001b[65;2H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# DocumentRoot: The directory out of which you will serve your\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,21\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# documents. By default, all requests are taken from this directory, but\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H# symbolic links and aliases may be used to point to other locations.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,2          40\u001b[65;2H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http\"\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,21\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f60,6 \u001b[65;6H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Possible values for the Options directive are \"None\", \"All\",\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1,21\u001b[65;21H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # or any combination of:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,21         41\u001b[65;21H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\u001b[65;21H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,6 \u001b[65;6H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5,21\u001b[65;21H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # doesn't give it to you.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\u001b[65;21H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,6          42\u001b[65;6H\u001b[?25h"]
