[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Redirect: Allows you to tell clients about documents that used to \u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # exist in your server's namespace, but do not anymore. The client \u001b[K\u001b[66;224H\u001b[0;10;7m\u000f50\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # will make a new request for the document at its new location.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Redirect permanent /foo http://www.example.com/bar\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3,1          60\r\u001b[A\u001b[?25h"]
