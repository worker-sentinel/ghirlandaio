[0.000, "o", "\u001b[m\u000fctiv\u001b[30m\u001b[103me\u001b[m\u000f (\u001b[30m\u001b[103me\u001b[48;7He\u001b[m\u000fssions in th\u001b[30m\u001b[103me\u001b[m\u000f INI fil\u001b[30m\u001b[103me\u001b[m\u000f ar\u001b[30m\u001b[103me\u001b[m\u000f limit\u001b[30m\u001b[103me\u001b[m\u000fd to bitwis\u001b[30m\u001b[103me\u001b[m\u000f op\u001b[30m\u001b[103me\u001b[m\u000frators and par\u001b[30m\u001b[103me\u001b[m\u000fnth\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[49;12He\u001b[50;12He\u001b[51;12He\u001b[52;12He\u001b[53;10He\u001b[55;7He\u001b[m\u000fan flags can b\u001b[30m\u001b[103me\u001b[m\u000f turn\u001b[30m\u001b[103me\u001b[m\u000fd on using th\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000fs 1, On, Tru\u001b[30m\u001b[103me\u001b[m\u000f or Y\u001b[30m\u001b[103me\u001b[56;5He\u001b[m\u000fy can b\u001b[30m\u001b[103me\u001b[m\u000f turn\u001b[30m\u001b[103me\u001b[m\u000fd off using th\u001b[30m\u001b[103me\u001b[m\u000f valu\u001b[30m\u001b[103me\u001b[m\u000fs 0, Off, Fals\u001b[30m\u001b[103me\u001b[58;6He\u001b[m\u000fmpty string can b\u001b[30m\u001b[103me\u001b[m\u000f d\u001b[30m\u001b[103me\u001b[m\u000fnot\u001b[30m\u001b[103me\u001b[m\u000fd by simply not writing anything aft\u001b[30m\u001b[103me\u001b[m\u000fr th\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[59;23He\u001b[m\u000f Non\u001b[30m\u001b[103me\u001b[m\u000f k\u001b[30m\u001b[103me\u001b[61;20He\u001b[m\u000fts foo to an \u001b[30m\u001b[103me\u001b[62;12He\u001b[m\u000f    ; s\u001b[30m\u001b[103me\u001b[m\u000fts foo to an \u001b[30m\u001b[103me\u001b[63;13He\u001b[m\u000f\"  ; s\u001b[30m\u001b[103me\u001b[m\u000fts foo to th\u001b[30m\u001b[103me\u001b[m\u000f string 'Non\u001b[30m\u001b[103me\u001b[65;12He\u001b[m\u000f constants in your valu\u001b[30m\u001b[103me\u001b[m\u000f, and th\u001b[30m\u001b[103me\u001b[m\u000fs\u001b[30m\u001b[103me\u001b[m\u000f constants b\u001b[30m\u001b[103me\u001b[66;223H\u001b[0;10;7m\u000f6,27 \u001b[67;3H\u001b[?25h"]
