[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H# running httpd, as with most system services.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H# It is usually good practice to create a dedicated user and group for\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H# User/Group: The name (or #number) of the user/group to run httpd as.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6,1          40\u001b[H\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H#\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\u001b[H\u001b[?25h"]
