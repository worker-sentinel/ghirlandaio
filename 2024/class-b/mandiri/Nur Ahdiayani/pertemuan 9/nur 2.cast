[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H# container, that host's errors will be logged there and not here.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,19         63\u001b[1;19H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[L\u001b[1;67r\u001b[H# logged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\u001b[1;19H\u001b[?25h"]
