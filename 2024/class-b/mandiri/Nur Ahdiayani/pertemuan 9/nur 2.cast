[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # documents in the target directory are treated as applications and\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f70\u001b[65;22H\u001b[?25h"]
