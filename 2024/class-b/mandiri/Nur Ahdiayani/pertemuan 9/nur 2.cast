[0.032, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Alias: Maps web paths into filesystem paths and is used to\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # access content that does not live under the DocumentRoot.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Example:\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8,1          61\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # Alias /webpath /full/filesystem/path\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f60\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # If you include a trailing / on /webpath then the server will\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f1\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # require it to be present in the URL.  You will also likely\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f2,1          62\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # need to provide a <Directory> section to allow access to\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # the filesystem path.\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f5\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    #\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f6\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # ScriptAlias: This controls which directories contain server scripts. \u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,1          63\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # ScriptAliases are essentially the same as Aliases, except that\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f8\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # documents in the target directory are treated as applications and\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f9\r\u001b[A\u001b[?25h"]
