[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # If you do not define any access logfiles within a <VirtualHost>\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f3\r\u001b[A\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[65;1H    # container, they will be logged here.  Contrariwise, if you *do*\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f4,1          56\r\u001b[A\u001b[?25h"]
