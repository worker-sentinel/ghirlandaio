[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           24\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## Allow sudo-run commands to inherit the callers' ConsoleKit session\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f70,1           25\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Defaults env_keep += \"XDG_SESSION_COOKIE\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           26\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           27\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## Uncomment to enable special input methods.  Care should be taken as\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           29\r\u001b[A\u001b[?25h"]
