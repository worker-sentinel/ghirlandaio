[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1            6\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## You may wish to keep some of the following environment variables\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1            7\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## when running commands via sudo.\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1            8\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1            9\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## Locale settings\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f6,1           10\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Defaults env_keep += \"LANG LANGUAGE LINGUAS LC_* _XKB_CHARSET\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f7,1           11\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f8,1           12\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## Run X applications through sudo; HOME is used to find the\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f9,1           13\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## .Xauthority file.  Note that other programs use HOME to find   \u001b[K\u001b[47;153H\u001b[0;10;7m\u000f60,1           15\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## configuration files and this may lead to privilege escalation!\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f1,1           16\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Defaults env_keep += \"HOME\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f2,1           17\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H##\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f3,1           18\r\u001b[A\u001b[?25h"]
[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## X11 resource path settings\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f4,1           19\r\u001b[A\u001b[?25h"]
[0.035, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H# Defaults env_keep += \"XAPPLRESDIR XFILESEARCHPATH XUSERFILESEARCHPATH\"\u001b[K\u001b[47;154H\u001b[0;10;7m\u000f5,1           20\r\u001b[A\u001b[?25h"]
