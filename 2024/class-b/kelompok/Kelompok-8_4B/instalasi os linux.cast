[0.034, "o", "\u001b[?25l\u001b[1;46r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;48r\u001b[46;1H## arbitrary commands under sudo.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f50,1            4\r\u001b[A\u001b[?25h"]
