[0.016, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.001, "o", "\u001b[?25l\u001b[m\u000f; Start a new pool named 'www'.\u001b[K\r\n; the variable $pool can be used in any directive and will be replaced by the\u001b[K\r\n; pool name ('www' here)\u001b[K\r\n\u001b[96m[www]\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Per pool prefix\u001b[K\r\n; It only applies on the following directives:\u001b[K\r\n; - 'access.log'\u001b[K\r\n; - 'slowlog'\u001b[K\r\n; - 'listen' (unixsocket)\u001b[K\r\n; - 'chroot'\u001b[K\r\n; - 'chdir'\u001b[K\r\n; - 'php_values'\u001b[K\r\n; - 'php_admin_values'\u001b[K\r\n; When not set, the global prefix (or /usr) applies instead.\u001b[K\r\n; Note: This directive can also be relative to the global prefix.\u001b[K\r\n; Default Value: none\u001b[K\r\n;prefix = /path/to/pools/$pool\u001b[K\r\n\u001b[K\n; Unix user/group of the child processes. This can be used only if the master\u001b[K\r\n; process running user is root. It is set after the child process is created.\u001b[K\r\n; The user and group can be specified either by their name or by their numeric\u001b[K\r\n; IDs.\u001b[K\r\n; Note: If the user is root, the executable needs to be started with\u001b[K\r\n;       --allow-to-run-as-root option to work.\u001b[K\r\n; Default Values: The user is set to master process running user by default.\u001b[K\r\n;                 If the group is not set, the user's group is used.\u001b[K\r\nuser =\u001b[92m http\u001b[m\u000f\u001b[K\r\ngroup =\u001b[92m http\u001b[m\u000f\u001b[K\r\n\u001b[K\n; The address on which to accept FastCGI requests.\u001b[K\r\n; Valid syntaxes are:\u001b[K\r\n;   'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   'port'                 - to listen on a TCP socket to all addresses\u001b[K\r\n;                            (IPv6 and IPv4-mapped) on a specific port;\u001b[K\r\n;   '/path/to/unix/socket' - to listen on a unix socket.\u001b[K\r\n; Note: This value is mandatory.\u001b[K\r\nlisten =\u001b[92m /run/php-fpm/php-fpm.sock\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Set listen(2) backlog.\u001b[K\r\n; Default Value: 511 (-1 on Linux, FreeBSD and OpenBSD)\u001b[K\r\n;listen.backlog = 511\u001b[K\r\n\u001b[K\n\u001b[0;10;7m\u000f/etc/php/php-fpm.d/www.conf                                                                                                                             1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H; Start a new pool named 'www'.\u001b[K\r\n; the variable $pool can be used in any directive and will be replaced by the\u001b[K\r\n; pool name ('www' here)\u001b[K\r\n\u001b[96m[www]\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Per pool prefix\u001b[K\r\n; It only applies on the following directives:\u001b[K\r\n; - 'access.log'\u001b[K\r\n; - 'slowlog'\u001b[K\r\n; - 'listen' (unixsocket)\u001b[K\r\n; - 'chroot'\u001b[K\r\n; - 'chdir'\u001b[K\r\n; - 'php_values'\u001b[K\r\n; - 'php_admin_values'\u001b[K\r\n; When not set, the global prefix (or /usr) applies instead.\u001b[K\r\n; Note: This directive can also be relative to the global prefix.\u001b[K\r\n; Default Value: none\u001b[K\r\n;prefix = /path/to/pools/$pool\u001b[K\r\n\u001b[K\n; Unix user/group of the child processes. This can be used only if the master\u001b[K\r\n; process running user is root. It is set after the child process is created.\u001b[K\r\n; The user and group can be specified either by their name or by their numeric\u001b[K\r\n; IDs.\u001b[K\r\n; Note: If the user is root, the executable needs to be started with\u001b[K\r\n;       --allow-to-run-as-root option to work.\u001b[K\r\n; Default Values: The user is set to master process running user by default.\u001b[K\r\n;                 If the group is not set, the user's group is used.\u001b[K\r\nuser =\u001b[92m http\u001b[m\u000f\u001b[K\r\ngroup =\u001b[92m http\u001b[m\u000f\u001b[K\r\n\u001b[K\n; The address on which to accept FastCGI requests.\u001b[K\r\n; Valid syntaxes are:\u001b[K\r\n;   'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\u001b[K\r\n;                            a specific port;\u001b[K\r\n;   'port'                 - to listen on a TCP socket to all addresses\u001b[K\r\n;                            (IPv6 and IPv4-mapped) on a specific port;\u001b[K\r\n;   '/path/to/unix/socket' - to listen on a unix socket.\u001b[K\r\n; Note: This value is mandatory.\u001b[K\r\nlisten =\u001b[92m /run/php-fpm/php-fpm.sock\u001b[m\u000f\u001b[K\r\n\u001b[K\n; Set listen(2) backlog.\u001b[K\r\n; Default Value: 511 (-1 on Linux, FreeBS"]
[0.002, "o", "D and OpenBSD)\u001b[K\r\n;listen.backlog = 511\u001b[K\r\n\u001b[K\n\u001b[0;10;7m\u000f/etc/php/php-fpm.d/www.conf                                                                                                                             1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
