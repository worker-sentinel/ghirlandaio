[0.004, "o", "\u001b[1;18H\u001b[30m\u001b[103ml\u001b[2;13Hl\u001b[m\u000fe $poo\u001b[30m\u001b[103ml\u001b[m\u000f can be used in any directive and wi\u001b[30m\u001b[103mll\u001b[m\u000f be rep\u001b[30m\u001b[103ml\u001b[3;6Hl\u001b[6;10Hl\u001b[7;8Hl\u001b[m\u000fy app\u001b[30m\u001b[103ml\u001b[m\u000fies on the fo\u001b[30m\u001b[103mll\u001b[8;13Hl\u001b[9;7Hl\u001b[m\u000fow\u001b[30m\u001b[103ml\u001b[10;6Hl\u001b[13;12Hl\u001b[14;18Hl\u001b[15;22Hl\u001b[m\u000foba\u001b[30m\u001b[103ml\u001b[m\u000f prefix (or /usr) app\u001b[30m\u001b[103ml\u001b[16;29Hl\u001b[m\u000fso be re\u001b[30m\u001b[103ml\u001b[m\u000fative to the g\u001b[30m\u001b[103ml\u001b[m\u000foba\u001b[30m\u001b[103ml\u001b[17;8Hl\u001b[m\u000ft Va\u001b[30m\u001b[103ml\u001b[18;23Hl\u001b[m\u000fs/$poo\u001b[30m\u001b[103ml\u001b[20;29Hl\u001b[m\u000fd processes. This can be used on\u001b[30m\u001b[103ml\u001b[21;56Hl\u001b[24;42Hl\u001b[25;12Hll\u001b[26;8Hl\u001b[m\u000ft Va\u001b[30m\u001b[103ml\u001b[m\u000fues: The user is set to master process running user by defau\u001b[30m\u001b[103ml\u001b[32;5Hl\u001b[33;33Hl\u001b[35;33Hl\u001b[37;33Hl\u001b[m\u000fisten on a TCP socket to a\u001b[30m\u001b[103mll\u001b[39;33Hl\u001b[40;16Hl\r\nl\u001b[43;7Hl\u001b[m\u000fisten(2) back\u001b[30m\u001b[103ml\u001b[44;8Hl\u001b[m\u000ft Va\u001b[30m\u001b[103ml\u001b[45;2Hl\u001b[m\u000fisten.back\u001b[30m\u001b[103ml\u001b[47;156H\u001b[0;10;7m\u000f8\u001b[48;3H\u001b[?25h"]
[0.353, "o", "\u001b[?25l\u001b[m\u000fi"]
[0.004, "o", "\u001b[1;18Hl\u001b[2;13Hle $pool can be used in any directive and will be repl\u001b[3;6Hl\u001b[6;10Hl\u001b[7;8Hly app\u001b[30m\u001b[103mli\u001b[m\u000fes on the foll\u001b[8;13Hl\u001b[9;7Hlowl\u001b[10;7H\u001b[30m\u001b[103mi\u001b[13;12H\u001b[m\u000fl\u001b[14;18Hl\u001b[15;22Hlobal prefix (or /usr) app\u001b[30m\u001b[103mli\u001b[16;29H\u001b[m\u000flso be relative to the global\u001b[17;8Hlt Val\u001b[18;23Hls/$pool\u001b[20;29Hld processes. This can be used onl\u001b[21;56Hl\u001b[24;42Hl\u001b[25;12Hll\u001b[26;8Hlt Values: The user is set to master process running user by defaul\u001b[32;6H\u001b[30m\u001b[103mi\u001b[33;34Hi\u001b[35;34Hi\u001b[37;34Hi\u001b[m\u000fsten on a TCP socket to all\u001b[39;34H\u001b[30m\u001b[103mi\u001b[40;16H\u001b[m\u000fl\u001b[41;2H\u001b[30m\u001b[103mi\u001b[43;8Hi\u001b[m\u000fsten(2) backl\u001b[44;8Hlt Val\u001b[45;3H\u001b[30m\u001b[103mi\u001b[m\u000fsten.backl\u001b[47;153H\u001b[0;10;7m\u000f7,14\u001b[48;4H\u001b[?25h"]
