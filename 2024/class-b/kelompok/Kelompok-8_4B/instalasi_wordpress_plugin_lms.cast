[0.004, "o", "\u001b[1;18H\u001b[30m\u001b[103ml\u001b[2;13Hl\u001b[m\u000fe $poo\u001b[30m\u001b[103ml\u001b[m\u000f can be used in any directive and wi\u001b[30m\u001b[103mll\u001b[m\u000f be rep\u001b[30m\u001b[103ml\u001b[3;6Hl\u001b[6;10Hl\u001b[7;8Hl\u001b[m\u000fy app\u001b[30m\u001b[103ml\u001b[m\u000fies on the fo\u001b[30m\u001b[103mll\u001b[8;13Hl\u001b[9;7Hl\u001b[m\u000fow\u001b[30m\u001b[103ml\u001b[10;6Hl\u001b[13;12Hl\u001b[14;18Hl\u001b[15;22Hl\u001b[m\u000foba\u001b[30m\u001b[103ml\u001b[m\u000f prefix (or /usr) app\u001b[30m\u001b[103ml\u001b[16;29Hl\u001b[m\u000fso be re\u001b[30m\u001b[103ml\u001b[m\u000fative to the g\u001b[30m\u001b[103ml\u001b[m\u000foba\u001b[30m\u001b[103ml\u001b[17;8Hl\u001b[m\u000ft Va\u001b[30m\u001b[103ml\u001b[18;23Hl\u001b[m\u000fs/$poo\u001b[30m\u001b[103ml\u001b[20;29Hl\u001b[m\u000fd processes. This can be used on\u001b[30m\u001b[103ml\u001b[21;56Hl\u001b[24;42Hl\u001b[25;12Hll\u001b[26;8Hl\u001b[m\u000ft Va\u001b[30m\u001b[103ml\u001b[m\u000fues: The user is set to master process running user by defau\u001b[30m\u001b[103ml\u001b[32;5Hl\u001b[33;33Hl\u001b[35;33Hl\u001b[37;33Hl\u001b[m\u000fisten on a TCP socket to a\u001b[30m\u001b[103mll\u001b[39;33Hl\u001b[40;16Hl\r\nl\u001b[43;7Hl\u001b[m\u000fisten(2) back\u001b[30m\u001b[103ml\u001b[44;8Hl\u001b[m\u000ft Va\u001b[30m\u001b[103ml\u001b[45;2Hl\u001b[m\u000fisten.back\u001b[30m\u001b[103ml\u001b[47;156H\u001b[0;10;7m\u000f8\u001b[48;3H\u001b[?25h"]
[0.209, "o", "\u001b[?25l\u001b[m\u000fi"]
[0.004, "o", "\u001b[1;18Hl\u001b[2;13Hle $pool can be used in any directive and will be repl\u001b[3;6Hl\u001b[6;10Hl\u001b[7;8Hly app\u001b[30m\u001b[103mli\u001b[m\u000fes on the foll\u001b[8;13Hl\u001b[9;7Hlowl\u001b[10;7H\u001b[30m\u001b[103mi\u001b[13;12H\u001b[m\u000fl\u001b[14;18Hl\u001b[15;22Hlobal prefix (or /usr) app\u001b[30m\u001b[103mli\u001b[16;29H\u001b[m\u000flso be relative to the global\u001b[17;8Hlt Val\u001b[18;23Hls/$pool\u001b[20;29Hld processes. This can be used onl\u001b[21;56Hl\u001b[24;42Hl\u001b[25;12Hll\u001b[26;8Hlt Values: The user is set to master process running user by defaul\u001b[32;6H\u001b[30m\u001b[103mi\u001b[33;34Hi\u001b[35;34Hi\u001b[37;34Hi\u001b[m\u000fsten on a TCP socket to all\u001b[39;34H\u001b[30m\u001b[103mi\u001b[40;16H\u001b[m\u000fl\u001b[41;2H\u001b[30m\u001b[103mi\u001b[43;8Hi\u001b[m\u000fsten(2) backl\u001b[44;8Hlt Val\u001b[45;3H\u001b[30m\u001b[103mi\u001b[m\u000fsten.backl\u001b[47;153H\u001b[0;10;7m\u000f7,14\u001b[48;4H\u001b[?25h"]
[0.309, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.005, "o", "\u001b[1;3HDefault Value: not set\u001b[7X\u001b[2;2Hpm.status_path = /status\u001b[52X\r\n\u001b[24X\n; The address on which to accept FastCGI status request. This creates a new\r\n; invisible pool that can handle requests independently. This is useful\u001b[6;3Hif the main pool is busy with long running requests because it is still possible\u001b[7;3Hto get the status before finishing the long running requests.\u001b[8;2H\u001b[15X\u001b[9;3HValid syntaxes are:\u001b[10;3H  'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\u001b[11;3H                           a specific port;\u001b[12;3H  '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\u001b[13;3H                           a specific port;\u001b[14;3H  'port'                 - to listen on a TCP socket to all addresses\u001b[15;3H                           (IPv6 and IPv4-mapped) on a specific port;\u001b[16;3H  '/path/to/unix/socket' - to listen on a unix socket.\u001b[9X\u001b[17;18Hvalue of the listen option\u001b[18;3Hm.status_listen = 127.0.0.1:9001\u001b[20;3HThe ping URI to call the monitoring page of FPM. If this value is not set, no\u001b[21;3HURI will be recognized as a ping page. This could be used to test from outside\u001b[22;3Hthat FPM is alive and responding, or to\u001b[37X\u001b[23;3H- create a graph of FPM availabi\u001b[30m\u001b[103mlit\u001b[m\u000fy (rrd or such);\u001b[24;3H- remove a server from a group if it is not responding (load balancing);\u001b[25;3H- trigger alerts for the operating team (24/7).\u001b[26;3HNote: The value must start with a leading slash (/). The value can be\u001b[5X\u001b[27;9Hanything, but it may not be a good idea to use the .php extension or it\r\n;       may conflict with a real PHP file.\r\n; Default Value: not set\r\n;ping.path = /ping\r\n\u001b[50X\u001b[32;3HThis directive may be used to customize the response of a ping request. The\u001b[33;3Hresponse is formatted as text/plain with a 200 response code.\u001b[21X\u001b[34;3HDefault Value: pong\u001b[24X\u001b[35;2Hping.response = pong\u001b[63X\r\n\u001b[45X\u001b[37;3HThe access log file\u001b[50X\u001b[38;3HDefault: not set\u001b[53X\u001b[39;2Haccess.log = log/$pool.access.log\u001b[22X\r\n\u001b[32X\n; The access log format.\u001b[10X\r\n; The following syntax is allowed\u001b[43;3H %%: the '%' character\u001b[44;3H %C: %CPU used by the request\u001b[24X\u001b[45;2H      it can accept the following format:\r\n;      - %{user}C for user CPU only\u001b[47;153H\u001b[0;10;7m\u000f279,35         57%\u001b[48;5H\u001b[?25h"]
[0.189, "o", "\u001b[?25l\u001b[m\u000fe"]
[0.005, "o", "\u001b[1;3HStart a new pool named 'www'.\u001b[2;2H the variable $pool can be used in any directive and will be replaced by the\r\n; pool name ('www' here)\r\n\u001b[96m[www]\u001b[m\u000f\u001b[70X\r\n\u001b[71X\u001b[6;3HPer pool prefix\u001b[65X\u001b[7;3HIt only applies on the following directives:\u001b[17X\u001b[8;2H - 'access.log'\u001b[9;3H- 'slowlog'\u001b[8X\u001b[10;3H- 'listen' (unixsocket)\u001b[59X\u001b[11;3H- 'chroot'\u001b[33X\u001b[12;3H- 'chdir'\u001b[73X\u001b[13;3H- 'php_values'\u001b[29X\u001b[14;3H- 'php_admin_values'\u001b[49X\u001b[15;3HWhen not set, the global prefix (or /usr) applies instead.\u001b[11X\u001b[16;3HNote: This directive can also be relative to the global prefix.\u001b[17;18Hnone\u001b[22X\u001b[18;3Hrefix = /path/to/pools/$pool    \u001b[20;3HUnix user/group of the child processes. This can be used only if the master  \u001b[21;3Hprocess running user is root. It is set after the child process is created.   \u001b[22;3HThe user and group can be specified either by their name or by their numeric\u001b[23;3HIDs.\u001b[47X\u001b[24;3HNote: If the user is root, the executable needs to be started with\u001b[6X\u001b[25;3H      --allow-to-run-as-root option to work.   \u001b[26;3HDefault Values: The user is set to master process running user by default.\u001b[27;9H          If the group is not set, the user's group is used.\u001b[11X\r\nuser =\u001b[92m http\u001b[m\u000f\u001b[31X\r\ngroup =\u001b[92m http\u001b[m\u000f\u001b[12X\r\n\u001b[18X\n; The address on which to accept FastCGI requests.\u001b[32;3HValid syntaxes are:\u001b[56X\u001b[33;3H  'ip.add.re.ss:port'    - to listen on a TCP socket to a specific IPv4 address on\u001b[34;3H                           a specific port;\u001b[35;2H   '[ip:6:addr:ess]:port' - to listen on a TCP socket to a specific IPv6 address on\r\n;                            a specific port;\u001b[37;3H  'port'                 - to listen on a TCP socket to all addresses\u001b[38;3H                           (IPv6 and IPv4-mapped) on a specific port;\u001b[39;2H   '/path/to/unix/socket' - to listen on a unix socket.\r\n; Note: This value is mandatory.\r\nlisten =\u001b[92m /run/php-fpm/php-fpm.sock\u001b[m\u000f\r\n\u001b[33X\u001b[43;3HSet listen(2) backlog.\u001b[44;3HDefault Value: 511 (-1 on Linux, FreeBSD and OpenBSD)\u001b[45;2Hlisten.backlog = 511\u001b[21X\r\n\u001b[35X\u001b[47;153H\u001b[0;10;7m\u000f1,1            Top\u001b[48;6H\u001b[?25h"]
