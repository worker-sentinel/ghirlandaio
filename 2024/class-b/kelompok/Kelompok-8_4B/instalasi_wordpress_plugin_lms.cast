[0.009, "o", "\u001b[23;17H\u001b[30m\u001b[103my\u001b[m\u000f_html_module modules/mod_\u001b[30m\u001b[103mproxy\u001b[43;17Hy\u001b[m\u000f_module modules/mod_\u001b[30m\u001b[103mproxy\u001b[44;17Hy\u001b[m\u000f_connect_module modules/mod_\u001b[30m\u001b[103mproxy\u001b[45;17Hy\u001b[m\u000f_ftp_module modules/mod_\u001b[30m\u001b[103mproxy\u001b[46;17Hy\u001b[m\u000f_http_module modules/mod_\u001b[30m\u001b[103mproxy\u001b[48;7H\u001b[?25h"]
[2.380, "o", "\u001b[?25l\u001b[C"]
[0.006, "o", "\u001b[1;2H\u001b[m\u000f for a discussion of each configuration directive.\u001b[6X\u001b[2;2H\u001b[66X\n Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\u001b[4;2H what they do.  They're here only as hints or reminders.  If you are unsure\u001b[5;2H consult the online docs. You have been warned.  \u001b[6;2H\u001b[40X\n Configuration and logfile names: If the filenames you specify for many\u001b[8;2H of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[9;2H server will use that explicit path.  If the filenames do *not* begin\u001b[10;2H with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\u001b[11;2H with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\n# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \u001b[13;2H will be interpreted as '/logs/access_log'.\u001b[11X\r\n\u001b[49X\n#\u001b[47X\r\n# ServerRoot: The top of the directory tree under which the server's\u001b[17;2H configuration, error, and log files are kept.\u001b[6X\u001b[18;2H\u001b[54X\n Do not add a slash at the end of the directory path.  If you point\u001b[20;2H ServerRoot at a non-local disk, be sure to specify a local disk on the\u001b[21;2H Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[22;2H same ServerRoot for multiple httpd daemons, you will need to change at\u001b[23;2H least PidFile.\u001b[39X\u001b[24;2H\u001b[46X\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[19X\r\n\u001b[43X\n#\u001b[53X\n Mutex: Allows you to set the mutex mechanism and mutex file directory\u001b[29;2H for individual mutexes, or change the global defaults    \u001b[30;2H\u001b[44X\n Uncomment and change the directory if mutexes are file-based and the default\r\n# mutex file directory is not on a local disk or is not appropriate for some\u001b[33;2H other reason.\u001b[40X\u001b[34;2H\u001b[52X\n Mutex default:/run/httpd\u001b[23X\r\n\u001b[48X\u001b[37;2H\u001b[44X\n Listen: Allows you to bind Apache to specific IP addresses and/or\u001b[39;2H ports, instead of the default. See also the <VirtualHost>\r\n# directive.\u001b[38X\r\n#\u001b[47X\n Change this to Listen on specific IP addresses as shown below to \u001b[43;2H prevent Apache from glomming onto all bound IP addresses.\u001b[44;2H\u001b[60X\u001b[45;3Histen 12.34.56.78:80\u001b[31X\r\n\u001b[96mListen\u001b[m\u000f 80\u001b[46X\u001b[47;153H\u001b[0;10;7m\u000f52,1            1\u001b[48;8H\u001b[?25h"]
[0.766, "o", "\u001b[?25l\u001b[m\u000fc"]
[0.007, "o", "\u001b[?25h"]
