[0.005, "o", "\u001b[1;2HInclude conf/extra/httpd-dav.conf\r\n\u001b[72X\u001b[3;3HVarious default settings\u001b[50X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-default.conf\u001b[33X\r\n\u001b[72X\u001b[6;3HConfigure mod_proxy_html to understand HTML4/XHTML1\u001b[19X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f proxy_html_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[49X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/proxy-html.conf\u001b[10X\r\n\u001b[0;10;1m\u000f</IfModule>\r\n\u001b[m\u000f \u001b[11;5Hcure (SSL/TLS) connections\u001b[38X\u001b[12;2HInclude conf/extra/httpd-ssl.conf\u001b[13X\u001b[14;3HNote: The following must be present to support\u001b[20X\u001b[15;3H      starting without SSL on platforms with no /dev/random equivalent\u001b[16;3H      but a statically compiled-in mod_ssl.\u001b[31X\u001b[17;2H\u001b[71X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f ssl_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f\u001b[96mSSLRandomSeed\u001b[m\u000f startup builtin\u001b[20;2H\u001b[96mSLRandomSeed\u001b[m\u000f connect builtin\r\n\u001b[0;10;1m\u000f</IfModule>\r\n\u001b[m\u000f \r\nIncludeOptional conf/conf.d/*.conf\u001b[37X\r\n\u001b[55X\n\u001b[0;10;1m\u000f<FilesMatch\u001b[m\u000f \"\\.php$\"\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    \u001b[96mSetHandler\u001b[m\u000f \u001b[92m\"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[m\u000f\u001b[7X\r\n\u001b[0;10;1m\u000f</FilesMatch>\u001b[m\u000f    \u001b[59X\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f520,13         Bot\u001b[48;5H\u001b[?25h"]
