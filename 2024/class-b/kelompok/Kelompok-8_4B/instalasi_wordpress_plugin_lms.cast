[0.005, "o", "\u001b[1;46r\u001b[H\u001b[9M\u001b[1;48r\u001b[1;6Hlisten'\u001b[24;33Hlisten \u001b[26;33Hlisten \u001b[28;33Hlisten \u001b[30;33Hlisten \r\n\nlisten \u001b[34;7Hlisten(\u001b[36;2Hlisten.\r\n\n; Set permissions for unix socket, if one is used. In Linux, read/write\u001b[K\r\n; permissions must be set in order to allow connections from a web server. Many\u001b[K\r\n; BSD-derived systems allow connections regardless of permissions. The owner\u001b[K\r\n; and group can be specified either by name or by their numeric IDs.\u001b[K\r\n; Default Values: Owner is set to the master process running user. If the group\u001b[K\r\n;                 is not set, the owner's group is used. Mode is set to 0660.\u001b[K\r\nlisten.owner =\u001b[92m http\u001b[m\u000f\u001b[K\r\nlisten.group =\u001b[92m http\u001b[m\u000f\u001b[K\r\n;\u001b[30m\u001b[103mlisten.m\u001b[m\u000fode = 0660\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f55,2            2%\u001b[48;10H\u001b[?25h"]
