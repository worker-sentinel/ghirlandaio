[0.004, "o", "\u001b[?25l\u001b[m\u000f<?php\u001b[K\r\n/**\u001b[K\r\n * The base configuration for WordPress\u001b[K\r\n *\u001b[K\r\n * The wp-config.php creation script uses this file during the installation.\u001b[K\r\n * You don't have to use the website, you can copy this file to \"wp-config.php\"\u001b[K\r\n * and fill in the values.\u001b[K\r\n *\u001b[K\r\n * This file contains the following configurations:\u001b[K\r\n *\u001b[K\r\n * * Database settings\u001b[K\r\n * * Secret keys\u001b[K\r\n * * Database table prefix\u001b[K\r\n * * ABSPATH\u001b[K\r\n *\u001b[K\r\n * @link https://developer.wordpress.org/advanced-administration/wordpress/wp-config/\u001b[K\r\n *\u001b[K\r\n * @package WordPress\u001b[K\r\n */\u001b[K\r\n\u001b[K\n// ** Database settings - You can get this info from your web host ** //\u001b[K\r\n/** The name of the database for WordPress */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_NAME'\u001b[m\u000f, \u001b[92m'database_name_here'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database username */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_USER'\u001b[m\u000f, \u001b[92m'username_here'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database password */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_PASSWORD'\u001b[m\u000f, \u001b[92m'password_here'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database hostname */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_HOST'\u001b[m\u000f, \u001b[92m'localhost'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database charset to use in creating database tables. */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_CHARSET'\u001b[m\u000f, \u001b[92m'utf8mb4'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** The database collate type. Don't change this if in doubt. */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_COLLATE'\u001b[m\u000f, \u001b[92m''\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/**#@+\u001b[K\r\n * Authentication unique keys and salts.\u001b[K\r\n *\u001b[K\r\n * Change these to different unique phrases! You can generate these using\u001b[K\r\n * the {@link https://api.wordpress.org/secret-key/1.1/salt/ WordPress.org secret-key service}.\u001b[K\r\n *\u001b[K\r\n * You can change these at any point in time to invalidate all existing cookies.\u001b[K\r\n\u001b[0;10;7m\u000fwp-config.php                                                                                                                                           1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H<?php\u001b[K\r\n/**\u001b[K\r\n * The base configuration for WordPress\u001b[K\r\n *\u001b[K\r\n * The wp-config.php creation script uses this file during the installation.\u001b[K\r\n * You don't have to use the website, you can copy this file to \"wp-config.php\"\u001b[K\r\n * and fill in the values.\u001b[K\r\n *\u001b[K\r\n * This file contains the following configurations:\u001b[K\r\n *\u001b[K\r\n * * Database settings\u001b[K\r\n * * Secret keys\u001b[K\r\n * * Database table prefix\u001b[K\r\n * * ABSPATH\u001b[K\r\n *\u001b[K\r\n * @link https://developer.wordpress.org/advanced-administration/wordpress/wp-config/\u001b[K\r\n *\u001b[K\r\n * @package WordPress\u001b[K\r\n */\u001b[K\r\n\u001b[K\n// ** Database settings - You can get this info from your web host ** //\u001b[K\r\n/** The name of the database for WordPress */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_NAME'\u001b[m\u000f, \u001b[92m'database_name_here'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database username */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_USER'\u001b[m\u000f, \u001b[92m'username_here'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database password */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_PASSWORD'\u001b[m\u000f, \u001b[92m'password_here'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database hostname */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_HOST'\u001b[m\u000f, \u001b[92m'localhost'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** Database charset to use in creating database tables. */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_CHARSET'\u001b[m\u000f, \u001b[92m'utf8mb4'\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/** The database collate type. Don't change this if in doubt. */\u001b[K\r\n\u001b[96mdefine\u001b[m\u000f( \u001b[92m'DB_COLLATE'\u001b[m\u000f, \u001b[92m''\u001b[m\u000f );\u001b[K\r\n\u001b[K\n/**#@+\u001b[K\r\n * Authentication unique keys and salts.\u001b[K\r\n *\u001b[K\r\n * Change these to different unique phrases! You can generate these using\u001b[K\r\n * the {@link https://api.wordpress.org/secret-key/1.1/salt/ WordPress.org secret-key service}.\u001b[K\r\n *\u001b[K\r\n * You can change these at any point in time to invalidate all existing cookies.\u001b[K\r\n\u001b[0;10;7m\u000fwp-config.php                                                                                                                                           1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
