[0.279, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[1;19Ha/httpd-da\u001b[3;4Harious defa\u001b[4;18Ha/httpd-defa\u001b[6;38Ha\u001b[8;18Ha\n\n\n\na\u001b[15;11Harting without SSL on platforms with no /dev/random equiva\u001b[16;13Ha statica\u001b[19;5H\u001b[96mandomSeed\u001b[m\u000f sta\u001b[20;5H\u001b[96ma\u001b[23;14H\u001b[m\u000fa\u001b[25;8H\u001b[0;10;1m\u000fa\n\u001b[m\u000f\u001b[96mandler\u001b[m\u000f \u001b[92m\"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://loca\u001b[27;9H\u001b[0;10;1m\u000fa\u001b[47;158H\u001b[0;10;7m\u000f3\u001b[48;2H\u001b[?25h"]
[0.575, "o", "\u001b[?25l\u001b[m\u000fA"]
[0.006, "o", "\u001b[1;2H\u001b[33X\r\n# This is the main \u001b[30m\u001b[103mA\u001b[m\u000fpache HTTP server configuration file.  It contains the\u001b[3;3Hconfiguration directives that give the server its instructions.\r\n# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\r\n# In particular, see \u001b[6;3H<URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\r\n# for a discussion of each configuration directive.\r\n#\u001b[33X\r\n# Do \u001b[0;10;1m\u000fNOT\u001b[m\u000f simply read the instructions in here without understanding\r\n# what they do.  They're here only as hints or reminders.  If you are unsure\u001b[11;3Hconsult the online docs. You have been warned.  \u001b[12;2H\u001b[33X\n Configuration and logfile names: If the filenames you specify for many\u001b[14;3Hof the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\u001b[15;3Hserver will use that explicit path.  If the filenames do *not* begin  \u001b[16;3Hwith \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\u001b[17;2H with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\n# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\" \r\n# will be interpreted as '/logs/access_log'.\r\n\u001b[29X\n#\u001b[10X\r\n# ServerRoot: The top of the directory tree under which the server's\r\n# configuration, error, and log files are kept.\r\n#\r\n# Do not add a slash at the end of the directory path.  If you point\r\n# ServerRoot at a non-local disk, be sure to specify a local disk on the\r\n# Mutex directive, if file-based mutexes are used.  If you wish to share the\r\n# same ServerRoot for multiple httpd daemons, you will need to change at\u001b[K\r\n# least PidFile.\u001b[K\r\n#\u001b[K\r\n\u001b[96mServerRoot\u001b[m\u000f \u001b[92m\"/etc/httpd\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Mutex: \u001b[30m\u001b[103mA\u001b[m\u000fllows you to set the mutex mechanism and mutex file directory\u001b[K\r\n# for individual mutexes, or change the global defaults\u001b[K\r\n#\u001b[K\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[K\r\n# mutex file directory is not on a local disk or is not appropriate for some\u001b[K\r\n# other reason.\u001b[K\r\n#\u001b[K\r\n# Mutex default:/run/httpd\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Listen: \u001b[30m\u001b[103mA\u001b[m\u000fllows you to bind \u001b[30m\u001b[103mA\u001b[m\u000fpache to specific IP addresses and/or\u001b[K\r\n# ports, instead of the default. See also the <VirtualHost>\u001b[K\r\n# directive.\u001b[K\u001b[47;153H\u001b[0;10;7m\u000f2,20           Top\u001b[48;3H\u001b[?25h"]
