[0.773, "o", "\u001b[?2004l\u001b[K\r\r\n"]
[0.017, "o", "==> Creating install root at /mnt\r\n"]
[0.047, "o", "==> Installing packages to /mnt\r\n"]
[0.016, "o", "\u001b[?25l\u001b[1;34m::\u001b[0;1m Synchronizing package databases...\r\n\u001b[0m"]
[0.000, "o", " core\r\n extra\r\n"]
[0.098, "o", "\u001b[2F core is up to date\u001b[K"]
[0.190, "o", "\u001b[1E extra is up to date\u001b[K"]
[0.187, "o", "\u001b[1E"]
[0.213, "o", "resolving dependencies...\r\n"]
[0.004, "o", "\u001b[1;34m::\u001b[0;1m There are 2 providers available for libxtables.so=12-64:\r\n\u001b[0m\u001b[1;34m::\u001b[0;1m Repository \u001b[1;35mcore\r\n\u001b[0m\u001b[0;1m  \u001b[0m 1) iptables  2) iptables-legacy\r\n\r\nEnter a number (default=1): \r\n"]
