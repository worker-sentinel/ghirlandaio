[0.003, "o", "\u001b[0;1;31m Mount point '/boot' which backs the random seed file is world accessible, which is a security hole! \u001b[0m\r\r\n\u001b[0;1;31mRandom seed file '/boot/loader/.#bootctlrandom-seed893e9af271633296' is world accessible, which is a security hole!\u001b[0m\r\r\n"]
[0.003, "o", "Random seed file /boot/loader/random-seed successfully written (32 bytes).\r\r\n\u001b[0;1;39mNot booted with EFI or running in a container, skipping EFI variable modifications.\u001b[0m\r\r\n"]
