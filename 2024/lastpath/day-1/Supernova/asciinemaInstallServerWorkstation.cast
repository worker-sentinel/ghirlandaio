[0.004, "o", "Running in a chroot, enabling --graceful.\r\r\n"]
[0.069, "o", "Created directory \"/boot/EFI\".\r\r\nCreated directory \"/boot/EFI/systemd\".\r\r\nCreated directory \"/boot/EFI/BOOT\".\r\r\n"]
