[0.000, "o", "\u001b[?25l\u001b[m\u000f# Configuration file for locale-gen\u001b[K\r\n#\u001b[K\r\n# lists of locales that are to be generated by the locale-gen command.\u001b[K\r\n#\u001b[K\r\n# Each line is of the form:\u001b[K\r\n#\u001b[K\r\n#     <locale> <charset>\u001b[K\r\n#\u001b[K\r\n#  where <locale> is one of the locales given in /usr/share/i18n/locales\u001b[K\r\n#  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\u001b[K\r\n#\u001b[K\r\n#  The locale-gen command will generate all the locales,\u001b[K\r\n#  placing them in /usr/lib/locale.\u001b[K\r\n#\u001b[K\r\n#  A list of supported locales is given in /usr/share/i18n/SUPPORTED\u001b[K\r\n#  and is included in this file. Uncomment the needed locales below.\u001b[K\r\n#\u001b[K\r\n#aa_DJ.UTF-8 UTF-8  \u001b[K\r\n#aa_DJ ISO-8859-1  \u001b[K\r\n#aa_ER UTF-8  \u001b[K\r\n#aa_ET UTF-8  \u001b[K\r\n#af_ZA.UTF-8 UTF-8  \u001b[K\r\n#af_ZA ISO-8859-1  \u001b[K\r\n#agr_PE UTF-8  \u001b[K\r\n#ak_GH UTF-8  \u001b[K\r\n#am_ET UTF-8  \u001b[K\r\n#an_ES.UTF-8 UTF-8  \u001b[K\r\n#an_ES ISO-8859-15  \u001b[K\r\n#anp_IN UTF-8  \u001b[K\r\n#ar_AE.UTF-8 UTF-8  \u001b[K\r\n#ar_AE ISO-8859-6  \u001b[K\r\n#ar_BH.UTF-8 UTF-8  \u001b[K\r\n#ar_BH ISO-8859-6  \u001b[K\r\n#ar_DZ.UTF-8 UTF-8  \u001b[K\r\n#ar_DZ ISO-8859-6  \u001b[K\r\n#ar_EG.UTF-8 UTF-8  \u001b[K\r\n#ar_EG ISO-8859-6  \u001b[K\r\n#ar_IN UTF-8  \u001b[K\r\n#ar_IQ.UTF-8 UTF-8  \u001b[K\r\n#ar_IQ ISO-8859-6  \u001b[K\r\n#ar_JO.UTF-8 UTF-8  \u001b[K\r\n#ar_JO ISO-8859-6  \u001b[K\r\n#ar_KW.UTF-8 UTF-8  \u001b[K\r\n#ar_KW ISO-8859-6  \u001b[K\r\n#ar_LB.UTF-8 UTF-8  \u001b[K\r\n#ar_LB ISO-8859-6  \u001b[K\r\n#ar_LY.UTF-8 UTF-8  \u001b[K\r\n#ar_LY ISO-8859-6  \u001b[K\r\n#ar_MA.UTF-8 UTF-8  \u001b[K\r\n#ar_MA ISO-8859-6  \u001b[K\r\n#ar_OM.UTF-8 UTF-8  \u001b[K\r\n#ar_OM ISO-8859-6  \u001b[K\r\n#ar_QA.UTF-8 UTF-8  \u001b[K\r\n#ar_QA ISO-8859-6  \u001b[K\r\n#ar_SA.UTF-8 UTF-8  \u001b[K\r\n#ar_SA ISO-8859-6  \u001b[K\r\n#ar_SD.UTF-8 UTF-8  \u001b[K\r\n#ar_SD ISO-8859-6  \u001b[K\r\n#ar_SS UTF-8  \u001b[K\r\n#ar_SY.UTF-8 UTF-8  \u001b[K\r\n#ar_SY ISO-8859-6  \u001b[K\r\n#ar_TN.UTF-8 UTF-8  \u001b[K\r\n#ar_TN ISO-8859-6  \u001b[K\r\n#ar_YE.UTF-8 UTF-8  \u001b[K\r\n#ar_YE ISO-8859-6  \u001b[K\r\n\u001b[0;10;7m\u000fetc/locale.gen                                                                                                                                                                                                                1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# Configuration file for locale-gen\u001b[K\r\n#\u001b[K\r\n# lists of locales that are to be generated by the locale-gen command.\u001b[K\r\n#\u001b[K\r\n# Each line is of the form:\u001b[K\r\n#\u001b[K\r\n#     <locale> <charset>\u001b[K\r\n#\u001b[K\r\n#  where <locale> is one of the locales given in /usr/share/i18n/locales\u001b[K\r\n#  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\u001b[K\r\n#\u001b[K\r\n#  The locale-gen command will generate all the locales,\u001b[K\r\n#  placing them in /usr/lib/locale.\u001b[K\r\n#\u001b[K\r\n#  A list of supported locales is given in /usr/share/i18n/SUPPORTED\u001b[K\r\n#  and is included in this file. Uncomment the needed locales below.\u001b[K\r\n#\u001b[K\r\n#aa_DJ.UTF-8 UTF-8  \u001b[K\r\n#aa_DJ ISO-8859-1  \u001b[K\r\n#aa_ER UTF-8  \u001b[K\r\n#aa_ET UTF-8  \u001b[K\r\n#af_ZA.UTF-8 UTF-8  \u001b[K\r\n#af_ZA ISO-8859-1  \u001b[K\r\n#agr_PE UTF-8  \u001b[K\r\n#ak_GH UTF-8  \u001b[K\r\n#am_ET UTF-8  \u001b[K\r\n#an_ES.UTF-8 UTF-8  \u001b[K\r\n#an_ES ISO-8859-15  \u001b[K\r\n#anp_IN UTF-8  \u001b[K\r\n#ar_AE.UTF-8 UTF-8  \u001b[K\r\n#ar_AE ISO-8859-6  \u001b[K\r\n#ar_BH.UTF-8 UTF-8  \u001b[K\r\n#ar_BH ISO-8859-6  \u001b[K\r\n#ar_DZ.UTF-8 UTF-8  \u001b[K\r\n#ar_DZ ISO-8859-6  \u001b[K\r\n#ar_EG.UTF-8 UTF-8  \u001b[K\r\n#ar_EG ISO-8859-6  \u001b[K\r\n#ar_IN UTF-8  \u001b[K\r\n#ar_IQ.UTF-8 UTF-8  \u001b[K\r\n#ar_IQ ISO-8859-6  \u001b[