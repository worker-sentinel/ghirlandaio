[0.005, "o", "\u001b[?2026h\u001b[?2031h\u001b[?2048h\u001b[>3u\u001b(B\u001b[m\u001b[43B\u001b[J\u001b[93mE1568: Terminal did not respond to DSR request for 'background' color. Startup may be slower.\u001b[H\u001b(B\u001b[m<?xml version=\u001b[92m\"1.0\"\u001b(B\u001b[m encoding=\u001b[92m\"utf-8\"\u001b(B\u001b[m ?>\u001b[K\r\n\u001b[96m<!\u001b(B\u001b[0;1mDOCTYPE\u001b(B\u001b[m pam_mount \u001b(B\u001b[0;1mSYSTEM\u001b(B\u001b[m \u001b[92m\"pam_mount.conf.xml.dtd\"\u001b(B\u001b[m\u001b[96m>\u001b(B\u001b[m\u001b[K\r\n<!--\u001b[K\r\n        See pam_mount.conf(5) for a description.\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n\u001b[96m<pam_mount>\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n                <!-- debug should come before everything else,\u001b[K\r\n                since this file is still processed in a single pass\u001b[K\r\n                from top-to-bottom -->\u001b[K\r\n\u001b[K\n\u001b[96m<debug \u001b(B\u001b[menable=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n                <!-- Volume definitions -->\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: General tunables -->\u001b[K\r\n\u001b[K\n<!--\u001b[K\r\n<luserconf name=\".pam_mount.conf.xml\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n<!-- Note that commenting out mntoptions will give you the defaults.\u001b[K\r\n     You will need to explicitly initialize it with the empty string\u001b[K\r\n     to reset the defaults to nothing. -->\u001b[K\r\n\u001b[96m<mntoptions \u001b(B\u001b[mallow=\u001b[92m\"nosuid,nodev,loop,encryption,fsck,nonempty,allow_root,allow_other\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n<!--\u001b[K\r\n<mntoptions deny=\"suid,dev\" />\u001b[K\r\n<mntoptions allow=\"*\" />\u001b[K\r\n<mntoptions deny=\"*\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[96m<mntoptions \u001b(B\u001b[mrequire=\u001b[92m\"nosuid,nodev\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n<!-- requires ofl from hxtools to be present -->\u001b[K\r\n\u001b[96m<logout \u001b(B\u001b[mwait=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mhup=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mterm=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mkill=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: Volume-related -->\u001b[K\r\n\u001b[K\n\u001b[96m<mkmountpoint \u001b(B\u001b[menable=\u001b[92m\"1\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mremove=\u001b[92m\"true\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[0;7mpam_mount.conf.xml.pacnew                                                  1,1            Top\u001b[2 q\u001b[2 q\u001b[H\u001b(B\u001b[m<?xml version=\u001b[92m\"1.0\"\u001b(B\u001b[m encoding=\u001b[92m\"utf-8\"\u001b(B\u001b[m ?>\u001b[K\r\n\u001b[96m<!\u001b(B\u001b[0;1mDOCTYPE\u001b(B\u001b[m pam_mount \u001b(B\u001b[0;1mSYSTEM\u001b(B\u001b[m \u001b[92m\"pam_mount.conf.xml.dtd\"\u001b(B\u001b[m\u001b[96m>\u001b(B\u001b[m\u001b[K\r\n<!--\u001b[K\r\n        See pam_mount.conf(5) for a description.\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n\u001b[96m<pam_mount>\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n                <!-- debug should come before everything else,\u001b[K\r\n                since this file is still processed in a single pass\u001b[K\r\n                from top-to-bottom -->\u001b[K\r\n\u001b[K\n\u001b[96m<debug \u001b(B\u001b[menable=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n                <!-- Volume definitions -->\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: General tunables -->\u001b[K\r\n\u001b[K\n<!--\u001b[K\r\n<luserconf name=\".pam_mount.conf.xml\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n<!-- Note that commenting out mntoptions will give you the defaults.\u001b[K\r\n     You will need to explicitly initialize it with the empty string\u001b[K\r\n     to reset the defaults to nothing. -->\u001b[K\r\n\u001b[96m<mntoptions \u001b(B\u001b[mallow=\u001b[92m\"nosuid,nodev,loop,encryption,fsck,nonempty,allow_root,allow_other\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n<!--\u001b[K\r\n<mntoptions deny=\"suid,dev\" />\u001b[K\r\n<mntoptions allow=\"*\" />\u001b[K\r\n<mntoptions deny=\"*\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[96m<mntoptions \u001b(B\u001b[mrequire=\u001b[92m\"nosuid,nodev\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n<!-- requires ofl from hxtools to be present -->\u001b[K\r\n\u001b[96m<logout \u001b(B\u001b[mwait=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mhup=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mterm=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mkill=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: Volume-related -->\u001b[K\r\n\u001b[K\n\u001b[96m<mkmountpoint \u001b(B\u001b[menable=\u001b[92m\"1\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mremove=\u001b[92m\"true\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b(B\u001b[0;7mpam_mount.conf.xml.pacnew                                                  1,1            Top\r\n\u001b(B\u001b[m\u001b[93mE1568: Terminal did not respond to DSR request for 'background' color. Startup may be slower.\u001b[H\u001b[?2026l"]
[0.128, "o", "\u001b[?2026h\u001b(B\u001b[m\u001b[H\u001b[2J<?xml version=\u001b[92m\"1.0\"\u001b(B\u001b[m encoding=\u001b[92m\"utf-8\"\u001b(B\u001b[m ?>\r\n\u001b[96m<!\u001b(B\u001b[0;1mDOCTYPE\u001b(B\u001b[m pam_mount \u001b(B\u001b[0;1mSYSTEM\u001b(B\u001b[m \u001b[92m\"pam_mount.conf.xml.dtd\"\u001b(B\u001b[m\u001b[96m>\r\n\u001b(B\u001b[m<!--\r\n        See pam_mount.conf(5) for a description.\r\n-->\r\n\n\u001b[96m<pam_mount>\u001b[9;17H\u001b(B\u001b[m<!-- debug should come before everything else,\r\n                since this file is still processed in a single pass\r\n                from top-to-bottom -->\r\n\n\u001b[96m<debug \u001b(B\u001b[menable=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m />\u001b[15;17H\u001b(B\u001b[m<!-- Volume definitions -->\u001b[18;17H<!-- pam_mount parameters: General tunables -->\r\n\n<!--\r\n<luserconf name=\".pam_mount.conf.xml\" />\r\n-->\r\n\n<!-- Note that commenting out mntoptions will give you the defaults.\r\n     You will need to explicitly initialize it with the empty string\r\n     to reset the defaults to nothing. -->\r\n\u001b[96m<mntoptions \u001b(B\u001b[mallow=\u001b[92m\"nosuid,nodev,loop,encryption,fsck,nonempty,allow_root,allow_other\"\u001b(B\u001b[m\u001b[96m />\r\n\u001b(B\u001b[m<!--\r\n<mntoptions deny=\"suid,dev\" />\r\n<mntoptions allow=\"*\" />\r\n<mntoptions deny=\"*\" />\r\n-->\r\n\u001b[96m<mntoptions \u001b(B\u001b[mrequire=\u001b[92m\"nosuid,nodev\"\u001b(B\u001b[m\u001b[96m />\r\n\n\u001b(B\u001b[m<!-- requires ofl from hxtools to be present -->\r\n\u001b[96m<logout \u001b(B\u001b[mwait=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mhup=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mterm=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mkill=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m />\u001b[39;17H\u001b(B\u001b[m<!-- pam_mount parameters: Volume-related -->\r\n\n\u001b[96m<mkmountpoint \u001b(B\u001b[menable=\u001b[92m\"1\"\u001b(B\u001b[m\u001b[96m \u001b(B\