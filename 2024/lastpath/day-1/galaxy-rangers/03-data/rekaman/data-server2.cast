[0.480, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3L\u001b[r\u001b[H\u001b[96m<mkmountpoint \u001b(B\u001b[menable=\u001b[92m\"1\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mremove=\u001b[92m\"true\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\n\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H\u001b[K\n                <!-- pam_mount parameters: Volume-related -->\u001b[K\r\n\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H<!-- requires ofl from hxtools to be present -->\u001b[K\r\n\u001b[96m<logout \u001b(B\u001b[mwait=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mhup=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mterm=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m \u001b(B\u001b[mkill=\u001b[92m\"no\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H-->\u001b[K\r\n\u001b[96m<mntoptions \u001b(B\u001b[mrequire=\u001b[92m\"nosuid,nodev\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n\u001b[K\u001b[10B\u001b[?2026l"]
[0.016, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H<mntoptions deny=\"suid,dev\" />\u001b[K\r\n<mntoptions allow=\"*\" />\u001b[K\r\n<mntoptions deny=\"*\" />\u001b[K\r\u001b[13B\u001b[?2026l"]
[0.197, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H     to reset the defaults to nothing. -->\u001b[K\r\n\u001b[96m<mntoptions \u001b(B\u001b[mallow=\u001b[92m\"nosuid,nodev,loop,encryption,fsck,nonempty,allow_root,allow_other\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\n<!--\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H\u001b[K\n<!-- Note that commenting out mntoptions will give you the defaults.\u001b[K\r\n     You will need to explicitly initialize it with the empty string\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H<!--\u001b[K\r\n<luserconf name=\".pam_mount.conf.xml\" />\u001b[K\r\n-->\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H\u001b[K\n                <!-- pam_mount parameters: General tunables -->\u001b[K\r\n\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H\u001b[K\n                <!-- Volume definitions -->\u001b[K\r\n\u001b[K\u001b[1;42r\u001b[H\u001b[3L\u001b[r\u001b[H                from top-to-bottom -->\u001b[K\r\n\u001b[K\n\u001b[96m<debug \u001b(B\u001b[menable=\u001b[92m\"0\"\u001b(B\u001b[m\u001b[96m />\u001b(B\u001b[m\u001b[K\r\u001b[31B\u001b[?2026l"]
