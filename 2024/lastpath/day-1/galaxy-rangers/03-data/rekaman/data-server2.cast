[0.005, "o", "\u001b[?2026h\u001b[?2031h\u001b[?2048h\u001b[>3u\u001b(B\u001b[m# vim:set ft=sh:\u001b[K\r\n# MODULES\u001b[K\r\n# The following modules are loaded before any boot hooks are\u001b[K\r\n# run.  Advanced users may wish to specify all system modules\u001b[K\r\n# in this array.  For instance:\u001b[K\r\n#     MODULES=(usbhid xhci_hcd)\u001b[K\r\nMODULES=()\u001b[K\r\n\u001b[K\n# BINARIES\u001b[K\r\n# This setting includes any additional binaries a given user may\u001b[K\r\n# wish into the CPIO image.  This is run last, so it may be used to\u001b[K\r\n# override the actual binaries included by a given hook\u001b[K\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\r\nBINARIES=()\u001b[K\r\n\u001b[K\n# FILES\u001b[K\r\n# This setting is similar to BINARIES above, however, files are added\u001b[K\r\n# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\r\nFILES=()\u001b[K\r\n\u001b[K\n# HOOKS\u001b[K\r\n# This is the most important setting in this file.  The HOOKS control the\u001b[K\r\n# modules and scripts added to the image, and what happens at boot time.\u001b[K\r\n# Order is important, and it is recommended that you do not change the\u001b[K\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\r\n# help on a given hook.\u001b[K\r\n# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\r\n# 'udev' is _required_ in order to automatically load modules\u001b[K\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\r\n# Examples:\u001b[K\r\n##   This setup specifies all modules in the MODULES setting above.\u001b[K\r\n##   No RAID, lvm2, or encrypted root is needed.\u001b[K\r\n#    HOOKS=(base)\u001b[K\r\n#\u001b[K\r\n##   This setup will autodetect all modules for your system and should\u001b[K\r\n##   work as a sane default\u001b[K\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup will generate a 'full' image which supports most systems.\u001b[K\r\n##   No autodetection is done.\u001b[K\r\n#    HOOKS=(base udev microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n\u001b(B\u001b[0;7m/etc/mkinitcpio.conf                                                       1,1            Top\u001b(B\u001b[m\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# vim:set ft=sh:\u001b[K\r\n# MODULES\u001b[K\r\n# The following modules are loaded before any boot hooks are\u001b[K\r\n# run.  Advanced users may wish to specify all system modules\u001b[K\r\n# in this array.  For instance:\u001b[K\r\n#     MODULES=(usbhid xhci_hcd)\u001b[K\r\nMODULES=()\u001b[K\r\n\u001b[K\n# BINARIES\u001b[K\r\n# This setting includes any additional binaries a given user may\u001b[K\r\n# wish into the CPIO image.  This is run last, so it may be used to\u001b[K\r\n# override the actual binaries included by a given hook\u001b[K\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\r\nBINARIES=()\u001b[K\r\n\u001b[K\n# FILES\u001b[K\r\n# This setting is similar to BINARIES above, however, files are added\u001b[K\r\n# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\r\nFILES=()\u001b[K\r\n\u001b[K\n# HOOKS\u001b[K\r\n# This is the most important setting in this file.  The HOOKS control the\u001b[K\r\n# modules and scripts added to the image, and what happens at boot time.\u001b[K\r\n# Order is important, and it is recommended that you do not change the\u001b[K\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\r\n# help on a given hook.\u001b[K\r\n# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\r\n# 'udev' is _required_ in order to automatically load modules\u001b[K\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\r\n# Examples:\u001b[K\r\n##   This setup specifies all modules in the MODULES setting above.\u001b[K\r\n##   No RAID, lvm2, or encrypted root is needed.\u001b[K\r\n#    HOOKS=(base)\u001b[K\r\n#\u001b[K\r\n##   This setup will autodetect all modules for your system and should\u001b[K\r\n##   work as a sane default\u001b[K\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup will generate a 'full' image which supports most systems.\u001b[K\r\n##   No autodetection is done.\u001b[K\r\n#    HOOKS=(base udev microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n\u001b(B\u001b[0;7m/etc/mkinitcpio.conf                                                       1,1            Top\u001b(B\u001b[m\r\n\u001b[J\u001b[H\u001b[?2026l"]
[0.003, "o", "\u001b[?2026h\u001b[?1004h\u001b[?2026l"]
[0.105, "o", "\u001b[?2026h\u001b[H\u001b[2J# vim:set ft=sh:\r\n# MODULES\r\n# The following modules are loaded before any boot hooks are\r\n# run.  Advanced users may wish to specify all system modules\r\n# in this array.  For instance:\r\n#     MODULES=(usbhid xhci_hcd)\r\nMODULES=()\r\n\n# BINARIES\r\n# This setting includes any additional binaries a given user may\r\n# wish into the CPIO image.  This is run last, so it may be used to\r\n# override the actual binaries included by a given hook\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\r\nBINARIES=()\r\n\n# FILES\r\n# This setting is similar to BINARIES above, however, files are added\r\n# as-is and are not parsed in any way.  This is useful for config files.\r\nFILES=()\r\n\n# HOOKS\r\n# This is the most important setting in this file.  The HOOKS control the\r\n# modules and scripts added to the image, and what happens at boot time.\r\n# Order is important, and it is recommended that you do not change the\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\r\n# help on a given hook.\r\n# 'base' is _required_ unless you know precisely what you are doing.\r\n# 'udev' is _required_ in order to automatically load modules\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\r\n# Examples:\r\n##   This setup specifies all modules in the MODULES setting above.\r\n##   No RAID, lvm2, or encrypted root is needed.\r\n#    HOOKS=(base)\r\n#\r\n##   This setup will autodetect all modules for your system and should\r\n##   work as a sane default\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\r\n#\r\n##   This setup will generate a 'full' image which supports most systems.\r\n##   No autodetection is done.\r\n#    HOOKS=(base udev microcode modconf block filesystems fsck)\r\n#\r\n\u001b(B\u001b[0;7m/etc/mkinitcpio.conf                                                       1,1            Top\r\n\u001b(B\u001b[m                                                                                             \u001b[H\u001b[?2026l"]
[0.001, "o", "\u001b[?2026h\u001b[2 q\u001b[2 q\u001b[?2026l"]
[3.684, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b[3M\u001b[r\u001b[40;1H##   This setup assembles a mdadm array with an encrypted root file system.\u001b[K\r\n##   Note: See 'mkinitcpio -H mdadm_udev' for more information on RAID devices.\u001b[K\r\n#    HOOKS=(base udev microcode modconf keyboard keymap consolefont block mdadm_udev encrypt \u001b[42;91H@@@\u001b[43;76H\u001b(B\u001b[0;7m4,1             7%\u001b[H\u001b[?2026l"]
[0.101, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[39;91Hpt filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup loads an lvm2 volume group.\u001b[K\u001b[43;76H\u001b(B\u001b[0;7m7,1            15\u001b[H\u001b[?2026l"]
[0.106, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H#    HOOKS=(base udev microcode modconf block lvm2 filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This will create a systemd based initramfs which loads an encrypted root filesystem.\u001b[K\u001b[43;76H\u001b(B\u001b[0;7m10,1           22\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H#    HOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block sd-encrypt filesystems fsck)\u001b[K\r\n#\u001b[K\u001b[43;77H\u001b(B\u001b[0;7m3,1           29\u001b[H\u001b[?2026l"]
[0.107, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H##   NOTE: If you have /usr on a separate partition, you MUST include the\u001b[K\r\n#    usr and fsck hooks.\u001b[K\r\nHOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block filesystems f\u001b[42;91H@@@\u001b[43;77H\u001b(B\u001b[0;7m6,1           35\u001b[H\u001b[?2026l"]
[0.093, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[39;91Hs fsck)\u001b[K\r\n\u001b[K\n# COMPRESSION\u001b[K\u001b[43;77H\u001b(B\u001b[0;7m9,1           42\u001b[H\u001b[?2026l"]
[0.104, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H# Use this to compress the initramfs image. By default, zstd compression\u001b[K\r\n# is used for Linux ≥\u001b[41;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\r\n# Use 'cat' to create an uncompressed image.\u001b[K\u001b[43;76H\u001b(B\u001b[0;7m22,1           50\u001b[H\u001b[?2026l"]
[0.312, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H#COMPRESSION=\"zstd\"\u001b[K\r\n#COMPRESSION=\"gzip\"\u001b[K\r\n#COMPRESSION=\"bzip2\"\u001b[K\u001b[43;77H\u001b(B\u001b[0;7m5,1           57\u001b[H\u001b[?2026l"]
[0.199, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H#COMPRESSION=\"lzma\"\u001b[K\r\n#COMPRESSION=\"xz\"\u001b[K\r\n#COMPRESSION=\"lzop\"\u001b[K\u001b[43;77H\u001b(B\u001b[0;7m8,1           64\u001b[H\u001b[?2026l"]
[0.003, "o", "\u001b[?2026h\u001b[1;42r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[40;1H#COMPRESSION=\"lz4\"\u001b[K\r\n\u001b[K\n# COMPRESSION_OPTIONS\u001b[K\u001b[43;76H\u001b(B\u001b[0;7m31,1           71\u001b[H\u001b[?2026l"]
