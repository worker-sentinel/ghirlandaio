[0.000, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/kernel/vmlinuz-linux-hardened -c /etc/mkinitcpio.d/default.conf -U /boot/efi/linux/arch-linux-hardened.efi\u001b[m\u000f\r\n"]
[0.020, "o", "==> ERROR: Invalid option -U -- '/boot/efi/linux/arch-linux-hardened.efi' must be writable\r\n"]
