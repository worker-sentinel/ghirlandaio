[0.202, "o", "\u001b[c\u001b[?25l\u001b(B\u001b[m\u001b[39B\u001b[J\u001b[93mE1568: Terminal did not respond to DSR request for 'background' color. Startup may be slower. :help 'ttyfast'\u001b[H\u001b(B\u001b[m# vim:set ft=sh:\u001b[K\r\n# MODULES\u001b[K\r\n# The following modules are loaded before any boot hooks are\u001b[K\r\n# run.  Advanced users may wish to specify all system modules\u001b[K\r\n# in this array.  For instance:\u001b[K\r\n#     MODULES=(usbhid xhci_hcd)\u001b[K\r\nMODULES=()\u001b[K\r\n\u001b[K\n# BINARIES\u001b[K\r\n# This setting includes any additional binaries a given user may\u001b[K\r\n# wish into the CPIO image.  This is run last, so it may be used to\u001b[K\r\n# override the actual binaries included by a given hook\u001b[K\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\r\nBINARIES=()\u001b[K\r\n\u001b[K\n# FILES\u001b[K\r\n# This setting is similar to BINARIES above, however, files are added\u001b[K\r\n# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\r\nFILES=()\u001b[K\r\n\u001b[K\n# HOOKS\u001b[K\r\n# This is the most important setting in this file.  The HOOKS control the\u001b[K\r\n# modules and scripts added to the image, and what happens at boot time.\u001b[K\r\n# Order is important, and it is recommended that you do not change the\u001b[K\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\r\n# help on a given hook.\u001b[K\r\n# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\r\n# 'udev' is _required_ in order to automatically load modules\u001b[K\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\r\n# Examples:\u001b[K\r\n##   This setup specifies all modules in the MODULES setting above.\u001b[K\r\n##   No RAID, lvm2, or encrypted root is needed.\u001b[K\r\n#    HOOKS=(base)\u001b[K\r\n#\u001b[K\r\n##   This setup will autodetect all modules for your system and should\u001b[K\r\n##   work as a sane default\u001b[K\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n\u001b(B\u001b[0;7metc/mkinitcpio.conf                                                                                                 1,1            Top\u001b[2 q\u001b[2 q\u001b[H\u001b(B\u001b[m# vim:set ft=sh:\u001b[K\r\n# MODULES\u001b[K\r\n# The following modules are loaded before any boot hooks are\u001b[K\r\n# run.  Advanced users may wish to specify all system modules\u001b[K\r\n# in this array.  For instance:\u001b[K\r\n#     MODULES=(usbhid xhci_hcd)\u001b[K\r\nMODULES=()\u001b[K\r\n\u001b[K\n# BINARIES\u001b[K\r\n# This setting includes any additional binaries a given user may\u001b[K\r\n# wish into the CPIO image.  This is run last, so it may be used to\u001b[K\r\n# override the actual binaries included by a given hook\u001b[K\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\r\nBINARIES=()\u001b[K\r\n\u001b[K\n# FILES\u001b[K\r\n# This setting is similar to BINARIES above, however, files are added\u001b[K\r\n# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\r\nFILES=()\u001b[K\r\n\u001b[K\n# HOOKS\u001b[K\r\n# This is the most important setting in this file.  The HOOKS control the\u001b[K\r\n# modules and scripts added to the image, and what happens at boot time.\u001b[K\r\n# Order is important, and it is recommended that you do not change the\u001b[K\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\r\n# help on a given hook.\u001b[K\r\n# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\r\n# 'udev' is _required_ in order to automatically load modules\u001b[K\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\r\n# Examples:\u001b[K\r\n##   This setup specifies all modules in the MODULES setting above.\u001b[K\r\n##   No RAID, lvm2, or encrypted root is needed.\u001b[K\r\n#    HOOKS=(base)\u001b[K\r\n#\u001b[K\r\n##   This setup will autodetect all modules for your system and should\u001b[K\r\n##   work as a sane default\u001b[K\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n\u001b(B\u001b[0;7metc/mkinitcpio.conf                                                                                                 1,1            Top\r\n\u001b(B\u001b[m\u001b[93mE1568: Terminal did not respond to DSR request for 'background' color. Startup may be slower. :help 'ttyfast'\u001b(B\u001b[m\u001b[K\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\\u001b[?25l\u001b[?2031h\u001b[>4;2m\u001b[?25h"]
[4.046, "o", "\u001b[?25l\u001b[40;124H/         \u001b[H\u001b[?25h\u001b[?25l\u001b[39B\u001b[J/\u001b[2 q\u001b[?1002l\u001b[?1006l\u001b[?25h"]
[3.023, "o", "\u001b[?25l\r\u001b[40;1H \u001b[2 q\u001b[?1002h\u001b[?1006h\u001b[H\u001b[?25h"]
[2.096, "o", "\u001b[?25l\u001b[1;38r\u001b[H\u001b[3M\u001b[r\u001b[36;1H##   This setup will generate a 'full' image which supports most systems.\u001b[K\r\n##   No autodetection is done.\u001b[K\r\n#    HOOKS=(base udev microcode modconf block filesystems fsck)\u001b[K\u001b[39;117H\u001b(B\u001b[0;7m4,1             6%\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#\u001b[K\r\n##   This setup assembles a mdadm array with an encrypted root file system.\u001b[K\r\n##   Note: See 'mkinitcpio -H mdadm_udev' for more information on RAID devices.\u001b[K\u001b[39;117H\u001b(B\u001b[0;7m7,1            13\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#    HOOKS=(base udev microcode modconf keyboard keymap consolefont block mdadm_udev encrypt filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup loads an lvm2 volume group.\u001b[K\u001b[39;117H\u001b(B\u001b[0;7m10,1           20\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#    HOOKS=(base udev microcode modconf block lvm2 filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This will create a systemd based initramfs which loads an encrypted root filesystem.\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m3,1           27\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#    HOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block sd-encrypt filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   NOTE: If you have /usr on a separate partition, you MUST include the\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m6,1           34\u001b[H\u001b[?25h"]
[0.257, "o", "\u001b[?25l\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#    usr and fsck hooks.\u001b[K\r\nHOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block filesystems fsck)\u001b[K\r\n\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m9,1           41\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H# COMPRESSION\u001b[K\r\n# Use this to compress the initramfs image. By default, zstd compression\u001b[K\r\n# is used for Linux ≥\u001b[38;22H 5.9 and gzip compression is used for Linux < 5.9.\u001b[K\u001b[39;117H\u001b(B\u001b[0;7m22,1           48\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H# Use 'cat' to create an uncompressed image.\u001b[K\r\n#COMPRESSION=\"zstd\"\u001b[K\r\n#COMPRESSION=\"gzip\"\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m5,1           55\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#COMPRESSION=\"bzip2\"\u001b[K\r\n#COMPRESSION=\"lzma\"\u001b[K\r\n#COMPRESSION=\"xz\"\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m8,1           62\u001b[H\u001b[?25h"]
[0.049, "o", "\u001b[?25l\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H#COMPRESSION=\"lzop\"\u001b[K\r\n#COMPRESSION=\"lz4\"\u001b[K\r\n\u001b[K\u001b[39;117H\u001b(B\u001b[0;7m31,1           69\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H# COMPRESSION_OPTIONS\u001b[K\r\n# Additional options for the compressor\u001b[K\r\n#COMPRESSION_OPTIONS=()\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m4,1           76\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H\u001b[K\n# MODULES_DECOMPRESS\u001b[K\r\n# Decompress loadable kernel modules and their firmware during initramfs\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m7,1           83\u001b[H\u001b[?25h\u001b[?25l\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H# creation. Switch (yes/no).\u001b[K\r\n# Enable to allow further decreasing image size when using high compression\u001b[K\r\n# (e.g. xz -9e or zstd --long --ultra -22) at the expense of increased RAM usage\u001b[K\u001b[39;117H\u001b(B\u001b[0;7m40,1           90\u001b[H\u001b[?25h"]
[0.002, "o", "\u001b[?25l\u001b[1;38r\u001b[H\u001b(B\u001b[m\u001b[3M\u001b[r\u001b[36;1H# at early boot.\u001b[K\r\n# Note that any compressed files will be placed in the uncompressed early CPIO\u001b[K\r\n# to avoid double compression.\u001b[K\u001b[39;118H\u001b(B\u001b[0;7m3,1           97\u001b[H\u001b[?25h"]
