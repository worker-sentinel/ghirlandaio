[0.610, "o", "+ return 0\r\n+ rm -rf /var/lib/kubelet\r\n+ rm -f /usr/local/bin/k3s\r\n+ rm -f /usr/local/bin/k3s-killall.sh\r\n+ rpm_ostree_uninstall_cmd='rpm-ostree uninstall --idempotent k3s-selinux'\r\n+ '[' -r /etc/os-release ']'\r\n"]
