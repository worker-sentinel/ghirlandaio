[0.003, "o", "+ '[' 0 -eq 0 ']'\r\n+ K3S_DATA_DIR=/var/lib/rancher/k3s\r\n+ /usr/local/bin/k3s-killall.sh\r\n"]
[0.011, "o", "+ for service in /etc/systemd/system/k3s*.service\r\n+ '[' -s /etc/systemd/system/k3s-agent.service ']'\r\n++ basename /etc/systemd/system/k3s-agent.service\r\n"]
[0.013, "o", "+ systemctl stop k3s-agent.service\r\n"]
[0.016, "o", "+ for service in /etc/init.d/k3s*\r\n+ '[' -x '/etc/init.d/k3s*' ']'\r\n"]
[0.014, "o", "+ killtree\r\n+ kill -9\r\n+ do_unmount_and_remove /run/k3s\r\n+ set +x\r\n"]
[0.006, "o", "+ do_unmount_and_remove /var/lib/kubelet/pods\r\n+ set +x\r\n"]
