[0.004, "o", "Cannot find device \"flannel-wg-v6\"\r\n"]
[0.005, "o", "++ command -v tailscale\r\n+ '[' -n '' ']'\r\n+ rm -rf /var/lib/cni/\r\n+ iptables-save\r\n+ grep -v KUBE-\r\n+ grep -v CNI-\r\n+ grep -iv flannel\r\n+ iptables-restore\r\n"]
[0.009, "o", "+ ip6tables-save\r\n+ grep -v KUBE-\r\n+ grep -v CNI-\r\n+ grep -iv flannel\r\n+ ip6tables-restore\r\n+ command -v systemctl\r\n/usr/bin/systemctl\r\n+ systemctl disable k3s-agent\r\n"]
