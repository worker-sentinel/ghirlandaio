[0.007, "o", "+ do_unmount_and_remove /run/netns/cni-\r\n+ set +x\r\n"]
[0.002, "o", "+ ip netns show\r\n"]
[0.007, "o", "+ grep cni-\r\n+ xargs -r -t -n 1 ip netns delete\r\n+ remove_interfaces\r\n+ ip link show\r\n+ grep 'master cni0'\r\n+ read ignore iface ignore\r\n"]
[0.002, "o", "+ ip link delete cni0\r\n"]
[0.007, "o", "Cannot find device \"cni0\"\r\n"]
[0.002, "o", "+ ip link delete flannel.1\r\n"]
