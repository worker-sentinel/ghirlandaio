[0.555, "o", "\r\n    1  echo data  > /etc/hostname\r\n    2  ln -fs /usr/share/zoneinfo/Asia/Jakarta /etc/localtime\r\n    3  hwclock --systohc\r\n    4  nvim /etc/locale.gen\r\n    5  locale-gen\r\n    6  locale > /etc/locale.conf\r\n    7  nvim /etc/locale.conf\r\n    8  cryptsetup luksOpen /dev/proc/sector internal\r\n    9  mkfs.ext4 /dev/mapper/internal\r\n   10  mkdir -p /home/user\r\n   11  useradd -d /home/user rektor\r\n   12  chown -R rektor:rektor /home/user\r\n   13  passwd rektor\r\n   14  echo 'rektor ALL=(ALL:ALL) ALL' > /etc/sudoers.d/none\r\n   15  nvim /etc/security/pam_mount.conf.xml\r\n   16  exit\r\n   17  nvim /etc/security/pam_mount.conf.xml\r\n   18  nvim /etc/security/pam_mount.conf.xml\r\n   19  exit\r\n   20  nvim /etc/security/pam_mount.conf.xml\r\n   21  exit\r\n   22  pacman -S pam-mount\r\n   23  pacman -S pam_mount\r\n   24  cd /etc/security/\r\n   25  ls\r\n   26  nvim pam_mount.conf.xml.pacnew \r\n   27  rm -rf pam_mount.conf.xml\r\n   28  mv pam_mount.conf.xml.pacnew pam_mount.conf.xml\r\n   29  ls\r\n   30  nvim /etc/security/pam_mount.conf.xml\r\n   31  nvim /etc/pam.d/system-login\r\n   32  mkdir -p /etc/cmdline.d\r\n   33  touch /etc/cmdline.d/{01-boot.conf,02-misc.conf}\r\n   34  echo \"root=/dev/proc/root\" > /etc/cmdline.d/01-boot.conf\r\n   35  echo \"rw\" > /etc/cmdline.d/02-misc.conf\r\n   36  rm -fr /boot/initramfs-linux-*\r\n   37  nvim /etc/mkinitcpio.conf\r\n"]
