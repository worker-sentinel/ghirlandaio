[0.197, "o", "\r\n"]
[0.000, "o", ":: The firewallD components & utilities have now been split into different packages:\r\n\r\n"]
[0.001, "o", "   - firewalld: Firewall daemon with D-Bus interface \r\n   - python-firewall: Python bindings for firewallD\r\n"]
[0.001, "o", "   - firewall-config: Graphical user interface for firewallD\r\n   - firewall-applet: Systray applet for firewallD\r\n   - firewalld-test: FirewallD test suite\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "   Make sure to install the ones you may want / need.\r\n"]
[0.000, "o", "\r\n"]
[0.001, "o", "Optional dependencies for firewalld\r\n"]
[0.000, "o", "\u001b[0;1m   \u001b[0m bash-completion: bash completion\r\n"]
[0.000, "o", "    networkmanager: NetworkManager support [installed]\r\n"]
[0.000, "o", "    polkit: privileged actions [installed]\r\n"]
[0.001, "o", "    firewall-config: Graphical user interface for firewallD configuration\r\n"]
