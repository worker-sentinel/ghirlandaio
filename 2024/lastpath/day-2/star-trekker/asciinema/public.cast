[0.050, "o", "\u001b[c\u001b[?25l\u001b[?2031h\u001b[>4;2m\u001b(B\u001b[m# mkinitcpio preset file for the 'linux-lts' package\u001b[K\r\n\u001b[K\nALL_config=\u001b[92m\"/etc/mkinitcpio.conf\"\u001b(B\u001b[m\u001b[K\r\nALL_kver=\u001b[92m\"/boot/vmlinuz-linux-lts\"\u001b(B\u001b[m\u001b[K\r\nALL_kerneldest=\u001b[92m\"/boot/vmlinuz-linux-lts\"\u001b(B\u001b[m\u001b[K\r\n\u001b[K\nPRESETS=(\u001b[92m'default'\u001b(B\u001b[m)\u001b[K\r\n#PRESETS=('default' 'fallback')\u001b[K\r\n\u001b[K\n#default_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#default_image=\"/boot/initramfs-linux-lts.img\"\u001b[K\r\ndefault_uki=\u001b[92m\"/boot/EFI/Linux/arch-linux-lts.efi\"\u001b(B\u001b[m\u001b[K\r\n#default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\u001b[K\r\n\u001b[K\n#fallback_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#fallback_image=\"/boot/initramfs-linux-lts-fallback.img\"\u001b[K\r\n#fallback_uki=\"/efi/EFI/Linux/arch-linux-lts-fallback.efi\"\u001b[K\r\n#fallback_options=\"-S autodetect\"\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b(B\u001b[0;7metc/mkinitcpio.d/linux-lts.preset                                                                                                                                              1,1            All\u001b(B\u001b[m\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# mkinitcpio preset file for the 'linux-lts' package\u001b[K\r\n\u001b[K\nALL_config=\u001b[92m\"/etc/mkinitcpio.conf\"\u001b(B\u001b[m\u001b[K\r\nALL_kver=\u001b[92m\"/boot/vmlinuz-linux-lts\"\u001b(B\u001b[m\u001b[K\r\nALL_kerneldest=\u001b[92m\"/boot/vmlinuz-linux-lts\"\u001b(B\u001b[m\u001b[K\r\n\u001b[K\nPRESETS=(\u001b[92m'default'\u001b(B\u001b[m)\u001b[K\r\n#PRESETS=('default' 'fallback')\u001b[K\r\n\u001b[K\n#default_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#default_image=\"/boot/initramfs-linux-lts.img\"\u001b[K\r\ndefault_uki=\u001b[92m\"/boot/EFI/Linux/arch-linux-lts.efi\"\u001b(B\u001b[m\u001b[K\r\n#default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\u001b[K\r\n\u001b[K\n#fallback_config=\"/etc/mkinitcpio.conf\"\u001b[K\r\n#fallback_image=\"/boot/initramfs-linux-lts-fallback.img\"\u001b[K\r\n#fallback_uki=\"/efi/EFI/Linux/arch-linux-lts-fallback.efi\"\u001b[K\r\n#fallback_options=\"-S autodetect\"\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b(B\u001b[0;7metc/mkinitcpio.d/linux-lts.preset                                                                                                                                              1,1            All\u001b(B\u001b[m\r\n\u001b[J\u001b[H\u001b[?25h\u001b[?25l\u001b[?1004h\u001b[?25h"]
