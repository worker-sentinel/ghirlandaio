[1.337, "o", "\u001b[?25le\u001b[1;20H\u001b[30m\u001b[103me\u001b(B\u001b[m for local\u001b[30m\u001b[103me\u001b(B\u001b[m-g\u001b[30m\u001b[103me\u001b[3;17He\u001b(B\u001b[ms that ar\u001b[30m\u001b[103me\u001b(B\u001b[m to b\u001b[30m\u001b[103me\u001b(B\u001b[m g\u001b[30m\u001b[103me\u001b(B\u001b[mn\u001b[30m\u001b[103me\u001b(B\u001b[mrat\u001b[30m\u001b[103me\u001b(B\u001b[md by th\u001b[30m\u001b[103me\u001b(B\u001b[m local\u001b[30m\u001b[103me\u001b(B\u001b[m-g\u001b[30m\u001b[103me\u001b[5;11He\u001b(B\u001b[m is of th\u001b[30m\u001b[103me\u001b[7;13He\u001b(B\u001b[m> <chars\u001b[30m\u001b[103me\u001b[9;6He\u001b(B\u001b[mr\u001b[30m\u001b[103me\u001b(B\u001b[m <local\u001b[30m\u001b[103me\u001b(B\u001b[m> is on\u001b[30m\u001b[103me\u001b(B\u001b[m of th\u001b[30m\u001b[103me\u001b(B\u001b[m local\u001b[30m\u001b[103me\u001b(B\u001b[ms giv\u001b[30m\u001b[103me\u001b(B\u001b[mn in /usr/shar\u001b[30m\u001b[103me\u001b(B\u001b[m/i18n/local\u001b[30m\u001b[103me\u001b[10;14He\u001b(B\u001b[mt> is on\u001b[30m\u001b[103me\u001b(B\u001b[m of th\u001b[30m\u001b[103me\u001b(B\u001b[m charact\u001b[30m\u001b[103me\u001b(B\u001b[mr s\u001b[30m\u001b[103me\u001b(B\u001b[mts list\u001b[30m\u001b[103me\u001b(B\u001b[md in /usr/shar\u001b[30m\u001b[103me\u001b[12;6He\u001b(B\u001b[m local\u001b[30m\u001b[103me\u001b(B\u001b[m-g\u001b[30m\u001b[103me\u001b(B\u001b[mn command will g\u001b[30m\u001b[103me\u001b(B\u001b[mn\u001b[30m\u001b[103me\u001b(B\u001b[mrat\u001b[30m\u001b[103me\u001b(B\u001b[m all th\u001b[30m\u001b[103me\u001b(B\u001b[m local\u001b[30m\u001b[103me\u001b[13;14He\u001b(B\u001b[mm in /usr/lib/local\u001b[30m\u001b[103me\u001b[15;21He\u001b(B\u001b[md local\u001b[30m\u001b[103me\u001b(B\u001b[ms is giv\u001b[30m\u001b[103me\u001b(B\u001b[mn in /usr/shar\u001b[30m\u001b[103me\u001b[16;17He\u001b(B\u001b[md in this fil\u001b[30m\u001b[103me\u001b(B\u001b[m. Uncomm\u001b[30m\u001b[103me\u001b(B\u001b[mnt th\u001b[30m\u001b[103me\u001b(B\u001b[m n\u001b[30m\u001b[103mee\u001b(B\u001b[md\u001b[30m\u001b[103me\u001b(B\u001b[md local\u001b[30m\u001b[103me\u001b(B\u001b[ms b\u001b[30m\u001b[103me\u001b[42;176H\u001b(B\u001b[0;7m3,17\u001b[43;3H\u001b[?25h"]
