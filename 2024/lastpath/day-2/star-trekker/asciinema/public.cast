[0.050, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[3A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[42;177H\u001b(B\u001b[0;7m1\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H#\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m2,1            2%\r\u001b[A\u001b[?25h"]
[0.100, "o", "\u001b[?25l\u001b[1;41r\u001b[H\u001b(B\u001b[m\u001b[M\u001b[r\u001b[41;1H##   This setup assembles a mdadm array with an encrypted root file system.\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m3,1            5\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H##   Note: See 'mkinitcpio -H mdadm_udev' for more information on RAID devices.\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m4,1            7\r\u001b[A\u001b[?25h"]
[0.006, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H#    HOOKS=(base udev microcode modconf keyboard keymap consolefont block mdadm_udev encrypt filesystems fsck)\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m5,1           10\r\u001b[A\u001b[?25h"]
[0.003, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H#\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m6,1           12\r\u001b[A\u001b[?25h"]
[0.146, "o", "\u001b[?25l\u001b[1;41r\u001b[H\u001b(B\u001b[m\u001b[M\u001b[r\u001b[41;1H##   This setup loads an lvm2 volume group.\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m7,1           15\u001b[1;41r\u001b[H\u001b(B\u001b[m\u001b[M\u001b[r\u001b[41;1H#    HOOKS=(base udev microcode modconf block lvm2 filesystems fsck)\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m8,1           17\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H#\u001b[K\u001b[42;177H\u001b(B\u001b[0;7m9,1           20\r\u001b[A\u001b[?25h"]
[0.007, "o", "\u001b[?25l\u001b[43;183H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[43;183H   \u001b[1;41r\u001b[H\u001b[M\u001b[r\u001b[41;1H##   This will create a systemd based initramfs which loads an encrypted root filesystem.\u001b[K\u001b[42;176H\u001b(B\u001b[0;7m50,1           22\r\u001b[A\u001b[?25h"]
