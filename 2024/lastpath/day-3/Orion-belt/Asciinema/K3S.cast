[0.009, "o", "\u001b[0;1;31mFailed to reset failed state of unit k3s-agent.service: Unit k3s-agent.service not loaded.\u001b[0m\r\r\n"]
[0.001, "o", "+ systemctl daemon-reload\r\n"]
[0.354, "o", "+ command -v rc-update\r\n+ rm -f /etc/systemd/system/k3s-agent.service\r\n"]
[0.002, "o", "+ rm -f /etc/systemd/system/k3s-agent.service.env\r\n"]
[0.003, "o", "+ trap remove_uninstall EXIT\r\n"]
