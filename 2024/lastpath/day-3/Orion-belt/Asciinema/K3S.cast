[0.004, "o", "+ '[' 0 '!=' 0 ']'\r\n+ '[' arch = fedora ']'\r\n"]
[0.000, "o", "++ expr '' : '.*fedora.*\\|.*rhel.*\\|.*centos.*'\r\n"]
[0.003, "o", "+ '[' 0 '!=' 0 ']'\r\n+ type rpm-ostree\r\n+ type zypper\r\n+ type yum\r\n+ '[' -d /usr/share/selinux ']'\r\n+ '[' -d /etc/zypp/repos.d ']'\r\n+ '[' -d /etc/yum.repos.d ']'\r\n+ remove_uninstall\r\n+ rm -f /usr/local/bin/k3s-agent-uninstall.sh\r\n"]
