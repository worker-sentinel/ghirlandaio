[0.007, "o", "++ id -u\r\n"]
[0.003, "o", "+ '[' 0 -eq 0 ']'\r\n+ K3S_DATA_DIR=/var/lib/rancher/k3s\r\n+ /usr/local/bin/k3s-killall.sh\r\n"]
[0.009, "o", "+ for service in /etc/systemd/system/k3s*.service\r\n+ '[' -s /etc/systemd/system/k3s-agent.service ']'\r\n"]
[0.000, "o", "++ basename /etc/systemd/system/k3s-agent.service\r\n"]
[0.003, "o", "+ systemctl stop k3s-agent.service\r\n"]
[0.013, "o", "+ for service in /etc/init.d/k3s*\r\n+ '[' -x '/etc/init.d/k3s*' ']'\r\n"]
[0.018, "o", "+ killtree\r\n"]
[0.001, "o", "+ kill -9\r\n+ do_unmount_and_remove /run/k3s\r\n+ set +x\r\n"]
[0.003, "o", "+ do_unmount_and_remove /var/lib/kubelet/pods\r\n+ set +x\r\n"]
[0.004, "o", "+ do_unmount_and_remove /var/lib/kubelet/plugins\r\n+ set +x\r\n"]
[0.005, "o", "+ do_unmount_and_remove /run/netns/cni-\r\n+ set +x\r\n"]
[0.004, "o", "+ ip netns show\r\n"]
[0.001, "o", "+ grep cni-\r\n"]
[0.000, "o", "+ xargs -r -t -n 1 ip netns delete\r\n"]
[0.004, "o", "+ remove_interfaces\r\n"]
[0.000, "o", "+ ip link show\r\n"]
[0.000, "o", "+ grep 'master cni0'\r\n"]
[0.001, "o", "+ read ignore iface ignore\r\n"]
[0.003, "o", "+ ip link delete cni0\r\n"]
[0.008, "o", "Cannot find device \"cni0\"\r\n"]
[0.000, "o", "+ ip link delete flannel.1\r\n"]
[0.006, "o", "Cannot find device \"flannel.1\"\r\n"]
[0.001, "o", "+ ip link delete flannel-v6.1\r\n"]
