[0.008, "o", "\u001b[?25l\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[H\u001b[2J\u001b[20B                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n             "]
[0.000, "o", "                                                                                                                                         \r\n                                                                                                                                                      \r\n                                                                                                                                                      \r\n                                                                                                                                                      \u001b[H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# For more information on this configuration file, see containers-registries.conf(5).\r\n#\r\n# NOTE: RISK OF USING UNQUALIFIED IMAGE NAMES\r\n# We recommend always using fully qualified image names including the registry\r\n# server (full dns name), namespace, image name, and tag\r\n# (e.g., registry.redhat.io/ubi8/ubi:latest). Pulling by digest (i.e.,\r\n# quay.io/repository/name@digest) further eliminates the ambiguity of tags.\r\n# When using short names, there is always an inherent risk that the image being\r\n# pulled could be spoofed. For example, a user wants to pull an image named\r\n# `foobar` from a registry and expects it to come from myregistry.com. If\r\n# myregistry.com is not first in the search list, an attacker could place a\r\n# different `foobar` image at a registry earlier in the search list. The user\r\n# would accidentally pull and run the attacker's image and code rather than the\r\n# intended content. We recommend only adding registries which are completely\r\n# trusted (i.e., registries which don't allow unknown or anonymous users to\r\n# create accounts with arbitrary names). This will prevent an image from being\r\n# spoofed, squatted or otherwise made insecure.  If it is necessary to use one\r\n# of these registries, it should be added at the end of the list.\r\n#\r\n# # An array of host[:port] registries to try when pulling an unqualified image, in order.\r\n\u001b(B\u001b[m\u001b[38;2;166;219;255m\u001b[48;2;20;22;27munqualified-search-registries\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m = [\u001b(B\u001b[m\u001b[38;2;179;246;192m\u001b[48;2;20;22;27m\"docker.io\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m]\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\r\n# [[registry]]\r\n# # The \"prefix\" field is used to choose the relevant [[registry]] TOML table;\r\n# # (only) the TOML table with the longest match for the input image name\r\n# # (taking into account namespace/repo/tag/digest separators) is used.\r\n# #\r\n# # The prefix can also be of the form: *.example.com for wildcard subdomain\r\n# # matching.\r\n# #\r\n# # If the prefix field is missing, it defaults to be the same as the \"location\" field.\r\n# prefix = \"example.com/foo\"\r\n#\r\n# # If true, unencrypted HTTP as well as TLS connections with untrusted\r\n# # certificates are allowed.\r\n# insecure = false\r\n\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m/etc/containers/registries.conf                                                                                                     1,1            Top\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\r\n\u001b[J\u001b[H\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[2 q\u001b[2 q\u001b[?25h"]
[10.794, "o", "\u001b[?25l\u001b[1;36r\u001b[H\u001b[3M\u001b[r\u001b[34;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# # If true, pulling images with matching names is forbidden.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# blocked = false\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[37;133H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4,1             7%\u001b[1;36r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[34;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# # The physical location of the \"prefix\"-rooted namespace.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[37;133H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m7,1            14\u001b[1;36r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[34;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# # By default, this is equal to \"prefix\" (in which case \"prefix\" can be omitted\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# # and the [[registry]] TOML table can only specify \"location\").\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# #\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[37;133H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m10,1           21\u001b[1;36r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[34;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# # Example: Given\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# #   prefix = \"example.com/foo\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# #   location = \"internal-registry-for-example.com/bar\"\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[37;134H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3,1           29\u001b[1;36r\u001b[H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[3M\u001b[r\u001b[34;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# # requests for "]
