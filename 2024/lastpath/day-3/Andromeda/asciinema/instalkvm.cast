[0.001, "o", "\u001b[1;1H\u001b[34m# Master libvirt daemon configuration file\r\n#\u001b[m\u001b[2;2H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[34m#################################################################\r\n#\r\n# Network connectivity controls\r\n#\r\n\r\n# Flag listening for secure TLS connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\r\n#\r\n# This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\r\n\r\n# Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\r\n#\r\n# This is disabled by default, uncomment this to enable it.\r\n#listen_tcp = 1\u001b[42;1H# Override the port for accepting secure TLS connections\r\n# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#tls_port = \"16514\"\r\n\r\n# Override the port for accepting insecure TCP connections\r\n# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#tcp_port = \"16509\"\u001b[m\u001b[59;173H1,1\u001b[11CTop\u001b[?25h\u001b[1;1H\u001b[?4m"]
[0.004, "o", "\u001bP+q436f\u001b\\\u001bP+q6b75\u001b\\\u001bP+q6b64\u001b\\\u001bP+q6b72\u001b\\\u001bP+q6b6c\u001b\\\u001bP+q2332\u001b\\\u001bP+q2334\u001b\\\u001bP+q2569\u001b\\\u001bP+q2a37\u001b\\\u001bP+q6b31\u001b\\\u001bP$q q\u001b\\\u001b[?12$p"]
[0.002, "o", "\u001b[?25l\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[1;1H\u001b[96m# Master libvirt daemon configuration file\r\n#\r\n\r\n#################################################################\r\n#\r\n# Network connectivity controls\r\n#\r\n\r\n# Flag listening for secure TLS connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\r\n#\r\n# This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\r\n\r\n# Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\r\n#\r\n# This is disabled by default, uncomment this to enable it.\r\n#listen_tcp = 1\u001b[42;1H# Override the port for accepting secure TLS connections\r\n# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#tls_port = \"16514\"\r\n\r\n# Override the port for accepting insecure TCP connections\r\n# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#tcp_port = \"16509\"\u001b[m\u001b[59;173H1,1\u001b[11CTop\u001b[?25h\r\"/etc/libvirt/libvirtd.conf\" 552L, 18357B\u001b[1;1H"]
