[0.000, "o", "    qemu-base: QEMU/KVM support [installed]\r\n    qemu-desktop: QEMU/KVM desktop support\r\n    qemu-emulators-full: Support of additional QEMU architectures\r\n    radvd: IPv6 RAD support\r\n    swtpm: TPM emulator support\r\n"]
