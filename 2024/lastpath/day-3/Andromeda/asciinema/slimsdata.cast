[0.000, "o", "+ ip6tables-save\r\n+ grep -v KUBE-\r\n+ grep -iv flannel\r\n+ grep -v CNI-\r\n"]
[0.018, "o", "+ ip6tables-restore\r\n+ command -v systemctl\r\n/usr/bin/systemctl\r\n+ systemctl disable k3s-agent\r\n"]
[0.004, "o", "Removed '/etc/systemd/system/multi-user.target.wants/k3s-agent.service'.\r\r\n"]
