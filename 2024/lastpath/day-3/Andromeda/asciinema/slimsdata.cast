[0.009, "o", "+ do_unmount_and_remove /run/netns/cni-\r\n+ set +x\r\n"]
[0.001, "o", "+ ip netns show\r\n+ grep cni-\r\n+ xargs -r -t -n 1 ip netns delete\r\n"]
