[0.026, "o", "++ id -u\r\n"]
[0.041, "o", "+ '[' 1000 -eq 0 ']'\r\n+ exec sudo --preserve-env=K3S_DATA_DIR /usr/local/bin/k3s-agent-uninstall.sh\r\n"]
[0.000, "o", "\u001b]3008;start=6847503f0d5940fe9c7b9f3e3b11b06b;user=server;hostname=internal;machineid=a1b43a7ed60a46479d7565ed99c0d882;bootid=0889dec3ef9441b19317714ddb8f3ecb;pid=1129;pidfdid=1130;comm=sudo;targetuser=root;type=session\u001b\\++ id -u\r\n+ '[' 0 -eq 0 ']'\r\n+ K3S_DATA_DIR=/var/lib/rancher/k3s\r\n+ /usr/local/bin/k3s-killall.sh\r\n"]
[0.018, "o", "+ for service in /etc/systemd/system/k3s*.service\r\n+ '[' -s /etc/systemd/system/k3s-agent.service ']'\r\n++ basename /etc/systemd/system/k3s-agent.service\r\n"]
[0.007, "o", "+ systemctl stop k3s-agent.service\r\n"]
[10.067, "o", "+ for service in /etc/init.d/k3s*\r\n+ '[' -x '/etc/init.d/k3s*' ']'\r\n"]
[0.304, "o", "+ killtree\r\n"]
