[0.004, "o", "+ '[' -d /usr/share/selinux ']'\r\n+ '[' -d /etc/zypp/repos.d ']'\r\n+ '[' -d /etc/yum.repos.d ']'\r\n+ remove_uninstall\r\n+ rm -f /usr/local/bin/k3s-agent-uninstall.sh\r\n"]
