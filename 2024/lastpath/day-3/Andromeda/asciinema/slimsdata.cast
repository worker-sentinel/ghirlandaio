[0.003, "o", "+ clean_mounted_directory /var/lib/rancher/k3s\r\n+ grep -q ' /var/lib/rancher/k3s' /proc/mounts\r\n"]
[0.005, "o", "+ rm -rf /var/lib/rancher/k3s\r\n"]
