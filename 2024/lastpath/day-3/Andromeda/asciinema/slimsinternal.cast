[0.002, "o", "+ do_unmount_and_remove /run/netns/cni-\r\n+ set +x\r\n"]
[0.002, "o", "+ ip netns show\r\n+ grep cni-\r\n"]
[0.000, "o", "+ xargs -r -t -n 1 ip netns delete\r\n"]
[0.002, "o", "+ remove_interfaces\r\n"]
[0.002, "o", "+ ip link show\r\n+ grep 'master cni0'\r\n"]
