[0.003, "o", "Cannot find device \"flannel-wg-v6\"\r\n"]
[0.000, "o", "++ command -v tailscale\r\n+ '[' -n '' ']'\r\n+ rm -rf /var/lib/cni/\r\n"]
[0.002, "o", "+ iptables-save\r\n"]
[0.000, "o", "+ grep -v KUBE-\r\n+ grep -v CNI-\r\n"]
[0.001, "o", "+ iptables-restore\r\n+ grep -iv flannel\r\n"]
