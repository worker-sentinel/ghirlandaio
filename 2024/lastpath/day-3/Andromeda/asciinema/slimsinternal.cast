[0.005, "o", "++ id -u\r\n"]
[0.002, "o", "+ '[' 1000 -eq 0 ']'\r\n+ exec sudo --preserve-env=K3S_DATA_DIR /usr/local/bin/k3s-agent-uninstall.sh\r\n"]
[0.039, "o", "\u001b]3008;start=2834750e61df4d9abcb676f85f172ddd;user=andromeda;hostname=internal;machineid=60d52327222b4704bd55a5b7fdd317e3;bootid=b828949356cb4730b72124b63f25f47c;pid=2461;pidfdid=16726;comm=sudo;targetuser=root;type=session\u001b\\++ id -u\r\n+ '[' 0 -eq 0 ']'\r\n+ K3S_DATA_DIR=/var/lib/rancher/k3s\r\n+ /usr/local/bin/k3s-killall.sh\r\n+ for service in /etc/systemd/system/k3s*.service\r\n+ '[' -s /etc/systemd/system/k3s-agent.service ']'\r\n++ basename /etc/systemd/system/k3s-agent.service\r\n"]
[0.000, "o", "+ systemctl stop k3s-agent.service\r\n"]
[0.013, "o", "+ for service in /etc/init.d/k3s*\r\n+ '[' -x '/etc/init.d/k3s*' ']'\r\n"]
[0.032, "o", "+ killtree\r\n"]
[0.001, "o", "+ kill -9\r\n+ do_unmount_and_remove /run/k3s\r\n+ set +x\r\n"]
[0.010, "o", "+ do_unmount_and_remove /var/lib/kubelet/pods\r\n+ set +x\r\n+ do_unmount_and_remove /var/lib/kubelet/plugins\r\n+ set +x\r\n+ do_unmount_and_remove /run/netns/cni-\r\n+ set +x\r\n+ ip netns show\r\n+ grep cni-\r\n+ xargs -r -t -n 1 ip netns delete\r\n+ remove_interfaces\r\n+ ip link show\r\n+ grep 'master cni0'\r\n+ read ignore iface ignore\r\n+ ip link delete cni0\r\nCannot find device \"cni0\"\r\n+ ip link delete flannel.1\r\nCannot find device \"flannel.1\"\r\n+ ip link delete flannel-v6.1\r\n"]
[0.001, "o", "Cannot find device \"flannel-v6.1\"\r\n+ ip link delete kube-ipvs0\r\nCannot find device \"kube-ipvs0\"\r\n+ ip link delete flannel-wg\r\nCannot find device \"flannel-wg\"\r\n+ ip link delete flannel-wg-v6\r\n"]
[0.000, "o", "Cannot find device \"flannel-wg-v6\"\r\n++ command -v tailscale\r\n+ '[' -n '' ']'\r\n+ rm -rf /var/lib/cni/\r\n"]
[0.002, "o", "+ iptables-save\r\n"]
[0.001, "o", "+ grep -v KUBE-\r\n+ grep -v CNI-\r\n"]
[0.001, "o", "+ grep -iv flannel\r\n+ iptables-restore\r\n"]
[0.001, "o", "+ ip6tables-save\r\n"]
[0.000, "o", "+ grep -v KUBE-\r\n+ grep -v CNI-\r\n"]
[0.000, "o", "+ grep -iv flannel\r\n+ ip6tables-restore\r\n"]
[0.002, "o", "+ command -v systemctl\r\n/usr/bin/systemctl\r\n+ systemctl disable k3s-agent\r\n"]
[0.004, "o", "Removed '/etc/systemd/system/multi-user.target.wants/k3s-agent.service'.\r\r\n"]
[0.233, "o", "+ systemctl reset-failed k3s-agent\r\n+ systemctl daemon-reload\r\n"]
[0.300, "o", "+ command -v rc-update\r\n+ rm -f /etc/systemd/system/k3s-agent.service\r\n+ rm -f /etc/systemd/system/k3s-agent.service.env\r\n+ trap remove_uninstall EXIT\r\n+ for cmd in kubectl crictl ctr\r\n+ '[' -L /usr/local/bin/kubectl ']'\r\n+ rm -f /usr/local/bin/kubectl\r\n+ for cmd in kubectl crictl ctr\r\n+ '[' -L /usr/local/bin/crictl ']'\r\n+ rm -f /usr/local/bin/crictl\r\n"]
[0.002, "o", "+ for cmd in kubectl crictl ctr\r\n+ '[' -L /usr/local/bin/ctr ']'\r\n+ rm -f /usr/local/bin/ctr\r\n"]
[0.000, "o", "+ rm -rf /etc/rancher/k3s\r\n+ rm -rf /run/k3s\r\n+ rm -rf /run/flannel\r\n"]
[0.000, "o", "+ clean_mounted_directory /var/lib/rancher/k3s\r\n+ grep -q ' /var/lib/rancher/k3s' /proc/mounts\r\n+ rm -rf /var/lib/rancher/k3s\r\n"]
[0.024, "o", "+ return 0\r\n+ rm -rf /var/lib/kubelet\r\n"]
[0.001, "o", "+ rm -f /usr/local/bin/k3s\r\n"]
[0.008, "o", "+ rm -f /usr/local/bin/k3s-killall.sh\r\n"]
[0.001, "o", "+ rpm_ostree_uninstall_cmd='rpm-ostree uninstall --idempotent k3s-selinux'\r\n+ '[' -r /etc/os-release ']'\r\n+ . /etc/os-release\r\n++ NAME='Arch Linux'\r\n++ PRETTY_NAME='Arch Linux'\r\n++ ID=arch\r\n++ BUILD_ID=rolling\r\n++ ANSI_COLOR='38;2;23;147;209'\r\n++ HOME_URL=https://archlinux.org/\r\n++ DOCUMENTATION_URL=https://wiki.archlinux.org/\r\n++ SUPPORT_URL=https://bbs.archlinux.org/\r\n++ BUG_REPORT_URL=https://gitlab.archlinux.org/groups/archlinux/-/issues\r\n++ PRIVACY_POLICY_URL=https://terms.archlinux.org/docs/privacy-policy/\r\n++ LOGO=archlinux-logo\r\n"]
[0.001, "o", "++ expr '' : '.*suse.*'\r\n"]
[0.001, "o", "+ '[' 0 '!=' 0 ']'\r\n+ '[' arch = fedora ']'\r\n"]
[0.001, "o", "++ expr '' : '.*fedora.*\\|.*rhel.*\\|.*centos.*'\r\n"]
[0.001, "o", "+ '[' 0 '!=' 0 ']'\r\n+ type rpm-ostree\r\n+ type zypper\r\n+ type yum\r\n+ '[' -d /usr/share/selinux ']'\r\n+ '[' -d /etc/zypp/repos.d ']'\r\n+ '[' -d /etc/yum.repos.d ']'\r\n+ remove_uninstall\r\n+ rm -f /usr/local/bin/k3s-agent-uninstall.sh\r\n"]
