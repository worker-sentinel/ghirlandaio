[0.101, "o", "\u001b[44;142H  \u001b[38;1H\u001b[44;152H40,0-1\u001b[9C0%\u001b[38;1H\u001b[?25h"]
[1.231, "o", "\u001b[?25l\u001b[44;142H/\u001b[38;1H\u001b[44;142H\u001b[K\u001b[44;1H/\u001b[?25h"]
[2.741, "o", "u\u001b[?25l"]
[0.001, "o", "\u001b[1;43r\u001b[1;1H\u001b[2M\u001b[1;44r\u001b[38;38H\u001b[7m\u001b[96mu\u001b[m\u001b[42;1H\u001b[96m# activation.\r\n#\u001b[m\u001b[44;1H\u001b[K\u001b[44;152H42,38\u001b[10C0%\u001b[?25h\u001b[?25l\r/u\u001b[44;152H\u001b[K\u001b[44;3H\u001b[?25h"]
[0.799, "o", "n\u001b[?25l"]
[0.001, "o", "\u001b[2;3H\u001b[96mIf the libvirtd service is started in parallel with network\r\n# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\u001b[m\u001b[5;2H\u001b[K\u001b[6;2H\u001b[96mlisten_addr = \"192.168.0.1\"\u001b[m\u001b[7;1H\u001b[K\u001b[8;1H\u001b[K\u001b[9;2H\u001b[96m################################################################\r\n\r\n# UNIX socket access controls\u001b[m\u001b[11;30H\u001b[K\u001b[12;2H\u001b[K\u001b[13;1H\u001b[K\u001b[14;3H\u001b[96mSet the UNIX domain socket group ownership. This can be used to\u001b[m\u001b[14;66H\u001b[K\u001b[15;3H\u001b[96mallow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\u001b[m\u001b[17;2H\u001b[K\u001b[18;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[20;2H\u001b[K\u001b[21;2H\u001b[96m This is restricted to 'root' by default.\u001b[m\r\n\u001b[7mun\u001b[mix_sock_group = \u001b[95m\"libvirt\"\u001b[m\u001b[22;28H\u001b[K\u001b[23;1H\u001b[K\u001b[24;3H\u001b[96mSet the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\u001b[m\u001b[26;2H\u001b[K\u001b[27;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[29;2H\u001b[K\u001b[30;3H\u001b[96mDefault allows any user. If setting group ownership, you may want to\r\n# restrict this too.\u001b[m\u001b[31;21H\u001b[K\u001b[32;2H\u001b[96munix_sock_ro_perms = \"0777\"\u001b[m\u001b[33;1H\u001b[K\u001b[34;2H\u001b[96m Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[38;14H\u001b[K\u001b[39;2H\u001b[K\u001b[40;2H\u001b[96m Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\u001b[m\u001b[41;55H\u001b[K\u001b[42;2H\u001b[K\u001b[43;2H\u001b[96m If not using PolicyKit and setting group ownership for access\u001b[m\u001b[44;152H85,1\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;4H\u001b[?25h"]
[0.235, "o", "i\u001b[?25l"]
[0.001, "o", "\u001b[22;3H\u001b[7mi\u001b[m\u001b[44;152H85,1\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;5H\u001b[?25h"]
[0.325, "o", "x\u001b[?25l"]
