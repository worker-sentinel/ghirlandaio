[0.030, "o", "\u001b[?25l\u001b[44;3H\u001b[K"]
[0.001, "o", "\u001b[2;3H\u001b[96mNetwork connectivity controls\u001b[m\u001b[2;32H\u001b[K\u001b[3;2H\u001b[K\u001b[4;1H\u001b[K\u001b[5;2H\u001b[96m Flag listening for secure TLS connections on the public TCP/IP port.\u001b[m\u001b[6;2H\u001b[K\u001b[7;1H\u001b[96m# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\u001b[m\u001b[9;40H\u001b[K\u001b[11;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\u001b[m\u001b[15;25H\u001b[K\u001b[16;2H\u001b[K\u001b[17;2H\u001b[96m This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\u001b[m\u001b[18;16H\u001b[K\u001b[19;1H\u001b[K\u001b[20;2H\u001b[96m Listen for unencrypted TCP connections on the public TCP/IP port.\u001b[m\u001b[21;2H\u001b[K\u001b[22;1H\u001b[96m# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\u001b[m\u001b[24;40H\u001b[K\u001b[25;2H\u001b[K\u001b[26;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[27;14H\u001b[K\u001b[28;2H\u001b[K\u001b[29;2H\u001b[96m Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\u001b[m\u001b[30;69H\u001b[K\u001b[31;3H\u001b[96mDIGEST_MD5 and GSSAPI (Kerberos5)\u001b[m\u001b[32;2H\u001b[K\u001b[33;1H\u001b[96m# This is disabled by default, uncomment this to enable it.\r\n#listen_tcp = 1\u001b[m\u001b[34;16H\u001b[K\u001b[35;1H\u001b[K\u001b[36;1H\u001b[K\u001b[37;1H\u001b[K\u001b[38;3H\u001b[96mOverride the port for accepti\u001b[m\u001b[7m\u001b[96mn\u001b[m\u001b[96mg secure TLS connections\r\n# This can be a port number, or service name\u001b[m\u001b[40;2H\u001b[K\u001b[41;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[43;2H\u001b[K\u001b[44;152H42,32\u001b[10C0%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;3H\u001b[?25h"]
