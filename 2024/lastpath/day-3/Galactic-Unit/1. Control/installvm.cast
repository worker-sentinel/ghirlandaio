[0.618, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;1H\u001b[K\u001b[44;152H9,1\u001b[12C0%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#tls_port = \"16514\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H12,1\u001b[11C1%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Override the port for accepting insecure TCP connections\r\n# This can be a port number, or service name\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H15,1\u001b[11C1%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H18,1\u001b[11C2%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#tcp_port = \"16509\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H21,1\u001b[11C2%\u001b[?25h\u001b[6;1H"]
[0.025, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Override the default configuration which binds to all network\r\n# interfaces. This can be a numeric IPv4/6 address, or hostname\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H24,1\u001b[11C3%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H27,1\u001b[11C4%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# If the libvirtd service is started in parallel with network\r\n# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H30,1\u001b[11C4%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#listen_addr = \"192.168.0.1\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H33,1\u001b[11C5%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H36,1\u001b[11C5%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# UNIX socket access controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H39,0-1\u001b[9C6%\u001b[?25h\u001b[6;1H"]
[0.024, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H42,1\u001b[11C7%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H45,1\u001b[11C7%\u001b[?25h\u001b[6;1H"]
[0.144, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This is restricted to 'root' by default.\r\n#unix_sock_group = \"libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H48,1\u001b[11C8%\u001b[?25h\u001b[6;1H"]
[0.401, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H51,1\u001b[11C8%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H54,1\u001b[11C9%\u001b[?25h\u001b[6;1H"]
[0.035, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H57,0-1\u001b[8C10%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#unix_sock_ro_perms = \"0777\"\r\n\r\n# Set the UNIX socket permissions for the R/W socket. This is used\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H60,1\u001b[10C10%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# for full management of VMs\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H63,1\u001b[10C11%\u001b[?25h\u001b[6;1H"]
[0.026, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# activation.\r\n#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H66,1\u001b[10C11%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the default will change to allow everyone (eg, 0777)\r\n#\r\n# If not using PolicyKit and setting group ownership for access\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H69,1\u001b[10C12%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H72,1\u001b[10C12%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the UNIX socket permissions for the admin interface socket.\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H75,1\u001b[10C13%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# activation.\r\n#\r\n# Default allows only owner (root), do not change it unless you are\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H78,1\u001b[10C14%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H81,1\u001b[10C14%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H84,1\u001b[10C15%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H87,1\u001b[10C15%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[44;152H\u001b[K\u001b[44;152H90,1\u001b[10C16%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# Authentication.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H93,1\u001b[10C17%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# There are the following choices available:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H96,0-1\u001b[8C17%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\r\n#          restrictions on connecting to the socket (eg, UNIX\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H99,1\u001b[10C18%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H102,1\u001b[9C18%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\r\n#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H105,1\u001b[9C19%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\r\n#  - polkit: use PolicyKit to authenticate. This is only suitable\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H108,1\u001b[9C20%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\r\n#            full read/write access (aka sudo like), while anyone\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H111,1\u001b[9C20%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#            is allowed read/only access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H114,1\u001b[9C21%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\r\n#\r\n# By default socket permissions allow anyone to connect\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H117,1\u001b[9C21%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# no access control checks are done, but libvirt still only\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H120,1\u001b[9C22%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# allows execution of APIs which don't change state.\r\n#\r\n# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H123,1\u001b[9C22%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still a"]
[0.000, "o", "llows any local\r\n# user access.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H126,0-1\u001b[7C23%\u001b[?25h\u001b[6;1H"]
[0.022, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# To restrict monitoring of domains you may wish to either\r\n# enable 'sasl' here, or change the polkit policy definition.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H129,1\u001b[9C24%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_unix_ro = \"polkit\"\r\n\r\n# Set an authentication scheme for UNIX read-write sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H132,1\u001b[9C24%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0600 by default\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H135,1\u001b[9C25%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H138,1\u001b[9C25%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\r\n# allows any user to connect and 'auth_unix_rw' will default\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H141,1\u001b[9C26%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\r\n# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H144,1\u001b[9C27%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#auth_unix_rw = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H147,1\u001b[9C27%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Change the authentication scheme for TCP sockets.\r\n#\r\n# If you don't enable SASL, then all TCP traffic is cleartext.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H150,1\u001b[9C28%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\r\n# mechanism in /etc/sasl2/libvirt.conf\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H153,1\u001b[9C28%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_tcp = \"sasl\"\r\n\r\n# Change the authentication scheme for TLS sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H156,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.037, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H159,1\u001b[9C30%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H162,1\u001b[9C30%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_tls = \"none\"\r\n\r\n# Enforce a minimum SSF value for TCP sockets\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H165,1\u001b[9C31%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# The default minimum is currently 56 (single-DES) which will\r\n# be raised to 112 in the future.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H168,0-1\u001b[7C31%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H171,1\u001b[9C32%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# Change the API access control scheme\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H174,1\u001b[9C33%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H177,1\u001b[9C33%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H180,1\u001b[9C34%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#access_drivers = [ \"polkit\" ]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H183,1\u001b[9C34%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# TLS x509 certificate configuration\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H186,1\u001b[9C35%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n\r\n# Use of TLS requires that x509 certificates be issued. The default locations\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H189,1\u001b[9C35%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# for the certificate files is as follows:\r\n#\r\n#   /etc/pki/CA/cacert.pem - The CA master certificate\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H192,0-1\u001b[7C36%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H195,1\u001b[9C37%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# It is possible to override the default locations by altering the 'key_file',\r\n# 'cert_file', and 'ca_file' values and uncommenting them below.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H198,1\u001b[9C37%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H201,0-1\u001b[7C38%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server key file path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H204,1\u001b[9C38%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'key_files'\r\n#\r\n#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H207,1\u001b[9C39%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server key file path(s)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C40%\u001b[?25h\u001b[6;1H"]
[0.015, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'key_file'\r\n#\r\n#key_files = [\"/etc/pki/libvirt/private/serverkey-0.pem\", \"/etc/pki/libvirt/private/serverkey-1.pem\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H213,1\u001b[9C40%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server certificate file path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H216,1\u001b[9C41%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'cert_files'\r\n#\r\n#cert_file = \"/etc/pki/libvirt/servercert.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H219,1\u001b[9C41%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server certificate file path(s)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H222,1\u001b[9C42%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'cert_file'\r\n#\r\n#cert_files = [\"/etc/pki/libvirt/servercert-0.pem\", \"/etc/pki/libvirt/servercert-1.pem\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H225,0-1\u001b[7C43%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default CA certificate path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H228,1\u001b[9C43%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#ca_file = \"/etc/pki/CA/cacert.pem\"\r\n\r\n# Specify a certificate revocation list.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H231,1\u001b[9C44%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Defaults to not using a CRL, uncomment to enable it\r\n#crl_file = \"/etc/pki/CA/crl.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H234,1\u001b[9C44%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[44;152H\u001b[K\u001b[44;152H237,1\u001b[9C45%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# Authorization controls\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H240,1\u001b[9C45%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H243,1\u001b[9C46%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Flag to disable verification of our own server certificates\r\n#\r\n# When libvirtd starts it performs some sanity checks against\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H246,1\u001b[9C47%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# its own certificates.\r\n#\r\n# Default is to always run sanity checks. Uncommenting this\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H249,1\u001b[9C47%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H[\u001b[6;1H\u001b[44;143H<\u001b[6;1H\u001b[44;144H6\u001b[6;1H\u001b[44;145H5\u001b[6;1H\u001b[44;146H;\u001b[6;1H\u001b[44;147H1\u001b[6;1H\u001b[44;148H0\u001b[6;1H\u001b[44;149H8\u001b[6;1H\u001b[44;150H;\u001b[6;1H\u001b[44;151H1\u001b[6;1H"]
[0.000, "o", "\u001b[44;142H          \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# will disable sanity checks which is not a good idea\r\n#tls_no_sanity_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H252,1\u001b[9C48%\u001b[?25h\u001b[6;1H"]
[0.021, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Flag to disable verification of client certificates\r\n#\r\n# Client certificate verification is the primary authentication mechanism.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H255,1\u001b[9C48%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Any client which does not present a certificate signed by the CA\r\n# will be rejected.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H258,1\u001b[9C49%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Default is to always verify. Uncommenting this will disable\r\n# verification.\r\n#tls_no_verify_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H261,1\u001b[9C50%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# An access control list of allowed x509 Distinguished Names\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H264,1\u001b[9C50%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This list may contain wildcards such as\r\n#\r\n#    \"C=GB,ST=London,L=London,O=Red Hat,CN=*\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H267,0-1\u001b[7C51%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Any * matches any number of consecutive spaces, like a simplified glob(7).\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H270,1\u001b[9C51%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# The format of the DN for a particular certificate can be queried\r\n# using:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H273,0-1\u001b[7C52%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    virt-pki-query-dn clientcert.pem\r\n#\r\n# NB If this is an empty list, no client can connect, so comment out\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H276,1\u001b[9C53%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# entirely rather than using empty list to disable these checks\r\n#\r\n# By default, no DN's are checked\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H279,0-1\u001b[7C53%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H\u001b[44;144H[\u001b[6;1H"]
[0.001, "o", "\u001b[44;142H   \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#tls_allowed_dn_list = [\"DN1\", \"DN2\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H282,1\u001b[9C54%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Override the compile time default TLS priority string. The\r\n# default is usually \"NORMAL\" unless overridden at build time.\r\n# Only set this is it is desired for libvirt to deviate from\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H285,1\u001b[9C54%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the global default settings.\r\n#\r\n#tls_priority=\"NORMAL\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H288,1\u001b[9C55%\u001b[?25h\u001b[6;1H"]
[0.024, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# An access control list of allowed SASL usernames. The format for username\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H291,1\u001b[9C55%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# depends on the SASL authentication mechanism. Kerberos usernames\r\n# look like username@REALM\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H294,1\u001b[9C56%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This list may contain wildcards such as\r\n#\r\n#    \"*@EXAMPLE.COM\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H297,1\u001b[9C57%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# See the g_pattern_match function for the format of the wildcards.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H300,0-1\u001b[7C57%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# https://developer.gnome.org/glib/stable/glib-Glob-style-pattern-matching.html\r\n#\r\n# NB If this is an empty list, no client can connect, so comment out\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H303,1\u001b[9C58%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H\u001b[44;144H[\u001b[6;1H"]
[0.000, "o", "\u001b[44;142H   \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# entirely rather than using empty list to disable these checks\r\n#\r\n# By default, no Username's are checked\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C58%\u001b[?25h\u001b[6;1H"]
[0.276, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#tls_no_verify_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C58%\u001b[?25h\u001b[9;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Default is to always verify. Uncommenting this will disable\r\n# verification.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C57%\u001b[?25h\u001b[12;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Client certificate verification is the primary authentication mechanism.\r\n# Any client which does not present a certificate signed by the CA\r\n# will be rejected.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C57%\u001b[?25h\u001b[15;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Flag to disable verification of client certificates\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C56%\u001b[?25h\u001b[18;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Default is to always run sanity checks. Uncommenting this\r\n# will disable sanity checks which is not a good idea\r\n#tls_no_sanity_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C55%\u001b[?25h\u001b[21;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# When libvirtd starts it performs some sanity checks against\r\n# its own certificates.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C55%\u001b[?25h\u001b[24;1H"]
[0.026, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Flag to disable verification of our own server certificates\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C54%\u001b[?25h\u001b[27;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Authorization controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C54%\u001b[?25h\u001b[30;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C53%\u001b[?25h\u001b[33;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#crl_file = \"/etc/pki/CA/crl.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C53%\u001b[?25h\u001b[36;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Specify a certificate revocation list.\r\n#\r\n# Defaults to not using a CRL, uncomment to enable it\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H305,1\u001b[9C52%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#ca_file = \"/etc/pki/CA/cacert.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H302,1\u001b[9C51%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#cert_files = [\"/etc/pki/libvirt/servercert-0.pem\", \"/etc/pki/libvirt/servercert-1.pem\"]\r\n\r\n# Override the default CA certificate path\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H299,0-1\u001b[7C51%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This parameter is mutually exclusive with 'cert_file'\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H296,1\u001b[9C50%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#cert_file = \"/etc/pki/libvirt/servercert.pem\"\r\n\r\n# Override the default server certificate file path(s)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H293,1\u001b[9C50%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This parameter is mutually exclusive with 'cert_files'\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H290,1\u001b[9C49%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#key_files = [\"/etc/pki/libvirt/private/serverkey-0.pem\", \"/etc/pki/libvirt/private/serverkey-1.pem\"]\r\n\r\n# Override the default server certificate file path\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H287,1\u001b[9C48%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This parameter is mutually exclusive with 'key_file'\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H284,1\u001b[9C48%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\r\n\r\n# Override the default server key file path(s)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H281,1\u001b[9C47%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This parameter is mutually exclusive with 'key_files'\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H278,1\u001b[9C47%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n\r\n# Override the default server key file path\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H275,1\u001b[9C46%\u001b[?25h\u001b[38;1H"]
[0.003, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H272,0-1\u001b[7C45%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# It is possible to override the default locations by altering the 'key_file',\r\n# 'cert_file', and 'ca_file' values and uncommenting them below.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H269,1\u001b[9C45%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#   /etc/pki/CA/cacert.pem - The CA master certificate\r\n#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H266,1\u001b[9C44%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Use of TLS requires that x509 certificates be issued. The default locations\r\n# for the certificate files is as follows:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H263,0-1\u001b[7C44%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# TLS x509 certificate configuration\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H260,1\u001b[9C43%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H257,0-1\u001b[7C43%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# client has authenticated with libvirtd\r\n#\r\n#access_drivers = [ \"polkit\" ]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H254,1\u001b[9C42%\u001b[?25h\u001b[38;1H"]
[0.035, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# to all APIs. Access drivers can place restrictions\r\n# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H251,0-1\u001b[7C41%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Change the API access control scheme\r\n#\r\n# By default an authenticated user is allowed access\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H248,1\u001b[9C41%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#tcp_min_ssf = 112\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H245,0-1\u001b[7C40%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# be raised to 112 in the future.\r\n#\r\n# This option can be used to set values higher than 112\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H242,1\u001b[9C40%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Enforce a minimum SSF value for TCP sockets\r\n#\r\n# The default minimum is currently 56 (single-DES) which will\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H239,0-1\u001b[7C39%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# mechanism as well, by using 'sasl' for this option\r\n#auth_tls = \"none\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H236,1\u001b[9C38%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# layer, and limited authentication is done by certificates\r\n#\r\n# It is possible to make use of any SASL authentication\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H233,1\u001b[9C38%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Change the authentication scheme for TLS sockets.\r\n#\r\n# TLS sockets already have encryption provided by the TLS\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H230,1\u001b[9C37%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# mechanism in /etc/sasl2/libvirt.conf\r\n#auth_tcp = \"sasl\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H227,1\u001b[9C37%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If you don't enable SASL, then all TCP traffic is cleartext.\r\n# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H224,1\u001b[9C36%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Change the authentication scheme for TCP sockets.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H221,1\u001b[9C35%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# back to 0600, to avoid an insecure configuration.\r\n#\r\n#auth_unix_rw = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H218,1\u001b[9C35%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# allows any user to connect and 'auth_unix_rw' will default\r\n# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H215,1\u001b[9C34%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H212,1\u001b[9C34%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0600 by default\r\n# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H209,0-1\u001b[7C33%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Set an authentication scheme for UNIX read-write sockets.\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H206,1\u001b[9C33%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# enable 'sasl' here, or change the polkit policy definition.\r\n#auth_unix_ro = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H203,1\u001b[9C32%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# user access.\r\n#\r\n# To restrict monitoring of domains you may wish to either\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H200,1\u001b[9C31%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\r\n# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still allows any local\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H197,1\u001b[9C31%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# no access control checks are done, but libvirt still only\r\n# allows execution of APIs which don't change state.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H194,1\u001b[9C30%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# By default socket permissions allow anyone to connect\r\n#"]
[0.000, "o", "\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H191,1\u001b[9C30%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H188,1\u001b[9C29%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H185,1\u001b[9C28%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H182,1\u001b[9C28%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H179,1\u001b[9C27%\u001b[?25h\u001b[38;1H"]
[0.017, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H176,1\u001b[9C27%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H173,1\u001b[9C26%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H170,1\u001b[9C25%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Authentication.\r\n#\r\n# There are the following choices available:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H167,1\u001b[9C25%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H164,1\u001b[9C24%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H161,1\u001b[9C24%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H158,1\u001b[9C23%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set the name of the directory in which sockets will be found/created.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H155,1\u001b[9C22%\u001b[?25h\u001b[38;1H"]
[0.057, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C22%\u001b[?25h\u001b[38;1H"]
[1.090, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# allows execution of APIs which don't change state.\r\n#\r\n# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C22%\u001b[?25h\u001b[35;1H"]
[0.142, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still allows any local\r\n# user access.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C23%\u001b[?25h\u001b[32;1H"]
[0.617, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# To restrict monitoring of domains you may wish to either\r\n# enable 'sasl' here, or change the polkit policy definition.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C24%\u001b[?25h\u001b[29;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_unix_ro = \"polkit\"\r\n\r\n# Set an authentication scheme for UNIX read-write sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C24%\u001b[?25h\u001b[26;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0600 by default\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C25%\u001b[?25h\u001b[23;1H"]
[0.025, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C25%\u001b[?25h\u001b[20;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\r\n# allows any user to connect and 'auth_unix_rw' will default\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C26%\u001b[?25h\u001b[17;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\r\n# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C27%\u001b[?25h\u001b[14;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#auth_unix_rw = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C27%\u001b[?25h\u001b[11;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Change the authentication scheme for TCP sockets.\r\n#\r\n# If you don't enable SASL, then all TCP traffic is cleartext.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,1\u001b[9C28%\u001b[?25h\u001b[8;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\r\n# mechanism in /etc/sasl2/libvirt.conf\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H153,1\u001b[9C28%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_tcp = \"sasl\"\r\n\r\n# Change the authentication scheme for TLS sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H156,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H159,1\u001b[9C30%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H162,1\u001b[9C30%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_tls = \"none\"\r\n\r\n# Enforce a minimum SSF value for TCP sockets\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H165,1\u001b[9C31%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# The default minimum is currently 56 (single-DES) which will\r\n# be raised to 112 in the future.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H168,0-1\u001b[7C31%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H171,1\u001b[9C32%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# Change the API access control scheme\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H174,1\u001b[9C33%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H177,1\u001b[9C33%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H180,1\u001b[9C34%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#access_drivers = [ \"polkit\" ]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H183,1\u001b[9C34%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# TLS x509 certificate configuration\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H186,1\u001b[9C35%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n\r\n# Use of TLS requires that x509 certificates be issued. The default locations\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H189,1\u001b[9C35%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# for the certificate files is as follows:\r\n#\r\n#   /etc/pki/CA/cacert.pem - The CA master certificate\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H192,0-1\u001b[7C36%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H195,1\u001b[9C37%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# It is possible to override the default locations by altering the 'key_file',\r\n# 'cert_file', and 'ca_file' values and uncommenting them below.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H198,1\u001b[9C37%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H201,0-1\u001b[7C38%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server key file path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H204,1\u001b[9C38%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'key_files'\r\n#\r\n#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H207,1\u001b[9C39%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server key file path(s)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C40%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'key_file'\r\n#\r\n#key_files = [\"/etc/pki/libvirt/private/serverkey-0.pem\", \"/etc/pki/libvirt/private/serverkey-1.pem\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H213,1\u001b[9C40%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server certificate file path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H216,1\u001b[9C41%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'cert_files'\r\n#\r\n#cert_file = \"/etc/pki/libvirt/servercert.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H219,1\u001b[9C41%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server certificate file path(s)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H222,1\u001b[9C42%\u001b[?25h\u001b[6;1H\u001b[?"]
[0.000, "o", "25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'cert_file'\r\n#\r\n#cert_files = [\"/etc/pki/libvirt/servercert-0.pem\", \"/etc/pki/libvirt/servercert-1.pem\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H225,0-1\u001b[7C43%\u001b[?25h\u001b[6;1H"]
[0.002, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default CA certificate path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H228,1\u001b[9C43%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#ca_file = \"/etc/pki/CA/cacert.pem\"\r\n\r\n# Specify a certificate revocation list.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H231,1\u001b[9C44%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Defaults to not using a CRL, uncomment to enable it\r\n#crl_file = \"/etc/pki/CA/crl.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H234,1\u001b[9C44%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[44;152H\u001b[K\u001b[44;152H237,1\u001b[9C45%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# Authorization controls\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H240,1\u001b[9C45%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H243,1\u001b[9C46%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Flag to disable verification of our own server certificates\r\n#\r\n# When libvirtd starts it performs some sanity checks against\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H246,1\u001b[9C47%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# its own certificates.\r\n#\r\n# Default is to always run sanity checks. Uncommenting this\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H249,1\u001b[9C47%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# will disable sanity checks which is not a good idea\r\n#tls_no_sanity_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H252,1\u001b[9C48%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Flag to disable verification of client certificates\r\n#\r\n# Client certificate verification is the primary authentication mechanism.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H255,1\u001b[9C48%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Any client which does not present a certificate signed by the CA\r\n# will be rejected.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H258,1\u001b[9C49%\u001b[?25h\u001b[6;1H"]
[0.025, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Default is to always verify. Uncommenting this will disable\r\n# verification.\r\n#tls_no_verify_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H261,1\u001b[9C50%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# An access control list of allowed x509 Distinguished Names\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H264,1\u001b[9C50%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This list may contain wildcards such as\r\n#\r\n#    \"C=GB,ST=London,L=London,O=Red Hat,CN=*\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H267,0-1\u001b[7C51%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Any * matches any number of consecutive spaces, like a simplified glob(7).\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H270,1\u001b[9C51%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# The format of the DN for a particular certificate can be queried\r\n# using:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H273,0-1\u001b[7C52%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    virt-pki-query-dn clientcert.pem\r\n#\r\n# NB If this is an empty list, no client can connect, so comment out\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H276,1\u001b[9C53%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# entirely rather than using empty list to disable these checks\r\n#\r\n# By default, no DN's are checked\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H279,0-1\u001b[7C53%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#tls_allowed_dn_list = [\"DN1\", \"DN2\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H282,1\u001b[9C54%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Override the compile time default TLS priority string. The\r\n# default is usually \"NORMAL\" unless overridden at build time.\r\n# Only set this is it is desired for libvirt to deviate from\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H285,1\u001b[9C54%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the global default settings.\r\n#\r\n#tls_priority=\"NORMAL\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H288,1\u001b[9C55%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# An access control list of allowed SASL usernames. The format for username\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H291,1\u001b[9C55%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# depends on the SASL authentication mechanism. Kerberos usernames\r\n# look like username@REALM\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H294,1\u001b[9C56%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This list may contain wildcards such as\r\n#\r\n#    \"*@EXAMPLE.COM\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H297,1\u001b[9C57%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# See the g_pattern_match function for the format of the wildcards.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H300,0-1\u001b[7C57%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# https://developer.gnome.org/glib/stable/glib-Glob-style-pattern-matching.html\r\n#\r\n# NB If this is an empty list, no client can connect, so comment out\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H303,1\u001b[9C58%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# entirely rather than using empty list to disable these checks\r\n#\r\n# By default, no Username's are checked\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H306,1\u001b[9C58%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#sasl_allowed_username_list = [\"joe@EXAMPLE.COM\", \"fred@EXAMPLE.COM\" ]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H309,1\u001b[9C59%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# Processing controls\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H312,1\u001b[9C60%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n\r\n# The maximum number of concurrent client connections to allow\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H315,1\u001b[9C60%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# over all sockets combined.\r\n#max_clients = 5000\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H318,0-1\u001b[7C61%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# The maximum length of queue of connections waiting to be\r\n# accepted by the daemon. Note, that some protocols supporting\r\n# retransmission may obey this so that a later reattempt at\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H321,1\u001b[9C61%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H\u001b[44;144H[\u001b[6;1H\u001b[44;145H<\u001b[6;1H\u001b[44;146H6\u001b[6;1H"]
[0.002, "o", "\u001b[44;142H     \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# connection succeeds.\r\n#max_queued_clients = 1000\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H324,1\u001b[9C62%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# The maximum length of queue of accepted but not yet\r\n# authenticated clients. The default value is 20. Set this to\r\n# zero to turn this feature off.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H327,0-1\u001b[7C63%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#max_anonymous_clients = 20\r\n\r\n# The minimum limit sets the number of workers to start up\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H330,1\u001b[9C63%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# initially. If the number of active clients exceeds this,\r\n# then more threads are spawned, up to max_workers limit.\r\n# Typically you'd want max_workers to equal maximum number\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H333,1\u001b[9C64%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# of clients allowed\r\n#min_workers = 5\r\n#max_workers = 20\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H336,1\u001b[9C64%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# The number of priority workers. If all workers from above\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H339,1\u001b[9C65%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# pool are stuck, some calls marked as high priority\r\n# (notably domainDestroy) can be executed in this pool.\r\n#prio_workers = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H342,1\u001b[9C66%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Limit on concurrent requests from a single client\r\n# connection. To avoid one client monopolizing the server\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H345,0-1\u001b[7C66%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# this should be a small fraction of the global max_workers\r\n# parameter.\r\n# Setting this too low may cause keepalive timeouts.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H348,1\u001b[9C67%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#max_client_requests = 5\r\n\r\n# Same processing controls, but this time for the admin interface.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H351,0-1\u001b[7C67%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# For description of each option, be so kind to scroll few lines\r\n# upwards.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H354,1\u001b[9C68%\u001b[?25h\u001b[6;1H"]
[0.012, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#admin_min_workers = 1\r\n#admin_max_workers = 5\r\n#admin_max_clients = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H357,1\u001b[9C68%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#admin_max_queued_clients = 5\r\n#admin_max_client_requests = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H360,1\u001b[9C69%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# Logging controls\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H363,1\u001b[9C70%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n\r\n# Logging level: 4 errors, 3 warnings, 2 information, 1 debug\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H366,0-1\u001b[7C70%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# basically 1 will log everything possible\r\n#\r\n# WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H369,1\u001b[9C71%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# WARNING: It outputs too much information to practically read.\r\n# WARNING: The \"log_filters\" setting is recommended instead.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H372,1\u001b[9C71%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# WARNING: Journald applies rate limiting of messages and so libvirt\r\n# WARNING: will limit \"log_level\" to only allow values 3 or 4 if\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H375,0-1\u001b[7C72%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# WARNING: journald is the current output.\r\n#\r\n# WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H378,1\u001b[9C73%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#log_level = 3\r\n\r\n# Logging filters:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H381,1\u001b[9C73%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# A filter allows to select a different logging level for a given category\r\n# of logs. The format for a filter is:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H384,1\u001b[9C74%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H\u001b[44;144H[\u001b[6;1H\u001b[44;145H<\u001b[6;1H\u001b[44;146H6\u001b[6;1H\u001b[44;147H5\u001b[6;1H\u001b[44;148H;\u001b[6;1H\u001b[44;149H1\u001b[6;1H\u001b[44;150H0\u001b[6;1H"]
[0.001, "o", "\u001b[44;142H         \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    level:match\r\n#\r\n# where 'match' is a string which is matched against the category\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H387,0-1\u001b[7C74%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# given in the VIR_LOG_INIT() at the top of each libvirt source\r\n# file, e.g., \"remote\", \"qemu\", or \"util.json\". The 'match' in the\r\n# filter matches using shell wildcard syntax (see 'man glob(7)').\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H390,1\u001b[9C75%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# The 'match' is always treated as a substring match. IOW a match\r\n# string 'foo' is equivalent to '*foo*'.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H393,1\u001b[9C76%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# 'level' is the minimal level where matching messages should\r\n#  be logged:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H396,1\u001b[9C76%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    1: DEBUG\r\n#    2: INFO\r\n#    3: WARNING\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H399,1\u001b[9C77%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    4: ERROR\r\n#\r\n# Multiple filters can be defined in a single @log_filters, they just need\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H402,0-1\u001b[7C77%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# to be separated by spaces. Note that libvirt performs \"first\" match, i.e.\r\n# if there are concurrent filters, the first one that matches will be applied,\r\n# given the order in @log_filters.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H405,1\u001b[9C78%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H\u001b[44;144H[\u001b[6;1H\u001b[44;145H<\u001b[6;1H\u001b[44;146H6\u001b[6;1H\u001b[44;147H5\u001b[6;1H\u001b[44;148H;\u001b[6;1H\u001b[44;149H1\u001b[6;1H\u001b[44;150H0\u001b[6;1H\u001b[44;151H8\u001b[6;1H"]
[0.001, "o", "\u001b[44;142H          \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# A typical need is to capture information from a hypervisor driver,\r\n# public API entrypoints and some of the utility code. Some utility\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H408,1\u001b[9C78%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# code is very verbose and is generally not desired. Taking the QEMU\r\n# hypervisor as an example, a suitable filter string for debugging\r\n# might be to turn off object, json & event logging, but enable the\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H411,1\u001b[9C79%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# rest of the util code:\r\n#\r\n#log_filters=\"1:qemu 1:libvirt 4:object 4:json 4:event 1:util\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H414,1\u001b[9C80%\u001b[?25h\u001b[6;1H"]
[0.013, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Logging outputs:\r\n# An output is one of the places to save logging information\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H417,0-1\u001b[7C80%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# The format for an output can be:\r\n#    level:stderr\r\n#      output goes to stderr\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H420,1\u001b[9C81%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    level:syslog:name\r\n#      use syslog for the output and use the given name as the ident\r\n#    level:file:file_path\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H423,1\u001b[9C81%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#      output to a file, with the given filepath\r\n#    level:journald\r\n#      output to journald logging system\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H426,1\u001b[9C82%\u001b[?25h\u001b[6;1H"]
[0.004, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# In all cases 'level' is the minimal priority, acting as a filter\r\n#    1: DEBUG\r\n#    2: INFO\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H429,1\u001b[9C83%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#    3: WARNING\r\n#    4: ERROR\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H432,1\u001b[9C83%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Multiple outputs can be defined, they just need to be separated by spaces.\r\n# e.g. to log all warnings and errors to syslog under the libvirtd ident:\r\n#log_outputs=\"3:syslog:libvirtd\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H435,1\u001b[9C84%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m##################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H438,1\u001b[9C84%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Auditing\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H441,1\u001b[9C85%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This setting allows usage of the auditing subsystem to be altered:\r\n#\r\n#   audit_level == 0  -> disable all auditing\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H444,1\u001b[9C86%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#   audit_level == 1  -> enable auditing, only if enabled on host (default)\r\n#   audit_level == 2  -> enable auditing, and exit if disabled on host\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H447,1\u001b[9C86%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#audit_level = 2\r\n#\r\n# If set to 1, then audit messages will also be sent\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H450,1\u001b[9C87%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# via libvirt logging infrastructure. Defaults to 0\r\n#\r\n#audit_logging = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H453,1\u001b[9C87%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m###################################################################\r\n# UUID of the host:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H456,1\u001b[9C88%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Host UUID is read from one of the sources specified in host_uuid_source.\r\n#\r\n# - 'smbios': fetch the UUID from 'dmidecode -s system-uuid'\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H459,1\u001b[9C88%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# - 'machine-id': fetch the UUID from /etc/machine-id\r\n#\r\n# The host_uuid_source default is 'smbios'. If 'dmidecode' does not provide\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H462,1\u001b[9C89%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# a valid UUID a temporary UUID will be generated.\r\n#\r\n# Another option is to specify host UUID in host_uuid.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H465,1\u001b[9C90%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Keep the format of the example UUID below. UUID must not have all digits\r\n# be the same.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H468,1\u001b[9C90%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# NB This default all-zeros UUID will not work. Replace\r\n# it with the output of the 'uuidgen' command and then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H471,1\u001b[9C91%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# uncomment this entry\r\n#host_uuid = \"00000000-0000-0000-0000-000000000000\"\r\n#host_uuid_source = \"smbios\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H474,0-1\u001b[7C91%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m###################################################################\r\n# Keepalive protocol:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H477,1\u001b[9C92%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This allows libvirtd to detect broken client connections or even\r\n# dead clients.  A keepalive message is sent to a client after\r\n# keepalive_interval seconds of inactivity to check if the client is\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H480,1\u001b[9C93%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# still responding; keepalive_count is a maximum number of keepalive\r\n# messages that are allowed to be sent to the client without getting\r\n# any response before the connection is considered broken.  In other\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H483,1\u001b[9C93%\u001b[?25h\u001b[6;1H"]
[0.015, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# words, the connection is automatically closed approximately after\r\n# keepalive_interval * (keepalive_count + 1) seconds since the last\r\n# message received from the client.  If keepalive_interval is set to\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H486,1\u001b[9C94%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# -1, libvirtd will never send keepalive requests; however clients\r\n# can still send them and the daemon will send responses.  When\r\n# keepalive_count is set to 0, connections will be automatically\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H489,1\u001b[9C94%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# closed after keepalive_interval seconds of inactivity without\r\n# sending any keepalive messages.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H492,1\u001b[9C95%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#keepalive_interval = 5\r\n#keepalive_count = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H495,1\u001b[9C96%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# These configuration options are no longer used.  There is no way to\r\n# restrict such clients from connecting since they first need to\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H498,1\u001b[9C96%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# connect in order to ask for keepalive.\r\n#\r\n#keepalive_required = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H501,1\u001b[9C97%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#admin_keepalive_required = 1\r\n\r\n# Keepalive settings for the admin interface\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H504,1\u001b[9C97%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#admin_keepalive_interval = 5\r\n#admin_keepalive_count = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H507,1\u001b[9C98%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m###################################################################\r\n# Open vSwitch:\r\n# This allows to specify a timeout for openvswitch calls made by\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H510,1\u001b[9C99%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# libvirt. The ovs-vsctl utility is used for the configuration and\r\n# its timeout option is set by default to 5 seconds to avoid\r\n# potential infinite waits blocking libvirt.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H513,1\u001b[9C99%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#ovs_timeout = 5\u001b[m\r\n\u001b[94m~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H516,1\u001b[9CBot\u001b[?25h\u001b[6;1H"]
[0.015, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H519,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H522,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H525,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H528,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H531,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H534,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                  "]
[0.000, "o", "                                                                                                                                      \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H537,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H540,0-1\u001b[7CBot\u001b[?25h\u001b[6;1H"]
[0.016, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H543,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H546,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H549,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[94m~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[3;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[2M\u001b[1;44r\u001b[42;1H\u001b[94m~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[1;1H\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h"]
[0.017, "o", "\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h"]
[0.015, "o", "\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h"]
[0.513, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# its timeout option is set by default to 5 seconds to avoid\r\n# potential infinite waits blocking libvirt.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[4;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Open vSwitch:\r\n# This allows to specify a timeout for openvswitch calls made by\r\n# libvirt. The ovs-vsctl utility is used for the configuration and\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[7;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#admin_keepalive_count = 5\r\n\r\n###################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[10;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Keepalive settings for the admin interface\r\n#admin_keepalive_interval = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[13;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#keepalive_required = 1\r\n#admin_keepalive_required = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[16;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# These configuration options are no longer used.  There is no way to\r\n# restrict such clients from connecting since they first need to\r\n# connect in order to ask for keepalive.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[19;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#keepalive_count = 5\r\n\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[22;1H"]
[0.009, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# sending any keepalive messages.\r\n#\r\n#keepalive_interval = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[25;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# can still send them and the daemon will send responses.  When\r\n# keepalive_count is set to 0, connections will be automatically\r\n# closed after keepalive_interval seconds of inactivity without\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[28;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# keepalive_interval * (keepalive_count + 1) seconds since the last\r\n# message received from the client.  If keepalive_interval is set to\r\n# -1, libvirtd will never send keepalive requests; however clients\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[31;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# messages that are allowed to be sent to the client without getting\r\n# any response before the connection is considered broken.  In other\r\n# words, the connection is automatically closed approximately after\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[34;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# dead clients.  A keepalive message is sent to a client after\r\n# keepalive_interval seconds of inactivity to check if the client is\r\n# still responding; keepalive_count is a maximum number of keepalive\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[37;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m###################################################################\r\n# Keepalive protocol:\r\n# This allows libvirtd to detect broken client connections or even\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[40;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#host_uuid = \"00000000-0000-0000-0000-000000000000\"\r\n#host_uuid_source = \"smbios\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,1\u001b[9CBot\u001b[?25h\u001b[43;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# NB This default all-zeros UUID will not work. Replace\r\n# it with the output of the 'uuidgen' command and then\r\n# uncomment this entry\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H544,0-1\u001b[7C99%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Keep the format of the example UUID below. UUID must not have all digits\r\n# be the same.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H541,1\u001b[9C98%\u001b[?25h\u001b[38;1H"]
[0.021, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Another option is to specify host UUID in host_uuid.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H538,1\u001b[9C98%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# The host_uuid_source default is 'smbios'. If 'dmidecode' does not provide\r\n# a valid UUID a temporary UUID will be generated.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H535,1\u001b[9C97%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# - 'smbios': fetch the UUID from 'dmidecode -s system-uuid'\r\n# - 'machine-id': fetch the UUID from /etc/machine-id\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H532,0-1\u001b[7C97%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m###################################################################\r\n# UUID of the host:\r\n# Host UUID is read from one of the sources specified in host_uuid_source.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H529,1\u001b[9C96%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#audit_logging = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H526,1\u001b[9C95%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If set to 1, then audit messages will also be sent\r\n# via libvirt logging infrastructure. Defaults to 0\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H523,1\u001b[9C95%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#   audit_level == 2  -> enable auditing, and exit if disabled on host\r\n#\r\n#audit_level = 2\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H520,1\u001b[9C94%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#   audit_level == 0  -> disable all auditing\r\n#   audit_level == 1  -> enable auditing, only if enabled on host (default)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H517,1\u001b[9C94%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Auditing\r\n#\r\n# This setting allows usage of the auditing subsystem to be altered:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H514,1\u001b[9C93%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m##################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H511,1\u001b[9C92%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# e.g. to log all warnings and errors to syslog under the libvirtd ident:\r\n#log_outputs=\"3:syslog:libvirtd\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H508,1\u001b[9C92%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#    4: ERROR\r\n#\r\n# Multiple outputs can be defined, they just need to be separated by spaces.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H505,1\u001b[9C91%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#    1: DEBUG\r\n#    2: INFO\r\n#    3: WARNING\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H502,1\u001b[9C91%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#    level:journald\r\n#      output to journald logging system\r\n# In all cases 'level' is the minimal priority, acting as a filter\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H499,1\u001b[9C90%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#      use syslog for the output and use the given name as the ident\r\n#    level:file:file_path\r\n#      output to a file, with the given filepath\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H496,1\u001b[9C89%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#    level:stderr\r\n#      output goes to stderr\r\n#    level:syslog:name\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H493,1\u001b[9C89%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Logging outputs:\r\n# An output is one of the places to save logging information\r\n# The format for an output can be:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H490,1\u001b[9C88%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#log_filters=\"1:qemu 1:libvirt 4:object 4:json 4:event 1:util\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H487,1\u001b[9C88%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# hypervisor as an example, a suitable filter string for debugging\r\n# might be to turn off object, json & event logging, but enable the\r\n# rest of the util code:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H484,1\u001b[9C87%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# A typical need is to capture information from a hypervisor driver,\r\n# public API entrypoints and some of the utility code. Some utility\r\n# code is very verbose and is generally not desired. Taking the QEMU\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H481,1\u001b[9C87%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# if there are concurrent filters, the first one that matches will be applied,\r\n# given the order in @log_filters.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H478"]
[0.000, "o", ",1\u001b[9C86%\u001b[?25h\u001b[38;1H"]
[0.002, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Multiple filters can be defined in a single @log_filters, they just need\r\n# to be separated by spaces. Note that libvirt performs \"first\" match, i.e.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H475,1\u001b[9C85%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#    2: INFO\r\n#    3: WARNING\r\n#    4: ERROR\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H472,1\u001b[9C85%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#  be logged:\r\n#\r\n#    1: DEBUG\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H469,1\u001b[9C84%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# string 'foo' is equivalent to '*foo*'.\r\n#\r\n# 'level' is the minimal level where matching messages should\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H466,1\u001b[9C84%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# file, e.g., \"remote\", \"qemu\", or \"util.json\". The 'match' in the\r\n# filter matches using shell wildcard syntax (see 'man glob(7)').\r\n# The 'match' is always treated as a substring match. IOW a match\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H463,1\u001b[9C83%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# where 'match' is a string which is matched against the category\r\n# given in the VIR_LOG_INIT() at the top of each libvirt source\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H460,1\u001b[9C82%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# of logs. The format for a filter is:\r\n#\r\n#    level:match\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H457,1\u001b[9C82%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Logging filters:\r\n# A filter allows to select a different logging level for a given category\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H454,1\u001b[9C81%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\r\n#log_level = 3\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H451,1\u001b[9C81%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# WARNING: Journald applies rate limiting of messages and so libvirt\r\n# WARNING: will limit \"log_level\" to only allow values 3 or 4 if\r\n# WARNING: journald is the current output.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H448,1\u001b[9C80%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# WARNING: It outputs too much information to practically read.\r\n# WARNING: The \"log_filters\" setting is recommended instead.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H445,1\u001b[9C79%\u001b[?25h\u001b[38;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H442,1\u001b[9C79%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Logging level: 4 errors, 3 warnings, 2 information, 1 debug\r\n# basically 1 will log everything possible\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H439,1\u001b[9C78%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Logging controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H436,1\u001b[9C78%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#admin_max_client_requests = 5\r\n\r\n#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H433,1\u001b[9C77%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#admin_max_workers = 5\r\n#admin_max_clients = 5\r\n#admin_max_queued_clients = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H430,1\u001b[9C77%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# upwards.\r\n\r\n#admin_min_workers = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H427,1\u001b[9C76%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Same processing controls, but this time for the admin interface.\r\n# For description of each option, be so kind to scroll few lines\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H424,1\u001b[9C75%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# parameter.\r\n# Setting this too low may cause keepalive timeouts.\r\n#max_client_requests = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H421,1\u001b[9C75%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Limit on concurrent requests from a single client\r\n# connection. To avoid one client monopolizing the server\r\n# this should be a small fraction of the global max_workers\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H418,1\u001b[9C74%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# (notably domainDestroy) can be executed in this pool.\r\n#prio_workers = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H415,1\u001b[9C74%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# The number of priority workers. If all workers from above\r\n# pool are stuck, some calls marked as high priority\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H412,1\u001b[9C73%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#min_workers = 5\r\n#max_workers = 20\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H409,1\u001b[9C72%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# then more threads are spawned, up to max_workers limit.\r\n# Typically you'd want max_workers to equal maximum number\r\n# of clients allowed\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H406,1\u001b[9C72%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# The minimum limit sets the number of workers to start up\r\n# initially. If the number of active clients exceeds this,\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H403,1\u001b[9C71%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# authenticated clients. The default value is 20. Set this to\r\n# zero to turn this feature off.\r\n#max_anonymous_clients = 20\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H400,1\u001b[9C71%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#max_queued_clients = 1000\r\n\r\n# The maximum length of queue of accepted but not yet\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H397,0-1\u001b[7C70%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# accepted by the daemon. Note, that some protocols supporting\r\n# retransmission may obey this so that a later reattempt at\r\n# connection succeeds.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H394,1\u001b[9C69%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#max_clients = 5000\r\n\r\n# The maximum length of queue of connections waiting to be\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H391,0-1\u001b[7C69%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# The maximum number of concurrent client connections to allow\r\n# over all sockets combined.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H388,1\u001b[9C68%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[44;142H<\u001b[38;1H\u001b[44;143H6\u001b[38;1H\u001b[44;144H4\u001b[38;1H\u001b[44;145H;\u001b[38;1H\u001b[44;146H1\u001b[38;1H\u001b[44;147H0\u001b[38;1H\u001b[44;148H8\u001b[38;1H\u001b[44;149H;\u001b[38;1H\u001b[44;150H1\u001b[38;1H\u001b[44;151H9\u001b[38;1H"]
[0.003, "o", "\u001b[44;142H          \u001b[38;1H\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Processing controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H385,1\u001b[9C68%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H382,1\u001b[9C67%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# By default, no Username's are checked\r\n#sasl_allowed_username_list = [\"joe@EXAMPLE.COM\", \"fred@EXAMPLE.COM\" ]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H379,1\u001b[9C66%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# NB If this is an empty list, no client can connect, so comment out\r\n# entirely rather than using empty list to disable these checks\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H376,1\u001b[9C66%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# See the g_pattern_match function for the format of the wildcards.\r\n#\r\n# https://developer.gnome.org/glib/stable/glib-Glob-style-pattern-matching.html\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H373,1\u001b[9C65%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#    \"*@EXAMPLE.COM\"\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H370,1\u001b[9C65%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# look like username@REALM\r\n#\r\n# This list may contain wildcards such as\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H367,1\u001b[9C64%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# An access control list of allowed SASL usernames. The format for username\r\n# depends on the SASL authentication mechanism. Kerberos usernames\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H364,1\u001b[9C64%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#tls_priority=\"NORMAL\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H361,0-1\u001b[7C63%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# default is usually \"NORMAL\" unless overridden at build time.\r\n# Only set this is it is desired for libvirt to deviate from\r\n# the global default settings.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H358,1\u001b[9C62%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m# Override the compile time default TLS priority string. The\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H355,0-1\u001b[7C62%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# By default, no DN's are checked\r\n#tls_allowed_dn_list = [\"DN1\", \"DN2\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H352,1\u001b[9C61%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# NB If this is an empty list, no client can connect, so comment out\r\n# entirely rather than using empty list to disable these checks\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H349,1\u001b[9C61%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# using:\r\n#\r\n#    virt-pki-query-dn clientcert.pem\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H346,0-1\u001b[7C60%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[44;142H^[\u001b[38;1H\u001b[44;144H[\u001b[38;1H"]
[0.001, "o", "\u001b[44;142H   \u001b[38;1H\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Any * matches any number of consecutive spaces, like a simplified glob(7).\r\n#\r\n# The format of the DN for a particular certificate can be queried\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H343,1\u001b[9C59%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#    \"C=GB,ST=London,L=London,O=Red Hat,CN=*\"\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H340,1\u001b[9C59%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# An access control list of allowed x509 Distinguished Names\r\n# This list may contain wildcards such as\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H337,1\u001b[9C58%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# verification.\r\n#tls_no_verify_certificate = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H334,1\u001b[9C58%\u001b[?25h\u001b[38;1H"]
[0.011, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# will be rejected.\r\n#\r\n# Default is to always verify. Uncommenting this will disable\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H331,1\u001b[9C57%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Client certificate verification is the primary authentication mechanism.\r\n# Any client which does not present a certificate signed by the CA\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H328,1\u001b[9C56%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#tls_no_sanity_certificate = 1\r\n\r\n# Flag to disable verification of client certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H325,1\u001b[9C56%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Default is to always run sanity checks. Uncommenting this\r\n# will disable sanity checks which is not a good idea\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H322,1\u001b[9C55%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# When libvirtd starts it performs some sanity checks against\r\n# its own certificates.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H319,0-1\u001b[7C55%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m# Flag to disable verification of our own server certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H316,1\u001b[9C54%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Authorization controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H313,1\u001b[9C54%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[44;142H^[\u001b[38;1H\u001b[44;144H[\u001b[38;1H\u001b[44;145H<\u001b[38;1H\u001b[44;146H6\u001b[38;1H\u001b[44;147H4\u001b[38;1H\u001b[44;148H;\u001b[38;1H\u001b[44;149H1\u001b[38;1H"]
[0.001, "o", "\u001b[44;142H        \u001b[38;1H\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H310,1\u001b[9C53%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Defaults to not using a CRL, uncomment to enable it\r\n#crl_file = \"/etc/pki/CA/crl.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H307,1\u001b[9C52%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Specify a certificate revocation list.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H304,1\u001b[9C52%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Override the default CA certificate path\r\n#\r\n#ca_file = \"/etc/pki/CA/cacert.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H301,1\u001b[9C51%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#cert_files = [\"/etc/pki/libvirt/servercert-0.pem\", \"/etc/pki/libvirt/servercert-1.pem\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H298,1\u001b[9C51%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[44;142H^[\u001b[38;1H\u001b[44;144H[\u001b[38;1H\u001b[44;145H<\u001b[38;1H\u001b[44;146H6\u001b[38;1H\u001b[44;147H4\u001b[38;1H\u001b[44;148H;\u001b[38;1H\u001b[44;149H1\u001b[38;1H\u001b[44;150H0\u001b[38;1H"]
[0.000, "o", "\u001b[44;142H         \u001b[38;1H\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Override the default server certificate file path(s)\r\n#\r\n# This parameter is mutually exclusive with 'cert_file'\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H295,1\u001b[9C50%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#cert_file = \"/etc/pki/libvirt/servercert.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H292,1\u001b[9C49%\u001b[?25h\u001b[38;1H"]
[0.016, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Override the default server certificate file path\r\n#\r\n# This parameter is mutually exclusive with 'cert_files'\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H289,0-1\u001b[7C49%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#key_files = [\"/etc/pki/libvirt/private/serverkey-0.pem\", \"/etc/pki/libvirt/private/serverkey-1.pem\"]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H286,1\u001b[9C48%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Override the default server key file path(s)\r\n#\r\n# This parameter is mutually exclusive with 'key_file'\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H283,1\u001b[9C48%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H280,0-1\u001b[7C47%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Override the default server key file path\r\n#\r\n# This parameter is mutually exclusive with 'key_files'\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H277,1\u001b[9C46%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H274,0-1\u001b[7C46%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# 'cert_file', and 'ca_file' values and uncommenting them below.\r\n#\r\n# NB, overriding the default of one location requires uncommenting and\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H271,1\u001b[9C45%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#   /etc/pki/libvirt/private/serverkey.pem - The server private key\r\n#\r\n# It is possible to override the default locations by altering the 'key_file',\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H268,1\u001b[9C45%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#   /etc/pki/CA/cacert.pem - The CA master certificate\r\n#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H265,1\u001b[9C44%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Use of TLS requires that x509 certificates be issued. The default locations\r\n# for the certificate files is as follows:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H262,1\u001b[9C44%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# TLS x509 certificate configuration\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H259,1\u001b[9C43%\u001b[?25h\u001b[38;1H"]
[0.048, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#access_drivers = [ \"polkit\" ]\r\n\r\n#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H256,1\u001b[9C42%\u001b[?25h\u001b[38;1H"]
[2.074, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H253,1\u001b[9C42%\u001b[?25h\u001b[38;1H"]
[0.547, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\r\n# on this. By default the 'nop' driver is enabled,\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H250,1\u001b[9C41%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Change the API access control scheme\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H247,1\u001b[9C41%\u001b[?25h\u001b[38;1H"]
[0.236, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H244,1\u001b[9C40%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# The default minimum is currently 56 (single-DES) which will\r\n# be raised to 112 in the future.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H241,1\u001b[9C39%\u001b[?25h\u001b[38;1H"]
[0.387, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Enforce a minimum SSF value for TCP sockets\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H238,1\u001b[9C39%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\r\n#auth_tls = \"none\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H235,1\u001b[9C38%\u001b[?25h\u001b[38;1H"]
[0.062, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H232,1\u001b[9C38%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Change the authentication scheme for TLS sockets.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H229,1\u001b[9C37%\u001b[?25h\u001b[38;1H"]
[0.035, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# use, always enable SASL and use the GSSAPI or DIGEST-MD5\r\n# mechanism in /etc/sasl2/libvirt.conf\r\n#auth_tcp = \"sasl\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H226,1\u001b[9C36%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If you don't enable SASL, then all TCP traffic is cleartext.\r\n# Don't do this outside of a dev/test scenario. For real world\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H223,1\u001b[9C36%\u001b[?25h\u001b[38;1H"]
[0.159, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#auth_unix_rw = \"polkit\"\r\n\r\n# Change the authentication scheme for TCP sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H220,0-1\u001b[7C35%\u001b[?25h\u001b[38;1H"]
[0.339, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# is essential to change the systemd SocketMode parameter\r\n# back to 0600, to avoid an insecure configuration.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H217,1\u001b[9C35%\u001b[?25h\u001b[38;1H"]
[0.271, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0666 which\r\n# allows any user to connect and 'auth_unix_rw' will default\r\n# to 'polkit'. If you disable use of 'polkit' here, then it\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H214,1\u001b[9C34%\u001b[?25h\u001b[38;1H"]
[0.117, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# will default to 'none'.\r\n#\r\n# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H211,1\u001b[9C33%\u001b[?25h\u001b[38;1H"]
[0.256, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If libvirt was compiled without support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0600 by default\r\n# thus only allowing root user to connect, and 'auth_unix_rw'\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H208,1\u001b[9C33%\u001b[?25h\u001b[38;1H"]
[0.127, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set an authentication scheme for UNIX read-write sockets.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H205,1\u001b[9C32%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# To restrict monitoring of domains you may wish to either\r\n# enable 'sasl' here, or change the polkit policy definition.\r\n#auth_unix_ro = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H202,1\u001b[9C32%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# connections. The default policy still allows any local\r\n# user access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H199,1\u001b[9C31%\u001b[?25h\u001b[38;1H"]
[0.108, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If libvirt was compiled with support for 'polkit', then\r\n# the libvirt socket will perform a check with polkit after\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H196,1\u001b[9C31%\u001b[?25h\u001b[38;1H"]
[0.228, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If libvirt was compiled without support for 'polkit', then\r\n# no access control checks are done, but libvirt still only\r\n# allows execution of APIs which don't change state.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H193,1\u001b[9C30%\u001b[?25h\u001b[38;1H"]
[0.084, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# By default socket permissions allow anyone to connect\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H190,1\u001b[9C29%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n\r\n# Set an authentication scheme for UNIX read-only sockets\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H187,1\u001b[9C29%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#            require a user to supply their own password to gain\r\n#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H184,0-1\u001b[7C28%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H181,1\u001b[9C28%\u001b[?25h\u001b[38;1H"]
[0.026, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          controlled from /etc/sasl2/libvirt.conf. For the TCP\r\n#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H178,1\u001b[9C27%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          the network providing auth (eg, TLS/x509 certificates)\r\n#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H175,1\u001b[9C26%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          socket you are allowed. This is suitable if there are\r\n#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H172,1\u001b[9C26%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# There are the following choices available:\r\n#\r\n#  - none: do not perform auth checks. If you can connect to the\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H169,1\u001b[9C25%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Authentication.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H166,1\u001b[9C25%\u001b[?25h\u001b[38;1H"]
[0.039, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H163,1\u001b[9C24%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H160,1\u001b[9C23%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H157,1\u001b[9C23%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#unix_sock_admin_perms = \"0700\"\r\n\r\n# Set the name of the directory in which sockets will be found/created.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H154,1\u001b[9C22%\u001b[?25h\u001b[38;1H"]
[0.061, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H151,0-1\u001b[7C22%\u001b[?25h\u001b[38;1H"]
[0.082, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H148,1\u001b[9C21%\u001b[?25h\u001b[38;1H"]
[0.048, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H145,1\u001b[9C21%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H142,1\u001b[9C20%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H139,1\u001b[9C19%\u001b[?25h\u001b[38;1H"]
[0.024, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H136,1\u001b[9C19%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H133,1\u001b[9C18%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H130,1\u001b[9C18%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H127,0-1\u001b[7C17%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H124,1\u001b[9C16%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This is restricted to 'root' by default.\r\n#unix_sock_group = \"libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H121,1\u001b[9C16%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H118,0-1\u001b[7C15%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H115,1\u001b[9C15%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n\r\n# Set the UNIX domain socket group ownership. This can be used to\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H112,1\u001b[9C14%\u001b[?25h\u001b[38;1H"]
[0.036, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#################################################################\r\n#\r\n# UNIX socket access controls\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H109,0-1\u001b[7C13%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#listen_addr = \"192.168.0.1\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H106,1\u001b[9C13%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H103,1\u001b[9C12%\u001b[?25h\u001b[38;1H"]
[0.072, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n# If the libvirtd service is started in parallel with network\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H100,1\u001b[9C12%\u001b[?25h\u001b[38;1H"]
[0.051, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# interfaces. This can be a numeric IPv4/6 address, or hostname\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H97,1\u001b[10C11%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m# Override the default configuration which binds to all network\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H94,1\u001b[10C11%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n#tcp_port = \"16509\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H91,1\u001b[10C10%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H88,1\u001b[11C9%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#tls_port = \"16514\"\r\n\r\n# Override the port for accepting insecure TCP connections\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H85,1\u001b[11C9%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H82,1\u001b[11C8%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Override the port for accepting secure TLS connections\r\n# This can be a port number, or service name\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H79,1\u001b[11C8%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[44;152H\u001b[K\u001b[44;152H76,0-1\u001b[9C7%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This is disabled by default, uncomment this to enable it.\r\n#listen_tcp = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H73,1\u001b[11C6%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H70,0-1\u001b[9C6%\u001b[?25h\u001b[38;1H"]
[0.663, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H67,1\u001b[11C5%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H64,1\u001b[11C5%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H61,1\u001b[11C4%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H58,0-1\u001b[9C3%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H55,1\u001b[11C3%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H52,1\u001b[11C2%\u001b[?25h\u001b[38;1H"]
[0.008, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H49,0-1\u001b[9C2%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Flag listening for secure TLS connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H46,1\u001b[11C1%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Network connectivity controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H43,1\u001b[11C0%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H40,0-1\u001b[9C0%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[2L\u001b[1;44r\u001b[1;1H\u001b[96m# Master libvirt daemon configuration file\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H38,1\u001b[10CTop\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[?25h"]
