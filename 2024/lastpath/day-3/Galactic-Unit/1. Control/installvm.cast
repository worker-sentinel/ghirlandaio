[2.392, "o", "_\u001b[?25l"]
[0.001, "o", "\u001b[22;10H\u001b[7m_\u001b[m\u001b[44;152H85,1\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;12H\u001b[?25h"]
[0.559, "o", "r\u001b[?25l"]
[0.001, "o", "\u001b[1;43r\u001b[1;1H\u001b[10M\u001b[1;44r\u001b[12;1Hunix_sock_\u001b[22;2H\u001b[7m\u001b[96munix_sock_r\u001b[m\u001b[34;1H\u001b[96m# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\u001b[m\u001b[44;1H\u001b[K\u001b[44;152H95,2\u001b[10C14%\u001b[?25h\u001b[?25l\r/unix_sock_r\u001b[44;152H\u001b[K\u001b[44;13H\u001b[?25h"]
[0.142, "o", "w\u001b[?25l"]
[0.000, "o", "\u001b[1;43r\u001b[1;1H\u001b[13M\u001b[1;44r\u001b[9;2H\u001b[96munix_sock_r\u001b[m\u001b[22;2H\u001b[7m\u001b[96munix_sock_rw\u001b[m\u001b[31;1H\u001b[96m#unix_sock_admin_perms = \"0700\"\r\n\r\n# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[42;1H#################################################################\r\n#\u001b[m\u001b[44;1H\u001b[K\u001b[44;152H108,2\u001b[9C16%\u001b[?25h\u001b[?25l\r/unix_sock_rw\u001b[44;152H\u001b[K\u001b[44;14H\u001b[?25h"]
[5.460, "o", "i\u001b[?25l"]
[0.002, "o", "\u001b[1;1H\u001b[K\u001b[2;2H\u001b[96m################################################################\r\n\r\n# Network connectivity controls\u001b[m\u001b[4;32H\u001b[K\u001b[5;2H\u001b[K\u001b[6;1H\u001b[K\u001b[7;3H\u001b[96mFlag listening for secure TLS connections on the public TCP/IP port.\u001b[m\u001b[8;2H\u001b[K\u001b[9;2H\u001b[96m To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\u001b[m\u001b[11;40H\u001b[K\u001b[12;2H\u001b[K\u001b[13;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[14;14H\u001b[K\u001b[15;2H\u001b[K\u001b[16;2H\u001b[96m It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\u001b[m\u001b[17;25H\u001b[K\u001b[18;2H\u001b[K\u001b[19;2H\u001b[96m This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\u001b[m\u001b[20;16H\u001b[K\u001b[21;1H\u001b[K\u001b[22;2H\u001b[96m Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\u001b[26;8His not needed with 'virtproxyd'.\u001b[m\u001b[26;40H\u001b[K\u001b[27;2H\u001b[K\u001b[28;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[29;14H\u001b[K\u001b[30;2H\u001b[K\u001b[31;2H\u001b[96m Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\u001b[m\u001b[33;36H\u001b[K\u001b[35;8H\u001b[96mis disabled by default, uncomment this to enable it.\u001b[m\u001b[35;60H\u001b[K\u001b[36;2H\u001b[96mlisten_tcp = 1\u001b[m\u001b[37;1H\u001b[K\u001b[38;1H\u001b[K\u001b[40;1H\u001b[96m# Override the port for accepting secure TLS connections\r\n# This can be a port number, or service name\u001b[m\u001b[42;2H\u001b[K\u001b[43;2H\u001b[96m This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H40,0-1\u001b[9C0%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;15H\u001b[?25h"]
[1.576, "o", "\u001b[?25l\u001b[44;14H\u001b[K"]
[0.001, "o", "\u001b[1;1H\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\u001b[m\u001b[2;32H\u001b[K\u001b[4;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\u001b[m\u001b[9;29H\u001b[K\u001b[10;1H\u001b[K\u001b[11;3H\u001b[96mSet the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\u001b[m\u001b[13;2H\u001b[K\u001b[14;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[16;2H\u001b[K\u001b[17;3H\u001b[96mDefault allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\u001b[m\u001b[19;2H\u001b[K\u001b[20;2H\u001b[96m If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\u001b[m\u001b[22;2H\u001b[7m\u001b[96munix_sock_rw\u001b[m\u001b[96m_perms = \"0770\"\u001b[m\u001b[22;29H\u001b[K\u001b[23;1H\u001b[K\u001b[24;3H\u001b[96mSet the UNIX socket permissions for the admin interface socket.\u001b[m\u001b[24;66H\u001b[K\u001b[25;2H\u001b[K\u001b[26;8H\u001b[96msetting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[28;2H\u001b[K\u001b[29;3H\u001b[96mDefault allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\u001b[m\u001b[31;32H\u001b[K\u001b[32;1H\u001b[K\u001b[33;3H\u001b[96mSet the name of the directory in which sockets will be found/created.\u001b[35;8Hsetting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[36;14H\u001b[K\u001b[37;1H\u001b[96m#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[40;1H\u001b[K\u001b[41;1H\u001b[K\u001b[42;2H\u001b[96m################################################################\u001b[m\u001b[43;2H\u001b[K\u001b[44;152H108,2\u001b[9C16%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;14H\u001b[?25h"]
[2.530, "o", "\r/"]
[1.446, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[150C108,2\u001b[9C16%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;2H\u001b[?25h"]
[1.244, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[150C108,2\u001b[9C16%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;2H\u001b[?25h"]
[1.871, "o", "\u001b[12C"]
[1.468, "o", "\u001b[?25l\u001b[44;13H\u001b[K"]
[0.002, "o", "\u001b[1;43r\u001b[1;1H\u001b[13L\u001b[1;44r\u001b[1;1H\u001b[96m# UNIX socket access controls\r\n#\r\n\r\n# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# This is restricted to 'root' by default.\u001b[m\r\nunix_sock_group = \u001b[95m\"libvirt\"\u001b[m\u001b[22;2H\u001b[7m\u001b[96munix_sock_r\u001b[m\u001b[35;2H\u001b[96munix_sock_rw\u001b[m\u001b[44;1H\u001b[K\u001b[44;152H95,2\u001b[10C14%\u001b[?25h\u001b[?25l\r/unix_sock_r\u001b[44;152H\u001b[K\u001b[44;13H\u001b[?25h"]
[2.220, "o", "w\u001b[?25l"]
[0.001, "o", "\u001b[1;43r\u001b[1;1H\u001b[13M\u001b[1;44r\u001b[9;2H\u001b[96munix_sock_r\u001b[m\u001b[22;2H\u001b[7m\u001b[96munix_sock_rw\u001b[m\u001b[31;1H\u001b[96m#unix_sock_admin_perms = \"0700\"\r\n\r\n# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[42;1H#################################################################\r\n#\u001b[m\u001b[44;1H\u001b[K\u001b[44;152H108,2\u001b[9C16%\u001b[?25h\u001b[?25l\r/unix_sock_rw\u001b[44;152H\u001b[K\u001b[44;14H\u001b[?25h"]
