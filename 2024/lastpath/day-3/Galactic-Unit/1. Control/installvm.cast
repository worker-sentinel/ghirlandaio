[0.001, "o", "\u001b[1;1H\u001b[K\u001b[2;2H\u001b[96m################################################################\r\n\r\n# Network connectivity controls\u001b[m\u001b[4;32H\u001b[K\u001b[5;2H\u001b[K\u001b[6;1H\u001b[K\u001b[7;3H\u001b[96mFlag listening for secure TLS connections on the public TCP/IP port.\u001b[m\u001b[8;2H\u001b[K\u001b[9;2H\u001b[96m To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\u001b[m\u001b[11;40H\u001b[K\u001b[12;2H\u001b[K\u001b[13;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[14;14H\u001b[K\u001b[15;2H\u001b[K\u001b[16;2H\u001b[96m It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\u001b[m\u001b[17;25H\u001b[K\u001b[18;2H\u001b[K\u001b[19;2H\u001b[96m This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\u001b[m\u001b[20;16H\u001b[K\u001b[21;1H\u001b[K\u001b[22;2H\u001b[96m Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\u001b[26;8His not needed with 'virtproxyd'.\u001b[m\u001b[26;40H\u001b[K\u001b[27;2H\u001b[K\u001b[28;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[29;14H\u001b[K\u001b[30;2H\u001b[K\u001b[31;2H\u001b[96m Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\u001b[m\u001b[33;36H\u001b[K\u001b[35;8H\u001b[96mis disabled by default, uncomment this to enable it.\u001b[m\u001b[35;60H\u001b[K\u001b[36;2H\u001b[96mlisten_tcp = 1\u001b[m\u001b[37;1H\u001b[K\u001b[38;1H\u001b[K\u001b[40;1H\u001b[96m# Override the port for accepting secure TLS connections\r\n# This can be a port number, or service name\u001b[m\u001b[42;2H\u001b[K\u001b[43;2H\u001b[96m This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H40,0-1\u001b[9C0%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;15H\u001b[?25h"]
