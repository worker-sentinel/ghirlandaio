[4.693, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H74,4\u001b[11C7%\u001b[?25h\u001b[38;4H"]
[1.248, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[5M\u001b[1;44r\u001b[39;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# This is restricted to 'root' by default.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H79,4\u001b[11C8%\u001b[?25h\u001b[38;4H"]
[1.917, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[2M\u001b[1;44r\u001b[42;1H\u001b[96m#unix_sock_group = \"libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H81,6\u001b[11C8%\u001b[?25h\u001b[38;6H"]
[1.608, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[4M\u001b[1;44r\u001b[40;1H\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H85,3\u001b[11C9%\u001b[?25h\u001b[38;3H"]
