[1.465, "o", "\u001b[?25l\bunix_sock_group = \u001b[95m\"libvirt\"\u001b[m\u001b[38;28H\u001b[K\u001b[?25h\u001b[?25l\u001b[44;155H1\u001b[38;1H\u001b[?25h"]
[5.991, "o", "\u001b[?25l'unix_sock_group = \u001b[95m\"libvirt\"\u001b[?25h\u001b[?25l\u001b[m\u001b[44;155H2\u001b[38;2H\u001b[?25h"]
[1.657, "o", "\u001b[?25l\bunix_sock_group = \u001b[95m\"libvirt\"\u001b[m\u001b[38;28H\u001b[K\u001b[?25h\u001b[?25l\u001b[44;155H1\u001b[38;1H\u001b[?25h"]
[6.292, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[12M\u001b[1;44r\u001b[32;1H\u001b[96m# activation.\r\n#\r\n# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\r\n\r\n# Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H85,1\u001b[10C11%\u001b[?25h\u001b[26;1H"]
[0.023, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[24M\u001b[1;44r\u001b[20;1H\u001b[96m# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\r\n#\r\n# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\r\n\r\n# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H89,1\u001b[10C16%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[6M\u001b[1;44r\u001b[39;1H\u001b[96m#################################################################\r\n#\r\n# Authentication.\r\n#\r\n# There are the following choices available:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H95,1\u001b[10C17%\u001b[?25h\u001b[6;1H"]
[0.056, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[6M\u001b[1;44r\u001b[38;1H\u001b[96m#\r\n#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\r\n#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H101,1\u001b[9C18%\u001b[?25h\u001b[6;1H"]
[0.041, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H104,1\u001b[9C19%\u001b[?25h\u001b[6;1H"]
[0.063, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[9M\u001b[1;44r\u001b[35;1H\u001b[96m#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\r\n#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\r\n#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H113,1\u001b[9C21%\u001b[?25h\u001b[6;1H"]
[0.056, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H116,1\u001b[9C21%\u001b[?25h\u001b[6;1H"]
[1.329, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H116,1\u001b[9C21%\u001b[?25h\u001b[9;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[9L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\r\n#\r\n# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H116,1\u001b[9C19%\u001b[?25h\u001b[18;1H"]
[0.022, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[30L\u001b[1;44r\u001b[1;1H\u001b[96m#listen_addr = \"192.168.0.1\"\r\n\r\n\r\n#################################################################\r\n#\r\n# UNIX socket access controls\r\n#\r\n\r\n# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# This is restricted to 'root' by default.\u001b[m\r\nunix_sock_group = \u001b[95m\"libvirt\"\u001b[m\r\n\r\n\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\r\n\r\n# Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H106,1\u001b[9C13%\u001b[?25h\u001b[38;1H"]
[0.026, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[6L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n# If the libvirtd service is started in parallel with network\r\n# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H100,1\u001b[9C12%\u001b[?25h\u001b[38;1H"]
[8.495, "o", "\u001b[?25l\u001b[1;43r\u001b[43;1H\r\n\u001b[1;44r\u001b[43;1H\u001b[96m# If not using PolicyKit and setting group ownership for access\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H101,3\u001b[9C12%\u001b[?25h\u001b[38;3H"]
[5.421, "o", "\u001b[?25l\u001b[44;152H95,3 \u001b[32;3H\u001b[?25h"]
[12.060, "o", "\u001b[?25l\u001b[1;43r\u001b[43;1H\r\n\u001b[1;44r\u001b[43;1H\u001b[96m# control, then you may want to relax this too.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H102,2\u001b[9C12%\u001b[?25h\u001b[38;2H"]
[2.901, "o", "\u001b[?25l\u001b[44;154H1,6\u001b[37;6H\u001b[?25h"]
[1.053, "o", "\u001b[?25l\u001b[44;156H14\u001b[37;14H\u001b[?25h"]
[1.136, "o", "\u001b[?25l\u001b[44;152H99,2  \u001b[35;2H\u001b[?25h"]
[0.680, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18M\u001b[1;44r\u001b[26;1H\u001b[96m#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\r\n\r\n# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H99,2\u001b[10C16%\u001b[?25h\u001b[17;2H"]
[0.008, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[36M\u001b[1;44r\u001b[10;1H\u001b[96m#################################################################\r\n#\r\n# Authentication.\r\n#\r\n# There are the following choices available:\r\n#\r\n#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\r\n#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\r\n#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\r\n#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\r\n#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\r\n#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\r\n#\r\n\r\n# Set an authentication scheme for UNIX read-only sockets\r\n#\r\n# By default socket permissions allow anyone to connect\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# no access control checks are done, but libvirt still only\r\n# allows execution of APIs which don't change state.\r\n#\r\n# If libvirt was compiled with support for 'polkit', then\r\n# the libvirt socket will perform a check with polkit after\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H124,21\u001b[8C23%\u001b[?25h\u001b[6;21H[\b\u001b[?25l\u001b[44;142H^[\u001b[6;21H\u001b[44;144H[\u001b[6;21H"]
[0.000, "o", "\u001b[44;142H   \u001b[6;21H\u001b[96mu\b\u001b[1;43r\u001b[m\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# connections. The default policy still allows any local\r\n# user access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H127,1\u001b[9C23%\u001b[?25h\u001b[6;1H"]
[0.016, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[21M\u001b[1;44r\u001b[23;1H\u001b[96m# To restrict monitoring of domains you may wish to either\r\n# enable 'sasl' here, or change the polkit policy definition.\r\n#auth_unix_ro = \"polkit\"\r\n\r\n# Set an authentication scheme for UNIX read-write sockets.\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0600 by default\r\n# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\r\n#\r\n# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\r\n# allows any user to connect and 'auth_unix_rw' will default\r\n# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\r\n# back to 0600, to avoid an insecure configuration.\r\n#\r\n#auth_unix_rw = \"polkit\"\r\n\r\n# Change the authentication scheme for TCP sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H148,21\u001b[8C27%\u001b[?25h\u001b[6;21H4\b\u001b[?25l\u001b[44;142H^[\u001b[6;21H\u001b[44;144H[\u001b[6;21H\u001b[44;145H<\u001b[6;21H\u001b[44;146H6\u001b[6;21H\u001b[44;147H5\u001b[6;21H\u001b[44;148H;\u001b[6;21H\u001b[44;149H1\u001b[6;21H\u001b[44;150H5\u001b[6;21H\u001b[44;151H;\u001b[6;21H\u001b[44;142H[[<65;15;4\u001b[6;21H"]
[0.002, "o", "\u001b[44;142H          \u001b[6;21H\u001b[96ma\b\u001b[1;43r\u001b[m\u001b[1;1H\u001b[33M\u001b[1;44r\u001b[11;1H\u001b[96m#\r\n# If you don't enable SASL, then all TCP traffic is cleartext.\r\n# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\r\n# mechanism in /etc/sasl2/libvirt.conf\r\n#auth_tcp = \"sasl\"\r\n\r\n# Change the authentication scheme for TLS sockets.\r\n#\r\n# TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\r\n#\r\n# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\r\n#auth_tls = \"none\"\r\n\r\n# Enforce a minimum SSF value for TCP sockets\r\n#\r\n# The default minimum is currently 56 (single-DES) which will\r\n# be raised to 112 in the future.\r\n#\r\n# This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\r\n\r\n\r\n# Change the API access control scheme\r\n#\r\n# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\r\n# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H181,21\u001b[8C34%\u001b[?25h\u001b[6;21H"]
[0.002, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[21M\u001b[1;44r\u001b[23;1H\u001b[96m#access_drivers = [ \"polkit\" ]\r\n\r\n#################################################################\r\n#\r\n# TLS x509 certificate configuration\r\n#\r\n\r\n# Use of TLS requires that x509 certificates be issued. The default locations\r\n# for the certificate files is as follows:\r\n#\r\n#   /etc/pki/CA/cacert.pem - The CA master certificate\r\n#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\r\n#\r\n# It is possible to override the default locations by altering the 'key_file',\r\n# 'cert_file', and 'ca_file' values and uncommenting them below.\r\n#\r\n# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H202,21\u001b[8C38%\u001b[?25h\u001b[6;21H"]
[0.029, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[33M\u001b[1;44r\u001b[11;1H\u001b[96m# Override the default server key file path\r\n#\r\n# This parameter is mutually exclusive with 'key_files'\r\n#\r\n#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\r\n\r\n# Override the default server key file path(s)\r\n#\r\n# This parameter is mutually exclusive with 'key_file'\r\n#\r\n#key_files = [\"/etc/pki/libvirt/private/serverkey-0.pem\", \"/etc/pki/libvirt/private/serverkey-1.pem\"]\r\n\r\n# Override the default server certificate file path\r\n#\r\n# This parameter is mutually exclusive with 'cert_files'\r\n#\r\n#cert_file = \"/etc/pki/libvirt/servercert.pem\"\r\n\r\n# Override the default server certificate file path(s)\r\n#\r\n# This parameter is mutually exclusive with 'cert_file'\r\n#\r\n#cert_files = [\"/etc/pki/libvirt/servercert-0.pem\", \"/etc/pki/libvirt/servercert-1.pem\"]\r\n\r\n# Override the default CA certificate path\r\n#\r\n#ca_file = \"/etc/pki/CA/cacert.pem\"\r\n\r\n# Specify a certificate revocation list.\r\n#\r\n# Defaults to not using a CRL, uncomment to enable it\r\n#crl_file = \"/etc/pki/CA/crl.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H235,2\u001b[9C44%\u001b[?25h\u001b[6;2H"]
[0.061, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H238,2\u001b[9C45%\u001b[?25h\u001b[6;2H"]
[0.034, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[6M\u001b[1;44r\u001b[38;1H\u001b[96m#\r\n# Authorization controls\r\n#\r\n\r\n\r\n# Flag to disable verification of our own server certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H244,21\u001b[8C46%\u001b[?25h\u001b[6;21H"]
[1.273, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H244,21\u001b[8C46%\u001b[?25h\u001b[9;21H"]
[0.907, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# Flag to disable verification of our own server certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H244,21\u001b[8C46%\u001b[?25h\u001b[6;21H"]
[0.042, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[6M\u001b[1;44r\u001b[38;1H\u001b[96m#\r\n# When libvirtd starts it performs some sanity checks against\r\n# its own certificates.\r\n#\r\n# Default is to always run sanity checks. Uncommenting this\r\n# will disable sanity checks which is not a good idea\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H250,21\u001b[8C47%\u001b[?25h\u001b[6;21H"]
[0.028, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[6M\u001b[1;44r\u001b[38;1H\u001b[96m#tls_no_sanity_certificate = 1\r\n\r\n# Flag to disable verification of client certificates\r\n#\r\n# Client certificate verification is the primary authentication mechanism.\r\n# Any client which does not present a certificate signed by the CA\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H256,21\u001b[8C49%\u001b[?25h\u001b[6;21H"]
[0.027, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18M\u001b[1;44r\u001b[26;1H\u001b[96m# will be rejected.\r\n#\r\n# Default is to always verify. Uncommenting this will disable\r\n# verification.\r\n#tls_no_verify_certificate = 1\r\n\r\n\r\n# An access control list of allowed x509 Distinguished Names\r\n# This list may contain wildcards such as\r\n#\r\n#    \"C=GB,ST=London,L=London,O=Red Hat,CN=*\"\r\n#\r\n# Any * matches any number of consecutive spaces, like a simplified glob(7).\r\n#\r\n# The format of the DN for a particular certificate can be queried\r\n# using:\r\n#\r\n#    virt-pki-query-dn clientcert.pem\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H274,1\u001b[9C52%\u001b[?25h\u001b[6;1H"]
[0.023, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[24M\u001b[1;44r\u001b[20;1H\u001b[96m#\r\n# NB If this is an empty list, no client can connect, so comment out\r\n# entirely rather than using empty list to disable these checks\r\n#\r\n# By default, no DN's are checked\r\n#tls_allowed_dn_list = [\"DN1\", \"DN2\"]\r\n\r\n\r\n# Override the compile time default TLS priority string. The\r\n# default is usually \"NORMAL\" unless overridden at build time.\r\n# Only set this is it is desired for libvirt to deviate from\r\n# the global default settings.\r\n#\r\n#tls_priority=\"NORMAL\"\r\n\r\n\r\n# An access control list of allowed SASL usernames. The format for username\r\n# depends on the SASL authentication mechanism. Kerberos usernames\r\n# look like username@REALM\r\n#\r\n# This list may contain wildcards such as\r\n#\r\n#    \"*@EXAMPLE.COM\"\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H298,21\u001b[8C57%\u001b[?25h\u001b[6;21H"]
[0.045, "o", "\u001b[?25l\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[1;1H\u001b[96m#\u001b[m\u001b[1;2H\u001b[K\u001b[2;1H\u001b[96m# See the g_pattern_match function for the format of the wildcards.\u001b[m\u001b[2;68H\u001b[K\u001b[3;1H\u001b[96m#\u001b[m\u001b[3;2H\u001b[K\u001b[4;1H\u001b[96m# https://developer.gnome.org/glib/stable/glib-Glob-style-pattern-matching.html\u001b[m\u001b[4;80H\u001b[K\u001b[5;1H\u001b[96m#\u001b[m\u001b[5;2H\u001b[K\u001b[6;1H\u001b[96m# NB If this is an empty list, no client can connect, so comment out\u001b[m\u001b[6;69H\u001b[K\u001b[7;1H\u001b[96m# entirely rather than using empty list to disable these checks\u001b[m\u001b[7;64H\u001b[K\u001b[8;1H\u001b[96m#\u001b[m\u001b[8;2H\u001b[K\u001b[9;1H\u001b[96m# By default, no Username's are checked\u001b[m\u001b[9;40H\u001b[K\u001b[10;1H\u001b[96m#sasl_allowed_username_list = [\"joe@EXAMPLE.COM\", \"fred@EXAMPLE.COM\" ]\u001b[m\u001b[10;71H\u001b[K\u001b[11;1H\u001b[K\u001b[12;1H\u001b[K\u001b[13;1H\u001b[96m#################################################################\u001b[m\u001b[13;66H\u001b[K\u001b[14;1H\u001b[96m#\u001b[m\u001b[14;2H\u001b[K\u001b[15;1H\u001b[96m# Processing controls\u001b[m\u001b[15;22H\u001b[K\u001b[16;1H\u001b[96m#\u001b[m\u001b[16;2H\u001b[K\u001b[17;1H\u001b[K\u001b[18;1H\u001b[96m# The maximum number of concurrent client connections to allow\u001b[m\u001b[18;63H\u001b[K\u001b[19;1H\u001b[96m# over all sockets combined.\u001b[m\u001b[19;29H\u001b[K\u001b[20;1H\u001b[96m#max_clients = 5000\u001b[m\u001b[20;20H\u001b[K\u001b[21;1H\u001b[K\u001b[22;1H\u001b[96m# The maximum length of queue of connections waiting to be\u001b[m\u001b[22;59H\u001b[K\u001b[23;1H\u001b[96m# accepted by the daemon. Note, that some protocols supporting\u001b[m\u001b[23;63H\u001b[K\u001b[24;1H\u001b[96m# retransmission may obey this so that a later reattempt at\u001b[m\u001b[24;60H\u001b[K\u001b[25;1H\u001b[96m# connection succeeds.\u001b[m\u001b[25;23H\u001b[K\u001b[26;1H\u001b[96m#max_queued_clients = 1000\u001b[m\u001b[26;27H\u001b[K\u001b[27;1H\u001b[K\u001b[28;1H\u001b[96m# The maximum length of queue of accepted but not yet\u001b[m\u001b[28;54H\u001b[K\u001b[29;1H\u001b[96m# authenticated clients. The default value is 20. Set this to\u001b[m\u001b[29;62H\u001b[K\u001b[30;1H\u001b[96m# zero to turn this feature off.\u001b[m\u001b[30;33H\u001b[K\u001b[31;1H\u001b[96m#max_anonymous_clients = 20\u001b[m\u001b[31;28H\u001b[K\u001b[32;1H\u001b[K\u001b[33;1H\u001b[96m# The minimum limit sets the number of workers to start up\u001b[m\u001b[33;59H\u001b[K\u001b[34;1H\u001b[96m# initially. If the number of active clients exceeds this,\u001b[m\u001b[34;59H\u001b[K\u001b[35;1H\u001b[96m# then more threads are spawned, up to max_workers limit.\u001b[m\u001b[35;58H\u001b[K\u001b[36;1H\u001b[96m# Typically you'd want max_workers to equal maximum number\u001b[m\u001b[36;59H\u001b[K\u001b[37;1H\u001b[96m# of clients allowed\u001b[m\u001b[37;21H\u001b[K\u001b[38;1H\u001b[96m#min_workers = 5\u001b[m\u001b[38;17H\u001b[K\u001b[39;1H\u001b[96m#max_workers = 20\u001b[m\u001b[39;18H\u001b[K\u001b[40;1H\u001b[K\u001b[41;1H\u001b[K\u001b[42;1H\u001b[96m# The number of priority workers. If all workers from above\u001b[m\u001b[42;60H\u001b[K\u001b[43;1H\u001b[96m# pool are stuck, some calls marked as high priority\u001b[m\u001b[43;53H\u001b[K\u001b[44;1H\u001b[1m-- INSERT --\u001b[m\u001b[44;13H\u001b[K\u001b[44;152H340,21\u001b[8C65%\u001b[?25h\u001b[6;21H"]
[0.000, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[9M\u001b[1;44r\u001b[35;1H\u001b[96m# (notably domainDestroy) can be executed in this pool.\r\n#prio_workers = 5\r\n\r\n# Limit on concurrent requests from a single client\r\n# connection. To avoid one client monopolizing the server\r\n# this should be a small fraction of the global max_workers\r\n# parameter.\r\n# Setting this too low may cause keepalive timeouts.\r\n#max_client_requests = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H349,21\u001b[8C67%\u001b[?25h\u001b[6;21H"]
[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[9M\u001b[1;44r\u001b[36;1H\u001b[96m# Same processing controls, but this time for the admin interface.\r\n# For description of each option, be so kind to scroll few lines\r\n# upwards.\r\n\r\n#admin_min_workers = 1\r\n#admin_max_workers = 5\r\n#admin_max_clients = 5\r\n#admin_max_queued_clients = 5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H358,21\u001b[8C69%\u001b[?25h\u001b[6;21H"]
[0.123, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#admin_max_client_requests = 5\r\n\r\n#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H361,1\u001b[9C69%\u001b[?25h\u001b[6;1H"]
[0.250, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[9M\u001b[1;44r\u001b[35;1H\u001b[96m#\r\n# Logging controls\r\n#\r\n\r\n# Logging level: 4 errors, 3 warnings, 2 information, 1 debug\r\n# basically 1 will log everything possible\r\n#\r\n# WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H370,21\u001b[8C71%\u001b[?25h\u001b[6;21H"]
[0.026, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18M\u001b[1;44r\u001b[26;1H\u001b[96m# WARNING: It outputs too much information to practically read.\r\n# WARNING: The \"log_filters\" setting is recommended instead.\r\n#\r\n# WARNING: Journald applies rate limiting of messages and so libvirt\r\n# WARNING: will limit \"log_level\" to only allow values 3 or 4 if\r\n# WARNING: journald is the current output.\r\n#\r\n# WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\r\n#log_level = 3\r\n\r\n# Logging filters:\r\n# A filter allows to select a different logging level for a given category\r\n# of logs. The format for a filter is:\r\n#\r\n#    level:match\r\n#\r\n# where 'match' is a string which is matched against the category\r\n# given in the VIR_LOG_INIT() at the top of each libvirt source\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H388,21\u001b[8C75%\u001b[?25h\u001b[6;21H"]
[0.021, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[15M\u001b[1;44r\u001b[29;1H\u001b[96m# file, e.g., \"remote\", \"qemu\", or \"util.json\". The 'match' in the\r\n# filter matches using shell wildcard syntax (see 'man glob(7)').\r\n# The 'match' is always treated as a substring match. IOW a match\r\n# string 'foo' is equivalent to '*foo*'.\r\n#\r\n# 'level' is the minimal level where matching messages should\r\n#  be logged:\r\n#\r\n#    1: DEBUG\r\n#    2: INFO\r\n#    3: WARNING\r\n#    4: ERROR\r\n#\r\n# Multiple filters can be defined in a single @log_filters, they just need\r\n# to be separated by spaces. Note that libvirt performs \"first\" match, i.e.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H403,21\u001b[8C77%\u001b[?25h\u001b[6;21H"]
[0.018, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[30M\u001b[1;44r\u001b[14;1H\u001b[96m# if there are concurrent filters, the first one that matches will be applied,\r\n# given the order in @log_filters.\r\n#\r\n# A typical need is to capture information from a hypervisor driver,\r\n# public API entrypoints and some of the utility code. Some utility\r\n# code is very verbose and is generally not desired. Taking the QEMU\r\n# hypervisor as an example, a suitable filter string for debugging\r\n# might be to turn off object, json & event logging, but enable the\r\n# rest of the util code:\r\n#\r\n#log_filters=\"1:qemu 1:libvirt 4:object 4:json 4:event 1:util\"\r\n\r\n# Logging outputs:\r\n# An output is one of the places to save logging information\r\n# The format for an output can be:\r\n#    level:stderr\r\n#      output goes to stderr\r\n#    level:syslog:name\r\n#      use syslog for the output and use the given name as the ident\r\n#    level:file:file_path\r\n#      output to a file, with the given filepath\r\n#    level:journald\r\n#      output to journald logging system\r\n# In all cases 'level' is the minimal priority, acting as a filter\r\n#    1: DEBUG\r\n#    2: INFO\r\n#    3: WARNING\r\n#    4: ERROR\r\n#\r\n# Multiple outputs can be defined, they just need to be separated by spaces.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H433,2\u001b[9C83%\u001b[?25h\u001b[6;2H"]
[0.034, "o", "\u001b[?25l\u001b[1;3H\u001b[96mHost UUID is read from one of the sources specified in host_uuid_source.\u001b[m\u001b[2;2H\u001b[K\u001b[3;2H\u001b[96m - 'smbios': fetch the UUID from 'dmidecode -s system-uuid'\r\n# - 'machine-id': fetch the UUID from /etc/machine-id\u001b[m\u001b[4;54H\u001b[K\u001b[5;2H\u001b[K\u001b[6;2H\u001b[96m The host_uuid_source default is 'smbios'. If 'dmidecode' does not provide\r\n# a valid UUID a temporary UUID will be generated.\u001b[m\u001b[8;2H\u001b[K\u001b[9;3H\u001b[96mAnother option is to specify host UUID in host_uuid.\u001b[m\u001b[10;2H\u001b[K\u001b[11;2H\u001b[96m Keep the format of the example UUID below. UUID must not have all digits\r\n# be the same.\u001b[m\u001b[12;15H\u001b[K\u001b[13;1H\u001b[K\u001b[14;3H\u001b[96mNB This default all-zeros UUID will not work. Replace\u001b[m\u001b[14;56H\u001b[K\u001b[15;3H\u001b[96mit with the output of the 'uuidgen' command and then\r\n# uncomment this entry\r\n#host_uuid = \"00000000-0000-0000-0000-000000000000\"\u001b[m\u001b[17;52H\u001b[K\u001b[18;2H\u001b[96mhost_uuid_source = \"smbios\"\u001b[m\u001b[18;29H\u001b[K\u001b[19;1H\u001b[K\u001b[20;2H\u001b[96m##################################################################\r\n# Keepalive protocol:\u001b[m\u001b[21;22H\u001b[K\u001b[22;3H\u001b[96mThis allows libvirtd to detect broken client connections or even\r\n# dead clients.  A keepalive message is sent to a client after\r\n# keepalive_interval seconds of inactivity to check if the client is\r\n# still responding; keepalive_count is a maximum number of keepalive\r\n# messages that are allowed to be sent to the client without getting\r\n# any response before the connection is considered broken.  In other\r\n# words, the connection is automatically closed approximately after\r\n# keepalive_interval * (keepalive_count + 1) seconds since the last\r\n# message received from the client.  If keepalive_interval is set to\r\n# -1, libvirtd will never send keepalive requests; however clients\r\n# can still send them and the daemon will send responses.  When\u001b[m\u001b[32;64H\u001b[K\u001b[33;3H\u001b[96mkeepalive_count is set to 0, connections will be automatically\r\n# closed after keepalive_interval seconds of inactivity without\r\n# sending any keepalive messages.\u001b[m\u001b[36;2H\u001b[K\u001b[37;2H\u001b[96mkeepalive_interval = 5\u001b[m\u001b[37;24H\u001b[K\u001b[38;2H\u001b[96mkeepalive_count = 5\u001b[m\u001b[39;1H\u001b[K\u001b[40;2H\u001b[K\u001b[41;3H\u001b[96mThese configuration options are no longer used.  There is no way to\r\n# restrict such clients from connecting since they first need to\r\n# connect in order to ask for keepalive.\u001b[m\u001b[43;41H\u001b[K\u001b[44;152H\u001b[K\u001b[44;152H499,21\u001b[8C96%\u001b[?25h\u001b[6;21H"]
[0.023, "o", "\u001b[?25l\u001b[1;2H\u001b[K\u001b[2;2H\u001b[96movs_timeout = 5\u001b[m\r\n\u001b[94m~                                                                                                                                                                        \u001b[4;1H~                                                                                                                                                                        \u001b[5;1H~                                                                                                                                                                        \u001b[6;1H~                                                                                                                                                                        \u001b[7;1H~                                                                                                                                                                        \u001b[8;1H~                                                                                                                                                                        \u001b[9;1H~                                                                                                                                                                        \u001b[10;1H~                                                                                                                                                                        \u001b[11;1H~                                                                                                                                                                        \u001b[12;1H~                                                                                                                                                                        \u001b[13;1H~                                                                                                                                                                        \u001b[14;1H~                                                                                                                                                                        \u001b[15;1H~                                                                                                                                                                        \u001b[16;1H~                                                                                                                                                                        \u001b[17;1H~                                                                                                                                                                        \u001b[18;1H~                                                                                                                                                                        \u001b[19;1H~                                                                                                                                                                        \u001b[20;1H~                                                                                                                                                                        \u001b[21;1H~                                                                                                                                                                        \u001b[22;1H~                                                                                                                                                                        \u001b[23;1H~                                                                                                                                                                        \u001b[24;1H~                                                                                                                                                                        \u001b[25;1H~                                                                                                                                                                        \u001b[26;1H~ "]
[0.000, "o", "                                                                                                                                                                       \u001b[27;1H~                                                                                                                                                                        \u001b[28;1H~                                                                                                                                                                        \u001b[29;1H~                                                                                                                                                                        \u001b[30;1H~                                                                                                                                                                        \u001b[31;1H~                                                                                                                                                                        \u001b[32;1H~                                                                                                                                                                        \u001b[33;1H~                                                                                                                                                                        \u001b[34;1H~                                                                                                                                                                        \u001b[35;1H~                                                                                                                                                                        \u001b[36;1H~                                                                                                                                                                        \u001b[37;1H~                                                                                                                                                                        \u001b[38;1H~                                                                                                                                                                        \u001b[39;1H~                                                                                                                                                                        \u001b[40;1H~                                                                                                                                                                        \u001b[41;1H~                                                                                                                                                                        \u001b[42;1H~                                                                                                                                                                        \u001b[43;1H~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,17\u001b[8CBot\u001b[?25h\u001b[2;17H"]
[0.024, "o", "\u001b[?25l\u001b[1;43r\u001b[43;1H\r\n\u001b[1;44r\u001b[43;1H\u001b[94m~                                                                                                                                                                        \u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,17\u001b[8CBot\u001b[?25h\u001b[1;17H"]
[0.235, "o", "\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;152H552,17\u001b[8CBot\u001b[?25h\u001b[1;17H"]
[0.319, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[12L\u001b[1;44r\u001b[2;1H\u001b[96m# Keepalive settings for the admin interface\r\n#admin_keepalive_interval = 5\r\n#admin_keepalive_count = 5\r\n\r\n###################################################################\r\n# Open vSwitch:\r\n# This allows to specify a timeout for openvswitch calls made by\r\n# libvirt. The ovs-vsctl utility is used for the configuration and\r\n# its timeout option is set by default to 5 seconds to avoid\r\n# potential infinite waits blocking libvirt.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H552,17\u001b[8CBot\u001b[?25h\u001b[13;17H"]
[0.025, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[36L\u001b[1;44r\u001b[1;1H\u001b[96m# Keep the format of the example UUID below. UUID must not have all digits\r\n# be the same.\r\n\r\n# NB This default all-zeros UUID will not work. Replace\r\n# it with the output of the 'uuidgen' command and then\r\n# uncomment this entry\r\n#host_uuid = \"00000000-0000-0000-0000-000000000000\"\r\n#host_uuid_source = \"smbios\"\r\n\r\n###################################################################\r\n# Keepalive protocol:\r\n# This allows libvirtd to detect broken client connections or even\r\n# dead clients.  A keepalive message is sent to a client after\r\n# keepalive_interval seconds of inactivity to check if the client is\r\n# still responding; keepalive_count is a maximum number of keepalive\r\n# messages that are allowed to be sent to the client without getting\r\n# any response before the connection is considered broken.  In other\r\n# words, the connection is automatically closed approximately after\r\n# keepalive_interval * (keepalive_count + 1) seconds since the last\r\n# message received from the client.  If keepalive_interval is set to\r\n# -1, libvirtd will never send keepalive requests; however clients\r\n# can still send them and the daemon will send responses.  When\r\n# keepalive_count is set to 0, connections will be automatically\r\n# closed after keepalive_interval seconds of inactivity without\r\n# sending any keepalive messages.\r\n#\r\n#keepalive_interval = 5\r\n#keepalive_count = 5\r\n\r\n#\r\n# These configuration options are no longer used.  There is no way to\r\n# restrict such clients from connecting since they first need to\r\n# connect in order to ask for keepalive.\r\n#\r\n#keepalive_required = 1\r\n#admin_keepalive_required = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H541,21\u001b[8C98%\u001b[?25h\u001b[38;21H4\b\u001b[?25l\u001b[44;142H^[\u001b[38;21H\u001b[44;144H[\u001b[38;21H\u001b[44;145H<\u001b[38;21H\u001b[44;146H6\u001b[38;21H\u001b[44;147H4\u001b[38;21H"]
[0.001, "o", "\u001b[44;142H      \u001b[38;21H\u001b[96m \b\u001b[1;43r\u001b[m\u001b[1;1H\u001b[24L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#   audit_level == 0  -> disable all auditing\r\n#   audit_level == 1  -> enable auditing, only if enabled on host (default)\r\n#   audit_level == 2  -> enable auditing, and exit if disabled on host\r\n#\r\n#audit_level = 2\r\n#\r\n# If set to 1, then audit messages will also be sent\r\n# via libvirt logging infrastructure. Defaults to 0\r\n#\r\n#audit_logging = 1\r\n\r\n###################################################################\r\n# UUID of the host:\r\n# Host UUID is read from one of the sources specified in host_uuid_source.\r\n#\r\n# - 'smbios': fetch the UUID from 'dmidecode -s system-uuid'\r\n# - 'machine-id': fetch the UUID from /etc/machine-id\r\n#\r\n# The host_uuid_source default is 'smbios'. If 'dmidecode' does not provide\r\n# a valid UUID a temporary UUID will be generated.\r\n#\r\n# Another option is to specify host UUID in host_uuid.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H517,21\u001b[8C94%\u001b[?25h\u001b[38;21H;\b\u001b[?25l\u001b[44;142H^[\u001b[38;21H\u001b[44;144H[\u001b[38;21H\u001b[44;145H<\u001b[38;21H\u001b[44;146H6\u001b[38;21H\u001b[44;147H4\u001b[38;21H\u001b[44;148H;\u001b[38;21H\u001b[44;149H1\u001b[38;21H\u001b[44;150H5\u001b[38;21H\u001b[44;151H;\u001b[38;21H"]
[0.001, "o", "\u001b[44;142H          \u001b[38;21H\u001b[96m \b\u001b[1;43r\u001b[m\u001b[1;1H\u001b[9L\u001b[1;44r\u001b[1;1H\u001b[96m# e.g. to log all warnings and errors to syslog under the libvirtd ident:\r\n#log_outputs=\"3:syslog:libvirtd\"\r\n\r\n\r\n##################################################################\r\n#\r\n# Auditing\r\n#\r\n# This setting allows usage of the auditing subsystem to be altered:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H508,21\u001b[8C92%\u001b[?25h\u001b[38;21H"]
[0.021, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[12L\u001b[1;44r\u001b[1;1H\u001b[96m#      use syslog for the output and use the given name as the ident\r\n#    level:file:file_path\r\n#      output to a file, with the given filepath\r\n#    level:journald\r\n#      output to journald logging system\r\n# In all cases 'level' is the minimal priority, acting as a filter\r\n#    1: DEBUG\r\n#    2: INFO\r\n#    3: WARNING\r\n#    4: ERROR\r\n#\r\n# Multiple outputs can be defined, they just need to be separated by spaces.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H496,21\u001b[8C89%\u001b[?25h\u001b[38;21H;\b\u001b[?25l\u001b[44;142H^[\u001b[38;21H\u001b[44;144H[\u001b[38;21H\u001b[44;145H<\u001b[38;21H\u001b[44;146H6\u001b[38;21H\u001b[44;147H4\u001b[38;21H\u001b[44;148H;\u001b[38;21H\u001b[44;149H1\u001b[38;21H\u001b[44;150H5\u001b[38;21H\u001b[44;151H;\u001b[38;21H"]
[0.003, "o", "\u001b[44;142H          \u001b[38;21H\u001b[96mt\b\u001b[m\u001b[1;1H\u001b[K\u001b[2;3H\u001b[96mLogging level: 4 errors, 3 warnings, 2 information, 1 debug\r\n# basically 1 will log everything possible\u001b[m\u001b[3;43H\u001b[K\u001b[4;2H\u001b[K\u001b[5;3H\u001b[96mWARNING: USE OF THIS IS STRONGLY DISCOURAGED.\u001b[m\u001b[6;2H\u001b[K\u001b[7;3H\u001b[96mWARNING: It outputs too much information to practically read.\r\n# WARNING: The \"log_filters\" setting is recommended instead.\u001b[m\u001b[9;2H\u001b[K\u001b[10;3H\u001b[96mWARNING: Journald applies rate limiting of messages and so libvirt\r\n# WARNING: will limit \"log_level\" to only allow values 3 or 4 if\r\n# WARNING: journald is the current output.\u001b[m\u001b[12;43H\u001b[K\u001b[13;2H\u001b[K\u001b[14;2H\u001b[96m WARNING: USE OF THIS IS STRONGLY DISCOURAGED.\r\n#log_level = 3\r\n\r\n# Logging filters:\u001b[m\u001b[17;19H\u001b[K\u001b[18;2H\u001b[96m A filter allows to select a different logging level for a given category\r\n# of logs. The format for a filter is:\r\n\r\n#    level:match\u001b[m\u001b[21;17H\u001b[K\u001b[23;3H\u001b[96mwhere 'match' is a string which is matched against the category\r\n# given in the VIR_LOG_INIT() at the top of each libvirt source\u001b[m\u001b[24;64H\u001b[K\u001b[25;3H\u001b[96mfile, e.g., \"remote\", \"qemu\", or \"util.json\". The 'match' in the\u001b[m\u001b[25;67H\u001b[K\u001b[26;2H\u001b[96m filter matches using shell wildcard syntax (see 'man glob(7)').\r\n# The 'match' is always treated as a substring match. IOW a match\r\n# string 'foo' is equivalent to '*foo*'.\u001b[m\u001b[29;2H\u001b[K\u001b[30;3H\u001b[96m'level' is the minimal level where matching messages should\r\n#  be logged:\u001b[m\u001b[32;2H\u001b[K\u001b[33;1H\u001b[96m#    1: DEBUG\r\n#    2: INFO\u001b[m\u001b[34;13H\u001b[K\u001b[35;3H\u001b[96m   3: WARNING\u001b[m\u001b[35;16H\u001b[K\u001b[36;3H\u001b[96m   4: ERROR\u001b[m\u001b[36;14H\u001b[K\u001b[38;3H\u001b[96mMultiple filters can be defined in a single @log_filters, they just need\r\n# to be separated by spaces. Note that libvirt performs \"first\" match, i.e.\r\n# if there are concurrent filters, the first one that matches will be applied,\r\n# given the order in @log_filters.\u001b[m\u001b[41;35H\u001b[K\u001b[42;2H\u001b[K\u001b[43;2H\u001b[96m A typical need is to capture information from a hypervisor driver,\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H439,21\u001b[8C78%\u001b[?25h\u001b[38;21H"]
[0.014, "o", "\u001b[?25l\u001b[2;3H\u001b[96mThe maximum number of concurrent client connections to allow\r\n# over all sockets combined.\u001b[m\u001b[3;29H\u001b[K\u001b[4;2H\u001b[96mmax_clients = 5000\u001b[m\u001b[5;1H\u001b[K\u001b[6;2H\u001b[96m The maximum length of queue of connections waiting to be\r\n# accepted by the daemon. Note, that some protocols supporting\u001b[m\u001b[7;63H\u001b[K\u001b[8;3H\u001b[96mretransmission may obey this so that a later reattempt at\u001b[m\u001b[8;60H\u001b[K\u001b[9;2H\u001b[96m connection succeeds.\r\n#max_queued_clients = 1000\u001b[m\u001b[10;27H\u001b[K\u001b[11;1H\u001b[K\u001b[12;3H\u001b[96mThe maximum length of queue of accepted but not yet\r\n# authenticated clients. The default value is 20. Set this to\r\n# zero to turn this feature off.\u001b[m\u001b[14;33H\u001b[K\u001b[15;2H\u001b[96mmax_anonymous_clients = 20\r\n\r\n# The minimum limit sets the number of workers to start up\r\n# initially. If the number of active clients exceeds this,\u001b[m\u001b[18;59H\u001b[K\u001b[19;3H\u001b[96mthen more threads are spawned, up to max_workers limit.\r\n# Typically you'd want max_workers to equal maximum number\r\n# of clients allowed\r\n#min_workers = 5\r\n#max_workers = 20\u001b[m\u001b[23;18H\u001b[K\u001b[24;1H\u001b[K\u001b[25;1H\u001b[K\u001b[26;3H\u001b[96mThe number of priority workers. If all workers from above\u001b[m\u001b[26;60H\u001b[K\u001b[27;3H\u001b[96mpool are stuck, some calls marked as high priority\u001b[m\u001b[27;53H\u001b[K\u001b[28;3H\u001b[96m(notably domainDestroy) can be executed in this pool.\r\n#prio_workers = 5\u001b[m\u001b[30;1H\u001b[K\u001b[31;3H\u001b[96mLimit on concurrent requests from a single client\r\n# connection. To avoid one client monopolizing the server\r\n# this should be a small fraction of the global max_workers\r\n# parameter.\r\n# Setting this too low may cause keepalive timeouts.\r\n#max_client_requests = 5\u001b[m\u001b[37;1H\u001b[K\u001b[38;3H\u001b[96mSame processing controls, but this time for the admin interface.\u001b[m\u001b[38;67H\u001b[K\u001b[39;3H\u001b[96mFor description of each option, be so kind to scroll few lines\u001b[m\u001b[39;65H\u001b[K\u001b[40;3H\u001b[96mupwards.\u001b[m\u001b[40;11H\u001b[K\u001b[41;1H\u001b[K\u001b[42;2H\u001b[96madmin_min_workers = 1\r\n#admin_max_workers = 5\u001b[m\u001b[43;23H\u001b[K\u001b[44;152H\u001b[K\u001b[44;152H388,21\u001b[8C68%\u001b[?25h\u001b[38;21H"]
[0.018, "o", "\u001b[?25l\u001b[1;1H\u001b[96m# using:\u001b[m\u001b[2;2H\u001b[K\u001b[3;3H\u001b[96m   virt-pki-query-dn clientcert.pem\u001b[m\u001b[4;2H\u001b[K\u001b[5;1H\u001b[96m# NB If this is an empty list, no client can connect, so comment out\r\n# entirely rather than using empty list to disable these checks\u001b[m\u001b[7;2H\u001b[K\u001b[8;3H\u001b[96mBy default, no DN's are checked\u001b[m\u001b[8;34H\u001b[K\u001b[9;2H\u001b[96mtls_allowed_dn_list = [\"DN1\", \"DN2\"]\u001b[m\u001b[10;1H\u001b[K\u001b[12;3H\u001b[96mOverride the compile time default TLS priority string. The\r\n# default is usually \"NORMAL\" unless overridden at build time.\r\n# Only set this is it is desired for libvirt to deviate from\r\n# the global default settings.\r\n#\r\n#tls_priority=\"NORMAL\"\u001b[m\u001b[17;23H\u001b[K\u001b[18;1H\u001b[K\u001b[19;1H\u001b[K\u001b[20;3H\u001b[96mAn access control list of allowed SASL usernames. The format for username\r\n# depends on the SASL authentication mechanism. Kerberos usernames\r\n# look like username@REALM\u001b[m\u001b[23;2H\u001b[K\u001b[24;1H\u001b[96m# This list may contain wildcards such as\r\n#\r\n#    \"*@EXAMPLE.COM\"\u001b[m\u001b[26;21H\u001b[K\u001b[27;2H\u001b[K\u001b[28;3H\u001b[96mSee the g_pattern_match function for the format of the wildcards.\u001b[m\u001b[29;2H\u001b[K\u001b[30;1H\u001b[96m# https://developer.gnome.org/glib/stable/glib-Glob-style-pattern-matching.html\u001b[m\u001b[31;2H\u001b[K\u001b[32;3H\u001b[96mNB If this is an empty list, no client can connect, so comment out\r\n# entirely rather than using empty list to disable these checks\u001b[m\u001b[34;2H\u001b[K\u001b[35;3H\u001b[96mBy default, no Username's are checked\u001b[m\u001b[35;40H\u001b[K\u001b[36;2H\u001b[96msasl_allowed_username_list = [\"joe@EXAMPLE.COM\", \"fred@EXAMPLE.COM\" ]\u001b[m\u001b[38;1H\u001b[K\u001b[39;2H\u001b[96m################################################################\u001b[m\u001b[40;2H\u001b[K\u001b[41;1H\u001b[96m# Processing controls\u001b[m\u001b[42;2H\u001b[K\u001b[43;1H\u001b[K\u001b[44;152H\u001b[K\u001b[44;152H346,1\u001b[9C60%\u001b[?25h\u001b[38;1H"]
[0.015, "o", "\u001b[?25l\u001b[1;3H\u001b[96m'cert_file', and 'ca_file' values and uncommenting them below.\r\n\r\n# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\u001b[m\u001b[5;2H\u001b[K\u001b[6;1H\u001b[K\u001b[7;2H\u001b[96m Override the default server key file path\u001b[m\u001b[8;2H\u001b[K\u001b[9;2H\u001b[96m This parameter is mutually exclusive with 'key_files'\r\n#\r\n#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\u001b[m\u001b[12;1H\u001b[K\u001b[13;3H\u001b[96mOverride the default server key file path(s)\u001b[m\u001b[13;47H\u001b[K\u001b[14;2H\u001b[K\u001b[15;3H\u001b[96mThis parameter is mutually exclusive with 'key_file'\r\n\r\n#key_files = [\"/etc/pki/libvirt/private/serverkey-0.pem\", \"/etc/pki/libvirt/private/serverkey-1.pem\"]\r\n\r\n# Override the default server certificate file path\u001b[m\u001b[20;2H\u001b[K\u001b[21;3H\u001b[96mThis parameter is mutually exclusive with 'cert_files'\u001b[m\u001b[21;57H\u001b[K\u001b[22;2H\u001b[K\u001b[23;2H\u001b[96mcert_file = \"/etc/pki/libvirt/servercert.pem\"\u001b[m\u001b[24;1H\u001b[K\u001b[25;2H\u001b[96m Override the default server certificate file path(s)\u001b[m\u001b[26;2H\u001b[K\u001b[27;2H\u001b[96m This parameter is mutually exclusive with 'cert_file'\u001b[m\u001b[28;2H\u001b[K\u001b[29;2H\u001b[96mcert_files = [\"/etc/pki/libvirt/servercert-0.pem\", \"/etc/pki/libvirt/servercert-1.pem\"]\u001b[m\u001b[30;1H\u001b[K\u001b[31;2H\u001b[96m Override the default CA certificate path\u001b[m\u001b[32;2H\u001b[K\u001b[33;2H\u001b[96mca_file = \"/etc/pki/CA/cacert.pem\"\u001b[m\u001b[33;36H\u001b[K\u001b[34;1H\u001b[K\u001b[35;3H\u001b[96mSpecify a certificate revocation list.\u001b[m\u001b[36;2H\u001b[K\u001b[37;1H\u001b[96m# Defaults to not using a CRL, uncomment to enable it\r\n#crl_file = \"/etc/pki/CA/crl.pem\"\u001b[m\u001b[39;1H\u001b[K\u001b[40;1H\u001b[K\u001b[41;1H\u001b[K\u001b[42;2H\u001b[96m################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H271,21\u001b[8C45%\u001b[?25h\u001b[38;21H"]
[0.017, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[39L\u001b[1;44r\u001b[1;1H\u001b[96m# TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\r\n#\r\n# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\r\n#auth_tls = \"none\"\r\n\r\n# Enforce a minimum SSF value for TCP sockets\r\n#\r\n# The default minimum is currently 56 (single-DES) which will\r\n# be raised to 112 in the future.\r\n#\r\n# This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\r\n\r\n\r\n# Change the API access control scheme\r\n#\r\n# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\r\n# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\r\n#\r\n#access_drivers = [ \"polkit\" ]\r\n\r\n#################################################################\r\n#\r\n# TLS x509 certificate configuration\r\n#\r\n\r\n# Use of TLS requires that x509 certificates be issued. The default locations\r\n# for the certificate files is as follows:\r\n#\r\n#   /etc/pki/CA/cacert.pem - The CA master certificate\r\n#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\r\n#\r\n# It is possible to override the default locations by altering the 'key_file',\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H232,2\u001b[9C38%\u001b[?25h\u001b[38;2H"]
[0.018, "o", "\u001b[?25l\u001b[1;3H\u001b[96m           require a user to supply their own password to gain\r\n#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\u001b[m\u001b[4;2H\u001b[K\u001b[5;1H\u001b[K\u001b[6;2H\u001b[96m Set an authentication scheme for UNIX read-only sockets\r\n#\r\n# By default socket permissions allow anyone to connect\r\n\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[10;61H\u001b[K\u001b[11;3H\u001b[96mno access control checks are done, but libvirt still only\r\n# allows execution of APIs which don't change state.\u001b[m\u001b[13;2H\u001b[K\u001b[14;2H\u001b[96m If libvirt was compiled with support for 'polkit', then\r\n# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still allows any local\r\n# user access.\u001b[m\u001b[17;15H\u001b[K\u001b[19;3H\u001b[96mTo restrict monitoring of domains you may wish to either\r\n# enable 'sasl' here, or change the polkit policy definition.\r\n#auth_unix_ro = \"polkit\"\u001b[m\u001b[21;25H\u001b[K\u001b[22;1H\u001b[K\u001b[23;3H\u001b[96mSet an authentication scheme for UNIX read-write sockets.\r\n\r\n# If libvirt was compiled without support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0600 by default\r\n# thus only allowing root user to connect, and 'auth_unix_rw'\u001b[m\u001b[27;62H\u001b[K\u001b[28;2H\u001b[96m will default to 'none'.\u001b[m\u001b[29;2H\u001b[K\u001b[30;2H\u001b[96m If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\r\n# allows any user to connect and 'auth_unix_rw' will default\u001b[m\u001b[32;61H\u001b[K\u001b[33;3H\u001b[96mto 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\r\n# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[35;52H\u001b[K\u001b[36;2H\u001b[K\u001b[37;2H\u001b[96mauth_unix_rw = \"polkit\"\u001b[m\u001b[37;25H\u001b[K\u001b[38;1H\u001b[K\u001b[39;3H\u001b[96mChange the authentication scheme for TCP sockets.\u001b[m\u001b[39;52H\u001b[K\u001b[40;2H\u001b[K\u001b[41;2H\u001b[96m If you don't enable SASL, then all TCP traffic is cleartext.\r\n# Don't do this outside of a dev/test scenario. For real world\u001b[m\u001b[42;63H\u001b[K\u001b[43;3H\u001b[96muse, always enable SASL and use the GSSAPI or DIGEST-MD5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H184,1\u001b[9C28%\u001b[?25h\u001b[38;1H"]
[0.014, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# Authentication.\r\n#\r\n# There are the following choices available:\r\n#\r\n#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\r\n#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\r\n#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\r\n#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\r\n#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H166,21\u001b[8C25%\u001b[?25h\u001b[38;21H"]
[0.019, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\r\n\r\n# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[18;1H#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H148,21\u001b[8C21%\u001b[?25h\u001b[38;21H"]
[0.051, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[24L\u001b[1;44r\u001b[1;1H\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\r\n\r\n# Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\r\n#\r\n# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H124,21\u001b[8C16%\u001b[?25h\u001b[38;21H"]
[0.024, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18L\u001b[1;44r\u001b[1;1H\u001b[96m#listen_addr = \"192.168.0.1\"\r\n\r\n\r\n#################################################################\r\n#\r\n# UNIX socket access controls\r\n#\r\n\r\n# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# This is restricted to 'root' by default.\u001b[m\r\nunix_sock_group = \u001b[95m\"libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H106,21\u001b[8C13%\u001b[?25h\u001b[38;21H"]
[0.046, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H103,21\u001b[8C12%\u001b[?25h\u001b[38;21H"]
[0.043, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[12L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n#tcp_port = \"16509\"\r\n\r\n\r\n# Override the default configuration which binds to all network\r\n# interfaces. This can be a numeric IPv4/6 address, or hostname\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# If the libvirtd service is started in parallel with network\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H91,14\u001b[9C10%\u001b[?25h\u001b[38;14H"]
[0.025, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[33L\u001b[1;44r\u001b[1;1H\u001b[96m# This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\r\n\r\n# Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Using the TCP socket requires SASL authentication by default. Only\r\n# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\r\n#\r\n# This is disabled by default, uncomment this to enable it.\r\n#listen_tcp = 1\u001b[22;1H# Override the port for accepting secure TLS connections\r\n# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n#tls_port = \"16514\"\r\n\r\n# Override the port for accepting insecure TCP connections\r\n# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H58,1\u001b[11C3%\u001b[?25h\u001b[38;1H"]
[0.026, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[18L\u001b[1;44r\u001b[2;1H\u001b[96m#################################################################\r\n#\r\n# Network connectivity controls\r\n#\r\n\r\n# Flag listening for secure TLS connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H40,1\u001b[11C0%\u001b[?25h\u001b[38;1H"]
[4.308, "o", "\u001b[?25lh\u001b[?25h\u001b[?25l\u001b[44;155H2\u001b[38;2H\u001b[?25h"]
[0.743, "o", "\u001b[?25l\u001b[38;1H\u001b[K\u001b[?25h\u001b[?25l\u001b[44;155H1\u001b[38;1H\u001b[?25h"]
[4.726, "o", "\u001b[?25l:\u001b[?25h\u001b[?25l\u001b[44;155H2\u001b[38;2H\u001b[?25h"]
[0.955, "o", "\u001b[?25l\u001b[38;1H\u001b[K\u001b[?25h\u001b[?25l\u001b[44;155H1\u001b[38;1H\u001b[?25h"]
