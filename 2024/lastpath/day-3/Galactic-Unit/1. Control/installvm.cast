[0.804, "o", "s\u001b[?25l"]
[0.001, "o", "\u001b[22;6H\u001b[7ms\u001b[m\u001b[44;152H85,1\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[44;152H\u001b[K\u001b[44;8H\u001b[?25h"]
[0.181, "o", "o\u001b[?25l"]
