[0.018, "o", "\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h"]
[0.017, "o", "\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h"]
[0.025, "o", "\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h\u001b[?25l\u001b[?25h"]
[1.190, "o", "\u001b[?25l\u001b[44;153H2,1 \u001b[32;1H\u001b[?25h"]
[0.389, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C0%\u001b[?25h\u001b[29;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#tls_port = \"16514\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C1%\u001b[?25h\u001b[26;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Override the port for accepting insecure TCP connections\r\n# This can be a port number, or service name\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C1%\u001b[?25h\u001b[23;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C2%\u001b[?25h\u001b[20;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#tcp_port = \"16509\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C2%\u001b[?25h\u001b[17;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Override the default configuration which binds to all network\r\n# interfaces. This can be a numeric IPv4/6 address, or hostname\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C3%\u001b[?25h\u001b[14;1H"]
[0.007, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C4%\u001b[?25h\u001b[11;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# If the libvirtd service is started in parallel with network\r\n# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H32,1\u001b[11C4%\u001b[?25h\u001b[8;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#listen_addr = \"192.168.0.1\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H33,22\u001b[10C5%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H36,1\u001b[11C5%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# UNIX socket access controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H39,0-1\u001b[9C6%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H42,22\u001b[10C7%\u001b[?25h\u001b[6;22H"]
[0.021, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H45,22\u001b[10C7%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This is restricted to 'root' by default.\r\n#unix_sock_group = \"libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H48,19\u001b[10C8%\u001b[?25h\u001b[6;19H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H51,22\u001b[10C8%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H54,13\u001b[10C9%\u001b[?25h\u001b[6;13H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H57,0-1\u001b[8C10%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#unix_sock_ro_perms = \"0777\"\r\n\r\n# Set the UNIX socket permissions for the R/W socket. This is used\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H60,22\u001b[9C10%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# for full management of VMs\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H63,13\u001b[9C11%\u001b[?25h\u001b[6;13H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# activation.\r\n#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H66,22\u001b[9C11%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the default will change to allow everyone (eg, 0777)\r\n#\r\n# If not using PolicyKit and setting group ownership for access\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H69,22\u001b[9C12%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H72,22\u001b[9C12%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the UNIX socket permissions for the admin interface socket.\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H75,1\u001b[10C13%\u001b[?25h\u001b[6;1H"]
[0.022, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# activation.\r\n#\r\n# Default allows only owner (root), do not change it unless you are\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H78,22\u001b[9C14%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H81,22\u001b[9C14%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set the name of the directory in which sockets will be found/created.\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H84,22\u001b[9C15%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# activation.\r\n#\r\n#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H87,22\u001b[9C15%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[44;152H\u001b[K\u001b[44;152H90,22\u001b[9C16%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# Authentication.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H93,22\u001b[9C17%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# There are the following choices available:\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H96,0-1\u001b[8C17%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\r\n#          restrictions on connecting to the socket (eg, UNIX\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H99,1\u001b[10C18%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H102,1\u001b[9C18%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\r\n#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H105,1\u001b[9C19%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H"]
[0.001, "o", "\u001b[44;142H  \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\r\n#  - polkit: use PolicyKit to authenticate. This is only suitable\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H108,22\u001b[8C20%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\r\n#            full read/write access (aka sudo like), while anyone\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H111,1\u001b[9C20%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#            is allowed read/only access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H114,1\u001b[9C21%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\r\n#\r\n# By default socket permissions allow anyone to connect\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H117,22\u001b[8C21%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# no access control checks are done, but libvirt still only\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H120,1\u001b[9C22%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# allows execution of APIs which don't change state.\r\n#\r\n# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H123,1\u001b[9C22%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still allows any local\r\n# user access.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H126,0-1\u001b[7C23%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# To restrict monitoring of domains you may wish to either\r\n# enable 'sasl' here, or change the polkit policy definition.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H129,1\u001b[9C24%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[44;142H^[\u001b[6;1H\u001b[44;144H[\u001b[6;1H\u001b[44;145H<\u001b[6;1H\u001b[44;146H6\u001b[6;1H\u001b[44;147H5\u001b[6;1H\u001b[44;148H;\u001b[6;1H\u001b[44;149H2\u001b[6;1H\u001b[44;150H2\u001b[6;1H\u001b[44;151H;\u001b[6;1H"]
[0.002, "o", "\u001b[44;142H          \u001b[6;1H\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_unix_ro = \"polkit\"\r\n\r\n# Set an authentication scheme for UNIX read-write sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H132,22\u001b[8C24%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# If libvirt was compiled without support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0600 by default\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H135,22\u001b[8C25%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H138,22\u001b[8C25%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\r\n# allows any user to connect and 'auth_unix_rw' will default\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H141,22\u001b[8C26%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\r\n# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H144,1\u001b[9C27%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#auth_unix_rw = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H147,22\u001b[8C27%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Change the authentication scheme for TCP sockets.\r\n#\r\n# If you don't enable SASL, then all TCP traffic is cleartext.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H150,1\u001b[9C28%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\r\n# mechanism in /etc/sasl2/libvirt.conf\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H153,1\u001b[9C28%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_tcp = \"sasl\"\r\n\r\n# Change the authentication scheme for TLS sockets.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H156,22\u001b[8C29%\u001b[?25h\u001b[6;22H"]
[0.031, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H159,1\u001b[9C30%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H162,22\u001b[8C30%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#auth_tls = \"none\"\r\n\r\n# Enforce a minimum SSF value for TCP sockets\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H165,22\u001b[8C31%\u001b[?25h\u001b[6;22H"]
[0.056, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# The default minimum is currently 56 (single-DES) which will\r\n# be raised to 112 in the future.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H168,0-1\u001b[7C31%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H171,22\u001b[8C32%\u001b[?25h\u001b[6;22H"]
[0.028, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[43;1H\u001b[96m# Change the API access control scheme\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H174,22\u001b[8C33%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H177,22\u001b[8C33%\u001b[?25h\u001b[6;22H"]
[0.033, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H180,22\u001b[8C34%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n#access_drivers = [ \"polkit\" ]\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H183,22\u001b[8C34%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#################################################################\r\n#\r\n# TLS x509 certificate configuration\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H186,1\u001b[9C35%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#\r\n\r\n# Use of TLS requires that x509 certificates be issued. The default locations\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H189,22\u001b[8C35%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# for the certificate files is as follows:\r\n#\r\n#   /etc/pki/CA/cacert.pem - The CA master certificate\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H192,0-1\u001b[7C36%\u001b[?25h\u001b[6;1H"]
[0.034, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H195,22\u001b[8C37%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# It is possible to override the default locations by altering the 'key_file',\r\n# 'cert_file', and 'ca_file' values and uncommenting them below.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H198,22\u001b[8C37%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H201,0-1\u001b[7C38%\u001b[?25h\u001b[6;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server key file path\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H204,22\u001b[8C38%\u001b[?25h\u001b[6;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[41;1H\u001b[96m# This parameter is mutually exclusive with 'key_files'\r\n#\r\n#key_file = \"/etc/pki/libvirt/private/serverkey.pem\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H207,22\u001b[8C39%\u001b[?25h\u001b[6;22H"]
[0.030, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m# Override the default server key file path(s)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C40%\u001b[?25h\u001b[6;1H"]
[0.208, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Enforce a minimum SSF value for TCP sockets\r\n#\r\n# The default minimum is currently 56 (single-DES) which will\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C39%\u001b[?25h\u001b[9;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# mechanism as well, by using 'sasl' for this option\r\n#auth_tls = \"none\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C38%\u001b[?25h\u001b[12;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# layer, and limited authentication is done by certificates\r\n#\r\n# It is possible to make use of any SASL authentication\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C38%\u001b[?25h\u001b[15;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Change the authentication scheme for TLS sockets.\r\n#\r\n# TLS sockets already have encryption provided by the TLS\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C37%\u001b[?25h\u001b[18;1H"]
[0.025, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# mechanism in /etc/sasl2/libvirt.conf\r\n#auth_tcp = \"sasl\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C37%\u001b[?25h\u001b[21;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If you don't enable SASL, then all TCP traffic is cleartext.\r\n# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C36%\u001b[?25h\u001b[24;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Change the authentication scheme for TCP sockets.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C35%\u001b[?25h\u001b[27;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# back to 0600, to avoid an insecure configuration.\r\n#\r\n#auth_unix_rw = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C35%\u001b[?25h\u001b[30;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# allows any user to connect and 'auth_unix_rw' will default\r\n# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C34%\u001b[?25h\u001b[33;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H210,0-1\u001b[7C34%\u001b[?25h\u001b[36;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0600 by default\r\n# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H209,0-1\u001b[7C33%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Set an authentication scheme for UNIX read-write sockets.\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H206,1\u001b[9C33%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# enable 'sasl' here, or change the polkit policy definition.\r\n#auth_unix_ro = \"polkit\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H203,1\u001b[9C32%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# user access.\r\n#\r\n# To restrict monitoring of domains you may wish to either\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H200,18\u001b[8C31%\u001b[?25h\u001b[38;18H"]
[0.002, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\r\n# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still allows any local\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H197,1\u001b[9C31%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# no access control checks are done, but libvirt still only\r\n# allows execution of APIs which don't change state.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H194,1\u001b[9C30%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# By default socket permissions allow anyone to connect\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H191,18\u001b[8C30%\u001b[?25h\u001b[38;18H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H188,22\u001b[8C29%\u001b[?25h\u001b[38;22H"]
[0.036, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H185,22\u001b[8C28%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H182,1\u001b[9C28%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H179,22\u001b[8C27%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H176,22\u001b[8C27%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H173,22\u001b[8C26%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H170,1\u001b[9C25%\u001b[?25h\u001b[38;1H"]
[0.033, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Authentication.\r\n#\r\n# There are the following choices available:\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H167,22\u001b[8C25%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H164,1\u001b[9C24%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H161,22\u001b[8C24%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H158,22\u001b[8C23%\u001b[?25h\u001b[38;22H"]
[0.019, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set the name of the directory in which sockets will be found/created.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H155,1\u001b[9C22%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H152,22\u001b[8C22%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H149,22\u001b[8C21%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set the UNIX socket permissions for the admin interface socket.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H146,22\u001b[8C21%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H143,22\u001b[8C20%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H140,22\u001b[8C20%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H137,22\u001b[8C19%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H134,22\u001b[8C18%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H131,1\u001b[9C18%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n# Default allows any user. If setting group ownership, you may want to\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H128,22\u001b[8C17%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# for monitoring VM status only\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H125,0-1\u001b[7C17%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#unix_sock_group = \"libvirt\"\r\n\r\n# Set the UNIX socket permissions for the R/O socket. This is used\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H122,13\u001b[8C16%\u001b[?25h\u001b[38;13H"]
[0.014, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n# This is restricted to 'root' by default.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H119,22\u001b[8C15%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# without becoming root.\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H116,22\u001b[8C15%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H113,13\u001b[8C14%\u001b[?25h\u001b[38;13H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# UNIX socket access controls\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H110,22\u001b[8C14%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m#################################################################\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H107,22\u001b[8C13%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# the wildcards (0.0.0.0/::) might not be available yet.\r\n#\r\n#listen_addr = \"192.168.0.1\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H104,22\u001b[8C12%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# If the libvirtd service is started in parallel with network\r\n# startup (e.g. with systemd), binding to addresses other than\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H101,13\u001b[8C12%\u001b[?25h\u001b[38;13H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H98,22\u001b[9C11%\u001b[?25h\u001b[38;22H"]
[0.019, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Override the default configuration which binds to all network\r\n# interfaces. This can be a numeric IPv4/6 address, or hostname\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H95,22\u001b[9C11%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n#tcp_port = \"16509\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H92,1\u001b[10C10%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H89,1\u001b[10C10%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[2;1H\u001b[96m# Override the port for accepting insecure TCP connections\r\n# This can be a port number, or service name\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H86,0-1\u001b[9C9%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n#tls_port = \"16514\"\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H83,1\u001b[11C8%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This can be a port number, or service name\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H80,1\u001b[11C8%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[3;1H\u001b[96m# Override the port for accepting secure TLS connections\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H77,22\u001b[10C7%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This is disabled by default, uncomment this to enable it.\r\n#listen_tcp = 1\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H74,22\u001b[10C7%\u001b[?25h\u001b[38;22H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# SASL mechanisms which support data encryption are allowed. This is\r\n# DIGEST_MD5 and GSSAPI (Kerberos5)\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H71,0-1\u001b[9C6%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n# Using the TCP socket requires SASL authentication by default. Only\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H68,1\u001b[11C5%\u001b[?25h\u001b[38;1H\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3L\u001b[1;44r\u001b[1;1H\u001b[96m# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H65,22\u001b[10C5%\u001b[?25h\u001b[38;22H"]
[1.014, "o", "\u001b[?25l\u001b[1;43r\u001b[1;1H\u001b[3M\u001b[1;44r\u001b[42;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[44;152H\u001b[K\u001b[44;152H65,22\u001b[10C5%\u001b[?25h\u001b[35;22H"]
