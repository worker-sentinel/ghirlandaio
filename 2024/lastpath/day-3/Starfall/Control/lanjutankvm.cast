[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H186,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# is essential to change the systemd SocketMode parameter\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H185,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# to 'polkit'. If you disable use of 'polkit' here, then it\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H184,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# allows any user to connect and 'auth_unix_rw' will default\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H183,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0666 which\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H182,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H181,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H180,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# will default to 'none'.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H179,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# thus only allowing root user to connect, and 'auth_unix_rw'\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H178,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0600 by default\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H177,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.314, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H176,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.235, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H175,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.501, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# Set an authentication scheme for UNIX read-write sockets.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H174,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.025, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H173,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#auth_unix_ro = \"polkit\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H172,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# enable 'sasl' here, or change the polkit policy definition.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H171,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# To restrict monitoring of domains you may wish to either\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H170,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
