[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H137,1\u001b[9C21%\u001b[?25h\u001b[28;1H"]
