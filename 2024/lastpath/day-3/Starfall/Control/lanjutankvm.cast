[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# meaning no access control checks are done once a\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H221,1\u001b[9C41%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# on this. By default the 'nop' driver is enabled,\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H220,1\u001b[9C41%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# to all APIs. Access drivers can place restrictions\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H219,1\u001b[9C41%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# By default an authenticated user is allowed access\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H218,1\u001b[9C40%\u001b[?25h\u001b[6;1H"]
