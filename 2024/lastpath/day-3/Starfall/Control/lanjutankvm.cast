[0.001, "o", "\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[?25l\u001b[34;1H\"/etc/libvirt/libvirtd.conf\""]
[0.000, "o", " 552L, 18357B"]
[0.008, "o", "\u001b[2;1H▽\u001b[6n\u001b[2;1H  \u001b[3;1H\u001bPzz\u001b\\\u001b[0%m\u001b[6n\u001b[3;1H           \u001b[1;1H\u001b[>c\u001b]10;?\u0007\u001b]11;?\u0007"]
[0.001, "o", "\u001b[1;1H\u001b[34m# Master libvirt daemon configuration file\r\n#\u001b[m\u001b[2;2H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[34m#################################################################\r\n#\r\n# Network connectivity controls\r\n#\r\n\r\n# Flag listening for secure TLS connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\r\n#\r\n# This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\r\n\r\n# Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Using the TCP socket requires SASL authentication by default. Only\u001b[m\u001b[34;121H1,1\u001b[11CTop\u001b[?25h\u001b[1;1H\u001b[?4m\u001bP+q436f\u001b\\\u001bP+q6b75\u001b\\\u001bP+q6b64\u001b\\\u001bP+q6b72\u001b\\\u001bP+q6b6c\u001b\\\u001bP+q2332\u001b\\\u001bP+q2334\u001b\\\u001bP+q2569\u001b\\\u001bP+q2a37\u001b\\\u001bP+q6b31\u001b\\\u001bP$q q\u001b\\\u001b[?12$p"]
[0.001, "o", "\u001b[?25l\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[1;1H\u001b[96m# Master libvirt daemon configuration file\r\n#\r\n\r\n#################################################################\r\n#\r\n# Network connectivity controls\r\n#\r\n\r\n# Flag listening for secure TLS connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# It is necessary to setup a CA and issue server certificates before\r\n# using this capability.\r\n#\r\n# This is enabled by default, uncomment this to disable it\r\n#listen_tls = 0\r\n\r\n# Listen for unencrypted TCP connections on the public TCP/IP port.\r\n#\r\n# To enable listening sockets with the 'libvirtd' daemon it's also required to\r\n# pass the '--listen' flag on the commandline of the daemon.\r\n# This is not needed with 'virtproxyd'.\r\n#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Using the TCP socket requires SASL authentication by default. Only\u001b[m\u001b[34;121H1,1\u001b[11CTop\u001b[?25h\r\"/etc/libvirt/libvirtd.conf\" 552L, 18357B\u001b[1;1H"]
