[76.586, "o", "systemctl cat libvirtd.services"]
[0.842, "o", "\b\u001b[K"]
[0.772, "o", "\r\n\u001b[?2004l\r"]
[0.011, "o", "\u001b[0;1;34m# \u001b]8;;file://laptopserver/usr/lib/systemd/system/libvirtd.service\u001b\\/usr/lib/systemd/system/libvirtd.service\u001b]8;;\u001b\\\u001b[0m\r\n\u001b[0;1;36m[Unit]\u001b[0m\r\n\u001b[0;1;32mDescription=\u001b[0mlibvirt legacy monolithic daemon\r\n\u001b[0;1;32mDocumentation=\u001b[0mman:libvirtd(8)\r\n\u001b[0;1;32mDocumentation=\u001b[0mhttps://libvirt.org/\r\n\u001b[0;1;38:5:245m# Use Wants instead of Requires so that users\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# can disable these three .socket units to revert\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# to a traditional non-activation deployment setup\u001b[0m\r\n\u001b[0;1;32mWants=\u001b[0mlibvirtd.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mWants=\u001b[0mlibvirtd-ro.socket\r\n\u001b[0;1;32mWants=\u001b[0mlibvirtd-admin.socket\r\n"]
[0.001, "o", "\u001b[0;1;32mAfter=\u001b[0mlibvirtd.socket\r\n\u001b[0;1;32mAfter=\u001b[0mlibvirtd-ro.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mlibvirtd-admin.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mRequires=\u001b[0mvirtlogd.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mWants=\u001b[0mvirtlockd.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mvirtlogd.socket\r\n\u001b[0;1;32mAfter=\u001b[0mvirtlockd.socket\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# To ensure that our helper daemons are not shut down before the main daemon\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# shuts down we need also explicit ordering with the .service unit\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mvirtlogd.service\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mvirtlock.service\r\n"]
[0.000, "o", "\u001b[0;1;32mWants=\u001b[0msystemd-machined.service\r\n\u001b[0;1;32mAfter=\u001b[0mnetwork.target\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mdbus.service\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0miscsid.service\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mapparmor.service\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mremote-fs.target\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0msystemd-machined.service\r\n"]
[0.000, "o", "\u001b[0;1;32mAfter=\u001b[0mxencommons.service\r\n"]
[0.000, "o", "\u001b[0;1;32mConflicts=\u001b[0mxendomains.service\r\n\r\n\u001b[0;1;36m[Service]\u001b[0m\r\n"]
[0.000, "o", "\u001b[7m--More--\u001b[27m"]
[63.323, "o", "\r\r\u001b[K\r\n...skipping 1 line\r\n"]
[0.000, "o", "\r\u001b[0;1;32mEnvironment=\u001b[0mLIBVIRTD_ARGS=\"--timeout 120\"\r\n"]
[0.000, "o", "\u001b[0;1;32mEnvironmentFile=\u001b[0m-/etc/conf.d/libvirtd\r\n"]
[0.000, "o", "\u001b[0;1;32mExecStart=\u001b[0m/usr/bin/libvirtd $LIBVIRTD_ARGS\r\n"]
[0.000, "o", "\u001b[0;1;32mExecReload=\u001b[0m/bin/kill -HUP $MAINPID\r\n\u001b[0;1;32mKillMode=\u001b[0mprocess\r\n"]
[0.000, "o", "\u001b[0;1;32mRestart=\u001b[0mon-failure\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# Raise hard limits to match behaviour of systemd >= 240.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# During startup, daemon will set soft limit to match hard limit\u001b[0m\r\n"]
[0.001, "o", "\u001b[0;1;38:5:245m# per systemd recommendations\u001b[0m\r\n\u001b[0;1;32mLimitNOFILE=\u001b[0m1024:524288\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# The cgroups pids controller can limit the number of tasks started by\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# the daemon, which can limit the number of domains for some hypervisors.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# A conservative default of 8 tasks per guest results in a TasksMax of\u001b[0m\r\n\u001b[0;1;38:5:245m# 32k to support 4096 guests.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;32mTasksMax=\u001b[0m32768\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# With cgroups v2 there is no devices controller anymore, we have to use\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# eBPF to control access to devices. In order to do that we create a eBPF\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# hash MAP which locks memory. The default map size for 64 devices together\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# with program takes 12k per guest. After rounding up we will get 64M to\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;38:5:245m# support 4096 guests.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;32mLimitMEMLOCK=\u001b[0m64M\r\n\r\n"]
[0.000, "o", "\u001b[0;1;36m[Install]\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;32mWantedBy=\u001b[0mmulti-user.target\r\n"]
[0.000, "o", "\u001b[0;1;32mAlso=\u001b[0mvirtlockd.socket\r\n"]
[0.001, "o", "\u001b[0;1;32mAlso=\u001b[0mvirtlogd.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mAlso=\u001b[0mlibvirtd.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mAlso=\u001b[0mlibvirtd-ro.socket\r\n"]
[0.000, "o", "\u001b[0;1;32mAlso=\u001b[0mlibvirtd-admin.socket\r\n\r\n"]
[0.000, "o", "\u001b[0;1;34m# \u001b]8;;file://laptopserver/usr/lib/systemd/system/libvirtd.service.d/10-secret.conf\u001b\\/usr/lib/systemd/system/libvirtd.service.d/10-s\r\n"]
[0.000, "o", "ecret.conf\u001b]8;;\u001b\\\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;36m[Unit]\u001b[0m\r\n\u001b[7m--More--\u001b[27m"]
[0.159, "o", "\r\r\u001b[K\r\n"]
[0.000, "o", "...skipping 1 line\r\n"]
[0.000, "o", "\r\u001b[0;1;32mAfter=\u001b[0mvirt-secret-init-encryption.service\r\n\r\n"]
[0.000, "o", "\u001b[0;1;36m[Service]\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;1;32mEnvironment=\u001b[0mSECRETS_ENCRYPTION_KEY=%d/secrets-encryption-key\r\n"]
[0.000, "o", "\u001b[0;1;32mLoadCredentialEncrypted=\u001b[0msecrets-encryption-key:/var/lib/libvirt/secrets/secrets-encryption-key\r\n\r\n"]
