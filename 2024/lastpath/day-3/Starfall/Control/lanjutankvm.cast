[0.030, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# The default TLS configuration only uses certificates for the server\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;123H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m9,1  \r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# allowing the client to verify the server's identity and establish\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;122H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m50\r\u001b[A\u001b[?25h"]
[0.026, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# an encrypted channel.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;123H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m1,1          35\r\u001b[A\u001b[?25h"]
[0.032, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.000, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m#\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;123H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m2\r\u001b[A\u001b[?25h"]
