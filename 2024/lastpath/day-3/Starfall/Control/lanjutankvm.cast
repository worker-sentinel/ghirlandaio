[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H206,1\u001b[9C38%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#auth_tls = \"none\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H205,1\u001b[9C38%\u001b[?25h\u001b[6;1H"]
[0.033, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# mechanism as well, by using 'sasl' for this option\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H204,1\u001b[9C38%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# It is possible to make use of any SASL authentication\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H203,1\u001b[9C37%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H202,1\u001b[9C37%\u001b[?25h\u001b[6;1H"]
[0.472, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# layer, and limited authentication is done by certificates\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H201,1\u001b[9C37%\u001b[?25h\u001b[6;1H"]
[0.501, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# TLS sockets already have encryption provided by the TLS\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H200,1\u001b[9C37%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H199,1\u001b[9C37%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# Change the authentication scheme for TLS sockets.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H198,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H197,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#auth_tcp = \"sasl\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H196,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# mechanism in /etc/sasl2/libvirt.conf\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H195,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# use, always enable SASL and use the GSSAPI or DIGEST-MD5\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H194,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# Don't do this outside of a dev/test scenario. For real world\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H193,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If you don't enable SASL, then all TCP traffic is cleartext.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H192,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H191,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# Change the authentication scheme for TCP sockets.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H190,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H189,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#auth_unix_rw = \"polkit\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H188,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H187,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H186,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# is essential to change the systemd SocketMode parameter\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H185,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# to 'polkit'. If you disable use of 'polkit' here, then it\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H184,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# allows any user to connect and 'auth_unix_rw' will default\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H183,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0666 which\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H182,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H181,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H180,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# will default to 'none'.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H179,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# thus only allowing root user to connect, and 'auth_unix_rw'\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H178,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# the systemd .socket files will use SocketMode=0600 by default\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H177,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H176,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H175,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# Set an authentication scheme for UNIX read-write sockets.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H174,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H173,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.036, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#auth_unix_ro = \"polkit\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H172,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.025, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# enable 'sasl' here, or change the polkit policy definition.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H171,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# To restrict monitoring of domains you may wish to either\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H170,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.027, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H169,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# user access.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H168,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# connections. The default policy still allows any local\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H167,1\u001b[9C31%\u001b[?25h\u001b[6;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# the libvirt socket will perform a check with polkit after\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H166,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H165,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H164,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.617, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# allows execution of APIs which don't change state.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H163,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.500, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# no access control checks are done, but libvirt still only\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H162,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H161,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H160,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# By default socket permissions allow anyone to connect\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H159,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H158,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.027, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H157,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.033, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H156,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H155,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#            is allowed read/only access.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H154,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#            full read/write access (aka sudo like), while anyone\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H153,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#            require a user to supply their own password to gain\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H152,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
