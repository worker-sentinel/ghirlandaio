[0.030, "o", "\u001b[?25l\u001b[34;123H7\u001b[16;1H\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[34;123H6\u001b[15;1H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\u001b[34;123H5\u001b[14;1H\u001b[?25h"]
