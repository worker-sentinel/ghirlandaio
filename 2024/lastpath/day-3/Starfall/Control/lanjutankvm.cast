[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# back to 0600, to avoid an insecure configuration.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H176,1\u001b[9C28%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H177,1\u001b[9C28%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#auth_unix_rw = \"polkit\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H178,1\u001b[9C28%\u001b[?25h\u001b[28;1H"]
[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H179,1\u001b[9C29%\u001b[?25h\u001b[28;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# Change the authentication scheme for TCP sockets.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H180,1\u001b[9C29%\u001b[?25h\u001b[28;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H181,1\u001b[9C29%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# If you don't enable SASL, then all TCP traffic is cleartext.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H182,1\u001b[9C29%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# Don't do this outside of a dev/test scenario. For real world\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H183,1\u001b[9C29%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# use, always enable SASL and use the GSSAPI or DIGEST-MD5\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H184,1\u001b[9C30%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# mechanism in /etc/sasl2/libvirt.conf\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H185,1\u001b[9C30%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#auth_tcp = \"sasl\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H186,1\u001b[9C30%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H187,1\u001b[9C30%\u001b[?25h\u001b[28;1H"]
[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# Change the authentication scheme for TLS sockets.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H188,1\u001b[9C30%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H189,1\u001b[9C31%\u001b[?25h\u001b[28;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# TLS sockets already have encryption provided by the TLS\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H190,1\u001b[9C31%\u001b[?25h\u001b[28;1H"]
[2.682, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# layer, and limited authentication is done by certificates\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H191,1\u001b[9C31%\u001b[?25h\u001b[28;1H"]
[0.224, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H192,1\u001b[9C31%\u001b[?25h\u001b[28;1H"]
[0.162, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# It is possible to make use of any SASL authentication\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H193,1\u001b[9C31%\u001b[?25h\u001b[28;1H"]
[0.161, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# mechanism as well, by using 'sasl' for this option\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H194,1\u001b[9C31%\u001b[?25h\u001b[28;1H"]
[0.153, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#auth_tls = \"none\"\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H195,1\u001b[9C32%\u001b[?25h\u001b[28;1H"]
[0.123, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H196,1\u001b[9C32%\u001b[?25h\u001b[28;1H"]
[0.136, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# Enforce a minimum SSF value for TCP sockets\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H197,1\u001b[9C32%\u001b[?25h\u001b[28;1H"]
[0.174, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H198,1\u001b[9C32%\u001b[?25h\u001b[28;1H"]
[0.451, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# The default minimum is currently 56 (single-DES) which will\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H199,1\u001b[9C32%\u001b[?25h\u001b[28;1H"]
[0.177, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# be raised to 112 in the future.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H200,1\u001b[9C33%\u001b[?25h\u001b[28;1H"]
[0.595, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H201,1\u001b[9C33%\u001b[?25h\u001b[28;1H"]
[0.196, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# This option can be used to set values higher than 112\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H202,1\u001b[9C33%\u001b[?25h\u001b[28;1H"]
[0.138, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#tcp_min_ssf = 112\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H203,1\u001b[9C33%\u001b[?25h\u001b[28;1H"]
[0.183, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H204,1\u001b[9C33%\u001b[?25h\u001b[28;1H"]
[0.149, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H205,1\u001b[9C34%\u001b[?25h\u001b[28;1H"]
[0.158, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# Change the API access control scheme\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H206,1\u001b[9C34%\u001b[?25h\u001b[28;1H"]
[0.151, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H207,1\u001b[9C34%\u001b[?25h\u001b[28;1H"]
[0.152, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# By default an authenticated user is allowed access\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H208,1\u001b[9C34%\u001b[?25h\u001b[28;1H"]
[0.221, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# to all APIs. Access drivers can place restrictions\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H209,1\u001b[9C34%\u001b[?25h\u001b[28;1H"]
