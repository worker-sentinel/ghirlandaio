[0.029, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H211,1\u001b[9C39%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# be raised to 112 in the future.\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H210,1\u001b[9C39%\u001b[?25h\u001b[6;1H"]
[0.030, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m# The default minimum is currently 56 (single-DES) which will\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H209,1\u001b[9C39%\u001b[?25h\u001b[6;1H"]
[0.033, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[1;1H\u001b[96m#\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H208,1\u001b[9C38%\u001b[?25h\u001b[6;1H"]
