[0.032, "o", "\u001b[?25l\u001b[1;33r\u001b[33;1H\r\n\u001b[1;34r\u001b[33;1H\u001b[96m# for the certificate files is as follows:\u001b[m\u001b[34;121H\u001b[K\u001b[34;121H222,1\u001b[9C37%\u001b[?25h\u001b[28;1H"]
