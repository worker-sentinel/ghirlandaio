[0.031, "o", "\u001b[?25l\u001b[1;33r\u001b[1;1H\u001b[L\u001b[1;34r\u001b[34;121H\u001b[K\u001b[34;121H215,1\u001b[9C40%\u001b[?25h\u001b[6;1H"]
