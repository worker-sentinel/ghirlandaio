[0.029, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# provided path does not exist, libvirtd will fail to start. If the path is\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;123H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m2\r\u001b[A\u001b[?25h"]
[0.031, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# not provided, but TLS-encrypted backup is requested, then the\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;123H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m3\r\u001b[A\u001b[?25h"]
[0.029, "o", "\u001b[?25l\u001b[34;128H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[34;128H   \u001b[1;32r\u001b[H\u001b[M\u001b[r\u001b[32;1H\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m# default_tls_x509_cert_dir path will be used.\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\u001b[33;123H\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;79;82;88m4\r\u001b[A\u001b[?25h"]
