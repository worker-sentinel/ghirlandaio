[0.002, "o", "\u001b[?2026h\u001b[1;3H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mactivation.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                             \r\n\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# If the libvirtd service is started in parallel with network\u001b[4;2H startup (e.g. with systemd), binding to addresses other than\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m   \u001b[5;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m the wildcards (0.0.0.0/::) might not be available yet.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\u001b[6;2H                              \u001b[7;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mlisten_addr = \"192.168.0.1\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\r\n\n                                                                      \u001b[10;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m################################################################\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\u001b[11;2H                                                                             \u001b[12;3H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mUNIX socket access controls\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                               \u001b[13;2H                                      \r\n \u001b[15;3H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mSet the UNIX domain socket group ownership. This can be used to\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m \u001b[16;4H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mllow a 'trusted' set of users access to management capabilities\u001b[17;2H without becoming root.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\u001b[18;2H                                                                   \u001b[19;3H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mThis setting is not required or honoured if using systemd socket\u001b[20;2H activation.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\u001b[21;2H                                                         \u001b[22;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m This is restricted to 'root' by default.\r\n#unix_sock_group = \"libvirt\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\r\n                                                                   \u001b[25;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m Set the UNIX socket permissions for the R/O socket. This is used\u001b[26;3Hfor monitoring VM status only\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                               \u001b[27;2H                                                           \u001b[28;8H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27msetting is not required or honoured if using systemd socket\u001b[29;2H activation.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\u001b[30;2H                                                                 \u001b[31;3H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mDefault allows any user. If setting group ownership, you may want to\u001b[32;2H restrict this too.\u001b[33;2Hunix_sock_ro_perms = \"0777\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                        \r\n                                                                    \u001b[35;3H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27mSet the UNIX socket permissions for the R/W socket. This is used\u001b[36;2H for full management of VMs\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\u001b[37;2H                                                          \u001b[38;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\u001b[42;3Hthe default will change to allow everyone (eg, 0777)\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m  \u001b[43;2H                                           \u001b[44;2H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m If not using PolicyKit and setting group ownership for access\u001b[45;3Hcontrol, then you may want to relax this too.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                   \u001b[46;134H\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:79:82:88m85,1           12%\u001b[2 q\u001b[?1002h\u001b[?1006h\r\u001b[23A\u001b[?2026l"]
