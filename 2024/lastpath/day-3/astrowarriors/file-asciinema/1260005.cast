[0.001, "o", "\u001b[?2026h\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Master libvirt daemon configuration file\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                             \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#################################################################\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Network connectivity controls\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Flag listening for secure TLS connections on the public TCP/IP port.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                 \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# To enable listening sockets with the 'libvirtd' daemon it's also required to\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                         \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# pass the '--listen' flag on the commandline of the daemon.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                           \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This is not needed with 'virtproxyd'.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This setting is not required or honoured if using systemd socket\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                     \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# activation.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                          \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# It is necessary to setup a CA and issue server certificates before\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                   \r\n\u001b(B\u001b[m\u001b[38:2:155:158:"]
[0.000, "o", "164m\u001b[48:2:20:22:27m# using this capability.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                               \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This is enabled by default, uncomment this to disable it\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                             \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#listen_tls = 0\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                        \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Listen for unencrypted TCP connections on the public TCP/IP port.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                    \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# To enable listening sockets with the 'libvirtd' daemon it's also required to\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                         \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# pass the '--listen' flag on the commandline of the daemon.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                           \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This is not needed with 'virtproxyd'.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This setting is not required or honoured if using systemd socket\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                     \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# activation.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                          \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Using the TCP socket requires SASL authentication by default. Only\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                   \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# SASL mechanisms which support data encryption are allowed. This is\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                   \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# DIGEST_MD5 and GSSAPI (Kerberos5)\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                    \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                        "]
[0.000, "o", "                              \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This is disabled by default, uncomment this to enable it.\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                            \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#listen_tcp = 1\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                        \r\n                                                                                                                                                       \r\n                                                                                                                                                       \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Override the port for accepting secure TLS connections\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                               \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This can be a port number, or service name\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                           \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# This setting is not required or honoured if using systemd socket\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                     \r\n\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:79:82:88m/etc/libvirt/libvirtd.conf                                                                                                           1,1            Top\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m\r\n                                                                                                                                                       \u001b[2 q\u001b[2 q\u001b[H\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Master libvirt daemon configuration file\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                             \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#################################################################\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# Network connectivity controls\u001b(B\u001b