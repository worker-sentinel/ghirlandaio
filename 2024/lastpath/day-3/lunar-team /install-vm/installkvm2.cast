[0.003, "o", "Optional dependencies for libvirt\r\n    dmidecode: DMI system info support\r\n    dnsmasq: required for default NAT/DHCP for guests [pending]\r\n    gettext: required for libvirt-guests.service [installed]\r\n    iptables-nft: required for default NAT networking [installed]\r\n    libvirt-python: for virt-qemu-qmp-proxy and virt-qemu-sev-validate commands [pending]\r\n    libvirt-storage-gluster: Gluster storage backend\r\n    libvirt-storage-iscsi-direct: iSCSI-direct storage backend\r\n    lvm2: Logical Volume Manager support [installed]\r\n"]
[0.000, "o", "    openbsd-netcat: for remote management over ssh [pending]\r\n    open-iscsi: iSCSI support via iscsiadm\r\n    python-cryptography: for virt-qemu-sev-validate command\r\n    python-lxml: for virt-qemu-sev-validate command\r\n    qemu-base: QEMU/KVM support [installed]\r\n"]
[0.000, "o", "    qemu-desktop: QEMU/KVM desktop support\r\n    qemu-emulators-full: Support of additional QEMU architectures\r\n    radvd: IPv6 RAD support\r\n    swtpm: TPM emulator support\r\n"]
