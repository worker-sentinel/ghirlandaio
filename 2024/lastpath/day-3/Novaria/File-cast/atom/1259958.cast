[0.190, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# restrict this too.\r\n#unix_sock_ro_perms = \"0777\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H63,1\u001b[10C11%\u001b[?25h\u001b[6;1H"]
[0.682, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H66,1\u001b[10C11%\u001b[?25h\u001b[6;1H"]
[0.482, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H69,1\u001b[10C12%\u001b[?25h\u001b[6;1H"]
[5.838, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H72,1\u001b[10C12%\u001b[?25h\u001b[6;1H"]
[0.064, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\r\n#unix_sock_rw_perms = \"0770\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H75,1\u001b[10C13%\u001b[?25h\u001b[6;1H"]
[0.152, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[38;1H\u001b[96m# Set the UNIX socket permissions for the admin interface socket.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H78,1\u001b[10C14%\u001b[?25h\u001b[6;1H"]
[0.675, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H81,1\u001b[10C14%\u001b[?25h\u001b[6;1H"]
[0.460, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Default allows only owner (root), do not change it unless you are\r\n# sure to whom you are exposing the access to.\r\n#unix_sock_admin_perms = \"0700\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H84,1\u001b[10C15%\u001b[?25h\u001b[6;1H"]
[0.360, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[38;1H\u001b[96m# Set the name of the directory in which sockets will be found/created.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H87,1\u001b[10C15%\u001b[?25h\u001b[6;1H"]
[183.418, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H90,1\u001b[10C16%\u001b[?25h\u001b[6;1H"]
[0.047, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#unix_sock_dir = \"/run/libvirt\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H93,1\u001b[10C16%\u001b[?25h\u001b[6;1H"]
[0.135, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[38;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H96,0-1\u001b[8C17%\u001b[?25h\u001b[6;1H"]
[0.101, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Authentication.\r\n#\r\n# There are the following choices available:\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H99,1\u001b[10C18%\u001b[?25h\u001b[6;1H"]
[4.491, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n#  - none: do not perform auth checks. If you can connect to the\r\n#          socket you are allowed. This is suitable if there are\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H102,1\u001b[9C18%\u001b[?25h\u001b[6;1H"]
[0.048, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#          restrictions on connecting to the socket (eg, UNIX\r\n#          socket permissions), or if there is a lower layer in\r\n#          the network providing auth (eg, TLS/x509 certificates)\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H105,1\u001b[9C19%\u001b[?25h\u001b[6;1H"]
[0.057, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n#  - sasl: use SASL infrastructure. The actual auth scheme is then\r\n#          controlled from /etc/sasl2/libvirt.conf. For the TCP\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H108,1\u001b[9C19%\u001b[?25h\u001b[6;1H"]
[0.103, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#          socket only GSSAPI & DIGEST-MD5 mechanisms will be used.\r\n#          For non-TCP or TLS sockets, any scheme is allowed.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H111,1\u001b[9C20%\u001b[?25h\u001b[6;1H"]
[0.249, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#  - polkit: use PolicyKit to authenticate. This is only suitable\r\n#            for use on the UNIX sockets. The default policy will\r\n#            require a user to supply their own password to gain\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H114,1\u001b[9C21%\u001b[?25h\u001b[6;1H"]
[0.295, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#            full read/write access (aka sudo like), while anyone\r\n#            is allowed read/only access.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H117,1\u001b[9C21%\u001b[?25h\u001b[6;1H"]
[0.034, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[38;1H\u001b[96m# Set an authentication scheme for UNIX read-only sockets\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H120,1\u001b[9C22%\u001b[?25h\u001b[6;1H"]
[0.050, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# By default socket permissions allow anyone to connect\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H123,1\u001b[9C22%\u001b[?25h\u001b[6;1H"]
[0.043, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# no access control checks are done, but libvirt still only\r\n# allows execution of APIs which don't change state.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H126,0-1\u001b[7C23%\u001b[?25h\u001b[6;1H"]
[0.035, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# If libvirt was compiled with support for 'polkit', then\r\n# the libvirt socket will perform a check with polkit after\r\n# connections. The default policy still allows any local\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H129,1\u001b[9C23%\u001b[?25h\u001b[6;1H"]
[0.064, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# user access.\r\n#\r\n# To restrict monitoring of domains you may wish to either\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H132,1\u001b[9C24%\u001b[?25h\u001b[6;1H"]
[0.404, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# enable 'sasl' here, or change the polkit policy definition.\r\n#auth_unix_ro = \"polkit\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H135,1\u001b[9C25%\u001b[?25h\u001b[6;1H"]
[0.257, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Set an authentication scheme for UNIX read-write sockets.\r\n#\r\n# If libvirt was compiled without support for 'polkit', then\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H138,1\u001b[9C25%\u001b[?25h\u001b[6;1H"]
[0.070, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# the systemd .socket files will use SocketMode=0600 by default\r\n# thus only allowing root user to connect, and 'auth_unix_rw'\r\n# will default to 'none'.\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H141,1\u001b[9C26%\u001b[?25h\u001b[6;1H"]
[0.127, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n# If libvirt was compiled with support for 'polkit', then\r\n# the systemd .socket files will use SocketMode=0666 which\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H144,1\u001b[9C26%\u001b[?25h\u001b[6;1H"]
[0.409, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# allows any user to connect and 'auth_unix_rw' will default\r\n# to 'polkit'. If you disable use of 'polkit' here, then it\r\n# is essential to change the systemd SocketMode parameter\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H147,1\u001b[9C27%\u001b[?25h\u001b[6;1H"]
[0.124, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# back to 0600, to avoid an insecure configuration.\r\n#\r\n#auth_unix_rw = \"polkit\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H150,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
[0.938, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[38;1H\u001b[96m# Change the authentication scheme for TCP sockets.\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H153,1\u001b[9C28%\u001b[?25h\u001b[6;1H"]
[0.156, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# If you don't enable SASL, then all TCP traffic is cleartext.\r\n# Don't do this outside of a dev/test scenario. For real world\r\n# use, always enable SASL and use the GSSAPI or DIGEST-MD5\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H156,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.181, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# mechanism in /etc/sasl2/libvirt.conf\r\n#auth_tcp = \"sasl\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H159,1\u001b[9C29%\u001b[?25h\u001b[6;1H"]
[0.110, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Change the authentication scheme for TLS sockets.\r\n#\r\n# TLS sockets already have encryption provided by the TLS\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H162,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.099, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# layer, and limited authentication is done by certificates\r\n#\r\n# It is possible to make use of any SASL authentication\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H165,1\u001b[9C30%\u001b[?25h\u001b[6;1H"]
[0.079, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# mechanism as well, by using 'sasl' for this option\r\n#auth_tls = \"none\"\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H168,0-1\u001b[7C31%\u001b[?25h\u001b[6;1H"]
[0.064, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Enforce a minimum SSF value for TCP sockets\r\n#\r\n# The default minimum is currently 56 (single-DES) which will\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H171,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.550, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# be raised to 112 in the future.\r\n#\r\n# This option can be used to set values higher than 112\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H174,1\u001b[9C32%\u001b[?25h\u001b[6;1H"]
[0.035, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#tcp_min_ssf = 112\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H177,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.036, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Change the API access control scheme\r\n#\r\n# By default an authenticated user is allowed access\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H180,1\u001b[9C33%\u001b[?25h\u001b[6;1H"]
[0.021, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# to all APIs. Access drivers can place restrictions\r\n# on this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H183,1\u001b[9C34%\u001b[?25h\u001b[6;1H"]
[0.022, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# client has authenticated with libvirtd\r\n#\r\n#access_drivers = [ \"polkit\" ]\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H186,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.035, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[38;1H\u001b[96m#################################################################\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H189,1\u001b[9C35%\u001b[?25h\u001b[6;1H"]
[0.023, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# TLS x509 certificate configuration\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H192,0-1\u001b[7C36%\u001b[?25h\u001b[6;1H"]
[0.020, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m# Use of TLS requires that x509 certificates be issued. The default locations\r\n# for the certificate files is as follows:\r\n#\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H195,1\u001b[9C36%\u001b[?25h\u001b[6;1H"]
[0.028, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#   /etc/pki/CA/cacert.pem - The CA master certificate\r\n#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H198,1\u001b[9C37%\u001b[?25h\u001b[6;1H"]
[0.901, "o", "\u001b[?25l\u001b[40;107H/\u001b[6;1H"]
[0.000, "o", "\u001b[40;107H\u001b[K\u001b[40;1H/\u001b[?25h"]
[1.249, "o", "u\u001b[?25l"]
[0.005, "o", "\u001b[6;26H\u001b[7m\u001b[96mu\u001b[m\u001b[40;117H198,26\u001b[8C37%\u001b[?25h\u001b[?25l\u001b[40;117H\u001b[K\u001b[40;3H\u001b[?25h"]
[0.193, "o", "n\u001b[?25l"]
[0.002, "o", "\u001b[1;39r\u001b[1;1H\u001b[8M\u001b[1;40r\u001b[32;1H\u001b[96m#\r\n# It is possible to override the default locations by altering the 'key_file',\r\n# 'cert_file', and 'ca_file' values and \u001b[m\u001b[7m\u001b[96mun\u001b[m\u001b[96mcommenting them below.\r\n#\r\n# NB, overriding the default of one location requires uncommenting and\r\n# possibly additionally overriding the other settings.\r\n#\u001b[m\u001b[40;1H\u001b[K\u001b[40;117H234,41\u001b[8C38%\u001b[?25h\u001b[?25l\r/un\u001b[40;117H\u001b[K\u001b[40;4H\u001b[?25h"]
[0.213, "o", "i\u001b[?25l"]
[0.005, "o", "\u001b[1;1H\u001b[96m# startup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\r\n\r\n#listen_addr = \"192.168.0.1\"\u001b[m\u001b[4;29H\u001b[K\u001b[5;1H\u001b[K\u001b[6;1H\u001b[K\u001b[7;2H\u001b[96m################################################################\u001b[m\u001b[8;2H\u001b[K\u001b[9;1H\u001b[96m# UNIX socket access controls\r\n#\u001b[m\u001b[11;1H\u001b[K\u001b[12;2H\u001b[96m Set the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\u001b[m\u001b[14;25H\u001b[K\u001b[15;2H\u001b[K\u001b[16;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[17;14H\u001b[K\u001b[19;2H\u001b[96m This is restricted to 'root' by default.\r\n#\u001b[m\u001b[7m\u001b[96muni\u001b[m\u001b[96mx_sock_group = \"libvirt\"\u001b[m\u001b[21;1H\u001b[K\u001b[22;2H\u001b[96m Set the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\u001b[m\u001b[23;32H\u001b[K\u001b[25;1H\u001b[96m# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[26;14H\u001b[K\u001b[27;2H\u001b[K\u001b[28;2H\u001b[96m Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\u001b[m\u001b[29;21H\u001b[K\u001b[30;2H\u001b[96munix_sock_ro_perms = \"0777\"\u001b[m\u001b[30;29H\u001b[K\u001b[31;1H\u001b[K\u001b[32;2H\u001b[96m Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\u001b[m\u001b[33;29H\u001b[K\u001b[34;2H\u001b[K\u001b[35;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[36;14H\u001b[K\u001b[37;2H\u001b[K\u001b[38;2H\u001b[96m Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\u001b[m\u001b[40;117H85,2\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[40;117H\u001b[K\u001b[40;5H\u001b[?25h"]
[5.359, "o", "i\u001b[?25l"]
[0.005, "o", "\u001b[1;3H\u001b[96mChange the authentication scheme for TLS sockets.\u001b[m\u001b[1;52H\u001b[K\u001b[2;2H\u001b[K\u001b[3;2H\u001b[96m TLS sockets already have encryption provided by the TLS\r\n# layer, and limited authentication is done by certificates\r\n#\r\n# It is possible to make use of any SASL authentication\r\n# mechanism as well, by using 'sasl' for this option\u001b[m\u001b[7;53H\u001b[K\u001b[8;2H\u001b[96mauth_tls = \"none\"\u001b[m\u001b[9;1H\u001b[K\u001b[10;2H\u001b[96m Enforce a minimum SSF value for TCP sockets\r\n#\r\n# The default minimum is currently 56 (single-DES) which will\u001b[m\u001b[12;62H\u001b[K\u001b[13;3H\u001b[96mbe raised to 112 in the future.\u001b[m\u001b[13;34H\u001b[K\u001b[14;2H\u001b[K\u001b[15;2H\u001b[96m This option can be used to set values higher than 112\r\n#tcp_min_ssf = 112\u001b[m\u001b[16;19H\u001b[K\u001b[17;1H\u001b[K\u001b[18;1H\u001b[K\u001b[19;3H\u001b[96mChange the API access control scheme\u001b[m\u001b[19;39H\u001b[K\u001b[20;2H\u001b[K\u001b[21;1H\u001b[96m# By default an authenticated user is allowed access\r\n# to all APIs. Access drivers can place restrictions\u001b[m\u001b[22;53H\u001b[K\u001b[23;3H\u001b[96mon this. By default the 'nop' driver is enabled,\r\n# meaning no access control checks are done once a\r\n# client has authenticated with libvirtd\u001b[m\u001b[25;41H\u001b[K\u001b[26;2H\u001b[K\u001b[27;2H\u001b[96maccess_drivers = [ \"polkit\" ]\u001b[m\u001b[28;1H\u001b[K\u001b[29;2H\u001b[96m################################################################\u001b[m\u001b[30;2H\u001b[K\u001b[31;1H\u001b[96m# TLS x509 certificate configuration\u001b[m\u001b[32;2H\u001b[K\u001b[33;1H\u001b[K\u001b[34;2H\u001b[96m Use of TLS requires that x509 certificates be issued. The default locations\r\n# for the certificate files is as follows:\u001b[m\u001b[35;43H\u001b[K\u001b[36;2H\u001b[K\u001b[37;2H\u001b[96m   /etc/pki/CA/cacert.pem - The CA master certificate\r\n#   /etc/pki/libvirt/servercert.pem - The server certificate signed by cacert.pem\r\n#   /etc/pki/libvirt/private/serverkey.pem - The server private key\u001b[m\u001b[40;117H198,1\u001b[9C37%\u001b[?25h\u001b[?25l\u001b[40;117H\u001b[K\u001b[40;6H\u001b[?25h"]
[1.326, "o", "\u001b[?25l\u001b[40;5H\u001b[K"]
[0.003, "o", "\u001b[1;3H\u001b[96mstartup (e.g. with systemd), binding to addresses other than\r\n# the wildcards (0.0.0.0/::) might not be available yet.\u001b[m\u001b[3;2H\u001b[K\u001b[4;2H\u001b[96mlisten_addr = \"192.168.0.1\"\u001b[m\u001b[4;29H\u001b[K\u001b[5;1H\u001b[K\u001b[6;1H\u001b[K\u001b[7;2H\u001b[96m################################################################\u001b[m\u001b[8;2H\u001b[K\u001b[9;1H\u001b[96m# UNIX socket access controls\u001b[m\u001b[10;2H\u001b[K\u001b[11;1H\u001b[K\u001b[12;3H\u001b[96mSet the UNIX domain socket group ownership. This can be used to\r\n# allow a 'trusted' set of users access to management capabilities\r\n# without becoming root.\u001b[m\u001b[15;2H\u001b[K\u001b[16;2H\u001b[96m This setting is not required or honoured if using systemd socket\r\n# activation.\r\n#\r\n# This is restricted to 'root' by default.\u001b[m\u001b[20;2H\u001b[7m\u001b[96muni\u001b[m\u001b[96mx_sock_group = \"libvirt\"\u001b[m\u001b[21;1H\u001b[K\u001b[22;3H\u001b[96mSet the UNIX socket permissions for the R/O socket. This is used\r\n# for monitoring VM status only\u001b[m\u001b[23;32H\u001b[K\u001b[24;2H\u001b[K\u001b[25;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[27;2H\u001b[K\u001b[28;1H\u001b[96m# Default allows any user. If setting group ownership, you may want to\r\n# restrict this too.\u001b[m\u001b[29;21H\u001b[K\u001b[30;2H\u001b[96munix_sock_ro_perms = \"0777\"\u001b[m\u001b[31;1H\u001b[K\u001b[32;2H\u001b[96m Set the UNIX socket permissions for the R/W socket. This is used\r\n# for full management of VMs\u001b[m\u001b[34;2H\u001b[K\u001b[35;3H\u001b[96mThis setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[37;2H\u001b[K\u001b[38;3H\u001b[96mDefault allows only root. If PolicyKit is enabled on the socket,\u001b[m\u001b[38;67H\u001b[K\u001b[39;3H\u001b[96mthe default will change to allow everyone (eg, 0777)\u001b[m\u001b[39;55H\u001b[K\u001b[40;117H85,2\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[40;117H\u001b[K\u001b[40;5H\u001b[?25h"]
[1.278, "o", "\r"]
