[0.114, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3L\u001b[1;40r\u001b[1;1H\u001b[96m# activation.\r\n#\r\n# If the libvirtd service is started in parallel with network\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H85,1\u001b[10C12%\u001b[?25h\u001b[23;1H"]
[0.167, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n# Default allows only root. If PolicyKit is enabled on the socket,\r\n# the default will change to allow everyone (eg, 0777)\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H85,1\u001b[10C12%\u001b[?25h\u001b[20;1H"]
[0.120, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H85,1\u001b[10C13%\u001b[?25h\u001b[17;1H"]
