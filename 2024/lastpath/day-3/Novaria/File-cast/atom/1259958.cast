[0.000, "o", "\u001b[38;5;224msearch hit BOTTOM, continuing at TOP"]
[0.004, "o", "\u001b[20;2H\u001b[m\u001b[96muni\u001b[m\u001b[40;117H85,2\u001b[10C12%\u001b[?25h\u001b[?25l\u001b[40;117H\u001b[K\u001b[40;117H85,2\u001b[10C12%\u001b[20;2H\u001b[?25h"]
[1.471, "o", "\u001b[?25l\u001b[40;107Hi\u001b[20;2H\u001b[40;107H \u001b[20;2H\u001b[40;1H\u001b[1m-- INSERT --\u001b[m\u001b[40;13H\u001b[K\u001b[40;117H85,2\u001b[10C12%\u001b[20;2H\u001b[?25h"]
[3.199, "o", "\u001b[?25l\bunix_sock_group = \u001b[95m\"libvirt\"\u001b[m\u001b[20;28H\u001b[K\u001b[?25h\u001b[?25l\u001b[40;120H1\u001b[20;1H\u001b[?25h"]
[9.558, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n# If not using PolicyKit and setting group ownership for access\r\n# control, then you may want to relax this too.\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H85,1\u001b[10C13%\u001b[?25h\u001b[17;1H"]
[0.171, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#unix_sock_rw_perms = \"0770\"\r\n\r\n# Set the UNIX socket permissions for the admin interface socket.\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H85,1\u001b[10C13%\u001b[?25h\u001b[14;1H"]
[0.128, "o", "\u001b[?25l\u001b[1;39r\u001b[1;1H\u001b[3M\u001b[1;40r\u001b[37;1H\u001b[96m#\r\n# This setting is not required or honoured if using systemd socket\r\n# activation.\u001b[m\u001b[40;117H\u001b[K\u001b[40;117H85,1\u001b[10C14%\u001b[?25h\u001b[11;1H"]
