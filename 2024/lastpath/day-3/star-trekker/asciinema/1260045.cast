[0.030, "o", "\u001b]3008;start=5b13b97d8876486e8c09b258f60360b3;user=root;hostname=dimas;machineid=a5d8d19a6f0e495e956f913aed471bf0;bootid=86ff5397c6c64016ad4cce906ddcfd22;pid=26338;pidfdid=25784;comm=sudo;targetuser=root;type=session\u001b\\"]
[0.050, "o", "[   0.0] \u001b[0;32mExamining the guest ...\u001b[0m\r\n"]
[41.536, "o", "\u001b[1;31mvirt-customize: error: libguestfs error: guestfs_launch failed.\r\nThis usually means the libguestfs appliance failed to start or crashed.\r\nDo:\r\n  export LIBGUESTFS_DEBUG=1 LIBGUESTFS_TRACE=1\r\nand run the command again.  For further information, read:\r\n  http://libguestfs.org/guestfs-faq.1.html#debugging-libguestfs\r\nYou can also run 'libguestfs-test-tool' and post the *complete* output\r\ninto a bug report or message to the libguestfs mailing list.\r\n"]
[0.000, "o", "\r\nIf reporting bugs, run virt-customize with debugging enabled and include \r\nthe complete output:\r\n\r\n  virt-customize -v -x [...]\u001b[0m\r\n"]
[0.019, "o", "\u001b]3008;end=5b13b97d8876486e8c09b258f60360b3\u001b\\"]
[0.004, "o", "\u001b]0;root@dimas:/var/lib/libvirt/images\u0007\u001b[?2004h[root@dimas images]# "]
[34.899, "o", "sudo virt-customize -a ubuntu-24.04-server-cloudimg-amd64.img --root-password password:default"]
