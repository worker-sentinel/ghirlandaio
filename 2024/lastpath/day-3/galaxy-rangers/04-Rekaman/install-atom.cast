[11.264, "o", "\u001b[?25l\u001b(B\u001b[m\u001b[93mserver\u001b(B\u001b[m {\r\n    \u001b[38;5;121mlisten\u001b(B\u001b[m \u001b[95m80\u001b(B\u001b[m;\u001b[K\r\n    \u001b[38;5;121mserver_name\u001b(B\u001b[m _;\u001b[96m # Mengizinkan akses langsung lewat IP VM\u001b(B\u001b[m\u001b[K\r\n    \u001b[38;5;121mroot\u001b(B\u001b[m /usr/share/nginx/atom;\u001b[K\r\n\u001b[K\n\u001b[96m    # Log file\u001b(B\u001b[m\u001b[K\r\n    \u001b(B\u001b[0;1m\u001b[96maccess_log\u001b(B\u001b[m /var/log/nginx/atom_access.log;\u001b[K\r\n    \u001b(B\u001b[0;1m\u001b[96merror_log\u001b(B\u001b[m /var/log/nginx/atom_error.log;\u001b[K\r\n\u001b[K\n    \u001b(B\u001b[0;1m\u001b[96mindex\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[96mindex\u001b(B\u001b[m.php;\u001b[K\r\n\u001b[K\n    \u001b[93mlocation\u001b(B\u001b[m / {\u001b[K\r\n        \u001b[38;5;121mtry_files\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[96m$uri\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[96m$uri\u001b(B\u001b[m/ /\u001b(B\u001b[0;1m\u001b[96mindex\u001b(B\u001b[m.php?\u001b(B\u001b[0;1m\u001b[96m$args\u001b(B\u001b[m;\u001b[K\r\n    }\u001b[K\r\n\u001b[K\n    \u001b[93mlocation\u001b(B\u001b[m ~ \\.php$ {\u001b[K\r\n        \u001b[38;5;121minclude\u001b(B\u001b[m snippets/fastcgi-php.conf;\u001b[K\r\n        \u001b[K\r\n\u001b[96m        # PENTING: Menggunakan php7.4-fpm karena versi ini yang direkomendasikan untuk AtoM\u001b(B\u001b[m\u001b[K\r\n        \u001b[38;5;121mfastcgi_pass\u001b(B\u001b[m unix:/var/run/php/php7.\u001b[95m4\u001b(B\u001b[m-fpm.sock;\u001b[K\r\n        \u001b[K\r\n        \u001b(B\u001b[0;1m\u001b[96mfastcgi_param\u001b(B\u001b[m SCRIPT_FILENAME \u001b(B\u001b[0;1m\u001b[96m$document_root$fastcgi_script_name\u001b(B\u001b[m;\u001b[K\r\n        \u001b[38;5;121minclude\u001b(B\u001b[m fastcgi_params;\u001b[K\r\n    }\u001b[K\r\n\u001b[K\n    \u001b[93mlocation\u001b(B\u001b[m ~ /\\.ht {\u001b[K\r\n        \u001b(B\u001b[0;1m\u001b[96mdeny\u001b(B\u001b[m all;\u001b[K\r\n    }\u001b[K\r\n}\u001b[K\r\n\u001b[K\u001b[43;33H\u001b(B\u001b[0;1;7m[+]\u001b[135C30,0-1\u001b[?25h"]
