[0.266, "o", "\r\n    1  ls\r\n    2  cd /etc/mysql/conf.d/\r\n    3  ls\r\n    4  sudo apt install neovim\r\n    5  ls\r\n    6  nvim mysql.cnf \r\n    7  ls\r\n    8  nvim /etc/mysql/conf.d/mysqld.cnf\r\n    9  sudo systemctl restart mysql\r\n   10  sudo apt install -y openjdk-11-jre-headless apt-transport-https software-properties-common\r\n   11  wget -qO - https://artifacts.elastic.co/GPG-KEY-elasticsearch | sudo gpg --dearmor -o /usr/share/keyrings/elasticsearch-keyring.gpg\r\n   12  echo \"deb [signed-by=/usr/share/keyrings/elasticsearch-keyring.gpg] https://artifacts.elastic.co/packages/oss-7.x/apt stable main\" | sudo tee -a /etc/apt/sources.list.d/elastic-7.x.list\r\n   13  sudo apt update\r\n   14  sudo apt install -y elasticsearch-oss\r\n   15  sudo update-java-alternatives -l\r\n   16  sudo update-alternatives --get-selections | grep java\r\n   17  sudo apt install -y imagemagick ghostscript poppler-utils ffmpeg\r\n   18  systemctl status mysql\r\n   19  cat /etc/mysql/conf.d/mysqld.cnf\r\n   20  sudo systemctl restart mysql\r\n   21  sudo apt install -y openjdk-11-jre-headless apt-transport-https software-properties-common\r\n   22  wget -qO - https://artifacts.elastic.co/GPG-KEY-elasticsearch | sudo gpg --dearmor -o /usr/share/keyrings/elasticsearch-keyring.gpg\r\n   23  echo \"deb [signed-by=/usr/share/keyrings/elasticsearch-keyring.gpg] https://artifacts.elastic.co/packages/oss-7.x/apt stable main\" | sudo tee -a /etc/apt/sources.list.d/elastic-7.x.list\r\n   24  sudo apt update\r\n   25  sudo apt install -y elasticsearch-oss\r\n   26  sudo systemctl enable elasticsearch\r\n   27  sudo systemctl start elasticsearch\r\n   28  sudo apt install -y php-common php8.3-common php8.3-cli php8.3-curl php-json php8.3-ldap php8.3-mysql php8.3-opcache php8.3-readline php8.3-xml php8.3-mbstring php8.3-xsl php8.3-zip php-apcu\r\n   29  sudo apt install -y --no-install-recommends fop libsaxon-java\r\n   30  sudo update-java-alternatives -s java-1.11.0-openjdk-amd64\r\n   31  sudo apt install -y imagemagick ghostscript poppler-utils ffmpeg\r\n   32  apt install nginx\r\n   33  cd /usr/share/nginx\r\n   34  ls\r\n   35  wget https://storage.accesstomemory.org/releases/atom-latest.tar.gz\r\n   36  sudo mkdir -p /usr/share/nginx/atom\r\n   37  sudo tar xzf atom-latest.tar.gz -C /usr/share/nginx/atom --strip 1\r\n   38  ls\r\n   39  rm -rf atom-latest.tar.gz \r\n   40  rm -rf atom/\r\n   41  sudo apt install -y git\r\n   42  sudo git clone -b stable/2.10.x http://github.com/artefactual/atom.git /usr/share/nginx/atom\r\n   43  cd /usr/share/nginx/atom\r\n   44  sudo composer install --no-dev\r\n   45  sudo ~/composer.phar install --no-dev\r\n   46  ls\r\n   47  sudo ~/composer.phar install --no-dev\r\n   48  php -r \"copy('https://getcomposer.org/installer', 'composer-setup.php');\"\r\n   49  php -r \"if (hash_file('sha384', 'composer-setup.php') === 'c8b085408188070d5f52bcfe4ecfbee5f727afa458b2573b8eaaf77b3419b0bf2768dc67c86944da1544f06fa544fd47') { echo 'Installer verified'.PHP_EOL; } else { echo 'Installer corrupt'.PHP_EOL; unlink('composer-setup.php'); exit(1); }\"\r\n   50  php composer-setup.php\r\n   51  php -r \"unlink('composer-setup.php');\"\r\n   52  sudo ~/composer.phar install --no-dev\r\n   53  sudo mv composer.phar /usr/local/bin/composer\r\n   54  sudo ~/composer.phar install --no-dev\r\n   55  ls\r\n   56  sudo mysql -h localhost -u root -p -e \"CREATE DATABASE atom CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci;\"\r\n   57  sudo mysql -h localhost -u root -p -e \"CREATE USER 'atom'@'localhost' IDENTIFIED BY '12345';\"\r\n   58  sudo mysql -h localhost -u root -p -e \"GRANT ALL PRIVILEGES ON atom.* TO 'atom'@'localhost';\"\r\n   59  sudo php symfony tools:install\r\n   60  sudo sudo php symfony tools:install\r\n   61  cd ..\r\n   62  ls\r\n   63  rm -rf atom/\r\n   64  wget https://storage.accesstomemory.org/releases/atom-latest.tar.gz\r\n   65  sudo tar xzf atom-latest.tar.gz -C /usr/share/nginx/atom --strip 1\r\n   66  ls\r\n   67  sudo tar xzf atom-latest.tar.gz -C /usr/share/nginx/atom --strip 1\r\n   68  sudo mkdir -p /usr/share/nginx/atom\r\n   69  sudo tar xzf atom-latest.tar.gz -C /usr/share/nginx/atom --strip 1\r\n   70  sudo ~/composer.phar install --no-dev\r\n   "]
