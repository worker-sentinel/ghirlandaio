[0.015, "o", "\u001b[c\u001b[?2026h\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# mkinitcpio preset file for the 'linux-hardened' package\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                            \r\n                                                                                                                                                                                                                     \r\nALL_config=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/etc/mkinitcpio.d/default.conf\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                          \r\nALL_kver=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/boot/kernel/vmlinuz-linux-hardened\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                       \r\nALL_kerneldest=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/boot/kernel/vmlinuz-linux-hardened\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                 \r\n                                                                                                                                                                                                                     \r\nPRESETS=(\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m'default'\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m)                                                                                                                                                                                                  \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#PRESETS=('default' 'fallback')\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                                      \r\n                                                                                                                                                                                                                     \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#default_config=\"/etc/mkinitcpio.conf\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                               \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#default_image=\"/boot/initramfs-linux-hardened.img\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                  \r\ndefault_uki=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/boot/efi/Linux/arch-linux-hardened.efi\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                         