[0.000, "o", "                                         \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#fallback_image=\"/boot/initramfs-linux-hardened-fallback.img\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                        \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#fallback_uki=\"/efi/EFI/Linux/arch-linux-hardened-fallback.efi\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                      \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m#fallback_options=\"-S autodetect\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                                    \r\n\u001b(B\u001b[m\u001b[38:2:79:82:88m\u001b[48:2:20:22:27m~                                                                                                                                                                                                                    \r\n~                                                                                                                                                                                                                    \r\n~                                                                                                                                                                                                                    \r\n~                                                                                                                                                                                                                