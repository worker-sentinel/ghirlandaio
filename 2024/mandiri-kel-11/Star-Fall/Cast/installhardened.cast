[0.012, "o", "\u001b[c\u001b[?2026h\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m# mkinitcpio preset file for the 'linux-hardened' package\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                            \r\n                                                                                                                                                                                                                     \r\nALL_config=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/etc/mkinitcpio.d/default.conf\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                          \r\nALL_kver=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/boot/kernel/vmlinuz-linux-hardened\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                       \r\nALL_kerneldest=\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m\"/boot/kernel/vmlinuz-linux-hardened\"\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                                                                                                 \r\n                                                                                                                                                                                                                     \r\nPRESETS=(\u001b(B\u001b[m\u001b[38:2:179:246:192m\u001b[48:2:20:22:27m'default'\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m)                            