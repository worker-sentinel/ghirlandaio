[0.000, "o", "                                                                                                             \u001b[20;1H                                                                                              \u001b[30m\u001b[47m┌─┤ \u001b[31mNetworkManager TUI\u001b[30m ├──┐\u001b[97m\u001b[44m                                                                                            \u001b[21;1H                                                                                              \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m                                                                                           \u001b[22;1H                                                                                              \u001b[30m\u001b[47m│ \u001b[34mPlease select an option\u001b[30m │\u001b[97m\u001b[40m \u001b[44m                                                                                           \u001b[23;1H                                                                                              \u001b[30m\u001b[47m│                         │\u001b[97m\u001b[40m \u001b[44m                                                                                           \u001b[24;1H                                                                                              \u001b[30m\u001b[47m│ \u001b[37m\u001b[41mEdit a connection      \u001b[30m\u001b[47m │\u001b[97m\u001b[40m \u001b[44m                                                                                           \u001b[25;1H                                                                                              \u001b[30m\u001b[47m│ Activate a connection   │\u001b[97m\u001b[40m \u001b[44m                                                                                           \u001b[26;1H                                                                                              \u001b[30m\u001b[47m│ Set system hostname     │\u00