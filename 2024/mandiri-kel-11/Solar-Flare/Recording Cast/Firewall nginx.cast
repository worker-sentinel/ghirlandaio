[0.011, "o", "\u001b[?25l\u001b[m\u000f\u001b[K\n\u001b[96muser\u001b[m\u000f http;\u001b[K\r\n\u001b[96mworker_processes\u001b[m\u000f  1;\u001b[K\r\n\u001b[K\n#error_log  logs/error.log;\u001b[K\r\n#error_log  logs/error.log  notice;\u001b[K\r\n#error_log  logs/error.log  info;\u001b[K\r\n\u001b[K\n#pid        logs/nginx.pid;\u001b[K\r\n\u001b[K\n\u001b[K\n# Load all installed modules\u001b[K\r\ninclude modules.d/*.conf;\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000fevents\u001b[m\u000f {\u001b[K\r\n    \u001b[96mworker_connections\u001b[m\u000f  1024;\u001b[K\r\n}\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[0;10;1m\u000fhttp\u001b[m\u000f {\u001b[K\r\n    include       mime.types;\u001b[K\r\n    \u001b[96mdefault_type\u001b[m\u000f  \u001b[96mapplication\u001b[m\u000f/octet-stream;\u001b[K\r\n\u001b[K\n    #log_format  main  '$remote_addr - $remote_user [$time_local] \"$request\" '\u001b[K\r\n    #                  '$status $body_bytes_sent \"$http_referer\" '\u001b[K\r\n    #                  '\"$http_user_agent\" \"$http_x_forwarded_for\"';\u001b[K\r\n\u001b[K\n    #access_log  logs/access.log  main;\u001b[K\r\n\u001b[K\n    \u001b[96msendfile\u001b[m\u000f        on;\u001b[K\r\n    #tcp_nopush     on;\u001b[K\r\n\u001b[K\n    #keepalive_timeout  0;\u001b[K\r\n    \u001b[96mkeepalive_timeout\u001b[m\u000f  65;\u001b[K\r\n\u001b[K\n    #gzip  on;\u001b[K\r\n\u001b[K\n    \u001b[0;10;1m\u000fserver\u001b[m\u000f {\u001b[K\r\n        listen       80;\u001b[K\r\n        server_name  localhost;\u001b[K\r\n\u001b[K\n        #access_log  logs/host.access.log  main;\u001b[K\r\n\u001b[K\n        \u001b[0;10;1m\u000flocation\u001b[m\u000f / {\u001b[K\r\n            root   /usr/share/nginx/html;\u001b[K\r\n            \u001b[96mindex\u001b[m\u000f  \u001b[96mindex\u001b[m\u000f.html \u001b[96mindex\u001b[m\u000f.htm;\u001b[K\r\n        }\u001b[K\r\n\u001b[K\n        #error_page  404              /404.html;\u001b[K\r\n\u001b[K\n        # redirect server error pages to the static page