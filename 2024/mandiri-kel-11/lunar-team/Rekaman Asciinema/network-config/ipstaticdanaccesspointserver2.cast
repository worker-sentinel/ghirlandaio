[0.474, "o", "\r\u001b[K\u001b[7A                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n                                                                                \r\n\u001b[7A\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot\r\u001b[K                                    Devices\u001b[1;90m                                    \u001b[0m\r\n"]
[0.002, "o", "\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot\r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot"]
[0.000, "o", "\r\u001b[K\u001b[1;90m  Name                  Address               Powered     Adapter     Mode      \r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot\r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot\r\u001b[K  wlan0                 32:21:47:58:e0:d4     on          phy0        ap          \r\n\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot\r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot\r\u001b[K\u0001\u001b[32m\u0002[iwd]\u0001\u001b[0m\u0002# device wlan0 set-property Mode ap \r\n\u001b[32m[iwd]\u001b[0m# ap wlan0 start-profile myhotspot"]
