[0.001, "o", "\u001b[39;49m\u001b[m\u000f\u001b[H\u001b[J\u001b[46;79H\u001b[0;10;7m\u000f[ Reading... ]\u001b[m\u000f\u001b[46;77H\u001b[0;10;7m\u000f[ Read 24 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                     /etc/systemd/network/20-ethernet.network                                                               \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d[Match]\r\u001b[3dType=ether\r\u001b[4d# Exclude virtual Ethernet interfaces\r\u001b[5dKind=!*\r\u001b[7d[Link]\r\u001b[8dRequiredForOnline=routable\r\u001b[10d[Network]\r\u001b[11dAddress=10.10.10.3/24\r\u001b[12dGateway=10.10.10.1\r\u001b[13dDNS=1.1.1.1 8.8.8.8\r\u001b[14dMulticastDNS=yes\r\u001b[16d# systemd-networkd does not set per-interface-type default route metrics\r\u001b[17d# https://github.com/systemd/systemd/issues/17698\r\u001b[18d# Explicitly set route metric, so that Ethernet is preferred over Wi-Fi and Wi-Fi is preferred over mobile broadband.\r\u001b[19d# Use values from NetworkManager. From nm_device_get_route_metric_default in\r\u001b[20d# https://gitlab.freedesktop.org/NetworkManager/NetworkManager/-/blob/main/src/core/devices/nm-device.c\r\u001b[21d[DHCPv4]\r\u001b[22dRouteMetric=100\r\u001b[24d[IPv6AcceptRA]\r\u001b[25dRouteMetric=100\r\u001b[2d\u001b[?25h\u001b[?0c"]
