[0.002, "o", "\u001b[1m\u001b[32m==>\u001b(B\u001b[m \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-lts.preset: 'default'\u001b(B\u001b[m\r\n\u001b[1m\u001b[32m==>\u001b(B\u001b[m \u001b[1mUsing configuration file: '/etc/mkinitcpio.d/default.conf'\u001b(B\u001b[m\r\n  \u001b[1m\u001b[34m->\u001b(B\u001b[m \u001b[1m-k /boot/vmlinuz-linux-lts -c /etc/mkinitcpio.d/default.conf -U /boot/efi/Linux/arch-linux-lts.efi\u001b(B\u001b[m\r\n"]
[0.013, "o", "==> ERROR: Invalid option -k -- '/boot/vmlinuz-linux-lts' must be readable\r\n"]
