[3.217, "o", "\r\n\u001b[?2004l\r\u001b[?2004h\u001b[32m[iwd]\u001b[0m# "]
[0.001, "o", "\r\u001b[K                               Available networks\u001b[1;90m                              \u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m      Network name                      Security            Signal\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K  \u001b[1;90m> \u001b[0m  allysa                            psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      babyhair                          psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      bach                              psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Warkop Kita 2                     psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Balifiber Free - Molecool         open                ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      JANGAN SOK IYE LOE                psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      oooal                             psk                 ***\u001b[1;90m*\u001b[0m    \r\n"]
