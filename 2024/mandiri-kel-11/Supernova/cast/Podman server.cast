[0.001, "o", "\u001b[?25l\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m\" ============================================================================\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m\" Netrw Directory Listing                                        \u001b(B\u001b[m\u001b[38;2;166;219;255m\u001b[48;2;20;22;27m(netrw v184)\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m\"   /root\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m\"   Sorted by\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m      name\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m\"   Sort sequence:\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m [\\/]$\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m,\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m*\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m,\u001b(B\u001b[0;1m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\\(\\.bak\\|\\~\\|\\.o\\|\\.h\\|\\.info\\|\\.swp\\|\\.obj\\)[*@]\\=$\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m\u001b[K\r\n\u001b(B\u001b[m\u001b[38;2;155;158;164m\u001b[48;2;20;22;27m\"   Quick Help: \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27m<F1>\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mhelp  \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27m-\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27m:\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[48;2;20;22;27mgo up dir  \u001b(B\u001b[m\u001b[38;2;140;248;247m\u001b[48;2;20;22;27mD\u001b(B\u001b[m\u001b[38;2;224;226;234m\u001b[4