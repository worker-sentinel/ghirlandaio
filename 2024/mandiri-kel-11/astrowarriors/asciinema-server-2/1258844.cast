[0.000, "o", "\u001b[?25l\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mMatch\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[m\u000f\u001b[K\r\nType=\u001b[92mwlan\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[96m[Link]\u001b[m\u000f\u001b[K\r\nRequiredForOnline=\u001b[92mroutable\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[96m[Network]\u001b[m\u000f\u001b[K\r\nDHCP=\u001b[92myes\u001b[m\u000f\u001b[K\r\nMulticastDNS=\u001b[92myes\u001b[m\u000f\u001b[K\r\n\u001b[K\n# systemd-networkd does not set per-interface-type default route metrics\u001b[K\r\n# https://github.com/systemd/systemd/issues/17698\u001b[K\r\n# Explicitly set route metric, so that Ethernet is preferred over Wi-Fi and Wi-Fi is preferred over mobile broadband.\u001b[K\r\n# Use values from NetworkManager. From nm_device_get_route_metric_default in\u001b[K\r\n# https://gitlab.freedesktop.org/NetworkManager/NetworkManager/-/blob/main/src/core/devices/nm-device.c\u001b[K\r\n\u001b[96m[DHCPv4]\u001b[m\u000f\u001b[K\r\nRouteMetric=600\u001b[K\r\n\u001b[K\n\u001b[96m[IPv6AcceptRA]\u001b[m\u000f\u001b[K\r\nRouteMetric=600\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000f/etc/systemd/network/20-wlan.network                                                                                                                    1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mMatch\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[m\u000f\u001b[K\r\nType=\u001b[92mwlan\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[96m[Link]\u001b[m\u000f\u001b[K\r\nRequiredForOnline=\u001b[92mroutable\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[96m[Network]\u001b[m\u000f\u001b[K\r\nDHCP=\u001b[92myes\u001b[m\u000f\u001b[K\r\nMulticastDNS=\u001b[92myes\u001b[m\u000f\u001b[K\r\n\u001b[K\n# systemd-networkd does not set per-interface-type default route metrics\u001b[K\r\n# https://github.com/systemd/systemd/issues/17698\u001b[K\r\n# Explicitly set route metric, so that Ethernet is preferred over Wi-Fi and Wi-Fi is preferred over mobile broadband.\u001b[K\r\n# Use values from NetworkManager. From nm_device_get_route_metric_default in\u001b[K\r\n# https://gitlab.freedesktop.org/NetworkManager/NetworkManager/-/blob/main/src/core/devices/nm-device.c\u001b[K\r\n\u001b[96m[DHCPv4]\u001b[m\u000f\u001b[K\r\nRouteMetric=600\u001b[K\r\n\u001b[K\n\u001b[96m[IPv6AcceptRA]\u001b[m\u000f\u001b[K\r\nRouteMetric=600\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n"]
