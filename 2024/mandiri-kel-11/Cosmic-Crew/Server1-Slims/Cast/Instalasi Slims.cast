[0.004, "o", "* Applying /usr/lib/sysctl.d/10-arch.conf ...\r\n* Applying /etc/sysctl.d/30-ipforward.conf ...\r\n* Applying /usr/lib/sysctl.d/50-coredump.conf ...\r\n* Applying /usr/lib/sysctl.d/50-default.conf ...\r\n"]
[0.001, "o", "* Applying /usr/lib/sysctl.d/50-pid-max.conf ...\r\n* Applying /etc/sysctl.d/99-custom.conf ...\r\n"]
[0.000, "o", "fs.inotify.max_user_instances = 1024\r\nfs.inotify.max_user_watches = 524288\r\nvm.max_map_count = 1048576\r\nnet.ipv4.tcp_keepalive_time = 120\r\n"]
[0.000, "o", "net.ipv4.ip_forward = 1\r\nkernel.core_pattern = |/usr/lib/systemd/systemd-coredump %P %u %g %s %t %c %h %d %F\r\nkernel.core_pipe_limit = 16\r\nfs.suid_dumpable = 2\r\nkernel.sysrq = 16\r\nkernel.core_uses_pid = 1\r\nnet.ipv4.conf.default.rp_filter = 2\r\n"]
[0.004, "o", "net.ipv4.conf.eno1.rp_filter = 2\r\nnet.ipv4.conf.lo.rp_filter = 2\r\n"]
[0.000, "o", "net.ipv4.conf.wlp3s0.rp_filter = 2\r\nnet.ipv4.conf.default.accept_source_route = 0\r\n"]
[0.000, "o", "net.ipv4.conf.eno1.accept_source_route = 0\r\nnet.ipv4.conf.lo.accept_source_route = 0\r\n"]
[0.000, "o", "net.ipv4.conf.wlp3s0.accept_source_route = 0\r\nnet.ipv4.conf.default.promote_secondaries = 1\r\n"]
[0.001, "o", "net.ipv4.conf.eno1.promote_secondaries = 1\r\nnet.ipv4.conf.lo.promote_secondaries = 1\r\n"]
[0.000, "o", "net.ipv4.conf.wlp3s0.promote_secondaries = 1\r\nnet.ipv4.ping_group_range = 0 2147483647\r\nnet.core.default_qdisc = fq_codel\r\nfs.protected_hardlinks = 1\r\nfs.protected_symlinks = 1\r\n"]
[0.000, "o", "fs.protected_regular = 1\r\nfs.protected_fifos = 1\r\nkernel.pid_max = 4194304\r\nnet.ipv4.ip_unprivileged_port_start = 80\r\nkernel.unprivileged_userns_clone = 1\r\n"]
