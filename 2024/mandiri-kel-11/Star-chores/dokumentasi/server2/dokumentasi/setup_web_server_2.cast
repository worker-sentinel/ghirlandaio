[0.000, "o", "#LoadModule rewrite_module modules/mod_rewrite.so\r\u001b[6d\u001b[K\u001b[7d<IfModule unixd_module>\u001b[K\u001b[8;3H\u001b[K\u001b[9dIf you wish httpd to run as a different user or group, you must run\u001b[10;3Hhttpd as root initially and it will switch.\u001b[11;3H\u001b[K\u001b[12dUser/Group: The name (or #number) of the user/group to run httpd as.\r\u001b[13d# It is usually good practice to create a dedicated user and group for\r\u001b[14d"]
[0.001, "o", "# running httpd, as with most system services.\r\u001b[16dUser http\u001b[K\r\u001b[17dGroup http\u001b[K\r\u001b[18d\u001b[K\u001b[19d</IfModule>\r\u001b[20d\u001b[K\u001b[21d# 'Main' server configuration\r\u001b[22d#\u001b[K\u001b[23d\b"]
[0.000, "o", "# The directives in this section set up the values used by the 'main'\r\u001b[24d# server, which responds to any requests that aren't handled by a\u001b[25;3H<VirtualHost> definition.  These values also provide defaults for\u001b[26;3H"]
[0.001, "o", "any <VirtualHost> containers you may define later in the file.\u001b[27;3H\u001b[K\u001b[28dAll of these directives may appear inside <VirtualHost> containers,\u001b[29;3Hin which case these default settings will be overridden for the\u001b[30;3Hvirtual host being defined.\r\u001b[31d#\u001b[32d\b"]
[0.000, "o", "\u001b[K\u001b[33d# \u001b[K\u001b[34dServerAdmin: Your address, where problems with the server should be\u001b[K\u001b[35;3He-mailed.  This address appears on some server-generated pages, such\u001b[36;3H"]
[0.001, "o", "as error documents.  e.g. admin@your-domain.com\r\u001b[37d#\u001b[K\u001b[21d\u001b[?12l\u001b[?25h"]
