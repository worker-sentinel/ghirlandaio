[0.001, "o", "\u001b[2d\b#\u001b[K\u001b[3d\b#Listen 12.34.56.78:80\u001b[K\r\u001b[4d"]
[0.000, "o", "Listen 80\u001b[K\r\u001b[5d\u001b[K\u001b[6d#\u001b[K\u001b[7d Dynamic Shared Object (DSO) Support\u001b[K\r\u001b[8d#\u001b[K\u001b[9d"]
[0.001, "o", " To be able to use the functionality of a module which was built as a DSO you\r\u001b[10d# have to place corresponding `LoadModule' lines at this location so the\r\u001b[11d# directives contained in it are actually available _before_ they are used.\r\u001b[12d#"]
[0.000, "o", " Statically compiled modules (those listed by `httpd -l') do not need\r\u001b[13d# to be loaded here.\u001b[K\r\u001b[14d#\u001b[K\u001b[15d"]
[0.001, "o", " Example:\u001b[K\r\u001b[16d# LoadModule foo_module modules/mod_foo.so\u001b[K\r\u001b[17d\u001b[K\u001b[18dLoadModule mpm_event_module modules/mod_mpm_event.so\u001b[19;13Hmpm_prefork_\u001b[31G modules/mod_mpm_prefork.so\u001b[20;13Hmpm_worker_module modules/mod_mpm_worker.so\r\u001b[21dLoadModule authn_file_module modules/mod"]
[0.000, "o", "_authn_file.so\u001b[22;13Hauthn_dbm\u001b[22;42Hauthn_dbm\r\u001b[23d#LoadModule authn_anon_module modules/mod_authn_anon.so\u001b[24;13Hauthn_dbd_module modules/mod_authn_dbd.so\u001b[K\u001b[25;13Hauthn_socache_module modules/mod_authn_socache.so\u001b[26;12Hauthn_core_module modules/mod_authn_core.so\u001b[27;12Hauthz_host_module modules/mod_au"]
[0.001, "o", "thz_host.so\r\u001b[28dLoadModule authz_groupfile_module modules/mod_authz_groupfile.so\r\u001b[29dLoadModule authz_user_module modules/mod_authz_user.so\u001b[K\u001b[30;13Hauthz_dbm_module modules/mod_authz_dbm.so\u001b[31;13Hauthz_owner_module modules/mod_authz_owner.so\u001b[K\u001b[32;13Hauthz_dbd_module modules/mod_authz_dbd.so\r\u001b[33dLoadModule authz_core_module modules/mod_authz_core.so\u001b[34;13Hauthnz_ldap_module modules/mod_authnz_ldap.so\u001b[35;13Hauthnz_fcgi_module modules/mod_authnz_fcgi.so\u001b[36;12Haccess_compat_module modules/mod_access_compat.so\r\u001b[37dLoadModule auth_basic_module modules/mod_auth_basic.so\r\u001b[21dL\u001b[?12l\u001b[?25h"]
[0.047, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[2d with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\u001b[3d# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\u001b[4d"]
[0.000, "o", "# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\"\r\u001b[5d# will be interpreted as '/logs/access_log'.\r\u001b[6d\u001b[K\u001b[7d# "]
[0.000, "o", "\u001b[K\u001b[8dServerRoot: The top of the directory tree under which the server's\u001b[9;3Hconfiguration, error, and log files are kept.\u001b[K\u001b[10;3H\u001b[K\u001b[11dDo not add a slash at the end of the directory path.  If you point\u001b[K\u001b[12;4HerverRoot at a non-local disk, be sure to specify a local disk on the\u001b[13;3H"]
[0.001, "o", "Mutex directive, if file-based mutexes are used.  If you wish to share the\u001b[14;3Hsame ServerRoot for multiple httpd daemons, you will need to change at\u001b[15;3Hleast PidFile.\u001b[16;3H\u001b[K\r\u001b[17dServerRoot \"/etc/httpd\"\r\u001b[18d\u001b[K\u001b[19d#\u001b[K\u001b[20d"]
[0.000, "o", " Mutex: Allows you to set the mutex mechanism and mutex file directory\r\u001b[21d"]
[0.001, "o", "# for individual mutexes, or change the global defaults\r\u001b[22d#\u001b[K\u001b[23d Uncomment and change the directory if mutexes are file-based and the default\r\u001b[24d# mutex file directory is not on a local disk or is not appropriate for some\r\u001b[25d# other reason.\u001b[K\r\u001b[26d#\u001b[K\u001b[27d\b# Mutex default:/run/httpd\u001b[K\r\u001b[28d\u001b[K\u001b[29d#\u001b[K\u001b[30d Listen: Allows you to bind Apache to specific IP addresses and/or\r\u001b[31d#"]
[0.000, "o", " ports, instead of the default. See also the <VirtualHost>\r\u001b[32d# directive.\u001b[K\r\u001b[33d#\u001b[K\u001b[34d Change this to Listen on specific IP addresses as shown below to\r\u001b[35d# prevent Apache from glomming onto all bound IP addresses.\r\u001b[36d#\u001b[K\u001b[37d\b"]
[0.000, "o", "#Listen 12.34.56.78:80\u001b[K\r\u001b[21d#\u001b[?12l\u001b[?25h"]
[0.048, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[2;37r\u001b[2;1H\u001b[15T\u001b[1;40r\u001b[2;1H#\u001b[3d\b"]
