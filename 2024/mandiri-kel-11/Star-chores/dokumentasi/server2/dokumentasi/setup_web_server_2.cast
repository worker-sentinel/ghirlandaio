[0.001, "o", "Note: The following must be present to support\u001b[K\u001b[10;3H      starting without SSL on platforms with no /dev/random equivalent\u001b[K\u001b[11;3H      but a statically compiled-in mod_ssl.\u001b[K\u001b[12;3H\u001b[K\r\u001b[13d<IfModule ssl_module>\r\u001b[14dSSLRandomSeed startup builtin\r\u001b[15dSSLRandomSeed connect builtin\u001b[K\r\u001b[16d</IfModule>\r\u001b[17d\u001b[K\u001b[18dIncludeOptional conf/conf.d/*.conf\u001b[K\r\u001b[19d\u001b[K\u001b[20;12H\u001b[30m\u001b[103mphp_module\u001b[39;49m\u001b(B\u001b[m \u001b[29Gs/libphp.so\u001b[K\r\u001b[21dAddHandler php-script .php\u001b[K\r\u001b[22dInclude conf/extra/php\u001b[30G.conf\u001b[K\r\u001b[23d\u001b[K\u001b[24d\u001b[K\u001b[25d\u001b[K\u001b[26d\u001b[K\u001b[27d\u001b[K\u001b[28d\u001b[K\u001b[29d\u001b[K\u001b[30d\u001b[K\u001b[31d\u001b[K\u001b[32d\u001b[K\u001b[33d\u001b[K\u001b[34d\u001b[K\u001b[35d\u001b[K\u001b[36d\u001b[K\u001b[37d\u001b[K\u001b[20;12H"]
