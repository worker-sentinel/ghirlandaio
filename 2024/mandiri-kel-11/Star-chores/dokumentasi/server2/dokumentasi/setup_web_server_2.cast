[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d\n\u001b[1;40r\u001b[37;1H# mutex file directory is not on a local disk or is not appropriate for some\r"]
[0.050, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H# other reason.\r"]
[0.049, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H#\b"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# Mutex default:/run/httpd\r"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.002, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d\n\u001b[1;40r\u001b[37;1H"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H#\b"]
[0.049, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d\n\u001b[1;40r\u001b[37;1H# Listen: Allows you to bind Apache to specific IP addresses and/or\r"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# ports, instead of the default. See also the <VirtualHost>\r"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d\n\u001b[1;40r\u001b[37;1H# directive.\r"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H#\b"]
[0.049, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d\n\u001b[1;40r\u001b[37;1H# Change this to Listen on specific IP addresses as shown below to\r"]
[0.051, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H# prevent Apache from glomming onto all bound IP addresses.\r"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H#\b"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H#Listen 12.34.56.78:80\r"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1HListen 80\r"]
[0.050, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H#\b"]
[0.050, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# Dynamic Shared Object (DSO) Support\r"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b7\u001b[2;38r\u001b8\u001b[38d\n\u001b[1;40r\u001b[37;1H#\b"]
[0.050, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# To be able to use the functionality of a module which was built as a DSO you\r"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.003, "o", "\n\u001b[1;40r\u001b[37;1H# have to place corresponding `LoadModule' lines at this location so the\r"]
[0.048, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# directives contained in it are actually available _before_ they are used.\r"]
[0.050, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.000, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.001, "o", "\n\u001b[1;40r\u001b[37;1H# Statically compiled modules (those listed by `httpd -l') do not need\r"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# to be loaded here.\r"]
[0.049, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H#\b"]
[0.049, "o", "\u001b[?25l\u001b[?12l\u001b[?25h"]
[0.001, "o", "\u001b7\u001b[2;38r\u001b8\u001b[38d"]
[0.000, "o", "\n\u001b[1;40r\u001b[37;1H# Example:\r"]
