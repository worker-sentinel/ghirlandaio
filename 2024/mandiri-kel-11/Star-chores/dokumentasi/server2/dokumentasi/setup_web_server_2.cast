[0.004, "o", "\r\u001b[K\u001b[39;17H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut          \u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute      \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location     \u001b(B\u001b[0;7mM-U\u001b(B\u001b[m Undo        \u001b(B\u001b[0;7mM-A\u001b(B\u001b[m Set Mark\u001b[40;2H\u001b(B\u001b[0;7mX\u001b(B\u001b[m Exit  \u001b[17G\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[49G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste        \u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify      \u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line   \u001b(B\u001b[0;7mM-E\u001b(B\u001b[m Redo\u001b[40;113H\u001b(B\u001b[0;7mM-6\u001b(B\u001b[m Copy\r\u001b[2d# memory-mapping or the sendfile syscall may be used to deliver\u001b[3;3Hfiles.  This usually improves server performance, but must\u001b[4;3Hbe turned off when serving from networked-mounted\u001b[K\u001b[5;4Hilesystems or if support for these functions is otherwise\u001b[6;3Hbroken on your system.\u001b[7;3HDefaults: EnableMMAP On, EnableSendfile Off\u001b[K\u001b[8;3H\u001b[K\u001b[9d\bEnableMMAP off\r\u001b[10d#EnableSendfile on\r\u001b[11d\u001b[K\u001b[12d"]
[0.001, "o", "# Supplemental configuration\u001b[14;3HThe configuration files in the conf/extra/ directory can be\u001b[K\u001b[15;3Hincluded to add extra features or to modify the default configuration of\u001b[16;3Hthe server, or you may simply copy their contents here and change as\u001b[17;3Hnecessary.\r\u001b[18d\u001b[K\u001b[19d# Server-pool management (MPM specific)\u001b[K\r\u001b[20d"]
[0.000, "o", "\u001b[30m\u001b[103mInclude conf\u001b[39;49m\u001b(B\u001b[m/extra/httpd-mpm.conf\r\u001b[21d\u001b[K\u001b[22d# Multi-language error messages\r\u001b[23dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[24d\u001b[K\u001b[25d# Fancy directory listings\u001b[K\r\u001b[26dInclude conf/extra/httpd-autoindex.conf\r\u001b[27d\u001b[K\u001b[28d# Language settings\u001b[K\r\u001b[29dInclude conf/extra/httpd-languages.conf\u001b[K\r\u001b[30d\u001b[K\u001b[31d# User home directories\r\u001b[32dInclude conf/extra/httpd-userdir.conf\r\u001b[33d\u001b[K\u001b[34d# Real-time info on requests and configuration\r\u001b[35d#Include conf/extra/httpd-info.conf\r\u001b[36d\u001b[K\u001b[37d# Virtual hosts\u001b[K\r\u001b[20d"]
