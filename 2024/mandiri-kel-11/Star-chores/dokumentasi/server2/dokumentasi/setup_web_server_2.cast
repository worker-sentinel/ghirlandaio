[0.003, "o", "\r\u001b[39d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[39;17H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut\u001b[39;65H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute\u001b[81G\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location     \u001b(B\u001b[0;7mM-U\u001b(B\u001b[m Undo\u001b[39;113H\u001b(B\u001b[0;7mM-A\u001b(B\u001b[m Set Mark\r\u001b[40d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Exit\u001b[40;17H\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[49G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste\u001b[40;65H\u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[81G\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line   \u001b(B\u001b[0;7mM-E\u001b(B\u001b[m Redo\u001b[40;113H\u001b(B\u001b[0;7mM-6\u001b(B\u001b[m Copy\r\u001b[2d#\u001b[3d\b# This is the main Apache HTTP server configuration file.  It contains the\r\u001b[4d# configuration directives that give the server its instructions.\r\u001b[5d# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\r\u001b[6d# In particular, see\r\u001b[7d# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\r\u001b[8d# for a discussion of each configuration directive.\r\u001b[9d#\u001b[10d\b# Do NOT simply read the instructions in here without understanding\r\u001b[11d# what they do.  They're here only as hints or reminders.  If you are unsure\r\u001b[12d# consult the online docs. You have been warned.\r\u001b[13d#\u001b[14d\b# Configuration and logfile names: If the filenames you specify for many\r\u001b[15d# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\r\u001b[16d# server will use that explicit path.  If the filenames do *not* begin\r\u001b[17d# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\u001b[18d# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\u001b[19d# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\"\r\u001b[20d# will be interpreted as '/logs/access_log'.\r\u001b[22d#\u001b[23d\b# ServerRoot: The top of the directory tree under which the server's\r\u001b[24d"]
[0.000, "o", "# configuration, error, and log files are kept.\r\u001b[25d#\u001b[26d\b"]
[0.000, "o", "# Do not add a slash at the end of the directory path.  If you point\r\u001b[27d# ServerRoot at a non-local disk, be sure to specify a local disk on the\r\u001b[28d# Mutex directive, if file-based mutexes are used.  If you wish to share the\r\u001b[29d# same ServerRoot for multiple httpd daemons, you will need to change at\r\u001b[30d# least PidFile.\r\u001b[31d#\u001b[32d\bServerRoot \"/etc/httpd\"\r\u001b[34d#\u001b[35d\b# Mutex: Allows you to set the mutex mechanism and mutex file directory\r\u001b[36d# for individual mutexes, or change the global defaults\r\u001b[37d#\u001b[2d\b\u001b[?12l\u001b[?25h"]
