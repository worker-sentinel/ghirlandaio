[0.001, "o", ".so\u001b[K\r\u001b[17d#LoadModule speling\u001b[17;41Hpeling.so\u001b[K\u001b[18;12Huserdir\u001b[18;39Huserdir\r\u001b[19dLoadModule alias_module modules/mod_alias.so\u001b[K\r\u001b[20d#\u001b[30m\u001b[103mLoadModule rewrite_module\u001b[39;49m\u001b(B\u001b[m modules/mod_rewrite.so\r\u001b[21d\u001b[K\u001b[22d<IfModule unixd_module>\u001b[K\r\u001b[23d#\u001b[K\u001b[24d If you wish httpd to run as a different user or group, you must run\r\u001b[25d# httpd as root initially and it will switch.\u001b[K\r\u001b[26d#\u001b[K\u001b[27d User/Group: The name (or #number) of the user/group to run httpd as.\r\u001b[28d#"]
[0.000, "o", " It is usually good practice to create a dedicated user and group for\r\u001b[29d# running httpd, as with most system services.\u001b[K\r\u001b[30d#\u001b[K\u001b[31d\bUser http\u001b[K\r\u001b[32dGroup http\u001b[K\r\u001b[33d\u001b[K\u001b[34d</IfModule>\u001b[K\r\u001b[35d\u001b[K\u001b[36d#"]
