[0.002, "o", "\u001b[38;49H\u001b(B\u001b[0;1m\u001b[37m\u001b[41m[ \"include conf/httpd-php\" not found ]\u001b[39;49m\u001b(B\u001b[m"]
[0.001, "o", "\u001b[39;17H"]
[0.000, "o", "\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is     \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut          \u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute      \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location     \u001b(B\u001b[0;7mM-U\u001b(B\u001b[m Undo        \u001b(B\u001b[0;7mM-A\u001b(B\u001b[m Set Mark\u001b[40;2H\u001b(B\u001b[0;7mX\u001b(B\u001b[m Exit  \u001b[17G\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File    \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[49G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste        \u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify      \u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line   \u001b(B\u001b[0;7mM-E\u001b(B\u001b[m Redo\u001b[40;113H\u001b(B\u001b[0;7mM-6\u001b(B\u001b[m Copy\u001b[?12l\u001b[?25h\r\u001b[22d#"]
[6.694, "o", "\u001b[?25l\u001b[?12l\u001b[?25h\u001b[A"]
[0.840, "o", "\u001b[?25l\u001b[2d\b# the server, or you may simply copy their contents here and change as\r\u001b[3d# necessary.\u001b[K\r\u001b[4d\u001b[K\u001b[5d# Server-pool management (MPM specific)\r\u001b[6dInclude conf/extra/httpd-mpm.conf\r\u001b[7d"]
[0.002, "o", "\u001b[K\u001b[8d# Multi-language error messages\r\u001b[9dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[10d\u001b[K\u001b[11d# Fancy directory listings\u001b[K\r\u001b[12dInclude conf/extra/httpd-autoindex.conf\r\u001b[13d\u001b[K\u001b[14d# Language settings\u001b[K\r\u001b[15dInclude conf/extra/httpd-languages.conf\r\u001b[16d\u001b[K\u001b[17d# User home directories\u001b[18;8H conf/extra/httpd-userdir.conf\r\u001b[20d# Real-time info on requests and configuration\r\u001b[21d#Include conf/extra/httpd-info.conf\r\u001b[22d\u001b[K\u001b[23d# Virtual hosts\r\u001b[24d#Include conf/extra/httpd-vhosts.conf\r\u001b[26d# Local access to the Apache HTTP Server Manual\r\u001b[27d#Include conf/extra/httpd-manual.conf\r\u001b[29d# Distributed authoring and versioning (WebDAV)\r\u001b[30d#Include conf/extra/httpd-dav.conf\r\u001b[32d# Various default settings\r\u001b[33dInclude conf/extra/httpd-default.conf\r\u001b[35d# Configure mod_proxy_html to understand HTML4/XHTML1\r\u001b[36d<IfModule proxy_html_module>\r\u001b[37dInclude conf/extra/proxy-html.conf\r\u001b[21d#\u001b[?12l\u001b[?25h"]
[0.499, "o", "\u001b[?25l\u001b[2d \u001b[K\u001b[3dCustomizable error responses come in three flavors:\r\u001b[4d# 1) plain text 2) local redirects 3) external redirects\u001b[5;3H\u001b[K\r\u001b[6d# Some examples:\u001b[K\r\u001b[7d#ErrorDocument 500 \"The server made a boo boo.\"\r\u001b[8d#ErrorDocument 404 /missing.html\r\u001b[9d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\r\u001b[10d#ErrorDocument 402 http://www.example.com/subscription_info.html\u001b[11;3H\u001b[K\r\u001b[12d\u001b[K\u001b[13d#\u001b[14d MaxRanges: Maximum number of Ranges in a request before\r\u001b[15d# returning the entire resource, or one of the special\r\u001b[16d# values 'default', 'none' or 'unlimited'.\u001b[17;3HDefault setting is to accept 200 Ranges.\r\u001b[18d#MaxRanges unlimited\u001b[K\u001b[20;3H\u001b[K\u001b[21d\b EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[22d# memory-mapping or the sendfile syscall may be used to deliver\u001b[23;3Hfiles.  This usually improves server performance, but must\r\u001b[24d# be turned off when serving from networked-mounted\r\u001b[25d# filesystems or if support for these functions is otherwise\u001b[26;3Hbroken on your system.\u001b[K\r\u001b[27d# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[28d#\u001b[29dEnableMMAP off\u001b[K\r\u001b[30d#EnableSendfile on\u001b[K\u001b[32;3HSupplemental configuration\r\u001b[33d#\u001b[K\u001b[34d\b# The configuration files in the conf/extra/ directory can be\u001b[35;3Hincluded to add extra features or to modify the default configuration of\r\u001b[36d# the server, or you may simply copy their contents here and change as\r\u001b[37d# necessary.\u001b[K\r\u001b[21d#\u001b[?12l\u001b[?25h"]
[0.049, "o", "\u001b[?25l\u001b[2d\b    #\r\u001b[3d    AddType application/x-compress .Z\u001b[K\r\u001b[4d    AddType application/x-gzip .gz .tgz\u001b[K\r\u001b[5d\u001b[K\u001b[6d    #\u001b[K\r\u001b[7d    # AddHandler allows you to map certain file extensions to \"handlers\":\r\u001b[8d    # actions unrelated to filetype. These can be either built into the server\r\u001b[9d    # or added with the Action directive (see below)\r\u001b[10d    #\u001b[K\r\u001b[11d    # To use CGI scripts outside of ScriptAliased directories:\u001b[12;5H# (You will also need to add \"ExecCGI\" to the \"Options\" directive.)\r\u001b[13d    #\r\u001b[14d    #AddHandler cgi-script .cgi\u001b[K\r\u001b[15d\u001b[K\u001b[16d    # For type maps (negotiated resources):\r\u001b[17d"]
[0.001, "o", "    #AddHandler type-map var\u001b[K\r\u001b[18d\u001b[K\u001b[19;5H#\r\u001b[20d    # Filters allow you to process content before it is sent to the client.\r\u001b[21d    #\u001b[K\r\u001b[22d"]
[0.001, "o", "    # To parse .shtml files for server-side includes (SSI):\u001b[K\r\u001b[23d    # (You will also need to add \"Includes\" to the \"Options\" directive.)\r\u001b[24d    #\u001b[K\r\u001b[25d    #AddType text/html .shtml\u001b[K\r\u001b[26d    #AddOutputFilter INCLUDES .shtml\r\u001b[27d</IfModule>\u001b[K\r\u001b[28d\u001b[K\u001b[29d#\u001b[K\u001b[30d The mod_mime_magic module allows the server to use various hints from the\r\u001b[31d# contents of the file itself to determine its type.  The MIMEMagicFile\u001b[32;3H"]
[0.002, "o", "directive tells the module where the hint definitions are located.\r\u001b[34d#MIMEMagicFile conf/magic\u001b[K\r\u001b[35d\u001b[K\u001b[36d# \u001b[K\u001b[37dCustomizable error responses come in three flavors:\r\u001b[21d \u001b[?12l\u001b[?25h"]
[0.044, "o", "\u001b[?25l"]
[0.003, "o", "\u001b[2;5HOptions None\u001b[3;5HRequire all granted\u001b[K\r\u001b[4d</Directory>\u001b[K\r\u001b[6d<IfModule headers_module>\u001b[7;7H\u001b[K\u001b[8dAvoid passing HTTP_PROXY environment to CGI's on this or any proxied\u001b[K\u001b[9;7Hbackend servers which have lingering \"httpoxy\" defects.\u001b[10;7H'Proxy' request header is undefined by the IETF, not listed by IANA\u001b[11;7H\u001b[K\u001b[12d\b\bRequestHeader unset Proxy early\u001b[K\r\u001b[13d</IfModule>\r\u001b[14d\u001b[K\u001b[15d<IfModule mime_module>\u001b[16;7H\u001b[K\u001b[17d\b TypesConfig points to the file containing the list of mappings from\u001b[18;5H# filename extension to MIME-type.\u001b[20;5HTypesConfig conf/mime.types\u001b[K\r\u001b[21d\u001b[K\u001b[22;7H\u001b[K\u001b[23dAddType allows you to add to or override the MIME configuration\u001b[K\u001b[24;7Hfile specified in TypesConfig for specific file types.\u001b[25;6H\u001b[K\u001b[26;9HType application/x-gzip .tgz\r\u001b[27d    #\u001b[K\u001b[28d\b# AddEncoding allows you to have certain browsers uncompress\r\u001b[29d    # information on the fly. Note: Not all browsers support this.\r\u001b[30d    #\u001b[K\r\u001b[31d    #AddEncoding x-compress .Z\u001b[K\r\u001b[32d    #AddEncoding x-gzip .gz .tgz\u001b[K\r\u001b[33d    #\r\u001b[34d    # If the AddEncoding directives above are commented-out, then you\u001b[35;5H"]
[0.001, "o", "# probably should define those extensions to indicate media types:\r\u001b[36d    #\r\u001b[37d    AddType application/x-compress .Z\u001b[K\r\u001b[21d\u001b[?12l\u001b[?25h"]
[0.046, "o", "\u001b[?25l"]
[0.002, "o", "\u001b[2;5H# Example:\u001b[K\u001b[3;5H# Alias /webpath /full/filesystem/path\r\u001b[4d    #\u001b[K\u001b[5d\b# If you include a trailing / on /webpath then the server will\r\u001b[6d    # require it to be present in the URL.  You will also likely\u001b[7;7Hneed to provide a <Directory> section to allow access to\u001b[8;7Hthe filesystem path.\u001b[K\r\u001b[9d\u001b[K\u001b[10;7H\u001b[K\u001b[11dScriptAlias: This controls which directories contain server scripts.\u001b[12;5H# ScriptAliases are essentially the same as Aliases, except that\r\u001b[13d    # documents in the target directory are treated as applications and\u001b[14;5H# run by the server when requested rather than as documents sent to the\r\u001b[15d    # client.  The same rules about trailing \"/\" apply to ScriptAlias\u001b[16;7Hdirectives as to Alias.\u001b[17;7H\u001b[K\u001b[18d\b\bScriptAlias /cgi-bin/ \"/srv/http/cgi-bin/\"\r\u001b[19d\u001b[K\u001b[20d"]
[0.001, "o", "</IfModule>\u001b[K\r\u001b[22d<IfModule cgid_module>\u001b[23;7H"]
[0.001, "o", "\u001b[K\u001b[24dScriptSock: On threaded servers, designate the path to the UNIX\u001b[25;7Hsocket used to communicate with the CGI daemon of mod_cgid.\u001b[26;6H\u001b[K\u001b[27dScriptsock cgisock\r\u001b[28d</IfModule>\u001b[K\r\u001b[29d\u001b[K\u001b[30d#\u001b[K\u001b[31d\b# \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\r\u001b[32d# CGI directory exists, if you have that configured.\r\u001b[33d#\u001b[K\u001b[34d\b<Directory \"/srv/http/cgi-bin\">\u001b[K\u001b[35;5HAllowOverride None\u001b[K\u001b[36;5HOptions None\u001b[37;5HRequire all granted\u001b[K\r\u001b[21d\u001b[?12l\u001b[?25h"]
[0.049, "o", "\u001b[?25l\u001b[2;5HLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b\" common\r\u001b[3d\u001b[K\u001b[4;5H<IfModule logio_module>\u001b[5;5H  # You need to enable mod_logio.c to use %I and %O\u001b[K\u001b[6;5H  LogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\" combinedio\u001b[7;5H</IfModule>\u001b[K\r\u001b[8d\u001b[K\u001b[9;5H"]
[0.002, "o", "#\u001b[10d The location and format of the access logfile (Common Logfile Format).\u001b[11;7HIf you do not define any access logfiles within a <VirtualHost>\u001b[K\u001b[12;7Hcontainer, they will be logged here.  Contrariwise, if you *do*\u001b[13;8Hefine per-<VirtualHost> access logfiles, transactions will be\u001b[K\u001b[14;7Hlogged therein and *not* in this file.\u001b[K\u001b[15;7H\u001b[K\u001b[16d\b\b"]
[0.002, "o", "CustomLog \"/var/log/httpd/access_log\" common\r\u001b[17d\u001b[K\u001b[18;5H#\u001b[K\u001b[19d\b# If you prefer a logfile with access, agent, and referer information\r\u001b[20d    # (Combined Logfile Format) you can use the following directive.\u001b[21;5H#\r\u001b[22d    #CustomLog \"/var/log/httpd/access_log\" combined\r\u001b[23d</IfModule>\r\u001b[24d\u001b[K\u001b[25d<IfModule alias_module>\u001b[K\u001b[27;6H Redirect: Allows you to tell clients about documents that used to\r\u001b[28d    # exist in your server's namespace, but do not anymore. The client\u001b[29;5H# will make a new request for the document at its new location.\r\u001b[30d    # Example:\r\u001b[31d"]
[0.001, "o", "    # Redirect permanent /foo http://www.example.com/bar\u001b[K\r\u001b[32d\u001b[K\u001b[33d    #\r\u001b[34d    # Alias: Maps web paths into filesystem paths and is used to\u001b[35;5H# access content that does not live under the DocumentRoot.\u001b[36;5H# Example:\u001b[K\u001b[37;5H# Alias /webpath /full/filesystem/path\r\u001b[21d \u001b[?12l\u001b[?25h"]
[0.043, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[2d\b<IfModule dir_module>\u001b[K\u001b[3;5HDirectoryIndex index.html\r\u001b[4d</IfM"]
[0.000, "o", "\u001b[16P\r\u001b[5d"]
[0.000, "o", "\u001b[K\u001b[6d"]
[0.001, "o", "#\u001b[K\u001b[7d\b# The following lines prevent .htaccess and .htpasswd files from being\r\u001b[8d# viewed by Web clients.\r\u001b[9d"]
[0.003, "o", "#\u001b[K\u001b[10d\b<Files \".ht*\">\u001b[K\u001b[11;5HRequire all denied\u001b[K\r\u001b[12d</Files>\u001b[K\r\u001b[13d\u001b[K\u001b[14d#\u001b[K\u001b[15d\b# ErrorLog: The location of the error log file.\r\u001b[16d# If you do not specify an ErrorLog directive within a <VirtualHost>\r\u001b[17d# container, error messages relating to that virtual host will be\r\u001b[18d# logged here.  If you *do* define an error logfile for a <VirtualHost>\r\u001b[19d# container, that host's errors will be logged there and not here.\u001b[K\r\u001b[20d#\u001b[K\u001b[21d\bErrorLog \"/var/log/httpd/error_log\"\r\u001b[22d\u001b[K\u001b[23d#\u001b[K\u001b[24d\b# LogLevel: Control the number of messages logged to the error_log.\r\u001b[25d# Possible values include: debug, info, notice, warn, error, crit,\r\u001b[26d# alert, emerg.\r\u001b[27d#\u001b[K\u001b[28d\bLogLevel warn\u001b[K\r\u001b[29d\u001b[K\u001b[30d<IfModule log_config_module>\u001b[31;7H\u001b[K\u001b[32d\b\b# The following directives define some format nicknames for use with\u001b[33;7Ha CustomLog directive (see below).\u001b[34;7H\u001b[K\u001b[35d\b\bLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\" combined\u001b[36;5HLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b\" common\r\u001b[37d\u001b[K\u001b[21dE\u001b[?12l\u001b[?25h"]
[0.046, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[2d\b#\u001b[K\u001b[3d\bDocumentRoot \"/srv/http\"\u001b[K\r\u001b[4d<Directory"]
[0.001, "o", " \"/srv/http\">\u001b[5;5H#\r\u001b[6d    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[7d    # or any combination of:\u001b[K\r\u001b[8d    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\u001b[9d    #\r\u001b[10d"]
[0.000, "o", "    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\u001b[11;5H# doesn't give it to you.\r\u001b[12d"]
[0.001, "o", "    #\u001b[K\u001b[13d\b# The Options directive is both complicated and important.  Please see\r\u001b[14d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[15d    # for more information.\u001b[K\r\u001b[16d    #\u001b[K\r\u001b[17d    Options Indexes FollowSymLinks\u001b[K\r\u001b[18d\u001b[K\u001b[19d    #\u001b[K\r\u001b[20d    # AllowOverride controls what directives may be placed in .htaccess files.\r\u001b[21d    # It can be \"All\", \"None\", or any combination of the keywords:\u001b[22;5H"]
[0.000, "o", "#   AllowOverride FileInfo AuthConfig Limit\r\u001b[23d    #\r\u001b[24d    AllowOverride None\u001b[K\r\u001b[25d"]
[0.000, "o", "\u001b[K\u001b[26d    #\u001b[K\r\u001b[27d"]
[0.001, "o", "    # Controls who can get stuff from this server.\r\u001b[28d    #\u001b[K\u001b[29d\bRequire all granted\r\u001b[30d</Directory>\u001b[K\r\u001b[31d\u001b[K\u001b[32d"]
[0.001, "o", "#\u001b[K\u001b[33d\b# DirectoryIndex: sets the file that Apache will serve if a directory\r\u001b[34d# is requested.\r\u001b[35d#\u001b[K\u001b[36d\b<IfModule dir_module>\u001b[K\u001b[37;5HDirectoryIndex index.html\r\u001b[21d \u001b[?12l\u001b[?25h"]
[0.045, "o", "\u001b[?25l"]
[0.000, "o", "\u001b[16;32r\u001b[32;1H\u001b[7S\u001b[1;40r\u001b[2;3H"]
[0.001, "o", "as error documents.  e.g. admin@your-domain.com\r\u001b[3d#\u001b[K\u001b[4d\b"]
[0.000, "o", "ServerAdmin you@example.com\r\u001b[5d\u001b[K\u001b[6d#\u001b[K\u001b[7d\b# ServerName gives the name and port that the server uses to identify itself.\r\u001b[8d# This can often be determined automatically, but we recommend you specify\u001b[K\r\u001b[9d"]
[0.001, "o", "# it explicitly to prevent problems during startup.\r\u001b[10d#\u001b[K\u001b[11d\b# If your host doesn't have a registered DNS name, enter its IP address here.\r\u001b[12d#\u001b[K\u001b[13d\b#ServerName www.example.com:80\u001b[K\r\u001b[14d"]
[0.000, "o", "\u001b[K\u001b[15d#\u001b[K\u001b[16d\b# Deny access to the entirety of your server's filesystem. You must\r\u001b[17d# explicitly permit access to web content directories in other\r\u001b[18d# <Directory> blocks below.\r\u001b[19d#\u001b[K\u001b[20d\b<Directory />\u001b[K\u001b[21;5H"]
[0.001, "o", "AllowOverride none\u001b[22;17Hdenied\u001b[K\r\u001b[26d"]
[0.001, "o", "# Note that from this point forward you must specifically allow\r\u001b[27d# particular features to be enabled - so if something's not working as\r\u001b[28d# you might expect, make sure that you have specifically enabled it\r\u001b[29d# below.\r\u001b[30d#\u001b[32d\b#\u001b[33d DocumentRoot: The directory out of which you will serve your\u001b[K\u001b[34;3Hdocuments. By default, all requests are taken from this directory, but\u001b[35;3Hsymbolic links and aliases may be used to point to other locations.\r\u001b[36d#\u001b[K\u001b[37d\bDocumentRoot \"/srv/http\"\u001b[K\r\u001b[21d \u001b[?12l\u001b[?25h"]
[0.046, "o", "\u001b[?25l"]
[0.001, "o", "\u001b[2dLoadModule speling_module modules/mod_speling.so\r\u001b[3d"]
