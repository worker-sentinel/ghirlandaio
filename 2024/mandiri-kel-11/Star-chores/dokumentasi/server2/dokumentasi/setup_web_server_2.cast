[0.002, "o", "\u001b[2d\u001b[K\u001b[3d# Virtual hosts\u001b[K\r\u001b[4d#Include conf/extra/httpd-vhosts.conf\u001b[K\r\u001b[5d\u001b[K\u001b[6d# Local access to the Apache HTTP Server Manual\r\u001b[7d#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[8d\u001b[K\u001b[9d# Distributed authoring and versioning (WebDAV)\r\u001b[10d#Include conf/extra/httpd-dav.conf\u001b[12;3HVarious default settings\u001b[K\r\u001b[13dInclude conf/extra/httpd-default.conf\r\u001b[14d\u001b[K\u001b[15d# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[K\r\u001b[16d<IfModule proxy_html_module>\u001b[K\r\u001b[17dInclude conf/extra/proxy-html.conf\r\u001b[18d</IfModule>\r\u001b[19d\u001b[K\u001b[20d# Secure (SSL/TLS) connections\u001b[K\r\u001b[21d#Include conf/extra/httpd-ssl.conf\u001b[22;3H\u001b[K\r\u001b[23d# Note: The following must be present to support\r\u001b[24d#\u001b[9Gstarting without SSL on platforms with no /dev/random equivalent\u001b[25;3H      but a statically compiled-in mod_ssl.\r\u001b[26d"]
[0.000, "o", "#\u001b[K\u001b[27d\b<IfModule ssl_module>\r\u001b[28dSSLRandomSeed startup builtin\r\u001b[29dSSLRandomSeed connect builtin\u001b[K\r\u001b[30d</IfModule>\r\u001b[31d\u001b[K\u001b[32;8HOptional conf/conf.d/*.conf\u001b[K\r\u001b[34d#"]
