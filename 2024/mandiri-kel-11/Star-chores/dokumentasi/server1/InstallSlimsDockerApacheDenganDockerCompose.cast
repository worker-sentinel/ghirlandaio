[0.035, "o", "creating mbstring.la\r\n"]
[0.009, "o", "(cd .libs && rm -f mbstring.la && ln -s ../mbstring.la mbstring.la)\r\n"]
[0.003, "o", "/bin/bash /usr/src/php/ext/mbstring/libtool --tag=CC --mode=install cp ./mbstring.la /usr/src/php/ext/mbstring/modules\r\n"]
[0.029, "o", "cp ./.libs/mbstring.so /usr/src/php/ext/mbstring/modules/mbstring.so\r\n"]
[0.004, "o", "cp ./.libs/mbstring.lai /usr/src/php/ext/mbstring/modules/mbstring.la\r\n"]
