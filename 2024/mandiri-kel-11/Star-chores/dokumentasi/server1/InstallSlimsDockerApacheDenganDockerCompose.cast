[0.033, "o", "creating gd.la\r\n"]
[0.008, "o", "(cd .libs && rm -f gd.la && ln -s ../gd.la gd.la)\r\n"]
[0.003, "o", "/bin/bash /usr/src/php/ext/gd/libtool --tag=CC --mode=install cp ./gd.la /usr/src/php/ext/gd/modules\r\n"]
