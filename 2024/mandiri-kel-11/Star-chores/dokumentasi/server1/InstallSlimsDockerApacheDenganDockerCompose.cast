[0.002, "o", "name: slims9_bulian\r\nservices:\r\n  db:\r\n    container_name: db\r\n    environment:\r\n      MARIADB_DATABASE: senayan\r\n      MARIADB_PASSWORD: \"123\"\r\n      MARIADB_ROOT_PASSWORD: \"123\"\r\n      MARIADB_USER: slimsuser\r\n    image: mariadb:lts\r\n    networks:\r\n      proxy: null\r\n    ports:\r\n      - mode: ingress\r\n        target: 3306\r\n        published: \"3307\"\r\n        protocol: tcp\r\n    volumes:\r\n      - type: bind\r\n        source: /root/Projects/slims9_bulian/install/senayan_ddl.sql\r\n        target: /docker-entrypoint-initdb.d/init.sql\r\n        bind: {}\r\n      - type: volume\r\n        source: dbdata\r\n        target: /var/lib/mysql\r\n        volume: {}\r\n  slims:\r\n    build:\r\n      context: /root/Projects/slims9_bulian\r\n      dockerfile: Dockerfile\r\n    container_name: slims\r\n    depends_on:\r\n      db:\r\n        condition: service_started\r\n        required: true\r\n    environment:\r\n      DB_HOST: 127.0.0.1\r\n      DB_NAME: senayan\r\n      DB_PASS: \"123\"\r\n      DB_PORT: \"3306\"\r\n      DB_USER: slimsuser\r\n      ENV: development\r\n    networks:\r\n      proxy: null\r\n    ports:\r\n      - mode: ingress\r\n        target: 80\r\n        published: \"80\"\r\n        protocol: tcp\r\n    restart: unless-stopped\r\n    volumes:\r\n      - type: volume\r\n        source: appfiles\r\n        target: /var/www/html/files\r\n        volume: {}\r\n      - type: volume\r\n        source: appimages\r\n        target: /var/www/html/images\r\n        volume: {}\r\n      - type: volume\r\n        source: apprepo\r\n        target: /var/www/html/repository\r\n        volume: {}\r\nnetworks:\r\n  proxy:\r\n    name: slims9_bulian_proxy\r\n    driver: bridge\r\nvolumes:\r\n  appfiles:\r\n    name: slims9_bulian_appfiles\r\n  appimages:\r\n    name: slims9_bulian_appimages\r\n  apprepo:\r\n    name: slims9_bulian_apprepo\r\n  dbdata:\r\n    name: slims9_bulian_dbdata\r\n"]
