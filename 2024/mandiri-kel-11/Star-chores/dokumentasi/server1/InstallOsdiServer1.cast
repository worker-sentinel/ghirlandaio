[0.001, "o", "\u001b[1B\u001b[7mnvme0%    \u001b[0m  \r\u001b[7mnvme0%    \u001b[0m  \r\u001b[A\u001b[A\u001b[m\u000f\u001b[27m\u001b[24m\u001b[m\u000f\u001b[39m\r\u001b[19Cfdisk /dev/nvme0\u001b[K\u001b[m\u000f\u001b[39mn1\r\r\n"]
