[1.166, "o", "\r\r\n\u001b[J\u001b[A\u001b[37C\u001b[1m \u001b[m\u000f"]
[1.977, "o", "\b\u001b[m\u000f \b\u001b[?2004l\r\r\n\u001b[J"]
[0.035, "o", "\u001b[32m\r\nWelcome to fdisk (util-linux 2.42.1).\r\n\u001b[0mChanges will remain in memory only, until you decide to write them.\r\nBe careful before using the write command.\r\n\r\n"]
[0.020, "o", "\r\n"]
[0.000, "o", "\u001b[?2004hCommand (m for help): "]
[3.147, "o", "m"]
[0.568, "o", "\r\n\u001b[?2004l\r"]
[0.001, "o", "\r\nHelp:\r\n\u001b[1m\r\n  GPT\r\n\u001b[0m   M   enter protective/hybrid MBR\r\n\u001b[1m\r\n  Generic\r\n\u001b[0m   d   delete a partition\r\n   F   list free unpartitioned space\r\n   l   list known partition types"]
[0.000, "o", "\r\n"]
[0.002, "o", "   n   add a new partition\r\n   p   print the partition table\r\n   t   change a partition type\r\n   v   verify the partition table\r\n   i   print information about a partition\r\n   e   resize a partition\r\n   T   discard (trim) sectors\r\n\u001b[1m\r\n  Misc\r\n\u001b[0m   m   print this menu\r\n   x   extra functionality (experts only)\r\n\u001b[1m\r\n  Script\r\n\u001b[0m   I   load disk layout from sfdisk script file\r\n   O   dump disk layout to sfdisk script file\r\n\u001b[1m\r\n  Save & Exit\r\n\u001b[0m   w   write table to disk and exit\r\n   q   quit without saving changes\r\n\u001b[1m\r\n  Create a new label\r\n\u001b[0m   g   create a new empty GPT partition table\r\n   G   create a new empty SGI (IRIX) partition table\r\n   o   create a new empty MBR (DOS) partition table\r\n   s   create a new empty Sun partition table\r\n\r\n\r\n\u001b[?2004hCommand (m for help): "]
[5.170, "o", "F"]
[0.475, "o", "\r\n\u001b[?2004l\r"]
