[0.469, "o", "me0\r\r\n\u001b[0;31mcompleting \u001b[1mfile\u001b[m\u000f\u001b[0m\u001b[K\u001b[K\r\n\u001b[J\u001b[7mnvme0%    \u001b[0m  \u001b[J\u001b[40;33;01mnvme0n1\u001b[0m#    \u001b[J\u001b[40;33;01mnvme0n1p1\u001b[0m#  \u001b[J\u001b[40;33;01mnvme0n1p2\u001b[0m#  \u001b[J\u001b[40;33;01mnvme0n1p3\u001b[0m#  \u001b[J\u001b[40;33;01mnvme0n1p4\u001b[0m#  \u001b[J\u001b[40;33;01mnvram\u001b[0m%    \u001b[J\u001b[A\u001b[A\u001b[m\u000f\u001b[27m\u001b[24m\u001b[m\u000f\u001b[39m\r\u001b[19Cfdisk /dev/nvme0\u001b[K\u001b[m\u000f\u001b[39m"]
