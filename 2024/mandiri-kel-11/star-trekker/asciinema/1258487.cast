[0.001, "o", "\u001b[?25l\u001b[m\u000f<?xml version=\u001b[92m\"1.0\"\u001b[m\u000f encoding=\u001b[92m\"utf-8\"\u001b[m\u000f ?>\u001b[K\r\n\u001b[96m<!\u001b[0;10;1m\u000fDOCTYPE\u001b[m\u000f pam_mount \u001b[0;10;1m\u000fSYSTEM\u001b[m\u000f \u001b[92m\"pam_mount.conf.xml.dtd\"\u001b[m\u000f\u001b[96m>\u001b[m\u000f\u001b[K\r\n<!--\u001b[K\r\n        See pam_mount.conf(5) for a description.\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n\u001b[96m<pam_mount>\u001b[m\u000f\u001b[K\r\n\u001b[K\n                <!-- debug should come before everything else,\u001b[K\r\n                since this file is still processed in a single pass\u001b[K\r\n                from top-to-bottom -->\u001b[K\r\n\u001b[K\n\u001b[96m<debug \u001b[m\u000fenable=\u001b[92m\"0\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n                <!-- Volume definitions -->\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: General tunables -->\u001b[K\r\n\u001b[K\n<!--\u001b[K\r\n<luserconf name=\".pam_mount.conf.xml\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n<!-- Note that commenting out mntoptions will give you the defaults.\u001b[K\r\n     You will need to explicitly initialize it with the empty string\u001b[K\r\n     to reset the defaults to nothing. -->\u001b[K\r\n\u001b[96m<mntoptions \u001b[m\u000fallow=\u001b[92m\"nosuid,nodev,loop,encryption,fsck,nonempty,allow_root,allow_other\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n<!--\u001b[K\r\n<mntoptions deny=\"suid,dev\" />\u001b[K\r\n<mntoptions allow=\"*\" />\u001b[K\r\n<mntoptions deny=\"*\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[96m<mntoptions \u001b[m\u000frequire=\u001b[92m\"nosuid,nodev\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n<!-- requires ofl from hxtools to be present -->\u001b[K\r\n\u001b[96m<logout \u001b[m\u000fwait=\u001b[92m\"0\"\u001b[m\u000f\u001b[96m \u001b[m\u000fhup=\u001b[92m\"no\"\u001b[m\u000f\u001b[96m \u001b[m\u000fterm=\u001b[92m\"no\"\u001b[m\u000f\u001b[96m \u001b[m\u000fkill=\u001b[92m\"no\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: Volume-related -->\u001b[K\r\n\u001b[K\n\u001b[96m<mkmountpoint \u001b[m\u000fenable=\u001b[92m\"1\"\u001b[m\u000f\u001b[96m \u001b[m\u000fremove=\u001b[92m\"true\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[96m</pam_mount>\u001b[m\u000f\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000fetc/security/pam_mount.conf.xml                                                                                                                         1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H<?xml version=\u001b[92m\"1.0\"\u001b[m\u000f encoding=\u001b[92m\"utf-8\"\u001b[m\u000f ?>\u001b[K\r\n\u001b[96m<!\u001b[0;10;1m\u000fDOCTYPE\u001b[m\u000f pam_mount \u001b[0;10;1m\u000fSYSTEM\u001b[m\u000f \u001b[92m\"pam_mount.conf.xml.dtd\"\u001b[m\u000f\u001b[96m>\u001b[m\u000f\u001b[K\r\n<!--\u001b[K\r\n        See pam_mount.conf(5) for a description.\u001b[K"]
[0.001, "o", "\r\n-->\u001b[K\r\n\u001b[K\n\u001b[96m<pam_mount>\u001b[m\u000f\u001b[K\r\n\u001b[K\n                <!-- debug should come before everything else,\u001b[K\r\n                since this file is still processed in a single pass\u001b[K\r\n                from top-to-bottom -->\u001b[K\r\n\u001b[K\n\u001b[96m<debug \u001b[m\u000fenable=\u001b[92m\"0\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n                <!-- Volume definitions -->\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: General tunables -->\u001b[K\r\n\u001b[K\n<!--\u001b[K\r\n<luserconf name=\".pam_mount.conf.xml\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[K\n<!-- Note that commenting out mntoptions will give you the defaults.\u001b[K\r\n     You will need to explicitly initialize it with the empty string\u001b[K\r\n     to reset the defaults to nothing. -->\u001b[K\r\n\u001b[96m<mntoptions \u001b[m\u000fallow=\u001b[92m\"nosuid,nodev,loop,encryption,fsck,nonempty,allow_root,allow_other\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n<!--\u001b[K\r\n<mntoptions deny=\"suid,dev\" />\u001b[K\r\n<mntoptions allow=\"*\" />\u001b[K\r\n<mntoptions deny=\"*\" />\u001b[K\r\n-->\u001b[K\r\n\u001b[96m<mntoptions \u001b[m\u000frequire=\u001b[92m\"nosuid,nodev\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n<!-- requires ofl from hxtools to be present -->\u001b[K\r\n\u001b[96m<logout \u001b[m\u000fwait=\u001b[92m\"0\"\u001b[m\u000f\u001b[96m \u001b[m\u000fhup=\u001b[92m\"no\"\u001b[m\u000f\u001b[96m \u001b[m\u000fterm=\u001b[92m\"no\"\u001b[m\u000f\u001b[96m \u001b[m\u000fkill=\u001b[92m\"no\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n                <!-- pam_mount parameters: Volume-related -->\u001b[K\r\n\u001b[K\n\u001b[96m<mkmountpoint \u001b[m\u000fenable=\u001b[92m\"1\"\u001b[m\u000f\u001b[96m \u001b[m\u000fremove=\u001b[92m\"true\"\u001b[m\u000f\u001b[96m />\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[96m</pam_mount>\u001b[m\u000f\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000fetc/security/pam_mount.conf.xml                                                                                                                         1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
