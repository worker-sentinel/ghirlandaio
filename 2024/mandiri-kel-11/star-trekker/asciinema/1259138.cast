[0.000, "o", "                                                                                    \r\n    \u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27minclude\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m       mime.types;                                                                                                                          \r\n    \u001b(B\u001b[m\u001b[38:2:140:248:247m\u001b[48:2:20:22:27mdefault_type\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m  \u001b(B\u001b[m\u001b[38:2:140:248:247m\u001b[48:2:20:22:27mapplication\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m/octet-stream;                                                                                                            \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m    #log_format  main  '$remote_addr - $remote_user [$time_local] \"$request\" '\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                         \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m    #                  '$status $body_bytes_sent \"$http_referer\" '\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                     \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m    #                  '\"$http_user_agent\" \"$http_x_forwarded_for\"';\u001b(B\u001b[m\u001b[38:2:224:226:234m\u001b[48:2:20:22:27m                                                                                   \r\n                                                                                                                                                       \r\n\u001b(B\u001b[m\u001b[38:2:155:158:164m\u001b[48:2:20:22:27m    #access_