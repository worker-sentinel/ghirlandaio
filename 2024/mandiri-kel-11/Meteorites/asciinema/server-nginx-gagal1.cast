[4.472, "o", "\r\n\u001b[?2004l\r"]
[0.010, "o", "\tSupported interface modes:\r\n\t\t * managed\r\n\t\t * AP\r\n\t\t * AP/VLAN\r\n\t\t * monitor\r\n\t\t * P2P-client\r\n\t\t * P2P-GO\r\n\tBand 1:\r\n\t\tCapabilities: 0x19ef\r\n\t\t\tRX LDPC\r\n\t\t\tHT20/HT40\r\n\t\t\tSM Power Save disabled\r\n\t\t\tRX HT20 SGI\r\n"]
[0.001, "o", "\t\t\tRX HT40 SGI\r\n\t\t\tTX STBC\r\n\t\t\tRX STBC 1-stream\r\n"]
