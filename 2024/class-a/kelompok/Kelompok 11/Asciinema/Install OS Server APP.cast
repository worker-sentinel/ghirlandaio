[0.029, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-hardened.preset: 'default'\u001b[m\u000f\r\n\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.d/defaultconf'\u001b[m\u000f\r\n"]
[0.000, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/kernel/vmlinuz-linux-hardened -c /etc/mkinitcpio.d/defaultconf -U /boot/linux/arch-linux-hardened.efi\u001b[m\u000f\r\n"]
[0.020, "o", "==> ERROR: Invalid option -c -- '/etc/mkinitcpio.d/defaultconf' must be readable\r\n"]
