[0.002, "o", "\u001b[65;112H\u001b[0;10;7m\u000f[ Read 49 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                                   docker-compose.yml                                                                                                             \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2dversion: \"3\"\r\u001b[4dservices:\u001b[5;3Hslims:\u001b[6;5Hcontainer_name: slims\u001b[7;5Hbuild:\u001b[8;7Hcontext: .\u001b[9;7Hdockerfile: Dockerfile\u001b[10;5Henvironment:\u001b[11;7H- ENV=production\u001b[12;7H- DB_HOST=db\u001b[13;7H- DB_PORT=3306\u001b[14;7H- DB_USER=root\u001b[15;7H- DB_PASS=Pass123\u001b[16;7H- DB_NAME=senayan\u001b[17;5Hvolumes:\u001b[18;7H- appfiles:/var/www/html/files\u001b[19;7H- appimages:/var/www/html/images\u001b[20;7H- apprepo:/var/www/html/repository\u001b[21;5Hports:\u001b[22;7H- \"${HTTP_PORT}:80\"\u001b[23;5Hnetworks:\u001b[24;7H- proxy\u001b[25;5Hdepends_on:\u001b[26;7H- db\u001b[28;3Hdb:\u001b[29d\bimage: docker.io/library/mariadb:11\u001b[30;5Hcontainer_name: db\u001b[31;5Hports:\u001b[32;7H- \"${DB_PORT}:3306\"\u001b[33;5Hvolumes:\u001b[34;7H- ./install/senayan_ddl.sql:/docker-entrypoint-initdb.d/init.sql\u001b[35;7H- dbdata:/var/lib/mysql\u001b[36;5Henvironment:\u001b[37;7H- MARIADB_ROOT_PASSWORD=Pass123\u001b[38;7H- MARIADB_DATABASE=senayan\u001b[39;5Hnetworks:\u001b[40;7H- proxy\r\u001b[42dnetworks:\u001b[43;3Hproxy:\u001b[44;5Hdriver: bridge\r\u001b[46dvolumes:\u001b[47;3Hdbdata:\u001b[48;3Happfiles:\u001b[49;3Happimages:\u001b[50;3Happrepo:\r\u001b[2d\u001b[?25h\u001b[?0c"]
