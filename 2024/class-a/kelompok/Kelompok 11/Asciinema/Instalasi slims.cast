[0.062, "o", "version: \"3\"\r\n\r\nservices:\r\n  slims:\r\n    container_name: slims\r\n    build:\r\n      context: .\r\n      dockerfile: Dockerfile\r\n    environment:\r\n      - ENV=production\r\n      - DB_HOST=db\r\n      - DB_PORT=3306\r\n      - DB_USER=root\r\n      - DB_PASS=Pass123\r\n      - DB_NAME=senayan\r\n    volumes:\r\n      - appfiles:/var/www/html/files\r\n      - appimages:/var/www/html/images\r\n      - apprepo:/var/www/html/repository\r\n    ports:\r\n      - \"${HTTP_PORT}:80\"\r\n    networks:\r\n      - proxy\r\n    depends_on:\r\n      - db\r\n\r\n  db:\r\n    image: docker.io/library/mariadb:11\r\n    container_name: db\r\n    ports:\r\n      - \"${DB_PORT}:3306\"\r\n    volumes:\r\n      - ./install/senayan_ddl.sql:/docker-entrypoint-initdb.d/init.sql\r\n      - dbdata:/var/lib/mysql\r\n    environment:\r\n      - MARIADB_ROOT_PASSWORD=Pass123\r\n      - MARIADB_DATABASE=senayan\r\n    networks:\r\n      - proxy\r\n\r\nnetworks:\r\n  proxy:\r\n    driver: bridge\r\n\r\nvolumes:\r\n  dbdata:\r\n  appfiles:\r\n  appimages:\r\n  apprepo:\r\n"]
