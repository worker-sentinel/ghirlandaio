[10.013, "o", "\r\n\u001b[?2004l\r"]
[0.052, "o", "SLiMS Console \u001b[32mv9.7.2\u001b[39m\r\n\r\n\u001b[33mUsage:\u001b[39m\r\n  command [options] [arguments]\r\n\r\n"]
[0.003, "o", "\u001b[33mOptions:\u001b[39m\r\n  \u001b[32m-h, --help\u001b[39m            Display help for the given command. When no command is given display help for the \u001b[32mlist\u001b[39m command\r\n  \u001b[32m-q, --quiet\u001b[39m           Do not output any message\r\n  \u001b[32m-V, --version\u001b[39m         Display this application version\r\n  \u001b[32m    --ansi|--no-ansi\u001b[39m  Force (or disable --no-ansi) ANSI output\r\n  \u001b[32m-n, --no-interaction\u001b[39m  Do not ask any interactive question\r\n  \u001b[32m-v|vv|vvv, --verbose\u001b[39m  Increase the verbosity of messages: 1 for normal output, 2 for more verbose output and 3 for debug\r\n\r\n\u001b[33mAvailable commands:\u001b[39m\r\n  \u001b[32mcompletion\u001b[39m         Dump the shell completion script\r\n  \u001b[32menv\u001b[39m                create or recreate env.php file\r\n  \u001b[32mhelp\u001b[39m               Display help for a command\r\n  \u001b[32mlist\u001b[39m               List commands\r\n  \u001b[32mstatus\u001b[39m             Get SLiMS status info\r\n  \u001b[32mtarsius\u001b[39m            Create tarsius file in main SLiMS root\r\n \u001b[33mdb\u001b[39m\r\n  \u001b[32mdb:backup\u001b[39m          backup database\r\n  \u001b[32mdb:health\u001b[39m          Get database health info\r\n  \u001b[32mdb:migrate\u001b[39m         migrating database structure\r\n \u001b[33mmake\u001b[39m\r\n  \u001b[32mmake:command\u001b[39m       Create new command in plugins/Commands\r\n \u001b[33mplugin\u001b[39m\r\n  \u001b[32mplugin:activate\u001b[39m    active a plugin\r\n  \u001b[32mplugin:deactivate\u001b[39m  deactive a plugin\r\n  \u001b[32mplugin:detail\u001b[39m      Get detail of a plugin by name or id\r\n"]
[0.000, "o", "  \u001b[32mplugin:list\u001b[39m        Get available plugin\r\n"]
