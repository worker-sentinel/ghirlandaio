[0.002, "o", "\u001b[39;49m\u001b[m\u000f\u001b[H\u001b[J\u001b[46;79H\u001b[0;10;7m\u000f[ Reading... ]\u001b[m\u000f\u001b[46;77H\u001b[0;10;7m\u000f[ Read 28 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                              /etc/pam.d/system-auth                                                                        \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d#%PAM-1.0\r\u001b[4dauth\u001b[12Grequired\u001b[4;40Hpam_faillock.so\u001b[61Gpreauth deny=5  unlock_time=900\r\u001b[5d# Optionally use requisite above if you do not want to prompt for the password\r\u001b[6d# on locked accounts.\r\u001b[7d-auth\u001b[12G[success=2 default=ignore]  pam_systemd_home.so\r\u001b[8dauth\u001b[12G[success=1 default=bad]     pam_unix.so\r\u001b[9dauth\u001b[12G[default=die]\u001b[9;40Hpam_faillock.so\u001b[61Gauthfail    auth   [default=die]  pam_faillock.so  authfail  deny=5  unlock_time=900\r\u001b[10dauth\u001b[12Goptional\u001b[10;40Hpam_permit.so\r\u001b[11dauth\u001b[12Grequired\u001b[11;40Hpam_env.so\r\u001b[12dauth\u001b[12Grequired\u001b[12;40Hpam_faillock.so\u001b[61Gauthsucc\r\u001b[13d# If you drop the above call to pam_faillock.so the lock will be done also\r\u001b[14d# on non-consecutive authentication failures.\r\u001b[16d-account   [success=1 default=ignore]  pam_systemd_home.so\r\u001b[17daccount    required\u001b[17;40Hpam_unix.so\r\u001b[18daccount    optional\u001b[18;40Hpam_permit.so\r\u001b[19daccount    required\u001b[19;40Hpam_time.so\r\u001b[21d-password  [success=1 default=ignore]  pam_systemd_home.so\r\u001b[22dpassword   required\u001b[22;40Hpam_unix.so\u001b[22;61Htry_first_pass nullok shadow\r\u001b[23d"]
