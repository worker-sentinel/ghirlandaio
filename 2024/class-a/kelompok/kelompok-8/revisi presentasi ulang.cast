[0.007, "o", "\u001b[1;65r\u001b[H\u001b[4M\u001b[1;67r\u001b[2;62H\u001b[30m\u001b[103mA\u001b[6;70HA\u001b[16;7HA\u001b[17;18HA\u001b[18;9HA\u001b[m\u000fllowOverride FileInfo \u001b[30m\u001b[103mA\u001b[20;5HA\u001b[29;3H\u001b[m\u000fDirectoryIndex: sets the file that \u001b[30m\u001b[103mA\u001b[33;5H\u001b[m\u000f\u001b[96mDirectoryIndex\r\u001b[29B\u001b[m\u000f    # The following directives define some format nicknames for use with\u001b[K\r\n    # a CustomLog directive (see below).\u001b[K\r\n    #\u001b[K\r\n    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-\u001b[m\u000f\u001b[30m\u001b[103mA\u001b[m\u000f\u001b[92mgent}i\\\"\"\u001b[m\u000f combined\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f321,67         53\u001b[67;3H\u001b[?25h"]
[0.816, "o", "\u001b[?25l\u001b[m\u000fl"]
[0.007, "o", "\u001b[1;65r\u001b[H\u001b[26M\u001b[1;67r\u001b[3;38HA\u001b[39;67H\u001b[92mA\r\n\u001b[m\u000f    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b\"\u001b[m\u000f common\u001b[K\r\n\u001b[K\n    \u001b[0;10;1m\u000f<IfModule\u001b[m\u000f logio_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      # You need to enable mod_logio.c to use %I and %O\u001b[K\r\n      \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\"\u001b[m\u000f combinedio\u001b[K\r\n    \u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[K\r\n\u001b[K\n    #\u001b[K\r\n    # The location and format of the access logfile (Common Logfile Format).\u001b[K\r\n    # If you do not define any access logfiles within a <VirtualHost>\u001b[K\r\n    # container, they will be logged here.  Contrariwise, if you *do*\u001b[K\r\n    # define per-<VirtualHost> access logfiles, transactions will be\u001b[K\r\n    # logged therein and *not* in this file.\u001b[K\r\n    #\u001b[K\r\n    \u001b[96mCustomLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/access_log\"\u001b[m\u000f common\u001b[K\r\n\u001b[K\n    #\u001b[K\r\n    # If you prefer a logfile with access, agent, and referer information\u001b[K\r\n    # (Combined Logfile Format) you can use the following directive.\u001b[K\r\n    #\u001b[K\r\n    #CustomLog \"/var/log/httpd/access_log\" combined\u001b[K\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f alias_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    #\u001b[K\r\n    # Redirect: \u001b[30m\u001b[103mAl\u001b[m\u000flows you to tell clients about documents that used to \u001b[K\u001b[66;224H\u001b[0;10;7m\u000f47,17         58\u001b[67;4H\u001b[?25h"]
