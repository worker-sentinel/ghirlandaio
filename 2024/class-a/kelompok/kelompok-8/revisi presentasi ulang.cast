[0.009, "o", "\u001b[3;19Hr\u001b[6;47Hr\u001b[7;9H\u001b[30m\u001b[103mdi\u001b[m\u000fscussion of each configuration \u001b[30m\u001b[103mdi\u001b[m\u000fr\u001b[9;64H\u001b[30m\u001b[103mdi\u001b[22;32H\u001b[m\u000fr\u001b[25;42Hr\u001b[26;29H\u001b[30m\u001b[103mdi\u001b[m\u000fsk, be sure to specify a local \u001b[30m\u001b[103mdi\u001b[27;11H\u001b[m\u000fr\u001b[34;65Hr\u001b[35;9H\u001b[30m\u001b[103mdi\u001b[37;30H\u001b[m\u000fr\u001b[38;16Hrectory is not on a local \u001b[30m\u001b[103mdi\u001b[46;5H\u001b[m\u000fr\u001b[58;26H\u001b[30m\u001b[103mdi\u001b[59;5H\u001b[m\u000fr\u001b[67;4H\u001b[?25h"]
