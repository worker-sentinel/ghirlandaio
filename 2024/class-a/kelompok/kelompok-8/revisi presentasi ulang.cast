9;2HLoadModule unique_id_module modules/mod_unique_id.so\r\n\u001b[96mLoadModule\u001b[m\u000f setenvif_module modules/mod_setenvif.so\r\n\u001b[96mLoadModule\u001b[m\u000f version_module modules/mod_version.so\r\n#LoadModule remoteip_module modules/mod_remoteip.so\u001b[33;2HLoadModule \u001b[30m\u001b[103mproxy_module\u001b[m\u000f modules/mod_proxy.so\u001b[34;2HLoadModule proxy_connect_module modules/mod_proxy_connect.so\u001b[10X\u001b[35;2HLoadModule proxy_ftp_module modules/mod_proxy_ftp.so  \u001b[36;2HLoadModule proxy_http_module modules/mod_proxy_http.so\u001b[37;2HLoadModule proxy_fcgi_module modules/mod_proxy_fcgi.so\u001b[23X\u001b[38;2HLoadModule proxy_scgi_module modules/mod_proxy_scgi.so\u001b[21X\u001b[39;2HLoadModule proxy_uwsgi_module modules/mod_proxy_uwsgi.so\u001b[40;2HLoadModule proxy_fdpass_module modules/mod_proxy_fdpass.so\u001b[41;2HLoadModule proxy_wstunnel_module modules/mod_proxy_wstunnel.so\r\n#LoadModule proxy_ajp_module modules/mod_proxy_ajp.so\u001b[43;2HLoadModule proxy_balancer_module modules/mod_proxy_balancer.so\u001b[44;2HLoadModule proxy_express_module modules/mod_proxy_express.so\u001b[6X\u001b[45;2HLoadModule proxy_hcheck_module modules/mod_proxy_hcheck.so\u001b[46;2HLoadModule session_module modules/mod_session.so\u001b[47;2HLoadModule session_cookie_module modules/mod_session_cookie.so\u001b[48;2HLoadModule session_crypto_module modules/mod_session_crypto.so    \u001b[49;2HLoadModule session_dbd_module modules/mod_session_dbd.so  \r\n\u001b[96mLoadModule\u001b[m\u000f slotmem_shm_module modules/mod_slotmem_shm.so\u001b[51;3HoadModule slotmem_plain_module modules/mod_slotmem_plain.so\r\n#LoadModule ssl_module modules/mod_ssl.so\r\n#LoadModule dialup_module modules/mod_dialup.so\u001b[54;2HLoadModule http2_module modules/mod_http2.so\u001b[55;2HLoadModule proxy_http2_module modules/mod_proxy_http2.so\u001b[56;2HLoadModule md_module modules/mod_md.so\u001b[57;2HLoadModule lbmethod_byrequests_module modules/mod_lbmethod_byrequests.so\u001b[5X\u001b[58;2HLoadModule lbmethod_bytraffic_module modules/mod_lbmethod_bytraffic.so \u001b[59;2HLoadModule lbmethod_bybusyness_module modules/mod_lbmethod_bybusyness.so  \u001b[60;2HLoadModule lbmethod_heartbeat_module modules/mod_lbmethod_heartbeat.so\r\n\u001b[96mLoadModule\u001b[m\u000f unixd_module modules/mod_unixd.so\u001b[62;2HLoadModule heartbeat_module modules/mod_heartbeat.so\u001b[63;2HLoadModule heartmonitor_module modules/mod_heartmonitor.so\u001b[64;2HLoadModule dav_module modules/mod_dav.so \r\n\u001b[96mLoadModule\u001b[m\u000f status_module modules/mod_status.so\u001b[66;224H\u001b[0;10;7m\u000f36,13         21%\u001b[67;14H\u001b[?25h"]
