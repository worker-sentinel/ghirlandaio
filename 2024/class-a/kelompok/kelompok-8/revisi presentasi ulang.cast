[0.007, "o", "\u001b[H    # Alias /webpath /full/filesystem/path\u001b[27X\r\n    #\r\n    # If you include a trailing / on /webpath then the server will\r\n    # require it to be present in the URL.  You will also likely\u001b[5;6H need to provide a <Directory> section to allow access to\u001b[6;7Hthe filesystem path.\u001b[40X\r\n\u001b[28X\u001b[8;6H\u001b[74X\n ScriptAlias: This controls which directories contain server scripts. \u001b[10;7HScriptAliases are essentially the same as Aliases, except that\u001b[5X\u001b[11;9Hcuments in the target directory are treated as applications and\u001b[12;6H run by the server when requested rather than as documents sent to the\u001b[13;7Hclient.  The same rules about trailing \"/\" apply to ScriptAlias\u001b[5X\u001b[14;7Hdirectives as to Alias.\u001b[31X\u001b[15;6H\u001b[22X\r\n    \u001b[96mScriptAlias\u001b[m\u000f /cgi-bin/ \u001b[92m\"/srv/http/cgi-bin/\"\u001b[m\u000f\u001b[17;5H\u001b[30X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\r\n\u001b[5X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f cgid_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[56X\u001b[21;6H\u001b[61X\u001b[22;7HScriptSock: On threaded servers, designate the path to the UNIX\u001b[23;6H socket used to communicate with the CGI daemon of mod_cgid.\r\n    #\u001b[17X\r\n    #Scriptsock cgisock\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\r\n\u001b[50X\n#    \r\n# \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\r\n# CGI directory exists, if you have that configured.\r\n#\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/cgi-bin\"\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    \u001b[30m\u001b[103mAllowOve\u001b[m\u000f\u001b[96mrride\u001b[m\u000f None\u001b[47X\r\n    \u001b[96mOptions\u001b[m\u000f None\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[36;2H\u001b[0;10;1m\u000f/Directory>\u001b[m\u000f\u001b[9X\u001b[37;5H\u001b[45X\u001b[38;2H\u001b[0;10;1m\u000fIfModule\u001b[m\u000f headers_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    #\r\n    # Avoid passing HTTP_PROXY environment to CGI's on this or any proxied\r\n    # backend servers which have lingering \"httpoxy\" defects.\u001b[10X\r\n    # 'Proxy' request header is undefined by the IETF, not listed by IANA\r\n    #\r\n    \u001b[96mRequestHeader\u001b[m\u000f unset Proxy early\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[11X\r\n\u001b[8X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mime_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    #\r\n    # TypesConfig points to the file containing the list of mappings from\r\n    # filename extension to MIME-type.\u001b[30X\r\n    #\u001b[60X\r\n    \u001b[96mTypesConfig\u001b[m\u000f conf/mime.types\u001b[40X\r\n\u001b[66X\n    #\r\n    # AddType allows you to add to or override the MIME configuration\r\n    # file specified in TypesConfig for specific file types.\r\n    #\r\n    #AddType application/x-gzip .tgz\u001b[31X\r\n    #\u001b[61X\r\n    # AddEncoding allows you to have certain browsers uncompress\r\n    # information on the fly. Note: Not all browsers support this.\r\n    #\u001b[8X\r\n    #AddEncoding x-compress .Z\r\n    #AddEncoding x-gzip .gz .tgz\u001b[66;223H\u001b[0;10;7m\u000f389,5          74\u001b[67;10H\u001b[?25h"]
