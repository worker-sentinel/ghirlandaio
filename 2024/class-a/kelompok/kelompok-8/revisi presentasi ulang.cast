[0.007, "o", "\u001b[1;3Hfilesystems or if support for these functions is otherwise\u001b[9X\u001b[2;2H broken on your system.\r\n# Defaults: EnableMMAP On, EnableSendfile Off\r\n#\u001b[22X\r\n#EnableMMAP off\r\n#EnableSendfile on\u001b[48X\r\n\u001b[28X\n# Supplemental configuration\u001b[51X\r\n#    \r\n# The configuration files in the conf/extra/ directory can be \u001b[11X\r\n# included to add extra features or to modify the default configuration of \r\n# the server, or you may simply copy their contents here and change as \r\n# necessary.\u001b[62X\r\n\u001b[60X\n# Server-pool management (MPM specific)\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-mpm.conf\u001b[17;5H\u001b[30X\r\n# Multi-language error messages\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-multilang-errordoc.conf\r\n\u001b[78X\n# Fancy directory listings\u001b[40X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-autoindex.conf\u001b[8X\r\n\u001b[5X\n# Language settings   \r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-languages.conf\r\n\u001b[5X\n# User home directories\u001b[27X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-userdir.conf\u001b[29;5H\u001b[19X\r\n# Real-time info on requests and configuration\r\n#Include conf/extra/httpd-info.conf\r\n \u001b[33;3HVirtual hosts\u001b[54X\u001b[34;2HInclude conf/extra/httpd-vhosts.conf\r\n \r\n# Local access to the Apache HTTP Server Manual\r\n#Include conf/extra/httpd-manual.conf\r\n\u001b[11X\n# Distributed authoring and versioning (WebDAV)\u001b[40;2HInclude conf/extra/httpd-dav.conf\r\n\u001b[71X\u001b[42;3HVarious default settings\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-default.conf\r\n\u001b[14X\n# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[46;2H\u001b[0;10;1m\u000fIfModule\u001b[m\u000f proxy_html_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f\u001b[96mInclude\u001b[m\u000f conf/extra/proxy-html.conf\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\r\n\u001b[47X\u001b[50;3HSecure (SSL/TLS) connections\u001b[38X\u001b[51;2HInclude conf/extra/httpd-ssl.conf\u001b[31X\u001b[52;2H\u001b[70X\u001b[53;3HNote: The following must be present to support\u001b[18X\u001b[54;2H       starting without SSL on platforms with no /dev/random equivalent\r\n#       but a statically compiled-in mod_ssl.\r\n#\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f ssl_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f\u001b[96mSSLRandomSeed\u001b[m\u000f startup builtin\u001b[38X\r\n\u001b[96mSSLRandomSeed\u001b[m\u000f connect builtin\u001b[37X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f    \r\n \r\nIncludeOptional conf/conf.d/*.conf\r\n\u001b[0;10;1m\u000f<FilesMatch\u001b[m\u000f \"\\.php$\"\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    \u001b[96mSetHandler\u001b[m\u000f \u001b[92m\"proxy:unix:/run/php-fpm//php-fpm.sock|fcgi://localhost\"\r\n\u001b[0;10;1m\u000f</FilesMatch>\u001b[66;223H\u001b[0;10;7m\u000f545,10         Bot\u001b[67;15H\u001b[?25h"]
