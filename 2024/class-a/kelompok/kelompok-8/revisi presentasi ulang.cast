[0.004, "o", "\u001b[1;2Hiconv.input_encoding =\u001b[56X\r\n\u001b[20X\u001b[3;3HUse of this INI entry is deprecated, use global internal_encoding instead.\u001b[4;2H If empty, default_charset or internal_encoding or iconv.internal_encoding is used.\r\n; The precedence is: default_charset < internal_encoding < iconv.internal_encoding\u001b[6;2Hiconv.internal_encoding =\u001b[46X\r\n\u001b[28X\u001b[8;2H Use of this INI entry is deprecated, use global output_encoding instead.\r\n; If empty, default_charset or output_encoding or iconv.output_encoding is used.\u001b[10;3HThe precedence is: default_charset < output_encoding < iconv.output_encoding\u001b[11;3HTo use an output encoding conversion, iconv's output handler must be set\r\n; otherwise output encoding conversion cannot be performed.\r\n;iconv.output_encoding =\r\n\u001b[65X\n\u001b[96m[intl]\u001b[m\u000f\u001b[56X\u001b[16;2Hintl.default_locale =\u001b[38X\u001b[17;3HThis directive allows you to produce PHP errors when some error\u001b[18;3Hhappens within intl functions. The value is the level of the error produced.\u001b[19;3HDefault is 0, which does not produce any errors.\u001b[20;2H This directive is deprecated.\r\n;intl.error_level = E_WARNING\u001b[22;2H If enabled this directive indicates that when an error occurs within an\u001b[23;3Hintl function a IntlException should be thrown.\u001b[24;2H Default is Off, which means errors need to be handled manually.\r\n;intl.use_exceptions = On\r\n\u001b[74X\n\u001b[96m[sqlite3]\u001b[28;2H\u001b[m\u000f Directory pointing to SQLite3 extensions\u001b[29;3Hhttps://php.net/sqlite3.extension-dir\u001b[30;2Hsqlite3.extension_dir =\r\n\u001b[14X\u001b[32;2H SQLite defensive mode flag (only available from SQLite 3.26+)\u001b[33;3HWhen the defensive flag is enabled, langua\u001b[30m\u001b[103mge\u001b[m\u000f features that allow ordinary\u001b[34;2H SQL to deliberately corrupt the database file are disabled. This forbids\u001b[35;3Hwriting directly to the schema, shadow tables (eg. FTS data tables), or   \u001b[36;3Hthe sqlite_dbpa\u001b[30m\u001b[103mge\u001b[m\u000f virtual table.\u001b[32X\u001b[37;2H https://www.sqlite.org/c3ref/c_dbconfig_defensive.html\u001b[38;3H(for older SQLite versions, this flag has no use)\u001b[39;2Hsqlite3.defensive = 1\r\n\u001b[75X\n\u001b[96m[Pcre]\u001b[m\u000f\u001b[66X\u001b[42;3HPCRE library backtracking limit.\u001b[41X\u001b[43;3Hhttps://php.net/pcre.backtrack-limit\u001b[6X\u001b[44;2Hpcre.backtrack_limit=100000\r\n\u001b[17X\u001b[46;2H PCRE library recursion limit.\u001b[47;2H Please note that if you set this value to a high number you may consume all\r\n; the available process stack and eventually crash PHP (due to reaching the\u001b[49;2H stack size limit imposed by the Operating System).\u001b[50;2H https://php.net/pcre.recursion-limit\u001b[51;2Hpcre.recursion_limit=100000\r\n\u001b[14X\u001b[53;2H Enables or disables JIT compilation of patterns. This requires the PCRE\u001b[54;2H library to be compiled with JIT support.\u001b[55;2Hpcre.jit=1\u001b[7X\r\n\u001b[14X\n\u001b[96m[Pdo]\u001b[m\u000f\u001b[11X\u001b[58;2H Whether to pool ODBC connections. Can be one of \"strict\", \"relaxed\" or \"off\"\u001b[59;2H https://php.net/pdo-odbc.connection-pooling\r\n;pdo_odbc.connection_pooling=strict\r\n\u001b[15X\n\u001b[96m[Pdo_mysql]\u001b[m\u000f\u001b[9X\u001b[63;2H Default socket name for local MySQL connects.  If empty, uses the built-in\u001b[64;2H MySQL defaults.  \r\npdo_mysql.default_socket=\u001b[66;223H\u001b[0;10;7m\u000f1016,45        54\u001b[67;4H\u001b[?25h"]
[0.345, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.004, "o", "\u001b[H\u001b[23X\n; It allows the user to specify a folder where files that can be sent via LOAD DATA\u001b[3;3HLOCAL can exist. It is ignored if mysqli.allow_local_infile is enabled.   \u001b[4;2Hmysqli.local_infile_directory =\u001b[52X\r\n\u001b[82X\u001b[6;2H Allow or prevent persistent links.\r\n; https://php.net/mysqli.allow-persistent\r\nmysqli.allow_persistent =\u001b[92m On\u001b[m\u000f\u001b[46X\r\n\u001b[80X\u001b[10;3HMaximum number of links.  -1 means no limit.\u001b[32X\u001b[11;3Hhttps://php.net/mysqli.max-links\u001b[40X\r\nmysqli.max_links =\u001b[92m -1\u001b[m\u000f\u001b[38X\r\n\u001b[24X\n; Default port number for mysqli_connect().\r\n; https://php.net/mysqli.default-port\r\nmysqli.default_port = 3306\r\n\u001b[65X\u001b[18;3HDefault socket name for local MySQL connects.  If empty, uses the built-in  \u001b[19;3HMySQL defaults.\u001b[33X\u001b[20;3Hhttps://php.net/mysqli.default-socket\r\nmysqli.default_socket =\u001b[6X\r\n\u001b[73X\u001b[23;3HDefault host for mysqli_connect().\u001b[13X\u001b[24;3Hhttps://php.net/mysqli.default-host\u001b[28X\r\nmysqli.default_host =    \r\n\n; Default user for mysqli_connect().\u001b[28;3Hhttps://php.net/mysqli.default-user\u001b[5X\r\nmysqli.default_user =\u001b[18X\r\n\u001b[24X\n; Default password for mysqli_connect().\u001b[32;3HNote that this is generally a *bad* idea to store passwords in this file.\u001b[33;3H*Any* user with PHP access can run 'echo \u001b[30m\u001b[103mget\u001b[m\u000f_cfg_var(\"mysqli.default_pw\")\u001b[34;3Hand reveal this password!  And of course, any users with read access to this\u001b[35;3Hfile will be able to reveal the password as well.\u001b[22X\u001b[36;3Hhttps://php.net/mysqli.default-pw\r\nmysqli.default_pw =\u001b[37X\r\n\u001b[51X\u001b[39;2H If this option is enabled, closing a persistent connection will rollback\r\n; any pending transactions of this connection, before it is put back\r\n; into the persistent connection pool.\u001b[42;2Hmysqli.rollback_on_cached_plink = Off\r\n\u001b[38X\n\u001b[96m[mysqlnd]\u001b[m\u000f\u001b[19X\r\n; Enable / Disable collection of general statistics by mysqlnd which can be\u001b[46;3Hused to tune and monitor MySQL operations.\r\nmysqlnd.collect_statistics =\u001b[92m On\u001b[m\u000f\u001b[46X\r\n\u001b[75X\u001b[49;3HEnable / Disable collection of memory usage statistics by mysqlnd which can be\u001b[50;3Hused to tune and monitor MySQL operations.\u001b[51;2H Default Value: Off\u001b[8X\r\n; Development Value: On\u001b[53;3HProduction Value: Off\u001b[50X\r\nmysqlnd.collect_memory_statistics =\u001b[92m Off\u001b[m\u000f   \r\n\u001b[11X\n; Records communication from all extensions using mysqlnd to the specified log\r\n; file.\u001b[58;3Hhttps://php.net/mysqlnd.debug\u001b[47X\u001b[59;2Hmysqlnd.debug =\u001b[29X\r\n\u001b[35X\n; Defines which queries will be logged.\r\n;mysqlnd.log_mask = 0\r\n\u001b[76X\u001b[64;3HDefault size of the mysqlnd memory pool, which is used by result sets.\r\n;mysqlnd.mempool_default_size = 16000\u001b[66;224H\u001b[0;10;7m\u000f182,44        63\u001b[67;5H\u001b[?25h"]
[0.999, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.004, "o", "\u001b[H; Define the anonymous ftp password (your email address). PHP's default setting\u001b[2;3Hfor this is empty.\u001b[63X\u001b[3;3Hhttps://php.net/from\u001b[51X\u001b[4;2Hfrom=\"john@doe.com\"\u001b[12X\u001b[6;3HDefine the User-Agent string. PHP's default setting for this is empty.\u001b[7;19Huser-agent\u001b[13X\r\n;user_agent=\"PHP\"\u001b[11X\u001b[10;3HDefault timeout for socket based streams (seconds)\u001b[11;19Hdefault-socket-timeout\r\ndefault_socket_timeout = 60\u001b[14;3HIf your scripts have to deal with files from Macintosh systems,\u001b[15;3Hor you are running on a Mac and need to deal with files from\r\n; unix or win32 systems, setting this flag will cause PHP to\r\n; automatically detect the EOL character in those files so that\u001b[18;3Hfgets() and file() will work regardless of the source of the file.\u001b[8X\u001b[19;3Hhttps://php.net/auto-detect-line-endings\u001b[20;2Hauto_detect_line_endings = Off\u001b[8X\r\n\u001b[23X\n;;;;;;;;;;;;;;;;;;;;;;\u001b[23;4Hynamic Extensions ;\u001b[14X\u001b[24;2H;;;;;;;;;;;;;;;;;;;;;\u001b[15X\r\n\u001b[21X\n; If you wish to have an extension loaded automatically, use the following\u001b[27;3Hsyntax:\u001b[27X\u001b[28;2H\u001b[36X\r\n;   extension=modulename\r\n;\u001b[31;3HFor example:\u001b[26X\u001b[32;2H\u001b[74X\u001b[33;3H  extension=mysqli\u001b[55X\u001b[34;2H\u001b[77X\u001b[35;3HWhen the extension library to load is not located in the default extension\u001b[36;3Hdirectory, You may specify an absolute path to the library file:\r\n;\u001b[18X\r\n;   extension=/path/to/extension/mysqli.so\u001b[39;2H\u001b[73X\u001b[40;3HNote : The syntax used in previous PHP versions ('extension=<ext>.so' and\u001b[41;3H'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[42;2H deprecated in a future PHP major version. So, when it is possible, please\r\n; move to the new ('extension=<ext>) syntax.\r\n;\u001b[8X\nextension=bcmath\u001b[58X\u001b[46;2Hextension=bz2\u001b[30X\r\n;extension=calendar\u001b[12X\r\nextension=\u001b[92mcurl\u001b[49;2H\u001b[m\u000fextension=dba\u001b[66X\u001b[50;2Hextension=enchant\u001b[26X\u001b[51;2Hextension=exif\u001b[5X\u001b[52;2Hextension=ffi\u001b[9X\u001b[53;2Hextension=ftp\u001b[9X\r\n;extension=gd\u001b[26X\r\n;extension=\u001b[30m\u001b[103mgett\u001b[m\u000fext\u001b[56;2Hextension=gmp\u001b[64X\u001b[57;2Hextension=iconv\u001b[58;2Hextension=intl\u001b[16X\u001b[59;2Hextension=ldap \r\nextension=\u001b[92mmysqli\u001b[61;2H\u001b[m\u000fextension=odbc\u001b[24X\u001b[62;2Hextension=pdo_dblib \r\n;extension=pdo_mysql\u001b[64;2Hextension=pdo_odbc\u001b[53X\u001b[65;2Hextension=pdo_pgsql\u001b[17X\u001b[66;223H\u001b[0;10;7m\u000f922,12         47\u001b[67;6H\u001b[?25h"]
