[0.004, "o", "\u001b[1;65r\u001b[H\u001b[m\u000f\u001b[M\u001b[1;67r\u001b[38;57Hextension\r\u001b[27B; dynamically loaded \u001b[30m\u001b[103mextension \u001b[m\u000f(either a PHP \u001b[30m\u001b[103mextension \u001b[m\u000for a Zend extension),\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f66,22           0%\u001b[67;12H\u001b[?25h"]
