[0.008, "o", "\u001b[H# symbolic links and aliases may be used to point to other locations.\r\n#    \r\n\u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http\"\u001b[m\u000f\u001b[42X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[41X\u001b[5;6H\u001b[57X\u001b[6;7HPossible values for the Options directive are \"None\", \"All\",\r\n    # or any combination of:\u001b[8;6H   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[9;6H\u001b[70X\u001b[10;7HNote that \"MultiViews\" must be named *explicitly* --- \"Options All\"\u001b[11;9Hesn't give it to you.\u001b[42X\u001b[12;6H\u001b[70X\u001b[13;7HThe Options directive is both complicated and important.  Please see\u001b[14;7Hhttp://httpd.apache.org/docs/2.4/mod/core.html#options\u001b[15;6H for more information.\r\n    #\u001b[41X\u001b[17;5H\u001b[96mOptions\u001b[m\u000f Indexes FollowSymLinks\r\n\u001b[11X\n    #\r\n    # AllowOverride controls what directives may be placed in .htaccess files.\u001b[21;6H It can be \"All\", \"None\", or any combination of the keywords:\u001b[22;7H  AllowOverride FileInfo AuthConfig Limit\u001b[22X\u001b[23;6H\u001b[60X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\r\n\u001b[23X\n    #\u001b[6X\r\n    # Controls who can get stuff from this server.\r\n    #\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[47X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[40X\r\n \r\n#\u001b[30X\r\n# DirectoryIndex: sets the file that Apache will serve if a directory\r\n# is requested. \r\n#\u001b[22X\n\u001b[0;10;1m\u000fIfModule\u001b[m\u000f dir_module\u001b[0;10;1m\u000f>\u001b[37;5H\u001b[m\u000f\u001b[96mDirectoryIndex\u001b[m\u000f index.php index.html index.htm\u001b[38;2H\u001b[0;10;1m\u000f/IfModule>\u001b[m\u000f\u001b[14X\r\n\u001b[5X\n#\u001b[73X\r\n# The following lines prevent .htaccess and .htpasswd files from being \r\n# viewed by Web clients. \u001b[48X\r\n#    \r\n\u001b[0;10;1m\u000f<Files\u001b[m\u000f \".ht*\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[21X\r\n    \u001b[96mRequire\u001b[m\u000f all denied\r\n\u001b[0;10;1m\u000f</Files>\u001b[m\u000f\r\n\u001b[22X\n#    \r\n# ErrorLog: The location of the error log file.\u001b[26X\r\n# If you do not specify an ErrorLog directive within a <VirtualHost>\r\n# container, error messages relating to that virtual host will be\r\n# logged here.  If you *do* define an error logfile for a <VirtualHost>\r\n# container, that host's errors will be logged there and not here.\r\n#    \r\n\u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/error_log\"\u001b[m\u000f\u001b[34X\r\n\u001b[60X\n#    \r\n# LogLevel: Control the number of messages logged to the error_log.\r\n# Possible values include: debug, info, notice, warn, error, crit,\r\n# alert, emerg.\u001b[49X\r\n#\u001b[65X\r\n\u001b[96mLogLevel\u001b[m\u000f warn\r\n\u001b[30X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f log_config_module\u001b[0;10;1m\u000f>\u001b[m\u000f    \u001b[66;223H\u001b[0;10;7m\u000f289,49         52\u001b[67;11H\u001b[?25h"]
