[0.006, "o", "\u001b[H    # Alias /webpath /full/filesystem/path\r\n    #\r\n    # If you include a trailing / on /webpath then the server will   \r\n    # require it to be present in the URL.  You will also likely\r\n    # need to provide a <Directory> section to allow access to\r\n    # the filesystem path.\u001b[7;5H\u001b[45X\r\n    #\u001b[6X\r\n    # ScriptAlias: This controls which directories contain server scripts. \r\n    # ScriptAliases are essentially the same as Aliases, except that\r\n    # documents in the target directory are treated as applications and\r\n    # run by the server when requested rather than as documents sent to the\r\n    # client.  The same rules about trailing \"/\" apply to ScriptAlias\r\n    # directives as to Alias.\r\n    #\u001b[17X\r\n    \u001b[96mScriptAlias\u001b[m\u000f /cgi-bin/ \u001b[92m\"/srv/http/cgi-bin/\"\r\n\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\r\n\u001b[47X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f cgid_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[46X\r\n    #\u001b[60X\r\n    # ScriptSock: On threaded servers, designate the path to the UNIX  \r\n    # socket used to communicate with the CGI daemon of mod_cgid. \r\n    #\r\n    #Scriptsock cgisock\u001b[12X\r\n\u001b[0;10;1m\u000f</IfModule>\r\n\u001b[m\u000f \n\u001b[66X\u001b[29;3H\"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\u001b[30;3HCGI directory exists, if you have that configured.\r\n\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/cgi-bin\"\u001b[0;10;1m\u000f>\u001b[33;5H\u001b[m\u000f\u001b[30m\u001b[103mAllowO\u001b[m\u000f\u001b[96mverride\u001b[m\u000f None\r\n    \u001b[96mOptions\u001b[m\u000f None\u001b[12X\r\n    \u001b[96mRequire\u001b[m\u000f all granted\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[60X\r\n\u001b[40X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f headers_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    #\u001b[80X\r\n    # Avoid passing HTTP_PROXY environment to CGI's on this or any proxied\r\n    # backend servers which have lingering \"httpoxy\" defects.\r\n    # 'Proxy' request header is undefined by the IETF, not listed by IANA\u001b[43;5H#\u001b[50X\u001b[44;5H\u001b[96mRequestHeader\u001b[m\u000f unset Proxy early\u001b[60X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f    \r\n\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mime_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[48;6H\u001b[71X\u001b[49;7HTypesConfig points to the file containing the list of mappings from\u001b[50;7Hfilename extension to MIME-type.\u001b[31X\u001b[51;6H\u001b[63X\r\n    \u001b[96mTypesConfig\u001b[m\u000f conf/mime.types\u001b[13X\r\n\u001b[5X\n    #\u001b[43X\r\n    # AddType allows you to add to or override the MIME configuration\u001b[56;6H file specified in TypesConfig for specific file types.\u001b[57;6H\u001b[68X\nAddType application/x-gzip .tgz\u001b[32X\u001b[60;6H AddEncoding allows you to have certain browsers uncompress\r\n    # information on the fly. Note: Not all browsers support this.\r\n    #\r\n    #AddEncoding x-compress .Z\u001b[64;6HAddEncoding x-gzip .gz .tgz\u001b[65;6H\u001b[67X\u001b[66;224H\u001b[0;10;7m\u000f89,5          74\u001b[67;8H\u001b[?25h"]
