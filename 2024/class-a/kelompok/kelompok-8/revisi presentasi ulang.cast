[0.009, "o", "\u001b[3;18Hi\u001b[4;23H\u001b[30m\u001b[103md\u001b[m\u000f.apache.org/\u001b[30m\u001b[103md\u001b[m\u000focs/2.4/> for \u001b[30m\u001b[103md\u001b[m\u000fetaile\u001b[30m\u001b[103md\u001b[6;19Hd\u001b[m\u000f.apache.org/\u001b[30m\u001b[103md\u001b[m\u000focs/2.4/mo\u001b[30m\u001b[103md\u001b[m\u000f/\u001b[30m\u001b[103md\u001b[m\u000fi\u001b[7;10Hiscussion of each configuration \u001b[30m\u001b[103md\u001b[m\u000fi\u001b[9;20H\u001b[30m\u001b[103md\u001b[m\u000f the instructions in here without un\u001b[30m\u001b[103md\u001b[m\u000ferstan\u001b[30m\u001b[103md\u001b[m\u000fi\u001b[10;13H\u001b[30m\u001b[103md\u001b[m\u000fo.  They're here only as hints or remin\u001b[30m\u001b[103md\u001b[11;22Hd\u001b[m\u000focs. You have been warne\u001b[30m\u001b[103md\u001b[13;19Hd\u001b[14;53Hd\u001b[15;57Hd\u001b[16;46Hd\u001b[m\u000fe\u001b[30m\u001b[103md\u001b[17;65Hd\u001b[19;21Hd\u001b[22;31H\u001b[m\u000firectory tree un\u001b[30m\u001b[103md\u001b[23;27Hd\u001b[25;11Hdd\u001b[m\u000f a slash at the en\u001b[30m\u001b[103md\u001b[m\u000f of the \u001b[30m\u001b[103md\u001b[m\u000fi\u001b[26;30Hisk, be sure to specify a local \u001b[30m\u001b[103md\u001b[m\u000fi\u001b[27;10Hirective, if file-base\u001b[30m\u001b[103md\u001b[m\u000f mutexes are use\u001b[30m\u001b[103md\u001b[28;36Hd\u001b[m\u000f \u001b[30m\u001b[103md\u001b[m\u000faemons, you will nee\u001b[30m\u001b[103md\u001b[29;11Hd\u001b[31;22Hd\u001b[34;50Hd\u001b[m\u000f mutex file \u001b[30m\u001b[103md\u001b[m\u000fi\u001b[35;10Hivi\u001b[30m\u001b[103md\u001b[m\u000fual mutexes, or change the global \u001b[30m\u001b[103md\u001b[37;15Hd\u001b[m\u000f change the \u001b[30m\u001b[103md\u001b[m\u000firectory if mutexes are file-base\u001b[30m\u001b[103md\u001b[m\u000f an\u001b[30m\u001b[103md\u001b[m\u000f the \u001b[30m\u001b[103md\u001b[38;15H\u001b[m\u000firectory is not on a local \u001b[30m\u001b[103md\u001b[m\u000fi\u001b[41;9H\u001b[30m\u001b[103md\u001b[m\u000fefault:/run/http\u001b[30m\u001b[103md\u001b[44;28Hd\u001b[m\u000f Apache to specific IP a\u001b[30m\u001b[103mdd\u001b[m\u000fresses an\u001b[30m\u001b[103md\u001b[45;16Hd\u001b[m\u000f of the \u001b[30m\u001b[103md\u001b[46;4H\u001b[m\u000fi\u001b[48;41H\u001b[30m\u001b[103mdd\u001b[49;45Hd\u001b[m\u000f IP a\u001b[30m\u001b[103mdd\u001b[55;16Hd\u001b[57;46Hd\u001b[58;27H\u001b[m\u000fing `Loa\u001b[30m\u001b[103md\u001b[m\u000fMo\u001b[30m\u001b[103md\u001b[59;4H\u001b[m\u000firectives containe\u001b[30m\u001b[103md\u001b[m\u000f in it are actually available _before_ they are use\u001b[30m\u001b[103md\u001b[60;21Hd\u001b[m\u000f mo\u001b[30m\u001b[103md\u001b[m\u000fules (those liste\u001b[30m\u001b[103md\u001b[m\u000f by `http\u001b[30m\u001b[103md\u001b[m\u000f -l') \u001b[30m\u001b[103md\u001b[m\u000fo not nee\u001b[30m\u001b[103md\u001b[61;12Hd\u001b[m\u000fe\u001b[30m\u001b[103md\u001b[64;6Hd\u001b[m\u000fMo\u001b[30m\u001b[103md\u001b[m\u000fule foo_mo\u001b[30m\u001b[103md\u001b[m\u000fule mo\u001b[30m\u001b[103md\u001b[m\u000fules/mo\u001b[30m\u001b[103md\u001b[67;3H\u001b[?25h"]
[0.027, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[1;2H filesystems or if support for these functions is otherwise\u001b[2;3Hbroken on your system.\u001b[50X\u001b[3;3HDefaults: EnableMMAP On, EnableSendfile Off\u001b[20X\u001b[4;2H\u001b[70X\nEnableMMAP off\u001b[6X\u001b[6;2HEnableSendfile on\u001b[42X\r\n\u001b[51X\u001b[8;2H Supplemental configuration\u001b[9;2H\u001b[66X\u001b[10;3HThe configuration files in the conf/extra/ directory can be \u001b[14X\u001b[11;3Hincluded to add extra features or to modify the default configuration of \u001b[12;2H the server, or you may simply copy their contents here and change as \u001b[13;3Hnecessary.\u001b[60X\r\n\u001b[76X\u001b[15;3HServer-pool management (MPM specific)\u001b[31X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-mpm.conf\u001b[39X\r\n\u001b[72X\u001b[18;3HMulti-language error messages\u001b[46X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-multilang-errordoc.conf\u001b[21;2H Fancy directory listings\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-autoindex.conf\u001b[29X\r\n\u001b[47X\u001b[24;2H Language settings\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-languages.conf\u001b[29X\r\n\u001b[72X\u001b[27;3HUser home directories\u001b[53X\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-userdir.conf\u001b[35X\r\n\u001b[16X\u001b[30;2H Real-time info on requests and configuration\r\n#Include conf/extra/httpd-info.conf\u001b[33;2H Virtual hosts\u001b[34;2HInclude conf/extra/httpd-vhosts.conf\u001b[34X\r\n\u001b[55X\u001b[36;2H Local access to the Apache HTTP Server Manual\u001b[37;2HInclude conf/extra/httpd-manual.conf\u001b[41X\r\n\u001b[76X\u001b[39;3HDistributed authoring and versioning (WebDAV)\u001b[40;2HInclude conf/extra/httpd-dav.conf\r\n\u001b[26X\n# Various default settings\r\n\u001b[96mInclude\u001b[m\u000f conf/extra/httpd-default.conf\r\n\u001b[67X\u001b[45;3HConfigure mod_proxy_html to understand HTML4/XHTML1\u001b[6X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f proxy_html_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f\u001b[96mInclude\u001b[m\u000f conf/extra/proxy-html.conf\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[56X\r\n\u001b[59X\u001b[50;2H Secure (SSL/TLS) connections\u001b[51;2HInclude conf/extra/httpd-ssl.conf\r\n#\u001b[8X\r\n# Note: The following must be present to support\u001b[54;2H       starting without SSL on platforms with no /dev/random equivalent\u001b[55;3H      but a statically compiled-in mod_ssl.\r\n\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f ssl_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[57X\r\n\u001b[96mSSLRandomSeed\u001b[m\u000f startup builtin\u001b[43X\r\n\u001b[96mSSLRandomSeed\u001b[m\u000f connect builtin\u001b[46X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[59X\r\n\u001b[20X\nIncludeOptional conf/conf.d/*.conf\r\n\u001b[0;10;1m\u000f<FilesMatch\u001b[m\u000f \"\\.php$\"\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    \u001b[96mSetHandler\u001b[m\u000f \u001b[92m\"proxy:unix:/run/php-fpm//php-fpm.sock|fcgi://localhost\"\r\n\u001b[0;10;1m\u000f</FilesMatch>\u001b[66;223H\u001b[0;10;7m\u000f545,13         Bot\u001b[67;2H\u001b[?25h"]
