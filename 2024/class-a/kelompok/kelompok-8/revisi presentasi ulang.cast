[0.005, "o", "\u001b[1;65r\u001b[H\u001b[6M\u001b[1;67r\u001b[1;27H\u001b[30m\u001b[103mg\u001b[m\u000f, a number, a PHP constant (e.\u001b[30m\u001b[103mg\u001b[3;6Hg\u001b[m\u000f. E_ALL & ~E_NOTICE), a quoted strin\u001b[30m\u001b[103mg\u001b[4;43Hg\u001b[13;14Hg\u001b[m\u000fs can be turned on usin\u001b[30m\u001b[103mg\u001b[14;30Hg\u001b[16;17Hg\u001b[m\u000f can be denoted by simply not writin\u001b[30m\u001b[103mg\u001b[m\u000f anythin\u001b[30m\u001b[103mg\u001b[17;5Hg\u001b[m\u000fn, or by usin\u001b[30m\u001b[103mg\u001b[19;45Hg\u001b[20;45Hg\u001b[21;40Hg\u001b[23;64Hg\u001b[30;18Hg\u001b[34;37Hg\u001b[35;64Hg\u001b[37;14Hg\u001b[m\u000f usin\u001b[30m\u001b[103mg\u001b[m\u000f the production ini in production and testin\u001b[30m\u001b[103mg\u001b[40;63Hg\u001b[50;15Hg\u001b[m\u000f are all the settin\u001b[30m\u001b[103mg\u001b[52;31Hg\u001b[53;26Hg\r\u001b[7B\u001b[m\u000f; display_startup_errors\u001b[K\r\n;   Default Value: On\u001b[K\r\n;   Development Value: On\u001b[K\r\n;   Production Value: Off\u001b[K\r\n\u001b[K\n; error_reportin\u001b[30m\u001b[103mg\u001b[m\u000f\u001b[K\u001b[66;225H\u001b[0;10;7m\u000f7,17          2\u001b[67;3H\u001b[?25h"]
[0.245, "o", "\u001b[?25l\u001b[m\u000fe"]
[0.004, "o", "\u001b[1;3H  Default Value: \"EGPCS\"\u001b[53X\u001b[2;3H  Development Value: \"GPCS\"\u001b[51X\u001b[3;3H  Production Value: \"GPCS\"\u001b[44X\r\n\u001b[52X\n; zend.assertions\u001b[6;3H  Default Value: 1\u001b[59X\u001b[7;3H  Development Value: 1\u001b[8;3H  Production Value: -1\r\n\u001b[16X\u001b[10;3Hzend.exception_ignore_args\u001b[11;3H  Default Value: Off\r\n;   Development Value: Off\u001b[13;3H  Production Value: On\u001b[45X\r\n\u001b[62X\n; zend.exception_string_param_max_len\u001b[16;3H  Default Value: 15\u001b[58X\u001b[17;3H  Development Value: 15\u001b[12X\r\n;   Production Value: 0\r\n\u001b[45X\u001b[20;2H;;;;;;;;;;;;;;;;;;;\u001b[25X\u001b[21;3Hphp.ini Options  ;\u001b[27X\r\n;;;;;;;;;;;;;;;;;;;;\u001b[23;3HName for user-defined php.ini (.htaccess) files. Default is \".user.ini\"\u001b[24;2Huser_ini.filename = \".user.ini\"\u001b[44X\r\n\u001b[77X\n; To disable this feature set this option to an empty value\u001b[27;2Huser_ini.filename =\r\n\u001b[19X\u001b[29;2H TTL for user-defined php.ini files (time-to-live) in seconds. Default is 300 seconds (5 minutes)\u001b[30;2Huser_ini.cache_ttl = 300\u001b[50X\r\n\u001b[70X\u001b[32;2H;;;;;;;;;;;;;;;;;;;\u001b[7X\r\n; Langua\u001b[30m\u001b[103mge\u001b[m\u000f Options ;\u001b[34;2H;;;;;;;;;;;;;;;;;;;\u001b[55X\r\n\u001b[75X\u001b[36;3HEnable the PHP scripting langua\u001b[30m\u001b[103mge\u001b[m\u000f engine under Apache.\u001b[14X\u001b[37;3Hhttps://php.net/engine\u001b[55X\r\nengine =\u001b[92m On\u001b[m\u000f\r\n\u001b[77X\u001b[40;3HThis directive determines whether or not PHP will recognize code between\u001b[41;3H<? and ?> tags as PHP source which should be processed as such. It is   \u001b[42;3H\u001b[30m\u001b[103mge\u001b[m\u000fnerally recommended that <?php and ?> should be used and that this feature\r\n; should be disabled, as enabling it may result in issues when \u001b[30m\u001b[103mge\u001b[m\u000fnerating XML\u001b[44;3Hdocuments, however this remains supported for backward compatibility reasons.\r\n; Note that this directive does not control the <?= shorthand tag, which can be\u001b[46;2H used regardless of this directive.\u001b[47;3HDefault Value: On\u001b[48;2H Development Value: Off\r\n; Production Value: Off\u001b[50;3Hhttps://php.net/short-open-tag\u001b[49X\r\nshort_open_tag =\u001b[92m Off\u001b[m\u000f\u001b[57X\r\n\u001b[81X\u001b[53;3HThe number of significant digits displayed in floating point numbers.\r\n; https://php.net/precision\r\nprecision = 14  \r\n\u001b[21X\u001b[57;3HOutput buffering is a mechanism for controlling how much output data\u001b[58;3H(excluding headers and cookies) PHP should keep internally before pushing that\r\n; data to the client. If your application's output exceeds this setting, PHP\u001b[60;3Hwill send that data in chunks of roughly the size you specify.\u001b[61;3HTurning on this setting and managing its maximum buffer size can yield some\u001b[62;3Hinteresting side-effects depending on your application and web server.\u001b[63;3HYou may be able to send headers and cookies after you've already sent output\r\n; through print or echo. You also may see performance benefits if your server is\u001b[65;4Hmitting less packets due to buffered output versus PHP streaming the output\u001b[66;224H\u001b[0;10;7m\u000f80,9           8\u001b[67;4H\u001b[?25h"]
[0.245, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.004, "o", "\u001b[1;65r\u001b[H\u001b[33M\u001b[1;67r\u001b[3;34Hge\u001b[9;3Hge\u001b[10;64Hge\r\u001b[23B; as it \u001b[30m\u001b[103mget\u001b[m\u000fs it. On production servers, 4096 bytes is a good setting for performance\u001b[K\r\n; reasons.\u001b[K\r\n; Note: Output buffering can also be controlled via Output Buffering Control\u001b[K\r\n;   functions.\u001b[K\r\n; Possible Values:\u001b[K\r\n;   On = Enabled and buffer is unlimited. (Use with caution)\u001b[K\r\n;   Off = Disabled\u001b[K\r\n;   Integer = Enables the buffer and sets its maximum size in bytes.\u001b[K\r\n; Note: This directive is hardcoded to Off for the CLI SAPI\u001b[K\r\n; Default Value: Off\u001b[K\r\n; Development Value: 4096\u001b[K\r\n; Production Value: 4096\u001b[K\r\n; https://php.net/output-buffering\u001b[K\r\noutput_buffering = 4096\u001b[K\r\n\u001b[K\n; You can redirect all of the output of your scripts to a function.  For\u001b[K\r\n; example, if you set output_handler to \"mb_output_handler\", character\u001b[K\r\n; encoding will be transparently converted to the specified encoding.\u001b[K\r\n; Setting any output handler automatically turns on output buffering.\u001b[K\r\n; Note: People who wrote portable scripts should not depend on this ini\u001b[K\r\n;   directive. Instead, explicitly set the output handler using ob_start().\u001b[K\r\n;   Using this ini directive may cause problems unless you know what script\u001b[K\r\n;   is doing.\u001b[K\r\n; Note: You cannot use both \"mb_output_handler\" with \"ob_iconv_handler\"\u001b[K\r\n;   and you cannot use both \"ob_gzhandler\" and \"zlib.output_compression\".\u001b[K\r\n; Note: output_handler must be empty if this is set 'On' !!!!\u001b[K\r\n;   Instead you must use zlib.output_handler.\u001b[K\r\n; https://php.net/output-handler\u001b[K\r\n;output_handler =\u001b[K\r\n\u001b[K\n; URL rewriter function rewrites URL on the fly by using\u001b[K\r\n; output buffer. You can set tar\u001b[30m\u001b[103mget\u001b[m\u000f tags by this configuration.\u001b[K\r\n; \"form\" tag is special tag. It will add hidden input tag to pass values.\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f213,9           9\u001b[67;5H\u001b[?25h"]
[1.065, "o", "\u001b[?25l\u001b[m\u000ft"]
[0.003, "o", "\u001b[1;2H Dynamic Extensions ;\r\n;;;;;;;;;;;;;;;;;;;;;;\r\n\u001b[56X\u001b[4;3HIf you wish to have an extension loaded automatically, use the following\r\n; syntax:  \r\n;\u001b[7;3H  extension=modulename\u001b[50X\u001b[8;2H\u001b[70X\u001b[9;3HFor example:\u001b[64X\u001b[10;2H\u001b[76X\u001b[11;3H  extension=mysqli\u001b[59X\u001b[12;2H\u001b[78X\u001b[13;3HWhen the extension library to load is not located in the default extension\u001b[14;3Hdirectory, You may specify an absolute path to the library file:\u001b[15;2H\u001b[23X\u001b[16;3H  extension=/path/to/extension/mysqli.so\u001b[17;2H\u001b[31X\r\n; Note : The syntax used in previous PHP versions ('extension=<ext>.so' and\r\n; 'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[20;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[21;3Hmove to the new ('extension=<ext>) syntax.\r\n;\u001b[13X\r\n;extension=bcmath\u001b[24;2Hextension=bz2\u001b[56X\u001b[25;2Hextension=calendar\u001b[61X\r\nextension=\u001b[92mcurl\u001b[m\u000f\u001b[62X\u001b[27;2Hextension=dba\u001b[50X\u001b[28;2Hextension=enchant\u001b[59X\u001b[29;2Hextension=exif\u001b[57X\u001b[30;2Hextension=ffi\u001b[64X\u001b[31;2Hextension=ftp\u001b[66X\r\nextension=\u001b[92mgd\u001b[m\u000f\u001b[66X\r\nextension=\u001b[30m\u001b[103mgett\u001b[m\u000f\u001b[92mext\u001b[m\u000f\u001b[67X\u001b[34;2Hextension=gmp\u001b[35;2Hextension=iconv\u001b[60X\u001b[36;2Hextension=intl\u001b[37;2Hextension=ldap   \r\nextension=\u001b[92mmysqli\u001b[m\u000f\u001b[44X\u001b[39;2Hextension=odbc   \u001b[40;2Hextension=pdo_dblib\u001b[48X\r\nextension=\u001b[92mpdo_mysql\u001b[m\u000f\u001b[40X\u001b[42;2Hextension=pdo_odbc \u001b[43;2Hextension=pdo_pgsql\u001b[5X\u001b[44;2Hextension=pdo_sqlite   \u001b[45;2Hextension=pgsql\u001b[18X\r\n;extension=shmop\u001b[7X\r\n;extension=snmp\u001b[48;2Hextension=soap\u001b[57X\u001b[49;2Hextension=sockets\u001b[52X\u001b[50;2Hextension=sodium\u001b[52X\u001b[51;2Hextension=sqlite3\u001b[51X\u001b[52;2Hextension=sysvmsg\u001b[53X\u001b[53;2Hextension=sysvsem\u001b[57X\u001b[54;2Hextension=sysvshm\u001b[57X\u001b[55;2Hextension=tidy\u001b[56;2Hextension=xsl\u001b[57X\r\nextension=\u001b[92mzip\u001b[m\u000f\u001b[60X\r\nextension=\u001b[92mxml\u001b[m\u000f\u001b[48X\r\nextension=\u001b[92mmbstring\u001b[m\u000f\u001b[27X\r\n\u001b[32X\u001b[61;2H;;;;;;;;;;;;;;;;;;\r\n; Module Settings ;\u001b[63;2H;;;;;;;;;;;;;;;;;;\u001b[37X\r\n\u001b[63X\n\u001b[96m[CLI Server]\u001b[m\u000f\u001b[61X\u001b[66;223H\u001b[0;10;7m\u000f922,11         4\u001b[67;6H\u001b[?25h"]
