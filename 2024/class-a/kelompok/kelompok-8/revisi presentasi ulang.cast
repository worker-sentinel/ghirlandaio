[0.008, "o", "\u001b[H    #\u001b[55X\r\n    # ScriptAlias: This controls which directories contain server scripts. \r\n    # ScriptAliases are essentially the same as Aliases, except that\r\n    # documents in the target directory are treated as applications and\r\n    # run by the server when requested rather than as documents sent to the\r\n    # client.  The same rules about trailing \"/\" apply to ScriptAlias\r\n    # directives as to Alias.\u001b[16X\r\n    #\u001b[50X\r\n    \u001b[96mScriptAlias\u001b[m\u000f /cgi-bin/ \u001b[92m\"/srv/http/cgi-bin/\"\u001b[m\u000f\u001b[15X\r\n\u001b[61X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[46X\r\n\u001b[67X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f cgid_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[39X\r\n    #\u001b[46X\r\n    # ScriptSock: On threaded servers, designate the path to the UNIX\r\n    # socket used to communicate with the CGI daemon of mod_cgid.\r\n    #\u001b[42X\r\n    #Scriptsock cgisock\u001b[20X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[36X\r\n\u001b[43X\u001b[21;2H\u001b[52X\r\n# \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\u001b[23;2H CGI directory exists, if you have that configured.   \u001b[24;2H\u001b[48X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/cgi-bin\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[17X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\u001b[24X\r\n    \u001b[96mOptions\u001b[m\u000f None\u001b[37X\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[32X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[29X\r\n\u001b[59X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f headers_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[24X\r\n    #\u001b[44X\r\n    # Avoid passing HTTP_PROXY environment to CGI's on this or any \u001b[30m\u001b[103mproxi\u001b[m\u000fed\r\n    # backend servers which have lingering \"httpoxy\" defects.\r\n    # 'Proxy' request header is undefined by the IETF, not listed by IANA\r\n    #\u001b[38X\r\n    \u001b[96mRequestHeader\u001b[m\u000f unset Proxy early\u001b[19X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[42X\r\n\u001b[59X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mime_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[23X\r\n    #\u001b[36X\r\n    # TypesConfig points to the file containing the list of mappings from\r\n    # filename extension to MIME-type.\u001b[17X\r\n    #\u001b[48X\r\n    \u001b[96mTypesConfig\u001b[m\u000f conf/mime.types\u001b[18X\r\n\u001b[48X\n    #\u001b[40X\r\n    # AddType allows you to add to or override the MIME configuration\r\n    # file specified in TypesConfig for specific file types.\r\n    #\u001b[45X\r\n    #AddType application/x-gzip .tgz\u001b[12X\r\n    #\u001b[46X\r\n    # AddEncoding allows you to have certain browsers uncompress\r\n    # information on the fly. Note: Not all browsers support this.\r\n    #\u001b[48X\r\n    #AddEncoding x-compress .Z\u001b[25X\r\n    #AddEncoding x-gzip .gz .tgz\u001b[23X\r\n    #\u001b[50X\r\n    # If the AddEncoding directives above are commented-out, then you\r\n    # probably should define those extensions to indicate media types:\r\n    #\u001b[58X\r\n    \u001b[96mAddType\u001b[m\u000f application/x-compress .Z\u001b[16X\r\n    \u001b[96mAddType\u001b[m\u000f application/x-gzip .gz .tgz\u001b[24X\r\n\u001b[61X\n    #\u001b[54X\u001b[66;223H\u001b[0;10;7m\u000f396,68         76\u001b[67;7H\u001b[?25h"]
