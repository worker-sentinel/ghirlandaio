[0.007, "o", "\u001b[1;65r\u001b[H\u001b[49M\u001b[1;67r\u001b[4;2H\u001b[0;10;1m\u000fDirectory\r\u001b[13B\u001b[m\u000f    \u001b[96mOptions\u001b[m\u000f Indexes FollowSymLinks\u001b[K\r\n\u001b[K\n    #\u001b[K\r\n    # AllowOverride controls what directives may be placed in .htaccess files.\u001b[K\r\n    # It can be \"All\", \"None\", or any combination of the keywords:\u001b[K\r\n    #   AllowOverride FileInfo AuthConfig Limit\u001b[K\r\n    #\u001b[K\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\u001b[K\r\n\u001b[K\n    #\u001b[K\r\n    # Controls who can get stuff from this server.\u001b[K\r\n    #\u001b[K\r\n    \u001b[96mRequire\u001b[m\u000f all granted\u001b[K\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# \u001b[30m\u001b[103mDirectoryI\u001b[m\u000fndex: sets the file that Apache will serve if a directory\u001b[K\r\n# is requested.\u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f dir_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[30m\u001b[103mDirectoryI\u001b[m\u000f\u001b[96mndex\u001b[m\u000f index.html\u001b[K\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# The following lines prevent .htaccess and .htpasswd files from being \u001b[K\r\n# viewed by Web clients. \u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<Files\u001b[m\u000f \".ht*\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mRequire\u001b[m\u000f all denied\u001b[K\r\n\u001b[0;10;1m\u000f</Files>\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# ErrorLog: The location of the error log file.\u001b[K\r\n# If you do not specify an ErrorLog directive within a <VirtualHost>\u001b[K\r\n# container, error messages relating to that virtual host will be\u001b[K\r\n# logged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[K\r\n# container, that host's errors will be logged there and not here.\u001b[K\r\n#\u001b[K\r\n\u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/error_log\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# LogLevel: Control the number of messages logged to the error_log.\u001b[K\r\n# Possible values include: debug, info, notice, warn, error, crit,\u001b[K\r\n# alert, emerg.\u001b[K\r\n#\u001b[K\r\n\u001b[96mLogLevel\u001b[m\u000f warn\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f log_config_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    #\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f85,3          5\u001b[67;12H\u001b[?25h"]
