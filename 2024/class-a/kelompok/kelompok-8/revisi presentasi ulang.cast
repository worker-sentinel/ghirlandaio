[0.003, "o", "\u001b[1;79H\u001b[30m\u001b[103mg\u001b[6;20Hg\u001b[m\u000fent strin\u001b[30m\u001b[103mg\u001b[m\u000f. PHP's default settin\u001b[30m\u001b[103mg\u001b[7;25Hg\u001b[8;8Hg\u001b[15;20Hg\u001b[16;32Hg\u001b[m\u000f this fla\u001b[30m\u001b[103mg\u001b[18;4Hg\u001b[m\u000fets() and file() will work re\u001b[30m\u001b[103mg\u001b[19;41Hg\u001b[20;24Hg\u001b[26;74Hg\u001b[33;5H\u001b[m\u000fextension=mysql\u001b[41;50H\u001b[30m\u001b[103mg\u001b[54;12Hg\u001b[55;12Hg\u001b[56;12Hg\r\n\n\n\n\u001b[m\u000fextension=\u001b[92mmysql\u001b[65;17H\u001b[m\u000f\u001b[30m\u001b[103mg\u001b[66;224H\u001b[0;10;7m\u000f32,17\u001b[67;3H\u001b[?25h"]
