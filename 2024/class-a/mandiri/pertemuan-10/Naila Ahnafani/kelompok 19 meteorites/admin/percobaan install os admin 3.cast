[0.001, "o", "Optional dependencies for networkmanager\r\n\u001b[0;1m   \u001b[0m bluez: Bluetooth support\r\n    dhcpcd: alternative DHCP client\r\n    dnsmasq: connection sharing\r\n    firewalld: firewall support\r\n    iptables: connection sharing [installed]\r\n    iwd: wpa_supplicant alternative\r\n    libnvme: NBFT support\r\n    modemmanager: cellular network support\r\n    nftables: connection sharing [installed]\r\n    openresolv: alternative resolv.conf manager\r\n    pacrunner: PAC proxy support\r\n"]
[0.000, "o", "    polkit: let non-root users control networking [installed]\r\n    ppp: dialup connection support\r\n"]
