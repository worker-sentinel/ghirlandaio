[0.000, "o", "\u001b)0\u001b[1;48r\u001b[m\u000f\u001b[4l\u001b[?7h\u001b[39;49m\u001b[?25l\u001b[?1c\u001b[39;49m\u001b[m\u000f\u001b[H\u001b[J\u001b[46;79H\u001b[0;10;7m\u000f[ Reading... ]\u001b[m\u000f\u001b[46;77H\u001b[0;10;7m\u000f[ Read 79 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                           /etc/security/pwquality.conf                                                                     \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G"]
[0.002, "o", "\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d# Configuration for systemwide password quality limits\r\u001b[3d# Defaults:\r\u001b[4d#\u001b[5d\b# Number of characters in the new password that must not be present in the\r\u001b[6d# old password.\r\u001b[7d# difok = 1\r\u001b[8d#\u001b[9d\b# Minimum acceptable size for the new password (plus one if\r\u001b[10d# credits are not disabled which is the default). (See pam_cracklib manual.)\r\u001b[11d# Cannot be set to lower value than 6.\r\u001b[12d# minlen = 14\r\u001b[13d#\u001b[14d\b# The maximum credit for having digits in the new password. If less than 0\r\u001b[15d# it is the minimum number of digits in the new password.\r\u001b[16d# dcredit = -1\r\u001b[17d#\u001b[18d\b# The maximum credit for having uppercase characters in the new password.\r\u001b[19d# If less than 0 it is the minimum number of uppercase characters in the new\r\u001b[20d# password.\r\u001b[21d# ucredit = -1\r\u001b[22d#\u001b[23d\b# The maximum credit for having lowercase characters in the new password.\r\u001b[24d# If less than 0 it is the minimum number of lowercase characters in the new\r\u001b[25d# password.\r\u001b[26d# lcredit = -1\r\u001b[27d#\u001b[28d\b# The maximum credit for having other characters in the new password.\r\u001b[29d# If less than 0 it is the minimum number of other characters in the new\r\u001b[30d# password.\r\u001b[31d"]
[0.000, "o", "# ocredit = -1\r\u001b[32d#\u001b[33d\b# The minimum number of required classes of characters for the new\r\u001b[34d# password (digits, uppercase, lowercase, others).\r\u001b[35d# minclass = 0\r\u001b[36d#\u001b[37d\b# The maximum number of allowed consecutive same characters in the new password.\r\u001b[38d# The check is disabled if the value is 0.\r\u001b[39d# maxrepeat = 0\r\u001b[40d#\u001b[41d\b# The maximum number of allowed consecutive characters of the same class in the\r\u001b[42d# new password.\r\u001b[43d# The check is disabled if the value is 0.\r\u001b[44d# maxclassrepeat = 0\r\u001b[45d#\u001b[2d\b\u001b[?25h\u001b[?0c"]
