[0.010, "o", "  \u001b[1;32mGreat, no warnings\u001b[0m\r\n\r\n"]
[0.010, "o", "  \u001b[1;33mSuggestions\u001b[0m (32):\r\n  \u001b[1;37m----------------------------\u001b[0m\r\n"]
[0.079, "o", "  \u001b[1;33m*\u001b[0m Set a password on GRUB boot loader to prevent altering boot configuration (e.g. boot in single user mode without password) [BOOT-5122] \r\n"]
[0.001, "o", "    - Related resources\r\n"]
[0.008, "o", "      * Website: \u001b[0;37mhttps://cisofy.com/lynis/controls/BOOT-5122/\u001b[0m\r\n\r\n"]
[0.076, "o", "  \u001b[1;33m*\u001b[0m Consider hardening system services [BOOT-5264] \r\n"]
[0.001, "o", "    - Details  : \u001b[0;36mRun '/usr/bin/systemd-analyze security SERVICE' for each service\u001b[0m\r\n    - Related resources\r\n"]
