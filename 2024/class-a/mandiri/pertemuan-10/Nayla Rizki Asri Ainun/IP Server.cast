[0.520, "o", "\u001b[2;17H\u001b[97m\u001b[44m\u001b[K\u001b[3;17H\u001b[K\u001b[4;17H\u001b[K\u001b[5;17H\u001b[K\u001b[6;17H\u001b[K\u001b[7;17H           \u001b[30m\u001b[47m┌─┤ \u001b[31mNetworkManager TUI\u001b[30m ├──┐\u001b[97m\u001b[44m\u001b[K\u001b[8;17H           \u001b[30m\u001b[47m│            \u001b[7C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[9;17H           \u001b[30m\u001b[47m│ \u001b[34mPlease select an option\u001b[30m │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[10;17H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[11;17H           \u001b[30m\u001b[47m│ Edit a connection       │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[12;17H           \u001b[30m\u001b[47m│ \u001b[37m\u001b[41mActivate a connection  \u001b[30m\u001b[47m │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[13;17H           \u001b[30m\u001b[47m│ Set system hostname     │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[14;17H           \u001b[30m\u001b[47m│ Radio\u001b[7C            │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[15;17H           \u001b[30m\u001b[47m│\u001b[13C            │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[16;17H           \u001b[30m\u001b[47m│ Quit\u001b[8C            │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[17;17H           \u001b[30m\u001b[47m│\u001b[13C            │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[18;17H           \u001b[30m\u001b[47m│\u001b[13C       <OK> │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[19;17H           \u001b[30m\u001b[47m│\u001b[19C      │\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[20;17H           \u001b[30m\u001b[47m└─────────────────────────┘\u001b[97m\u001b[40m \u001b[44m\u001b[K\u001b[21;17H            \u001b[40m                           \u001b[44m\u001b[K\u001b[22;17H\u001b[K\u001b[23;17H\u001b[K\u001b[24;18H\u001b[K\u001b[12;30H"]
