[0.003, "o", "\u001b[0m\u001b[01;34mapp\u001b[0m     db_default.env                                   docker-compose.yaml      README.md\r\n\u001b[01;34mconf\u001b[0m    docker-compose-redis-elasticsearch.yaml          docker-compose.yaml.lvm\r\n\u001b[01;34mdbdata\u001b[0m  docker-compose-redis-load_balanced-haproxy.yaml  phpmyadmin.env\r\n"]
[0.001, "o", "\u001b]0;iqbal@iqbal:~/.config/kel19/compose\u0007"]
