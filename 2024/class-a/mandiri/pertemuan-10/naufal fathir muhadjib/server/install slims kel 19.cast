[0.000, "o", "\u001b[?25l\u001b[?2031h\u001b[>4;2m\u001b(B\u001b[m\u001b[H                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \r\n                                                                                                   \u001b[1 q\u001b[?1002h\u001b[?1006h\u001b[H\u001b[?25h"]
