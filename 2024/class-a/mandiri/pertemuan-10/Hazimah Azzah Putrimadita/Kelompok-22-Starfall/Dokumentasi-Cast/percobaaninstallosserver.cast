[0.028, "o", "\u001b[1m\u001b[33m==> WARNING:\u001b[m\u000f \u001b[1mPreset file '/etc/mkinitcpio.d/linux-lts.preset' is empty or does not contain any presets.\u001b[m\u000f\r\n"]
[0.001, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux.preset: 'archiso'\u001b[m\u000f\r\n\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing configuration file: '/etc/mkinitcpio.conf.d/blackbird.conf'\u001b[m\u000f\r\n"]
[0.001, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux -c /etc/mkinitcpio.conf.d/blackbird.conf -g /boot/initramfs-linux.img\u001b[m\u000f\r\n"]
[0.018, "o", "==> ERROR: Invalid option -k -- '/boot/vmlinuz-linux' must be readable\r\n"]
