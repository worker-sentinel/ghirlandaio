[0.000, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux-lts -c /etc/mkinitcpio.conf -U /EFI/Linux/arch-linux-lts.efi\u001b[m\u000f\r\n"]
