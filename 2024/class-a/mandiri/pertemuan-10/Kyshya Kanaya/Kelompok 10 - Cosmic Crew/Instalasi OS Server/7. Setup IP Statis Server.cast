[0.000, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# possible to run hostapd as root (since it needs to change network\u001b[K\u001b[49;150H\u001b(B\u001b[0;7m70\r\u001b[A\u001b[?25h"]
[0.020, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.002, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# configuration and open raw sockets) and still allow GUI/CLI components to be\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m1\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# run as non-root users. However, since the control interface can be used to\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m2\r\u001b[A\u001b[?25h"]
[0.022, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# change the network configuration, this access needs to be protected in many\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m3\r\u001b[A\u001b[?25h"]
[0.039, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.000, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# cases. By default, hostapd is configured to use gid 0 (root). If you\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m4\r\u001b[A\u001b[?25h"]
[0.016, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.000, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# want to allow non-root users to use the control interface, add a new group\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m5\r\u001b[A\u001b[?25h"]
[0.037, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.002, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# and change this value to match with that group. Add users that should have\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m6\r\u001b[A\u001b[?25h"]
