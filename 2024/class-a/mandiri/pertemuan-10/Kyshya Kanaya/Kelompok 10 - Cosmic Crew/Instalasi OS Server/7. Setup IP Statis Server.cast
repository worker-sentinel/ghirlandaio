[0.016, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h"]
[0.001, "o", "\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# directory to allow only members of a group to use sockets. This way, it is\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m9\r\u001b[A\u001b[?25h"]
