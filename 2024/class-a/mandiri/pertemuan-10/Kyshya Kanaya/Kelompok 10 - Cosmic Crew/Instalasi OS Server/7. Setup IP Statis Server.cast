[0.018, "o", "\u001b[?25l\u001b[50;157H\u001b(B\u001b[m~@k\r\u001b[A\u001b[A\u001b[?25h\u001b[?25l\u001b[50;157H   \u001b[1;48r\u001b[H\u001b[M\u001b[r\u001b[48;1H# multiple hostapd processes/interfaces can be run at the same time if more\u001b[K\u001b[49;151H\u001b(B\u001b[0;7m2\r\u001b[A\u001b[?25h"]
