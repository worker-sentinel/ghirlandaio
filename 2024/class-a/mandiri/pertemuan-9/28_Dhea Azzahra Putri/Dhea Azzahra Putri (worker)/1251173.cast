[0.367, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[17Pcat > /srv/database/db-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\rservices:\r\n\rmariadb:\r\n\rimage: mariadb:10.11\r\n\rnetworks:\r\n\r- openkm-net\r\n\revironment;\r\n\r- MYSQL_ROOT_PASSWORD=root_secret\r\n\r- MYSQL_DATABASE=openkm\r\n\r- MYSSQL_USER=openkm\r\n\r- MYSQL_PASSWORD=openkm_db_secret\r\n\rvolumes:\r\n\r- /srv/database/mariadb:/var/lib/mysql\r\n\rports:\r\n\r- \"3306:3306\"\r\n\rcommand: >\r\n\r--charter-set-server=utf8mb4\r\n\r--collation-server=utf8mb4_unicode_ci\r\n\r--innodb-buffer-pool-size=512M\r\n\r--max-allowed-packet=64M\r\n\rdeploy:\r\n\rreplicas: 1\r\n\rplacment:\r\n\rconstraints:\r\n\r- node.role == worker\r\n\rrestart_policy:\r\n\rcondition: on-failure\r\n\rresources:\r\n\rlimits:\r\n\rmemory: 1G\r\n\rhealthcheck:\r\n\rtest: [\"CMD\". \"heathcheck.sh\". \"--connect\", \"--innodb_initialized\"]\r\n\rinterval: 30s\r\n\rtimeout: 10s\r\n\rretries: 5\r\n"]
[0.000, "o", "\r\n\rnetworks:\r\n\ropenkm-net:\r\n\rexternal: true\r\n\rEOF\r\n\r"]
