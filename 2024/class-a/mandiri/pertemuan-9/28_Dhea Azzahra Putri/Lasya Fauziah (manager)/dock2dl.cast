\u001b[C\u001b[C\u001b[1Pplacement:\r\n\r\u001b[C\u001b[C\u001b[C\u001b[3@ constraints\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C - node.role == manager\r\n\r\u001b[C\u001b[C\u001b[C\u001b[9Prestart_policy:\r\n\r\u001b[C\u001b[C\u001b[C condition: on-failure\r\n\r\u001b[C\u001b[C\u001b[C\u001b[12Presources:\r\n\r\u001b[C\u001b[C\u001b[C\u001b[2P limit\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C memory: 1.5G\r\n\r                 \r\n\rnginx:\r\n\r image: nginx:stable-alpine\r\n\r\u001b[C\u001b[17Pnetworks:\r\n\r\u001b[C - openkm-net\r\n\r\u001b[C\u001b[7Pports:\r\n\r\u001b[C - \"80:80\"\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[2@443:443\r\n\r\u001b[C\u001b[4Pconfigs:\r\n\r\u001b[C - source: nginx_conf\r\n\r\u001b[C\u001b[C\u001b[18@target: /etc/nginx/conf.d/default.\r\n\r\u001b[Cdeploy:                                \r\n\r\u001b[C replicas: 1\r\n\r\u001b[C\u001b[C\u001b[C\u001b[Cstart_policy:\r\n\r\u001b[C\u001b[C condition: on-failure\r\n\r                        \r\n\rvolumes:\r\n\r\u001b[5@ openkm_data\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Clogs\r\n\r             \r\n\rconfigs:\r\n\r\u001b[4@ nginx_conf\r\n\r\u001b[C file: ./nginx.conf\r\n\r                    \r\n\rnetworks:\r\n\r         \r\n\r openkm-net:\r\n\r\u001b[C external: true\r\n\rEOF             \r\n\r\u001b[K\r\n\r\u001b[K\u001b[A"]
