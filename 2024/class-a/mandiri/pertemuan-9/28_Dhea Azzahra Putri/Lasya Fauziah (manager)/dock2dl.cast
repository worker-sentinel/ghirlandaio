[1.067, "o", "\u001b[H\u001b[2J[root@cadhe openkm]# cat > opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\rservices:\r\n\r openkm:\r\n\r  image: openkm/openkm-ce:6.3.12\r\n\r  networks:\r\n\r   - openkm-net\r\n\r  environment:\r\n\r   - OPENKM_URL=http://openkm:8080/OpenKM\r\n\r   - DB_DRIVER=com.mysql.jdbc.Driver\r\n\r   - DB_URL=jdbc:mysql://172.20.10.3:2377/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r   - DB_USER=openkm\r\n\r   - DB_PASS=openkm_db_secret\r\n\r  volumes:\r\n\r   - openkm_data:/opt/openkm/repository\r\n\r   - openkm_logs:/opt/openkm/log\r\n\r  ports:\r\n\r   - \"8080\"8080\"\r\n\r  deploy:\r\n\r   replicas: 1\r\n\r   placement:\r\n\r    constraints:\r\n\r     - node.role == manager\r\n\r   restart_policy:\r\n\r    condition: on-failure\r\n\r   resources:\r\n\r    limits:\r\n\r\n\r\n\rmemory: 1.5G\r\n\r\n\rnginx:\r\n\rimage: nginx:stable-alpine\r\n\rnetworks:\r\n\r- openkm-net\r\n\rports:\r\n\r- \"80:80\"\r\n\r- \"443:443\"\r\n\rconfigs:\r\n\r- source: nginx_conf\r\n\rtarget: /etc/nginx/conf.d/default.conf\r\n\rdeploy:\r\n\rreplicas: 1\r\n\rrestart_policy:\r\n\rcondition: on-failure\r\n\r\n\rvolumes:\r\n\ropenkm_data:\r\n\ropenkm_logs:\r\n\r\n\rconfigs:\r\n\rnginx_conf:\r\n\rfile: ./nginx.conf\r\n\r\n\rnetworks:\r\n\r\n\ropenkm-net:\r\n\rexternal: true\r\n\r"]
[2.358, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A              \r\n\r\n\rversion: \"3.8\"\r\n\r        \r\n\rservices:                       \r\n\r\u001b[4Popenkm\r\n\rimage: openkm/openkm-ce:6.3.12\r\n\r\u001b[5Pnetworks\r\n\r- openkm-net                             \r\n\r\u001b[24Penvironment:\r\n\r\u001b[76P- OPENKM_URL=http://openkm:8080/OpenKM\r\n\r- DB_DRIVER=com.mysql.jdbc.Driver\r\n\r- DB_URL=jdbc:mysql://172.20.10.3:2377/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r- DB_USER=openkm\r\n\r\u001b[13P- DB_PASS=openkm_db_secret\r\n\rvolumes:                        \r\n\r- openkm_data:/opt/openkm/repository\r\n\r- openkm_logs:/opt/openkm/log\r\n\r\u001b[3Pports\r\n\r\u001b[1P- \"8080\"8080\"\r\n\r\u001b[6Pdeploy\r\n\r\u001b[5Preplicas: 1\r\n\r\u001b[17Pplacement:\r\n\r\u001b[6Pconstraints\r\n\r\u001b[3P- node.role == manager\r\n\r\u001b[2@restart_policy\r\n\rcondition: on-failure\r\n\rresources:\r\n\rlimits\r\n\r            \r\n\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n"]
