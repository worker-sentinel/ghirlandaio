[0.253, "o", "\u001b[H\u001b[2J[root@cadhe openkm]# cat > docker-stack.yml << 'EOF'\r\n\rcat > opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\rservices:\r\n\r openkm:\r\n\r  image: openkm/openkm-ce:6.3.12\r\n\r  networks:\r\n\r   - openkm-net\r\n\r  environment:\r\n\r   - OPENKM_URL=http://openkm:8080/OpenKM\r\n\r   - DB_DRIVER=com.mysql.jdbc.Driver\r\n\r   - DB_URL=jdbc:mysql://172.20.10.3:2377/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r   - DB_USER=openkm\r\n\r   - DB_PASS=openkm_db_secret\r\n\r  volumes:\r\n\r   - openkm_data:/opt/openkm/repository\r\n\r   - openkm_logs:/opt/openkm/log\r\n\r  ports:\r\n\r   - \"8080\"8080\"\r\n\r  deploy:\r\n\r   replicas: 1\r\n\r   placement:\r\n\r    constraints:\r\n\r     - node.role == manager\r\n\r   restart_policy:\r\n\r    condition: on-failure\r\n\r   resources:\r\n\r    limits:\r\n\r     memory: 1.5G\r\n\r\n\rnginx:\r\n\r image: nginx:stable-alpine\r\n\r networks:\r\n\r  - openkm-net\r\n\r ports:\r\n\r  - \"80:80\"\r\n\r  - \"443:443\"\r\n\r configs:\r\n\r  - source: nginx_conf\r\n\r  target: /etc/nginx/conf.d/default.conf\r\n\r deploy:\r\n\r  replicas: 1\r\n\r  restart_policy:\r\n\r   condition: on-failure\r\n\r\n\rvolumes:\r\n\r openkm_data:\r\n\r openkm_logs:\r\n\r\n\rconfigs:\r\n\r nginx_conf:\r\n\r  file: ./nginx.conf\r\n\r\n\rnetworks:\r\n\r\n\r openkm-net:\r\n\r  external: true\r\n\rEOF\r\n\r"]
[0.512, "o", "\u001b[H\u001b[2J[root@cadhe openkm]# cat > docker-stack.yml << 'EOF'\r\n\rcat > opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\rservices:\r\n\r openkm:\r\n\r  image: openkm/openkm-ce:6.3.12\r\n\r  networks:\r\n\r   - openkm-net\r\n\r  environment:\r\n\r   - OPENKM_URL=http://openkm:8080/OpenKM\r\n\r   - DB_DRIVER=com.mysql.jdbc.Driver\r\n\r   - DB_URL=jdbc:mysql://172.20.10.3:2377/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r   - DB_USER=openkm\r\n\r   - DB_PASS=openkm_db_secret\r\n\r  volumes:\r\n\r   - openkm_data:/opt/openkm/repository\r\n\r   - openkm_logs:/opt/openkm/log\r\n\r  ports:\r\n\r   - \"8080\"8080\"\r\n\r  deploy:\r\n\r   replicas: 1\r\n\r   placement:\r\n\r    constraints:\r\n\r     - node.role == manager\r\n\r   restart_policy:\r\n\r    condition: on-failure\r\n\r   resources:\r\n\r    limits:\r\n\r     memory: 1.5G\r\n\r\n\rnginx:\r\n\r image: nginx:stable-alpine\r\n\r networks:\r\n\r  - openkm-net\r\n\r ports:\r\n\r  - \"80:80\"\r\n\r  - \"443:443\"\r\n\r configs:\r\n\r  - source: nginx_conf\r\n\r  target: /etc/nginx/conf.d/default.conf\r\n\r deploy:\r\n\r  replicas: 1\r\n\r  restart_policy:\r\n\r   condition: on-failure\r\n\r\n\rvolumes:\r\n\r openkm_data:\r\n\r openkm_logs:\r\n\r\n\rconfigs:\r\n\r nginx_conf:\r\n\r  file: ./nginx.conf\r\n\r\n\rnetworks:\r\n\r\n\r openkm-net:\r\n\r  external: true\r\n\rEOF\r\n\r"]
[0.349, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[11@opt/openkm/\r\n\r\u001b[28Pversion: \"3.8\"\r\n\r              \r\n\rservices:\r\n\r\u001b[1P openkm\r\n\r\u001b[C image: openkm/openkm-ce:6.3.12\r\n\r\u001b[C\u001b[Cnetworks:                     \r\n\r\u001b[C\u001b[C - openkm-net\r\n\r\u001b[C\u001b[C\u001b[1Penvironment:\r\n\r\u001b[C\u001b[C - OPENKM_URL=http://openkm:8080/OpenKM\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[5PDB_DRIVER=com.mysql.jdbc.Driver\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[CURL=jdbc:mysql://172.20.10.3:2377/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[CSER=openkm                                                                                               \r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[CPASS=openkm_db_secret\r\n\r\u001b[C\u001b[Cvolumes:                   \r\n\r\u001b[C\u001b[C - openkm_data:/opt/openkm/repository\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[7Plogs:/opt/openkm/log\r\n\r\u001b[C\u001b[Cports:                        \r\n\r\u001b[C\u001b[C - \"8080\"8080\"\r\n\r\u001b[C\u001b[C\u001b[7Pdeploy:\r\n\r\u001b[C\u001b[C replicas: 1\r\n\r\u001b[C\u001b[C\u001b[C\u001b[1Pplacement:\r\n\r\u001b[C\u001b[C\u001b[C\u001b[3@ constraints\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C - node.role == manager\r\n\r\u001b[C\u001b[C\u001b[C\u001b[9Prestart_policy:\r\n\r\u001b[C\u001b[C\u001b[C condition: on-failure\r\n\r\u001b[C\u001b[C\u001b[C\u001b[12Presources:\r\n\r\u001b[C\u001b[C\u001b[C\u001b[2P limit\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C memory: 1.5G\r\n\r                 \r\n\rnginx:\r\n\r image: nginx:stable-alpine\r\n\r\u001b[C\u001b[17Pnetworks:\r\n\r\u001b[C - openkm-net\r\n\r\u001b[C\u001b[7Pports:\r\n\r\u001b[C - \"80:80\"\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[2@443:443\r\n\r\u001b[C\u001b[4Pconfigs:\r\n\r\u001b[C - source: nginx_conf\r\n\r\u001b[C\u001b[C\u001b[18@target: /etc/nginx/conf.d/default.\r\n\r\u001b[Cdeploy:                                \r\n\r\u001b[C replicas: 1\r\n\r\u001b[C\u001b[C\u001b[C\u001b[Cstart_policy:\r\n\r\u001b[C\u001b[C condition: on-failure\r\n\r                        \r\n\rvolumes:\r\n\r\u001b[5@ openkm_data\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Clogs\r\n\r             \r\n\rconfigs:\r\n\r\u001b[4@ nginx_conf\r\n\r\u001b[C file: ./nginx.conf\r\n\r                    \r\n\rnetworks:\r\n\r         \r\n\r openkm-net:\r\n\r\u001b[C external: true\r\n\rEOF             \r\n\r\u001b[K\r\n\r\u001b[K\u001b[A"]
