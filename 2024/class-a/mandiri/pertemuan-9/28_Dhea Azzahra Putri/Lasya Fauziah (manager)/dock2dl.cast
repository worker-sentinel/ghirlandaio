[0.007, "o", "     1\tversion: \"3.8\"\r\n     2\t\r\n     3\tservices:\r\n     4\t openkm:\r\n     5\t  image: openkm/openkm-ce:6.3.12\r\n     6\t  networks:\r\n     7\t   - openkm-net\r\n     8\t  environment:\r\n     9\t   - OPENKM_URL=http://openkm:8080/OpenKM\r\n    10\t   - DB_DRIVER=com.mysql.jdbc.Driver\r\n    11\t   - DB_URL=jdbc:mysql://192.168.1.11:3306/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n    12\t   - DB_USER=openkm\r\n    13\t   - DB_PASS=dhea19\r\n    14\t  volumes:\r\n    15\t   - openkm_data:/opt/openkm/repository\r\n    16\t   - openkm_logs:/opt/openkm/log\r\n    17\t  ports:\r\n    18\t   - \"8080\"8080\"\r\n    19\t  deploy:\r\n    20\t   replicas: 1\r\n    21\t   placement:\r\n    22\t    constraints:\r\n    23\t     - node.role == manager\r\n    24\t   restart_policy:\r\n    25\t    condition: on-failure\r\n    26\t   resources:\r\n    27\t    limits:\r\n    28\t     memory: 1.5G\r\n    29\t\r\n    30\tnginx:\r\n    31\t image: nginx:stable-alpine\r\n    32\t networks:\r\n    33\t  - openkm-net\r\n    34\t ports:\r\n    35\t  - \"80:80\"\r\n    36\t  - \"443:443\"\r\n    37\t configs:\r\n    38\t  - source: nginx_conf\r\n    39\t  target: /etc/nginx/conf.d/default.conf\r\n    40\t deploy:\r\n    41\t  replicas: 1\r\n    42\t  restart_policy:\r\n    43\t   condition: on-failure\r\n    44\t\r\n    45\tvolumes:\r\n    46\t openkm_data:\r\n    47\t openkm_logs:\r\n    48\t\r\n    49\tconfigs:\r\n    50\t nginx_conf:\r\n    51\t  file: ./nginx.conf\r\n    52\t\r\n    53\tnetworks:\r\n    54\t\r\n    55\t openkm-net:\r\n    56\t  external: true\r\n"]
