[0.683, "o", "\u001b[A\u001b[A\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[5P/opt/openkm/nginx.conf\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name -;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options \"SAMEORIGIN\" always;\r\n\radd_header X-Content-Type-Options \"nosniff\" always;\r\n\radd_header X-XXS-Protection \"1; mode-block\" always;\r\n\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n\rproxy_set_header X-Real-IP $remote_addr;\r\n\rproxy_set_header X-Forwaded-For $proxy_add_x_forwaded_for;\r\n\rproxy_set_header X-Forwaded-Proto $scheme;\r\n\rproxy_read_timeout 300s;\r\n\r}\r\n\r}\r\n\rEOF\r\n\r"]
