[3.993, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[A"]
[0.399, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[A"]
[0.733, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c#"]
