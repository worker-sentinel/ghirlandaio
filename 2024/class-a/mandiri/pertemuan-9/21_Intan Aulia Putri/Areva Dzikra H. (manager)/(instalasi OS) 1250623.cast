[0.002, "o", "\u001b[1;15H\u001b[30m\u001b[103mh\u001b[3;4Hh\u001b[m\u000fe following modules are loaded before any boot \u001b[30m\u001b[103mh\u001b[4;31Hh\u001b[5;7Hh\u001b[6;19Hh\u001b[m\u000fid x\u001b[30m\u001b[103mh\u001b[m\u000fci_\u001b[30m\u001b[103mh\u001b[10;4Hh\u001b[11;6Hh\u001b[m\u000f into t\u001b[30m\u001b[103mh\u001b[m\u000fe CPIO image.  T\u001b[30m\u001b[103mh\u001b[12;13Hh\u001b[m\u000fe actual binaries included by a given \u001b[30m\u001b[103mh\u001b[17;4Hh\u001b[m\u000fis setting is similar to BINARIES above, \u001b[30m\u001b[103mh\u001b[18;42Hh\u001b[22;4Hh\u001b[m\u000fis is t\u001b[30m\u001b[103mh\u001b[m\u000fe most important setting in t\u001b[30m\u001b[103mh\u001b[m\u000fis file.  T\u001b[30m\u001b[103mh\u001b[m\u000fe HOOKS control t\u001b[30m\u001b[103mh\u001b[23;33Hh\u001b[m\u000fe image, and w\u001b[30m\u001b[103mh\u001b[m\u000fat \u001b[30m\u001b[103mh\u001b[24;46Hh\u001b[m\u000fat you do not c\u001b[30m\u001b[103mh\u001b[m\u000fange t\u001b[30m\u001b[103mh\u001b[25;13Hh\u001b[m\u000fic\u001b[30m\u001b[103mh\u001b[m\u000f HOOKS are added.  Run 'mkinitcpio -H <\u001b[30m\u001b[103mh\u001b[26;3Hh\u001b[m\u000felp on a given \u001b[30m\u001b[103mh\u001b[27;51Hh\u001b[31;7Hh\u001b[m\u000fis setup specifies all modules in t\u001b[30m\u001b[103mh\u001b[35;7Hh\u001b[m\u000fis setup will autodetect all modules for your system and s\u001b[30m\u001b[103mh\u001b[39;7Hh\u001b[m\u000fis setup will generate a 'full' image w\u001b[30m\u001b[103mh\u001b[m\u000fic\u001b[30m\u001b[103mh\u001b[43;7Hh\u001b[m\u000fis setup assembles a mdadm array wit\u001b[30m\u001b[103mh\u001b[47;154H\u001b[0;10;7m\u000f7,4  \u001b[48;3H\u001b[?25h"]
