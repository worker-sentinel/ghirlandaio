[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d## sudoers file.\r\u001b[3d"]
[0.000, "o", "##\r\u001b[4d"]
[0.000, "o", "## This file MUST be edited with the 'visudo' command as root.\r\u001b[5d## Failure to use 'visudo' may result in syntax or file permission errors\r\u001b[6d"]
[0.000, "o", "## that prevent sudo from running.\r\u001b[7d##\r\u001b[8d"]
[0.000, "o", "## See the sudoers man page for the details on how to write a sudoers file.\r\u001b[9d"]
[0.000, "o", "##\r\u001b[11d"]
[0.000, "o", "##\r\u001b[12d"]
[0.001, "o", "## Host alias specification\r\u001b[13d##\r\u001b[14d## Groups of machines. These may include host names (optionally with wildcards),\r\u001b[15d## IP addresses, network numbers or netgroups.\r\u001b[16d"]
[0.000, "o", "# Host_Alias    WEBSERVERS = www1, www2, www3\r\u001b[18d##\r\u001b[19d"]
[0.000, "o", "## User alias specification\r\u001b[20d"]
[0.000, "o", "##\r\u001b[21d"]
[0.000, "o", "## Groups of users.  These may consist of user names, uids, Unix groups,\r\u001b[22d## or netgroups.\r\u001b[23d# User_Alias    ADMINS = millert, dowdy, mikef\r\u001b[25d##\r\u001b[26d## Cmnd alias specification\r\u001b[27d##\r\u001b[28d"]
[0.000, "o", "## Groups of commands.  Often used to group related commands together.\r\u001b[29d# Cmnd_Alias    PROCESSES = /usr/bin/nice, /bin/kill, /usr/bin/renice, \\\r\u001b[30d#\u001b[30;29H"]
[0.000, "o", "/usr/bin/pkill, /usr/bin/top\r\u001b[31d#\u001b[32d\b"]
[0.000, "o", "# Cmnd_Alias    REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff\r\u001b[33d#\u001b[34d\b# Cmnd_Alias    DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bin/strace, \\\r\u001b[35d"]
[0.000, "o", "#\u001b[35;29H"]
[0.000, "o", "/usr/bin/truss, /usr/bin/bpftrace, \\\r\u001b[36d#\u001b[36;29H/usr/bin/dtrace, /usr/bin/dtruss\r\u001b[37d#\u001b[38d\b"]
[0.000, "o", "# Cmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \\\r\u001b[39d#\u001b[39;26H"]
[0.000, "o", "/usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \\\r\u001b[40d"]
[0.000, "o", "#\u001b[40;26H"]
[0.000, "o", "/usr/bin/pacman\r\u001b[42d##\r\u001b[43d## Defaults specification\r\u001b[44d##\r\u001b[45d## Preserve editor environment variables for visudo.\r\u001b[2d\u001b[?25h\u001b[?0c"]
