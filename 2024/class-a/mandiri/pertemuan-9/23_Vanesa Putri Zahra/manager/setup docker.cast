[0.000, "o", "\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H"]
[0.000, "o", "\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d## sudoers file.\r\u001b[3d##\r\u001b[4d"]
[0.000, "o", "## This file MUST be edited with the 'visudo' command as root.\r\u001b[5d## Failure to use 'visudo' may result in syntax or file permission errors\r\u001b[6d"]
[0.000, "o", "## that prevent sudo from running.\r\u001b[7d##\r\u001b[8d## See the sudoers man page for the details on how to write a sudoers file.\r\u001b[9d"]
[0.000, "o", "##\r\u001b[11d"]
[0.000, "o", "##\r\u001b[12d## Host alias specification\r\u001b[13d##\r\u001b[14d## Groups of machines. These may include host names (optionally with wildcards),\r\u001b[15d"]
[0.001, "o", "## IP addresses, network numbers or netgroups.\r\u001b[16d# Host_Alias    WEBSERVERS = www1, www2, www3\r\u001b[18d"]
[0.000, "o", "##\r\u001b[19d## User alias specification\r\u001b[20d##\r\u001b[21d"]
[0.000, "o", "## Groups of users.  These may consist of user names, uids, Unix groups,\r\u001b[22d## or netgroups.\r\u001b[23d"]
[0.000, "o", "# User_Alias    ADMINS = millert, dowdy, mikef\r\u001b[25d"]
[0.000, "o", "##\r\u001b[26d"]
[0.000, "o", "## Cmnd alias specification\r\u001b[27d##\r\u001b[28d## Groups of commands.  Often used to group related commands together.\r\u001b[29d"]
[0.000, "o", "# Cmnd_Alias    PROCESSES = /usr/bin/nice, /bin/kill, /usr/bin/renice, \\\r\u001b[30d#\u001b[30;29H/usr/bin/pkill, /usr/bin/top\r\u001b[31d#\u001b[32d\b"]
[0.000, "o", "# Cmnd_Alias    REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff\r\u001b[33d#\u001b[34d\b# Cmnd_Alias    DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bin/strace, \\\r\u001b[35d#\u001b[35;29H"]
[0.000, "o", "/usr/bin/truss, /usr/bin/bpftrace, \\\r\u001b[36d#\u001b[36;29H/usr/bin/dtrace, /usr/bin/dtruss\r\u001b[37d#\u001b[38d\b"]
[0.000, "o", "# Cmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \\\r\u001b[39d#\u001b[39;26H/usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \\\r\u001b[40d#\u001b[40;26H/usr/bin/pacman\r\u001b[42d"]
[0.000, "o", "##\r\u001b[43d## Defaults specification\r\u001b[44d##\r\u001b[45d"]
[0.000, "o", "## Preserve editor environment variables for visudo.\r\u001b[2d\u001b[?25h\u001b[?0c"]
