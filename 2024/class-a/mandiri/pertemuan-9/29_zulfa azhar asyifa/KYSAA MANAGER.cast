[0.037, "o", "\b\b\b\b\b\b\b\b\b\b\b\b\bat > /opt/openkm/nginx.conf << 'EOF'\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name _;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options\r\n\r\"SAMEORIGIN\" always;\r\n\radd_header X_content-Type-Options\r\n\r\"nosnif\" always;\r\n\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n\rproxy_set_header\r\n"]
[0.000, "o", "\r"]
[0.036, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[CC\r\n\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[1@f\r\n\r\n\r\n\r\n\r\n\r\n\r\n\rcat > /opt/openkm/nginx.conf << 'EOF'\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name _;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options\r\n\r\"SAMEORIGIN\" always;\r\n"]
[0.001, "o", "\radd_header X_Content-Type-Options\r\n\r\"nosniff\" always;\r\n"]
[0.000, "o", "\radd_header X-XSS-Protection \"1;\r\n\r\n\r\n\rmode=block\" always;\r\n\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n"]
