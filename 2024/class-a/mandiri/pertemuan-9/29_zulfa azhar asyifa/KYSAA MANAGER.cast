[0.003, "o", "\u001b[?25l\u001b[m\u000f\u001b[94mversion\u001b[m\u000f\u001b[96m:\u001b[m\u000f \u001b[92m\"3.8\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[K\n\u001b[94mservices\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n  \u001b[94mopenkm\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f openkm/openkm-ce:6.3.12\u001b[K\r\n    \u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm-net\u001b[K\r\n    \u001b[94menvironment\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f OPENKM_URL=http://openkm:8080/OpenKM\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_DRIVER=com.mysql.jdbc.Driver\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_URL=jdbc:mysql://172.20.10.18/28/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_USER=openkm\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_PASS=kysa1012\u001b[K\r\n    \u001b[94mvolumes\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm_data:/opt/openkm/repository\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm_logs:/opt/openkm/log\u001b[K\r\n    \u001b[94mports\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[92m\"8080:8080\"\u001b[m\u000f\u001b[K\r\n    \u001b[94mdeploy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mreplicas\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1\u001b[K\r\n      \u001b[94mplacement\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mconstraints\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n         \u001b[0;10;1m\u000f-\u001b[m\u000f node.role == manager\u001b[K\r\n \u001b[94mrestart_policy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n  \u001b[94mcondition\u001b[m\u000f\u001b[96m:\u001b[m\u000f o