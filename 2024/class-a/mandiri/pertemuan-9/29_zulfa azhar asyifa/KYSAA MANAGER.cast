[2.698, "o", "\u001b[H\u001b[J[root@kyarch openkm]# cat > /opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\r\n\rservices:\r\n\ropenkm:\r\n\rimage: openkm/openkm-ce:6.3.12\r\n\rnetworks:\r\n\r- openkm-net\r\n\renvironment:\r\n\rOPENKM_URL=http://openkm:8080/OpenKM\r\n\r- DB_DRIVER=com.mysql.jdbc.Driver\r\n\r-\r\n\rDB_USl=jdbc:mysql://172.20.10.18/28/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r\n\r- DB_USER=openkm\r\n"]
[0.000, "o", "\r- DB_PASS=openkm_db_secret\r\n\rvolumes:\r\n\r- openkm_data:/opt/openkm/repository\r\n\r- openkm_logs:/opt/openkm/log\r\n\rports:\r\n\r\"8080:8080\"\r\n\rdeploy:\r\n\rreplicas: 1\r\n\rplacement:\r\n\rconstraints:"]
[0.000, "o", "\r\n\r- node.role == manager\r\n\rrestart_policy:\r\n"]
[0.000, "o", "\rcondition: on-faliure\r\n\rresourcs:\r\n\rlimits:\r\n"]
[0.000, "o", "\rmemory: 1.5G\r\n\r\n\r\n\rnginx:\r\n\rimage:nginx:stable-alpine\r\n\rnetworks:\r\n\r- openkm-net\r\n\rports:\r\n\r\"80:80\"\r\n\r- \"443:443:\"\r\n\rconfigs:\r\n\r- source: nginx_conf\r\n\rtarget: /etc/nginx/conf.d/defaults.conf\r\n\rdeploy:\r\n\rreplicas: 1\r\n\rrestart_policy:\r\n\rcondition: on-failure\r\n\r\n\r\n\rvolumes:\r\n\ropenkm_data:\r\n"]
