[0.656, "o", "\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bnginx.conf << 'EOF'\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name _;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options\r\n\r\"SAMEORIGIN\" always;\r\n\radd_header X_Content-Type-Options\r\n\r\"nosniff\" always;\r\n"]
[0.000, "o", "\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n"]
[0.000, "o", "\rproxy_set_header\r\n\r\n\rcat > /opt/openkm/nginx.conf << 'EOF'\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name _;\r\n\r\n"]
[0.000, "o", "\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n"]
[0.000, "o", "\radd_header X-Frame-Options\r\n"]
[0.000, "o", "\r\"SAMEORIGIN\" always;\r\n\radd_header X_Content-Type-Options\r\n\r\"nosniff\" always;\r\n"]
[0.000, "o", "\radd_header X-XSS-Protection \"1;\r\n\r\n\r\n\rmode=block\" always;\r\n\r\n"]
[0.000, "o", "\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n"]
[0.000, "o", "\rproxy_set_header Host $host;\r\n\rproxy_set_header X-Real-IP\r\n\r$remote_addr;\r\n"]
[0.000, "o", "\rproxy_set_header X-Forwarded-For\r\n\r$proxy_add_x_forwarded_for;\r\n\rproxy_set_header X-Forwarded-Proto\r\n\r$scheme;\r\n\rproxy_read_timeout 300s;\r\n\r}\r\n\r}\r\n\rEOF\r\n\r"]
