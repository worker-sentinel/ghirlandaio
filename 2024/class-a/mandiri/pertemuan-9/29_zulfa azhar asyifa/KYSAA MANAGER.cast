[0.066, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[Ccat > /opt/openkm/nginx.conf << 'EOF'\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name _;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options\r\n\r\"SAMEORIGIN\" always;\r\n\radd_header X_Content-Type-Options\r\n\r\"nosniff\" always;\r\n\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n\rproxy_set_header\r\n\r\n"]
[0.000, "o", "\rcat > /opt/openkm/nginx.conf << 'EOF'\r\n\rserver {\r\n"]
[0.000, "o", "\rlisten 80;\r\n\rserver_name _;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options\r\n\r\"SAMEORIGIN\" always;\r\n\radd_header X_Content-Type-Options\r\n\r\"nosniff\" always;\r\n\radd_header X-XSS-Protection \"1;\r\n\r\n\r\n\rmode=block\" always;\r\n\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n\rproxy_set_header X-Real-IP\r\n\r$remote_addr;\r\n\rproxy_set_header X-Forwarded-For\r\n"]
[0.000, "o", "\r$proxy_add_x_forwarded_for;\r\n\rproxy_set_header X-Forwarded-Proto\r\n\r$scheme;\r\n\rproxy_read_timeout 300s;\r\n\r}\r\n"]
[0.000, "o", "\r}\r\n\rEOF\r\n\r"]
[0.067, "o", "\u001b[H\u001b[J[root@kyarch openkm]# cat > /opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\r\n\rservices:\r\n\ropenkm:\r\n\rimage: openkm/openkm-ce:6.3.12\r\n\rnetworks:\r\n\r- openkm-net\r\n\renvironment:\r\n\r- OPENKM_URL=http://openkm:8080/OpenKM\r\n\r- DB_DRIVER=com.mysql.jdbc.Driver\r\n\r-\r\n\rDB_USl=jdbc:mysql://172.20.10.18/28/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r- DB_USER=openkm\r\n"]
[0.000, "o", "\r- DB_PASS=openkm_db_secret\r\n\rvolumes:\r\n"]
[0.000, "o", "\r- openkm_data:/opt/openkm/repository\r\n\r- openkm_logs:/opt/openkm/log\r\n\rports:\r\n\r- \"8080:8080\"\r\n\rdeploy:\r\n\rreplicas: 1\r\n\rplacement:\r\n\rconstraints:\r\n\r- node.role == manager\r\n\rrestart_policy:\r\n\rcondition: on-faliure\r\n\rresourcs:\r\n\rlimits:\r\n\rmemory: 1.5G\r\n\r\n\r\n\rnginx:\r\n\rimage:nginx:stable-alpine\r\n\rnetworks:\r\n\r- openkm-net\r\n\rports:\r\n\r- \"80:80\"\r\n\r- \"443:443:\"\r\n\rconfigs:\r\n\r- source: nginx_conf\r\n\rtarget: /etc/nginx/conf.d/defaults.conf\r\n\rdeploy:\r\n\rreplicas: 1\r\n"]
[0.000, "o", "\rrestart_policy:\r\n\rcondition: on-failure\r\n\r\n\r\n"]
[0.000, "o", "\rvolumes:\r\n\ropenkm_data:\r\n"]
