[0.033, "o", "\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bnginx.conf << 'EOF'\r\n\rserver {\r\n\rlisten 80;\r\n\rserver_name _;\r\n\r\n\rclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r\n\radd_header X-Frame-Options\r\n\r\"SAMEORIGIN\" always;\r\n\radd_header X_Content-Type-Options\r\n\r\"nosniff\" always;\r\n\r\n\rlocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n\rproxy_set_header\r\n\r\n\rcat > /opt/openkm/nginx.conf << 'EOF'\r\n"]
