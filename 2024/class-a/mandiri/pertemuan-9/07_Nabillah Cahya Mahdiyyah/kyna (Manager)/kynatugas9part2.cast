[0.000, "o", "\r\u001b[2d# mkinitcpio preset file for the 'linux-lts' package\r\u001b[4dALL_config=\"/etc/mkinitcpio.d/default.conf\"\r\u001b[5dALL_kver=\"/boot/vmlinuz-linux-lts\"\r\u001b[6d#ALL_kerneldest=\"/boot/vmlinuz-linux-lts\"\r\u001b[8dPRESETS=('default')\r\u001b[9d#PRESETS=('default' 'fallback')\r\u001b[11d"]
[0.000, "o", "default_config=\"/etc/mkinitcpio.conf\"\r\u001b[12ddefault_image=\"/boot/initramfs-linux-lts.img\"\r\u001b[13d"]
