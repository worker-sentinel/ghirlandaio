[0.000, "o", "default_options=\"--splash /usr/share/systemd/bootctl/splash-arch.bmp\"\r\u001b[16d"]
[0.000, "o", "#fallback_config=\"/etc/mkinitcpio.conf\"\r\u001b[17d"]
