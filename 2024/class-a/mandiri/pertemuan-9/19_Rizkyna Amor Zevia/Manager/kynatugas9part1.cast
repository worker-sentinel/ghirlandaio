[0.000, "o", "           \u001b[0;10;7m\u000f^R\u001b[m\u000f Replace    \u001b[67;120H        \u001b[67;137H"]
[0.001, "o", "        \u001b[0;10;7m\u000f^N\u001b[m\u000f Newer\u001b[K\u001b[66;206H"]
