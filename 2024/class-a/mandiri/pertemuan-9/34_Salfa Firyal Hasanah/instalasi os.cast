[0.001, "o", "\u001b[?2004h\u001b[32m[iwd]\u001b[0m# \r\u001b[K                               Available networks\u001b[1;90m                              \u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[1;90m      Network name                      Security            Signal\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Rumah-2.4G                        psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      ZTE_2.4G_AJENG                    psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Qira (5G)                         psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Rumah-5G                          psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Arshaka Dwiputra Putra Kahfi      psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      Qira                              psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K      MNindi                            psk                 *\u001b[1;90m***\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\r\n\u001b[32m[iwd]\u001b[0m# \r\u001b[K\u001b[32m[iwd]\u001b[0m# "]
