[0.003, "o", "\u001b[1;1H\u001b[1m\u001b[36m# /dev/mapper/proc-root\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m6e6d58d1-6ab6-4cb2-86c6-5871cb6fd393\u001b[m\u000f       /               \u001b[1m\u001b[32mext4\u001b[m\u000f            \u001b[1m\u001b[32mrw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f     \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m1\u001b[m\u000f\u001b[2;100H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[1m\u001b[36m# /dev/mapper/proc-vars\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m6bcb5047-e761-4a40-9602-ab21d34a6a75\u001b[m\u000f\u001b[7C/vars\u001b[11C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vtmp\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m35aed4b1-b9d0-4299-9b41-c6af78fa7e72\u001b[m\u000f\u001b[7C/var/tmp\u001b[8C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vlog\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m681ddf5c-261a-47f5-abdd-f31697b68925\u001b[m\u000f\u001b[7C/var/log\u001b[8C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-vaud\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m64e2532f-8a91-4dad-bb69-18bfd3e9aab9\u001b[m\u000f\u001b[7C/var/log/audit  \u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-home\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m2fb48f74-3f35-481d-9b10-abf17c4a1c46\u001b[m\u000f\u001b[7C/home\u001b[11C\u001b[1m\u001b[32mext4\u001b[12Crw\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnosuid\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnodev\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mnoexec\u001b[m\u000f\u001b[1m\u001b[33m,\u001b[m\u000f\u001b[1m\u001b[32mrelatime\u001b[m\u000f \u001b[1m\u001b[35m0\u001b[m\u000f \u001b[1m\u001b[35m2\u001b[m\u000f\r\n\r\n\u001b[1m\u001b[36m# /dev/mapper/proc-dock\u001b[m\u000f\r\n\u001b[1m\u001b[36mUUID\u001b[m\u000f\u001b[1m\u001b[33m=\u001b[m\u000f\u001b[1m\u001b[35m43dd0f30-fb5d-4bc3-836f-6c219509b1b2\u001b[m\u000f\u001b[7C/var/lib/docker \u001b[1m\u001b[32