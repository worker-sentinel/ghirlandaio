[0.001, "o", "\u001b[?25l\u001b[m\u000f\u001b[94mversion\u001b[m\u000f\u001b[96m:\u001b[m\u000f \u001b[92m\"3.8\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[94mservices\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n  \u001b[94mopenkm\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f openkm/openkm-ce:6312\u001b[K\r\n    \u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm-net\u001b[K\r\n    \u001b[94menvironment\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f OPENKM_URL=http://openkm:8080/OpenKM\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_DRIVER=com.mysql.jdbc.Driver\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_URL=jdbc:mysql://192.168.18.34:3306/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_USER=openkm\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f DB_PASS=1234\u001b[K\r\n    \u001b[94mvolumes\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm_data:/opt/openkm/repository\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm_logs:/opt/openkm/log\u001b[K\r\n    \u001b[94mports\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[92m\"8080:8080\"\u001b[m\u000f\u001b[K\r\n    \u001b[94mdeploy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mreplicas\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1\u001b[K\r\n      \u001b[94mplacement\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mconstraints\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n          \u001b[0;10;1m\u000f-\u001b[m\u000f node.role == manager\u001b[K\r\n      \u001b[94mrestart_policy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mcondition\u001b[m\u000f\u001b[96m:\u001b[m\u000f on-failure\u001b[K\r\n      \u001b[94mresources\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mlimits\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n          \u001b[94mmemory\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1.5G\u001b[K\r\n\u001b[K\n  nginx;\u001b[K\r\n      \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f nginx:stable-alpine\u001b[K\r\n      \u001b[94mnetwroks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[0;10;1m\u000f-\u001b[m\u000f openkm-net\u001b[K\r\n      \u001b[94mports\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[92m\"80:80\"\u001b[m\u000f\u001b[K\r\n        \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[92m\"443:443\"\u001b[m\u000f\u001b[K\r\n      \u001b[94mconfigs\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[94msource\u001b[m\u000f\u001b[96m:\u001b[m\u000f nginx_conf\u001b[K\r\n          \u001b[94mtarget\u001b[m\u000f\u001b[96m:\u001b[m\u000f /etc/nginx/conf.d/default.conf\u001b[K\r\n      \u001b[94mdeploy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n        \u001b[94mreplicas\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1\u001b[K\r\n        \u001b[94mrestart_policy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n          \u001b[94mcondition\u001b[m\u000f\u001b[96m:\u001b[m\u000f on-failure\u001b[K\r\n\u001b[K\n\u001b[94mvolumes\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mopenkm_data\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mopenkm_logs\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[94mconfigs\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n  \u001b[94mnginx_conf\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mfile\u001b[m\u000f\u001b[96m:\u001b[m\u000f ./nginx.conf\u001b[K\r\n\u001b[K\n\u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n\u001b[K\n  \u001b[94mopenkm-net\u001b[m\u000f\u001b[96m