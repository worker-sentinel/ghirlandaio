[0.005, "o", "version: \"3.8\"\r\n\r\nservices:\r\n  openkm:\r\n    image: openkm/openkm-ce:6.3.12\r\n    networks:\r\n      - openkm-net\r\n    envronment:\r\n      -OPENKM_URL=http://openkm:8080/OpenKM\r\n      -DB_DRIVER=com.mysql.jdbc.Driver\r\n      -DB_URL=jdbc:mysql://192.20.10.3:3306/openkm?useSSL=false&allowPublickKeyRetrieval=true&characterEncoding=UTF-8\r\n      -DB_USER=openkm\r\n      -DB_PASS=\r\nversion: \"3.8\"\r\n\r\nservices:\r\n  openkm:\r\n    image: openkm/openkm-ce:6312\r\n    networks:\r\n      - openkm-net\r\n    environment:\r\n      - OPENKM_URL=http://openkm:8080/OpenKM\r\n      - DB_DRIVER=com.mysql.jdbc.Driver\r\n      - DB_URL=jdbc:mysql://192.168.18.80:3306/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n      - DB_USER=openkm\r\n      - DB_PASS=1234\r\n    volumes:\r\n      - openkm_data:/opt/openkm/repository\r\n      - openkm_logs:/opt/openkm/log\r\n    ports:\r\n      - \"8080:8080\"\r\n    deploy:\r\n      replicas: 1\r\n      placement:\r\n        constraints:\r\n          - node.role == manager\r\n      restart_policy:\r\n        condition: on-failure\r\n      resources:\r\n        limits:\r\n          memory: 1.5G\r\n\r\n  nginx;\r\n      image: nginx:stable-alpine\r\n      netwroks:\r\n        - openkm-net\r\n      ports:\r\n        - \"80:80\"\r\n        - \"443:443\"\r\n      configs:\r\n        - source: nginx_conf\r\n          target: /etc/nginx/conf.d/default.conf\r\n      deploy:\r\n        replicas: 1\r\n        restart_policy:\r\n          condition: on-failure\r\n\r\nvolumes:\r\n      openkm_data:\r\n      openkm_logs:\r\n\r\nconfigs:\r\n  nginx_conf:\r\n    file: ./nginx.conf\r\n\r\nnetworks:\r\n\r\n  openkm-net:\r\n    external: true\r\n"]
