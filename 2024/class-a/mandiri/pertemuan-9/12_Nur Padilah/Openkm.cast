[0.001, "o", "\u001b[?25l\u001b[m\u000f\u001b[94mversion\u001b[m\u000f\u001b[96m:\u001b[m\u000f \u001b[92m\"3.8\"\u001b[m\u000f\u001b[K\r\n\u001b[K\n\u001b[94mservices\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n  \u001b[94mmariadb\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n    \u001b[94mimage\u001b[m\u000f\u001b[96m:\u001b[m\u000f mariadb:10.11\u001b[K\r\n    \u001b[94mnetworks\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f openkm-net\u001b[K\r\n    \u001b[94menvironment\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f MYSQL_ROOT_PASSWORD=1234\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f MYSQL_DATABASE=openkm\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f MYSQL_USER=openkm\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f MYSQL_PASSWORD=1234\u001b[K\r\n    \u001b[94mvolumes\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f /srv/database/mariadb:/var/lib/mysql\u001b[K\r\n    \u001b[94mports\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[0;10;1m\u000f-\u001b[m\u000f \u001b[92m\"3306:3306\"\u001b[m\u000f\u001b[K\r\n    \u001b[94mcommand\u001b[m\u000f\u001b[96m:\u001b[m\u000f \u001b[96m>\u001b[m\u000f\u001b[K\r\n      --character-set-server=utf8mb4\u001b[K\r\n      --collation-server=utf8mb4_unicode_ci\u001b[K\r\n      --innodb-buffer-pool-size=512M\u001b[K\r\n      --max-allowed-packet=64M\u001b[K\r\n    \u001b[94mdeploy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n      \u001b[94mreplicas\u001b[m\u000f\u001b[96m:\u001b[m\u000f 1\u001b[K\r\n      \u001b[94mplacement\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n         \u001b[94mconstraints\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n            \u001b[0;10;1m\u000f-\u001b[m\u000f node.role == worker\u001b[K\r\n      \u001b[94mrestart_policy\u001b[m\u000f\u001b[96m:\u001b[m\u000f\u001b[K\r\n         \u001b[94mcondition\u001b[m\u0