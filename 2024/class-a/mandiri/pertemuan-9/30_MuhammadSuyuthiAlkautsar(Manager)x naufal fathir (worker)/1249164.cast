[0.008, "o", "\u001b[1;1H\u001b[1m\u001b[36mversion\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f \u001b[1m\u001b[35m\"3.8\"\u001b[m\u000f\u001b[2;1H\u001b[K\u001b[3;1H\u001b[1m\u001b[36mservices\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[3;10H\u001b[K\u001b[4;3H\u001b[1m\u001b[36mnginx\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\r\n    \u001b[1m\u001b[36mimage\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f nginx:1.25\r\n    \u001b[1m\u001b[36mports\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[7;6H\u001b[1m\u001b[33m-\u001b[m\u000f \u001b[1m\u001b[35m\"80:80\"\u001b[m\u000f\r\n    \u001b[1m\u001b[36mvolumes\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[9;6H\u001b[1m\u001b[33m-\u001b[m\u000f ../proxy-config/default.conf:/etc/nginx/conf.d/default.conf:ro\r\n    \u001b[1m\u001b[36mnetworks\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[11;6H\u001b[1m\u001b[33m-\u001b[m\u000f openkm_net\r\n    \u001b[1m\u001b[36mdeploy\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[13;7H\u001b[1m\u001b[36mplacement\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[14;9H\u001b[1m\u001b[36mconstraints\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[15;11H\u001b[1m\u001b[33m-\u001b[m\u000f node.labels.openkm.role == app\u001b[16;7H\u001b[1m\u001b[36mrestart_policy\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[17;9H\u001b[1m\u001b[36mcondition\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f on-failure\r\n\r\n  \u001b[1m\u001b[36mapp\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\r\n    \u001b[1m\u001b[36mimage\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f openkm/openkm-ce:latest\r\n    \u001b[1m\u001b[36menvironment\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[22;7H\u001b[1m\u001b[33m-\u001b[m\u000f DATABASE_DRIVER=com.mysql.cj.jdbc.Driver\u001b[23;7H\u001b[1m\u001b[33m-\u001b[m\u000f DATABASE_URL=jdbc:mysql://mysql:3306/openkm?useUnicode=\u001b[1m\u001b[35mtrue\u001b[m\u000f&characterEncoding=UTF-8\u001b[24;7H\u001b[1m\u001b[33m-\u001b[m\u000f DATABASE_USER=openkm\u001b[25;7H\u001b[1m\u001b[33m-\u001b[m\u000f DATABASE_PASSWORD=kausar123\u001b[26;7H\u001b[1m\u001b[33m-\u001b[m\u000f DATABASE_DIALECT=org.hibernate.dialect.MySQL8Dialect\r\n    \u001b[1m\u001b[36mnetworks\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[28;7H\u001b[1m\u001b[33m-\u001b[m\u000f openkm_net\r\n    \u001b[1m\u001b[36mvolume\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[30;7H\u001b[1m\u001b[33m-\u001b[m\u000f openkm_date:/opt/tomcat/repository\r\n    \u001b[1m\u001b[36mdeploy\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[32;7H\u001b[1m\u001b[36mplacement\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[33;9H\u001b[1m\u001b[36mconstraints\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[34;11H\u001b[1m\u001b[33m-\u001b[m\u000f node.labels.openkm.role == app\u001b[35;7H\u001b[1m\u001b[36mrestart_policy\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[36;9H\u001b[1m\u001b[36mcondition\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f on-failure\u001b[37;7H\u001b[1m\u001b[36mresources\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[38;9H\u001b[1m\u001b[36mlimits\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[39;11H\u001b[1m\u001b[36mmemory\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f 2G\r\n\r\n  \u001b[1m\u001b[36mmysql\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\r\n    \u001b[1m\u001b[36mimage\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f mysql:8\r\n    \u001b[1m\u001b[36menvironment\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[44;7H\u001b[1m\u001b[36mMYSQL_DATABASE\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f openkm\u001b[45;7H\u001b[1m\u001b[36mMYSQL_USER\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f openkm\u001b[46;7H\u001b[1m\u001b[36mMYSQL_PASSWORD\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f \u001b[1m\u001b[35m\"123\"\u001b[m\u000f\u001b[47;7H\u001b[1m\u001b[36mMYSQL_ROOT_PASSWORD\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f \u001b[1m\u001b[35m\"123\"\u001b[m\u000f\r\n    \u001b[1m\u001b[36mvolume\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[49;7H\u001b[1m\u001b[33m-\u001b[m\u000f mysql_data:/var/lib/mysql\r\n    \u001b[1m\u001b[36mnetworks\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[51;7H\u001b[1m\u001b[33m-\u001b[m\u000f openkm_net\r\n    \u001b[1m\u001b[36mdeploy\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[53;7H\u001b[1m\u001b[36mplacement\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[54;9H\u001b[1m\u001b[36mconstraints\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[55;11H\u001b[1m\u001b[33m-\u001b[m\u000f node.labels.openkm.role == db\u001b[56;7H\u001b[1m\u001b[36mrestart_policy\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[57;9H\u001b[1m\u001b[36mcondition\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f on-failure\r\n\r\n  \u001b[1m\u001b[36mnetworks\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\r\n    \u001b[1m\u001b[36mopenkm_net\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[61;7H\u001b[1m\u001b[36mdriver\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f overlay\r\n\r\n  \u001b[1m\u001b[36mvolumes\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\r\n    \u001b[1m\u001b[36mmysql_data\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\r\n    \u001b[1m\u001b[36mopenkm_data\u001b[m\u000f\u001b[1m\u001b[31m:\u001b[m\u000f\u001b[67;223H25,24\u001b[9CAll\u001b[?25h\u001b[?0c\u001b[25;24H"]
