[0.037, "o", "System:\u001b[0m\r\n      Firmware: \u001b[0;1;39mUEFI 2.60 (Lenovo 0.5744)\u001b[0m\r\n Firmware Arch: x64\r\n   Secure Boot: \u001b[0mdisabled\u001b[0m\r\n  TPM2 Support: \u001b[0;1;32myes\u001b[0m\r\n  Measured UKI: \u001b[0;1;32myes\u001b[0m\r\n  Boot into FW: supported\r\n\r\nCurrent Boot Loader:\u001b[0m\r\n       Product: \u001b[0;1;39msystemd-boot 260.1-1-arch\u001b[0m\r\n     Features: \u001b[0;1;32m✓\u001b[0m Boot counting\r\n               \u001b[0;1;32m✓\u001b[0m Menu timeout control\r\n               \u001b[0;1;32m✓\u001b[0m One-shot menu timeout control\r\n               \u001b[0;1;32m✓\u001b[0m Default entry control\r\n               \u001b[0;1;32m✓\u001b[0m One-shot entry control\r\n               \u001b[0;1;32m✓\u001b[0m Support for XBOOTLDR partition\r\n               \u001b[0;1;32m✓\u001b[0m Support for passing random seed to OS\r\n               \u001b[0;1;32m✓\u001b[0m Load drop-in drivers\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 sort-key field\r\n               \u001b[0;1;32m✓\u001b[0m Support @saved pseudo-entry\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 devicetree field\r\n               \u001b[0;1;32m✓\u001b[0m Enroll SecureBoot keys\r\n               \u001b[0;1;32m✓\u001b[0m Retain SHIM protocols\r\n               \u001b[0;1;32m✓\u001b[0m Menu can be disabled\r\n               \u001b[0;1;32m✓\u001b[0m Multi-Profile UKIs are supported\r\n               \u001b[0;1;32m✓\u001b[0m Loader reports network boot URL\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 uki field\r\n               \u001b[0;1;32m✓\u001b[0m Support Type #1 uki-url field\r\n               \u001b[0;1;32m✓\u001b[0m Loader reports active TPM2 PCR banks\r\n     Partition: /dev/disk/by-partuuid/391435ed-112c-4f88-b87a-b96fbba81792\r\n        Loader: └─\u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/systemd/systemd-bootx64.efi\r\n Current Entry: arch-linux-hardened.efi\r\n\r\nCurrent Stub:\u001b[0m\r\n      Product: \u001b[0;1;39msystemd-stub 260.2-2-arch\u001b[0m\r\n     Features: \u001b[0;1;32m✓\u001b[0m Stub reports loader partition information\r\n               \u001b[0;1;32m✓\u001b[0m Stub reports stub partition information\r\n               \u001b[0;1;32m✓\u001b[0m Stub reports network boot URL\r\n               \u001b[0;1;32m✓\u001b[0m Picks up credentials from boot partition\r\n               \u001b[0;1;32m✓\u001b[0m Picks up system extension images from boot partition\r\n               \u001b[0;1;32m✓\u001b[0m Picks up configuration extension images from boot partition\r\n               \u001b[0;1;32m✓\u001b[0m Measures kernel+command line+sysexts\r\n               \u001b[0;1;32m✓\u001b[0m Support for passing random seed to OS\r\n               \u001b[0;1;32m✓\u001b[0m Pick up .cmdline from addons\r\n               \u001b[0;1;32m✓\u001b[0m Pick up .cmdline from SMBIOS Type 11\r\n               \u001b[0;1;32m✓\u001b[0m Pick up .dtb from addons\r\n               \u001b[0;1;32m✓\u001b[0m Stub understands profile selector\r\n    Partition: /dev/disk/by-partuuid/391435ed-112c-4f88-b87a-b96fbba81792\r\n         Stub: └─/EFI/Linux/arch-linux-hardened.efi\r\n\r\nRandom Seed:\u001b[0m\r\n System Token: set\r\n       Exists: yes\r\n\r\nAvailable Boot Loaders on ESP:\u001b[0m\r\n          ESP: /boot (/dev/disk/by-partuuid/391435ed-112c-4f88-b87a-b96fbba81792)\r\n         File: ├─\u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/systemd/systemd-bootx64.efi (\u001b[0;1;39msystemd-boot 260.1-1-arch\u001b[0m)\r\n               └─\u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/BOOT/BOOTX64.EFI (\u001b[0;1;39msystemd-boot 260.1-1-arch\u001b[0m)\r\n\r\nBoot Loaders Listed in EFI Variables:\u001b[0m\r\n        Title: \u001b[0;1;39mWindows Boot Manager\u001b[0m\r\n           ID: 0x0000\r\n       Status: active, boot-order\r\n    Partition: /dev/disk/by-partuuid/5f093c47-af17-497c-82bd-6526e7b70b1b"]
