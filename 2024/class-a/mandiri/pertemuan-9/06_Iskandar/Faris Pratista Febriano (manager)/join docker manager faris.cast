30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[13C\u001b[1m\u001b[37m\u001b[40m                 \u001b[14C\u001b[m\u000f\u001b[30m\u001b[47m│\u001b[1m\u001b[37m\u001b[40m \u001b[44m        \u001b[39;90H        \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                           ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[1m\u001b[37m\u001b[40m \u001b[44m        \u001b[40;91H       \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                           ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[1m\u001b[37m\u001b[40m \u001b[44m        \u001b[35;128H"]
[0.760, "o", "\u001b[m\u000f\u001b[37m\u001b[40m\u001b[24;38r\u001b[24;1H\u001b[6L\u001b[1;67r\u001b[18;29r\u001b[18;1H\u001b[7L\u001b[1;67r\u001b[7;102H\u001b[41m  berkat2         ***   \u001b[8;102H\u001b[30m\u001b[47m* berkat          ***   \u001b[18;1H\u001b[1m\u001b[37m\u001b[44m                                                                                                 \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                           ▮ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                              \u001b[19;1H                                                                                                 \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                           ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                              \u001b[20;1H                                                                                                 \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                           ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                              \u001b[21;1H                                                                                                 \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m                           ▒ \u001b[37m\u001b[44m│\u001b[30m\u001b[47m              │\u001b[1m\u001b[37m\u001b[40m \u001b[44m                                                                                              \u001b[22;1H                                                                                               