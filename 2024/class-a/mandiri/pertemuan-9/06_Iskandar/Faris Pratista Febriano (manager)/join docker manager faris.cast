[3.208, "o", "\u001b[2;98H                                                \u001b[3;98H                                                 \u001b[4;98H                                                 \u001b[5;98H                                                 \u001b[6;98H                                                 \u001b[7;98H                                                 \u001b[8;98H                                                 \u001b[9;98H                                                 \u001b[10;98H                                                 \u001b[11;98H                                                 \u001b[12;98H                                                 \u001b[13;98H                                                 \u001b[14;98H                                                 \u001b[15;98H                                                 \u001b[16;98H                                                 \u001b[17;98H                                                 \u001b[18;98H                                                 \u001b[19;98H                                                 \u001b[20;98H                                                 \u001b[21;98H                                                 \u001b[22;98H                                                 \u001b[23;98H                                                 \u001b[24;98H                                                 \u001b[25;98H                                                 \u001b[26;98H                                                 \u001b[27;98H                                                 \u001b[28;98H          \u001b[m\u000f\u001b[30m\u001b[47m┌─┤ \u001b[31mNetworkManager TUI\u001b[30m ├──┐\u001b[1m\u001b[37m\u001b[44m            \u001b[29;98H          \u001b[m\u000f\u001b[30m\u001b[47m│\u001b[19C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[30;98H          \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[34mPlease select an option\u001b[30m │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[31;98H          \u001b[m\u000f\u001b[30m\u001b[47m│\u001b[19C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[32;98H          \u001b[m\u000f\u001b[30m\u001b[47m│ Edit a connection       │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[33;98H          \u001b[m\u000f\u001b[30m\u001b[47m│ \u001b[37m\u001b[41mActivate a connection  \u001b[30m\u001b[47m │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[34;98H          \u001b[m\u000f\u001b[30m\u001b[47m│ Set system hostname     │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[35;98H          \u001b[m\u000f\u001b[30m\u001b[47m│ Radio\u001b[13C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[36;98H          \u001b[m\u000f\u001b[30m\u001b[47m│\u001b[19C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[37;98H          \u001b[m\u000f\u001b[30m\u001b[47m│ Quit\u001b[14C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[38;98H          \u001b[m\u000f\u001b[30m\u001b[47m│\u001b[19C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[39;98H          \u001b[m\u000f\u001b[30m\u001b[47m│\u001b[19C <OK> │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[40;98H          \u001b[m\u000f\u001b[30m\u001b[47m│\u001b[19C      │\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[41;98H          \u001b[m\u000f\u001b[30m\u001b[47m└─────────────────────────┘\u001b[1m\u001b[37m\u001b[40m \u001b[44m           \u001b[42;98H           \u001b[40m                           \u001b[44m           \u001b[43;98H                                                 \u001b[44;98H                                                 \u001b[45;98H                                                 \u001b[46;98H                                                 \u001b[47;98H                                                 \u001b[48;98H                                                 \u001b[49;98H                 