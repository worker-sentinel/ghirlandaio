[1.068, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[30;90H\u001b[m\u000f\u001b[30m\u001b[47m┌───────┤ \u001b[31mAuthentication required by wireless network\u001b[30m ├────────┐\u001b[31;90H│          \u001b[27C   \u001b[14C        │\u001b[1m\u001b[37m\u001b[40m \u001b[32;90H\u001b[m\u000f\u001b[30m\u001b[47m│ Push of the WPS button on the router or a password is        │\u001b[1m\u001b[37m\u001b[40m \u001b[33;90H\u001b[m\u000f\u001b[30m\u001b[47m│ required to access the wireless network 'berkat'.            │\u001b[1m\u001b[37m\u001b[40m \u001b[34;90H\u001b[m\u000f\u001b[30m\u001b[47m│          \u001b[12C \u001b[15C  \u001b[14C        │\u001b[1m\u001b[37m\u001b[40m \u001b[35;90H\u001b[m\u000f\u001b[30m\u001b[47m│     \u001b[34mPassword\u001b[30m \u001b[37m\u001b[44m______________________________\u001b[10C\u001b[30m\u001b[47m        │\u001b[1m\u001b[37m\u001b[40m \u001b[36;90H\u001b[m\u000f\u001b[30m\u001b[47m│          \u001b[12C \u001b[15C  \u001b[14C        │\u001b[1m\u001b[37m\u001b[40m \u001b[37;90H\u001b[m\u000f\u001b[30m\u001b[47m│          \u001b[12C                  \u001b[8C<Cancel>\u001b[34m <OK>\u001b[30m │\u001b[1m\u001b[37m\u001b[40m \u001b[38;90H\u001b[m\u000f\u001b[30m\u001b[47m│          \u001b[13C                 \u001b[14C        │\u001b[1m\u001b[37m\u001b[40m \u001b[39;90H\u001b[m\u000f\u001b[30m\u001b[47m└──────────────────────────────────────────────────────────────┘\u001b[1m\u001b[37m\u001b[40m \u001b[40;91H                                                                \u001b[35;105H"]
