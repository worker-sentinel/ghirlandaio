[0.904, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[37d"]
[0.284, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[38d"]
