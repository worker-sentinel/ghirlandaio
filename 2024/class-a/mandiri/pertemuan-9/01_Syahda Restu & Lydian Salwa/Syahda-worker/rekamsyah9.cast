[0.954, "o", "\r\n\u001b[?2004l\r"]
[0.010, "o", "table inet firewalld { #"]
[0.001, "o", " progname firewalld\r\n\tflags owner,persist\r\n\r\n\tchain mangle_PREROUTING {\r\n\t\ttype filter hook prerouting priority mangle + 10; policy accept;\r\n"]
[0.000, "o", "\t\tjump mangle_PREROUTING_POLICIES\r\n\t}\r\n\r\n\tchain mangle_PREROUTING_POLICIES {\r\n\t\tiifname \"docker0\" jump mangle_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker0\" "]
[0.000, "o", "jump mangle_PRE_docker"]
[0.000, "o", "\r\n\t\tiifname \"docker0\" return\r\n\t\tiifname \"docker_gwbridge\" jump mangle_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker_gwbridge\" jump mangle_PRE_docker\r\n\t\tiifname"]
[0.001, "o", " \"docker_gwbridge\" return\r\n\t\tjump mangle_PRE_policy_allow-host-ipv6\r\n\t\tjump mangle_PRE_public\r\n\t\treturn\r\n\t}\r\n\r\n\tchain nat_PREROUTING {\r\n\t\ttype nat hook prerouting priority dstnat + 10; policy accept;\r\n"]
[0.000, "o", "\t\tjump nat_PREROUTING_POLICIES\r\n\t}\r\n\r\n\tchain nat_PREROUTING_POLICIES {\r\n\t\tiifname \"docker0\" jump nat_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker0\" jump nat_PRE_docker\r\n"]
[0.000, "o", "\t\tiifname \"docker0\" return\r\n\t\tiifname \"docker_gwbridge\" jump nat_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker_gwbridge\" jump nat_PRE_docker\r\n\t\tiifname \"docker_gwbridge\" return\r\n\t\tjump nat_PRE_policy_allow-host-ipv6\r\n\t\t"]
[0.000, "o", "jump nat_PRE_public\r\n\t\treturn\r\n\t}\r\n\r\n\tchain nat_POSTROUTING {\r\n\t\ttype nat hook postrouting"]
[0.001, "o", " priority srcnat + 10; policy accept;\r\n\t\tjump nat_POSTROUTING_POLICIES\r\n\t}\r\n\r\n\tchain nat_POSTROUTING_POLICIES {\r\n\t\tiifname \"docker0\" oifname \"docker0\" jump nat_POST_policy_docker-forwarding\r\n"]
[0.000, "o", "\t\tiifname \"docker0\" oifname \"docker0\""]
[0.000, "o", " jump nat_POST_docker\r\n\t\tiifname \"docker0\" oifname \"docker0\" return\r\n\t\tiifname "]
[0.000, "o", "\"docker_gwbridge\" oifname \"docker0\" jump nat_POST_policy_docker-forwarding\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\""]
[0.000, "o", " jump nat_POST_docker\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" return\r\n\t\toifname \"docker0\" jump nat_POST_policy_docker-forwarding\r\n\t\toifname "]
[0.000, "o", "\"docker0\" jump nat_POST_docker\r\n\t\toifname \"docker0\" return\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\" jump nat_POST_policy_docker-forwarding\r\n\t\t"]
[0.001, "o", "iifname \"docker0\" oifname \"docker_gwbridge\" jump nat_POST_docker\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\""]
[0.000, "o", " return\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" jump nat_POST_policy_docker-forwarding\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\""]
