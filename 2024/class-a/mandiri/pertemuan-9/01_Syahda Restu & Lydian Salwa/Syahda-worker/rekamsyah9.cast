[0.037, "o", "table inet firewalld { #"]
[0.000, "o", " progname firewalld\r\n\tflags owner,persist\r\n\r\n\tchain mangle_PREROUTING {\r\n\t\ttype filter hook prerouting priority mangle + 10; policy accept;\r\n\t\tjump mangle_PREROUTING_POLICIES\r\n\t}\r\n\r\n\tchain mangle_PREROUTING_POLICIES {\r\n\t\tiifname"]
[0.000, "o", " \"docker0\" jump mangle_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker0\" jump mangle_PRE_docker\r\n\t\tiifname \"docker0\" return\r\n\t\tiifname \"docker_gwbridge\" "]
[0.003, "o", "jump mangle_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker_gwbridge\" jump mangle_PRE_docker\r\n\t\tiifname \"docker_gwbridge\" return\r\n\t\tjump mangle_PRE_policy_allow-host-ipv6\r\n\t\tjump mangle_PRE_public\r\n\t\treturn"]
[0.000, "o", "\r\n\t}\r\n\r\n\tchain nat_PREROUTING {\r\n\t\ttype nat hook prerouting priority dstnat + 10; policy accept;\r\n\t\tjump nat_PREROUTING_POLICIES\r\n\t}\r\n\r\n\tchain nat_PREROUTING_POLICIES {\r\n\t\tiifname \"docker0\" jump nat_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker0\" jump nat_PRE_docker\r\n\t\tiifname \"docker0\" return\r\n\t\tiifname \"docker_gwbridge\" jump nat_PRE_policy_allow-host-ipv6\r\n\t\tiifname \"docker_gwbridge\" jump nat_PRE_docker\r\n\t\tiifname \"docker_gwbridge\" return\r\n\t\tjump nat_PRE_policy_allow-host-ipv6\r\n\t\tjump nat_PRE_public\r\n\t\treturn\r\n\t}\r\n\r\n\tchain nat_POSTROUTING {\r\n\t\ttype nat hook postrouting priority srcnat + 10; policy accept;\r\n\t"]
[0.000, "o", "\tjump nat_POSTROUTING_POLICIES\r\n\t}\r\n\r\n\tchain nat_POSTROUTING_POLICIES {\r\n\t\tiifname \"docker0\" oifname \"docker0\" jump nat_POST_policy_docker-forwarding\r\n\t\tiifname \"docker0\" oifname \"docker0\" jump nat_POST_docker\r\n\t\tiifname \"docker0\" oifname \"docker0\" return\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" jump nat_POST_policy_docker-forwarding\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" jump nat_POST_docker\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" return\r\n\t\toifname \"docker0\" jump nat_POST_policy_docker-forwarding\r\n\t\toifname \"docker0\" jump nat_POST_docker\r\n\t\toifname \"docker0\" return\r\n"]
[0.001, "o", "\t\tiifname \"docker0\" oifname \"docker_gwbridge\" jump nat_POST_policy_docker-forwarding\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\" jump nat_POST_docker\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\" return\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" jump nat_POST_policy_docker-forwarding\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" jump nat_POST_docker\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" return\r\n\t\toifname \"docker_gwbridge\" jump nat_POST_policy_docker-forwarding\r\n\t\toifname \"docker_gwbridge\" jump nat_POST_docker\r\n\t\toifname"]
[0.000, "o", " \"docker_gwbridge\" return\r\n\t\tiifname \"docker0\" jump nat_POST_public\r\n\t\tiifname \"docker0\" return\r\n\t\tiifname \"docker_gwbridge\" jump nat_POST_public\r\n\t\tiifname \"docker_gwbridge\" return\r\n\t\tjump nat_POST_public\r\n\t\treturn\r\n\t}\r\n\r\n\tchain nat_OUTPUT {\r\n\t\ttype nat hook output priority dstnat + 10; policy accept;\r\n\t\tjump nat_OUTPUT_POLICIES\r\n\t}\r\n\r\n\tchain nat_OUTPUT_POLICIES {\r\n\t\toifname \"docker0\" jump nat_OUT_docker\r\n\t\toifname \"docker0\" return\r\n\t\toifname \"docker_gwbridge\" jump nat_OUT_docker\r\n\t\toifname \"docker_gwbridge\" return\r\n"]
[0.001, "o", "\t\tjump nat_OUT_public\r\n\t\treturn\r\n\t}\r\n\r\n\tchain filter_PREROUTING {\r\n\t\ttype filter hook prerouting priority filter + 10; policy accept;\r\n\t\ticmpv6 type { nd-router-advert, nd-neighbor-solicit } accept\r\n\t\tmeta nfproto ipv6 fib saddr . mark . iif check missing drop\r\n\t}\r\n\r\n\tchain filter_INPUT {\r\n\t\ttype filter hook input priority filter + 10; policy accept;\r\n\t\tct state { established, related } accept\r\n\t\tct status dnat accept\r\n\t\tiifname \"lo\" "]
[0.001, "o", "accept\r\n"]
[0.002, "o", "\t\tct state invalid drop\r\n\t\tjump filter_INPUT_POLICIES\r\n\t\treject with icmpx admin-prohibited\r\n\t}\r\n\r\n\tchain filter_FORWARD {\r\n\t\ttype filter hook forward priority filter + 10; policy accept;\r\n\t\tct state { established, related } accept\r\n\t\tct status dnat accept\r\n\t\tiifname \"lo\" accept\r\n\t\tct state invalid drop\r\n\t\tip6 daddr { ::/96, ::ffff:0.0.0.0/96, 2002::/24, 2002:a00::/24, 2002:7f00::/24, 2002:a9fe::/32, 2002:ac10::/28, 2002:c0a8::/32, 2002:e000::/19 } reject with icmpv6 addr-unreachable\r\n\t\tjump filter_FORWARD_POLICIES\r\n\t\treject with icmpx admin-prohibited\r\n\t}\r\n\r\n\tchain filter_OUTPUT {\r\n\t\ttype filter hook output priority filter + 10; policy accept;\r\n\t\tct state { established, related } accept\r\n\t\tct status dnat accept\r\n\t\toifname \"lo\" accept\r\n\t\tip6 daddr { ::/96, ::ffff:0.0.0.0/96, 2002::/24, 2002:a00::/24, 2002:7f00::/24, 2002:a9fe::/32, 2002:ac10::/28, 2002:c0a8::/32, 2002:e000::/19 } reject with icmpv6 addr-unreachable\r\n\t\tjump filter_OUTPUT_POLICIES\r\n\t}\r\n\r\n\tchain filter_INPUT_POLICIES {\r\n\t\tiifname \"docker0\" jump filter_IN_policy_allow-host-ipv6\r\n\t\tiifname \"docker0\" jump filter_IN_docker\r\n\t\tiifname \"docker0\" accept\r\n\t\tiifname \"docker_gwbridge\" jump filter_IN_policy_allow-host-ipv6\r\n\t\tiifname \"docker_gwbridge\" jump filter_IN_docker\r\n\t\tiifname \"docker_gwbridge\" accept\r\n\t\tjump filter_IN_policy_allow-host-ipv6\r\n\t\tjump filter_IN_public\r\n\t\treject with icmpx admin-prohibited\r\n\t}\r\n\r\n\tchain filter_FORWARD_POLICIES {\r\n\t\tiifname \"docker0\" oifname \"docker0\" jump filter_FWD_policy_docker-forwarding\r\n\t\tiifname \"docker0\" oifname \"docker0\" jump filter_FWD_docker\r\n\t\tiifname \"docker0\" oifname \"docker0\" accept\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\" jump filter_FWD_policy_docker-forwarding\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\" jump filter_FWD_docker\r\n\t\tiifname \"docker0\" oifname \"docker_gwbridge\" accept\r\n\t\tiifname \"docker0\" jump filter_FWD_docker\r\n\t\tiifname \"docker0\" accept\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" jump filter_FWD_policy_docker-forwarding\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" jump filter_FWD_docker\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker0\" accept\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" jump filter_FWD_policy_docker-forwarding\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" jump filter_FWD_docker\r\n\t\tiifname \"docker_gwbridge\" oifname \"docker_gwbridge\" accept\r\n\t\tiifname \"docker_gwbridge\" jump filter_FWD_docker\r\n\t\tiifname \"docker_gwbridge\" accept\r\n\t\toifname \"docker0\" jump filter_FWD_policy_docker-forwarding\r\n\t\toifname \"docker0\" jump filter_FWD_public\r\n\t\toifname \"docker0\" reject with icmpx admin-prohibited\r\n\t\toifname \"docker_gwbridge\" jump filter_FWD_policy_docker-forwarding\r\n\t\toifname \"docker_gwbridge\" jump filter_FWD_public\r\n\t\toifname \"docker_gwbridge\" reject with icmpx admin-prohibited\r\n\t\tjump filter_FWD_public\r\n\t\treject with icmpx admin-prohibited\r\n\t}\r\n\r\n\tchain filter_OUTPUT_POLICIES {\r\n\t\toifname \"docker0\" jump filter_OUT_docker\r\n\t\toifname \"docker0\" return\r\n\t\toifname \"docker_gwbridge\" jump filter_OUT_docker\r\n\t\toifname \"docker_gwbridge\" return\r\n\t\tjump filter_OUT_public\r\n\t\treturn\r\n\t}\r\n\r\n\tchain filter_IN_public {\r\n\t\tjump filter_IN_public_pre\r\n\t\tjump filter_IN_public_log\r\n\t\tjump filter_IN_public_deny\r\n\t\tjump filter_IN_public_allow\r\n\t\tjump filter_IN_public_post\r\n\t\tmeta l4proto { icmp, ipv6-icmp } accept\r\n\t}\r\n\r\n\tchain filter_IN_public_pre {\r\n\t}\r\n\r\n\tchain filter_IN_public_log {\r\n\t}\r\n\r\n\tchain filter_IN_public_deny {\r\n\t}\r\n\r\n\tchain filter_IN_public_allow {\r\n\t\ttcp dport 22 accept\r\n\t\tip6 daddr fe80::/64 udp dport 546 accept\r\n\t}\r\n\r\n\tchain filter_IN_publ