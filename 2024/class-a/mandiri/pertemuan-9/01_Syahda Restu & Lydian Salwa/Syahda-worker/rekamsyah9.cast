[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d#!/usr/bin/nft -f\r\u001b[3d# vim:set ts=2 sw=2 et:\r\u001b[5d# IPv4/IPv6 Simple & Safe firewall ruleset.\r\u001b[6d# More examples in /usr/share/nftables/ and /usr/share/doc/nftables/examples/.\r\u001b[8ddestroy table inet filter\r\u001b[9dtable inet filter {\u001b[10;3Hchain input {\u001b[11;5Htype filter hook input priority filter\u001b[12;5Hpolicy drop\u001b[14;5Hct state invalid drop comment \"early drop of invalid connections\"\u001b[15;5Hct state {established, related} accept comment \"allow tracked connections\"\u001b[16;5Hiif lo accept comment \"allow from loopback\"\u001b[17;5Hmeta l4proto { icmp, icmpv6 } accept comment \"allow icmp\"\u001b[18;5Htcp dport ssh accept comment \"allow sshd\"\u001b[19;5Hpkttype host limit rate 5/second counter reject with icmpx type admin-prohibited\u001b[20;5Hcounter\u001b[21;3H}\u001b[22d\bchain forward {\u001b[23;5Htype filter hook forward priority filter\u001b[24;5Hpolicy drop\u001b[25;3H}\r\u001b[26d}\u001b[2d\b\u001b[?25h\u001b[?0c"]
