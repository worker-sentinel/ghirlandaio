[0.002, "o", "\u001b[m\u000f\u001b[2;3HUNIX: \"/path1:/path2\"\u001b[K\r\u001b[3d;include_path = \".:/php/includes\"\u001b[4;3H\u001b[K\u001b[5dWindows: \"\\path1;\\path2\"\u001b[K\r\u001b[6d;include_path = \".;c:\\php\\includes\"\u001b[7;3H\u001b[K\r\u001b[8d; PHP's default setting for include_path is \".;/path/to/php/pear\"\r\u001b[9d; https://php.net/include-path\r\u001b[10d\u001b[K\u001b[11d; The root of the PHP pages, used only if nonempty.\u001b[K\u001b[12;3Hif PHP was not compiled with FORCE_REDIRECT, you SHOULD set doc_root\u001b[K\u001b[13;3Hif you are running php as a CGI under any web server (other than IIS)\u001b[14;3Hsee documentation for security issues.  The alternate is to use the\u001b[K\u001b[15;3Hcgi.force_redirect configuration below\u001b[K\u001b[16;3Hhttps://php.net/doc-root\u001b[K\r\u001b[17ddoc_root =\u001b[K\r\u001b[18d\u001b[K\u001b[19d; The directory under which PHP opens the script using /~username used only\u001b[20;3Hif nonempty.\u001b[K\r\u001b[21d; https://php.net/user-dir\r\u001b[22duser_dir =\r\u001b[23d\u001b[K\u001b[24d; Directory in which the loadable \u001b[30m\u001b[43mextension\u001b[39;49m\u001b[m\u000fs (modules) reside.\u001b[K\u001b[25;3Hhttps://php.net/extension-dir\u001b[K\r\u001b[26d"]
[0.001, "o", "extension_dir = \"/usr/lib/php/modules/\"\u001b[K\u001b[27;3HOn windows:\u001b[K\r\u001b[28d;extension_dir = \"ext\"\u001b[K\r\u001b[29d"]
[0.001, "o", "\u001b[K\u001b[30d; Directory where the temporary files should be placed.\u001b[31;3HDefaults to the system default (see sys_get_temp_dir)\r\u001b[32d;sys_temp_dir = \"/tmp\"\u001b[K\r\u001b[33d\u001b[K\u001b[34d; Whether or not to enable the dl() function.  The dl() function does NOT work\r\u001b[35d; properly in multithreaded servers, such as IIS or Zeus, and is automatically\u001b[36;3Hdisabled on them.\u001b[K\u001b[37;3Hhttps://php.net/enable-dl\u001b[K\r\u001b[38denable_dl = Off\u001b[K\r\u001b[39d\u001b[K\u001b[40d; cgi.force_redirect is necessary to provide security running PHP as a CGI under\u001b[41;3Hmost web servers.  Left undefined, PHP turns this on by default.  You can\r\u001b[42d; turn it off here AT YOUR OWN RISK\r\u001b[43d; **You CAN safely turn this off for IIS, in fact, you MUST.**\u001b[44;3Hhttps://php.net/cgi.force-redirect\u001b[K\r\u001b[45d;cgi.force_redirect = 1\u001b[K\u001b[24;35H"]
