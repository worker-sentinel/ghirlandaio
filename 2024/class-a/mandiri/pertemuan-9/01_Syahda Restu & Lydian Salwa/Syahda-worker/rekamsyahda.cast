[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.002, "o", "; Most likely, you won't want to disable this option globally. It causes $_POST\r;"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; and $_FILES to always be empty; the only way you will be able to read the\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; POST data will be through the php://input stream wrapper. This can be useful\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; to proxy requests or to process the POST data in a memory efficient fashion.\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; https://php.net/enable-post-data-reading\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H;enable_post_data_reading = Off\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; Maximum size of POST data that PHP will accept.\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Its value may be 0 to disable the limit. It is ignored if POST data reading\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; is disabled through enable_post_data_reading.\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; https://php.net/post-max-size\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
