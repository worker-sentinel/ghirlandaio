[0.000, "o", "; what PATH_INFO is.  For more information on PATH_INFO, see the cgi specs.  Setting\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; previous behaviour was to set PATH_TRANSLATED to SCRIPT_FILENAME, and to not grok\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; cgi.fix_pathinfo provides *real* PATH_INFO/PATH_TRANSLATED support for CGI.  PHP's\r"]
[0.299, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.283, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H;cgi.redirect_status_env =\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H; https://php.net/cgi.redirect-status-env\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; cause security issues, KNOW WHAT YOU ARE DOING FIRST.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; will look for to know it is OK to continue execution.  Setting this variable MAY\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; (iPlanet) web servers, you MAY need to set an environment variable name that PHP\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; if cgi.force_redirect is turned on, and you are not running under Apache or Netscape\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.423, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";cgi.nph = 1\r"]
[0.282, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; every request. PHP's default behavior is to disable this feature.\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H; if cgi.nph is enabled it will force cgi to always sent Status: 200 with\r"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H;cgi.force_redirect = 1\r"]
