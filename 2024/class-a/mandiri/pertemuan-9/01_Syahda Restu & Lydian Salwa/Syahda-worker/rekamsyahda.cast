[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; Default value: 0\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c"]
