[88.049, "o", "\u001b[?25l\u001b[?1c\r\u001b[2d; https://php.net/date.sunrise-zenith\r\u001b[3d;date.sunrise_zenith = 90.833333\r\u001b[4d\u001b[K\u001b[5d; https://php.net/date.sunset-zenith\r\u001b[6d;date.sunset_zenith = 90.833333\r\u001b[7d\u001b[K\u001b[8d[filter]\u001b[K\r\u001b[9d; https://php.net/filter.default\r\u001b[10d;filter.default = unsafe_raw\r\u001b[11d\u001b[K\u001b[12d; https://php.net/filter.default-flags\r\u001b[13d;filter.default_flags =\r\u001b[14d\u001b[K\u001b[15d[iconv]\u001b[K\r\u001b[16d; Use of this INI entry is deprecated, use global input_encoding instead.\r\u001b[17d; If empty, default_charset or input_encoding or iconv.input_encoding is used.\r\u001b[18d; The precedence is: default_charset < input_encoding < iconv.input_encoding\r\u001b[19d;iconv.input_encoding =\r\u001b[20d\u001b[K\u001b[21d; Use of this INI entry is deprecated, use global internal_encoding instead.\r\u001b[22d; If empty, default_charset or internal_encoding or iconv.internal_encoding is used.\r\u001b[23d; The precedence is: default_charset < internal_encoding < iconv.internal_encoding\r\u001b[24d;iconv.internal_encoding =\r\u001b[25d\u001b[K\u001b[26d; Use of this INI entry is deprecated, use global output_encoding instead.\r\u001b[27d;"]
[0.001, "o", " If empty, default_charset or output_encoding or iconv.output_encoding is used.\r\u001b[28d"]
