[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; use when sending HTTP response code. If set to 0, PHP sends Status: header that\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; is supported by Apache. When this option is set to 1, PHP will send\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; RFC2616 compliant header.\r"]
