[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[41d"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[42d"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[43d\b"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b[44d;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[45d"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; previously set variable or directive (e.g. ${foo})\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Expressions in the INI file are limited to bitwise operators and parentheses:\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; |  bitwise OR\r;"]
[0.341, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; ^  bitwise XOR\r;"]
[0.285, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; &  bitwise AND\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; ~  bitwise NOT\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; !  boolean NOT\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; Boolean flags can be turned on using the values 1, On, True or Yes.\r;"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; They can be turned off using the values 0, Off, False or No.\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; An empty string can be denoted by simply not writing anything after the equal\r;"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; sign, or by using the None keyword:\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; foo =\u001b[45;17H; sets foo to an empty string\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; foo = None    ; sets foo to an empty string\r;"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; foo = \"None\"  ; sets foo to the string 'None'\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; If you use constants in your value, and these constants belong to a\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; dynamically loaded extension (either a PHP extension or a Zend extension),\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; you may only use these constants *after* the line that loads the extension.\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H;;;;;;;;;;;;;;;;;;;\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; About this file ;\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H;;;;;;;;;;;;;;;;;;;\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; PHP comes packaged with two INI files. One that is recommended to be used\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; in production environments and one that is recommended to be used in\r;"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; development environments.\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H"]
[0.037, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; php.ini-production contains settings which hold security, performance and\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; best practices at its core. But please be aware, these settings may break\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; compatibility with older or less security-conscious applications. We\r;"]
