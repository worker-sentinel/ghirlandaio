[1.594, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute       \u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[2;3Hhttps://php.net/ignore-user-abort\u001b[K\r\u001b[3d"]
[0.000, "o", ";ignore_user_abort = On\r\u001b[4d\u001b[K\u001b[5d; "]
[0.002, "o", "Determines the size of the realpath cache to be used by PHP. This value should\u001b[6;3Hbe increased on systems where PHP opens many files to reflect the quantity of\u001b[7;3Hthe file operations performed.\u001b[K\u001b[8;3HNote: if open_basedir is set, the cache is disabled\u001b[9;3Hhttps://php.net/realpath-cache-size\u001b[K\r\u001b[10d;realpath_cache_size = 4096k\u001b[K\r\u001b[11d\u001b[K\u001b[12d; Duration of time, in seconds for which to cache realpath information for a given\u001b[13;3Hfile or\u001b[13;20H. For systems with rarely changing files, consider increasing this\u001b[14;3Hvalue.\u001b[K\u001b[15;19H"]
[0.000, "o", "realpath-cache-ttl\r\u001b[16d;realpath_cache_ttl = 120\r\u001b[17d"]
[0.002, "o", "\u001b[K\u001b[18d; Enables or disables the circular reference collector.\u001b[K\u001b[19;3Hhttps://php.net/zend.enable-gc\u001b[K\r\u001b[20dzend.enable_gc = On\u001b[K\u001b[22;3HIf enabled, scripts may be written in encodings that are incompatible with\u001b[23;3Hthe scanner.  CP936, Big5, CP949 and Shift_JIS are the examples of such\u001b[24;3Hencodings.  To use this feature, \u001b[30m\u001b[43mmbstring\u001b[39;49m\u001b[m\u000f extension must be enabled.\r\u001b[25d;zend.multibyte = Off\u001b[K\r\u001b[26d\u001b[K\u001b[27d; Allows to set the default encoding for the scripts.  This value will be used\u001b[28;3H"]
[0.000, "o", "unless \"declare(encoding=...)\" directive appears at the top of the script.\u001b[29;3HOnly affects if zend.multibyte is set.\r\u001b[30d;zend.script_encoding =\r\u001b[31d\u001b[K\u001b[32d; Allows to include or exclude arguments from stack traces generated for exceptions.\u001b[33;3HIn production, it is recommended to turn this setting on to prohibit the output\u001b[34;3H"]
[0.000, "o", "of sensitive information in stack traces\u001b[K\u001b[35;3HDefault Value: Off\u001b[K\u001b[36;3HDevelopment Value: Off\u001b[K\r\u001b[37d; Production Value: On\r\u001b[38dzend.exception_ignore_args = On\u001b[K\r\u001b[39d"]
[0.001, "o", "\u001b[K\u001b[40d; Allows setting the maximum string length in an argument of a stringified stack trace\u001b[41;3Hto a value between 0 and 1000000.\u001b[K\r\u001b[42d; This has no effect when zend.exception_ignore_args is enabled.\u001b[43;3HDefault Value: 15\u001b[K\u001b[44;3HDevelopment Value: 15\u001b[45;3HProduction Value: 0\u001b[24;36H"]
[1.502, "o", "\u001b[?25h\u001b[?0cmbstring\u001b[24;71H\u001b[24;36H"]
