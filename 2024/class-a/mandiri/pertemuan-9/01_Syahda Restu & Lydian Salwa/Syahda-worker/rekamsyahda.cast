[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/precision\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
