[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; Production value: 0\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; This directive controls whether PHP will output the backtrace of fatal errors.\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Default Value: On\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; Development Value: On\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; Production Value: On\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H;fatal_error_backtraces = On\r;"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H"]
