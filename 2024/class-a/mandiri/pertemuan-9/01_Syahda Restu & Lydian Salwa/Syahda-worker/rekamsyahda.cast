[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; Disable logging through FastCGI connection. PHP's default behavior is to enable\r;"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H; this feature.\r;"]
