[0.002, "o", "\u001b[K\u001b[4d# 'Main' server configuration\r\u001b[5d#\u001b[K\u001b[6d\b# The directives in this section set up the values used by the 'main'\r\u001b[7d# server, which responds to any requests that aren't handled by a\r\u001b[8d# <VirtualHost> definition.  These values also provide defaults for\r\u001b[9d# any <VirtualHost> containers you may define later in the file.\r\u001b[10d#\u001b[K\u001b[11d\b# All of these directives may appear inside <VirtualHost> containers,\r\u001b[12d# in which case these default settings will be overridden for the\r\u001b[13d# virtual host being defined.\u001b[K\r\u001b[14d#\u001b[K\u001b[16d\b#\u001b[K\u001b[17d\b# ServerAdmin: Your address, where problems with the server should be\u001b[K\r\u001b[18d# e-mailed.  This address appears on some server-generated pages, such\r\u001b[19d# as error documents.  e.g. admin@your-domain.com\u001b[K\r\u001b[20d#\u001b[K\u001b[21d\bServerAdmin you@example.com\u001b[K\r\u001b[22d\u001b[K\u001b[23d#\u001b[K\u001b[24d\b# \u001b[30m\u001b[43mServerName\u001b[39;49m\u001b[m\u000f gives the name and port that the server uses to identify itself.\r\u001b[25d# This can often be determined automatically, but we recommend you specify\r\u001b[26d# it explicitly to prevent problems during startup.\r\u001b[27d#\u001b[28d\b# If your host doesn't have a registered DNS name, enter its IP address here.\r\u001b[29d#\u001b[K\u001b[30d\b#ServerName www.example.com:80\u001b[K\r\u001b[31d"]
[0.000, "o", "\u001b[K\u001b[32d#\u001b[K\u001b[33d\b"]
[0.002, "o", "# Deny access to the entirety of your server's filesystem. You must\r\u001b[34d# explicitly permit access to web content directories in other\r\u001b[35d# <Directory> blocks below.\r\u001b[37d<Directory />\u001b[K\u001b[38;5HAllowOverride none\u001b[39;17Hdenied\u001b[K\r\u001b[42d#\u001b[43d\b# Note that from this point forward you must specifically allow\r\u001b[44d# particular features to be enabled - so if something's not working as\r\u001b[45d# you might expect, make sure that you have specifically enabled it\u001b[24;3H"]
[1.501, "o", "\u001b[?25h\u001b[?0cServerName\u001b[24;78H\r# "]
