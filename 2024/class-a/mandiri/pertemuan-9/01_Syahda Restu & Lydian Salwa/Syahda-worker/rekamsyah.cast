[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H# ErrorLog: The location of the error log file.\r"]
[0.913, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H# If you do not specify an ErrorLog directive within a <VirtualHost>\r"]
