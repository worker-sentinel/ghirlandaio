[0.117, "o", "\r\n================================================================================\r\n\r\n  -[ \u001b[1;37mLynis 3.1.6 Results\u001b[0m ]-\r\n\r\n"]
[0.013, "o", "  \u001b[1;31mWarnings\u001b[0m (1):\r\n  \u001b[1;37m----------------------------\u001b[0m\r\n"]
[0.092, "o", "  \u001b[1;31m!\u001b[0m Reboot of system is most likely needed [KRNL-5830] \r\n    - Solution : reboot\r\n      https://cisofy.com/lynis/controls/KRNL-5830/\r\n\r\n"]
[0.009, "o", "  \u001b[1;33mSuggestions\u001b[0m (47):\r\n  \u001b[1;37m----------------------------\u001b[0m\r\n"]
[0.092, "o", "  \u001b[1;33m*\u001b[0m Consider hardening system services [BOOT-5264] \r\n"]
[0.000, "o", "    - Details  : \u001b[0;36mRun '/usr/bin/systemd-analyze security SERVICE' for each service\u001b[0m\r\n"]
[0.000, "o", "    - Related resources\r\n"]
[0.031, "o", "      * Article: \u001b[0;36mSystemd features to secure service files\u001b[0m: https://linux-audit.com/systemd/systemd-features-to-secure-units-and-services/\r\n"]
[0.000, "o", "      * Website: \u001b[0;37mhttps://cisofy.com/lynis/controls/BOOT-5264/\u001b[0m\r\n"]
[0.002, "o", "\r\n"]
[0.089, "o", "  \u001b[1;33m*\u001b[0m If not required, consider explicit disabling of core dump in /etc/security/limits.conf file [KRNL-5820] \r\n"]
[0.001, "o", "    - Related resources\r\n"]
[0.030, "o", "      * Article: \u001b[0;36mUnderstand and configure core dumps on Linux\u001b[0m: https://linux-audit.com/software/understand-and-configure-core-dumps-work-on-linux/\r\n"]
[0.001, "o", "      * Website: \u001b[0;37mhttps://cisofy.com/lynis/controls/KRNL-5820/\u001b[0m\r\n\r\n"]
[0.092, "o", "  \u001b[1;33m*\u001b[0m Check process listing for processes waiting for IO requests [PROC-3614] \r\n"]
