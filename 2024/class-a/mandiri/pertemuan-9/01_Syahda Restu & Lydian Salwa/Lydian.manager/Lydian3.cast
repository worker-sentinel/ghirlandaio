[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Allows calling OPcache API functions only from PHP scripts which path is\u001b[72;33H"]
