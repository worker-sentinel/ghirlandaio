[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; By default, only fatal errors (level 0) or errors (level 1) are logged.\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; You can also enable warnings (level 2), info messages (level 3) or\u001b[72;33H"]
