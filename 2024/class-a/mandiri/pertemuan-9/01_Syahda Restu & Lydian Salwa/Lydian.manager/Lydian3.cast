[0.000, "o", "\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[75;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[75;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[75;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[75;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[75;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[75;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[75;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[75;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\r\u001b[2d\u001b[K\u001b[3;19Hfilter.default-flags\u001b[K\r\u001b[4d;filter.default_flags =\u001b[K\r\u001b[6d[iconv]\u001b[K\u001b[7;3HUse of this INI entry is deprecated, use global input_encoding instead.\u001b[8;3HIf empty, default_charset or input_encoding or iconv.input_encoding is used.\u001b[9;3H"]
[0.000, "o", "The precedence is: default_charset < input_encoding < iconv.input_encoding\r\u001b[10d;iconv.input_encoding =\u001b[K\r\u001b[11d\u001b[K\u001b[12d;"]
[0.000, "o", " Use of this INI entry is deprecated, use global internal_encoding instead.\r\u001b[13d; If empty, default_charset or internal_encoding or iconv.internal_encoding is used.\r\u001b[14d; The precedence is: default_charset < internal_encoding < iconv.internal_encoding\r\u001b[15d;iconv.internal_encoding =\r\u001b[16d\u001b[K\u001b[17d"]
[0.000, "o", "; Use of this INI entry is deprecated, use global output_encoding instead.\u001b[18;6Hempty, default_charset or output_encoding or iconv.output_encoding is used.\u001b[19;3H"]
[0.000, "o", "The precedence is: default_charset < output_encoding < iconv.output_encoding\u001b[20;3HTo use an output encoding conversion, iconv's output handler must be set\u001b[21;3Hotherwise output encoding conversion cannot be performed.\r\u001b[22d;iconv.output_encoding =\r\u001b[23d"]
[0.000, "o", "\u001b[K\u001b[24d[intl]\r\u001b[25d;intl.default_locale =\u001b[26;3HThis directive allows you to produce PHP errors when some error\u001b[27;3Hhappens within intl functions. The value is the level of the error produced.\u001b[28;3HDefault is 0, which does not produce any errors.\u001b[K\u001b[29;3HThis directive is deprecated.\r\u001b[30d;"]
[0.000, "o", "intl.error_level = E_WARNING\u001b[K\u001b[31;3HIf enabled this directive indicates that when an error occurs within an\u001b[32;3Hintl function a IntlException should be thrown.\u001b[K\u001b[33;3HDefault is Off, which means errors need to be handled manually.\u001b[K\r\u001b[34d;"]
[0.000, "o", "intl.use_exceptions = On\u001b[K\r\u001b[35d\u001b[K\u001b[36d"]
[0.000, "o", "[sqlite3]\r\u001b[37d;"]
[0.001, "o", " Directory pointing to SQLite3 \u001b[30m\u001b[43mextension\u001b[39;49m\u001b[m\u000fs\r\u001b[38d; https://php.net/sqlite3.extension-dir\r\u001b[39d;sqlite3.extension_dir =\r\u001b[40d\u001b[K\u001b[41d; SQLite defensive mode flag (only available from SQLite 3.26+)\r\u001b[42d; When the defensive flag is enabled, language features that allow ordinary\r\u001b[43d; SQL to deliberately corrupt the database file are disabled. This forbids\r\u001b[44d; writing directly to the schema, shadow tables (eg. FTS data tables), or\r\u001b[45d; the sqlite_dbpage virtual table.\r\u001b[46d"]
[0.000, "o", "; https://www.sqlite.org/c3ref/c_dbconfig_defensive.html\r\u001b[47d; (for older SQLite versions, this flag has no use)\r\u001b[48d;sqlite3.defensive = 1\r\u001b[49d\u001b[K\u001b[50d[Pcre]\u001b[K\r\u001b[51d;"]
[0.000, "o", " PCRE library backtracking limit.\r\u001b[52d; https://php.net/pcre.backtrack-limit\r\u001b[53d;pcre.backtrack_limit=100000\r\u001b[54d"]
[0.000, "o", "\u001b[K\u001b[55d; PCRE library recursion limit.\r\u001b[56d; Please note that if you set this value to a high number you may consume all\r\u001b[57d; the available process stack and eventually crash PHP (due to reaching the\r\u001b[58d; stack size limit imposed by the Operating System).\r\u001b[59d;"]
[0.000, "o", " https://php.net/pcre.recursion-limit\r\u001b[60d;pcre.recursion_limit=100000\r\u001b[61d\u001b[K\u001b[62d;"]
[0.000, "o", " Enables or disables JIT compilation of patterns. This requires the PCRE\r\u001b[63d; library to be compiled with JIT support.\r\u001b[64d;pcre.jit=1\u001b[K\r\u001b[65d\u001b[K\u001b[66d[Pdo]\u001b[K\r\u001b[67d;"]
[0.000, "o", " Whether to pool ODBC connections. Can be one of \"strict\", \"relaxed\" or \"off\"\r\u001b[68d; https://php.net/pdo-odbc.connection-pooling\r\u001b[69d;pdo_odbc.connection_pooling=strict\r\u001b[70d"]
[0.000, "o", "\u001b[K\u001b[71d[Pdo_mysql]\u001b[K\r\u001b[72d; Default socket name for local MySQL connects.  If empty, uses the built-in\u001b[37;33H"]
