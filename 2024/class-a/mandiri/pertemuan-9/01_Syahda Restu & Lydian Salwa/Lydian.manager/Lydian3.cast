[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; - crlf: Use CRLF line endings"]
