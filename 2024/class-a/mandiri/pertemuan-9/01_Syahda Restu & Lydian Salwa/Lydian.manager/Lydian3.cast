[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; If openssl.cafile is not specified or if the CA file is not found, the\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; directory pointed to by openssl.capath is searched for a suitable\u001b[72;33H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; certificate. This value must be a correctly hashed certificate directory.\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; Most users should not specify a value for this directive as PHP will\u001b[72;33H"]
[0.045, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; attempt to use the OS-managed cert stores in its absence. If specified,\u001b[72;33H"]
[1.928, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; this value may still be overridden on a per-stream basis via the \"capath\"\u001b[72;33H"]
[0.269, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; SSL stream context option."]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H;openssl.capath="]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; The libctx is an OpenSSL library context. OpenSSL defines a default library\u001b[72;33H"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; context, but PHP OpenSSL also defines its own library context to avoid\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; interference with other libraries using OpenSSL and to provide an independent\u001b[72;33H"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; context for each thread in ZTS. Possible values:\u001b[72;33H"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H;  \"custom\"  - use a custom library context (default)\u001b[72;33H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H;  \"default\" - use the default OpenSSL library context\u001b[72;33H"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H;openssl.libctx=custom"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H[ffi]"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; FFI API restriction. Possible values:\u001b[33G"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; \"preload\" - enabled in CLI scripts and preloaded files (default)\u001b[72;33H"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; \"false\"   - always disabled"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; \"true\"    - always enabled"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H;ffi.enable=preload"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; List of headers files to preload, wildcard patterns allowed.\u001b[72;33H"]
