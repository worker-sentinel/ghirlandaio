[0.001, "o", "\u001b[39;49m\u001b[m\u000f\u001b[H\u001b[J\u001b[73;114H\u001b[0;10;7m\u000f[ Reading... ]\u001b[m\u000f"]
[0.000, "o", "\u001b[73;112H\u001b[0;10;7m\u000f[ Read 41 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                        /etc/httpd/conf/extra/httpd-vhosts.conf                                                                                                   \u001b[1;239H\u001b[m\u000f\r\u001b[74d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[74;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[74;69H"]
[0.003, "o", "\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[74;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[74;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[74;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[75d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[75;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[75;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[75;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[75;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[75;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[75;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[75;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d#\u001b[19d\b# VirtualHost example:\r\u001b[20d# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d# The first VirtualHost section is used for all requests that do not\r\u001b[22d# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d#\u001b[24d\b<VirtualHost *:80>\u001b[25;5HServerAdmin webmaster@dummy-host.example.com\u001b[26;5HDocumentRoot \"/etc/httpd/docs/dummy-host.example.com\"\u001b[27;5HServerName dummy-host.example.com\u001b[28;5HServerAlias www.dummy-host.example.com\u001b[29;5HErrorLog \"/var/log/httpd/dummy-host.example.com-error_log\"\u001b[30;5HCustomLog \"/var/log/httpd/dummy-host.example.com-access_log\" common\r\u001b[31d</VirtualHost>\r\u001b[33d<VirtualHost *:80>\u001b[34;5HServerAdmin webmaster@dummy-host2.example.com\u001b[35;5HDocumentRoot \"/etc/httpd/docs/dummy-host2.example.com\"\u001b[36;5HServerName dummy-host2.example.com\u001b[37;5HErrorLog \"/var/log/httpd/dummy-host2.example.com-error_log\"\u001b[38;5HCustomLog \"/var/log/httpd/dummy-host2.example.com-access_log\" common\r\u001b[39d</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
