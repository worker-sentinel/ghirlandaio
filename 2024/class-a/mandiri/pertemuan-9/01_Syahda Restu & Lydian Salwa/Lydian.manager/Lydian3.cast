[0.000, "o", "\r\u001b[2d# ServerName gives the name and port that the server uses to identify itself.\r\u001b[3d# This can often be determined automatically, but we recommend you specify\r\u001b[4d# it explicitly to prevent problems during startup.\r\u001b[5d#\u001b[K\u001b[6d If your host doesn't have a registered DNS name, enter its IP address here.\r\u001b[7d#\u001b[K\u001b[8d\b#ServerName www.example.com:80\u001b[K\r\u001b[9d"]
[0.000, "o", "\u001b[K\u001b[10d#\u001b[K\u001b[11d\b# Deny access to the entirety of your server's filesystem. You must\r\u001b[12d#"]
[0.001, "o", " explicitly permit access to web content directories in other\r\u001b[13d# <Directory> blocks below.\u001b[K\r\u001b[14d#\u001b[K\u001b[15d\b<Directory />\u001b[K\r\u001b[16d"]
[0.000, "o", "    AllowOverride none\u001b[K\r\u001b[17d    Require all denied\u001b[K\r\u001b[18d</Directory>\u001b[K\r\u001b[19d"]
[0.000, "o", "\u001b[K\u001b[20d#\u001b[K\u001b[21d Note that from this point forward you must specifically allow\r\u001b[22d#"]
[0.000, "o", " particular features to be enabled - so if something's not working as\r\u001b[23d# you might expect, make sure that you have specifically enabled it\r\u001b[24d# below.\u001b[K\r\u001b[25d#\u001b[K\u001b[26d\b"]
[0.000, "o", "\u001b[K\u001b[27d#\u001b[K\u001b[28d\b# DocumentRoot: The directory out of which you will serve your\r\u001b[29d#"]
[0.000, "o", " documents. By default, all requests are taken from this directory, but\r\u001b[30d# symbolic links and aliases may be used to point to other locations.\r\u001b[31d#\u001b[K\u001b[32d\b"]
[0.000, "o", "DocumentRoot \"/srv/http\"\u001b[K\r\u001b[33d<Directory \"/srv/http\">\u001b[K\r\u001b[34d    #\u001b[K\r\u001b[35d"]
[0.000, "o", "    # Possible values for the Options directive are \"None\", \"All\",\u001b[K\r\u001b[36d    # or any combination of:\u001b[K\r\u001b[37d    #   Indexes \u001b[30m\u001b[43mInclude\u001b[39;49m\u001b[m\u000fs FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\u001b[38d    #\u001b[K\r\u001b[39d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[40d    # doesn't give it to you.\u001b[K\r\u001b[41d    #\u001b[K\r\u001b[42d    # The Options directive is both complicated and important.  Please see\r\u001b[43d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[44d"]
[0.000, "o", "    # for more information.\u001b[K\r\u001b[45d    #\u001b[K\r\u001b[46d    Options Indexes FollowSymLinks\u001b[K\r\u001b[47d\u001b[K\u001b[48d    #\u001b[K\u001b[49d\b"]
[0.000, "o", "# AllowOverride controls what directives may be placed in .htaccess files.\r\u001b[50d    # It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[51d    #   AllowOverride FileInfo AuthConfig Limit\u001b[52;5H#\u001b[K\r\u001b[53d"]
[0.000, "o", "    AllowOverride None\r\u001b[54d\u001b[K\u001b[55d    #\u001b[K\r\u001b[56d"]
[0.000, "o", "    # Controls who can get stuff from this server.\u001b[K\r\u001b[57d    #\u001b[K\r\u001b[58d"]
[0.000, "o", "    Require all granted\u001b[K\r\u001b[59d</Directory>\u001b[K\r\u001b[60d\u001b[K\u001b[61d#\u001b[K\u001b[62d\b"]
[0.000, "o", "# DirectoryIndex: sets the file that Apache will serve if a directory\r\u001b[63d# is requested.\u001b[K\r\u001b[64d#\u001b[K\u001b[65d\b<IfModule dir_module>\r\u001b[66d    DirectoryIndex index.html\r\u001b[67d</IfModule>\r\u001b[68d\u001b[K\u001b[69d# \u001b[K\u001b[70dThe following lines prevent .htaccess and .htpasswd files from being\u001b[71;3Hviewed by Web clients.\u001b[K\u001b[72;3H\u001b[K\u001b[37;17H"]
