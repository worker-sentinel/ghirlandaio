[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Output buffering is a mechanism for controlling how much output data\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; (excluding headers and cookies) PHP should keep internally before pushing that\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; data to the client. If your application's output exceeds this setting, PHP\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; will send that data in chunks of roughly the size you specify.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Turning on this setting and managing its maximum buffer size can yield some\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; interesting side-effects depending on your application and web server.\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; You may be able to send headers and cookies after you've already sent output\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; through print or echo. You also may see performance benefits if your server is\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; emitting less packets due to buffered output versus PHP streaming the output\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; as it gets it. On production servers, 4096 bytes is a good setting for performance\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; reasons.\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Note: Output buffering can also be controlled via Output Buffering Control\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
