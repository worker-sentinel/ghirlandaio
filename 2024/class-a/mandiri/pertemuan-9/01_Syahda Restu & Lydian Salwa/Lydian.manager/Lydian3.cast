[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;72r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;75r\u001b[2;1H; variable in order to use PHP's session functions.\u001b[2;33H"]
