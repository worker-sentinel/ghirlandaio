[0.000, "o", "\r\u001b[74d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[74;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[74;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[74;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[74;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[74;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[75d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[75;18H"]
