[0.000, "o", "\n\u001b[1;75r\u001b[72;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Facilitates multiple OPcache instances per user (for Windows only). All PHP\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; processes with the same cache ID and user share an OPcache instance.\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H;opcache.cache_id="]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; Enables and sets the second level cache directory.\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; It should improve performance when SHM memory is full, at server restart or\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; SHM reset. The default \"\" disables file based caching.\u001b[72;33H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H;opcache.file_cache="]
