[0.000, "o", "\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[75;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[75;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[75;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[75;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[75;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[75;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[75;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[75;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\u001b[64;71r\u001b[64;1H\u001b[2L\u001b[1;75r\u001b[2;3H\u001b[K\u001b[3dSome examples:\u001b[K\r\u001b[4d#ErrorDocument 500 \"The server made a boo boo.\"\u001b[K\r\u001b[5d#ErrorDocument 404 /missing.html\r\u001b[6d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\u001b[K\r\u001b[7d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[8d#\u001b[K\u001b[11d MaxRanges: Maximum number of Ranges in a request before\u001b[K\u001b[12;3Hreturning the entire resource, or one of the special\u001b[K\u001b[13;3Hvalues 'default', 'none' or 'unlimited'.\u001b[14;3HDefault setting is to accept 200 Ranges.\r\u001b[15d"]
[0.000, "o", "#MaxRanges unlimited\r\u001b[16d\u001b[K\u001b[17d#\u001b[K\u001b[18d\b# EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[19d"]
[0.000, "o", "# memory-mapping or the sendfile syscall may be used to deliver\u001b[20;3Hfiles.  This usually improves server performance, but must\u001b[21;3Hbe turned off when serving from networked-mounted\u001b[K\u001b[22;3Hfilesystems or if support for these functions is otherwise\u001b[K\u001b[23;3Hbroken on your system.\u001b[K\u001b[24;3H"]
[0.000, "o", "Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[26d#EnableMMAP off\r\u001b[27d#EnableSendfile on\r\u001b[28d\u001b[K\u001b[29d# Supplemental configuration\u001b[K\u001b[30;3H"]
[0.000, "o", "\u001b[K\u001b[31dThe configuration files in the conf/extra/ directory can be\r\u001b[32d# included to add extra features or to modify the default configuration of\r\u001b[33d# the server, or you may simply copy their contents here and change as\r\u001b[34d# necessary.\r\u001b[35d\u001b[K\u001b[36d"]
[0.000, "o", "# Server-pool management (MPM specific)\r\u001b[37d\u001b[30m\u001b[43mInclude conf\u001b[39;49m\u001b[m\u000f/extra/httpd-mpm.conf\u001b[K\r\u001b[38d\u001b[K\u001b[39d# Multi-language error messages\u001b[K\r\u001b[40dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[41d"]
[0.000, "o", "\u001b[K\u001b[42d# Fancy directory listings\u001b[K\r\u001b[43dInclude conf/extra/httpd-autoindex.conf\u001b[K\r\u001b[44d"]
[0.000, "o", "\u001b[K\u001b[45d# Language settings\r\u001b[46dInclude conf/extra/httpd-languages.conf\r\u001b[48d"]
[0.000, "o", "# User home directories\r\u001b[49dInclude conf/extra/httpd-userdir.conf\u001b[K\r\u001b[50d\u001b[K\u001b[51d"]
[0.000, "o", "# Real-time info on requests and configuration\u001b[K\r\u001b[52d#Include conf/extra/httpd-info.conf\r\u001b[53d\u001b[K\u001b[54d"]
[0.000, "o", "# Virtual hosts\r\u001b[55d#Include conf/extra/httpd-vhosts.conf\r\u001b[56d"]
[0.001, "o", "\u001b[K\u001b[57d# Local access to the Apache HTTP Server Manual\r\u001b[58d#Include conf/extra/httpd-manual.conf\r\u001b[59d\u001b[K\u001b[60d# Distributed authoring and versioning (WebDAV)\r\u001b[61d#Include conf/extra/httpd-dav.conf\r\u001b[62d\u001b[K\u001b[63d# Various default settings\r\u001b[64dInclude conf/extra/httpd-default.conf\u001b[66;3H"]
[0.000, "o", "Configure mod_proxy_html to understand HTML4/XHTML1\u001b[67;11Hproxy_html_module>\r\u001b[68d"]
[0.000, "o", "Include conf/extra/proxy-html.conf\u001b[71;3HSecure (SSL/TLS) connections\r\u001b[72d#Include conf/extra/httpd-ssl.conf\r\u001b[37d"]
