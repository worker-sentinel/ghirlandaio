[0.000, "o", "\n\u001b[1;75r\u001b[72;1Hserialize_precision = -1\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
