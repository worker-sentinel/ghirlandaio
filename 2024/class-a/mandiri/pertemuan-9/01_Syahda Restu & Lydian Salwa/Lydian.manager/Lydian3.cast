[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Note: You cannot use both \"mb_output_handler\" with \"ob_iconv_handler\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H;   and you cannot use both \"ob_gzhandler\" and \"zlib.output_compression\".\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Note: output_handler must be empty if this is set 'On' !!!!\r"]
[0.036, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H;   Instead you must use zlib.output_handler.\r"]
