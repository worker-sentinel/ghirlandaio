[0.001, "o", "\u001b7\u001b[2;72r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;75r\u001b[2;1H"]
[0.000, "o", ";     session.save_path = \"N;/path\"\b\b\b"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;72r\u001b8\r\u001bM\u001b[1;75r\u001b[2;1H"]
[0.000, "o", ";"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;72r\u001b8\b\u001bM\u001b[1;75r\u001b[2;1H"]
[0.000, "o", "; The path can be defined as:"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001bM\u001b[1;75r\u001b[2;1H"]
