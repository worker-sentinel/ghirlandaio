[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; The display of errors which occur during PHP's startup sequence are handled\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; separately from display_errors. We strongly recommend you set this to 'off'\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
