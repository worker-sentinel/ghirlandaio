[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Directory where the temporary files should be placed.\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Defaults to the system default (see sys_get_temp_dir)\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
