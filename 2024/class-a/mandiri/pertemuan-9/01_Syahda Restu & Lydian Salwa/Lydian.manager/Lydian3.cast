[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; Each OPcache blacklist file is a text file that holds the names of files\u001b[72;33H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; that should not be accelerated. The file format is to add each filename\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; to a new line. The filename may be a full path or just a file prefix\u001b[72;33H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; (i.e., /var/www/x  blacklists all the files and directories in /var/www\u001b[72;33H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\r\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; that start with 'x'). Line starting with a ; are ignored (comments).\u001b[72;33H"]
