[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.001, "o", "\n\u001b[1;75r\u001b[72;1H; cgi.fix_pathinfo provides *real* PATH_INFO/PATH_TRANSLATED support for CGI.  PHP's\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; previous behaviour was to set PATH_TRANSLATED to SCRIPT_FILENAME, and to not grok\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; what PATH_INFO is.  For more information on PATH_INFO, see the cgi specs.  Setting\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; this to 1 will cause PHP CGI to fix its paths to conform to the spec.  A setting\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; of zero causes PHP to behave as before.  Default is 1.  You should fix your scripts\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;73r\u001b8\u001b[73d"]
[0.000, "o", "\n\u001b[1;75r\u001b[72;1H; to use SCRIPT_FILENAME rather than PATH_TRANSLATED.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
