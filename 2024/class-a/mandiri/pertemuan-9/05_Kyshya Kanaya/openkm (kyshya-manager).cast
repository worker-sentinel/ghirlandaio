[0.003, "o", "\u001b[1;2H Configuration file for locale-gen\u001b[2;2H\u001b[20X\n lists of locales that are to be generated by the locale-gen command.\u001b[4;2H\u001b[14X\n Each line is of the form:\u001b[6;2H\u001b[13X\n     <locale> <charset>\u001b[8;2H\u001b[13X\n  where <locale> is one of the locales given in /usr/share/i18n/locales\u001b[10;2H  and <charset> is one of the character sets listed in /usr/share/i18n/charmaps\u001b[11;2H\u001b[18X\n  The locale-gen command will generate all the locales,\u001b[13;2H  placing them in /usr/lib/locale.\u001b[14;2H\u001b[19X\n  A list of supported locales is given in /usr/share/i18n/S\u001b[30m\u001b[103mU\u001b[m\u000fPPORTED\u001b[16;2H  and is included in this file. \u001b[30m\u001b[103mU\u001b[m\u000fncomment the needed locales below.\u001b[17;2H\u001b[19X\naa_DJ.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8\u001b[19;2Haa_DJ ISO-8859-1   \u001b[20;2Haa_ER \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[5X\u001b[21;2Haa_ET \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[11X\u001b[22;2Haf_ZA.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8     \u001b[23;2Haf_ZA ISO-8859-1   \u001b[24;2Hagr_PE \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[5X\u001b[25;2Hak_GH \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[6X\u001b[26;2Ham_ET \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[6X\u001b[27;2Han_ES.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[28;2Han_ES ISO-8859-15  \u001b[29;2Hanp_IN \u001b[30m\u001b[103mU\u001b[30;2H\u001b[m\u000far_AE.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[31;2Har_AE ISO-8859-6  \u001b[32;2Har_BH.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[33;2Har_BH ISO-8859-6   \u001b[34;2Har_DZ.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[35;2Har_DZ ISO-8859-6  \u001b[36;2Har_EG.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[37;2Har_EG ISO-8859-6   \u001b[38;2Har_IN \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[6X\u001b[39;2Har_IQ.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[40;2H\u001b[m\u000far_IQ ISO-8859-6\u001b[41;2Har_JO.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[42;2H\u001b[m\u000far_JO ISO-8859-6\u001b[43;2Har_KW.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[5X\u001b[44;2Har_KW ISO-8859-6   \u001b[45;2Har_LB.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[46;2Har_LB ISO-8859-6  \u001b[6X\u001b[47;2Har_LY.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[48;2H\u001b[m\u000far_LY ISO-8859-6\u001b[49;2Har_MA.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[50;2H\u001b[m\u000far_MA ISO-8859-6\u001b[51;2Har_OM.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[5X\u001b[52;2Har_OM ISO-8859-6   \u001b[53;2Har_QA.\u001b[30m\u001b[103mU\u001b[m\u000fTF-8 \u001b[30m\u001b[103mU\u001b[m\u000fTF-8  \u001b[54;2Har_QA ISO-8859-6   \u001b[55;184H\u001b[0;10;7m\u000f5,61          Top\u001b[56;3H\u001b[?25h"]
