[0.693, "o", "\r\n\u001b[?2004l\r"]
[0.036, "o", "         type: Boot Loader Specification Type #2 (UKI, .efi)\r\n        title: \u001b[0;1;39mArch Linux\u001b[0m \u001b[0;1;32m(default)\u001b[0m \u001b[0;1;35m(selected)\u001b[0m\r\n           id: arch-linux-hardened.efi\r\n       source: \u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/Linux/arch-linux-hardened.efi (on the EFI System Partition)\r\n     sort-key: arch\r\n      version: 7.0.10-hardened1-1-hardened\r\n        linux: \u001b[0;90m\u001b[0;38:5:245m/boot/\u001b[0m/EFI/Linux/arch-linux-hardened.efi\r\n      profile: 0\r\n      options: rd.luks.name=f9e72443-a7e9-4bc1-890e-9b1e51249e26=Itsukinnieee root=/dev/nobuchan/root rw\r\n\r\n         type: Automatic\r\n        title: \u001b[0;1;39mReboot Into Firmware Interface\u001b[0m\r\n           id: auto-reboot-to-firmware-setup\r\n       source: /sys/firmware/efi/efivars/LoaderEntries-4a67b082-0a4c-41cf-b6c7-440b29bb8c4f (on the EFI System Partition)\r\n"]
