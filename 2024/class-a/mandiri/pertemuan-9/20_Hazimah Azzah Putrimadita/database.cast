[1762.834384, "o", "\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mBuilding image from preset: /etc/mkinitcpio.d/linux-lts.preset: 'default'\u001b[m\u000f\r\n\u001b[1m\u001b[32m==>\u001b[m\u000f \u001b[1mUsing default configuration file: '/etc/mkinitcpio.conf'\u001b[m\u000f\r\n"]
[1762.83546, "o", "  \u001b[1m\u001b[34m->\u001b[m\u000f \u001b[1m-k /boot/vmlinuz-linux-lts -g /boot/initramfs-linux-lts.img\u001b[m\u000f\r\n"]
