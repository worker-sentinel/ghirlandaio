[2.644, "o", "cat > opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\rservices:\r\n\r openkm:\r\n\r  image: openkm/openkm-ce:6.3.12\r\n\r  networks:\r\n\r   - openkm-net\r\n\r  environment:\r\n\r   - OPENKM_URL=http://openkm:8080/OpenKM\r\n\r   - DB_DRIVER=com.mysql.jdbc.Driver\r\n\r   - DB_URL=jdbc:mysql://172.20.10.3:2377/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r   - DB_USER=openkm\r\n\r   - DB_PASS=openkm_db_secret\r\n\r  volumes:\r\n\r   - openkm_data:/opt/openkm/repository\r\n\r   - openkm_logs:/opt/openkm/log\r\n\r  ports:\r\n\r   - \"8080:8080\"\r\n\r  deploy:\r\n\r   replicas: 1\r\n\r   placement:\r\n\r    constraints:\r\n\r     - node.role == manager\r\n\r   restart_policy:\r\n\r    condition: on-failure\r\n\r   resources:\r\n\r    limits:\r\n\r     memory: 1.5G\r\n\r\n\rnginx:\r\n\r image: nginx:stable-alpine\r\n\r networks:\r\n\r  - openkm-net\r\n\r ports:\r\n\r  - \"80:80\"\r\n\r  - \"443:443\"\r\n\r configs:\r\n\r  - source: nginx_conf\r\n\r  target: /etc/nginx/conf.d/default.conf\r\n\r deploy:\r\n\r  replicas: 1\r\n\r  restart_policy:\r\n\r   condition: on-failure\r\n\r\n\rvolumes:\r\n\r opnekm_data:\r\n\r openkm_logs:\r\n\r\n\rconfigs:\r\n\r nginx_conf:\r\n\r  file: ./nginx.conf\r\n\r\n\rnetworks:\r\n\r\n"]
[0.001, "o", "\r openkm-net:\r\n\r  external: true\r\n\rEOF\r\n\r"]
[0.188, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C- openkm-net\r\n\r\u001b[8Pports:\r\n\r- \"80:80\"\r\n\r- \"443:443\r\n\r\u001b[5Pconfigs:\r\n\r- source: nginx_conf\r\n\r\u001b[16@target: /etc/nginx/conf.d/default.\r\n\rdeploy:                                 \r\n\rreplicas: 1\r\n\rrestart_policy:\r\n\rcondition: on-failure\r\n\r                        \r\n\rvolumes:\r\n\r\u001b[4@opnekm_data\r\n\r\u001b[1Popenkm_logs\r\n\r             \r\n\rconfigs:\r\n\r\u001b[3@nginx_conf\r\n\rfile: ./nginx.conf\r\n\r                    \r\n\rnetworks:\r\n\r         \r\n\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\u001b[A\u001b[A\u001b[A\u001b[A"]
[0.155, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[5P\r\n\r\n\r\n\r\u001b[1P\r\n\r\u001b[13Pnetworks:\r\n\r- openkm-net\r\n\r\u001b[3Pports:\r\n\r\u001b[C\u001b[C\u001b[C\u001b[2P80:80\r\n\r- \"443:443\"\r\n\r\u001b[12Pconfigs:\r\n\r\u001b[18P- source: nginx_\r\n\rtarget: /etc/nginx/conf.d/default.conf\r\n\r\u001b[4Pdeploy:\r\n\r\u001b[C\u001b[C\u001b[4Pplicas: 1\r\n\r\u001b[6Prestart_policy:\r\n\rcondition: on-failure\r\n\r        \r\n\r\u001b[4Pvolumes\r\n\r\u001b[C\u001b[Cnekm_data\r\n\ropenkm_logs:\r\n\r        \r\n\r\u001b[3Pconfigs\r\n\r\u001b[7Pnginx_conf:\r\n\rfile: ./nginx.conf\r\n\r         \r\n\rnetworks:\r\n\r"]
[0.144, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[1P\r\n\r\u001b[2P\r\n\r\u001b[2P\r\n\r\u001b[3P\r\n\r\u001b[2P\r\n\r\u001b[3P\r\n\r\u001b[3P\r\n\r\u001b[3P\r\n\r\u001b[3P\r\n\r\u001b[3P\r\n\r\u001b[2P\r\n\r\u001b[3P\r\n\r\u001b[3P\r\n\r\u001b[2P\r\n\r\u001b[3P- \"8080\"\r\n\r\u001b[2P\r\n\r\u001b[3P\r\n\r\u001b[3P\r\n\r\u001b[4P\r\n\r\u001b[5P\r\n\r\u001b[3P\r\n\r\u001b[4P\r\n\r\u001b[3P\r\n\r\u001b[5Plimits\r\n\r            \r\n\r\n\r      \r\n\r                          \r\n\r         \r\n\r            \r\n\r      \r\n\r         \r\n\r           \r\n\r        \r\n\r                    \r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A"]
[0.156, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[5P/opt/openkm/nginx.conf\r\n\r\u001b[6Pserver {\r\n\rlisten 80;\r\n\r\u001b[C\u001b[C\u001b[C\u001b[Cer_name _;\r\n\r       \r\n\r\u001b[4Pclient_max_body_size 100M;\r\n\rserver_tokens off;\r\n\r            \r\n\radd_header X-Frame-Options \"SAMEORIGIN\" always;\r\n\radd_header X-Content-Type-Options \"nosniff\" always;\r\n\radd_header X-XSS-Protection \"1; mode=block\" always;\r\n\r                                                                                                               \r\n\r\u001b[4Plocation / {\r\n\rproxy_pass http://openkm:8080;\r\n\rproxy_set_header Host $host;\r\n\rproxy_set_header X-Real-IP $remote_addr;\r\n\rproxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\r\n\r\u001b[Croxy_set_header X-Forwarded-Proto $scheme;\r\n\rproxy_read_timeout 300s;\r\n\r}      \r\n\r}          \r\n\rEOF       \r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\r\n\r\u001b[K\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A"]
