[0.030, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C            \r\n\r  - openkm-net\r\n\r\u001b[2P ports:\r\n\r  - \"80:80\r\n\r  - \"443:443\"\r\n\r\u001b[11P configs:\r\n\r\u001b[16P  - source: nginx_\r\n\r  target: /etc/nginx/conf.d/default.conf\r\n\r\u001b[3P deploy:\r\n\r\u001b[2P  replicas: 1\r\n\r\u001b[4P  restart_policy:\r\n\r   condition: on-failure\r\n\r        \r\n\r\u001b[4Pvolumes\r\n\r\u001b[1@ opnekm_data\r\n\r openkm_logs:\r\n\r        \r\n\r\u001b[3Pconfigs\r\n\r\u001b[6P nginx_conf:\r\n\r  file: ./nginx.conf\r\n\r         \r\n\rnetworks:\r\n\r\n\r openkm-net:\r\n\r  external: true\r\n\rEOF\r\n\r"]
