[0.207, "o", "\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\b\bcat > /opt/openkm/docker-stack.yml << 'EOF'\r\n\rversion: \"3.8\"\r\n\r\n\rservices:\r\n\r openkm:\r\n\r  image: openkm/openkm-ce:6.3.12\r\n\r  networks:\r\n\r   - openkm-net\r\n\r  environment:\r\n\r   - OPENKM_URL=http://openkm:8080/OpenKM\r\n\r   - DB_DRIVER=com.mysql.jdbc.Driver\r\n\r   - DB_URL=jdbc:mysql://172.20.10.3:3306/openkm?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8\r\n\r   - DB_USER=openkm\r\n\r   - DB_PASS=madita07\r\n\r  volumes:\r\n\r   - openkm_data:/opt/openkm/repository\r\n\r   - openkm_logs:/opt/openkm/log\r\n\r  ports:\r\n\r   - \"8080:8080\"\r\n\r  deploy:\r\n\r   replicas: 1\r\n\r   placement:\r\n\r    constraints:\r\n\r     - node.role == manager\r\n\r   restart_policy:\r\n\r    condition: on-failure\r\n\r   resources:\r\n\r    limits:\r\n\r     memory: 1.5G\r\n\r\n\rnginx:\r\n\r image: nginx:stable-alpine\r\n\r networks:\r\n\r  - openkm-net\r\n\r ports:\r\n\r  - \"80:80\"\r\n\r  - \"443:443\"\r\n\r configs:\r\n\r  - source: nginx_conf\r\n\r  target: /etc/nginx/conf.d/default.conf\r\n\r deploy:\r\n\r  replicas: 1\r\n\r  restart_policy:\r\n\r   condition: on-failure\r\n\r\n\rvolumes:\r\n\r opnekm_data:\r\n\r openkm_logs:\r\n\r\n\rconfigs:\r\n\r nginx_conf:\r\n\r  file: ./nginx.conf\r\n\r\n\rnetworks:\r\n\r\n\r openkm-net:\r\n\r  external: true\r\n\rEOF\r\n\r"]
