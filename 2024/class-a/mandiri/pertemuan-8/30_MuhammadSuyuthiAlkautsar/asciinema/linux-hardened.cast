ISTRIBUTOR=\"Arch\"\r\u001b[7dGRUB_CMDLINE_LINUX_DEFAULT=\"loglevel=3 quiet\"\r\u001b[8dGRUB_CMDLINE_LINUX=\"\"\r\u001b[10d# Preload both GPT and MBR modules so that they are not missed\r\u001b[11dGRUB_PRELOAD_MODULES=\"part_gpt part_msdos\"\r\u001b[13d# Uncomment to enable booting from LUKS encrypted devices\r\u001b[14d#GRUB_ENABLE_CRYPTODISK=y\r\u001b[16d# Set to 'countdown' or 'hidden' to change timeout behavior,\r\u001b[17d# press ESC key to display menu.\r\u001b[18dGRUB_TIMEOUT_STYLE=menu\r\u001b[20d# Uncomment to use basic console\r\u001b[21dGRUB_TERMINAL_INPUT=console\r\u001b[23d# Uncomment to disable graphical terminal\r\u001b[24d#GRUB_TERMINAL_OUTPUT=console\r\u001b[26d# The resolution used on graphical terminal\r\u001b[27d# note that you can use only modes which your graphic card supports via VBE\r\u001b[28d# you can see them in real GRUB with the command `videoinfo'\r\u001b[29dGRUB_GFXMODE=auto\r\u001b[31d# Uncomment to allow the kernel use the same resolution used by grub\r\u001b[32dGRUB_GFXPAYLOAD_LINUX=keep\r\u001b[34d# Uncomment if you want GRUB to pass to the Linux kernel the old parameter\r\u001b[35d# format \"root=/dev/xxx\" instead of \"root=/dev/disk/by-uuid/xxx\"\r\u001b[36d#GRUB_DISABLE_LINUX_UUID=true\r\u001b[38d# Uncomment to disable generation of recovery mode menu entries\r\u001b[39dGRUB_DISABLE_RECOVERY=true\r\u001b[41d# Uncomment and set to the desired menu colors.  Used by normal and wallpaper\r\u001b[42d# modes only.  Entries specified as foreground/background.\r\u001b[43d#GRUB_COLOR_NORMAL=\"light-blue/black\"\r\u001b[44d#GRUB_COLOR_HIGHLIGHT=\"light-cyan/blue\"\r\u001b[46d# Uncomment one of them for the gfx desired, a image background or a gfxtheme\r\u001b[47d#GRUB_BACKGROUND=\"/path/to/wallpaper\"\r\u001b[48d#GRUB_THEME=\"/path/to/gfxtheme\"\r\u001b[50d# Uncomment to get a beep at GRUB start\r\u001b[51d#GRUB_INIT_TUNE=\"480 440 1\"\r\u001b[53d# Uncomment to make GRUB remember the last selection. This requires\r\u001b[54d# setting 'GRUB_DEFAULT=saved' above.\r\u001b[55d#GRUB_SAVEDEFAULT=true\r\u001b[57d# Uncomment to disable submenus in boot menu\r\u001b[58d#GRUB_DISABLE_SUBMENU=y\r\u001b[60d# Probing for other operating systems is disabled for security reasons. Read\r\u001b[61d# documentation on GRUB_DISABLE_OS_PROBER, if still want to enable this\r\u001b[62d# functionality install os-prober and uncomment to detect and include other\r\u001b[63d# operating systems.\r\u001b[64d#GRUB_DISABLE_OS_PROBER=false\r\u001b[2d\u001b[?25h\u001b[?0c"]
