[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H"]
[0.000, "o", "\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d"]
[0.000, "o", "#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b"]
[0.000, "o", "# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d#\u001b[19d\b# VirtualHost example:\r\u001b[20d# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d"]
[0.000, "o", "# The first VirtualHost section is used for all requests that do not\r\u001b[22d# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d#\u001b[24d\b<VirtualHost *:80>\u001b[25;5H"]
[0.000, "o", "ServerName arteri.local\u001b[26;5HDocumentRoot \"/srv/http/arteri\"\r\u001b[27dDirectoryIndex index.php index.html\u001b[29;5H"]
[0.000, "o", "<Directory \"/srv/http/arteri\">\u001b[30;7HOptions -Indexes +FollowSymLinks\u001b[31;7HAllowOverride All\u001b[32;7HRequire all granted\u001b[33;5H</Directory>\u001b[35;5H<DirectoryMatch \"^/srv/http/arteri/(application|system|sql)\">\u001b[36;7HRequire all denied\u001b[37;5H"]
[0.000, "o", "</DirectoryMatch>\u001b[39;5H<FilesMatch \"\\.php$\">\u001b[40;7HSetHandler \"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[41;5H"]
[0.000, "o", "</FilesMatch>\u001b[43;5HErrorLog \"/var/log/httpd/arteri-error.log\"\u001b[44;5HCustomLog \"/var/log/httpd/arteri-access.log\" combined\r\u001b[45d</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
