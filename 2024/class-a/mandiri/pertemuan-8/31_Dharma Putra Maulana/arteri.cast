[1.315, "o", "\u001b[?25l\u001b[?1c\u001b[0;10;7m\u000fa\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[0.722, "o", "\u001b[?25l\u001b[?1c\u001b[0;10;7m\u000fm\u001b[m\u000f\u001b[?25h\u001b[?0c"]
