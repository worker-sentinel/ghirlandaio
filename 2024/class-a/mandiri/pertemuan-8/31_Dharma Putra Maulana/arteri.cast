[0.000, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G"]
[0.000, "o", "\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H"]
[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H"]
[0.000, "o", "\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G"]
[0.000, "o", "\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H"]
[0.000, "o", "\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H"]
[0.000, "o", "\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d/*\u001b[K\u001b[3d\b--------------------------------------------------------------------------\u001b[4;3HEncryption Key\u001b[K\r\u001b[5d|--------------------------------------------------------------------------\u001b[7;3H"]
[0.000, "o", "If you use the Encryption class, you must set an encryption key.\u001b[K\u001b[8;3HSee the user guide for more info.\u001b[9;3H"]
[0.000, "o", "\u001b[K\u001b[10d"]
[0.000, "o", "https://codeigniter.com/user_guide/libraries/encryption.html\u001b[11;3H\u001b[K\r\u001b[12d"]
[0.000, "o", "*/\u001b[K\r\u001b[13d$config['encryption_key'] = '';\r\u001b[14d"]
[0.000, "o", "\u001b[K\u001b[15d/*\r\u001b[16d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[17d| Session Variables\u001b[K\r\u001b[18d|"]
[0.000, "o", "--------------------------------------------------------------------------\r\u001b[19d|\u001b[K\u001b[20d "]
[0.000, "o", "'sess_driver'\u001b[21;3H\u001b[K\u001b[22d      The storage driver to use: files, database, redis, memcached\u001b[K\u001b[23;3H"]
[0.000, "o", "\u001b[K\u001b[24d'sess_cookie_name'\u001b[25;3H"]
[0.000, "o", "\u001b[K\u001b[26d"]
[0.000, "o", "      The session cookie name, must contain only [0-9a-z_-] characters\u001b[K\u001b[28;3H"]
[0.000, "o", "'sess_expiration'\u001b[K\u001b[30;3H"]
[0.000, "o", "      The number of SECONDS you want the session to last.\u001b[K\u001b[31;3H      Setting to 0 (zero) means expire when the browser is closed.\u001b[K\u001b[33;3H"]
[0.000, "o", "'\u001b[30m\u001b[43msess_save\u001b[39;49m\u001b[m\u000f_path'\u001b[K\r\u001b[35d"]
[0.000, "o", "| \u001b[9G"]
[0.000, "o", "The location to save sessions to, driver dependent.\r\u001b[36d|\u001b[K\u001b[37d\b|\u001b[9G"]
[0.000, "o", "For the 'files' driver, it's a path to a writable directory.\r\u001b[38d| \u001b[9G"]
[0.000, "o", "WARNING: Only absolute paths are supported!\r\u001b[39d|"]
[0.000, "o", "\u001b[K\u001b[40d "]
[0.000, "o", "      For the 'database' driver, it's a table name.\r\u001b[41d|       Please read up the manual for the format with other session drivers.\u001b[43;3H      IMPORTANT: You are REQUIRED to set a valid save path!\u001b[K\u001b[44;3H"]
[0.000, "o", "\u001b[K\u001b[45d"]
[0.000, "o", "'sess_match_ip'\u001b[46;3H"]
[0.000, "o", "\u001b[K\u001b[47d"]
[0.000, "o", "      Whether to match the user's IP address when reading the session data.\u001b[49;3H      WARNING: If you're using the database driver, don't forget to update\u001b[50;18H"]
[0.000, "o", "your session table's PRIMARY KEY when changing this setting.\u001b[51;3H\u001b[K\u001b[52d"]
[0.000, "o", "'sess_time_to_update'\u001b[K\u001b[53;3H\u001b[K\u001b[54;9H"]
[0.000, "o", "How many seconds between CI regenerating the session ID.\u001b[55;3H\u001b[K\u001b[56d"]
[0.000, "o", "'sess_regenerate_destroy'\u001b[K\u001b[57;3H\u001b[K\u001b[58;9H"]
[0.000, "o", "Whether to destroy session data associated with the old session ID\r\u001b[59d| \u001b[9G"]
[0.000, "o", "when auto-regenerating the session ID. When set to FALSE, the data\r\u001b[60d|       will be later deleted by the garbage collector.\r\u001b[61d"]
[0.000, "o", "|\u001b[K\u001b[62d\b"]
[0.000, "o", "| Other session cookie settings are shared with the rest of the application,\r\u001b[63d"]
[0.000, "o", "| except for 'cookie_prefix' and 'cookie_httponly', which are ignored here.\r\u001b[64d"]
[0.000, "o", "|\u001b[33d '"]
[1.503, "o", "\u001b[?25h\u001b[?0csess_save\u001b[19G\r| '"]
