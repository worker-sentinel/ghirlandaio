[0.000, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d#\u001b[19d\b# VirtualHost example:\r\u001b[20d"]
[0.000, "o", "# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d# The first VirtualHost section is used for all requests that do not\r\u001b[22d# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d#\u001b[24d\b<VirtualHost *:80>\u001b[25;5HServerName arteri.local\u001b[26;5HDocumentRoot \"/srv/http/arteri\"\u001b[28;5H<Directory \"/srv/http/arteri\">\u001b[29;7HOptions -Indexes +FollowSymLinks\u001b[30;7HAllowOverride All\u001b[31;7HRequire all granted\u001b[32;5H</Directory>\u001b[34;5H<DirectoryMatch \"^/srv/http/arteri/(application|system|sql)\">\u001b[35;7HRequire all denied\u001b[36;5H</DirectoryMatch>\u001b[38;5H<FilesMatch \"\\.php$\">\u001b[39;7H"]
[0.000, "o", "SetHandler \"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[40;5H</FilesMatch>\u001b[42;5HErrorLog \"/var/log/httpd/arteri-error.log\"\u001b[43;5HCustomLog \"/var/log/httpd/arteri-access.log\" combined\r\u001b[44d</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
