[0.000, "o", "\r\u001b[2d/*\u001b[K\r\u001b[3d|--------------------------------------------------------------------------\r\u001b[4d| Encryption Key\r\u001b[5d|--------------------------------------------------------------------------\r\u001b[6d|\u001b[K\u001b[7d If you use the Encryption class, you must set an encryption key.\r\u001b[8d| See the user guide for more info.\u001b[K\u001b[10;3H"]
[0.000, "o", "https://codeigniter.com/user_guide/libraries/encryption.html\u001b[K\u001b[11;3H\u001b[K\r\u001b[12d"]
[0.000, "o", "*/\r\u001b[13d"]
[0.001, "o", "$config['encryption_key'] = '';\r\u001b[14d\u001b[K\u001b[15d/*\u001b[K\u001b[16d\b"]
[0.000, "o", "--------------------------------------------------------------------------\u001b[17;3HSession Variables\u001b[K\r\u001b[18d|--------------------------------------------------------------------------\u001b[19;3H\u001b[K\u001b[20d'sess_driver'\u001b[K\u001b[21;3H\u001b[K\u001b[22;9H"]
[0.000, "o", "The storage driver to use: files, database, redis, memcached\u001b[23;3H\u001b[K\u001b[24d'sess_cookie_name'\u001b[K\r\u001b[26d| \u001b[9G"]
[0.000, "o", "The session cookie name, must contain only [0-9a-z_-] characters\r\u001b[27d|\u001b[K\u001b[28d\b"]
[0.000, "o", "| 'sess_expiration'\r\u001b[29d|\u001b[K\u001b[30d"]
[0.000, "o", "       The number of SECONDS you want the session to last.\u001b[K\u001b[31;3H      Setting to 0 (zero) means expire when the browser is closed.\r\u001b[32d|"]
[0.000, "o", "\u001b[K\u001b[33d "]
[0.000, "o", "'\u001b[30m\u001b[43msess_save\u001b[39;49m\u001b[m\u000f_path'\u001b[34;3H\u001b[K\u001b[35d"]
[0.000, "o", "      The location to save sessions to, driver dependent.\u001b[K\u001b[36;3H"]
[0.000, "o", "\u001b[K\u001b[37;9H"]
[0.000, "o", "For the 'files' driver, it's a path to a writable directory.\r\u001b[38d| \u001b[9GWARNING: Only absolute paths are supported!\r\u001b[39d"]
[0.000, "o", "|\u001b[K\u001b[40d\b|\u001b[9G"]
[0.000, "o", "For the 'database' driver, it's a table name.\r\u001b[41d"]
[0.000, "o", "| \u001b[9G"]
[0.000, "o", "Please read up the manual for the format with other session drivers.\r\u001b[42d|\u001b[K\u001b[43d "]
[0.000, "o", "      IMPORTANT: You are REQUIRED to set a valid save path!\r\u001b[44d|\u001b[K\u001b[45d "]
[0.000, "o", "'sess_match_ip'\u001b[46;3H"]
[0.000, "o", "\u001b[K\u001b[47d      Whether to match the user's IP address when reading the session da"]
[0.000, "o", "ta.\u001b[48;3H"]
[0.000, "o", "\u001b[K\u001b[49;9H"]
[0.000, "o", "WARNING: If you're using the database driver, don't forget to update\u001b[50;3H\u001b[15X\u001b[50;18H"]
[0.000, "o", "your session table's PRIMARY KEY when changing this setting.\u001b[51;3H\u001b[K\u001b[52d'"]
[0.000, "o", "sess_time_to_update'\u001b[K\u001b[54;3H"]
[0.000, "o", "      How many seconds between CI regenerating the session ID.\u001b[K\r\u001b[55d"]
[0.000, "o", "|\u001b[K\u001b[56d\b"]
[0.000, "o", "| 'sess_regenerate_destroy'\u001b[K\r\u001b[57d"]
[0.001, "o", "|\u001b[58d\b| \u001b[9G"]
[0.000, "o", "Whether to destroy session data associated with the old session ID\r\u001b[59d|       when auto-regenerating the session ID. When set to FALSE, the data\u001b[K\u001b[60;3H"]
[0.000, "o", "      will be later deleted by the garbage collector.\r\u001b[61d|"]
[0.000, "o", "\u001b[K\u001b[62d "]
[0.000, "o", "Other session cookie settings are shared with the rest of the application,\u001b[63;3Hexcept for 'cookie_prefix' and 'cookie_httponly', which are ignored here"]
[0.000, "o", ".\u001b[K\u001b[64;3H\u001b[K\u001b[33d'"]
