[0.000, "o", "\r\u001b[2d<?php\r\u001b[3ddefined('BASEPATH') OR exit('No direct script access allowed');\r\u001b[5d/*\r\u001b[6d|--------------------------------------------------------------------------\r\u001b[7d| Base Site URL\r\u001b[8d|--------------------------------------------------------------------------\r\u001b[9d"]
[0.000, "o", "|\u001b[10d\b"]
[0.000, "o", "| URL to your CodeIgniter root. Typically this will be your base URL,\r\u001b[11d| WITH a trailing slash:\r\u001b[12d"]
[0.000, "o", "|\u001b[13d\b|\u001b[9G"]
[0.000, "o", "http://example.com/\r\u001b[14d|\u001b[15d\b"]
[0.000, "o", "| WARNING: You MUST set this value!\r\u001b[16d|\u001b[17d\b| If it is not set, then CodeIgniter will try guess the protocol and path\r\u001b[18d"]
[0.000, "o", "| your installation, but due to security concerns the hostname will be set\r\u001b[19d"]
[0.000, "o", "| to $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\r\u001b[20d| The auto-detection mechanism exists only for convenience during\r\u001b[21d"]
[0.000, "o", "| development and MUST NOT be used in production!\r\u001b[22d"]
[0.000, "o", "|\u001b[23d\b"]
[0.000, "o", "| If you need to allow multiple domains, remember that this file is still\r\u001b[24d"]
[0.000, "o", "| a PHP script and you can easily do that on your own.\r\u001b[25d"]
[0.000, "o", "|\u001b[26d\b"]
[0.000, "o", "*/\r\u001b[27d"]
[0.000, "o", "$config['base_url'] = (isset($_SERVER['HTTPS']) ? \"https://\" : \"http://\") . $_SERVER['HTTP_HOST'] . ROOT;\r\u001b[29d/*\r\u001b[30d"]
[0.001, "o", "|--------------------------------------------------------------------------\r\u001b[31d| Index File\r\u001b[32d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[33d"]
[0.000, "o", "|\u001b[34d\b"]
[0.000, "o", "| Typically this will be your index.php file, unless you've renamed it to\r\u001b[35d| something else. If you are using mod_rewrite to remove the page set this\r\u001b[36d| variable so that it is blank.\r\u001b[37d|\u001b[38d\b*/\r\u001b[39d$config['index_page'] = 'index.php';\r\u001b[41d/*\r\u001b[42d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[43d"]
[0.000, "o", "| URI PROTOCOL\r\u001b[44d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[45d|\u001b[46d\b"]
[0.000, "o", "| This item determines which server global should be used to retrieve the\r\u001b[47d"]
[0.000, "o", "| URI string.  The default setting of 'REQUEST_URI' works for most servers.\r\u001b[48d"]
[0.000, "o", "| If your links do not seem to work, try one of the other delicious flavors:\r\u001b[49d|\u001b[50d\b"]
[0.000, "o", "| 'REQUEST_URI'    Uses $_SERVER['REQUEST_URI']\r\u001b[51d"]
[0.000, "o", "| 'QUERY_STRING'   Uses $_SERVER['QUERY_STRING']\r\u001b[52d| 'PATH_INFO'\u001b[20G"]
[0.000, "o", "Uses $_SERVER['PATH_INFO']\r\u001b[53d"]
[0.000, "o", "|\u001b[54d\b"]
[0.000, "o", "| WARNING: If you set this to 'PATH_INFO', URIs will always be URL-decoded!\r\u001b[55d*/\r\u001b[56d"]
[0.000, "o", "$config['uri_protocol'] = 'REQUEST_URI';\r\u001b[58d/*\r\u001b[59d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[60d"]
[0.000, "o", "| URL suffix\r\u001b[61d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[62d"]
[0.000, "o", "|\u001b[63d\b"]
[0.000, "o", "| This option allows you to add a suffix to all URLs generated by CodeIgniter.\r\u001b[64d"]
[0.000, "o", "| For more information please see the user guide:\r\u001b[2d\u001b[?25h\u001b[?0c"]
