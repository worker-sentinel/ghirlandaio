[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[2;3Hhttpd as root initially and it will switch.\u001b[3;3H\u001b[K\u001b[4dUser/Group: The name (or #number) of the user/group to run httpd as.\u001b[5;3HIt is usually good practice to create a dedicated user and group for\u001b[K\u001b[6;3Hrunning httpd, as with most system services.\u001b[7;3H\u001b[K\r\u001b[8dUser http\u001b[K\r\u001b[9dGroup http\r\u001b[10d\u001b[K\u001b[11d</IfModule>\u001b[K\r\u001b[12d\u001b[K\u001b[13d# 'Main' server configuration\u001b[14;3H\u001b[K\u001b[15dThe directives in this section set up the values used by the 'main'\u001b[K\u001b[16;9H, which responds to any requests that aren't handled by a\u001b[K\u001b[17;3H<VirtualHost> definition.  These values also provide defaults for\u001b[K\u001b[18;3H"]
[0.000, "o", "any <VirtualHost> containers you may define later in the file.\u001b[K\u001b[19;3H\u001b[K\u001b[20dAll of these directives may appear inside <VirtualHost> containers,\r\u001b[21d# in which case these default settings will be overridden for the\u001b[22;3H"]
[0.000, "o", "virtual host being defined.\u001b[23;3H\u001b[K\r\u001b[24d"]
[0.000, "o", "\u001b[K\u001b[26d# ServerAdmin: Your address, where problems with the server should be\u001b[27;3He-mailed.  This address appears on some server-generated pages, such\u001b[K\u001b[28;3H"]
[0.000, "o", "as error documents.  e.g. admin@your-domain.com\u001b[K\u001b[29;3H\u001b[K\r\u001b[30dServerAdmin you@example.com\r\u001b[31d"]
[0.000, "o", "\u001b[K\u001b[32d#\u001b[K\u001b[33d\b# \u001b[30m\u001b[43mServerName\u001b[39;49m\u001b[m\u000f gives the name and port that the server uses to identify itself.\u001b[34;3HThis can often be determined automatically, but we recommend you specify\u001b[35;3Hit explicitly to prevent problems during startup.\u001b[K\u001b[36;3H\u001b[K\u001b[37d"]
[0.000, "o", "If your host doesn't have a registered DNS name, enter its IP address here.\u001b[38;3H\u001b[K\u001b[39d\b"]
[0.000, "o", "ServerName www.example.com:80\u001b[K\r\u001b[40d\u001b[K\u001b[42d# Deny access to the entirety of your server's filesystem. You must\r\u001b[43d"]
[0.000, "o", "# explicitly permit access to web content directories in other\u001b[44;3H<Directory> blocks below.\u001b[45;3H\u001b[K\r\u001b[46d<Directory />\u001b[K\r\u001b[47d    AllowOverride none\r\u001b[48d    Require all denied\r\u001b[49d</Directory>\u001b[K\r\u001b[50d\u001b[K\u001b[52d#"]
[0.001, "o", " Note that from this point forward you must specifically allow\r\u001b[53d# particular features to be enabled - so if something's not working as\r\u001b[54d# you might expect, make sure that you have specifically enabled it\u001b[55;3Hbelow.\u001b[56;3H\u001b[K\r\u001b[57d\u001b[K\u001b[58d# \u001b[K\u001b[59d"]
[0.000, "o", "DocumentRoot: The directory out of which you will serve your\u001b[K\u001b[60;4Hocuments. By default, all requests are taken from this directory, but\u001b[K\u001b[61;3H"]
[0.000, "o", "symbolic links and aliases may be used to point to other locations.\u001b[K\u001b[62;3H\u001b[K\r\u001b[63dDocumentRoot \"/srv/http\"\r\u001b[64d<Directory \"/srv/http\">\u001b[33;3H"]
[1.502, "o", "\u001b[?25h\u001b[?0cServerName\u001b[33;78H\r# "]
