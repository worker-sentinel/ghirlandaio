[0.000, "o", "\n\u001b[1;67r\u001b[64;5H# (You will also need to add \"Includes\" to the \"Options\" directive.)\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;5H#\r"]
