[0.001, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d"]
[0.000, "o", "# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d"]
[0.000, "o", "#\u001b[19d\b# VirtualHost example:\r\u001b[20d# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d"]
[0.000, "o", "# The first VirtualHost section is used for all requests that do not\r\u001b[22d# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d#\u001b[24d\b"]
[0.000, "o", "<VirtualHost *:80>\u001b[25;5HServerAdmin webmaster@dummy-host.example.com\u001b[26;5HDocumentRoot \"/etc/httpd/docs/dummy-host.example.com\"\u001b[27;5H"]
[0.000, "o", "ServerName dummy-host.example.com\u001b[28;5HServerAlias www.dummy-host.example.com\u001b[29;5HErrorLog \"/var/log/httpd/dummy-host.example.com-error_log\"\u001b[30;5HCustomLog \"/var/log/httpd/dummy-host.example.com-access_log\" common\r\u001b[31d</VirtualHost>\r\u001b[33d<VirtualHost *:80>\u001b[34;5H"]
[0.000, "o", "ServerAdmin webmaster@dummy-host2.example.com\u001b[35;5HDocumentRoot \"/etc/httpd/docs/dummy-host2.example.com\"\u001b[36;5HServerName dummy-host2.example.com\u001b[37;5H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/dummy-host2.example.com-error_log\"\u001b[38;5HCustomLog \"/var/log/httpd/dummy-host2.example.com-access_log\" common\r\u001b[39d</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
