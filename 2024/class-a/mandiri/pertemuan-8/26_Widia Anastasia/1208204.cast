[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H# ErrorLog: The location of the error log file.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
