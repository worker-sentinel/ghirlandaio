[0.001, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d"]
[0.000, "o", "#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d"]
[0.000, "o", "# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d"]
[0.000, "o", "# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d"]
[0.000, "o", "# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b"]
[0.000, "o", "# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d#\u001b[19d\b"]
[0.000, "o", "# VirtualHost example:\r\u001b[20d# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d# The first VirtualHost section is used for all requests that do not\r\u001b[22d# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d#\u001b[24d\b"]
[0.000, "o", "<VirtualHost *:80>\u001b[25;5HServerName arteri.local\u001b[26;5HDocumentRoot \"/srv/http/arteri\"\u001b[27;5HDirectoryIndex index.php index.html\u001b[29;5H<Directory \"/srv/http/arteri\">\u001b[30;7HOptions -Indexes +FollowSymLinks\u001b[31;7H"]
[0.000, "o", "AllowOverride All\u001b[32;7HRequire all granted\u001b[33;5H</Directory>\u001b[35;5H"]
[0.000, "o", "<DirectoryMatch \"^/srv/http/arteri/(application|system|sql)\">\u001b[36;7HRequire all denied\u001b[37;5H"]
[0.000, "o", "<DirectoryMatch>\u001b[39;5H<FilesMatch \"\\.php$\">\u001b[40;7HSetHandler \"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[41;5H</FilesMatch>\u001b[43;5H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/arteri-error.log\"\u001b[44;5HCustomLog \"/var/log/httpd/arteri-access.log\"\r\u001b[45d</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
