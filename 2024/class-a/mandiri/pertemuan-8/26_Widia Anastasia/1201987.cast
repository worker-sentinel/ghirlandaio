[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; If you use constants in your value, and these constants belong to a\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; dynamically loaded extension (either a PHP extension or a Zend extension),\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; you may only use these constants *after* the line that loads the extension.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;;;;;;;;;;;;;;;;;;;\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; About this file ;\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H;;;;;;;;;;;;;;;;;;;\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; PHP comes packaged with two INI files. One that is recommended to be used\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; in production environments and one that is recommended to be used in\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; development environments.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; php.ini-production contains settings which hold security, performance and\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; best practices at its core. But please be aware, these settings may break\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; compatibility with older or less security-conscious applications. We\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; recommending using the production ini in production and testing environments.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; php.ini-development is very similar to its production variant, except it is\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; much more verbose when it comes to errors. We recommend using the\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; development version only in development environments, as errors shown to\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; application users can inadvertently leak otherwise secure information.\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; This is the php.ini-production INI file.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;;;;;;;;;;;;;;;;;;;\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; Quick Reference ;\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;;;;;;;;;;;;;;;;;;;\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; The following are all the settings which are different in either the production\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; or development versions of the INIs with respect to PHP's default behavior.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Please see the actual settings later in the document for more details as to why\r"]
[0.040, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; we recommend these changes in PHP's behavior.\r"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; display_errors\r"]
