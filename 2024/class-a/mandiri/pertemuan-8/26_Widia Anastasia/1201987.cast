[0.000, "o", "\n\u001b[1;67r\u001b[64;1Hextension_dir = \"/usr/lib/php/modules/\"\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
