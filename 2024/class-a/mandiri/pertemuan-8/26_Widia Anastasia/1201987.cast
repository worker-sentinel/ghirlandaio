[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; cgi.rfc2616_headers configuration option tells PHP what type of headers to\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
