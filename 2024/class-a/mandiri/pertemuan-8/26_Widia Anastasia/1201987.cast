[0.000, "o", "\n\u001b[1;67r\u001b[64;1H|\u001b[64;33HHowever, this may cause high memory usage, especially if you run\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
