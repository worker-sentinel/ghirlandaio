[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; To disable this feature set this option to an empty value\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001b[65d"]
