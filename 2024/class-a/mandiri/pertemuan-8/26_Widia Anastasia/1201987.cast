[0.000, "o", "\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d# 1) plain text 2) local redirects 3) external redirects\r\u001b[3d#\u001b[K\u001b[4d\b# Some examples:\u001b[K\r\u001b[5d#ErrorDocument 500 \"The server made a boo boo.\"\r\u001b[6d#ErrorDocument 404 /missing.html\u001b[K\r\u001b[7d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\r\u001b[8d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[9d#\u001b[K\u001b[10d\b\u001b[K\u001b[11d#\u001b[K\u001b[12d\b# MaxRanges: Maximum number of Ranges in a request before\r\u001b[13d# returning the entire resource, or one of the special\r\u001b[14d# values 'default', 'none' or 'unlimited'.\u001b[K\r\u001b[15d# Default setting is to accept 200 Ranges.\u001b[K\r\u001b[16d#MaxRanges unlimited\r\u001b[17d\u001b[K\u001b[18d#\u001b[K\u001b[19d\b# EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[20d# memory-mapping or the sendfile syscall may be used to deliver\r\u001b[21d"]
[0.000, "o", "# files.  This usually improves server performance, but must\u001b[K\r\u001b[22d# be turned off when serving from networked-mounted\u001b[K\r\u001b[23d"]
[0.000, "o", "# filesystems or if support for these functions is otherwise\r\u001b[24d# broken on your system.\r\u001b[25d# Defaults: EnableMMAP On, EnableSendfile Off\u001b[K\r\u001b[26d#\u001b[K\u001b[27d\b#EnableMMAP off\r\u001b[28d#EnableSendfile on\u001b[K\r\u001b[30d"]
[0.000, "o", "# Supplemental configuration\u001b[K\r\u001b[31d#\u001b[K\u001b[32d\b# The configuration files in the conf/extra/ directory can be\r\u001b[33d"]
[0.000, "o", "# \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000fd to add extra features or to modify the default configuration of\r\u001b[34d# the server, or you may simply copy their contents here and change as\u001b[K\r\u001b[35d# necessary.\r\u001b[36d\u001b[K\u001b[37d# Server-pool management (MPM specific"]
[0.000, "o", ")\u001b[K\r\u001b[38dInclude conf/extra/httpd-mpm.conf\r\u001b[39d\u001b[K\u001b[40d# Multi-language error messages\u001b[K\r\u001b[41dInclude conf/extra/httpd-multilang-errordoc.conf\u001b[43;3HFancy directory listings\r\u001b[44d"]
[0.000, "o", "Include conf/extra/httpd-autoindex.conf\u001b[K\r\u001b[45d\u001b[K\u001b[46d# Language settings\u001b[K\r\u001b[47dInclude conf/extra/httpd-languages.conf\r\u001b[48d\u001b[K\u001b[49d"]
