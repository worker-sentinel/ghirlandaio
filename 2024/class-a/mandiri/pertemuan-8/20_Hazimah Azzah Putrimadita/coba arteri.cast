[0.001, "o", "\r\u001b[2d# If your host doesn't have a registered DNS name, enter its IP address here.\r\u001b[3d#\u001b[K\u001b[4dServerName www.example.com:80\u001b[K\r\u001b[5d\u001b[K\u001b[6d#\u001b[K\u001b[7d Deny access to the entirety of your server's filesystem. You must\u001b[K\r\u001b[8d# explicitly permit access to web content directories in other\r\u001b[9d# <Directory> blocks below.\u001b[K\r\u001b[10d#\u001b[K\u001b[11d\b<Directory />\u001b[K\r\u001b[12d    AllowOverride none\u001b[K\r\u001b[13d"]
[0.000, "o", "    Require all denied\u001b[K\r\u001b[14d</Directory>\u001b[K\r\u001b[15d\u001b[K\u001b[16d#"]
[0.000, "o", "\u001b[K\u001b[17d\b# Note that from this point forward you must specifically allow\r\u001b[18d"]
[0.000, "o", "# particular features to be enabled - so if something's not working as\r\u001b[19d# you might expect, make sure that you have specifically enabled it\r\u001b[20d# below.\u001b[K\r\u001b[21d#\u001b[K\u001b[22d\b"]
[0.001, "o", "\u001b[K\u001b[23d#\u001b[K\u001b[24d DocumentRoot: The directory out of which you will serve your\r\u001b[25d# documents. By default, all requests are taken from this directory, but\r\u001b[26d# symbolic links and aliases may be used to point to other locations.\r\u001b[27d#\u001b[K\u001b[28d\b"]
[0.000, "o", "DocumentRoot \"/srv/http\"\u001b[K\r\u001b[29d<Directory \"/srv/http\">\u001b[K\r\u001b[30d    #\u001b[K\r\u001b[31d"]
[0.000, "o", "    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[32d    # or any combination of:\u001b[K\r\u001b[33d"]
[0.000, "o", "    #   Indexes \u001b[30m\u001b[43mInclude\u001b[39;49m\u001b[m\u000fs FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[34;5H#\r\u001b[35d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[36d    # doesn't give it to you.\r\u001b[37d    #\u001b[K\r\u001b[38d    # The Options directive is both complicated and important.  Please see\r\u001b[39d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[40d    # for more information.\u001b[K\r\u001b[41d    #\u001b[K\r\u001b[42d    Options Indexes FollowSymLinks\u001b[K\r\u001b[43d\u001b[K\u001b[44d    #\u001b[K\r\u001b[45d    # AllowOverride controls what directives may be placed in .htaccess files.\u001b[46;5H# It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[47d    #   AllowOverride FileInfo AuthConfig Limit\u001b[48;5H"]
[0.000, "o", "#\r\u001b[49d    AllowOverride None\u001b[K\r\u001b[50d\u001b[K\u001b[51d    #\u001b[K\r\u001b[52d    # Controls who can get stuff from this server.\u001b[K\r\u001b[53d    #\u001b[K\r\u001b[54d"]
[0.000, "o", "    Require all granted\u001b[K\r\u001b[55d</Directory>\r\u001b[56d"]
[0.000, "o", "\u001b[K\u001b[57d# \u001b[K\u001b[58d"]
[0.000, "o", "DirectoryIndex: sets the file that Apache will serve if a directory\u001b[59;3His requested.\r\u001b[60d#\u001b[61d\b<IfModule dir_module>\r\u001b[62d    DirectoryIndex index.html\u001b[K\r\u001b[63d</IfModule>\u001b[K\r\u001b[64d\u001b[K\u001b[33;17H"]
[1.503, "o", "\u001b[?25h\u001b[?0cInclude\u001b[33;80H\u001b[33;17H"]
[2.223, "o", "\u001b[?25l\u001b[?1c\u001b[66;18H\u001b[31X\u001b[66;49H\u001b[0;10;7m\u000fM-C\u001b[m\u000f Case Sens\u001b[69G          \u001b[86G           \u001b[0;10;7m\u000fM-B\u001b[m\u000f Backwards \u001b[66;120H\u001b[25X\u001b[66;145H\u001b[0;10;7m\u000f^P\u001b[m\u000f Older\u001b[24X\u001b[66;188H     \u001b[0;10;7m\u000f^T\u001b[m\u000f Go To Line\u001b[K\u001b[67;2H\u001b[0;10;7m\u000fC\u001b[m\u000f Cancel\u001b[67;18H\u001b[31X\u001b[67;49H\u001b[0;10;7m\u000fM-R\u001b[m\u000f Reg.exp.\u001b[67;69H          \u001b[86G           \u001b[0;10;7m\u000f^R\u001b[m\u000f Replace    \u001b[67;120H        \u001b[67;137H        \u001b[0;10;7m\u000f^N\u001b[m\u000f Newer\u001b[K\u001b[66;206H"]
[0.000, "o", "\r\u001b[A\u001b[0;10;7m\u000fSearch [include]:                                                                                                                                                                                                                               \u001b[65;19H\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[0.456, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[12;29r\u001b[12;1H\u001b[6L\u001b[1;67r\u001b[2;1H    #\u001b[K\r\u001b[3d    Require all granted\r\u001b[4d</Directory>\u001b[K\u001b[7;4HirectoryIndex: sets the file that Apache will serve if a directory\u001b[8;3His requested.\u001b[K\u001b[9;3H\u001b[K\r\u001b[10d<IfModule dir_module>\r\u001b[11d    DirectoryIndex index.html\r\u001b[12d</IfModule>\r\u001b[14d#\u001b[15d\b# The following lines prevent .htaccess and .htpasswd files from being\r\u001b[16d# viewed by Web clients.\r\u001b[17d#\u001b[18d\b<Files \".ht*\">\u001b[K\u001b[20;3HFiles>\u001b[K\u001b[23;3HErrorLog: The location of the error log file.\u001b[K\u001b[24;3HIf you do not specify an ErrorLog directive within a <VirtualHost>\u001b[K\u001b[25;3Hcontainer, error messages relating to that virtual host will be\u001b[K\u001b[26;3H"]
[0.000, "o", "logged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[27;3Hcontainer, that host's errors will be logged there and not here.\r\u001b[28d#\u001b[29d\bErrorLog \"/var/log/httpd/error_log\"\r\u001b[30d\u001b[K\u001b[31d#\u001b[K\u001b[32d\b# LogLevel: Control the number of messages logged to the error_log.\r\u001b[33d# Possible values \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000f: debug, info, notice, warn, error, crit,\u001b[K\r\u001b[34d"]
[0.000, "o", "# alert, emerg.\r\u001b[35d#\u001b[K\u001b[36d\bLogLevel warn\u001b[K\r\u001b[37d\u001b[K\u001b[38d"]
[0.000, "o", "<IfModule log_config_module>\u001b[K\u001b[39;7H\u001b[K\u001b[40dThe following directives define some format nicknames for use with\u001b[41;7H"]
[0.001, "o", "a CustomLog directive (see below).\u001b[42;5H#\u001b[K\u001b[43d\bLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\" combined\u001b[44;5HLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b\" common\r\u001b[45d"]
[0.000, "o", "\u001b[K\u001b[46;5H<IfModule logio_module>\u001b[K\u001b[47;5H  # You need to enable mod_logio.c to use %I and %O\u001b[48;5H"]
[0.000, "o", "  LogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\" combinedio\u001b[49;5H</IfModule>\u001b[K\u001b[52;7HThe location and format of the access logfile (Common Logfile Format).\u001b[53;7H"]
[0.000, "o", "If you do not define any access logfiles within a <VirtualHost>\u001b[54;5H# container, they will be logged here.  Contrariwise, if you *do*\r\u001b[55d    # define per-<VirtualHost> access logfiles, transactions will be\u001b[56;5H# logged therein and *not* in this file.\r\u001b[57d    #\r\u001b[58d    CustomLog \"/var/log/httpd/access_log\" common\u001b[K\r\u001b[59d\u001b[K\u001b[60d    #\r\u001b[61d    # If you prefer a logfile with access, agent, and referer information\u001b[62;5H# (Combined Logfile Format) you can use the following directive.\r\u001b[63d"]
[0.000, "o", "    #\u001b[K\u001b[64d\b#CustomLog \"/var/log/httpd/access_log\" combined\u001b[33;19H"]
[1.503, "o", "\u001b[?25h\u001b[?0cinclude\u001b[33;67H\u001b[33;19H"]
