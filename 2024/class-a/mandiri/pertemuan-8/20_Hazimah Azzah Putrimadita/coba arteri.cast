[0.001, "o", "\r\u001b[2d\u001b[K\u001b[3d;;;;;;;;;;;;;;;;\u001b[K\u001b[4;3HFile Uploads ;\u001b[K\r\u001b[5d;;;;;;;;;;;;;;;;\u001b[K\r\u001b[6d\u001b[K\u001b[7d; Whether to allow HTTP file uploads.\u001b[8;3Hhttps://php.net/file-uploads\u001b[K\r\u001b[9dfile_uploads = On\u001b[K\r\u001b[10d\u001b[K\u001b[11d; Temporary directory for HTTP uploaded files (will use system default if not\u001b[K\u001b[12;3Hspecified).\u001b[K\u001b[13;3Hhttps://php.net/upload-tmp-dir\r\u001b[14d;upload_tmp_dir =\u001b[K\r\u001b[15d\u001b[K\u001b[16d; Maximum allowed size for uploaded files.\u001b[K\r\u001b[17d; https://php.net/upload-max-filesize\r\u001b[18dupload_max_filesize = 64M\u001b[K\r\u001b[19d\u001b[K\u001b[20d; Maximum number of files that can be uploaded via a single request\u001b[K\r\u001b[21dmax_file_uploads = 20\u001b[K\r\u001b[22d\u001b[K\u001b[23d;;;;;;;;;;;;;;;;;;\u001b[K\u001b[24;3H"]
