[0.000, "o", "Whether to allow include/require to open URLs (like https:// or ftp://) as files.\u001b[56;3Hhttps://php.net/allow-url-include\u001b[K\r\u001b[57dallow_url_include = Off\u001b[K\r\u001b[58d\u001b[K\u001b[59d; Define the anonymous ftp password (your email address). PHP's default setting\u001b[60;3Hfor this is empty.\u001b[61;3Hhttps://php.net/from\u001b[K\r\u001b[62d;from=\"john@doe.com\"\u001b[K\r\u001b[63d\u001b[K\u001b[64d; Define the User-Agent string. PHP's default setting for this is empty.\u001b[K\r\u001b[33d"]
