[0.000, "o", "\u001b[K\u001b[25d; The default character set code-page to use when passing strings to and from COM objects.\r\u001b[26d; Default: system ANSI code page\r\u001b[27d;com.code_page=\r\u001b[28d"]
[0.000, "o", "\u001b[K\u001b[29d; The version of the .NET framework to use. The value of the setting are the first three parts\r\u001b[30d"]
