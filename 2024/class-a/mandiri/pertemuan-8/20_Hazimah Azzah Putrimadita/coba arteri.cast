[0.000, "o", "Whether to allow HTTP file uploads.\u001b[K\u001b[32;3Hhttps://php.net/file-uploads\u001b[K\r\u001b[33d\u001b[30m\u001b[43mfile_uploads\u001b[39;49m\u001b[m\u000f = On\r\u001b[34d\u001b[K\u001b[35d; Temporary directory for HTTP uploaded files (will use system default if not\u001b[36;3Hspecified).\u001b[K\u001b[37;3Hhttps://php.net/upload-tmp-dir\u001b[K\r\u001b[38d;upload_tmp_dir =\u001b[K\r\u001b[39d\u001b[K\u001b[40d; Maximum allowed size for uploaded files.\u001b[K\u001b[41;3Hhttps://php.net/upload-max-filesize\u001b[K\r\u001b[42dupload_max_filesize = 2M\u001b[K\r\u001b[43d\u001b[K\u001b[44d; Maximum number of files that can be uploaded via a single request\r\u001b[45dmax_file_uploads = 20\u001b[K\r\u001b[46d\u001b[K\u001b[47d;;;;;;;;;;;;;;;;;;\u001b[K\u001b[48;3HFopen wrappers ;\u001b[K\r\u001b[49d;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[50d\u001b[K\u001b[51d; Whether to allow the treatment of URLs (like http:// or ftp://) as files.\u001b[52;3H"]
