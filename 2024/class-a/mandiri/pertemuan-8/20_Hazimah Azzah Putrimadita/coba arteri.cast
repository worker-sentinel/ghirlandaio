[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d\u001b[K\u001b[3d;opcache.dups_fix=0\u001b[K\r\u001b[4d\u001b[K\u001b[5d; The location of the OPcache blacklist file (wildcards allowed).\r\u001b[6d; Each OPcache blacklist file is a text file that holds the names of files\u001b[7;3Hthat should not be accelerated. The file format is to add each filename\u001b[8;3Hto a new line. The filename may be a full path or just a file prefix\u001b[9;3H(i.e., /var/www/x  blacklists all the files and directories in /var/www\u001b[10;3Hthat start with 'x'). Line starting with a ; are ignored (comments).\r\u001b[11d;opcache.blacklist_filename=\u001b[K\r\u001b[12d\u001b[K\u001b[13d; Allows exclusion of large files from being cached. By default all files\u001b[14;3Hare cached.\u001b[K\r\u001b[15d;opcache.max_file_size=0\u001b[K\r\u001b[16d\u001b[K\u001b[17d; How long to wait (in seconds) for a scheduled restart to begin if the cache\u001b[18;3His not being accessed.\u001b[K\r\u001b[19d;opcache.force_restart_timeout=180\r\u001b[20d\u001b[K\u001b[21d; OPcache error_log file name. Empty string assumes \"stderr\".\r\u001b[22d;opcache.error_log=\u001b[K\r\u001b[23d\u001b[K\u001b[24d; All OPcache errors go to the Web server log"]
[0.000, "o", ".\u001b[K\r\u001b[25d; By default, only fatal errors (level 0) or errors (level 1) are logged.\r\u001b[26d"]
[0.000, "o", "; You can also enable warnings (level 2), info messages (level 3) or\u001b[27;3Hdebug messages (level 4).\u001b[K\r\u001b[28d;"]
[0.001, "o", "opcache.log_verbosity_level=1\u001b[K\r\u001b[29d\u001b[K\u001b[30d; Preferred Shared Memory back-end. Leave empty and let the system decide.\r\u001b[31d;opcache.preferred_memory_model=\r\u001b[32d\u001b[K\u001b[33d; Protect the shared memory from unexpected writing during script \u001b[30m\u001b[43mexecution\u001b[39;49m\u001b[m\u000f.\u001b[34;3HUseful for internal debugging only.\u001b[K\u001b[35;3Hpcache.protect_memory=0\u001b[K\u001b[37;3HAllows calling OPcache API functions only from PHP scripts which path is\u001b[38;3Hstarted from specified string. The default \"\" means no restriction\u001b[K\r\u001b[39d;opcache.restrict_api=\u001b[K\r\u001b[40d"]
[0.000, "o", "\u001b[K\u001b[41d; Mapping base of shared memory segments (for Windows only). All the PHP\u001b[42;3H"]
[0.000, "o", "processes have to map shared memory into the same address space. This\r\u001b[43d; directive allows to manually fix the \"Unable to reattach to base address\"\u001b[44;3H"]
[0.000, "o", "errors.\u001b[K\r\u001b[45d;opcache.mmap_base=\u001b[K\r\u001b[46d\u001b[K\u001b[47d; Facilitates multiple OPcache instances per user (for Windows only). All PHP\r\u001b[48d; processes with the same cache ID and user share an OPcache instance.\r\u001b[49d;opcache.cache_id=\r\u001b[50d\u001b[K\u001b[51d; Enables and sets the second level cache directory.\r\u001b[52d; It should improve performance when SHM memory is full, at server restart or\r\u001b[53d"]
[0.000, "o", "; SHM reset. The default \"\" disables file based caching.\r\u001b[54d;opcache.file_cache=\u001b[K\r\u001b[55d"]
[0.000, "o", "\u001b[K\u001b[56d; Enables or disables opcode caching in shared memory.\r\u001b[57d"]
[0.000, "o", ";opcache.file_cache_only=0\u001b[K\u001b[59;3HEnables or disables checksum validation when script lo"]
[0.000, "o", "aded from file cache.\r\u001b[60d;opcache.file_cache_consistency_checks=1\r\u001b[61d\u001b[K\u001b[62d; Implies opcache.file_cache_only=1 for a certain process that failed to\u001b[63;3H"]
[0.000, "o", "reattach to the shared memory (for Windows only). Explicitly enabled file\u001b[64;3Hcache is required.\u001b[K\u001b[33;67H"]
