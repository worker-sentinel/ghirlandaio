[0.000, "o", "# The configuration files in the \u001b[30m\u001b[43mconf/extra\u001b[39;49m\u001b[m\u000f/ directory can be\u001b[K\r\u001b[34d# included to add extra features or to modify the default configuration of\r\u001b[35d"]
[0.000, "o", "# the server, or you may simply copy their contents here and change as\r\u001b[36d# necessary.\u001b[K\r\u001b[38d# Server-pool management (MPM specific)\r\u001b[39dInclude conf/extra/httpd-mpm.conf\u001b[K\r\u001b[40d\u001b[K\u001b[41d# Multi-language error messages\u001b[K\r\u001b[42dInclude conf/extra/httpd-multilang-errordoc.conf\u001b[K\r\u001b[43d\u001b[K\u001b[44d# Fancy directory listings\u001b[K\r\u001b[45dInclude conf/extra/httpd-autoindex.conf\r\u001b[46d\u001b[K\u001b[47d# Language settings\r\u001b[48dInclude conf/extra/httpd-languages.conf\r\u001b[50d"]
