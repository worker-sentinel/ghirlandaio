[0.000, "o", "\u001b[1;3H\u001b[0;10;7m\u000f            \u001b[1;109HSearch Command Help Text \u001b[1;231H        \u001b[m\u000f"]
[0.001, "o", "\r\u001b[2d\u001b[K\u001b[3d Enter the words or characters you would like to search for, and then\r\u001b[4d press Enter.  If there is a match for the text you entered, the screen\r\u001b[5d will be updated to the location of the nearest match for the search\r\u001b[6d string.\u001b[K\r\u001b[8d The previous search string will be shown in brackets after the search\u001b[K\r\u001b[9d prompt.  Hitting Enter without entering any text will perform the\r\u001b[10d previous search.  If you have selected text with the mark and then search\r\u001b[11d to replace, only matches in the selected text will be replaced.\r\u001b[12d\u001b[K\u001b[13d The following function keys are available in Search mode:\u001b[K\r\u001b[14d\u001b[K\u001b[15d^G     (F1)      Display this help text\r\u001b[16d^C\u001b[15X\u001b[16;18HCancel the current function\r\u001b[17d\u001b[K\u001b[18dM-C\u001b[14X\u001b[18;18HToggle the case sensitivity of the search\r\u001b[19dM-R\u001b[19;18HToggle the use of regular expressions\r\u001b[20dM-B\u001b[14X\u001b[20;18H"]
[0.000, "o", "Reverse the direction of the search\u001b[K\r\u001b[21d\u001b[K\u001b[22d^R\u001b[15X\u001b[22;18H"]
