[0.000, "o", ";oci8.statement_cache_size = 20\r\u001b[31d\u001b[K\u001b[32d; "]
[0.000, "o", "Tuning: Enables row prefetching and sets the default number of\u001b[K\u001b[33;3Hrows that will be fetched automatically after statement \u001b[30m\u001b[43mexecution\u001b[39;49m\u001b[m\u000f.\u001b[K\u001b[34;3Hhttps://php.net/oci8.default-prefetch\u001b[K\r\u001b[35d;oci8.default_prefetch = 100\u001b[K\r\u001b[36d\u001b[K\u001b[37d; Tuning: Sets the amount of LOB data that is internally returned from\u001b[38;3HOracle Database when an Oracle LOB locator is initially retrieved a"]
[0.000, "o", "s\u001b[K\u001b[39;4Hart of a query. Setting this can improve performance by reducing\u001b[K\u001b[40;3Hround-trips.\u001b[K\u001b[41;3Hhttps://php.net/oci8.prefetch-lob-size\u001b[K\u001b[42;4Hci8.prefetch_lob_size = 0\u001b[K\r\u001b[43d\u001b[K\u001b[44d; "]
