[0.000, "o", ";;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[41;3HError handling and logging ;\u001b[K\r\u001b[42d;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[43d"]
[0.000, "o", "\u001b[K\u001b[44d; This directive informs PHP of which errors, warnings and notices you would like\u001b[45;3Hit to take action for. The recommended way of setting values for this\u001b[46;3Hdirective is through the use of the error level constants and bitwise\r\u001b[47d; operators. The error level constants are below here for convenience as well as\r\u001b[48d; some common settings and their meanings.\u001b[49;3HBy default, PHP is set to take action on all errors, notices and warnings EXCEPT\u001b[50;3Hthose related to E_NOTICE and E_STRICT, which together cover best practices and\u001b[51;3Hrecommended coding standards in PHP. For performance reasons, this is the\u001b[52;3Hrecommend error reporting setting. Your production server shouldn't be wasting\u001b[53;3Hresources complaining about best practices and coding standards. That's what\u001b[54;3Hdevelopment servers and development settings are for.\u001b[K\u001b[55;3HNote: The php.ini-development file has this setting as E_ALL. This\u001b[56;3Hmeans it pretty much reports everything which is exactly what you want during\u001b[57;3H"]
[0.000, "o", "development and early testing.\u001b[K\u001b[58;3H\u001b[K\r\u001b[59d; Error Level Constants:\u001b[K\r\u001b[60d; E_ALL\u001b[60;21H- All errors and warnings\u001b[61;3HE_ERROR           - fatal run-time errors\u001b[K\u001b[62;3HE_RECOVERABLE_ERROR  - almost fatal run-time errors\u001b[K\u001b[63;3H"]
[0.000, "o", "E_WARNING         - run-time warnings (non-fatal errors)\u001b[64;3HE_PARSE           - compile-time parse errors\u001b[K\u001b[33;52H"]
