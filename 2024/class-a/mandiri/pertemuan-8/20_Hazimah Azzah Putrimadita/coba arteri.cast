[0.108, "o", "2026-06-08  4:46:35 0 [Warning] mariadbd: io_uring_queue_init() failed with EPERM: sysctl kernel.io_uring_disabled has the value 2, or 1 and the user of the process is not a member of sysctl kernel.io_uring_group. (see man 2 io_uring_setup).\r\ncreate_uring failed: falling back to libaio\r\n2026-06-08  4:46:35 0 [Warning] InnoDB: native AIO failed: falling back to innodb_use_native_aio=OFF\r\n"]
[3.581, "o", "\r\n\r\nTwo all-privilege accounts were created.\r\nOne is root@localhost, it has no password, but you need to\r\nbe system 'root' user to connect. Use, for example, sudo mariadb\r\nThe second is mysql@localhost, it has no password either, but\r\nyou need to be the system 'mysql' user to connect.\r\nAfter connecting you can set the password, if you would need to be\r\nable to connect as any of these users with a password and without sudo\r\n\r\nSee the MariaDB Knowledgebase at https://mariadb.com/kb\r\n\r\nPlease report any problems at https://mariadb.org/jira\r\n\r\nThe latest information about MariaDB is available at https://mariadb.org/.\r\n\r\nConsider joining MariaDB's strong and vibrant community:\r\nhttps://mariadb.org/get-involved/\r\n\r\n"]
[0.002, "o", "\u001b]3008;end=1737bc6c-da5b-4d1c-813e-91abe5678e19;exit=success\u001b\\"]
[0.005, "o", "\u001b]3008;start=06ac34b1-786c-4d8f-b7f0-2e951bc9bac8;machineid=87bfb2a9fa984de8a97ab1bcabaae23f;user=ajah;hostname=cidut;bootid=ca0f7121-6e63-4229-b614-9ca09f2995af;pid=00000000000000001243;type=shell;cwd=/home/ajah\u001b\\"]
[0.000, "o", "\u001b[?2004h"]
[0.000, "o", "[ajah@cidut ~]$ "]
[85.018, "o", "sudo mariadb-install-db --user=mysql --basedir=/usr --datadir=/var/lib/mysql"]
[0.290, "o", "\r\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[C\u001b[41Psystemctl enable --now mariadb"]
