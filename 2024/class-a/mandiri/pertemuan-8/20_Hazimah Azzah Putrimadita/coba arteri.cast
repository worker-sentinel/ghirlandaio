[0.001, "o", "\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d; of sensitive information in stack traces\r\u001b[3d; Default Value: Off\r\u001b[4d; Development Value: Off\u001b[5;3HProduction Value: On\u001b[K\r\u001b[6dzend.exception_ignore_args = On\u001b[K\r\u001b[7d\u001b[K\u001b[8d; Allows setting the maximum string length in an argument of a stringified stack trace\u001b[9;3Hto a value between 0 and 1000000.\u001b[K\u001b[10;3HThis has no effect when zend.exception_ignore_args is enabled.\u001b[K\r\u001b[11d; Default Value: 15\u001b[K\r\u001b[12d; Development Value: 15\u001b[13;3HProduction Value: 0\u001b[K\u001b[14;3HIn production, it is recommended to set this to 0 to reduce the output\r\u001b[15d; of sensitive information in stack traces.\r\u001b[16dzend.exception_string_param_max_len = 0\r\u001b[17d\u001b[K\u001b[18d;"]
[0.000, "o", ";;;;;;;;;;;;;;;;\u001b[K\r\u001b[19d; Miscellaneous ;\u001b[K\r\u001b[20d;;;;;;;;;;;;;;;;;\r\u001b[21d\u001b[K\u001b[22d; Decides whether PHP may expose the fact that it is installed on the server\r\u001b[23d"]
[0.000, "o", "; (e.g. by adding its signature to the Web server header).  It is no security\u001b[24;3Hthreat in any way, but it makes it possible to determine whether you use PHP\u001b[25;3Hon your server or not.\u001b[K\u001b[26;3Hhttps://php.net/expose-php\u001b[K\r\u001b[27dexpose_php = On\u001b[K\r\u001b[28d"]
[0.000, "o", "\u001b[K\u001b[29d;;;;;;;;;;;;;;;;;;;\u001b[30;3HResource Limits ;\u001b[K\r\u001b[31d;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[33;3HMaximum \u001b[30m\u001b[43mexecution\u001b[39;49m\u001b[m\u000f time of each script, in seconds\u001b[K\u001b[34;3Hhttps://php.net/max-execution-time\u001b[K\r\u001b[35d; Note: This directive is hardcoded to 0 for the CLI SAPI\r\u001b[36d"]
[0.000, "o", "max_execution_time = 30\r\u001b[37d\u001b[K\u001b[38d; "]
[0.000, "o", "Maximum amount of time each script may spend parsing request data. It's a good\r\u001b[39d; idea to limit this time on productions servers in order to eliminate unexpectedly\r\u001b[40d; long running scripts.\u001b[41;3H"]
[0.001, "o", "Note: This directive is hardcoded to -1 for the CLI SAPI\u001b[K\u001b[42;3HDefault Value: -1 (Unlimited)\u001b[K\u001b[43;3HDevelopment Value: 60 (60 seconds)\u001b[K\u001b[44;3HProduction Value: 60 (60 seconds)\r\u001b[45d; https://php.net/max-input-time\r\u001b[46dmax_input_time = 60\r\u001b[47d\u001b[K\u001b[48d; "]
[0.000, "o", "Maximum input variable nesting level\u001b[K\r\u001b[49d; https://php.net/max-input-nesting-level\r\u001b[50d;max_input_nesting_level = 64\r\u001b[51d\u001b[K\u001b[52d; "]
[0.000, "o", "How many GET/POST/COOKIE input variables may be accepted\u001b[K\r\u001b[53d;max_input_vars = 1000\u001b[K\r\u001b[54d\u001b[K\u001b[55d; How many multipart body parts (combined input variable and file uploads) may\u001b[56;3Hbe accepted.\u001b[K\r\u001b[57d; Default Value: -1 (Sum of max_input_vars and max_file_uploads)\r\u001b[58d;max_multipart_body_parts = 1500\r\u001b[59d"]
[0.000, "o", "\u001b[K\u001b[60d; Maximum amount of memory a script may consume\r\u001b[61d; https://php.net/memory-limit\r\u001b[62dmemory_limit = 128M\u001b[K\r\u001b[63d"]
