[0.001, "o", "\r\u001b[2d; unless \"declare(encoding=...)\" directive appears at the top of the script.\r\u001b[3d; Only affects if zend.multibyte is set.\r\u001b[4d;zend.script_encoding =\r\u001b[5d\u001b[K\u001b[6d; Allows to include or exclude arguments from stack traces generated for exceptions.\r\u001b[7d; In production, it is recommended to turn this setting on to prohibit the output\r\u001b[8d; of sensitive information in stack traces\u001b[9;3HDefault Value: Off\u001b[K\u001b[10;3HDevelopment Value: Off\u001b[K\r\u001b[11d; Production Value: On\r\u001b[12dzend.exception_ignore_args = On\r\u001b[13d\u001b[K\u001b[14d; Allows setting the maximum string length in an argument of a stringified stack trace\r\u001b[15d; to a value between 0 and 1000000.\r\u001b[16d; This has no effect when zend.exception_ignore_args is enabled.\u001b[17;3HDefault Value: 15\u001b[K\u001b[18;3H"]
[0.000, "o", "Development Value: 15\u001b[K\r\u001b[19d; Production Value: 0\u001b[K\r\u001b[20d; In production, it is recommended to set this to 0 to reduce the output\u001b[21;3Hof sensitive information in stack traces.\u001b[K\r\u001b[22dzend.exception_string_param_max_len = 0\u001b[K\r\u001b[23d\u001b[K\u001b[24d;;;;;;;;;;;;;;;;;\u001b[25;3HMiscellaneous ;\u001b[K\r\u001b[26d;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[27d\u001b[K\u001b[28d; Decides whether PHP may expose the fact that it is installed on the server\u001b[29;3H"]
[0.000, "o", "(e.g. by adding its signature to the Web server header).  It is no security\u001b[K\u001b[30;3Hthreat in any way, but it makes it possible to determine whether you use PHP\u001b[K\r\u001b[31d; on your server or not.\r\u001b[32d; https://php.net/expose-php\r\u001b[33d\u001b[30m\u001b[43mexpose_php\u001b[39;49m\u001b[m\u000f = On\r\u001b[34d"]
[0.000, "o", "\u001b[K\u001b[35d;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[36;3HResource Limits ;\u001b[K\r\u001b[37d;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[39;3HMaximum execution time of each script, in seconds\u001b[K\u001b[40;3Hhttps://php.net/max-execution-time\u001b[41;3H"]
[0.000, "o", "Note: This directive is hardcoded to 0 for the CLI SAPI\u001b[K\r\u001b[42dmax_execution_time = 300\u001b[K\r\u001b[43d\u001b[K\u001b[44d; Maximum amount of time each script may spend parsing request data. It's a good\r\u001b[45d"]
[0.000, "o", "; idea to limit this time on productions servers in order to eliminate unexpectedly\u001b[46;3Hlong running scripts.\u001b[K\u001b[47;3H"]
[0.000, "o", "Note: This directive is hardcoded to -1 for the CLI SAPI\u001b[48;3HDefault Value: -1 (Unlimited)\u001b[K\u001b[49;3H"]
[0.000, "o", "Development Value: 60 (60 seconds)\u001b[K\u001b[50;3HProduction Value: 60 (60 seconds)\u001b[K\u001b[51;20H"]
[0.001, "o", "ax-input-time\u001b[K\r\u001b[52dmax_input_time = 60\u001b[K\u001b[54;3H"]
[0.000, "o", "Maximum input variable nesting level\u001b[K\u001b[55;7Hs://php.net/max-input-nesting-level\r\u001b[56d;"]
[0.000, "o", "max_input_nesting_level = 64\u001b[K\r\u001b[57d\u001b[K\u001b[58d; How many GET/POST/COOKIE input variables may be accepted\u001b[K\r\u001b[59d;"]
[0.000, "o", "max_input_vars = 1000\u001b[K\r\u001b[60d\u001b[K\u001b[61d; "]
[0.000, "o", "How many multipart body parts (combined input variable and file uploads) may\r\u001b[62d; be accepted.\u001b[K\r\u001b[63d"]
[0.000, "o", "; Default Value: -1 (Sum of max_input_vars and max_file_uploads)\r\u001b[64d;max_multipart_body_parts = 1500\u001b[K\r\u001b[33d"]
