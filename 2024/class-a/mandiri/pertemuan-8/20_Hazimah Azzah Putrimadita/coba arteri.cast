[0.001, "o", "\r\u001b[A\u001b[0;10;7m\u000fSearch [include]:                                                                                                                                                                                                                               \u001b[65;19H\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[0.608, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d\u001b[K\u001b[3;5H#\u001b[K\r\u001b[4d    # The location and format of the access logfile (Common Logfile Format).\u001b[5;5H# If you do not define any access logfiles within a <VirtualHost>\r\u001b[6d    # container, they will be logged here.  Contrariwise, if you *do*\r\u001b[7d    # define per-<VirtualHost> access logfiles, transactions will be\u001b[K\r\u001b[8d    # logged therein and *not* in this file.\r\u001b[9d    #\r\u001b[10d    CustomLog \"/var/log/httpd/access_log\" common\r\u001b[11d\u001b[K\u001b[12d    #\u001b[K\u001b[13d\b# If you prefer a logfile with access, agent, and referer information\r\u001b[14d    # (Combined Logfile Format) you can use the following directive.\r\u001b[15d    #\u001b[K\r\u001b[16d    #CustomLog \"/var/log/httpd/access_log\" combined\r\u001b[17d</IfModule>\r\u001b[18d\u001b[K\u001b[19d<IfModule alias_module>\r\u001b[20d    #\u001b[K\u001b[21d\b# Redirect: Allows you to tell clients about documents that used to\r\u001b[22d    # exist in your server's namespace, but do not anymore. The client\r\u001b[23d    # will make a new request for the document"]
[0.000, "o", " at its new location.\r\u001b[24d    # Example:\u001b[K\r\u001b[25d    # Redirect permanent /foo http://www.example.com/bar\u001b[K\r\u001b[26d\u001b[K\u001b[27d"]
[0.000, "o", "    #\u001b[K\r\u001b[28d    # Alias: Maps web paths into filesystem paths and is used to\r\u001b[29d    # access content that does not live under the DocumentRoot.\u001b[30;5H# Example:\r\u001b[31d    # Alias /webpath /full/filesystem/path\r\u001b[32d    #\u001b[K\r\u001b[33d"]
[0.001, "o", "    # If you \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000f a trailing / on /webpath then the server will\r\u001b[34d    # require it to be present in the URL.  You will also likely\r\u001b[35d    # need to provide a <Directory> section to allow access to\r\u001b[36d    # the filesystem path.\r\u001b[38d    #\u001b[K\u001b[39d ScriptAlias: This controls which directories contain server scripts.\u001b[40;7H"]
[0.000, "o", "ScriptAliases are essentially the same as Aliases, except that\u001b[K\u001b[41;7Hdocuments in the target directory are treated as applications and\u001b[42;7Hrun by the server when requested rather than as documents sent to the\u001b[43;5H# client.  The same rules about trailing \"/\" apply to ScriptAlias\u001b[K\u001b[44;5H# directives as to Alias.\u001b[K\u001b[45;5H#\u001b[46d\bScriptAlias /cgi-bin/ \"/srv/http/cgi-bin/\"\r\u001b[47d\u001b[K\u001b[48d</IfModule>\u001b[K\r\u001b[49d\u001b[K\u001b[50d<IfModule cgid_module>\u001b[52;7H"]
[0.000, "o", "ScriptSock: On threaded servers, designate the path to the UNIX\u001b[K\u001b[53;7Hsocket used to communicate with the CGI daemon of mod_cgid.\u001b[K\u001b[54;7H"]
[0.000, "o", "\u001b[K\u001b[55d\bScriptsock cgisock\u001b[K\r\u001b[56d</IfModule>\u001b[K\r\u001b[57d\u001b[K\u001b[58d#\u001b[K\u001b[59d\b"]
[0.000, "o", "# \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\r\u001b[60d# CGI directory exists, if you have that configured.\r\u001b[61d"]
[0.000, "o", "#\u001b[K\u001b[62d\b<Directory \"/srv/http/cgi-bin\">\u001b[K\u001b[63;5H"]
[0.000, "o", "AllowOverride None\u001b[64;5HOptions None\u001b[K\u001b[33;14H"]
