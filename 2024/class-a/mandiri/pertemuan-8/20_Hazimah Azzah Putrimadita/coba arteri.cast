[0.001, "o", "\r\u001b[2d# Customizable error responses come in three flavors:\r\u001b[3d# 1) plain text 2) local redirects 3) external redirects\r\u001b[4d#\u001b[K\u001b[5d\b# Some examples:\u001b[K\r\u001b[6d#ErrorDocument 500 \"The server made a boo boo.\"\u001b[K\r\u001b[7d#ErrorDocument 404 /missing.html\u001b[K\r\u001b[8d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\r\u001b[9d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[10d#\u001b[K\u001b[12d\b#\u001b[K\u001b[13d\b# MaxRanges: Maximum number of Ranges in a request before\u001b[K\r\u001b[14d# returning the entire resource, or one of the special\u001b[K\r\u001b[15d# values 'default', 'none' or 'unlimited'.\r\u001b[16d# Default setting is to accept 200 Ranges.\u001b[K\r\u001b[17d#MaxRanges unlimited\r\u001b[19d#\u001b[K\u001b[20d\b# EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[21d# memory-mapping or the sendfile syscall may be used to deliver\u001b[K\r\u001b[22d# files.  This usually improves server performance, but must\u001b[K\r\u001b[23d# be turned off when serving from networked-mounted\u001b[K\r\u001b[24d# filesystems or if support for these functions is otherwise\r\u001b[25d# broken on your system.\u001b[K\r\u001b[26d"]
[0.000, "o", "# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[27d#\u001b[K\u001b[28d\b"]
[0.000, "o", "#EnableMMAP off\u001b[K\r\u001b[29d#EnableSendfile on\u001b[K\r\u001b[30d\u001b[K\u001b[31d"]
