[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[2;3HE_USER_NOTICE     - user-generated notice message\u001b[K\u001b[3;3HE_DEPRECATED      - warn about code that will not work in future versions\r\u001b[4d;\u001b[21X\u001b[4;23Hof PHP\r\u001b[5d; E_USER_DEPRECATED - user-generated deprecation warnings\u001b[6;3H\u001b[K\u001b[7dCommon Values:\u001b[K\u001b[8;3H  E_ALL (Show all errors, warnings and notices including coding standards.)\u001b[9;3H  E_ALL & ~E_NOTICE  (Show all errors, except for notices)\u001b[10;3H  E_ALL & ~E_NOTICE & ~E_STRICT  (Show all errors, except for notices and coding standards warnings.)\u001b[11;3H  E_COMPILE_ERROR|E_RECOVERABLE_ERROR|E_ERROR|E_CORE_ERROR  (Show only errors)\r\u001b[12d; Default Value: E_ALL\u001b[K\r\u001b[13d; Development Value: E_ALL\u001b[14;3HProduction Value: E_ALL & ~E_DEPRECATED & ~E_STRICT\u001b[K\u001b[15;3Hhttps://php.net/error-reporting\u001b[K\r\u001b[16derror_reporting = E_ALL & ~E_DEPRECATED & ~E_STRICT\u001b[K\r\u001b[17d\u001b[K\u001b[18d; This directive controls whether or not and where PHP will output errors,\u001b[19;3Hnotices and warnings too. Error output is very useful during development, but\u001b[20;3H"]
[0.000, "o", "it could be very dangerous in production environments. Depending on the code\u001b[21;3Hwhich is triggering the error, sensitive information could potentially leak\r\u001b[22d"]
[0.000, "o", "; out of your application such as database usernames and passwords or worse.\r\u001b[23d; For production environments, we recommend logging errors rather than\r\u001b[24d; sending them to STDOUT.\u001b[25;3HPossible Values:\r\u001b[26d;   Off = Do not display any errors\r\u001b[27d;   stderr = Display errors to STDERR (affects only CGI/CLI binaries!)\u001b[28;3H  On or stdout = Display errors to STDOUT\u001b[K\u001b[29;3HDefault Value: On\u001b[K\u001b[30;3HDevelopment Value: On\u001b[K\u001b[31;3HProduction Value: Off\u001b[K\u001b[32;19H"]
[0.001, "o", "display-errors\r\u001b[33d\u001b[30m\u001b[43mdisplay_errors\u001b[39;49m\u001b[m\u000f = Off\r\u001b[35d; The display of errors which occur during PHP's startup sequence are handled\u001b[36;3H"]
[0.000, "o", "separately from display_errors. We strongly recommend you set this to 'off'\r\u001b[37d; for production servers to avoid leaking configuration details.\r\u001b[38d; Default Value: On\u001b[39;3HDevelopment Value: On\u001b[K\u001b[40;3HProduction Value: Off\u001b[K\u001b[41;3Hhttps://php.net/display-startup-errors\u001b[K\r\u001b[42ddisplay_startup_errors = Off\u001b[44;3HBesides displaying errors, PHP can also log errors to locations such as a\u001b[K\u001b[45;3Hserver-specific log, STDERR, or a location specified by the error_log\u001b[K\u001b[46;3Hdirective found below. While errors should not be displayed on productions\u001b[47;3Hservers they should still be monitored and logging is a great way to do that.\u001b[48;18HOff\u001b[K\u001b[49d On\u001b[K\u001b[50;21H"]
[0.000, "o", "On\u001b[K\u001b[51;19Hlog-errors\u001b[K\r\u001b[52dlog_errors = On\u001b[K\u001b[54;3H"]
[0.000, "o", "Do not log repeated messages. Repeated errors must occur in same file on same\u001b[55;3Hline unless ignore_repeated_source is set true.\r\u001b[56d; https://php.net/ignore-repeated-errors\r\u001b[57dignore_repeated_errors = Off\r\u001b[58d\u001b[K\u001b[59d;"]
[0.000, "o", " Ignore source of message when ignoring repeated messages. When this setting\r\u001b[60d; is On you will not log errors with repeated messages from different files or\u001b[61;3H"]
[0.000, "o", "source lines.\u001b[K\u001b[62;3Hhttps://php.net/ignore-repeated-source\r\u001b[63dignore_repeated_source = Off\u001b[K\r\u001b[64d\u001b[K\u001b[33d"]
[1.503, "o", "\u001b[?25h\u001b[?0cdisplay_errors\u001b[21G\r"]
