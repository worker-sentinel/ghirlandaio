[0.001, "o", "\u001b[2;19Hexpose-php\u001b[K\r\u001b[3dexpose_php = On\u001b[K\r\u001b[5d;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[6;3HResource Limits ;\u001b[K\r\u001b[7d;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[8d\u001b[K\u001b[9d; Maximum execution time of each script, in seconds\u001b[K\u001b[10;3Hhttps://php.net/max-execution-time\u001b[K\u001b[11;3HNote: This directive is hardcoded to 0 for the CLI SAPI\u001b[K\r\u001b[12dmax_execution_time = 30\r\u001b[13d\u001b[K\u001b[14d; Maximum amount of time each script may spend parsing request data. It's a good\u001b[15;3Hidea to limit this time on productions servers in order to eliminate unexpectedly\u001b[16;3Hlong running scripts.\u001b[K\r\u001b[17d; Note: This directive is hardcoded to -1 for the CLI SAPI\r\u001b[18d; Default Value: -1 (Unlimited)\u001b[19;3HDevelopment Value: 60 (60 seconds)\u001b[K\u001b[20;3HProduction Value: 60 (60 seconds)\u001b[K\u001b[21;19Hmax-input-time\u001b[K\r\u001b[22dmax_input_time = 60\u001b[K\u001b[24;3HMaximum input variable nesting level\u001b[25;19Hmax-input-nesting-level\r\u001b[26d"]
[0.000, "o", ";max_input_nesting_level = 64\u001b[28;3HHow many GET/POST/COOKIE input variables may be accepted\r\u001b[29d;max_input_vars = 1000\u001b[K\r\u001b[30d\u001b[K\u001b[31d; "]
[0.000, "o", "How many multipart body parts (combined input variable and file uploads) may\u001b[32;3Hbe accepted.\u001b[K\u001b[33;3HDefault Value: -1 (Sum of max_input_vars and max_\u001b[30m\u001b[43mfile_uploads\u001b[39;49m\u001b[m\u000f)\r\u001b[34d;max_multipart_body_parts = 1500\u001b[K\r\u001b[35d\u001b[K\u001b[36d; "]
