[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;34H"]
[0.002, "o", "to the table name when using the  Query Builder class\r"]
