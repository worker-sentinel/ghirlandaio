[0.002, "o", "\n\u001b[1;48r\u001b[45;9H'pconnect' => FALSE,\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;9H'db_debug' => (ENVIRONMENT !== 'production'),\r"]
