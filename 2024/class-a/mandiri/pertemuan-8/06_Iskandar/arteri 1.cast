[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;33H'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;33H"]
[0.001, "o", "'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;33H"]
[0.001, "o", "'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;33H"]
[0.001, "o", "'ssl_ca'     - Path to the certificate authority file\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;33H"]
[0.001, "o", "'ssl_cert'   - Path to the public key certificate file\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "|\u001b[2;33H'ssl_key'    - Path to the private key file\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
