[0.001, "o", "\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.001, "o", "\r\u001b[2d#MaxRanges unlimited\r\u001b[3d\u001b[K\u001b[4d# \u001b[K\u001b[5dEnableMMAP and EnableSendfile: On systems that support it,\u001b[K\u001b[6;3H"]
[0.000, "o", "memory-mapping or the sendfile syscall may be used to deliver\u001b[7;3Hfiles.  This usually improves server performance, but must\u001b[8;3H"]
[0.001, "o", "be turned off when serving from networked-mounted\u001b[9;3Hfilesystems or if support for these functions is otherwise\u001b[10;3Hbroken on your system.\u001b[K\u001b[11;3HDefaults: EnableMMAP On, EnableSendfile Off\u001b[K\u001b[12;3H\u001b[K\u001b[13d\bEnableMMAP off\r\u001b[14d#EnableSendfile on\u001b[K\r\u001b[15d\u001b[K\u001b[16d# Supplemental configuratio"]
[0.001, "o", "n\u001b[K\u001b[17;3H"]
[0.000, "o", "\u001b[K\u001b[18dThe configuration files in the conf/extra/ directory can be\u001b[K\u001b[19;3Hincluded to add extra features or to modify the default configuration of\u001b[K\u001b[20;3Hthe server, or you may simply copy their contents here and change as\r\u001b[21d# necessary.\r\u001b[22d\u001b[K\u001b[23;9H-pool management (MPM specific)\u001b[K\r\u001b[24d"]
[0.002, "o", "\u001b[30m\u001b[43mInclude conf\u001b[39;49m\u001b[m\u000f/extra/httpd-mpm.conf\u001b[K\r\u001b[25d\u001b[K\u001b[26d# Multi-language error messages\u001b[K\r\u001b[27dInclude conf/extra/httpd-multilang-errordoc.conf\u001b[K\r\u001b[28d\u001b[K\u001b[29d# Fancy directory listings\u001b[K\r\u001b[30dInclude conf/extra/httpd-autoindex.conf\r\u001b[31d\u001b[K\u001b[32d# Language settings\u001b[K\r\u001b[33dInclude conf/extra/httpd-languages.conf\r\u001b[34d\u001b[K\u001b[35d# User home directories\u001b[K\r\u001b[36dInclude conf/extra/httpd-userdir.conf\u001b[K\r\u001b[37d\u001b[K\u001b[38d# Real-time info on requests and configuration\u001b[K\r\u001b[39d#Include conf/extra/httpd-info.conf\u001b[K\r\u001b[40d\u001b[K\u001b[41d# Virtual hosts\r\u001b[42d#Include conf/extra/httpd-vhosts.conf\u001b[44;3HLocal access to the Apache HTTP Server Manual\r\u001b[45d#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[24d"]
