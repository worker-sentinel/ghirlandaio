[0.000, "o", "https://php.net/default-socket-timeout\u001b[K\r\u001b[3d"]
[0.001, "o", "default_socket_timeout = 60\r\u001b[4d\u001b[K\u001b[5d; If your scripts have to deal with files from Macintosh systems,\u001b[6;3Hor you are running on a Mac and need to deal with files from\u001b[7;3Hunix or win32 systems, setting this flag will cause PHP to\r\u001b[8d"]
