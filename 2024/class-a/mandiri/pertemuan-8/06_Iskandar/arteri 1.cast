[0.002, "o", "|\b"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.002, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;25H'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;25H"]
[0.001, "o", "'mysql' (deprecated), 'sqlsrv' and 'pdo/sqlsrv' drivers accept TRUE/FALSE\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "|\b"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[9G['encrypt']  Whether or not to use an encrypted connection.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[9G['swap_pre'] A default table prefix that should be swapped with the dbprefix\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;34HSites using Latin-1 or UTF-8 database character set and collation are unaffected.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", "|\u001b[2;34Hmulti-byte character set and are running versions lower than these.\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;34Hcan make your site vulnerable to SQL injection if you are using a\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", "|\u001b[2;34HThere is an incompatibility in PHP with mysql_real_escape_string() which\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[2;34H"]
[0.002, "o", "(and in table creation queries made with DB Forge).\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", "|\u001b[2;34Has a backup if your server is running PHP < 5.2.3 or MySQL < 5.0.7\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "|\u001b[2;34HNOTE: For MySQL and MySQLi databases, this setting is only used\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "|\u001b[9G['dbcollat'] The character collation used in communicating with the database\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[9G"]
[0.002, "o", "['char_set'] The character set used in communicating with the database\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H|\u001b[9G['cachedir'] The path to the folder where cache files should be stored\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", "|\u001b[9G['cache_on'] TRUE/FALSE - Enables/disables query caching\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H|\u001b[9G['db_debug'] TRUE/FALSE - Whether database errors should be displayed.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", "|\u001b[9G['pconnect'] TRUE/FALSE - Whether to use a persistent connection\r"]
