License\u001b[K\r\n * @link        https://codeigniter.com\u001b[K\r\n * @since       Version 1.0.0\u001b[K\r\n * @filesource\u001b[K\r\n */\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n *---------------------------------------------------------------\u001b[K\r\n * APPLICATION ENVIRONMENT\u001b[K\r\n *---------------------------------------------------------------\u001b[K\r\n *\u001b[K\r\n * You can load different configurations depending on your\u001b[K\r\n * current environment. Setting the environment also influences\u001b[K\r\n * things like logging and error reporting.\u001b[K\r\n *\u001b[K\r\n * This can be set to anything, but default usage is:\u001b[K\r\n *\u001b[K\r\n *     development\u001b[K\r\n *     testing\u001b[K\r\n *     production\u001b[K\r\n *\u001b[K\r\n * NOTE: If you change these, also change the error_reporting() code below\u001b[K\r\n */\u001b[K\r\n        \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ENVIRONMENT'\u001b[m\u000f, isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'CI_ENV'\u001b[m\u000f]) ? $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'CI_ENV'\u001b[m\u000f] : \u001b[92m'development'\u001b[m\u000f);\u001b[K\r\n        \u001b[K\r\n        \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ROOTPATH'\u001b[m\u000f, \u001b[96mrealpath\u001b[m\u000f(\u001b[96mdirname\u001b[m\u000f(__FILE__)) . \u001b[92m'/'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n\u001b[K\n        // installed in the docroot?\u001b[K\r\n        \u001b[0;10;1m\u000fif\u001b[m\u000f (\u001b[96mrealpath\u001b[m\u000f(\u001b[96mdirname\u001b[m\u000f(__FILE__)) \u001b[0;10;1m\u000f==\u001b[m\u000f $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'DOCUMENT_ROOT'\u001b[m\u000f])\u001b[K\r\n        {\u001b[K\r\n                \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ROOT'\u001b[m\u000f, \u001b[92m'/'\u001b[m\u000f);\u001b[K\r\n        }\u001b[K\r\n\u001b[0;10;7m\u000f/srv/http/arteri/index.php                                                                                                                    