[0.010, "o", "\u001b[H|    \r\n| This determines which character set is used by default in various methods\r\n| that require a character set to be provided.\r\n| \u001b[5;2H See http://php.net/htmlspecialchars for a list of supported charsets.    \u001b[6;2H\u001b[14X\r\n*/\u001b[73X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'charset'\u001b[m\u000f] = \u001b[92m'UTF-8'\u001b[m\u000f;\r\n\u001b[69X\n/*\u001b[22X\u001b[11;2H--------------------------------------------------------------------------\u001b[12;3HEnable/Disable System Hooks\u001b[13;2H--------------------------------------------------------------------------\u001b[14;2H\u001b[34X\n If you would like to use the 'hooks' feature you must enable it by\u001b[16;3Hsetting this variable to TRUE (boolean).  See the user guide for details.\u001b[17;2H\u001b[73X\r\n*/\u001b[64X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'enable_hooks'\u001b[m\u000f] = FALSE;\u001b[33X\r\n\u001b[49X\n/*\u001b[22;2H--------------------------------------------------------------------------\u001b[23;3HClass Extension Prefix\u001b[30X\u001b[24;2H--------------------------------------------------------------------------\r\n| \r\n| This item allows you to set the filename/classname prefix when extending\u001b[31X\r\n| native libraries.  For more information please see the user guide:\r\n| \u001b[29;2H https://codeigniter.com/user_guide/general/core_classes.html\u001b[13X\u001b[30;3Hhttps://codeigniter.com/user_guide/general/creating_libraries.html\u001b[31;2H\u001b[74X\r\n*/\r\n\u001b[30m\u001b[103m$config['s\u001b[m\u000f\u001b[92mubclass_prefix'\u001b[m\u000f] = \u001b[92m'MY_'\u001b[m\u000f;\u001b[38X\r\n\u001b[74X\n/*\u001b[29X\u001b[36;2H--------------------------------------------------------------------------\r\n| Composer auto-loading\r\n|--------------------------------------------------------------------------\r\n|\r\n| Enabling this setting will tell CodeIgniter to look for a Composer\u001b[41;2H package auto-loader script in application/vendor/autoload.php.\u001b[11X\u001b[42;2H\u001b[13X\n       $config['composer_autoload'] = TRUE;\u001b[31X\u001b[45;3HOr if you have your vendor/ directory located somewhere else, you\u001b[6X\u001b[46;3Hcan opt to set a specific path as well:\u001b[34X\u001b[47;2H\u001b[75X\n       $config['composer_autoload'] = '/path/to/vendor/autoload.php';\u001b[49;2H\u001b[46X\u001b[50;3HFor more information about Composer, please visit http://getcomposer.org/\u001b[51;2H\u001b[44X\n Note: This will NOT disable or override the CodeIgniter-specific\u001b[53;3H      autoloading (application/config/autoload.php)\u001b[22X\r\n\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'composer_autoload'\u001b[m\u000f] = FALSE;   \u001b[59;3HAllowed URL Characters\u001b[62;8Hlets you specify which characters are permitted within your URLs.\u001b[6X\u001b[63;3HWhen someone tries to submit a URL with disallowed characters they will\u001b[64;2H get a warning message.\u001b[65;2H\u001b[53X\u001b[66;223H\u001b[0;10;7m\u000f117,1          18%\u001b[67;12H\u001b[?25h"]
[0.673, "o", "\u001b[?25l\u001b[m\u000fe"]
[0.032, "o", "\u001b[2;3H      The location to save sessions to, driver dependent.\u001b[16X\u001b[3;2H\u001b[45X\n       For the 'files' driver, it's a path to a writable directory.\u001b[5;3H      WARNING: Only absolute paths are supported!\u001b[20X\r\n\n|       For the 'database' driver, it's a table name.\r\n|       Please read up the manual for the format with other session drivers.\r\n|\r\n|       IMPORTANT: You are REQUIRED to set a valid save path!\u001b[11;2H\u001b[74X\u001b[12;3H'sess_match_ip'\u001b[12X\u001b[13;2H\u001b[74X\n       Whether to match the user's IP address when reading the session data.\u001b[15;2H\u001b[67X\u001b[16;3H      WARNING: If you're using the database driver, don't forget to update\u001b[17;2H                your session table's PRIMARY KEY when changing this setting.\r\n| \r\n| 'sess_time_to_update'\u001b[9X\r\n|\r\n|       How many seconds between CI regenerating the session ID.\u001b[22;2H\u001b[74X\u001b[23;3H'sess_regenerate_destroy'\u001b[24;2H\u001b[74X\n       Whether to destroy session data associated with the old session ID\u001b[26;3H      when auto-regenerating the session ID. When set to FALSE, the data\u001b[27;3H      will be later deleted by the garbage collector.\u001b[13X\u001b[29;3HOther session cookie settings are shared with the rest of the application,\u001b[30;3Hexcept for 'cookie_prefix' and 'cookie_httponly', which are ignored here.\u001b[33;11H\u001b[30m\u001b[103me\u001b[m\u000f\u001b[92mss_driver'\u001b[m\u000f] = \u001b[92m'files'\u001b[m\u000f;  \r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_cookie_name'\u001b[m\u000f] = \u001b[92m'arteri'\u001b[m\u000f;\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_expiration'\u001b[m\u000f] = 7200;\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_save_path'\u001b[m\u000f] = NULL;\u001b[42X\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_match_ip'\u001b[m\u000f] = FALSE;\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_time_to_update'\u001b[m\u000f] = 300;\u001b[38X\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_regenerate_destroy'\u001b[m\u000f] = FALSE;\r\n\u001b[68X\n/*\u001b[62X\u001b[42;2H--------------------------------------------------------------------------\u001b[43;3HCookie Related Variables\u001b[18X\u001b[44;2H--------------------------------------------------------------------------\u001b[45;2H\u001b[66X\u001b[46;3H'cookie_prefix'   = Set a cookie name prefix if you need to avoid collisions\u001b[47;2H 'cookie_domain'   = Set to .your-domain.com for site-wide cookies\u001b[48;3H'cookie_path'     = Typically will be a forward slash\u001b[15X\u001b[49;2H 'cookie_secure'   = Cookie will only be set if a secure HTTPS connection exists.\u001b[50;3H'cookie_httponly' = Cookie will only be accessible via HTTP(S) (no javascript)\u001b[52;11Hese settings (with the exception of 'cookie_prefix' and \u001b[53;9H'cookie_httponly') will also affect sessions.\r\n| \r\n*/\u001b[35X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_prefix'\u001b[m\u000f]        = \u001b[92m''\u001b[m\u000f;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_domain'\u001b[m\u000f]        = \u001b[92m''\u001b[m\u000f;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_path'\u001b[m\u000f]          = \u001b[92m'/'\u001b[m\u000f;\u001b[37X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_secure'\u001b[m\u000f]        = FALSE;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_httponly'\u001b[m\u000f]      = FALSE;\u001b[35X\r\n \r\n/*\u001b[70X\u001b[63;2H--------------------------------------------------------------------------\u001b[64;3HStandardize newlines  \u001b[65;2H--------------------------------------------------------------------------\u001b[66;223H\u001b[0;10;7m\u000f380,1          75\u001b[67;13H\u001b[?25h"]
