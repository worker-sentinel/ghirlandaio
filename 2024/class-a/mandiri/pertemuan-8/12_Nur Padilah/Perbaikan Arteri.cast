[0.022, "o", "\u001b[1;65r\u001b[H\u001b[26M\u001b[1;67r\u001b[28;47Herror_reporting(\r\u001b[12B        \u001b[0;10;1m\u000felse\u001b[m\u000f\u001b[K\r\n        {\u001b[K\r\n                \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ROOT'\u001b[m\u000f, \u001b[92m'/'\u001b[m\u000f.\u001b[96msubstr\u001b[m\u000f(ROOTPATH, \u001b[96mstrlen\u001b[m\u000f($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'DOCUMENT_ROOT'\u001b[m\u000f])+1));\u001b[K\r\n        }\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n *---------------------------------------------------------------\u001b[K\r\n * ERROR REPORTING\u001b[K\r\n *---------------------------------------------------------------\u001b[K\r\n *\u001b[K\r\n * Different environments will require different levels of error reporting.\u001b[K\r\n * By default development will show errors but testing and live will hide them.\u001b[K\r\n */\u001b[K\r\n\u001b[0;10;1m\u000fswitch\u001b[m\u000f (ENVIRONMENT)\u001b[K\r\n{\u001b[K\r\n        \u001b[0;10;1m\u000fcase\u001b[m\u000f \u001b[92m'development'\u001b[m\u000f:\u001b[K\r\n                \u001b[96merror_reporting\u001b[m\u000f(-1);\u001b[K\r\n                \u001b[96mini_set\u001b[m\u000f(\u001b[92m'display_errors'\u001b[m\u000f, 1);\u001b[K\r\n        \u001b[0;10;1m\u000fbreak\u001b[m\u000f;\u001b[K\r\n\u001b[K\n        \u001b[0;10;1m\u000fcase\u001b[m\u000f \u001b[92m'testing'\u001b[m\u000f:\u001b[K\r\n        \u001b[0;10;1m\u000fcase\u001b[m\u000f \u001b[92m'production'\u001b[m\u000f:\u001b[K\r\n                \u001b[96mini_set\u001b[m\u000f(\u001b[92m'display_errors'\u001b[m\u000f, 0);\u001b[K\r\n                \u001b[0;10;1m\u000fif\u001b[m\u000f (\u001b[96mversion_compare\u001b[m\u000f(PHP_VERSION, \u001b[92m'5.3'\u001b[m\u000f, \u001b[92m'>='\u001b[m\u000f))\u001b[K\r\n                {\u001b[K\r\n                        \u001b[30m\u001b[103merror_reporting(E\u001b[m\u000f_ALL & ~E_NOTICE & ~E_DEPRECATED & ~E_STRICT & ~E_USER_NOTICE & ~E_USER_DEPRECATED);\u001b[K\u001b[66;223H\u001b[0;1