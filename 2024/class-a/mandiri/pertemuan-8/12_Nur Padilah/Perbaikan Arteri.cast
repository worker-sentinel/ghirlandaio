[0.011, "o", "\u001b[H<?php\u001b[63X\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\r\n \r\n/*\u001b[51X\u001b[5;2H-------------------------------------------------------------------------- \u001b[6;2H Base Site URL\u001b[7;2H--------------------------------------------------------------------------\u001b[9;3HURL to your CodeIgniter root. Typically this will be your base URL,\u001b[10;2H WITH a trailing slash:\u001b[11;2H\u001b[76X\n       http://example.com/\u001b[13;2H\u001b[75X\u001b[14;3HWARNING: You MUST set this value!\u001b[42X\u001b[16;3HIf it is not set, then CodeIgniter will try guess the protocol and path\u001b[17;2H your installation, but due to security concerns the hostname will be set\u001b[18;3Hto $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\u001b[19;2H The auto-detection mechanism exists only for convenience during\u001b[20;3Hdevelopment and MUST NOT be used in production!\u001b[22;3HIf you need to allow multiple domains, remember that this file is still \u001b[23;3Ha PHP script and you can easily do that on your own.\u001b[20X\u001b[24;2H\u001b[54X\r\n*/\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'base_url'\u001b[m\u000f] = (isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTPS'\u001b[m\u000f]) ? \u001b[92m\"https://\"\u001b[m\u000f : \u001b[92m\"http://\"\u001b[m\u000f) . $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTP_HOST'\u001b[m\u000f] . ROOT;\r\n\u001b[75X\n/*\r\n|--------------------------------------------------------------------------\r\n| Index File\u001b[21X\r\n|--------------------------------------------------------------------------\r\n|\u001b[33X\r\n| Typically this will be your index.php file, unless you've renamed it to\r\n| something else. If you are using mod_rewrite to remove the page set this\r\n| variable so that it is blank.\u001b[6X\r\n|\u001b[42X\r\n*/\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'index_page'\u001b[m\u000f] = \u001b[92m'index.php'\u001b[m\u000f;\r\n\u001b[75X\n/*\u001b[24X\u001b[42;2H URI PROTOCOL\u001b[43;2H--------------------------------------------------------------------------   \u001b[44;2H\u001b[66X\u001b[45;3HThis item determines which server global should be used to retrieve the\u001b[46;3HURI string.  The default setting of 'REQUEST_URI' works for most servers.\u001b[7X\u001b[47;3HIf your links do not seem to work, try one of the other delicious flavors:    \u001b[49;3H'REQUEST_URI'    Uses $_SERVER['REQUEST_URI']\u001b[18X\u001b[50;3H'QUERY_STRING'   Uses $_SERVER['QUERY_STRING']\u001b[5X\u001b[51;2H 'PATH_INFO'      Uses $_SERVER['PATH_INFO']\r\n| \r\n| WARNING: If you set this to 'PATH_INFO', URIs will always be URL-decoded!\r\n*/\u001b[35X\u001b[55;10H\u001b[92muri_protocol'\u001b[m\u000f] = \u001b[92m'REQUEST_URI'\u001b[m\u000f;\r\n\u001b[40X\n/*\u001b[38X\r\n|--------------------------------------------------------------------------\r\n| URL suffix\u001b[61;2H\u001b[21X\n This option allows you to add a suffix to all URLs generated by CodeIgniter.\u001b[63;2H For more information please see the user guide:\u001b[64;2H\u001b[68X\u001b[65;3Hhttps://codeigniter.com/user_guide/general/urls.html\u001b[15X\u001b[66;223H\u001b[0;10;7m\u000f1,1            Top\u001b[67;21H\u001b[?25h"]
