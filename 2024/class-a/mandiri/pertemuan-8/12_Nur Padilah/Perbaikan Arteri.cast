[2.538, "o", "\u001b[?25l\u001b[m\u000f\u001b[92m';\r\n$config['\u001b[m\u000fsess_match_ip\u001b[92m'] = FALSE;\r\n$config['\u001b[m\u000fsess_time_to_update\u001b[92m'] = 300;\r\n$config['\u001b[m\u000fsess_regenerate_destroy\u001b[92m'] = FALSE;\r\n\n/*\r\n|--------------------------------------------------------------------------\r\n| Cookie Related Variables\r\n|--------------------------------------------------------------------------\r\n|\r\n| '\u001b[m\u000fcookie_prefix\u001b[92m'   = Set a cookie name prefix if you need to avoid collisions\r\n| '\u001b[m\u000fcookie_domain\u001b[92m'   = Set to .your-domain.com for site-wide cookies\r\n| '\u001b[m\u000fcookie_path\u001b[92m'     = Typically will be a forward slash\r\n| '\u001b[m\u000fcookie_secure\u001b[92m'   = Cookie will only be set if a secure HTTPS connection exists.\r\n| '\u001b[m\u000fcookie_httponly\u001b[92m' = Cookie will only be accessible via HTTP(S) (no javascript)\r\n|\r\n| Note: These settings (with the exception of '\u001b[m\u000fcookie_prefix\u001b[92m' and\r\n|       '\u001b[m\u000fcookie_httponly\u001b[92m') will also affect sessions.\r\n|\r\n*/\r\n$config['\u001b[m\u000fcookie_prefix\u001b[92m']        = '';\r\n$config['\u001b[m\u000fcookie_domain\u001b[92m']        = '';\r\n$config['\u001b[m\u000fcookie_path\u001b[92m']          = '\u001b[m\u000f/\u001b[92m';\r\n$config['\u001b[m\u000fcookie_secure\u001b[92m']        = FALSE;\r\n$config['\u001b[m\u000fcookie_httponly\u001b[92m']      = FALSE;\r\n\n/*\r\n|--------------------------------------------------------------------------\r\n| Standardize newlines\r\n|--------------------------------------------------------------------------\r\n|\r\n| Determines whether to standardize newline characters in input data,\r\n| meaning to replace \\r\\n, \\r, \\n occurrences with the PHP_EOL value.\u001b[66;227H\u001b[0;10;7m\u000f30\u001b[33;30H\u001b[?25h"]
