[0.000, "o", "sion notice shall be included in\u001b[K\r\n * all copies or substantial portions of the Software.\u001b[K\r\n *\u001b[K\r\n * THE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\u001b[K\r\n * IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\u001b[K\r\n * FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\u001b[K\r\n * AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\u001b[K\r\n * LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\u001b[K\r\n * OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN\u001b[K\r\n * THE SOFTWARE.\u001b[K\r\n *\u001b[K\r\n * @package     CodeIgniter\u001b[K\r\n * @author      EllisLab Dev Team\u001b[K\r\n * @copyright   Copyright (c) 2008 - 2014, EllisLab, Inc. (https://ellislab.com/)\u001b[K\r\n * @copyright   Copyright (c) 2014 - 2017, British Columbia Institute of Technology (http://bcit.ca/)\u001b[K\r\n * @license     http://opensource.org/licenses/MIT      MIT License\u001b[K\r\n * @link        https://codeigniter.com\u001b[K\r\n * @since       Version 1.0.0\u001b[K\r\n * @filesource\u001b[K\r\n */\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n *---------------------------------------------------------------\u001b[K\r\n * APPLICATION ENVIRONMENT\u001b[K\r\n *---------------------------------------------------------------\u001b[K\r\n *\u001b[K\r\n * You can load different configurations depending on your\u001b[K\r\n * current environment. Setting the environment also influences\u001b[K\r\n * things like logging and error reporting.\u001b[K\r\n *\u001b[K\r\n * This can be set to anything, but default usage is:\u001b[K\r\n *\u001b[K\r\n *     development\u001b[K\r\n *     testing\u001b[K\r\n *     production\u001b[K\r\n *\u001b[K\r\n * NOTE: If you change these, also change the error_reporting() code below\u001b[K\r\n */\u001b[K\r\n        \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ENVIRONMENT'\u001b[m\u000f, isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'CI_ENV'\u001b[m\u000f]) ? $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'CI_ENV'\u001b[m\u000f] : \u001b[92m'development'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n        \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ROOTPATH'\u001b[m\u000f, \u001b[96mrealpath\u001b[m\u000f(\u001b[96mdirname\u001b[m\u000f(__FILE__)) . \u001b[92m'/'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n\u001b[K\n        // installed in the docroot?\u001b[K\r\n        \u001b[0;10;1m\u000fif\u001b[m\u000f (\u001b[96mrealpath\u001b[m\u000f(\u001b[96mdirname\u001b[m\u000f(__FILE__)) \u001b[0;10;1m\u000f==\u001b[m\u000f $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'DOCUMENT_ROOT'\u001b[m\u000f])\u001b[K\r\n        {\u001b[K\r\n                \u001b[96mdefine\u001b[m\u000f(\u001b[92m'ROOT'\u001b[m\u000f, \u001b[92m'/'\u001b[m\u000f);\u001b[K\r\n        }\u001b[K\r\n\u001b[0;10;7m\u000f/srv/http/arteri/index.php                                                                                                                                                                                                    1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
