[0.016, "o", "\u001b[H|       For the 'files' driver, it's a path to a writable directory.\r\n|       WARNING: Only absolute paths are supported!\u001b[12X\r\n|\r\n|       For the 'database' driver, it's a table name.\u001b[5;2H       Please read up the manual for the format with other session drivers.\u001b[6;2H\u001b[14X\n       IMPORTANT: You are REQUIRED to set a valid save path!\u001b[14X\u001b[9;3H'sess_match_ip'\u001b[52X\u001b[10;2H\u001b[23X\n       Whether to match the user's IP address when reading the session data.\u001b[12;2H\u001b[26X\n       WARNING: If you're using the database driver, don't forget to update\u001b[14;3H               your session table's PRIMARY KEY when changing this setting.\u001b[16;3H'sess_time_to_update'\u001b[50X\u001b[17;2H\u001b[73X\u001b[18;3H      How many seconds between CI regenerating the session ID.  \u001b[19;2H\u001b[64X\u001b[20;3H'sess_regenerate_destroy'\u001b[22X\u001b[22;3H      Whether to destroy session data associated with the old session ID\u001b[23;3H      when auto-regenerating the session ID. When set to FALSE, the data\u001b[24;2H       will be later deleted by the garbage collector.\r\n| \r\n| Other session cookie settings are shared with the rest of the application,\u001b[29X\r\n| except for 'cookie_prefix' and 'cookie_httponly', which are ignored here.\r\n| \r\n*/\u001b[73X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'sess_driver'\u001b[m\u000f] = \u001b[92m'files'\u001b[m\u000f;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'sess_cookie_name'\u001b[m\u000f] = \u001b[92m'arteri'\u001b[m\u000f;\u001b[36X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'sess_expiration'\u001b[m\u000f] = 7200;\r\n\u001b[30m\u001b[103m$config['sess_save\u001b[m\u000f\u001b[92m_path'\u001b[m\u000f] = NULL;\u001b[40X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'sess_match_ip'\u001b[m\u000f] = FALSE;\u001b[41X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'sess_time_to_update'\u001b[m\u000f] = 300;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'sess_regenerate_destroy'\u001b[m\u000f] = FALSE;\r\n  \r\n/*\u001b[34X\r\n|--------------------------------------------------------------------------\r\n| Cookie Related Variables\u001b[42;2H\u001b[13X\n 'cookie_prefix'   = Set a cookie name prefix if you need to avoid collisions\u001b[44;2H 'cookie_domain'   = Set to .your-domain.com for site-wide cookies\u001b[45;3H'cookie_path'     = Typically will be a forward slash\u001b[18X\u001b[46;3H'cookie_secure'   = Cookie will only be set if a secure HTTPS connection exists.\u001b[47;3H'cookie_httponly' = Cookie will only be accessible via HTTP(S) (no javascript)\u001b[49;3HNote: These settings (with the exception of 'cookie_prefix' and\u001b[50;3H      'cookie_httponly') will also affect sessions.\u001b[51;2H\u001b[44X\r\n*/\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_prefix'\u001b[m\u000f]        = \u001b[92m''\u001b[m\u000f;\u001b[38X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_domain'\u001b[m\u000f]        = \u001b[92m''\u001b[m\u000f;\u001b[55;10H\u001b[92mcookie_path'\u001b[m\u000f]          = \u001b[92m'/'\u001b[m\u000f;  \r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_secure'\u001b[m\u000f]        = FALSE;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_httponly'\u001b[m\u000f]      = FALSE;\r\n\u001b[75X\n/*\u001b[10X\u001b[61;2H Standardize newlines\u001b[62;2H--------------------------------------------------------------------------   \u001b[63;2H\u001b[48X\n Determines whether to standardize newline characters in input data,\u001b[65;3Hmeaning to replace \\r\\n, \\r, \\n occurrences with the PHP_EOL value.\u001b[66;223H\u001b[0;10;7m\u000f383,1          76%\u001b[67;20H\u001b[?25h"]
