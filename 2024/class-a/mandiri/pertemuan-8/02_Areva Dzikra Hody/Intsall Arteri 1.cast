[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[45;45H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; previously set variable or directive (e.g. ${foo})\u001b[45;45H"]
[0.431, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.270, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[45;45H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.000, "o", "; |  bitwise OR"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; ^  bitwise XOR"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; &  bitwise AND"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; ~  bitwise NOT"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; !  boolean NOT"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; Boolean flags can be turned on using the values 1, On, True or Yes.\u001b[45;45H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; They can be turned off using the values 0, Off, False or No.\u001b[45;45H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
