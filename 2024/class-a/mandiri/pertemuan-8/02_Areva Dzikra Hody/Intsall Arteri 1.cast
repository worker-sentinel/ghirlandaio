[0.000, "o", "; dynamically loaded extension (either a PHP extension or a Zend extension),\u001b[2;45H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; If you use constants in your value, and these constants belong to a\u001b[2;45H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.063, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; foo = \"None\"  ; sets foo to the string 'None'\b\b\b"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; foo = None    ; sets foo to an empty string\b"]
[0.014, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H; foo =\u001b[2;17H"]
[0.001, "o", "; sets foo to an empty string\b"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; sign, or by using the None keyword:"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; An empty string can be denoted by simply not writing anything after the equal\u001b[2;45H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; They can be turned off using the values 0, Off, False or No.\u001b[2;45H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; Boolean flags can be turned on using the values 1, On, True or Yes.\u001b[2;45H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; !  boolean NOT"]
[0.036, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; ~  bitwise NOT"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; &  bitwise AND"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; ^  bitwise XOR"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; |  bitwise OR"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[2;45H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.041, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; previously set variable or directive (e.g. ${foo})\u001b[2;45H"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[2;45H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[2;45H"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[2;45H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; directive because it is not set or is mistyped, a default value will be used.\u001b[2;45H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; There is no name validation.  If PHP can't find an expected\u001b[2;45H"]
[0.039, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Directives are variables used to configure PHP or PHP extensions.\u001b[2;45H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[2;45H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; directive = value"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Directives are specified using the following syntax:\u001b[2;45H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; https://php.net/ini.sections"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; CGI/FastCGI."]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; at runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[2;45H"]
[0.041, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; special sections cannot be overridden by user-defined INI files or\u001b[2;45H"]
[0.024, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H; PHP files served from www.example.com.  Directives set in these\u001b[2;45H"]
[0.040, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; following the section heading [HOST=www.example.com] only apply to\u001b[2;45H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; apply to PHP files in the /www/mysite directory.  Directives\u001b[2;45H"]
[0.037, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Directives following the section heading [PATH=/www/mysite] only\u001b[2;45H"]
