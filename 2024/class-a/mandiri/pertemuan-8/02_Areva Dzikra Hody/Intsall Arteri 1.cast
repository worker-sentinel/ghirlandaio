[0.001, "o", "\u001b[2;3Hhttps://php.net/default-socket-timeout\r\u001b[3ddefault_socket_timeout = 60\u001b[K\r\u001b[4d\u001b[K\u001b[5d; If your scripts have to deal with files from Macintosh systems,\r\u001b[6d; or you are running on a Mac and need to deal with files from\u001b[7;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[8;3Hautomatically detect the EOL character in those files so that\u001b[K\u001b[9;3Hfgets() and file() will work regardless of the source of the file.\r\u001b[10d; https://php.net/auto-detect-line-endings\r\u001b[11d;auto_detect_line_endings = Off\u001b[K\r\u001b[12d"]
[0.000, "o", "\u001b[K\u001b[13d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[14;3H"]
[0.000, "o", "Dynamic Extensions ;\u001b[K\r\u001b[15d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[16d\u001b[K\u001b[17d; If you wish to have an extension loaded automatically, use the following\r\u001b[18d"]
[0.000, "o", "; syntax:\u001b[19;3H"]
[0.000, "o", "\u001b[K\u001b[20d"]
[0.000, "o", "  extension=modulename\u001b[21;3H\u001b[K\r\u001b[22d; For example:\r\u001b[23d"]
[0.000, "o", ";\u001b[24d "]
[0.000, "o", "  \u001b[30m\u001b[43mextension=mysql\u001b[39;49m\u001b[m\u000fi\u001b[K\u001b[25;3H\u001b[K\r\u001b[26d"]
[0.000, "o", "; When the extension library to load is not located in the default extension\u001b[27;3Hdirectory,"]
[0.000, "o", " You may specify an absolute path to the library file:\r\u001b[28d;\u001b[K\u001b[29d\b"]
[0.000, "o", ";   extension=/path/to/extension/mysqli.so\u001b[30;3H"]
[0.000, "o", "\u001b[K\u001b[31d"]
