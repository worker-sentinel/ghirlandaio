[0.000, "o", "\r\u001b[2d|       ['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\r\u001b[3d|       ['failover'] array - A array with 0 or more data for connections if the main should fail.\r\u001b[4d|\u001b[9G['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\r\u001b[5d| \u001b[5;33HNOTE: Disabling this will also effectively disable both\u001b[6;3H\u001b[30X\u001b[6;33H$this->db->last_query() and profiling of DB queries.\u001b[7;3H\u001b[30X\u001b[7;33HWhen you run a query, with this setting set to TRUE (default),\u001b[8;3H\u001b[30X\u001b[8;33HCodeIgniter will store the SQL statement for debugging purposes.\u001b[9;3H\u001b[30X\u001b[9;33HHowever, this may cause high memory usage, especially if you run\u001b[10;33Ha lot of SQL queries ... disable this to avoid that problem.\u001b[11;3H\u001b[K\u001b[12d"]
[0.000, "o", "The $active_group variable lets you choose which connection group to\u001b[13;3Hmake active.  By default there is only one group (the 'default' group).\u001b[14;3H\u001b[K\u001b[15dThe $query_builder variables lets you determine whether or not to load\u001b[16;3Hthe query builder class.\u001b[K\r\u001b[17d*/\r\u001b[18d$active_group = 'default';\u001b[K\r\u001b[19d$query_builder = TRUE;\u001b[K\r\u001b[20d\u001b[K\u001b[21d$db['default'] = array(\u001b[K\u001b[22;8H\u001b[1K "]
