[0.000, "o", "\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H"]
[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d[PHP]\r\u001b[4d;;;;;;;;;;;;;;;;;;;\r\u001b[5d; About php.ini   ;\r\u001b[6d;;;;;;;;;;;;;;;;;;;\r\u001b[7d; PHP's initialization file, generally called php.ini, is responsible for\r\u001b[8d; configuring many of the aspects of PHP's behavior.\r\u001b[10d; PHP attempts to find and load this configuration from a number of locations.\r\u001b[11d"]
[0.001, "o", "; The following is a summary of its search order:\r\u001b[12d; 1. SAPI module specific location.\r\u001b[13d; 2. The PHPRC environment variable.\r\u001b[14d"]
[0.000, "o", "; 3. A number of predefined registry keys on Windows\r\u001b[15d; 4. Current working directory (except CLI)\r\u001b[16d"]
[0.000, "o", "; 5. The web server's directory (for SAPI modules), or directory of PHP\r\u001b[17d; (otherwise in Windows)\r\u001b[18d"]
[0.000, "o", "; 6. The directory from the --with-config-file-path compile time option, or the\r\u001b[19d; Windows directory (usually C:\\windows)\r\u001b[20d"]
[0.000, "o", "; See the PHP docs for more specific information.\r\u001b[21d; https://php.net/configuration.file\r\u001b[23d"]
[0.000, "o", "; The syntax of the file is extremely simple.  Whitespace and lines\r\u001b[24d; beginning with a semicolon are silently ignored (as you probably guessed).\r\u001b[25d"]
[0.000, "o", "; Section headers (e.g. [Foo]) are also silently ignored, even though\r\u001b[26d"]
[0.000, "o", "; they might mean something in the future.\r\u001b[28d; Directives following the section heading [PATH=/www/mysite] only\r\u001b[29d"]
[0.000, "o", "; apply to PHP files in the /www/mysite directory.  Directives\r\u001b[30d"]
[0.000, "o", "; following the section heading [HOST=www.example.com] only apply to\r\u001b[31d"]
[0.000, "o", "; PHP files served from www.example.com.  Directives set in these\r\u001b[32d; special sections cannot be overridden by user-defined INI files or\r\u001b[33d; at runtime. Currently, [PATH=] and [HOST=] sections only work under\r\u001b[34d; CGI/FastCGI.\r\u001b[35d"]
[0.000, "o", "; https://php.net/ini.sections\r\u001b[37d"]
[0.000, "o", "; Directives are specified using the following syntax:\r\u001b[38d"]
[0.000, "o", "; directive = value\r\u001b[39d"]
[0.000, "o", "; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\r\u001b[40d; Directives are variables used to configure PHP or PHP extensions.\r\u001b[41d; There is no name validation.  If PHP can't find an expected\r\u001b[42d"]
[0.000, "o", "; directive because it is not set or is mistyped, a default value will be used.\r\u001b[44d"]
[0.000, "o", "; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\r\u001b[45d"]
[0.000, "o", "; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\r\u001b[2d"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
