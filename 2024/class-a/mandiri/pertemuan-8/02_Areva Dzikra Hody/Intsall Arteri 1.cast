[2.605, "o", "\u001b[0;1;31mJob for mariadb.service failed because the control process exited with error code.\u001b[0m\r\r\n\u001b[0;1;31mSee \"systemctl status mariadb.service\" and \"journalctl -xeu mariadb.service\" for details.\u001b[0m\r\r\n"]
