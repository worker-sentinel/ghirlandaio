[0.001, "o", "\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                     /etc/httpd/conf/extra/httpd-vhosts.conf                                                                \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H"]
[0.000, "o", "\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H"]
[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b"]
[0.000, "o", "# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d#\u001b[19d\b"]
[0.000, "o", "# VirtualHost example:\r\u001b[20d# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d"]
[0.000, "o", "# The first VirtualHost section is used for all requests that do not\r\u001b[22d"]
[0.000, "o", "# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d"]
[0.000, "o", "#\u001b[24d\b"]
[0.000, "o", "<VirtualHost *:80>\u001b[25;3H"]
[0.000, "o", "DocumentRoot \"/srv/http/arteri\"\u001b[26;3H"]
[0.000, "o", "ServerName arteri.local\u001b[28;4H"]
[0.000, "o", "<Directory \"/srv/http/arteri\">\u001b[29;6H"]
[0.000, "o", "Options -Indexes +FollowSymLinks\u001b[30;6H"]
[0.000, "o", "AllowOveride All\u001b[31;6H"]
[0.000, "o", "Require all granted\u001b[32;4H"]
[0.000, "o", "</Directory>\u001b[34;4H"]
[0.000, "o", "<DirectoryMatch \"^/srv/http/arteri/(application|system|sql)\">\u001b[35;6H"]
[0.000, "o", "Require all denied\u001b[36;4H"]
[0.000, "o", "</DirectoryMatch>\u001b[38;4H<Filematch \"\\.php$\">\u001b[39;6H"]
[0.000, "o", "SetHandler \"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[40;4H</FileMatch>\u001b[42;4H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/arteri-error.log\"\u001b[43;4H"]
[0.000, "o", "CustomLog \"/var/log/httpd/arteri-access.log\" combined\r\u001b[44d"]
[0.000, "o", "</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
