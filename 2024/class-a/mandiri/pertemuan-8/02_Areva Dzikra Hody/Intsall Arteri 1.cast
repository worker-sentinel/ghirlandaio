[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; The unserialize_max_depth specifies the default depth limit for unserialized\u001b[2;45H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\r"]
