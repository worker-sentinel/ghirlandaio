[0.000, "o", "\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d"]
[0.000, "o", "# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d"]
[0.000, "o", "# for further details before you try to setup virtual hosts.\r\u001b[14d#\u001b[15d\b"]
[0.000, "o", "# You may use the command line option '-S' to verify your virtual host\r\u001b[16d# configuration.\r\u001b[18d"]
[0.000, "o", "#\u001b[19d\b"]
[0.000, "o", "# VirtualHost example:\r\u001b[20d"]
[0.000, "o", "# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d"]
[0.000, "o", "# The first VirtualHost section is used for all requests that do not\r\u001b[22d"]
[0.000, "o", "# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d"]
[0.000, "o", "#\u001b[24d\b"]
[0.000, "o", "<VirtualHost *:80>\u001b[25;5H"]
[0.000, "o", "ServerAdmin webmaster@dummy-host.example.com\u001b[26;5H"]
[0.000, "o", "DocumentRoot \"/etc/httpd/docs/dummy-host.example.com\"\u001b[27;5H"]
[0.000, "o", "ServerName dummy-host.example.com\u001b[28;5H"]
[0.000, "o", "ServerAlias www.dummy-host.example.com\u001b[29;5H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/dummy-host.example.com-error_log\"\u001b[30;5H"]
[0.000, "o", "CustomLog \"/var/log/httpd/dummy-host.example.com-access_log\" common\r\u001b[31d"]
[0.000, "o", "</VirtualHost>\r\u001b[33d"]
[0.000, "o", "<VirtualHost *:80>\u001b[34;5H"]
[0.000, "o", "ServerAdmin webmaster@dummy-host2.example.com\u001b[35;5H"]
[0.000, "o", "DocumentRoot \"/etc/httpd/docs/dummy-host2.example.com\"\u001b[36;5H"]
[0.000, "o", "ServerName dummy-host2.example.com\u001b[37;5H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/dummy-host2.example.com-error_log\"\u001b[38;5H"]
[0.000, "o", "CustomLog \"/var/log/httpd/dummy-host2.example.com-access_log\" common\r\u001b[39d"]
[0.000, "o", "</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
