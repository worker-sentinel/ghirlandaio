[0.000, "o", "\r\u001b[2d; https://php.net/default-socket-timeout\r\u001b[3ddefault_socket_timeout = 60\r\u001b[4d\u001b[K\u001b[5d; If your scripts have to deal with files from Macintosh systems,\r\u001b[6d; or you are running on a Mac and need to deal with files from\u001b[7;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[K\u001b[8;3H"]
[0.000, "o", "automatically detect the EOL character in those files so that\r\u001b[9d"]
[0.000, "o", "; fgets() and file() will work regardless of the source of the file.\u001b[10;3H"]
[0.000, "o", "https://php.net/auto-detect-line-endings\u001b[K\r\u001b[11d;auto_detect_line_endings = Off"]
[0.000, "o", "\u001b[K\r\u001b[12d\u001b[K\u001b[13d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[14;3H"]
[0.000, "o", "Dynamic Extensions ;\u001b[K\r\u001b[15d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[16d\u001b[K\u001b[17d; "]
[0.000, "o", "If you wish to have an extension loaded automatically, use the following\u001b[18;3Hsyntax:\u001b[K\u001b[19;3H\u001b[K\u001b[20d  extension=modulename\u001b[K\u001b[21;3H\u001b[K\r\u001b[22d; For example:\u001b[23;3H"]
[0.000, "o", "\u001b[K\r\u001b[24d"]
[0.000, "o", "\u001b[30m\u001b[43mextension=mysqli\u001b[39;49m\u001b[m\u000f\u001b[K\u001b[25;3H\u001b[K\u001b[26dWhen the extension library to load is not located in the default extension\r\u001b[27d; directory, You may specify an absolute path to the library file:\u001b[28;3H\u001b[K\u001b[29d"]
[0.000, "o", "  extension=/path/to/extension/mysqli.so\u001b[K\u001b[30;3H"]
[0.000, "o", "\u001b[K\u001b[31d"]
[0.000, "o", "Note : The syntax used in previous PHP versions ('extension=<ext>.so' and\u001b[32;3H"]
[0.000, "o", "'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[33;3H"]
[0.001, "o", "deprecated in a future PHP major version. So, when it is possible, please\u001b[34;3Hmove to the new ('extension=<ext>) syntax.\u001b[35;3H"]
[0.000, "o", "\u001b[K\r\u001b[36d;extension=bcmath\r\u001b[37d;extension=bz2\u001b[K\r\u001b[38d;"]
[0.000, "o", "extension=calendar\r\u001b[39d"]
[0.000, "o", "extension=curl\u001b[K\r\u001b[40d;extension=dba"]
[0.000, "o", "\u001b[K\r\u001b[41d;extension=enchant\u001b[K\r\u001b[42d;"]
[0.000, "o", "extension=exif\u001b[K\r\u001b[43d;extension=ffi\r\u001b[44d;"]
[0.000, "o", "extension=ftp\u001b[K\r\u001b[45d"]
[0.000, "o", "extension=gd\u001b[K\r\u001b[24d"]
