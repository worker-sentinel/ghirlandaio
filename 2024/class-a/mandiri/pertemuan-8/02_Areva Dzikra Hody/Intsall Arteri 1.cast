[0.000, "o", "\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.001, "o", "\u001b[2;3HUNIX: \"/path1:/path2\"\r\u001b[3d;include_path = \".:/php/includes\"\r\u001b[4d;\u001b[5d Windows: \"\\path1;\\path2\"\u001b[K\r\u001b[6d;include_path = \".;c:\\php\\includes\"\r\u001b[7d;\u001b[8d PHP's default setting for include_path is \".;/path/to/php/pear\"\u001b[K\u001b[9;3Hhttps://php.net/include-path\r\u001b[10d\u001b[K\u001b[11d; "]
[0.000, "o", "The root of the PHP pages, used only if nonempty.\r\u001b[12d; if PHP was not compiled with FORCE_REDIRECT, you SHOULD set doc_root\r\u001b[13d"]
[0.000, "o", "; if you are running php as a CGI under any web server (other than IIS)\u001b[14;3H"]
[0.000, "o", "see documentation for security issues.  The alternate is to use the\u001b[K\u001b[15;3H"]
[0.000, "o", "cgi.force_redirect configuration below\u001b[16;19H"]
[0.000, "o", "doc-root\u001b[K\r\u001b[17ddoc_root =\r\u001b[18d"]
[0.000, "o", "\u001b[K\u001b[19d; The directory under which PHP opens the script using /~username used only\u001b[20;3H"]
[0.000, "o", "if nonempty.\u001b[K\u001b[21;3Hhttps://php.net/user-dir\r\u001b[22d"]
[0.000, "o", "user_dir =\u001b[K\r\u001b[23d"]
[0.000, "o", "\u001b[K\u001b[24d;"]
[0.000, "o", " Directory in which the loadable \u001b[30m\u001b[43mextension\u001b[39;49m\u001b[m\u000fs (modules) reside.\u001b[25;3Hhttps://php.net/extension-dir\u001b[K\r\u001b[26dextension_dir = \"/usr/lib/php/modules/\"\r\u001b[27d"]
[0.000, "o", "; On windows:\r\u001b[28d;"]
[0.000, "o", "extension_dir = \"ext\"\u001b[K\r\u001b[29d"]
[0.000, "o", "\u001b[K\u001b[30d;"]
[0.000, "o", " Directory where the temporary files should be placed.\r\u001b[31d"]
[0.000, "o", "; Defaults to the system default (see sys_get_temp_dir)\r\u001b[32d;sys_temp_dir = \"/tmp\"\u001b[K\r\u001b[33d"]
[0.000, "o", "\u001b[K\u001b[34d; Whether or not to enable the dl() function.  The dl() function does NOT work\r\u001b[35d"]
[0.000, "o", "; properly in multithreaded servers, such as IIS or Zeus, and is automatically\u001b[36;3Hdisabled on them"]
[0.000, "o", ".\u001b[K\u001b[37;3H"]
[0.000, "o", "https://php.net/enable-dl\u001b[K\r\u001b[38d"]
[0.000, "o", "enable_dl = Off\u001b[K\r\u001b[39d"]
[0.000, "o", "\u001b[K\u001b[40d; "]
[0.000, "o", "cgi.force_redirect is necessary to provide security running PHP as a CGI under\u001b[41;3H"]
[0.000, "o", "most web servers.  Left undefined, PHP turns this on by default.  You can\u001b[42;3Hturn it off here AT YOUR OWN RISK\u001b[K\u001b[43;3H"]
[0.000, "o", "**You CAN safely turn this off for IIS, in fact, you MUST.**\u001b[44;3H"]
[0.000, "o", "https://php.net/cgi.force-redirect\u001b[K\r\u001b[45d;cgi.force_redirect = 1\u001b[K\u001b[24;35H"]
