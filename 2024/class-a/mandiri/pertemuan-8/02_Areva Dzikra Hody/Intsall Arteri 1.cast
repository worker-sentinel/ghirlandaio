[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; Note: You need to use zlib.output_handler instead of the standard\u001b[45;45H"]
