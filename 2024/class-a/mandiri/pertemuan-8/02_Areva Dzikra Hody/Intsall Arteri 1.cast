[0.000, "o", "\r\u001b[2d# Virtual Hosts\r\u001b[3d#\u001b[4d\b# Required modules: mod_log_config\r\u001b[6d# If you want to maintain multiple domains/hostnames on your\r\u001b[7d# machine you can setup VirtualHost containers for them. Most configurations\r\u001b[8d# use only name-based virtual hosts so the server doesn't need to worry about\r\u001b[9d# IP addresses. This is indicated by the asterisks in the directives below.\r\u001b[10d#\u001b[11d\b# Please see the documentation at\r\u001b[12d# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\r\u001b[13d"]
[0.000, "o", "# for further details before you try to setup virtual hosts.\r\u001b[14d"]
[0.000, "o", "#\u001b[15d\b"]
[0.000, "o", "# You may use the command line option '-S' to verify your virtual host\r\u001b[16d"]
[0.000, "o", "# configuration.\r\u001b[18d"]
[0.000, "o", "#\u001b[19d\b"]
[0.000, "o", "# VirtualHost example:\r\u001b[20d"]
[0.000, "o", "# Almost any Apache directive may go into a VirtualHost container.\r\u001b[21d# The first VirtualHost section is used for all requests that do not\r\u001b[22d"]
[0.000, "o", "# match a ServerName or ServerAlias in any <VirtualHost> block.\r\u001b[23d"]
[0.000, "o", "#\u001b[24d\b"]
[0.000, "o", "<VirtualHost *:80>\u001b[25;5H"]
[0.000, "o", "DocumentRoot \"/srv/http/arteri\"\u001b[26;5H"]
[0.000, "o", "ServerName arteri.local\u001b[28;4H"]
[0.000, "o", "<Directory \"/srv/http/arteri\">\u001b[29;6HOptions -Indexes +FollowSymLinks\u001b[30;6H"]
[0.000, "o", "AllowOveride All\u001b[31;6H"]
[0.000, "o", "Require all granted\u001b[32;4H"]
[0.000, "o", "</Directory>\u001b[34;4H"]
[0.000, "o", "<DirectoryMatch \"^/srv/http/arteri/(application|system|sql)\">\u001b[35;6H"]
[0.000, "o", "Require all denied\u001b[36;4H"]
[0.000, "o", "</DirectoryMatch>\u001b[38;4H<Filematch \"\\.php$\">\u001b[39;6HSetHandler \"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[40;4H"]
[0.000, "o", "</FileMatch>\u001b[42;4H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/arteri-error.log\"\u001b[43;4H"]
[0.000, "o", "CustomLog \"/var/log/httpd/arteri-access.log\" combined\r\u001b[44d</VirtualHost>\r\u001b[2d\u001b[?25h\u001b[?0c"]
