[0.001, "o", "\r\u001b[K\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute       \u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d; https://php.net/default-socket-timeout\r\u001b[3ddefault_socket_timeout = 60\r\u001b[4d\u001b[K\u001b[5d; If your scripts have to deal with files from Macintosh systems,\r\u001b[6d; or you are running on a Mac and need to deal with files from\u001b[7;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[K\u001b[8;3Hautomatically detect the EOL character in those files so that\r\u001b[9d; fgets() and file() will work regardless of the source of the file.\u001b[10;3Hhttps://php.net/auto-detect-line-endings\u001b[K\r\u001b[11d;auto_detect_line_endings = Off\u001b[K\r\u001b[12d\u001b[K\u001b[13d;"]
[0.000, "o", ";;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[14;3H"]
[0.000, "o", "Dynamic Extensions ;\u001b[K\r\u001b[15d;"]
[0.001, "o", ";;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[16d"]
[0.000, "o", "\u001b[K\u001b[17d; "]
[0.000, "o", "If you wish to have an extension loaded automatically, use the following\u001b[18;3Hsyntax:\u001b[K\u001b[19;3H"]
[0.000, "o", "\u001b[K\u001b[20d"]
[0.000, "o", "  extension=modulename\u001b[K\u001b[21;3H\u001b[K\r\u001b[22d"]
[0.000, "o", "; For example:\u001b[23;3H\u001b[K\r\u001b[24d"]
[0.000, "o", "\u001b[30m\u001b[43mextension=mysql\u001b[39;49m\u001b[m\u000fi\u001b[K\u001b[25;3H"]
[0.000, "o", "\u001b[K\u001b[26d"]
[0.000, "o", "When the extension library to load is not located in the default extension\r\u001b[27d"]
[0.000, "o", "; directory, You may specify an absolute path to the library file:\u001b[28;3H"]
[0.000, "o", "\u001b[K\u001b[29d"]
[0.000, "o", "  extension=/path/to/extension/mysqli.so\u001b[K\u001b[30;3H"]
[0.000, "o", "\u001b[K\u001b[31dNote : The syntax used in previous PHP versions ('extension=<ext>.so' and\u001b[32;3H"]
[0.000, "o", "'extension='php_<ext>.dll') is supported for legacy reasons and may be\u001b[33;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[34;3Hmove to the"]
[0.000, "o", " new ('extension=<ext>) syntax.\u001b[35;3H\u001b[K\r\u001b[36d"]
[0.000, "o", ";extension=bcmath\r\u001b[37d;"]
[0.000, "o", "extension=bz2\u001b[K\r\u001b[38d;"]
[0.000, "o", "extension=calendar\r\u001b[39dextension=curl\u001b[K\r\u001b[40d;"]
[0.000, "o", "extension=dba\u001b[K\r\u001b[41d;"]
[0.000, "o", "extension=enchant\u001b[K\r\u001b[42d;"]
