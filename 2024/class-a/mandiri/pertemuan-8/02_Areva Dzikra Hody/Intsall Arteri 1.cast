[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.284, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; The unserialize_max_depth specifies the default depth limit for unserialized\u001b[45;45H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.000, "o", "; structures. Setting the depth limit too high may result in stack overflows\u001b[45;45H"]
[0.044, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.000, "o", "; during unserialization. The unserialize_max_depth ini setting can be\u001b[45;45H"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; overridden by the max_depth option on individual unserialize() calls.\u001b[45;45H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; A value of 0 disables the depth limit."]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;unserialize_max_depth = 4096"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
