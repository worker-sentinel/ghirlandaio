[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; in production environments and one that is recommended to be used in\u001b[2;45H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; PHP comes packaged with two INI files. One that is recommended to be used\u001b[2;45H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;45r\u001b8\r"]
