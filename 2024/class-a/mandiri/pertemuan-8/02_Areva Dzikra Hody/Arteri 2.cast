[0.000, "o", "\r\u001b[2d<?php\r\u001b[3ddefined('BASEPATH') OR exit('No direct script access allowed');\r\u001b[5d/*\r\u001b[6d|--------------------------------------------------------------------------\r\u001b[7d| Base Site URL\r\u001b[8d|--------------------------------------------------------------------------\r\u001b[9d|\u001b[10d\b"]
[0.000, "o", "| URL to your CodeIgniter root. Typically this will be your base URL,\r\u001b[11d| WITH a trailing slash:\r\u001b[12d|\u001b[13d\b|\u001b[9Ghttp://example.com/\r\u001b[14d"]
[0.001, "o", "|\u001b[15d\b| WARNING: You MUST set this value!\r\u001b[16d"]
[0.000, "o", "|\u001b[17d\b| If it is not set, then CodeIgniter will try guess the protocol and path\r\u001b[18d"]
[0.000, "o", "| your installation, but due to security concerns the hostname will be set\r\u001b[19d| to $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\r\u001b[20d"]
[0.000, "o", "| The auto-detection mechanism exists only for convenience during\r\u001b[21d"]
[0.000, "o", "| development and MUST NOT be used in production!\r\u001b[22d"]
[0.000, "o", "|\u001b[23d\b"]
[0.000, "o", "| If you need to allow multiple domains, remember that this file is still\r\u001b[24d| a PHP script and you can easily do that on your own.\r\u001b[25d"]
[0.000, "o", "|\u001b[26d\b"]
[0.000, "o", "*/\r\u001b[27d"]
[0.000, "o", "$config['base_url'] = (isset($_SERVER['HTTPS']) ? \"https://\" : \"http://\") . $_SERVER['HTTP_HOST'] . ROOT;\r\u001b[29d/*\r\u001b[30d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[31d| Index File\r\u001b[32d"]
[0.000, "o", "|--------------------------------------------------------------------------\r\u001b[33d|\u001b[34d\b| Typically this will be your index.php file, unless you've renamed it to\r\u001b[35d"]
[0.000, "o", "| something else. If you are using mod_rewrite to remove the page set this\r\u001b[36d"]
[0.000, "o", "| variable so that it is blank.\r\u001b[37d"]
[0.000, "o", "|\u001b[38d\b"]
[0.000, "o", "*/\r\u001b[39d$config['index_page'] = 'index.php';\r\u001b[41d"]
