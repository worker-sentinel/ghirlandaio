[0.000, "o", "\u001b[2;3Hsecurity context that the request runs under.  mod_fastcgi under Apache\r\u001b[3d; does not currently support this feature (03/17/2002)\r\u001b[4d; Set to 1 if running under IIS.  Default is zero.\r\u001b[5d; https://php.net/fastcgi.impersonate\r\u001b[6d;fastcgi.impersonate = 1\r\u001b[7d\u001b[K\u001b[8d"]
[0.000, "o", "; Disable logging through FastCGI connection. PHP's default behavior is to enable\u001b[9;3Hthis feature.\u001b[K\r\u001b[10d;fastcgi.logging = 0\u001b[K\r\u001b[11d\u001b[K\u001b[12d; cgi.rfc2616_headers configuration option tells PHP what type of headers to\r\u001b[13d"]
[0.000, "o", "; use when sending HTTP response code. If set to 0, PHP sends Status: header that\u001b[14;3His supported by Apache. When this option is set to 1, PHP will send\u001b[K\u001b[15;3HRFC2616 compliant header.\u001b[K\u001b[16;3HDefault is zero.\u001b[K\u001b[17;3Hhttps://php.net/cgi.rfc2616-headers\u001b[K\r\u001b[18d;cgi.rfc2616_headers = 0\u001b[K\r\u001b[19d\u001b[K\u001b[20d; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\u001b[21;3H(shebang) at the top of the running script. This line might be needed if the\r\u001b[22d; script support running both as stand-alone script and via PHP CGI<. PHP in CGI\r\u001b[23d; mode skips this line and ignores its content if this directive is turned on.\u001b[24;3Hhttps://php.net/cgi.check-shebang-line\r\u001b[25d;cgi.check_shebang_line=1\u001b[K\r\u001b[26d\u001b[K\u001b[27d;;;;;;;;;;;;;;;;\u001b[28;3HFile Uploads ;\u001b[K\r\u001b[29d;;;;;;;;;;;;;;;;\u001b[K\u001b[31;3HWhether to allow HTTP file uploads.\u001b[K\u001b[32;3H"]
[0.001, "o", "https://php.net/file-uploads\r\u001b[33d\u001b[30m\u001b[43mfile_uploads\u001b[39;49m\u001b[m\u000f = On\u001b[K\r\u001b[34d\u001b[K\u001b[35d; Temporary directory for HTTP uploaded files (will use system default if not\u001b[36;3Hspecified).\u001b[K\u001b[37;19Hupload-tmp-dir\r\u001b[38d;upload_tmp_dir =\u001b[K\r\u001b[40d; Maximum allowed size for uploaded files.\u001b[41;3Hhttps://php.net/upload-max-filesize\r\u001b[42dupload_max_filesize = 2M\u001b[K\u001b[44;3HMaximum number of files that can be uploaded via a single request\u001b[K\r\u001b[45dmax_file_uploads = 20\u001b[K\r\u001b[46d\u001b[K\u001b[47d;;;;;;;;;;;;;;;;;;\u001b[K\u001b[48;3HFopen wrappers ;\u001b[K\r\u001b[49d;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[50d\u001b[K\u001b[51d; Whether to allow the treatment of URLs (like http:// or ftp://) as files.\u001b[52;3Hhttps://php.net/allow-url-fopen\u001b[K\r\u001b[53dallow_url_fopen = On\u001b[K\r\u001b[54d\u001b[K\u001b[55d; Whether to allow include/require to open URLs (like https:// or ftp://) as files.\u001b[56;3Hhttps://php.net/allow-url-include\u001b[K\r\u001b[57dallow_url_include = Off\u001b[K\r\u001b[58d\u001b[K\u001b[59d; Define the anonymous ftp password (your email address). PHP's default setting\u001b[60;3Hfor this is empty.\u001b[K\u001b[61;3Hhttps://php.net/from\u001b[K\r\u001b[62d;from=\"john@doe.com\"\u001b[K\r\u001b[63d\u001b[K\u001b[64d; Define the User-Agent string. PHP's default setting for this is empty.\r\u001b[33d"]
