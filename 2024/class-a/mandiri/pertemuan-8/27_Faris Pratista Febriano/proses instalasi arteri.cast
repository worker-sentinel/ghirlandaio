[0.000, "o", "; Strict session mode does not accept an uninitialized session ID, and\u001b[2;38H"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Whether to use strict session mode."]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";session.save_path = \"/tmp\""]
[0.023, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.save-path"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; does not overwrite the process's umask.\b\b\b\b"]
[0.021, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; where MODE is the octal representation of the mode. Note that this\u001b[2;38H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";     session.save_path = \"N;MODE;/path\"\b\b\b"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; You can change that by using"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; The file storage module creates files using mode 600 by default.\u001b[2;38H"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";"]
[0.027, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H;\u001b[2;11H"]
[0.001, "o", "use subdirectories for session storage\u001b[2;38H"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; NOTE 2: See the section on garbage collection below if you choose to\u001b[2;38H"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H;\u001b[2;11H"]
[0.001, "o", "You can use the script in the ext/session dir for that purpose.\u001b[2;38H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; NOTE 1: PHP will not create this directory structure automatically.\u001b[2;38H"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; a more efficient layout for servers that handle many sessions.\u001b[2;38H"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; your OS has problems with many files in one directory, and is\u001b[2;38H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; store the session data in those directories.  This is useful if\u001b[2;38H"]
[0.024, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; /path, what this will do is use subdirectories N-levels deep, and\u001b[2;38H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; where N is an integer.  Instead of storing all the session files in\u001b[2;38H"]
[0.023, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";     session.save_path = \"N;/path\""]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; The path can be defined as:"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";"]
[0.021, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; variable in order to use PHP's session functions.\u001b[2;38H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; where data files are stored. Note: Windows users have to change this\u001b[2;38H"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Argument passed to save_handler.  In the case of files, this is the path\u001b[2;38H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "session.save_handler = files"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.save-handler\b"]
[0.023, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Handler used to store/retrieve data.\b"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "[Session]"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.023, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;browscap = extra/browscap.ini"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/browscap"]
[0.021, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "[browscap]"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.023, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "bcmath.scale = 0"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/bcmath.scale"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; Number of decimal digits for all bcmath functions.\u001b[2;38H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "[bcmath]"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hpgsql.log_notice = 0"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; https://php.net/pgsql.log-notice"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Unless pgsql.ignore_notice=0, module cannot log notice message.\u001b[2;38H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Log PostgreSQL backends Notice message or not.\u001b[2;38H"]
[0.020, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "pgsql.ignore_notice = 0"]
[0.023, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/pgsql.ignore-notice"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Notice message logging require a little overheads.\u001b[2;38H"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Ignore PostgreSQL backends Notice message or not.\u001b[2;38H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.022, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "pgsql.max_links = -1"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/pgsql.max-links"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Maximum number of links (persistent+non persistent).  -1 means no limit.\u001b[2;38H"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "pgsql.max_persistent = -1"]
[0.020, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/pgsql.max-persistent\b"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Maximum number of persistent links.  -1 means no limit.\u001b[2;38H"]
[0.022, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "pgsql.auto_reset_persistent = Off"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/pgsql.auto-reset-persistent\u001b[2;38H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
