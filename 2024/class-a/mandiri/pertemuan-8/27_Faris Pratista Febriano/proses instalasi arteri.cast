[0.001, "o", "</If\u001b[11G>\u001b[K\u001b[23d dav_fs_module modules/mod_dav_fs.so\u001b[K\u001b[24;13Hdav_lock_module modules/mod_dav_lock.so\u001b[K\u001b[25;13Hvhost_alias_module modules/mod_vhost_alias.so\u001b[26;12Hnegotiation_module modules/mod_negotiation.so\r\u001b[27dLoadModule dir_module modules/mod_dir.so\u001b[K\u001b[28;13Himagemap_module modules/mod_imagemap.so\u001b[K\u001b[29;13Hactions_module modules/mod_actions.so\u001b[K\r\u001b[30d#LoadModule speling\u001b[30;41Hpeling.so\u001b[K\u001b[31;12Huserdir\u001b[31;39Huserdir\r\u001b[32dLoadModule alias_module modules/mod_alias.so\u001b[K\r\u001b[33d#LoadModule \u001b[30m\u001b[43mrewrite\u001b[39;49m\u001b[m\u000f_module modules/mod_rewrite.so\r\u001b[34d\u001b[K\u001b[35d<IfModule unixd_module>\u001b[K\r\u001b[36d#\u001b[K\u001b[37d\b# If you wish httpd to run as a different user or group, you must run\r\u001b[38d# httpd as root initially and it will switch.\u001b[K\r\u001b[39d#\u001b[K\u001b[40d User/Group: The name (or #number) of the user/group to run httpd as.\r\u001b[41d# It is usually good practice to create a dedicated user and group for\r\u001b[42d# running httpd, as with most system services.\u001b[K\r\u001b[43d#\u001b[K\u001b[44d\bUser http\u001b[K\r\u001b[45dGroup http\u001b[K\r\u001b[46d\u001b[K\u001b[47d</IfModule>\u001b[K\r\u001b[48d\u001b[K\u001b[49d# 'Main' server configuration\u001b[K\r\u001b[50d#\u001b[K\u001b[51d The directives in this section set up the values used by the 'main'\r\u001b[52d# server, which responds to any requests that aren't handled by a\r\u001b[53d# <VirtualHost> definition.  These values also provide defaults for\r\u001b[54d#"]
[0.000, "o", " any <VirtualHost> containers you may define later in the file.\r\u001b[55d#\u001b[K\u001b[56d All of these directives may appear inside <VirtualHost> containers,\r\u001b[57d# in which case these default settings will be overridden for the\u001b[K\r\u001b[58d# virtual host being defined.\u001b[K\r\u001b[59d#\u001b[K\u001b[60d\b\u001b[K\u001b[61d#\u001b[K\u001b[62d ServerAdmin: Your address, where problems with the server should be\r\u001b[63d# e-mailed.  This address appears on some server-generated pages, such\r\u001b[64d# as error documents.  e.g. admin@your-domain.com\u001b[33;13H"]
