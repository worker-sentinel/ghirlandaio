[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\r\u001b[2d; https://php.net/expose-php\r\u001b[3dexpose_php = On\r\u001b[4d\u001b[K\u001b[5d;;;;;;;;;;;;;;;;;;\r\u001b[6d; Resource Limits \r\u001b[7d;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[8d\u001b[K\u001b[9d; Maximum execution time of each script, in seconds\u001b[10;3Hhttps://php.net/max-execution-time\u001b[K\u001b[11;3HNote: This directive is hardcoded to 0 for the CLI SAPI\r\u001b[12dmax_execution_time = 30\u001b[K\r\u001b[13d\u001b[K\u001b[14d; "]
[0.000, "o", "Maximum amount of time each script may spend parsing request data. It's a good\u001b[15;3Hidea to limit this time on productions servers in order to eliminate unexpectedly\u001b[16;3Hlong running scripts.\u001b[K\u001b[17;3HNote: This directive is hardcoded to -1 for the CLI SAPI\u001b[18;3HDefault Value: -1 (Unlimited)\u001b[K\u001b[19;3HDevelopment Value: 60 (60 seconds)\u001b[K\u001b[20;3HProduction Value: 60 (60 seconds)\u001b[K\u001b[21;19Hmax-input-time\u001b[K\r\u001b[22dmax_input_time = 60\r\u001b[23d\u001b[K\u001b[24d; Maximum input variable nesting level\u001b[K\u001b[25;3Hhttps://php.net/max-input-nesting-level\u001b[K\r\u001b[26d;max_input_nesting_level = 64\u001b[K\u001b[28;3HHow many GET/POST/COOKIE input variables may be accepted\u001b[K\r\u001b[29d;max_input_vars = 1000\u001b[K\r\u001b[30d\u001b[K\u001b[31d; How many multipart body parts (combined input variable and file uploads) may\u001b[32;3Hbe accepted.\u001b[K\u001b[33;3HDefault Value: -1 (Sum of max_input_vars and max_\u001b[30m\u001b[43mfile_uploads\u001b[39;49m\u001b[m\u000f)\u001b[K\r\u001b[34d;max_multipart_body_parts = 1500\r\u001b[35d\u001b[K\u001b[36d"]
[0.001, "o", "; Maximum amount of memory a script may consume\u001b[37;3Hhttps://php.net/memory-limit\u001b[K\r\u001b[38dmemory_limit = 128M\r\u001b[39d\u001b[K\u001b[40d;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[41;3HError handling and logging ;\u001b[K\r\u001b[42d;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[44;5His directive informs PHP of which errors, warnings and notices you would like\u001b[45;3Hit to take action for. The recommended way of setting values for this\u001b[K\u001b[46;3Hdirective is through the use of the error level constants and bitwise\u001b[K\u001b[47;3Hoperators. The error level constants are below here for convenience as well as\r\u001b[48d; some common settings and their meanings.\u001b[49;3HBy default, PHP is set to take action on all errors, notice\u001b[68Gwarnings EXCEPT\u001b[50;3Hthose related to E_NOTICE and E_STRICT, which together cover best practices and\u001b[51;3Hrecommended coding standards in PHP. For performance reasons, this is the\u001b[52;3Hrecommend error reporting setting. Your production server shouldn't be wasting\u001b[53;3Hresources complaining about best practices and coding standards. That's what\u001b[54;3Hdevelopment servers and development settings are for.\r\u001b[55d; Note: The php.ini-development file has this setting as E_ALL. This\u001b[56;3Hmeans it pretty much reports everything which is exactly what you want during\u001b[57;3Hdevelopment and early testing.\u001b[K\r\u001b[58d;\u001b[59d Error Level Constants:\u001b[K\u001b[60;3HE_ALL             - All errors and warnings\r\u001b[61d; E_ERROR\u001b[61;21H- fatal run-time errors\u001b[62;3HE_RECOVERABLE_ERROR  - almost fatal run-time errors\u001b[63;3HE_WARNING         - run-time warnings (non-fatal errors)\u001b[64;3HE_PARSE           - compile-time parse errors\u001b[33;52H"]
