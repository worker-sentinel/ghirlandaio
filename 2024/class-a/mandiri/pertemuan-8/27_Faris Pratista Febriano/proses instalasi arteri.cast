[0.000, "o", "    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\u001b[9d    #\r\u001b[10d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[11d    # doesn't give it to you.\u001b[K\r\u001b[12d    #\u001b[K\r\u001b[13d    # The Options directive is both complicated and important.  Please see\r\u001b[14d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\u001b[K\r\u001b[15d    # for more information.\u001b[K\r\u001b[16d    #\u001b[K\r\u001b[17d    Options Indexes FollowSymLinks\u001b[K\r\u001b[18d\u001b[K\u001b[19d    #\u001b[K\r\u001b[20d    # AllowOverride controls what directives may be placed in .htaccess files.\u001b[21;5H# It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[22d    #   AllowOverride FileInfo AuthConfig Limit\r\u001b[23d    #\u001b[K\r\u001b[24d    AllowOverride None\u001b[K\r\u001b[25d"]
[0.000, "o", "\u001b[K\u001b[26d    #\u001b[K\r\u001b[27d    # Controls who can get stuff from this server.\u001b[K\r\u001b[28d    #\u001b[K\r\u001b[29d    Require all granted\u001b[K\r\u001b[30d</Directory>\u001b[K\r\u001b[31d\u001b[K\u001b[32d#\u001b[K\u001b[33d\b# \u001b[30m\u001b[43mDirectoryIndex\u001b[39;49m\u001b[m\u000f: sets the file that Apache will serve if a directory\u001b[34;3His requested.\u001b[35;3H\u001b[K\r\u001b[36d<IfModule dir_module>\u001b[K\r\u001b[37d    DirectoryIndex index.html\r\u001b[38d</IfModule>\u001b[K\r\u001b[39d\u001b[K\u001b[40d# \u001b[K\u001b[41dThe following lines prevent .htaccess and .htpasswd files from being\u001b[42;3Hviewed by Web clients.\u001b[K\r\u001b[43d#\u001b[44d\b<Files \".ht*\">\r\u001b[45d    Require all denied\u001b[K\r\u001b[46d</Files>\u001b[K\r\u001b[47d\u001b[K\u001b[49d# ErrorLog: The location of the error log file.\u001b[K\u001b[50;3HIf you do not specify an ErrorLog directive within a <VirtualHost>\u001b[51;3Hcontainer, error messages relating to that virtual host will be\r\u001b[52d# logged here.  If you *do* define an error logfile for a <VirtualHost>\r\u001b[53d# container, that host's errors will be logged there and not here.\r\u001b[54d#\u001b[55d\bErrorLog \"/var/log/httpd/error_log\"\r\u001b[56d\u001b[K\u001b[58d# LogLevel: Control the number of messages logged to the error_log.\u001b[K\u001b[59;3HPossible values include: debug, info, notice, warn, error, crit,\u001b[K\u001b[60;3Halert, emerg.\u001b[K\u001b[61;3H\u001b[K\r\u001b[62dLogLevel warn\u001b[K\r\u001b[63d\u001b[K\u001b[64d<IfModule log_config_module>\u001b[33;3H"]
