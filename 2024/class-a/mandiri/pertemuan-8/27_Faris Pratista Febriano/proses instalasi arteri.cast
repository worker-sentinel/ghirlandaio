[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
