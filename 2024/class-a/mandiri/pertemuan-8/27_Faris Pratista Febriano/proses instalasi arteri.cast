[0.000, "o", "\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d;\u001b[3d     session.save_path = \"N;/path\"\u001b[K\u001b[4;3H\u001b[K\u001b[5dwhere N is an integer.  Instead of storing all the session files in\u001b[K\u001b[6;3H/path, what this will do is use subdirectories N-levels deep, and\u001b[K\u001b[7;3Hstore the session data in those directories.  This is useful if\r\u001b[8d; your OS has problems with many files in one directory, and is\r\u001b[9d; a more efficient layout for servers that handle many sessions.\u001b[10;3H\u001b[K\u001b[11d"]
[0.000, "o", "NOTE 1: PHP will not create this directory structure automatically.\r\u001b[12d;         You can use the script in the ext/session dir for that purpose.\r\u001b[13d; NOTE 2: See the section on garbage collection below if you choose to\u001b[14;3H        use subdirectories for session storage\u001b[15;3H\u001b[K\r\u001b[16d; The file storage module creates files using mode 600 by default.\r\u001b[17d; You can change that by using\u001b[18;3H\u001b[K\u001b[19d    session.save_path = \"N;MODE;/path\"\u001b[K\r\u001b[20d;\u001b[K\u001b[21d\b; where MODE is the octal representation of the mode. Note that this\u001b[22;3Hdoes not overwrite the process's umask\u001b[23;27Hsav\u001b[2P\r\u001b[24d;session.save_path = \"/tmp\"\u001b[26;3HWhether to use strict session mode.\u001b[K\u001b[27;3HStrict session mode does not accept an uninitialized session ID, and\r\u001b[28d; regenerates the session ID if the browser sends an uninitialized session ID.\r\u001b[29d; Strict mode protects applications from session fixation via a session adoption\u001b[30;3Hvulnerability. It is disabled by default for maximum compatibility, but\u001b[31;3Henabling it is encouraged"]
[0.000, "o", ".\u001b[K\u001b[32;11Hwiki.php.net/rfc/strict_sessions\r\u001b[33d\u001b[30m\u001b[43msession.use_strict_mode\u001b[39;49m\u001b[m\u000f = 0\u001b[35;3HWhether to use cookies.\u001b[K\u001b[36;3Hhttps://php.net/session.use-cookies\u001b[K\r\u001b[37dsession.use_cookies = 1\u001b[K\r\u001b[38d\u001b[K\u001b[39d; https://php.net/session.cookie-secure\r\u001b[40d;session.cookie_secure =\r\u001b[41d\u001b[K\u001b[42d; This option forces PHP to fetch and use a cookie for storing and maintaining\r\u001b[43d; the session id. We encourage this operation as it's very helpful in combating\r\u001b[44d; session hijacking when not specifying and managing your own session id. It is\u001b[45;3Hnot the be-all and end-all of session hijacking defense, but it's a good start.\u001b[K\u001b[46;3Hhttps://php.net/session.use-only-cookies\u001b[K\r\u001b[47dsession.use_only_cookies = 1\u001b[K\r\u001b[48d\u001b[K\u001b[49d; Name of the session (used as cookie name).\u001b[50;3Hhttps://php.net/session.name\r\u001b[51dsession.name = PHPSESSID\u001b[K\r\u001b[52d\u001b[K\u001b[53d; Initialize session on request startup.\u001b[54;3Hhttps://php.net/session.auto-start\u001b[K\r\u001b[55dsession.auto_start = 0\u001b[K\r\u001b[56d\u001b[K\u001b[57d; Lifetime in seconds of cookie or, if 0, until browser is restarted.\u001b[K\u001b[58;3Hhttps://php.net/session.cookie-lifetime\r\u001b[59dsession.cookie_lifetime = 0\r\u001b[60d\u001b[K\u001b[61d; The path for which the cookie is valid.\r\u001b[62d; https://php.net/session.cookie-path\r\u001b[63dsession.cookie_path = /\r\u001b[64d\u001b[K\u001b[33d"]
[1.503, "o", "\u001b[?25h\u001b[?0csession.use_strict_mode = 0\r"]
