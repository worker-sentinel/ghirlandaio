[0.000, "o", "\u001b[K\u001b[6d; Allows to include or exclude arguments from stack traces generated for exceptions.\r\u001b[7d; In production, it is recommended to turn this setting on to prohibit the output\r\u001b[8d; of sensitive information in stack traces\r\u001b[9d; Default Value: Off\r\u001b[10d; Development Value: Off\r\u001b[11d; Production Value: On\r\u001b[12dzend.exception_ignore_args = On\r\u001b[13d\u001b[K\u001b[14d;"]
[0.000, "o", " Allows setting the maximum string length in an argument of a stringified stack trace\r\u001b[15d; to a value between 0 and 1000000.\r\u001b[16d; This has no effect when zend.exception_ignore_args is enabled.\r\u001b[17d; Default Value: 15\r\u001b[18d; Development Value: 15\r\u001b[19d; Production Value: 0\r\u001b[20d; In production, it is recommended to set this to 0 to reduce the output\r\u001b[21d; of sensitive information in stack traces.\r\u001b[22dzend.exception_string_param_max_len = 0\r\u001b[23d\u001b[K\u001b[24d;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[25d; Miscellaneous ;\u001b[K\r\u001b[26d;;;;;;;;;;;;;;;;;\r\u001b[27d\u001b[K\u001b[28d; "]
[0.000, "o", "Decides whether PHP may expose the fact that it is installed on the server\r\u001b[29d; (e.g. by adding its signature to the Web server header).  It is no security\r\u001b[30d; threat in any way, but it makes it possible to determine whether you use PHP\r\u001b[31d; on your server or not.\u001b[32;3Hhttps://php.net/expose-php\u001b[K\r\u001b[33d"]
[0.000, "o", "\u001b[30m\u001b[43mexpose_php\u001b[39;49m\u001b[m\u000f = On\u001b[K\r\u001b[34d\u001b[K\u001b[35d;;;;;;;;;;;;;;;;;;;\u001b[36;3HResource Limits ;\u001b[K\r\u001b[37d;;;;;;;;;;;;;;;;;;;\u001b[K\u001b[39;3HMaximum execution time of each script, in seconds\r\u001b[40d; https://php.net/max-execution-time\r\u001b[41d; Note: This directive is hardcoded to 0 for the CLI SAPI\r\u001b[42dmax_execution_time = 300\u001b[K\r\u001b[43d\u001b[K\u001b[44d; Maximum amount of time each script may spend parsing request data. It's a good\u001b[45;3Hidea to limit this time on productions servers in order to eliminate unexpectedly\r\u001b[46d; long running scripts.\u001b[K\r\u001b[47d; Note: This directive is hardcoded to -1 for the CLI SAPI\r\u001b[48d; Default Value: -1 (Unlimited)\u001b[49;3HDevelopment Value: 60 (60 seconds)\r\u001b[50d; Production Value: 60 (60 seconds)\r\u001b[51d; https://php.net/max-input-time\r\u001b[52dmax_input_time = 60\u001b[K\r\u001b[53d\u001b[K\u001b[54d; Maximum input variable nesting level\r\u001b[55d; https://php.net/max-input-nesting-level\r\u001b[56d;max_input_nesting_level = 64\u001b[K\r\u001b[57d\u001b[K\u001b[58d; How many GET/POST/COOKIE input variables may be accepted\u001b[K\r\u001b[59d;max_input_vars = 1000\u001b[K\u001b[61;3HHow many multipart body parts (combined input variable and file uploads) may\u001b[62;3Hbe accepted.\u001b[K\u001b[63;3HDefault Value: -1 (Sum of max_input_vars and max_file_uploads)\u001b[K\r\u001b[64d;max_multipart_body_parts = 1500\r\u001b[33d"]
