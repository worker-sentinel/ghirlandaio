[0.000, "o", "\r\u001b[2d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\u001b[K\r\u001b[3d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[4d#\u001b[K\u001b[5d\b\u001b[K\u001b[6d#\u001b[K\u001b[7d"]
[0.000, "o", " MaxRanges: Maximum number of Ranges in a request before\u001b[K\r\u001b[8d# returning the entire resource, or one of the special\r\u001b[9d#"]
[0.000, "o", " values 'default', 'none' or 'unlimited'.\u001b[K\r\u001b[10d# Default setting is to accept 200 Ranges.\u001b[K\r\u001b[11d#MaxRanges unlimited\u001b[K\r\u001b[12d\u001b[K\u001b[13d#\u001b[K\u001b[14d EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[15d# memory-mapping or the sendfile syscall may be used to deliver\r\u001b[16d# files.  This usually improves server performance, but must\r\u001b[17d# be turned off when serving from networked-mounted\r\u001b[18d# filesystems or if support for these functions is otherwise\r\u001b[19d# broken on your system.\r\u001b[20d# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[21d#\u001b[K\u001b[22d\b#EnableMMAP off\r\u001b[23d#EnableSendfile on\u001b[K\r\u001b[24d\u001b[K\u001b[25d# Supplemental configuration\u001b[K\r\u001b[26d#\u001b[K\u001b[27d\b# The configuration files in the conf/extra/ directory can be\r\u001b[28d#"]
[0.001, "o", " included to add extra features or to modify the default configuration of\r\u001b[29d# the server, or you may simply copy their contents here and change as\r\u001b[30d# necessary.\u001b[K\r\u001b[31d\u001b[K\u001b[32d# Server-pool management (MPM specific)\u001b[K\r\u001b[33d\u001b[30m\u001b[43mInclude conf\u001b[39;49m\u001b[m\u000f/extra/httpd-mpm.conf\u001b[K\r\u001b[35d# Multi-language error messages\r\u001b[36dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[37d\u001b[K\u001b[38d# Fancy directory listings\u001b[K\r\u001b[39dInclude conf/extra/httpd-autoindex.conf\r\u001b[40d\u001b[K\u001b[41d# Language settings\u001b[K\r\u001b[42dInclude conf/extra/httpd-languages.conf\u001b[K\r\u001b[43d\u001b[K\u001b[44d# User home directories\r\u001b[45dInclude conf/extra/httpd-userdir.conf\r\u001b[47d# Real-time info on requests and configuration\r\u001b[48d#Include conf/extra/httpd-info.conf\r\u001b[49d\u001b[K\u001b[50d# Virtual hosts\r\u001b[51d#Include conf/extra/httpd-vhosts.conf\u001b[K\r\u001b[52d\u001b[K\u001b[53d# Local access to the Apache HTTP Server Manual\u001b[K\r\u001b[54d#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[55d\u001b[K\u001b[56d# Distributed authoring and versioning (WebDAV)\u001b[K\r\u001b[57d#Include conf/extra/httpd-dav.conf\u001b[K\r\u001b[58d\u001b[K\u001b[59d# Various default settings\r\u001b[60dInclude conf/extra/httpd-default.conf\r\u001b[61d\u001b[K\u001b[62d# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[K\r\u001b[63d<IfModule proxy_html_module>\u001b[K\r\u001b[64dInclude conf/extra/proxy-html.conf\u001b[K\r\u001b[33d"]
