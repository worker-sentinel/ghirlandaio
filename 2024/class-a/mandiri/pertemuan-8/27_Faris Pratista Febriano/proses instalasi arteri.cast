[0.000, "o", "https://php.net/com.autoregister-casesensitive\r\u001b[19d;com.autoregister_casesensitive = false\r\u001b[20d\u001b[K\u001b[21d; show warnings on duplicate constant registrations\u001b[K\u001b[22;3Hhttps://php.net/com.autoregister-verbose\u001b[K\r\u001b[23d;com.autoregister_verbose = true\u001b[K\r\u001b[24d\u001b[K\u001b[25d; The default character set code-page to use when passing strings to and from COM objects.\r\u001b[26d; Default: system ANSI code page\r\u001b[27d;com.code_page=\u001b[K\r\u001b[28d\u001b[K\u001b[29d; The version of the .NET framework to use. The value of the setting are the first three parts\r\u001b[30d; of the framework's version number, separated by dots, and prefixed with \"v\", e.g. \"v4.0.30319\".\r\u001b[31d;com.dotnet_version=\r\u001b[32d\u001b[K\u001b[33d[\u001b[30m\u001b[43mmbstring\u001b[39;49m\u001b[m\u000f]\u001b[K\r\u001b[34d; language for internal character representation.\r\u001b[35d; This affects mb_send_mail() and mbstring.detect_order.\r\u001b[36d; https://php.net/mbstring.language\r\u001b[37d;mbstring.language = Japanese\r\u001b[38d\u001b[K\u001b[39d; Use of this INI entry is deprecated, use global internal_encoding instead.\r\u001b[40d; internal/script encoding.\r\u001b[41d; Some encoding cannot work as internal encoding. (e.g. SJIS, BIG5, ISO-2022-*)\r\u001b[42d; If empty, default_charset or internal_encoding or iconv.internal_encoding is used.\r\u001b[43d; The precedence is: default_charset < internal_encoding < iconv.internal_encoding\r\u001b[44d;mbstring.internal_encoding =\r\u001b[45d\u001b[K\u001b[46d; Use of this INI entry is deprecated, use global input_encoding instead.\r\u001b[47d;"]
[0.001, "o", " http input encoding.\r\u001b[48d; mbstring.encoding_translation = On is needed to use this setting.\r\u001b[49d; If empty, default_charset or input_encoding or mbstring.input is used.\r\u001b[50d; The precedence is: default_charset < input_encoding < mbstring.http_input\r\u001b[51d; https://php.net/mbstring.http-input\r\u001b[52d;mbstring.http_input =\r\u001b[53d\u001b[K\u001b[54d; Use of this INI entry is deprecated, use global output_encoding instead.\r\u001b[55d; http output encoding.\r\u001b[56d; mb_output_handler must be registered as output buffer to function.\r\u001b[57d; If empty, default_charset or output_encoding or mbstring.http_output is used.\r\u001b[58d; The precedence is: default_charset < output_encoding < mbstring.http_output\r\u001b[59d; To use an output encoding conversion, mbstring's output handler must be set\r\u001b[60d; otherwise output encoding conversion cannot be performed.\r\u001b[61d; https://php.net/mbstring.http-output\r\u001b[62d;mbstring.http_output =\r\u001b[63d\u001b[K\u001b[64d; enable automatic encoding translation according to\r\u001b[33d["]
