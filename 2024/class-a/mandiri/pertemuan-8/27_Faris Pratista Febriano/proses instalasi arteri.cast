[0.000, "o", "Temporary directory for HTTP uploaded files (will use system default if not\u001b[K\u001b[12;3Hspecified).\u001b[K\u001b[13;3Hhttps://php.net/upload-tmp-dir\r\u001b[14d;upload_tmp_dir =\u001b[K\r\u001b[15d\u001b[K\u001b[16d; Maximum allowed size for uploaded files.\u001b[K\r\u001b[17d; https://php.net/upload-max-filesize\r\u001b[18dupload_max_filesize = 64M\u001b[K\r\u001b[19d\u001b[K\u001b[20d; Maximum number of files that can be uploaded via a single request\u001b[K\r\u001b[21dmax_file_uploads = 20\u001b[K\r\u001b[22d\u001b[K\u001b[23d;;;;;;;;;;;;;;;;;;\u001b[K\u001b[24;3HFopen wrappers ;\u001b[K\r\u001b[25d;;;;;;;;;;;;;;;;;;\r\u001b[26d\u001b[K\u001b[27d; Whether to allow the treatment of URLs (like http:// or ftp://) as files.\u001b[28;3Hhttps://php.net/allow-url-fopen\u001b[K\r\u001b[29dallow_url_fopen = On\r\u001b[30d\u001b[K\u001b[31d; Whether to allow include/require to open URLs (like https:// or ftp://) as files.\u001b[32;19H"]
[0.000, "o", "allow-url-include\r\u001b[33d\u001b[30m\u001b[43mallow_url_include\u001b[39;49m\u001b[m\u000f = Off\u001b[35;3HDefine the anonymous ftp password (your email address). PHP's default setting\u001b[36;3Hfor this is empty.\u001b[K\u001b[37;3Hhttps://php.net/from\u001b[K\r\u001b[38d;from=\"john@doe.com\"\r\u001b[39d\u001b[K\u001b[40d; Define the User-Agent string. PHP's default setting for this is empty.\u001b[41;19Huser-agent\u001b[K\r\u001b[42d;user_agent=\"PHP\"\u001b[K\u001b[44;3HDefault timeout for socket based streams (seconds)\u001b[K\u001b[45;3Hhttps://php.net/default-socket-timeout\u001b[K\r\u001b[46ddefault_socket_timeout = 60\u001b[K\r\u001b[47d\u001b[K\u001b[48d; If your scripts have to deal with files from Macintosh systems,\u001b[49;3Hor you are running on a Mac and need to deal with files from\u001b[50;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[51;3Hautomatically detect the EOL character in those files so that\r\u001b[52d; fgets() and file() will work regardless of the source of the file.\r\u001b[53d; https://php.net/auto-detect-line-endings\r\u001b[54d;auto_detect_line_endings = Off\u001b[K\r\u001b[55d\u001b[K\u001b[56d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[57d; Dynamic Extensions ;\u001b[K\r\u001b[58d;;;;;;;;;;;;;;;;;;;;;;\r\u001b[59d\u001b[K\u001b[60d; If you wish to have an extension loaded automatically, use the following\u001b[K\u001b[61;4Hyntax:\u001b[K\u001b[62;3H\u001b[K\r\u001b[63d;   extension=modulename\u001b[K\r\u001b[64d;\u001b[33d\b"]
