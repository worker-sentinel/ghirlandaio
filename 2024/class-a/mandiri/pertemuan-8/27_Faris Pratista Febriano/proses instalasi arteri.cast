[0.000, "o", "\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\u001b[2;3Henabled, registering these variables consumes CPU cycles and memory each time\u001b[3;3Ha script is executed. For performance reasons, this feature should be disabled\u001b[4;3Hon production servers.\u001b[K\u001b[5;3HNote: This directive is hardcoded to On for the CLI SAPI\r\u001b[6d; Default Value: On\u001b[K\r\u001b[7d; Development Value: Off\u001b[8;3HProduction Value: Off\u001b[K\u001b[9;3Hhttps://php.net/register-argc-argv\r\u001b[10dregister_argc_argv = Off\u001b[12;3H"]
[0.001, "o", "When enabled, the ENV, REQUEST and SERVER variables are created when they're\u001b[13;3Hfirst used (Just In Time) instead of when the script starts. If these\u001b[K\u001b[14;3Hvariables are not used within a script, having this directive on will result\u001b[15;3Hin a performance gain. The PHP directive register_argc_argv must be disabled\u001b[16;3Hfor this directive to have any effect.\u001b[17;19Hauto-globals-jit\u001b[K\r\u001b[18dauto_globals_jit = On\u001b[K\u001b[20;3HWhether PHP will read the POST data.\u001b[K\u001b[21;3HThis option is enabled by default.\u001b[K\u001b[22;3HMost likely, you won't want to disable this option globally. It causes $_POST\u001b[K\u001b[23;3Hand $_FILES to always be empty; the only way you will be able to read the\u001b[K\u001b[24;3HPOST data will be through the php://input stream wrapper. This can be useful\r\u001b[25d; to proxy requests or to process the POST data in a memory efficient fashion.\r\u001b[26d; https://php.net/enable-post-data-reading\r\u001b[27d;enable_post_data_reading = Off\r\u001b[28d\u001b[K\u001b[29d; Maximum size of POST data that PHP will accept.\r\u001b[30d; Its value may be 0 to disable the limit. It is ignored if POST data reading\u001b[31;3His disabled through enable_post_data_reading.\u001b[32;19Hpost-max-size\r\u001b[33d\u001b[30m\u001b[43mpost_max_size\u001b[39;49m\u001b[m\u000f = 8M\u001b[35;3HAutomatically add files before PHP document.\u001b[K\u001b[36;3H"]
[0.000, "o", "https://php.net/auto-prepend-file\r\u001b[37dauto_prepend_file =\u001b[K\r\u001b[38d\u001b[K\u001b[39d; Automatically add files after PHP document.\u001b[40;3Hhttps://php.net/auto-append-file\u001b[K\r\u001b[41dauto_append_file =\u001b[K\r\u001b[42d\u001b[K\u001b[43d; By default, PHP will output a media type using the Content-Type header. To\u001b[44;3Hdisable this, simply set it to be empty.\u001b[K\r\u001b[45d;\u001b[K\u001b[46d\b; PHP's built-in default media type is set to text/html.\r\u001b[47d; https://php.net/default-mimetype\r\u001b[48ddefault_mimetype = \"text/html\"\r\u001b[49d\u001b[K\u001b[50d; PHP's default character set is set to UTF-8.\u001b[51;3Hhttps://php.net/default-charset\u001b[K\r\u001b[52ddefault_charset = \"UTF-8\"\u001b[K\r\u001b[53d\u001b[K\u001b[54d; PHP internal character encoding is set to empty.\u001b[55;3HIf empty, default_charset is used.\u001b[K\u001b[56;19Hinternal-encoding\r\u001b[57d;internal_encoding =\u001b[K\u001b[59;3HPHP input character encoding is set to empty.\u001b[K\u001b[60;3HIf empty, default_charset is used.\u001b[61;19Hinput-encoding\r\u001b[62d;input_encoding =\u001b[K\u001b[64;3HPHP output character encoding is set to\u001b[24P\r\u001b[33d"]
