[0.000, "o", "\r\u001b[2d|    \u001b[2;33H'ssl_key'    - Path to the private key file\r\u001b[3d|\u001b[31X\u001b[3;33H'ssl_cert'   - Path to the public key certificate file\r\u001b[4d|\u001b[4;33H'ssl_ca'     - Path to the certificate authority file\r\u001b[5d| \u001b[5;33H'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\u001b[6;3H\u001b[30X\u001b[6;33H'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\u001b[7;3H\u001b[30X\u001b[7;33H"]
[0.000, "o", "'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\u001b[8;3H\u001b[K\u001b[9d      ['compress'] Whether or not to use client compression (MySQL only)\u001b[10;9H['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\u001b[11;3H\u001b[54X\u001b[11;57H- good for ensuring strict SQL while developing\u001b[12;3H      ['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\u001b[13;9H['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[14;3H      ['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[15;3H\u001b[24X\u001b[15;33HNOTE: Disabling this will also effectively disable both\u001b[16;3H\u001b[30X\u001b[16;33H$this->db->last_query() and profiling of DB queries.\u001b[17;33HWhen you run a query, with this setting set to TRUE (default),\u001b[18;9H       \u001b[22G           CodeIgniter will store the SQL statement for debugging purposes.\u001b[19;9H\u001b[24X\u001b[19;33HHowever, this may cause high memory usage, especially if you run\u001b[20;9H\u001b[24X\u001b[20;33Ha lot of SQL queries ... disable this to avoid that problem.\u001b[21;9H\u001b[K\u001b[22;3HThe $active_group variable lets you choose which connection group to\u001b[23;3Hmake active.  By default there is only one group (the 'default' group).\u001b[24;25H\u001b[K\u001b[25;3H"]
[0.001, "o", "The $query_builder variables lets you determine whether or not to load\u001b[K\u001b[26;3Hthe query builder class.\u001b[K\r\u001b[27d*/\u001b[K\r\u001b[28d$active_group = 'default';\u001b[K\r\u001b[29d$query_builder = TRUE;\u001b[K\r\u001b[30d\u001b[K\u001b[31d$db['default'] = array(\u001b[K\u001b[32;8H\u001b[1K 'dsn'   => '',\u001b[K\u001b[33;8H\u001b[1K '\u001b[30m\u001b[43mhostname\u001b[39;49m\u001b[m\u000f' => 'localhost',\u001b[K\u001b[34;8H\u001b[1K 'username' => 'root',\u001b[K\u001b[35;8H\u001b[1K 'password' => '',\u001b[K\u001b[36;8H\u001b[1K 'database' => 'arteri',\u001b[K\u001b[37;8H\u001b[1K 'dbdriver' => 'mysqli',\u001b[K\u001b[38;8H\u001b[1K 'dbprefix' => '',\u001b[K\u001b[39;8H\u001b[1K 'pconnect' => FALSE,\u001b[K\u001b[40;8H\u001b[1K 'db_debug' => (ENVIRONMENT !== 'production'),\u001b[K\u001b[41;8H\u001b[1K 'cache_on' => FALSE,\u001b[K\u001b[42;8H\u001b[1K 'cachedir' => '',\u001b[K\u001b[43;8H\u001b[1K 'char_set' => 'utf8',\u001b[K\u001b[44;8H\u001b[1K 'dbcollat' => 'utf8_unicode_ci',\u001b[45;8H\u001b[1K 'swap_pre' => '',\u001b[K\u001b[46;8H\u001b[1K 'encrypt' => FALSE,\u001b[K\u001b[47;8H\u001b[1K 'compress' => FALSE,\u001b[48;8H\u001b[1K 'stricton' => FALSE,\u001b[K\u001b[49;8H\u001b[1K 'failover' => array(),\u001b[K\u001b[50;8H\u001b[1K 'save_queries' => TRUE\u001b[K\r\u001b[51d);\u001b[K\r\u001b[52d\u001b[K\u001b[53d\u001b[K\u001b[54d\u001b[K\u001b[55d\u001b[K\u001b[56d\u001b[K\u001b[57d\u001b[K\u001b[58d\u001b[K\u001b[59d\u001b[K\u001b[60d\u001b[K\u001b[61d\u001b[K\u001b[62d\u001b[K\u001b[63d\u001b[K\u001b[64d\u001b[K\u001b[33;10H"]
