[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H;\u001b[9G"]
[0.000, "o", "(see session.save_path above), then garbage collection does *not*\u001b[2;38H"]
