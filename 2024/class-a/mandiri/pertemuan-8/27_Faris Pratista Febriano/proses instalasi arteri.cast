[0.000, "o", "Should tidy clean and repair output automatically?\r\u001b[23d; WARNING: Do not use this option if you are generating non-html content\r\u001b[24d; such as dynamic images\u001b[25;3Hhttps://php.net/tidy.clean-output\u001b[K\r\u001b[26dtidy.clean_output = Off\u001b[K\r\u001b[27d\u001b[K\u001b[28d[soap]\u001b[29;3HEnables or disables WSDL caching feature.\u001b[K\u001b[30;3Hhttps://php.net/soap.wsdl-cache-enabled\u001b[K\r\u001b[31dsoap.wsdl_cache_enabled=1\r\u001b[33d; Sets the directory name where SOAP \u001b[30m\u001b[43mextension\u001b[39;49m\u001b[m\u000f will put cache files.\u001b[34;3Hhttps://php.net/soap.wsdl-cache-dir\u001b[K\r\u001b[35dsoap.wsdl_cache_dir=\"/tmp\"\u001b[K\r\u001b[36d\u001b[K\u001b[37d; (time to live) Sets the number of second while cached file will be used\r\u001b[38d; instead of original one.\u001b[39;3Hhttps://php.net/soap.wsdl-cache-ttl\u001b[K\r\u001b[40dsoap.wsdl_cache_ttl=86400\u001b[K\r\u001b[41d\u001b[K\u001b[42d; Sets the size of the cache limit. (Max. number of WSDL files to cache)\u001b[K\r\u001b[43dsoap.wsdl_cache_limit = 5\u001b[K\r\u001b[44d\u001b[K\u001b[45d[sysvshm]\u001b[46;3HA default size of the shared memory segment\u001b[K\r\u001b[47d;sysvshm.init_mem = 10000\r\u001b[48d\u001b[K\u001b[49d"]
[0.001, "o", "[ldap]\u001b[K\u001b[50;3HSets the maximum number of open links or -1 for unlimited.\u001b[K\r\u001b[51dldap.max_links = -1\u001b[K\r\u001b[52d\u001b[K\u001b[53d[dba]\r\u001b[54d;dba.default_handler=\u001b[K\r\u001b[55d\u001b[K\u001b[56d[opcache]\u001b[K\u001b[57;3HDetermines if Zend OPCache is enabled\u001b[K\r\u001b[58d;opcache.enable=1\u001b[K\r\u001b[59d\u001b[K\u001b[60d; Determines if Zend OPCache is enabled for the CLI version of PHP\r\u001b[61d;opcache.enable_cli=0\u001b[K\r\u001b[62d\u001b[K\u001b[63d; The OPcache shared memory storage size.\r\u001b[64d;opcache.memory_consumption=128\u001b[K\u001b[33;38H"]
