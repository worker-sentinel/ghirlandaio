[0.002, "o", "\u001b[65;112H\u001b[0;10;7m\u000f[ Read 542 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                               /etc/httpd/conf/httpd.conf                                                                                                         \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d#\u001b[3d\b# This is the main Apache HTTP server configuration file.  It contains the\r\u001b[4d# configuration directives that give the server its instructions.\r\u001b[5d# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\r\u001b[6d# In particular, see\r\u001b[7d# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\r\u001b[8d# for a discussion of each configuration directive.\r\u001b[9d#\u001b[10d\b# Do NOT simply read the instructions in here without understanding\r\u001b[11d# what they do.  They're here only as hints or reminders.  If you are unsure\r\u001b[12d# consult the online docs. You have been warned.\r\u001b[13d#\u001b[14d\b# Configuration and logfile names: If the filenames you specify for many\r\u001b[15d# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\r\u001b[16d# server will use that explicit path.  If the filenames do *not* begin\r\u001b[17d# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\u001b[18d# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\u001b[19d# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\"\r\u001b[20d# will be interpreted as '/logs/access_log'.\r\u001b[22d#\u001b[23d\b# ServerRoot: The top of the directory tree under which the server's\r\u001b[24d# configuration, error, and log files are kept.\r\u001b[25d#\u001b[26d\b# Do not add a slash at the end of the directory path.  If you point\r\u001b[27d# ServerRoot at a non-local disk, be sure to specify a local disk on the\r\u001b[28d# Mutex directive, if file-based mutexes are used.  If you wish to share the\r\u001b[29d# same ServerRoot for multiple httpd daemons, you will need to change at\r\u001b[30d# least PidFile.\r\u001b[31d#\u001b[32d\bServerRoot \"/etc/httpd\"\r\u001b[34d#\u001b[35d\b# Mutex: Allows you to set the mutex mechanism and mutex file directory\r\u001b[36d# for individual mutexes, or change the global defaults\r\u001b[37d#\u001b[38d\b# Uncomment and change the directory if mutexes are file-based and the default\r\u001b[39d# mutex file directory is not on a local disk or is not appropriate for some\r\u001b[40d# other reason.\r\u001b[41d#\u001b[42d\b# Mutex default:/run/httpd\r\u001b[44d#\u001b[45d\b# Listen: Allows you to bind Apache to specific IP addresses and/or\r\u001b[46d# ports, instead of the default. See also the <VirtualHost>\r\u001b[47d# directive.\r\u001b[48d#\u001b[49d\b# Change this to Listen on specific IP addresses as shown below to\r\u001b[50d# prevent Apache from glomming onto all bound IP addresses.\r\u001b[51d#\u001b[52d\b#Listen 12.34.56.78:80\r\u001b[53dListen 80\r\u001b[55d#\u001b[56d\b# Dynamic Shared Object (DSO) Support\r\u001b[57d#\u001b[58d\b# To be able to use the functionality of a module which was built as a DSO you\r\u001b[59d# have to place corresponding `LoadModule' lines at this location so the\r\u001b[60d# directives contained in it are actually available _before_ they are used.\r\u001b[61d# Statically compiled modules (those listed by `httpd -l') do not need\r\u001b[62d# to be loaded here.\r\u001b[63d#\u001b[64d\b# Example:\r\u001b[2d\u001b[?25h\u001b[?0c"]
