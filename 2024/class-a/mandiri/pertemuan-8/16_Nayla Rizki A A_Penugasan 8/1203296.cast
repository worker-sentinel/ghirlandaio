[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H# 1) plain text 2) local redirects 3) external redirects\u001b[64;29H"]
