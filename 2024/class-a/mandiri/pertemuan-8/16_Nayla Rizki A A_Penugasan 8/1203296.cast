[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H# filesystems or if support for these functions is otherwise\u001b[64;29H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H# broken on your system."]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H# Defaults: EnableMMAP On, EnableSendfile Off\u001b[64;29H"]
