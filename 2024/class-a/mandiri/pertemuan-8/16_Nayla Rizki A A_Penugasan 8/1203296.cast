[0.000, "o", "\n\u001b[1;67r\u001b[64;1H# contents of the file itself to determine its type.  The MIMEMagicFile\u001b[64;29H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
