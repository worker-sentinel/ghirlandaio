[0.000, "o", "* APPLICATION ENVIRONMENT\r\u001b[43d *---------------------------------------------------------------\r\u001b[44d *\u001b[45d\b"]
[0.000, "o", "* You can load different configurations depending on your\r\u001b[46d * current environment. Setting the environment also influences\r\u001b[47d "]
[0.000, "o", "* things like logging and error reporting.\r\u001b[48d *\u001b[49d\b"]
[0.000, "o", "* This can be set to anything, but default usage is:\r\u001b[50d *\u001b[51d\b*     development\r\u001b[52d *     testing\r\u001b[53d *     production\r\u001b[54d *\u001b[55d\b* NOTE: If you change these, also change the error_reporting() code below\r\u001b[56d */\u001b[57;9Hdefine('ENVIRONMENT', isset($_SERVER['CI_ENV']) ? $_SERVER['CI_ENV'] : 'development');\u001b[59;9Hdefine('ROOTPATH', realpath(dirname(__FILE__)) . '/');\u001b[62;9H// installed in the docroot?\u001b[63;9Hif (realpath(dirname(__FILE__)) == $_SERVER['DOCUMENT_ROOT'])\u001b[64;9H{\r\u001b[2d\u001b[?25h\u001b[?0c"]
