[0.000, "o", "Dynamic Extensions ;\u001b[K\r\u001b[24d;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[25d\u001b[K\u001b[26d; If you wish to have an extension loaded automatically, use the following\r\u001b[27d"]
[0.000, "o", "; syntax:\u001b[28;3H"]
[0.000, "o", "\u001b[K\u001b[29d  extension=modulename\u001b[K\u001b[30;3H"]
[0.000, "o", "\u001b[K\u001b[31dFor example:\u001b[K\u001b[32;3H"]
[0.000, "o", "\u001b[K\u001b[33d"]
[0.000, "o", "  \u001b[30m\u001b[43mextension=mysqli\u001b[39;49m\u001b[m\u000f\u001b[K\u001b[34;3H\u001b[K\u001b[35dWhen the extension library to load is not located in the default extension\r\u001b[36d"]
