[0.000, "o", "\u001b[K\u001b[38d"]
[0.000, "o", "  extension=/path/to/extension/mysqli.so\u001b[39;3H"]
[0.000, "o", "\u001b[K\u001b[40d"]
[0.000, "o", "Note : The syntax used in previous PHP versions ('extension=<ext>.so' and\u001b[41;3H"]
