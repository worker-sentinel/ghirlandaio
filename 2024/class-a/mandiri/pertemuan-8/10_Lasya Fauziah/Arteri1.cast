[0.001, "o", "\r\u001b[2d; for this is empty.\r\u001b[3d; https://php.net/from\r\u001b[4d;from=\"john@doe.com\"\r\u001b[5d\u001b[K\u001b[6d; Define the User-Agent string. PHP's default setting for this is empty.\u001b[7;3Hhttps://php.net/user-agent\u001b[K\r\u001b[8d;user_agent=\"PHP\"\u001b[K\u001b[10;3HDefault timeout for socket based streams (seconds)\u001b[K\u001b[11;3Hhttps://php.net/default-socket-timeout\u001b[K\r\u001b[12ddefault_socket_timeout = 60\u001b[K\r\u001b[13d\u001b[K\u001b[14d; If your scripts have to deal with files from Macintosh systems,\u001b[15;3Hor you are running on a Mac and need to deal with files from\u001b[16;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[K\u001b[17;3Hautomatically detect the EOL character in those files so that\u001b[18;3H"]
[0.000, "o", "fgets() and file() will work regardless of the source of the file.\u001b[K\u001b[19;3H"]
