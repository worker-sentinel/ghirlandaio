[0.007, "o", "Running in a chroot, enabling --graceful.\r\r\n"]
[0.001, "o", "Created directory \"/boot/EFI\".\r\r\nCreated directory \"/boot/EFI/systemd\".\r\r\nCreated directory \"/boot/EFI/BOOT\".\r\r\n"]
[0.001, "o", "Created directory \"/boot/loader\".\r\r\nCreated directory \"/boot/loader/keys\".\r\r\nCreated directory \"/boot/loader\".\r\r\nCreated directory \"/boot/loader/entries\".\r\r\nCreated directory \"/boot/EFI\".\r\r\nCreated directory \"/boot/EFI/Linux\".\r\r\n"]
[0.013, "o", "Copied \"/usr/lib/systemd/boot/efi/systemd-bootx64.efi\" to \"/boot/EFI/systemd/systemd-bootx64.efi\".\r\r\n"]
[0.003, "o", "Copied \"/usr/lib/systemd/boot/efi/systemd-bootx64.efi\" to \"/boot/EFI/BOOT/BOOTX64.EFI\".\r\r\n"]
[0.003, "o", "Random seed file /boot/loader/random-seed successfully written (32 bytes).\r\r\n\u001b[0;1;39mNot booted with EFI or running in a container, skipping EFI variable modifications.\u001b[0m\r\r\n"]
