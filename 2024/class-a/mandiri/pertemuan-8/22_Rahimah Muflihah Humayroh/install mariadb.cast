[0.001, "o", "\r\u001b[K                               Available networks\u001b[1;90m                              \u001b[0m\r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K\u001b[1;90m      Network name                      Security            Signal\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K\u001b[90m--------------------------------------------------------------------------------\r\n\u001b[0m\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K  \u001b[1;90m> \u001b[0m  Kelawai Ciputat 01                psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      Target Sales_5G                   psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      DIRECT-NA-SW-22AE NF              psk                 ****    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      Warkop Kelawai                    psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      TP-Link_2EAA                      psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      ndd                               psk                 **\u001b[1;90m**\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      Sya                               psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      pledis                            psk                 ***\u001b[1;90m*\u001b[0m    \r\n\u001b[32m[iwd]\u001b[0m# station wlan0 Kela\r\u001b[K      a56                               psk                 ***\u001b[1;90m*\u001b[0m    \r\n"]
