[0.002, "o", "\u001b[65;112H\u001b[0;10;7m\u000f[ Read 139 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                                    /etc/sudoers.tmp                                                                                                              \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d## sudoers file.\r\u001b[3d##\r\u001b[4d## This file MUST be edited with the 'visudo' command as root.\r\u001b[5d## Failure to use 'visudo' may result in syntax or file permission errors\r\u001b[6d## that prevent sudo from running.\r\u001b[7d##\r\u001b[8d## See the sudoers man page for the details on how to write a sudoers file.\r\u001b[9d##\r\u001b[11d##\r\u001b[12d## Host alias specification\r\u001b[13d##\r\u001b[14d## Groups of machines. These may include host names (optionally with wildcards),\r\u001b[15d## IP addresses, network numbers or netgroups.\r\u001b[16d# Host_Alias    WEBSERVERS = www1, www2, www3\r\u001b[18d##\r\u001b[19d## User alias specification\r\u001b[20d##\r\u001b[21d## Groups of users.  These may consist of user names, uids, Unix groups,\r\u001b[22d## or netgroups.\r\u001b[23d# User_Alias    ADMINS = millert, dowdy, mikef\r\u001b[25d##\r\u001b[26d## Cmnd alias specification\r\u001b[27d##\r\u001b[28d## Groups of commands.  Often used to group related commands together.\r\u001b[29d# Cmnd_Alias    PROCESSES = /usr/bin/nice, /bin/kill, /usr/bin/renice, \\\r\u001b[30d#\u001b[30;29H/usr/bin/pkill, /usr/bin/top\r\u001b[31d#\u001b[32d\b# Cmnd_Alias    REBOOT = /sbin/halt, /sbin/reboot, /sbin/poweroff\r\u001b[33d#\u001b[34d\b# Cmnd_Alias    DEBUGGERS = /usr/bin/gdb, /usr/bin/lldb, /usr/bin/strace, \\\r\u001b[35d#\u001b[35;29H/usr/bin/truss, /usr/bin/bpftrace, \\\r\u001b[36d#\u001b[36;29H/usr/bin/dtrace, /usr/bin/dtruss\r\u001b[37d#\u001b[38d\b# Cmnd_Alias    PKGMAN = /usr/bin/apt, /usr/bin/dpkg, /usr/bin/rpm, \\\r\u001b[39d#\u001b[39;26H/usr/bin/yum, /usr/bin/dnf,  /usr/bin/zypper, \\\r\u001b[40d#\u001b[40;26H/usr/bin/pacman\r\u001b[42d##\r\u001b[43d## Defaults specification\r\u001b[44d##\r\u001b[45d## Preserve editor environment variables for visudo.\r\u001b[46d## To preserve these for all commands, remove the \"!visudo\" qualifier.\r\u001b[47dDefaults!/usr/bin/visudo env_keep += \"SUDO_EDITOR EDITOR VISUAL\"\r\u001b[48d##\r\u001b[49d## Use a hard-coded PATH instead of the user's to find commands.\r\u001b[50d## This also helps prevent poorly written scripts from running\r\u001b[51d## arbitrary commands under sudo.\r\u001b[52dDefaults secure_path=\"/usr/local/sbin:/usr/local/bin:/usr/bin\"\r\u001b[53d##\r\u001b[54d## You may wish to keep some of the following environment variables\r\u001b[55d## when running commands via sudo.\r\u001b[56d##\r\u001b[57d## Locale settings\r\u001b[58d# Defaults env_keep += \"LANG LANGUAGE LINGUAS LC_* _XKB_CHARSET\"\r\u001b[59d##\r\u001b[60d## Run X applications through sudo; HOME is used to find the\r\u001b[61d## .Xauthority file.  Note that other programs use HOME to find\r\u001b[62d## configuration files and this may lead to privilege escalation!\r\u001b[63d# Defaults env_keep += \"HOME\"\r\u001b[64d##\r\u001b[2d\u001b[?25h\u001b[?0c"]
