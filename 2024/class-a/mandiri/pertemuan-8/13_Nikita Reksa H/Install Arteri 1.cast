[0.008, "o", "\u001b[1;65r\u001b[H\u001b[16L\u001b[1;67r\u001b[H#\u001b[K\r\n# Uncomment and change the directory if mutexes are file-based and the default\u001b[K\r\n# mutex file directory is not on a local disk or is not a\u001b[30m\u001b[103mpp\u001b[m\u000fro\u001b[30m\u001b[103mp\u001b[m\u000friate for some\u001b[K\r\n# other reason.\u001b[K\r\n#\u001b[K\r\n# Mutex default:/run/htt\u001b[30m\u001b[103mp\u001b[m\u000fd\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Listen: Allows you to bind A\u001b[30m\u001b[103mp\u001b[m\u000fache to s\u001b[30m\u001b[103mp\u001b[m\u000fecific IP addresses and/or\u001b[K\r\n# \u001b[30m\u001b[103mp\u001b[m\u000forts, instead of the default. See also the <VirtualHost>\u001b[K\r\n# directive.\u001b[K\r\n#\u001b[K\r\n# Change this to Listen on s\u001b[30m\u001b[103mp\u001b[m\u000fecific IP addresses as shown below to \u001b[K\r\n# \u001b[30m\u001b[103mp\u001b[m\u000frevent A\u001b[30m\u001b[103mp\u001b[m\u000fache from glomming onto all bound IP addresses.\u001b[K\r\n#\u001b[K\r\n#Listen 12.34.56.78:80\u001b[K\u001b[20;33H\u001b[30m\u001b[103mpp\u001b[23;11Hp\u001b[m\u000flace corres\u001b[30m\u001b[103mp\u001b[25;17Hp\u001b[m\u000filed modules (those listed by `htt\u001b[30m\u001b[103mp\u001b[28;7Hp\u001b[31;13Hp\u001b[m\u000fm_event_module modules/mod_m\u001b[30m\u001b[103mp\u001b[32;14Hp\u001b[m\u000fm_\u001b[30m\u001b[103mp\u001b[m\u000frefork_module modules/mod_m\u001b[30m\u001b[103mp\u001b[m\u000fm_\u001b[30m\u001b[103mp\u001b[m\u000fr\u001b[33;14H\u001b[30m\u001b[103mp\u001b[m\u000fm_worker_module modules/mod_m\u001b[30m\u001b[103mp\u001b[41;22Hp\u001b[m\u000ffile_module modules/mod_authz_grou\u001b[30m\u001b[103mp\u001b[47;23Hp\u001b[m\u000f_module modules/mod_authnz_lda\u001b[30m\u001b[103mp\u001b[49;22Hp\u001b[m\u000fat_module modules/mod_access_com\u001b[30m\u001b[103mp\u001b[65;16Hp\u001b[m\u000fio_module modules/mod_dum\u001b[30m\u001b[103mp\u001b[66;224H\u001b[0;10;7m\u000f00,16          7\u001b[67;3H\u001b[?25h"]
[0.030, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[1;65r\u001b[H\u001b[3L\u001b[1;67r\u001b[H#\u001b[K\r\n# Mutex: Allows you to set the mutex mechanism and mutex file directory\u001b[K\r\n# for individual mutexes, or change the global defaults\u001b[K\u001b[6;58Hpprop\u001b[9;25Hp\u001b[12;31Hpache to sp\u001b[13;3Hp\u001b[16;29Hp\u001b[17;3Hprevent Ap\u001b[23;33Hpp\u001b[26;11Hplace corresp\u001b[28;17Hpiled modules (those listed by `http\u001b[31;7Hp\u001b[34;13Hpm_event_module modules/mod_mp\u001b[35;14Hpm_prefork_module modules/mod_mpm_p\u001b[36;14Hpm_worker_module modules/mod_mp\u001b[44;22Hpfile_module modules/mod_authz_group\u001b[50;23Hp_module modules/mod_authnz_ldap\u001b[52;22Hpat_module modules/mod_access_comp\u001b[66;223H\u001b[0;10;7m\u000f97,1            6\u001b[67;2H\u001b[?25h"]
