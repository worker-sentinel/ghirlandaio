[0.007, "o", "\u001b[1;65r\u001b[H\u001b[54L\u001b[1;67r\u001b[H\u001b[96mListen\u001b[m\u000f 80\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Dynamic Shared Object (DSO) Support\u001b[K\r\n#\u001b[K\r\n# To be able to use the functionality of a module which was built as a DSO you\u001b[K\r\n# have to place corresponding `LoadModule' lines at this location so the\u001b[K\r\n# directives contained in it are actually available _before_ they are used.\u001b[K\r\n# Statically compiled modules (those listed by `httpd -l') do not need\u001b[K\r\n# to be loaded here.\u001b[K\r\n#\u001b[K\r\n# Example:\u001b[K\r\n# LoadModule foo_module modules/mod_foo.so\u001b[K\r\n#\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f mpm_event_module modules/mod_mpm_event.so\u001b[K\r\n#LoadModule mpm_prefork_module modules/mod_mpm_prefork.so\u001b[K\r\n#LoadModule mpm_worker_module modules/mod_mpm_worker.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f authn_file_module modules/mod_authn_file.so\u001b[K\r\n#LoadModule authn_dbm_module modules/mod_authn_dbm.so\u001b[K\r\n#LoadModule authn_anon_module modules/mod_authn_anon.so\u001b[K\r\n#LoadModule authn_dbd_module modules/mod_authn_dbd.so\u001b[K\r\n#LoadModule authn_socache_module modules/mod_authn_socache.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f authn_core_module modules/mod_authn_core.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f authz_host_module modules/mod_authz_host.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f authz_groupfile_module modules/mod_authz_groupfile.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f authz_user_module modules/mod_authz_user.so\u001b[K\r\n#LoadModule authz_dbm_module modules/mod_authz_dbm.so\u001b[K\r\n#LoadModule authz_owner_module modules/mod_authz_owner.so\u001b[K\r\n#LoadModule authz_dbd_module modules/mod_authz_dbd.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f authz_core_module modules/mod_authz_core.so\u001b[K\r\n#LoadModule authnz_ldap_module modules/mod_authnz_ldap.so\u001b[K\r\n#LoadModule authnz_fcgi_module modules/mod_authnz_fcgi.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f access_compat_module modules/mod_access_compat.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f auth_basic_module modules/mod_auth_basic.so\u001b[K\r\n#LoadModule auth_form_module modules/mod_auth_form.so\u001b[K\r\n#LoadModule auth_digest_module modules/mod_auth_digest.so\u001b[K\r\n#LoadModule allowmethods_module modules/mod_allowmethods.so\u001b[K\r\n#LoadModule file_cache_module modules/mod_file_cache.so\u001b[K\r\n#LoadModule cache_module modules/mod_cache.so\u001b[K\r\n#LoadModule cache_disk_module modules/mod_cache_disk.so\u001b[K\r\n#LoadModule cache_socache_module modules/mod_cache_socache.so\u001b[K\r\n#LoadModule socache_shmcb_module modules/mod_socache_shmcb.so\u001b[K\r\n#LoadModule socache_dbm_module modules/mod_socache_dbm.so\u001b[K\r\n#LoadModule socache_memcache_module modules/mod_socache_memcache.so\u001b[K\r\n#LoadModule socache_redis_module modules/mod_socache_redis.so\u001b[K\r\n#LoadModule watchdog_module modules/mod_watchdog.so\u001b[K\r\n#LoadModule macro_module modules/mod_macro.so\u001b[K\r\n#LoadModule dbd_module modules/mod_dbd.so\u001b[K\r\n#LoadModule dumpio_module modules/mod_dumpio.so\u001b[K\r\n#LoadModule echo_module modules/mod_echo.so\u001b[K\r\n#LoadModule buffer_module modules/mod_buffer.so\u001b[K\r\n#LoadModule data_module modules/mod_data.so\u001b[K\r\n#LoadModule ratelimit_module modules/mod_ratelimit.so\u001b[K\r\n\u001b[96mLoadModule\u001b[m\u000f reqtimeout_module modules/mod_reqtimeout.so\u001b[K\u001b[65;13H\u001b[30m\u001b[103mproxy_\u001b[m\u000fhtml_module modules/mod_\u001b[30m\u001b[103mproxy_\u001b[66;224H\u001b[0;10;7m\u000f16,13         10\u001b[67;8H\u001b[?25h"]
