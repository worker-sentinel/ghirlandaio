[0.002, "o", "\r\u001b[K\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute       \u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d<Directory />\u001b[K\r\u001b[3d    AllowOverride none\u001b[K\r\u001b[4d    Require all denied\u001b[K\r\u001b[5d</Directory>\u001b[K\r\u001b[6d\u001b[K\u001b[7d#\u001b[K\u001b[8d\b# Note that from this point forward you must specifically allow\r\u001b[9d# particular features to be enabled - so if something's not working as\r\u001b[10d# you might expect, make sure that you have specifically enabled it\r\u001b[11d# below.\u001b[K\r\u001b[12d#\u001b[K\u001b[13d\b\u001b[K\u001b[14d#\u001b[K\u001b[15d DocumentRoot: The directory out of which you will serve your\r\u001b[16d# documents. By default, all requests are taken from this directory, but\r\u001b[17d# symbolic links and aliases may be used to point to other locations.\r\u001b[18d#\u001b[K\u001b[19d\bDocumentRoot \"/srv/http\"\u001b[K\r\u001b[20d<Directory \"/srv/http\">\u001b[K\r\u001b[21d    #\u001b[K\r\u001b[22d    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[23d    # or any combination of:\u001b[K\r\u001b[24d    #   Indexes \u001b[30m\u001b[43mInclude\u001b[39;49m\u001b[m\u000fs FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[25;5H#\r\u001b[26d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[27d    # doesn't give it to you.\r\u001b[28d    #\u001b[K\r\u001b[29d    # The Options directive is both complicated and important.  Please see\r\u001b[30d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[31d    # for more information.\u001b[K\r\u001b[32d    #\u001b[K\r\u001b[33d    Options Indexes FollowSymLinks\u001b[K\r\u001b[34d\u001b[K\u001b[35d    #\u001b[K\r\u001b[36d    # AllowOverride controls what directives may be placed in .htaccess files.\u001b[37;5H# It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[38d    #   AllowOverride FileInfo AuthConfig Limit\u001b[39;5H#\r\u001b[40d    AllowOverride None\u001b[K\r\u001b[41d\u001b[K\u001b[42d    #\u001b[K\r\u001b[43d    # Controls who can get stuff from this server.\u001b[K\r\u001b[44d    #\u001b[K\r\u001b[45d"]
