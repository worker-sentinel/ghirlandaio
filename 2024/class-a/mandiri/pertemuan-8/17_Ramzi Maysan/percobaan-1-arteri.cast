[0.001, "o", "\r\u001b[K\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute       \u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\r\u001b[2d|       ['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\r\u001b[3d|       ['failover'] array - A array with 0 or more data for connections if the main should fail.\r\u001b[4d|\u001b[9G['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\r\u001b[5d| \u001b[5;33HNOTE: Disabling this will also effectively disable both\u001b[6;3H\u001b[30X\u001b[6;33H$this->db->last_query() and profiling of DB queries.\u001b[7;3H\u001b[30X\u001b[7;33HWhen you run a query, with this setting set to TRUE (default),\u001b[8;3H\u001b[30X\u001b[8;33HCodeIgniter will store the SQL statement for debugging purposes.\u001b[9;3H\u001b[30X\u001b[9;33HHowever, this may cause high memory usage, especially if you run\u001b[10;33Ha lot of SQL queries ... disable this to avoid that problem.\u001b[11;3H\u001b[K\u001b[12dThe $active_group variable lets you choose which connection group to\u001b[13;3Hmake active.  By default there is only one group (the 'default' group).\u001b[14;3H\u001b[K\u001b[15dThe $query_builder variables lets you determine whether or not to load\u001b[16;3Hthe query builder class.\u001b[K\r\u001b[17d*/\r\u001b[18d$active_group = 'default';\u001b[K\r\u001b[19d"]
[0.000, "o", "$query_builder = TRUE;\u001b[K\r\u001b[20d"]
