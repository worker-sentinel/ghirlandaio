00f\u001b[K\r\u001b[25d\u001b[K\u001b[26d# Local access to the Apache HTTP Server Manual\r\u001b[27d#Include conf/extra/httpd-manual.conf\r\u001b[28d\u001b[K\u001b[29d# Distributed authoring and versioning (WebDAV)\u001b[K\r\u001b[30d#Include conf/extra/httpd-dav.conf\r\u001b[31d\u001b[K\u001b[32d# Various default settings\r\u001b[33dInclude conf/extra/httpd-default.conf\r\u001b[34d\u001b[K\u001b[35d# "]
