[0.655, "o", "\r\n\u001b[?2004l\r"]
[0.046, "o", "\u001b[0;10;1m\u000fWelcome to the MariaDB monitor.  Commands end with ; or \\g.\r\n"]
[0.001, "o", "\u001b[m\u000f\u001b[0;10;1m\u000fYour MariaDB connection id is 13\r\nServer version: 12.3.2-MariaDB Arch Linux\r\n\r\n\u001b[m\u000f\u001b[0;10;1m\u000fCopyright (c) 2000, 2018, Oracle, MariaDB Corporation Ab and others.\r\n\r\n\u001b[m\u000f"]
[0.001, "o", "\u001b[0;10;1m\u000fType 'help;' or '\\h' for help. Type '\\c' to clear the current input statement.\r\n\r\n"]
[0.001, "o", "\u001b[m\u000fMariaDB [(none)]> "]
