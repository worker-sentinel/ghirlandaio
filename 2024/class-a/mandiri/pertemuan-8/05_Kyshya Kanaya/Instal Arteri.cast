[0.001, "o", "                                                                                                                                                                     \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                                                                        \r\n                                                                                                                                                 