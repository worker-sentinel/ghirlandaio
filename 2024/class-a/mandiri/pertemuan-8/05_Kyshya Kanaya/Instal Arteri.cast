[0.013, "o", "\u001b[2;34H\u001b[30m\u001b[103mr\u001b[m\u000fve\u001b[30m\u001b[103mr\u001b[m\u000f configu\u001b[30m\u001b[103mr\u001b[3;10Hr\u001b[m\u000fation di\u001b[30m\u001b[103mr\u001b[m\u000fectives that give the se\u001b[30m\u001b[103mr\u001b[m\u000fve\u001b[30m\u001b[103mr\u001b[m\u000f its inst\u001b[30m\u001b[103mr\u001b[4;33Hr\u001b[m\u000fg/docs/2.4/> fo\u001b[30m\u001b[103mr\u001b[m\u000f detailed info\u001b[30m\u001b[103mr\u001b[5;8Hr\u001b[m\u000fticula\u001b[30m\u001b[103mr\u001b[6;29Hr\u001b[m\u000fg/docs/2.4/mod/di\u001b[30m\u001b[103mr\u001b[m\u000fe\u001b[7;5H\u001b[30m\u001b[103mr\u001b[m\u000f a discussion of each configu\u001b[30m\u001b[103mr\u001b[m\u000fation di\u001b[30m\u001b[103mr\u001b[m\u000fe\u001b[9;18Head the inst\u001b[30m\u001b[103mr\u001b[m\u000fuctions in he\u001b[30m\u001b[103mr\u001b[m\u000fe without unde\u001b[30m\u001b[103mr\u001b[10;24H\u001b[m\u000fe he\u001b[30m\u001b[103mr\u001b[m\u000fe only as hints o\u001b[30m\u001b[103mr\u001b[m\u000f \u001b[30m\u001b[103mr\u001b[m\u000feminde\u001b[30m\u001b[103mr\u001b[m\u000fs.  If you a\u001b[30m\u001b[103mr\u001b[m\u000fe unsu\u001b[30m\u001b[103mr\u001b[m\u000fe\u001b[11;44H\u001b[30m\u001b[103mr\u001b[13;10Hr\u001b[m\u000fation and logfile names: If the filenames you specify fo\u001b[30m\u001b[103mr\u001b[14;12Hr\u001b[m\u000fve\u001b[30m\u001b[103mr\u001b[m\u000f's cont\u001b[30m\u001b[103mr\u001b[m\u000fol files begin with \"/\" (o\u001b[30m\u001b[103mr\u001b[m\u000f \"d\u001b[30m\u001b[103mr\u001b[m\u000five:/\" fo\u001b[30m\u001b[103mr\u001b[15;5Hr\u001b[m\u000fve\u001b[30m\u001b[103mr\u001b[16;28Hr\u001b[m\u000fve\u001b[30m\u001b[103mr\u001b[m\u000fRoot is p\u001b[30m\u001b[103mr\u001b[m\u000fe\u001b[17;10H\u001b[30m\u001b[103mr\u001b[m\u000fve\u001b[30m\u001b[103mr\u001b[m\u000fRoot set to \"/us\u001b[30m\u001b[103mr\u001b[m\u000f/local/apache2\" will be inte\u001b[30m\u001b[103mr\u001b[m\u000fp\u001b[30m\u001b[103mr\u001b[m\u000fe\u001b[18;5H\u001b[30m\u001b[103mr\u0