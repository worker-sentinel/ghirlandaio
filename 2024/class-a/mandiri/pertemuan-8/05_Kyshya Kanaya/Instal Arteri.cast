[0.005, "o", "\u001b[1;54r\u001b[H\u001b[25L\u001b[1;56r\u001b[H; https://php.net/from\u001b[K\r\n;from=\"john@doe.com\"\u001b[K\r\n\u001b[K\n; Define the User-Agent string. PHP's default setting for this is empty.\u001b[K\r\n; https://php.net/user-agent\u001b[K\r\n;user_agent=\"PHP\"\u001b[K\r\n\u001b[K\n; Default timeout for socket based streams (seconds)\u001b[K\r\n; https://php.net/default-socket-timeout\u001b[K\r\ndefault_socket_timeout = 60\u001b[K\r\n\u001b[K\n; If your scripts have to deal with files from Macintosh systems,\u001b[K\r\n; or you are running on a Mac and need to deal with files from\u001b[K\r\n; unix or win32 systems, setting this flag will cause PHP to\u001b[K\r\n; automatically detect the EOL character in those files so that\u001b[K\r\n; fgets() and file() will work regardless of the source of the file.\u001b[K\r\n; https://php.net/auto-detect-line-endings\u001b[K\r\n;auto_detect_line_endings = Off\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; Dynamic Extensions ;\u001b[K\r\n;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\n\u001b[K\n; If you wish to have an extension loaded automatically, use the following\u001b[K\r\n; syntax:\u001b[K\u001b[27;5H\u001b[30m\u001b[103mextension=\u001b[31;5Hextension=\u001b[36;5Hextension=\u001b[38;53Hextension=\u001b[39;4Hextension=\u001b[41;21Hextension=\u001b[43;2Hextension=\u001b[44;2Hextension=\u001b[45;2Hextension=\r\nextension=\u001b[47;2Hextension=\u001b[48;2Hextension=\u001b[49;2Hextension=\u001b[50;2Hextension=\u001b[51;2Hextension=\r\nextension=\u001b[m\u000f\u001b[92mg\u001b[53;11Hg\n\u001b[m\u000fg\u001b[55;183H\u001b[0;10;7m\u000f896,5          47\u001b[56;12H\u001b[?25h"]
