[0.005, "o", "\u001b[43;61H\u001b[30m\u001b[103mE\u001b[45;9HE\u001b[m\u000f_ALL & ~\u001b[30m\u001b[103mE\u001b[m\u000f_NOTIC\u001b[30m\u001b[103mE\u001b[48;3HE\u001b[55;183H\u001b[0;10;7m\u000f43,61\u001b[56;3H\u001b[?25h"]
[0.467, "o", "\u001b[?25l\u001b[m\u000fX"]
[0.007, "o", "\u001b[H; Maximum input variable nesting level\r\n; https://php.net/max-input-nesting-level\u001b[3;2Hmax_input_nesting_level = 64\r\n\u001b[19X\u001b[5;2H How many GET/POST/COOKIE input variables may be accepted\u001b[6;2Hmax_input_vars = 1000\u001b[51X\r\n\u001b[52X\n; How many multipart body parts (combined input variable and file uploads) may\u001b[9;3Hbe accepted.\u001b[64X\u001b[10;3HDefault Value: -1 (Sum of max_input_vars and max_file_uploads)\u001b[11;2Hmax_multipart_body_parts = 1500   \r\n\u001b[36X\u001b[13;3HMaximum amount of memory a script may consume\u001b[5X\u001b[14;3Hhttps://php.net/memory-limit\u001b[13X\r\nmemory_limit =\u001b[92m 128M\u001b[m\u000f\u001b[52X\r\nmax_memory_limit =\u001b[92m -1\u001b[m\u000f   \r\n\u001b[79X\u001b[18;2H;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[10X\u001b[19;3HError handling and logging ;\u001b[19X\u001b[20;2H;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[6X\u001b[22;5His directive informs PHP of which errors, warnings and notices you would like\u001b[23;3Hit to take action for. The recommended way of setting values for this\u001b[5X\u001b[24;3Hdirective is through the use of the error level constants and bitwise\u001b[25;3Hoperators. The error level constants are below here for convenience as well as\r\n; some common settings and their meanings.\u001b[27;3HBy default, PHP is set to take action on all errors, notices and warnings \u001b[30m\u001b[103mEX\u001b[m\u000fCEPT\u001b[28;3Hthose related to E_NOTICE, which together cover best practices and\u001b[29;3Hrecommended coding standards in PHP. For performance reasons, this is the\u001b[30;3Hrecommend error reporting setting. Your production server shouldn't be wasting\u001b[31;3Hresources complaining about best practices and coding standards. That's what\u001b[32;3Hdevelopment servers and development settings are for.\u001b[14X\u001b[33;3HNote: The php.ini-development file has this setting as E_ALL. This\u001b[34;3Hmeans it pretty much reports everything which is exactly what you want during\r\n; development and early testing.\u001b[36;2H\u001b[53X\u001b[37;3HError Level Constants:\u001b[38;3HE_ALL             - All errors and warnings\u001b[30X\u001b[39;3HE_ERROR           - fatal run-time errors\u001b[24X\u001b[40;3HE_RECOVERABLE_ERROR  - almost fatal run-time errors\u001b[8X\u001b[41;3HE_WARNING         - run-time warnings (non-fatal errors)\u001b[21X\r\n; E_PARSE           - compile-time parse errors\u001b[43;3HE_NOTICE          - run-time notices (these are warnings which often result  \u001b[44;3H                    from a bug in your code, but it's possible that it was    \u001b[45;3H                    intentional (e.g., using an uninitialized variable and\u001b[46;3H                    relying on the fact it is automatically initialized to an\r\n;                     empty string)\u001b[48;3HE_CORE_ERROR      - fatal errors that occur during PHP's initial startup\u001b[5X\u001b[49;3HE_CORE_WARNING    - warnings (non-fatal errors) that occur during PHP's\u001b[50;3H                    initial startup\u001b[51;3HE_COMPILE_ERROR   - fatal compile-time errors\u001b[52;3HE_COMPILE_WARNING - compile-time warnings (non-fatal errors)\u001b[53;3HE_USER_ERROR      - user-generated error message\r\n; E_USER_WARNING    - user-generated warning message\u001b[55;184H\u001b[0;10;7m\u000f42,77         22%\u001b[56;4H\u001b[?25h"]
[3.049, "o", "\u001b[?25l\u001b[m\u000fT"]
[0.007, "o", "\u001b[H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mPHP\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[m\u000f\u001b[33X\r\n\u001b[41X\u001b[3;2H;;;;;;;;;;;;;;;;;;\u001b[10X\r\n; About php.ini   ;\u001b[5;2H;;;;;;;;;;;;;;;;;;\u001b[39X\u001b[6;2H PHP's initialization file, generally called php.ini, is responsible for\r\n; configuring many of the aspects of PHP's behavior.\r\n\u001b[78X\u001b[9;3HPHP attempts to find and load this configuration from a number of locations.\u001b[10;3HThe following is a summary of its search order:\u001b[15X\u001b[11;2H 1. SAPI module specific location.\r\n; 2. The PHPRC environment variable.\u001b[13;3H3. A number of predefined registry keys on Windows\u001b[14;3H4. Current working directory (except CLI)\r\n; 5. The web server's directory (for SAPI modules), or directory of PHP\r\n; (otherwise in Windows)\r\n; 6. The directory from the --with-config-file-path compile time option, or the\u001b[18;2H Windows directory (usually C:\\windows)\u001b[19;3HSee the PHP docs for more specific information.\u001b[20;2H https://php.net/configuration.file\u001b[22;5He syntax of the file is extremely simple.  Whitespace and lines\u001b[14X\u001b[23;3Hbeginning with a semicolon are silently ignored (as you probably guessed).\u001b[24;3HSection headers (e.g. [Foo]) are also silently ignored, even though  \u001b[25;3Hthey might mean something in the future.\u001b[38X\r\n\u001b[42X\u001b[27;3HDirectives following the section heading [PATH=/www/mysite] only\u001b[16X\u001b[28;3Happly to PHP files in the /www/mysite directory.  Directives\u001b[6X\u001b[29;3Hfollowing the section heading [HOST=www.example.com] only apply to\u001b[7X\u001b[30;3HPHP files served from www.example.com.  Directives set in these\u001b[15X\u001b[31;3Hspecial sections cannot be overridden by user-defined INI files or\u001b[10X\u001b[32;3Hat runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[33;3HCGI/FastCGI.\u001b[54X\u001b[34;3Hhttps://php.net/ini.sections\u001b[49X\r\n\u001b[32X\u001b[36;2H Directives are specified using the following syntax:\u001b[37;3Hdirective = value\u001b[5X\u001b[38;3HDirective names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[39;3HDirectives are variables used to configure PHP or PHP extensions.\u001b[40;3HThere is no name validation.  If PHP can't find an expected\u001b[41;3Hdirective because it is not set or is mistyped, a default value will be used.\r\n\u001b[47X\u001b[43;3HThe value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[44;3Hof the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[45;3H(e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a    \u001b[46;3Hpreviously set variable or directive (e.g. ${foo})\u001b[27X\r\n\u001b[35X\u001b[48;4Hxpressions in the INI file are limited to bitwise operators and parentheses:\u001b[49;3H|  bitwise OR\u001b[58X\u001b[50;3H^  bitwise XOR\u001b[21X\u001b[51;3H&  bitwise AND\u001b[31X\u001b[52;3H~  bitwise NOT\u001b[46X\u001b[53;3H!  boolean NOT\u001b[34X\r\n\u001b[52X\u001b[55;183H\u001b[0;10;7m\u000f1,1            Top\u001b[56;5H\u001b[?25h"]
