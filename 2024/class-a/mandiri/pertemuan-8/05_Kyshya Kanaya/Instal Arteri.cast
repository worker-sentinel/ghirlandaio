[0.004, "o", "\u001b[2;5H\u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[4;5He\u001b[m\u000fn th\u001b[30m\u001b[103me\u001b[m\u000f \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion library to load is not locat\u001b[30m\u001b[103me\u001b[m\u000fd in th\u001b[30m\u001b[103me\u001b[m\u000f d\u001b[30m\u001b[103me\u001b[m\u000ffault \u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[5;6He\u001b[m\u000fctory, You may sp\u001b[30m\u001b[103me\u001b[m\u000fcify an absolut\u001b[30m\u001b[103me\u001b[m\u000f path to th\u001b[30m\u001b[103me\u001b[m\u000f library fil\u001b[30m\u001b[103me\u001b[7;5He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=/path/to/\u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[9;6He\u001b[m\u000f : Th\u001b[30m\u001b[103me\u001b[m\u000f syntax us\u001b[30m\u001b[103me\u001b[m\u000fd in pr\u001b[30m\u001b[103me\u001b[m\u000fvious PHP v\u001b[30m\u001b[103me\u001b[m\u000frsions ('\u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=<\u001b[30m\u001b[103me\u001b[10;4He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion='php_<\u001b[30m\u001b[103me\u001b[m\u000fxt>.dll') is support\u001b[30m\u001b[103me\u001b[m\u000fd for l\u001b[30m\u001b[103me\u001b[m\u000fgacy r\u001b[30m\u001b[103me\u001b[m\u000fasons and may b\u001b[30m\u001b[103me\u001b[11;4He\u001b[m\u000fpr\u001b[30m\u001b[103me\u001b[m\u000fcat\u001b[30m\u001b[103me\u001b[m\u000fd in a futur\u001b[30m\u001b[103me\u001b[m\u000f PHP major v\u001b[30m\u001b[103me\u001b[m\u000frsion. So, wh\u001b[30m\u001b[103me\u001b[m\u000fn it is possibl\u001b[30m\u001b[103me\u001b[m\u000f, pl\u001b[30m\u001b[103me\u001b[m\u000fas\u001b[30m\u001b[103me\u001b[12;6He\u001b[m\u000f to th\u001b[30m\u001b[103me\u001b[m\u000f n\u001b[30m\u001b[103me\u001b[m\u000fw ('\u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=<\u001b[30m\u001b[103me\u001b[14;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[15;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[16;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=cal\u001b[30m\u001b[103me\r\ne\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[18;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[19;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=\u001b[30m\u001b[103me\u001b[20;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=\u001b[30m\u001b[103me\u001b[21;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[22;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\r\ne\u001b[m\u000fxt\u001b[30m\u001b[103me\r\ne\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=\u001b[92mg\u001b[m\u000f\u001b[30m\u001b[103me\u001b[m\u000f\u001b[92mtt\u001b[m\u000f\u001b[30m\u001b[103me\u001b[25;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[26;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\r\ne\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=\u001b[92mintl\u001b[28;2H\u001b[m\u000f\u001b[30m\u001b[103me\u001b[m\u000fxt\u001b[30m\u001b[103me\r\ne\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[30;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[31;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\r\ne\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[33;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[34;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[35;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=pdo_sqlit\u001b[30m\u001b[103me\u001b[36;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[37;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[38;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[39;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[40;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=sock\u001b[30m\u001b[103me\u001b[41;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[42;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion=sqlit\u001b[30m\u001b[103me\u001b[43;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[44;2He\u001b[m\u000fxt\u001b[30m\u001b[103me\u001b[m\u000fnsion