[0.014, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[0.002, "o", "\u001b[?25l\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mPHP\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[m\u000f\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; About php.ini   ;\u001b[K\r\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; PHP's initialization file, generally called php.ini, is responsible for\u001b[K\r\n; configuring many of the aspects of PHP's behavior.\u001b[K\r\n\u001b[K\n; PHP attempts to find and load this configuration from a number of locations.\u001b[K\r\n; The following is a summary of its search order:\u001b[K\r\n; 1. SAPI module specific location.\u001b[K\r\n; 2. The PHPRC environment variable.\u001b[K\r\n; 3. A number of predefined registry keys on Windows\u001b[K\r\n; 4. Current working directory (except CLI)\u001b[K\r\n; 5. The web server's directory (for SAPI modules), or directory of PHP\u001b[K\r\n; (otherwise in Windows)\u001b[K\r\n; 6. The directory from the --with-config-file-path compile time option, or the\u001b[K\r\n; Windows directory (usually C:\\windows)\u001b[K\r\n; See the PHP docs for more specific information.\u001b[K\r\n; https://php.net/configuration.file\u001b[K\r\n\u001b[K\n; The syntax of the file is extremely simple.  Whitespace and lines\u001b[K\r\n; beginning with a semicolon are silently ignored (as you probably guessed).\u001b[K\r\n; Section headers (e.g. [Foo]) are also silently ignored, even though\u001b[K\r\n; they might mean something in the future.\u001b[K\r\n\u001b[K\n; Directives following the section heading [PATH=/www/mysite] only\u001b[K\r\n; apply to PHP files in the /www/mysite directory.  Directives\u001b[K\r\n; following the section heading [HOST=www.example.com] only apply to\u001b[K\r\n; PHP files served from www.example.com.  Directives set in these\u001b[K\r\n; special sections cannot be overridden by user-defined INI files or\u001b[K\r\n; at runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[K\r\n; CGI/FastCGI.\u001b[K\r\n; https://php.net/ini.sections\u001b[K\r\n\u001b[K\n; Directives are specified using the following syntax:\u001b[K\r\n; directive = value\u001b[K\r\n; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[K\r\n; Directives are variables used to configure PHP or PHP extensions.\u001b[K\r\n; There is no name validation.  If PHP can't find an expected\u001b[K\r\n; directive because it is not set or is mistyped, a default value will be used.\u001b[K\r\n\u001b[K\n; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[K\r\n; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[K\r\n; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[K\r\n; previously set variable or directive (e.g. ${foo})\u001b[K\r\n\u001b[K\n; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[K\r\n; |  bitwise OR\u001b[K\r\n; ^  bitwise XOR\u001b[K\r\n; &  bitwise AND\u001b[K\r\n; ~  bitwise NOT\u001b[K\r\n; !  boolean NOT\u001b[K\r\n\u001b[K\n\u001b[0;10;7m\u000f/etc/php/php.ini                                                                                                                                                                      1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H\u001b[0;10;4;1m\u000f\u001b[96m[\u001b[m\u000f\u001b[96mPHP\u001b[0;10;4;1m\u000f\u001b[96m]\u001b[m\u000f\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; About php.ini   ;\u001b[K\r\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; PHP's initialization file, generally called php.ini, is responsible for\u001b[K\r\n; configuring many of the aspects of PHP's behavior.\u001b[K\r\n\u001b[K\n; PHP attempts to find and load this configuration from a number of locations.\u001b[K\r\n; The following is a summary of its search order:\u001b[K\r\n; 1. SAPI module specific location.\u001b[K\r\n; 2. The PHPRC environment variable.\u001b[K\r\n; 3. A number of predefined registry keys on Windows\u001b[K\r\n; 4. Current working directory (except CLI)\u001b[K\r\n; 5. The web server's directory (for SAPI modules), or directory of PHP\u001b[K\r\n; (otherwise in Windows)\u001b[K\r\n; 6. The directory from the --with-config-file-path compile time option, or the\u001b[K\r\n; Windows directory (usually C:\\windows)\u001b[K\r\n; See the PHP docs for more specific information.\u001b[K\r\n; https://php.net/configuration.file\u001b[K\r\n\u001b[K\n; The syntax of the file is extremely simple.  Whitespace and lines\u001b[K\r\n; beginning with a semicolon are silently ignored (as you probably guessed).\u001b[K\r\n; Section headers (e.g. [Foo]) are also silently ignored, even though\u001b[K\r\n; they might mean something in the future.\u001b[K\r\n\u001b[K\n; Directives following the section heading [PATH=/www/mysite] only\u001b"]
[0.001, "o", "[K\r\n; apply to PHP files in the /www/mysite directory.  Directives\u001b[K\r\n; following the section heading [HOST=www.example.com] only apply to\u001b[K\r\n; PHP files served from www.example.com.  Directives set in these\u001b[K\r\n; special sections cannot be overridden by user-defined INI files or\u001b[K\r\n; at runtime. Currently, [PATH=] and [HOST=] sections only work under\u001b[K\r\n; CGI/FastCGI.\u001b[K\r\n; https://php.net/ini.sections\u001b[K\r\n\u001b[K\n; Directives are specified using the following syntax:\u001b[K\r\n; directive = value\u001b[K\r\n; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[K\r\n; Directives are variables used to configure PHP or PHP extensions.\u001b[K\r\n; There is no name validation.  If PHP can't find an expected\u001b[K\r\n; directive because it is not set or is mistyped, a default value will be used.\u001b[K\r\n\u001b[K\n; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[K\r\n; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[K\r\n; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[K\r\n; previously set variable or directive (e.g. ${foo})\u001b[K\r\n\u001b[K\n; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[K\r\n; |  bitwise OR\u001b[K\r\n; ^  bitwise XOR\u001b[K\r\n; &  bitwise AND\u001b[K\r\n; ~  bitwise NOT\u001b[K\r\n; !  boolean NOT\u001b[K\r\n\u001b[K\n\u001b[0;10;7m\u000f/etc/php/php.ini                                                                                                                                                                      1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
