[0.012, "o", "\u001b[1;2HLoadModule lbmethod_heartbeat_module modules/mod_lbmethod_heartbeat.so\r\n\u001b[96mLoadModule\u001b[m\u000f unixd_module modules/mod_unixd.so\u001b[30X\u001b[3;2HLoadModule heartbeat_module modules/mod_heartbeat.so\u001b[12X\u001b[4;2HLoadModule heartmonitor_module modules/mod_heartmonitor.so\u001b[12X\u001b[5;2HLoadModule dav_module modules/mod_dav.so\r\n\u001b[96mLoadModule\u001b[m\u000f status_module modules/mod_status.so\u001b[14X\r\n\u001b[96mLoadModule\u001b[m\u000f autoindex_module modules/mod_autoindex.so\u001b[8;2HLoadModule asis_module modules/mod_asis.so\u001b[9;2HLoadModule info_module modules/mod_info.so\u001b[24X\u001b[10;2HLoadModule suexec_module modules/mod_suexec.so\u001b[29X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f !mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[20X\r\n        #LoadModule cgid_module modules/mod_cgid.so\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[61X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f mpm_prefork_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[47X\r\n        #LoadModule cgi_module modules/mod_cgi.so\u001b[21X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[61X\u001b[17;2HLoadModule dav_fs_module modules/mod_dav_fs.so\u001b[25X\u001b[18;2HLoadModule dav_lock_module modules/mod_dav_lock.so\u001b[26X\u001b[19;2HLoadModule vhost_alias_module modules/mod_vhost_alias.so\r\n\u001b[96mLoadModule\u001b[m\u000f negotiation_module modules/mod_negotiation.so\r\n\u001b[96mLoadModule\u001b[m\u000f dir_module modules/mod_dir.so\u001b[22;2HLoadModule imagemap_module modules/mod_imagemap.so\u001b[17X\u001b[23;2HLoadModule actions_module modules/mod_actions.so\u001b[24;2HLoadModule speling_module modules/mod_speling.so\r\n\u001b[96mLoadModule\u001b[m\u000f userdir_module modules/mod_userdir.so\u001b[20X\r\n\u001b[96mLoadModule\u001b[m\u000f alias_module modules/mod_alias.so\u001b[28X\r\n\u001b[96mLoadModule\u001b[m\u000f \u001b[30m\u001b[103mrew\u001b[m\u000frite_module modules/mod_\u001b[30m\u001b[103mrew\u001b[m\u000frite.so\u001b[28X\r\n\u001b[72X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\r\n\n\u001b[m\u000f# If you wish httpd to run as a different user or group, you must run\r\n# httpd as root initially and it will switch.  \u001b[34;3HUser/Group: The name (or #number) of the user/group to run httpd as. \u001b[35;3HIt is usually good practice to create a dedicated user and group for\u001b[36;2H running httpd, as with most system services.\u001b[37;2H\u001b[77X\r\n\u001b[96mUser\u001b[m\u000f http\u001b[67X\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[5X\r\n \r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[15X\u001b[43;2H 'Main' server configuration\u001b[44;2H\u001b[66X\u001b[45;3HThe directives in this section set up the values used by the 'main'\u001b[46;3Hserver, which responds to any requests that aren't handled by a\u001b[47;2H <VirtualHost> definition.  These values also provide defaults for\u001b[48;3Hany <VirtualHost> containers you may define later in the file.   \u001b[49;2H\u001b[58X\n All of these directives may appear inside <VirtualHost> containers,\u001b[51;2H in which case these default settings will be overridden for the\r\n# virtual host being defined.\r\n#\r\n \u001b[55;183H\u001b[0;10;7m\u000f189,12         32%\u001b[56;5H\u001b[?25h"]
