[0.005, "o", "\u001b[H; https://php.net/from\r\n;from=\"john@doe.com\"\r\n\u001b[19X\u001b[4;3HDefine the User-Agent string. PHP's default setting for this is empty.\u001b[5;2H https://php.net/user-agent\u001b[6;2Huser_agent=\"PHP\"\u001b[56X\r\n\u001b[52X\n; Default timeout for socket based streams (seconds)\u001b[9;3Hhttps://php.net/default-socket-timeout\u001b[38X\r\ndefault_socket_timeout = 60\u001b[22X\r\n\u001b[35X\u001b[12;3HIf your scripts have to deal with files from Macintosh systems,\u001b[13;3Hor you are running on a Mac and need to deal with files from\u001b[14;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[15;3Hautomatically detect the EOL character in those files so that\u001b[8X\u001b[16;3Hfgets() and file() will work regardless of the source of the file.\u001b[17;3Hhttps://php.net/auto-detect-line-endings\u001b[37X\u001b[18;2Hauto_detect_line_endings = Off\u001b[9X\r\n\u001b[49X\u001b[20;2H;;;;;;;;;;;;;;;;;;;;;\u001b[14X\r\n; Dynamic Extensions ;\u001b[22;2H;;;;;;;;;;;;;;;;;;;;;\u001b[45X\r\n\u001b[76X\u001b[24;3HIf you wish to have an extension loaded automatically, use the following\u001b[25;3Hsyntax:\u001b[33X\r\n;\u001b[27;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000fmodulename\u001b[42X\u001b[28;2H\u001b[61X\u001b[29;3HFor example:\u001b[54X\u001b[30;2H\u001b[64X\u001b[31;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000fmysqli\u001b[48X\u001b[32;2H\u001b[68X\u001b[33;3HWhen the extension library to load is not located in the default extension\u001b[34;3Hdirectory, You may specify an absolute path to the library file:\r\n;\u001b[36;3H  \u001b[30m\u001b[103mextension=\u001b[m\u000f/path/to/extension/mysqli.so\u001b[12X\u001b[37;2H\u001b[18X\u001b[38;3HNote : The syntax used in previous PHP versions ('\u001b[30m\u001b[103mextension=\u001b[m\u000f<ext>.so' and\u001b[39;3H'\u001b[30m\u001b[103mextension=\u001b[m\u000f'php_<ext>.dll') is supported for legacy reasons and may be\u001b[40;3Hdeprecated in a future PHP major version. So, when it is possible, please\u001b[41;3Hmove to the new ('\u001b[30m\u001b[103mextension=\u001b[m\u000f<ext>) syntax.\u001b[35X\r\n;\n\u001b[30m\u001b[103mextension=\u001b[m\u000fbcmath\u001b[62X\u001b[44;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fbz2\u001b[66X\u001b[45;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fcalendar\u001b[53X\r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mcurl\u001b[m\u000f\u001b[38X\r\n;\u001b[30m\u001b[103mextension=\u001b[m\u000fdba\u001b[48;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fenchant\u001b[61X\u001b[49;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fexif\u001b[50;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fffi  \u001b[51;2H\u001b[30m\u001b[103mextension=\u001b[m\u000fftp  \r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mgd\u001b[m\u000f    \r\n\u001b[30m\u001b[103mextension=\u001b[m\u000f\u001b[92mgettext\r\n\u001b[m\u000f;\u001b[30m\u001b[103mextension=\u001b[m\u000fgmp\u001b[55;183H\u001b[0;10;7m\u000f896,5          47%\u001b[56;12H\u001b[?25h"]
