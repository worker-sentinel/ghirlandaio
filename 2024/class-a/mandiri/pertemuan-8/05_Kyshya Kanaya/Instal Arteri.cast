[0.005, "o", "\u001b[1;54r\u001b[H\u001b[28M\u001b[1;56r\u001b[3;5Hextension=\u001b[8;5Hextension=\u001b[10;53Hextension=\u001b[11;4Hextension=\u001b[13;21Hextension=\u001b[15;2Hextension=\u001b[16;2Hextension=\u001b[17;2Hextension=\r\nextension=\u001b[19;2Hextension=\u001b[20;2Hextension=\u001b[21;2Hextension=\u001b[22;2Hextension=\u001b[23;2Hextension=\r\nextension=\r\nextension=\u001b[26;2Hextension=\r\n;\u001b[30m\u001b[103mextension=i\u001b[m\u000fconv\u001b[K\r\n;\u001b[30m\u001b[103mextension=i\u001b[m\u000fntl\u001b[K\r\n;extension=ldap\u001b[K\r\nextension=\u001b[92mmysqli\u001b[m\u000f\u001b[K\r\n;extension=odbc\u001b[K\r\n;extension=pdo_dblib\u001b[K\r\nextension=\u001b[92mpdo_mysql\u001b[m\u000f\u001b[K\r\n;extension=pdo_odbc\u001b[K\r\n;extension=pdo_pgsql\u001b[K\r\n;extension=pdo_sqlite\u001b[K\r\n;extension=pgsql\u001b[K\r\n;extension=shmop\u001b[K\r\n;extension=snmp\u001b[K\r\n;extension=soap\u001b[K\r\n;extension=sockets\u001b[K\r\n;extension=sodium\u001b[K\r\n;extension=sqlite3\u001b[K\r\n;extension=sysvmsg\u001b[K\r\n;extension=sysvsem\u001b[K\r\n;extension=sysvshm\u001b[K\r\n;extension=tidy\u001b[K\r\n;extension=xsl\u001b[K\r\nextension=\u001b[92mzip\u001b[m\u000f\u001b[K\r\nextension=\u001b[92mxml\u001b[m\u000f\u001b[K\r\nextension=\u001b[92mmbstring\u001b[m\u000f\u001b[K\r\n\u001b[K\n;;;;;;;;;;;;;;;;;;;\u001b[K\r\n; Module Settings ;\u001b[K\u001b[55;183H\u001b[0;10;7m\u000f924,2          49\u001b[56;13H\u001b[?25h"]
