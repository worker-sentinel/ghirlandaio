[0.001, "o", "\u001b[?25l\u001b[m\u000f# Virtual Hosts\u001b[K\r\n#\u001b[K\r\n# Required modules: mod_log_config\u001b[K\r\n\u001b[K\n# If you want to maintain multiple domains/hostnames on your\u001b[K\r\n# machine you can setup VirtualHost containers for them. Most configurations\u001b[K\r\n# use only name-based virtual hosts so the server doesn't need to worry about\u001b[K\r\n# IP addresses. This is indicated by the asterisks in the directives below.\u001b[K\r\n#\u001b[K\r\n# Please see the documentation at \u001b[K\r\n# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\u001b[K\r\n# for further details before you try to setup virtual hosts.\u001b[K\r\n#\u001b[K\r\n# You may use the command line option '-S' to verify your virtual host\u001b[K\r\n# configuration.\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# VirtualHost example:\u001b[K\r\n# Almost any Apache directive may go into a VirtualHost container.\u001b[K\r\n# The first VirtualHost section is used for all requests that do not\u001b[K\r\n# match a ServerName or ServerAlias in any <VirtualHost> block.\u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<VirtualHost\u001b[m\u000f *:80\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      \u001b[96mServerName\u001b[m\u000f arteri.local\u001b[K\r\n      \u001b[96mServerAlias\u001b[m\u000f 192.168.1.9\u001b[K\r\n      \u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http/arteri/public\"\u001b[m\u000f\u001b[K\r\n \u001b[96mDirectoryIndex\u001b[m\u000f index.php index.htm\u001b[K\r\n \u001b[K\r\n    \u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/arteri/public\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      \u001b[96mAllowOverride\u001b[m\u000f ALL\u001b[K\r\n      \u001b[96mRequire\u001b[m\u000f all granted\u001b[K\r\n    \u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\r\n\u001b[K\n    \u001b[0;10;1m\u000f<FilesMatch\u001b[m\u000f \"\\.php$\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      \u001b[96mSetHandler\u001b[m\u000f \u001b[92m\"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[m\u000f\u001b[K\r\n    \u001b[0;10;1m\u000f</FilesMatch>\u001b[m\u000f   \u001b[K\r\n\u001b[0;10;1m\u000f</VirtualHost>\u001b[m\u000f\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000f/etc/httpd/conf/extra/httpd-vhosts.conf                                                                                                                                               1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H# Virtual Hosts\u001b[K\r\n#\u001b[K\r\n# Required modules: mod_log_config\u001b[K\r\n\u001b[K\n# If you want to maintain multiple domains/hostnames on your\u001b[K\r\n# machine you can setup VirtualHost containers for them. Most configurations\u001b[K\r\n# use only name-based virtual hosts so the server doesn't need to worry about\u001b[K\r\n# IP addresses. This is indicated by the asterisks in the directives below.\u001b[K\r\n#\u001b[K\r\n# Please see the documentation at \u001b[K\r\n# <URL:http://httpd.apache.org/docs/2.4/vhosts/>\u001b[K\r\n# for further details before you try to setup virtual hosts.\u001b[K\r\n#\u001b[K\r\n# You may use the command line option '-S' to verify your virtual host\u001b[K\r\n# configuration.\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# VirtualHost example:\u001b[K\r\n# Almost any Apache directive may go into a VirtualHost container.\u001b[K\r\n# The first VirtualHost section is used for all requests that do not\u001b[K\r\n# match a ServerName or ServerAlias in any <VirtualHost> block.\u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<VirtualHost\u001b[m\u000f *:80\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      \u001b[96mServerName\u001b[m\u000f arteri.local\u001b[K\r\n      \u001b[96mServerAlias\u001b[m\u000f 192.168.1.9\u001b[K\r\n      \u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http/arteri/public\"\u001b[m\u000f\u001b[K\r\n \u001b[96mDirectoryIndex\u001b[m\u000f index.php index.htm\u001b[K\r\n\u001b[K\n    \u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/arteri/public\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      \u001b[96mAllowOverride\u001b[m\u000f ALL\u001b[K\r\n      \u001b[96mRequire\u001b[m\u000f all granted\u001b[K\r\n    \u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\r\n\u001b[K\n    \u001b[0;10;1m\u000f<FilesMatch\u001b[m\u000f \"\\.php$\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n      \u001b[96mSetHandler\u001b[m\u000f \u001b[92m\"proxy:unix:/run/php-fpm/php-fpm.sock|fcgi://localhost/\"\u001b[m\u000f\u001b[K\r\n    \u001b[0;10;1m\u000f</FilesMatch>\u001b[m\u000f\u001b[K\r\n\u001b[0;10;1m\u000f</VirtualHost>\u001b[m\u000f\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n~\u001b[K\r\n\u001b[0;10;7m\u000f/etc/httpd/conf/extra/httpd-vhosts.conf                                                                                                                                               1,1            All\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
