[0.002, "o", "\u001b[46;77H\u001b[0;10;7m\u000f[ Read 81 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                               /etc/mkinitcpio.conf                                                                         \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H"]
[0.000, "o", "\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H"]
[0.000, "o", "\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d# vim:set ft=sh:\r\u001b[3d# MODULES\r\u001b[4d# The following modules are loaded before any boot hooks are\r\u001b[5d# run.  Advanced users may wish to specify all system modules\r\u001b[6d# in this array.  For instance:\r\u001b[7d#     MODULES=(usbhid xhci_hcd)\r\u001b[8dMODULES=()\r\u001b[10d# BINARIES\r\u001b[11d# This setting includes any additional binaries a given user may\r\u001b[12d# wish into the CPIO image.  This is run last, so it may be used to\r\u001b[13d# override the actual binaries included by a given hook\r\u001b[14d"]
[0.000, "o", "# BINARIES are dependency parsed, so you may safely ignore libraries\r\u001b[15dBINARIES=()\r\u001b[17d"]
[0.000, "o", "# FILES\r\u001b[18d"]
[0.000, "o", "# This setting is similar to BINARIES above, however, files are added\r\u001b[19d"]
[0.000, "o", "# as-is and are not parsed in any way.  This is useful for config files.\r\u001b[20dFILES=()\r\u001b[22d# HOOKS\r\u001b[23d# This is the most important setting in this file.  The HOOKS control the\r\u001b[24d# modules and scripts added to the image, and what happens at boot time.\r\u001b[25d# Order is important, and it is recommended that you do not change the\r\u001b[26d# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\r\u001b[27d# help on a given hook.\r\u001b[28d# 'base' is _required_ unless you know precisely what you are doing.\r\u001b[29d# 'udev' is _required_ in order to automatically load modules\r\u001b[30d# 'filesystems' is _required_ unless you specify your fs modules in MODULES\r\u001b[31d# Examples:\r\u001b[32d##   This setup specifies all modules in the MODULES setting above.\r\u001b[33d##   No RAID, lvm2, or encrypted root is needed.\r\u001b[34d#    HOOKS=(base)\r\u001b[35d#\u001b[36d\b##   This setup will autodetect all modules for your system and should\r\u001b[37d##   work as a sane default\r\u001b[38d#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\r\u001b[39d"]
[0.000, "o", "#\u001b[40d\b"]
[0.000, "o", "##   This setup will generate a 'full' image which supports most systems.\r\u001b[41d##   No autodetection is done.\r\u001b[42d#    HOOKS=(base udev microcode modconf block filesystems fsck)\r\u001b[43d#\u001b[44d\b##   This setup assembles a mdadm array with an encrypted root file system.\r\u001b[45d##   Note: See 'mkinitcpio -H mdadm_udev' for more information on RAID devices.\r\u001b[2d\u001b[?25h\u001b[?0c"]
