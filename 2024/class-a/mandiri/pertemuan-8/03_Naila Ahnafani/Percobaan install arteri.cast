[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1HErrorLog \"/var/log/httpd/error_log\"\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H#\b"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H# container, that host's errors will be logged there and not here.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "# logged here.  If you *do* define an error logfile for a <VirtualHost>\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H# container, error messages relating to that virtual host will be\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# If you do not specify an ErrorLog directive within a <VirtualHost>\r"]
