[0.000, "o", "\n\u001b[1;48r\u001b[45;5H#   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
