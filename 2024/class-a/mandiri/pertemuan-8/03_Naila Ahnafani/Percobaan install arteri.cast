[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# access content that does not live under the DocumentRoot.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# Alias: Maps web paths into filesystem paths and is used to\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# Redirect permanent /foo http://www.example.com/bar\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# Example:\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# will make a new request for the document at its new location.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# exist in your server's namespace, but do not anymore. The client\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.001, "o", "# Redirect: Allows you to tell clients about documents that used to\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "<IfModule alias_module>\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H</IfModule>\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#CustomLog \"/var/log/httpd/access_log\" combined\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# (Combined Logfile Format) you can use the following directive.\r"]
[1.178, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# If you prefer a logfile with access, agent, and referer information\r"]
[0.250, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "CustomLog \"/var/log/httpd/access_log\" common\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H#\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# logged therein and *not* in this file.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.001, "o", "# define per-<VirtualHost> access logfiles, transactions will be\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# container, they will be logged here.  Contrariwise, if you *do*\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;5H# If you do not define any access logfiles within a <VirtualHost>\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# The location and format of the access logfile (Common Logfile Format).\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H</IfModule>\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;7HLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\" combinedio\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;7H# You need to enable mod_logio.c to use %I and %O\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H<IfModule logio_module>\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "LogFormat \"%h %l %u %t \\\"%r\\\" %>s %b\" common\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "LogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\" combined\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H#\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# a CustomLog directive (see below).\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "# The following directives define some format nicknames for use with\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "#\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "<IfModule log_config_module>\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "LogLevel warn\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# alert, emerg.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# Possible values include: debug, info, notice, warn, error, crit,\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# LogLevel: Control the number of messages logged to the error_log.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "ErrorLog \"/var/log/httpd/error_log\"\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H# container, that host's errors will be logged there and not here.\r"]
[0.650, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H# logged here.  If you *do* define an error logfile for a <VirtualHost>\r"]
[0.251, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# container, error messages relating to that virtual host will be\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# If you do not specify an ErrorLog directive within a <VirtualHost>\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "# ErrorLog: The location of the error log file.\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "</Files>\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5HRequire all denied\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "<Files \".ht*\">\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# viewed by Web clients.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "# The following lines prevent .htaccess and .htpasswd files from being\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
[1.208, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.253, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "</IfModule>\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;5H"]
[0.000, "o", "DirectoryIndex index.html\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H<IfModule dir_module>\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "#\b"]
