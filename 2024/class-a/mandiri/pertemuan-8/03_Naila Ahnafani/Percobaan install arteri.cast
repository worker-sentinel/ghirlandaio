[0.001, "o", "\r\u001b[2d# included to add extra features or to modify the default configuration of\r\u001b[3d# the server, or you may simply copy their contents here and change as\r\u001b[4d# necessary.\r\u001b[5d\u001b[K\u001b[6d# Server-pool management (MPM specific)\u001b[K\r\u001b[7dInclude conf/extra/httpd-mpm.conf\r\u001b[8d\u001b[K\u001b[9d# Multi-language error messages\r\u001b[10dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[11d\u001b[K\u001b[12d# Fancy directory listings\r\u001b[13dInclude conf/extra/httpd-autoindex.conf\r\u001b[14d\u001b[K\u001b[15d# Language settings\u001b[K\r\u001b[16dInclude conf/extra/httpd-languages.conf\r\u001b[17d"]
[0.000, "o", "\u001b[K\u001b[18d# User home directories\r\u001b[19dInclude conf/extra/httpd-userdir.conf\u001b[21;3HReal-time info on requests and configuration\r\u001b[22d#"]
[0.000, "o", "Include conf/extra/httpd-info.conf\u001b[K\r\u001b[23d\u001b[K\u001b[24d# \u001b[30m\u001b[43mVirtual host\u001b[39;49m\u001b[m\u000fs\u001b[K\r\u001b[25d#Include conf/extra/httpd-vhosts.conf\u001b[K\r\u001b[26d\u001b[K\u001b[27d# Local access to the Apache HTTP Server Manual\r\u001b[28d#Include conf/extra/httpd-manual.conf\u001b[30;3HDistributed authoring and versioning (WebDAV)\r\u001b[31d#Include conf/extra/httpd-dav.conf\u001b[K\r\u001b[32d\u001b[K\u001b[33d# Various default settings\r\u001b[34dInclude conf/extra/httpd-default.conf\r\u001b[35d\u001b[K\u001b[36d# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[37;11Hproxy_html\r\u001b[38dInclude conf/extra/proxy-html.conf\r\u001b[39d</IfModule>\u001b[K\r\u001b[40d\u001b[K\u001b[41d# Secure (SSL/TLS) connections\r\u001b[42d#Include conf/extra/httpd-ssl.conf\u001b[K\r\u001b[43d#\u001b[K\u001b[44d\b# Note: The following must be present to support\r\u001b[45d#       starting without SSL on platforms with no /dev/random equivalent\u001b[24;3H"]
