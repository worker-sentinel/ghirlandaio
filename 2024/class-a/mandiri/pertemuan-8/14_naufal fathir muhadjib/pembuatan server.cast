[0.000, "o", "\u001b[46;77H\u001b[0;10;7m\u000f[ Read 542 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                            /etc/httpd/conf/httpd.conf                                                                      \u001b[1;169H\u001b[m\u000f\r\u001b[47d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[47;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H"]
[0.001, "o", "\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d#\u001b[3d\b"]
[0.000, "o", "# This is the main Apache HTTP server configuration file.  It contains the\r\u001b[4d# configuration directives that give the server its instructions.\r\u001b[5d# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\r\u001b[6d# In particular, see\r\u001b[7d"]
[0.000, "o", "# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\r\u001b[8d# for a discussion of each configuration directive.\r\u001b[9d"]
[0.000, "o", "#\u001b[10d\b# Do NOT simply read the instructions in here without understanding\r\u001b[11d# what they do.  They're here only as hints or reminders.  If you are unsure\r\u001b[12d# consult the online docs. You have been warned.\r\u001b[13d"]
[0.000, "o", "#\u001b[14d\b# Configuration and logfile names: If the filenames you specify for many\r\u001b[15d"]
[0.000, "o", "# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\r\u001b[16d# server will use that explicit path.  If the filenames do *not* begin\r\u001b[17d# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\u001b[18d"]
[0.000, "o", "# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\u001b[19d# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\"\r\u001b[20d# will be interpreted as '/logs/access_log'.\r\u001b[22d#\u001b[23d\b# ServerRoot: The top of the directory tree under which the server's\r\u001b[24d# configuration, error, and log files are kept.\r\u001b[25d#\u001b[26d\b# Do not add a slash at the end of the directory path.  If you point\r\u001b[27d# ServerRoot at a non-local disk, be sure to specify a local disk on the\r\u001b[28d# Mutex directive, if file-based mutexes are used.  If you wish to share the\r\u001b[29d# same ServerRoot for multiple httpd daemons, you will need to change at\r\u001b[30d# least PidFile.\r\u001b[31d"]
[0.000, "o", "#\u001b[32d\bServerRoot \"/etc/httpd\"\r\u001b[34d#\u001b[35d\b# Mutex: Allows you to set the mutex mechanism and mutex file directory\r\u001b[36d# for individual mutexes, or change the global defaults\r\u001b[37d#\u001b[38d\b# Uncomment and change the directory if mutexes are file-based and the default\r\u001b[39d# mutex file directory is not on a local disk or is not appropriate for some\r\u001b[40d# other reason.\r\u001b[41d#\u001b[42d\b# Mutex default:/run/httpd\r\u001b[44d#\u001b[45d\b# Listen: Allows you to bind Apache to specific IP addresses and/or\r\u001b[2d\u001b[?25h\u001b[?0c"]
[6.934, "o", "\u001b[?25l\u001b[?1c\u001b[47;18H\u001b[25X\u001b[47;43H\u001b[0;10;7m\u000f^W\u001b[m\u000f Begin of Paragr.\u001b[69G          \u001b[85G\u001b[0;10;7m\u000f^Y\u001b[m\u000f First Line             \u001b[47;120H       \u001b[0;10;7m\u000f^T\u001b[m\u000f Go To Text\u001b[K\u001b[48;2H\u001b[0;10;7m\u000fC\u001b[m\u000f Cancel\u001b[48;18H\u001b[25X\u001b[48;43H"]
[0.000, "o", "\u001b[0;10;7m\u000f^O\u001b[m\u000f End of Paragraph\u001b[69G          \u001b[85G\u001b[0;10;7m\u000f^V\u001b[m\u000f Last Line\u001b[K\u001b[47;140H"]
[0.000, "o", "\r\u001b[A\u001b[0;10;7m\u000fEnter line number, column number:                                                                                                                                         \u001b[46;35H\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[1.543, "o", "\u001b[?25l\u001b[?1c\u001b[0;10;7m\u000f5\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[0.244, "o", "\u001b[?25l\u001b[?1c\u001b[0;10;7m\u000f1\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[0.188, "o", "\u001b[?25l\u001b[?1c\u001b[0;10;7m\u000f4\u001b[m\u000f\u001b[?25h\u001b[?0c"]
[0.793, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[47;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[85G \u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[47;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H"]
[0.000, "o", "\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste  \u001b[69G\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[85G"]
[0.000, "o", " \u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.001, "o", "\u001b[2;3Hthe server, or you may simply copy their contents here and change as\u001b[3;3Hnecessary.\u001b[K\r\u001b[4d\u001b[K\u001b[5;5Hrver-pool management (MPM specific)\u001b[K\r\u001b[6d"]
[0.000, "o", "Include conf/extra/httpd-mpm.conf\r\u001b[7d\u001b[K\u001b[8d# "]
[0.000, "o", "Multi-language error messages\u001b[K\r\u001b[9dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[10d\u001b[K\u001b[11d# Fancy directory listings\u001b[K\r\u001b[12dInclude conf/extra/httpd-autoindex.conf\u001b[K\r\u001b[13d\u001b[K\u001b[14d# "]
[0.000, "o", "Language settings\u001b[K\r\u001b[15dInclude conf/extra/httpd-languages.conf\u001b[K\r\u001b[16d\u001b[K\u001b[17d# User home directories\u001b[K\r\u001b[18dInclude conf/extra/httpd-userdir.conf\u001b[K\r\u001b[19d\u001b[K\u001b[20d# Real-time info on requests and configuration\r\u001b[21d#Include conf/extra/httpd-info.conf\r\u001b[22d"]
[0.001, "o", "\u001b[K\u001b[23d# Virtual hosts\u001b[K\r\u001b[24dInclude conf/extra/httpd-vhosts.conf\u001b[K\r\u001b[25d\u001b[K\u001b[26d# Local access to the Apache HTTP Server Manual\u001b[K\r\u001b[27d#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[28d\u001b[K\u001b[29d# Distributed authoring and versioning (WebDAV)\u001b[K\r\u001b[30d#"]
[0.000, "o", "Include conf/extra/httpd-dav.conf\r\u001b[31d\u001b[K\u001b[32d# Various default settings\r\u001b[33dInclude conf/extra/httpd-default.conf\r\u001b[34d\u001b[K\u001b[35d# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[K\r\u001b[36d<IfModule proxy_html_module>\u001b[K\r\u001b[37dInclude conf/extra/proxy-html.conf\r\u001b[38d</IfModule>\u001b[K\r\u001b[39d\u001b[K\u001b[40d# Secure (SSL/TLS) connections\r\u001b[41d#Include conf/extra/httpd-ssl.conf\u001b[42;3H\u001b[K\r\u001b[43d# Note: The following must be present to support\u001b[44;9Hstarting without SSL on platforms with no /dev/random equivalent\u001b[45;3H"]
[0.001, "o", "      but a statically compiled-in mod_ssl.\u001b[K\r\u001b[24d\u001b[?25h\u001b[?0c"]
