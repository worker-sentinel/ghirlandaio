[0.000, "o", "\r\u001b[3d#\u001b[K\u001b[4d\b# MaxRanges: Maximum number of Ranges in a request before\u001b[K\r\u001b[5d# returning the entire resource, or one of the special\u001b[K\r\u001b[6d# values 'default', 'none' or 'unlimited'.\r\u001b[7d# Default setting is to accept 200 Ranges.\u001b[K\r\u001b[8d#MaxRanges unlimited\r\u001b[10d#\u001b[K\u001b[11d\b"]
[0.000, "o", "# EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[12d# memory-mapping or the sendfile syscall may be used to deliver\u001b[K\r\u001b[13d# files.  This usually improves server performance, but must\u001b[K\r\u001b[14d"]
[0.001, "o", "# be turned off when serving from networked-mounted\u001b[K\r\u001b[15d# filesystems or if support for these functions is otherwise\r\u001b[16d# broken on your system.\u001b[K\r\u001b[17d# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[18d#\u001b[K\u001b[19d\b#EnableMMAP off\u001b[K\r\u001b[20d#EnableSendfile on\u001b[K\r\u001b[21d\u001b[K\u001b[22d# Supplemental configuration\u001b[K\r\u001b[23d#\u001b[K\u001b[24d\b# The configuration files in the \u001b[30m\u001b[43mconf/extra\u001b[39;49m\u001b[m\u000f/ directory can be\u001b[K\r\u001b[25d# included to add extra features or to modify the default configuration of\r\u001b[26d# the server, or you may simply copy their contents here and change as\r\u001b[27d# necessary.\u001b[K\r\u001b[29d# Server-pool management (MPM specific)\r\u001b[30d"]
[0.000, "o", "Include conf/extra/httpd-mpm.conf\u001b[K\r\u001b[31d\u001b[K\u001b[32d# Multi-language error messages\u001b[K\r\u001b[33dInclude conf/extra/httpd-multilang-errordoc.conf\u001b[K\r\u001b[34d\u001b[K\u001b[35d# Fancy directory listings\u001b[K\r\u001b[36dInclude conf/extra/httpd-autoindex.conf\r\u001b[37d\u001b[K\u001b[38d# Language settings\r\u001b[39dInclude conf/extra/httpd-languages.conf\r\u001b[41d# User home directories\r\u001b[42dInclude conf/extra/httpd-userdir.conf\r\u001b[43d\u001b[K\u001b[44d# Real-time info on requests and configuration\u001b[K\r\u001b[45d#Include conf/extra/httpd-info.conf\u001b[24;34H"]
