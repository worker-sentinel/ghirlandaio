[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;   ascii (all printable ASCII characters and NL)\u001b[45;33H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
