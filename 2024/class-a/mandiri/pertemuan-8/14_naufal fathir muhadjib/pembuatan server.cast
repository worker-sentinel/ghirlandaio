[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; overridden by the max_depth option on individual unserialize() calls.\u001b[45;33H"]
