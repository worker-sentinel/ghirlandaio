[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; of zero causes PHP to behave as before.  Default is 1.  You should fix your scripts\u001b[45;33H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; to use SCRIPT_FILENAME rather than PATH_TRANSLATED.\u001b[45;33H"]
