[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;25H'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\b"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_key'    - Path to the private key file\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_cert'   - Path to the public key certificate file\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_ca'     - Path to the certificate authority file\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H|\b"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[9G['compress'] Whether or not to use client compression (MySQL only)\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[9G['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\r"]
[0.734, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c|"]
[0.259, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b[9G"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c["]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c'"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0cs"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0ct"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0cr"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0ci"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0cc"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0ct"]
[0.100, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;57H- good for ensuring strict SQL while developing\u001b[45;17H"]
[0.259, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[9G['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\u001b[45;17H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[9G['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[45;17H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H|\u001b[9G['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[45;17H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
