[0.000, "o", "    # (Combined Logfile Format) you can use the following directive.\r\u001b[6d    #\u001b[K\r\u001b[7d    #CustomLog \"/var/log/httpd/access_log\" combined\u001b[K\r\u001b[8d</IfModule>\u001b[K\r\u001b[9d\u001b[K\u001b[10d<IfModule alias_module>\u001b[11;5H#\r\u001b[12d"]
[0.000, "o", "    # Redirect: Allows you to tell clients about documents that used to\u001b[13;7Hexist in your server's namespace, but do not anymore. The client\u001b[14;7Hwill make a new request for the document at its new location.\u001b[K\u001b[15;7HExample:\u001b[K\u001b[16;7HRedirect permanent /foo http://www.example.com/bar\r\u001b[17d\u001b[K\u001b[18;5H#\u001b[K\u001b[19d\b# Alias: Maps web paths into filesystem paths and is used to\u001b[20;5H# access content that does not live under the DocumentRoot.\u001b[21;5H# Example:\u001b[K\u001b[22;5H"]
[0.001, "o", "# Alias /webpath /full/filesystem/path\u001b[K\u001b[23;5H#\u001b[K\u001b[24d\b# If you \u001b[30m\u001b[43minclude \u001b[39;49m\u001b[m\u000fa trailing / on /webpath then the server will\u001b[25;7Hrequire it to be present in the URL.  You will also likely\u001b[26;7Hneed to provide a <Directory> section to allow access to\u001b[K\u001b[27;7Hthe filesystem path.\u001b[K\r\u001b[28d\u001b[K\u001b[29;7H\u001b[K\u001b[30dScriptAlias: This controls which directories contain server scripts.\u001b[31;7HScriptAliases are essentially the same as Aliases, except that\u001b[32;5H# documents in the target directory are treated as applications and\u001b[33;5H"]
[0.000, "o", "# run by the server when requested rather than as documents sent to the\u001b[34;7Hclient.  The same rules about trailing \"/\" apply to ScriptAlias\u001b[35;7Hdirectives as to Alias.\u001b[K\u001b[36;7H\u001b[K\u001b[37d\b\bScriptAlias /cgi-bin/ \"/srv/http/cgi-bin/\"\r\u001b[38d\u001b[K\u001b[41;11Hcgid\u001b[1P\u001b[43;7HScriptSock: On threaded servers, designate the path to the UNIX\u001b[K\u001b[44;7Hsocket used to communicate with the CGI daemon of mod_cgid.\u001b[K\u001b[45;7H\u001b[K\u001b[24;14H"]
