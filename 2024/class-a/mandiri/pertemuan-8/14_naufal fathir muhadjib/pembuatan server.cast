[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; The syslog ident is a string which is prepended to every message logged\u001b[45;33H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; to syslog. Only used when error_log is set to syslog.\u001b[45;33H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H;syslog.ident = php"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; The syslog facility is used to specify what type of program is logging\u001b[45;33H"]
[0.594, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; the message. Only used when error_log is set to syslog.\u001b[45;33H"]
[0.259, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
