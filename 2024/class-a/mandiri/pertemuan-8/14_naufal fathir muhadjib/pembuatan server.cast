[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; and $_FILES to always be empty; the only way you will be able to read the\u001b[45;33H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; POST data will be through the php://input stream wrapper. This can be useful\u001b[45;33H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; to proxy requests or to process the POST data in a memory efficient fashion.\u001b[45;33H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d\n\u001b[1;48r\u001b[45;1H; https://php.net/enable-post-data-reading\u001b[45;33H"]
