[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\r\u001b[48d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H"]
[0.000, "o", "\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.000, "o", "\r\u001b[2d#\u001b[3d\b# This is the main Apache HTTP server configuration file.  It contains the\r\u001b[4d# configuration directives that give the server its instructions.\r\u001b[5d# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\r\u001b[6d# In particular, see\r\u001b[7d"]
[0.001, "o", "# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\r\u001b[8d# for a discussion of each configuration directive.\r\u001b[9d#\u001b[10d\b# Do NOT simply read the instructions in here without understanding\r\u001b[11d"]
[0.000, "o", "# what they do.  They're here only as hints or reminders.  If you are unsure\r\u001b[12d# consult the online docs. You have been warned.\r\u001b[13d"]
[0.000, "o", "#\u001b[14d\b# Configuration and logfile names: If the filenames you specify for many\r\u001b[15d"]
[0.000, "o", "# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\r\u001b[16d# server will use that explicit path.  If the filenames do *not* begin\r\u001b[17d"]
[0.000, "o", "# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\u001b[18d# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\u001b[19d"]
[0.000, "o", "# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\"\r\u001b[20d# will be interpreted as '/logs/access_log'.\r\u001b[22d"]
[0.000, "o", "#\u001b[23d\b# ServerRoot: The top of the directory tree under which the server's\r\u001b[24d# configuration, error, and log files are kept.\r\u001b[25d#\u001b[26d\b"]
[0.000, "o", "# Do not add a slash at the end of the directory path.  If you point\r\u001b[27d# ServerRoot at a non-local disk, be sure to specify a local disk on the\r\u001b[28d"]
[0.000, "o", "# Mutex directive, if file-based mutexes are used.  If you wish to share the\r\u001b[29d# same ServerRoot for multiple httpd daemons, you will need to change at\r\u001b[30d# least PidFile.\r\u001b[31d"]
[0.000, "o", "#\u001b[32d\bServerRoot \"/etc/httpd\"\r\u001b[34d#\u001b[35d\b"]
[0.000, "o", "# Mutex: Allows you to set the mutex mechanism and mutex file directory\r\u001b[36d# for individual mutexes, or change the global defaults\r\u001b[37d#\u001b[38d\b"]
[0.000, "o", "# Uncomment and change the directory if mutexes are file-based and the default\r\u001b[39d# mutex file directory is not on a local disk or is not appropriate for some\r\u001b[40d# other reason.\r\u001b[41d#\u001b[42d\b"]
[0.000, "o", "# Mutex default:/run/httpd\r\u001b[44d#\u001b[45d\b# Listen: Allows you to bind Apache to specific IP addresses and/or\r\u001b[2d\u001b[?25h\u001b[?0c"]
[2.604, "o", "\u001b[?25l\u001b[?1c\u001b[47;18H\u001b[25X\u001b[47;43H\u001b[0;10;7m\u000f^W\u001b[m\u000f Begin of Paragr.\u001b[69G          \u001b[85G\u001b[0;10;7m\u000f^Y\u001b[m\u000f First Line             \u001b[47;120H       \u001b[0;10;7m\u000f^T\u001b[m\u000f Go To Text\u001b[K\u001b[48;2H"]
