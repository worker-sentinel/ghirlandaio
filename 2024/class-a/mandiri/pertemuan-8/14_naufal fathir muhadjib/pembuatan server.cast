[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;   raw (like \"all\", but messages are not split at newlines)\u001b[45;33H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
