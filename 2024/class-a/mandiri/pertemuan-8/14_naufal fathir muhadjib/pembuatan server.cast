[0.503, "o", "\r\n\u001b[?2004l\r"]
[0.187, "o", "\u001b[1;34musage: \u001b[0m\u001b[35m'firewall-cmd --help' for usage information or see firewall-cmd(1) man page\u001b[0m\r\nfirewall-cmd: error: unrecognized arguments: -zone=public --remove-services=ssh\r\n"]
