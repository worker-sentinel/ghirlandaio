[0.014, "o", "\u001b[2;3H      The location to save sessions to, driver dependent.\u001b[16X\u001b[3;2H\u001b[45X\n       For the 'files' driver, it's a path to a writable directory.\u001b[5;3H      WARNING: Only absolute paths are supported!\u001b[20X\r\n\n|       For the 'database' driver, it's a table name.\r\n|       Please read up the manual for the format with other session drivers.\r\n|\r\n|       IMPORTANT: You are REQUIRED to set a valid save path!\u001b[11;2H\u001b[74X\u001b[12;3H'sess_match_ip'\u001b[12X\u001b[13;2H\u001b[74X\n       Whether to match the user's IP address when reading the session data.\u001b[15;2H\u001b[67X\u001b[16;3H      WARNING: If you're using the database driver, don't forget to update\u001b[17;2H                your session table's PRIMARY KEY when changing this setting.\r\n| \r\n| 'sess_time_to_update'\u001b[9X\r\n|\r\n|       How many seconds between CI regenerating the session ID.\u001b[22;2H\u001b[74X\u001b[23;3H'sess_regenerate_destroy'\u001b[24;2H\u001b[74X\n       Whether to destroy session data associated with the old session ID\u001b[26;3H      when auto-regenerating the session ID. When set to FALSE, the data\u001b[27;3H      will be later deleted by the garbage collector.\u001b[13X\u001b[29;3HOther session cookie settings are shared with the rest of the application,\u001b[30;3Hexcept for 'cookie_prefix' and 'cookie_httponly', which are ignored here.\u001b[33;11H\u001b[30m\u001b[103me\u001b[m\u000f\u001b[92mss_driver'\u001b[m\u000f] = \u001b[92m'files'\u001b[m\u000f;  \r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_cookie_name'\u001b[m\u000f] = \u001b[92m'arteri'\u001b[m\u000f;\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_expiration'\u001b[m\u000f] = 7200;\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_save_path'\u001b[m\u000f] = NULL;\u001b[42X\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_match_ip'\u001b[m\u000f] = FALSE;\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_time_to_update'\u001b[m\u000f] = 300;\u001b[38X\r\n\u001b[30m\u001b[103m$config['se\u001b[m\u000f\u001b[92mss_regenerate_destroy'\u001b[m\u000f] = FALSE;\r\n\u001b[68X\n/*\u001b[62X\u001b[42;2H--------------------------------------------------------------------------\u001b[43;3HCookie Related Variables\u001b[18X\u001b[44;2H--------------------------------------------------------------------------\u001b[45;2H\u001b[66X\u001b[46;3H'cookie_prefix'   = Set a cookie name prefix if you need to avoid collisions\u001b[47;2H 'cookie_domain'   = Set to .your-domain.com for site-wide cookies\u001b[48;3H'cookie_path'     = Typically will be a forward slash\u001b[15X\u001b[49;2H 'cookie_secure'   = Cookie will only be set if a secure HTTPS connection exists.\u001b[50;3H'cookie_httponly' = Cookie will only be accessible via HTTP(S) (no javascript)\u001b[52;11Hese settings (with the exception of 'cookie_prefix' and \u001b[53;9H'cookie_httponly') will also affect sessions.\r\n| \r\n*/\u001b[35X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_prefix'\u001b[m\u000f]        = \u001b[92m''\u001b[m\u000f;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_domain'\u001b[m\u000f]        = \u001b[92m''\u001b[m\u000f;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_path'\u001b[m\u000f]          = \u001b[92m'/'\u001b[m\u000f;\u001b[37X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_secure'\u001b[m\u000f]        = FALSE;\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'cookie_httponly'\u001b[m\u000f]      = FALSE;\u001b[35X\r\n \r\n/*\u001b[70X\u001b[63;2H--------------------------------------------------------------------------\u001b[64;3HStandardize newlines  \u001b[65;2H--------------------------------------------------------------------------\u001b[66;223H\u001b[0;10;7m\u000f380,1          75\u001b[67;13H\u001b[?25h"]
