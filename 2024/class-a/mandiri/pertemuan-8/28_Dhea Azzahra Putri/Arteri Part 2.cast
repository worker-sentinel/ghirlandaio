[0.008, "o", "\u001b[H|    \r\n| This determines which character set is used by default in various methods\r\n| that require a character set to be provided.\r\n| \u001b[5;2H See http://php.net/htmlspecialchars for a list of supported charsets.    \u001b[6;2H\u001b[14X\r\n*/\u001b[73X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'charset'\u001b[m\u000f] = \u001b[92m'UTF-8'\u001b[m\u000f;\r\n\u001b[69X\n/*\u001b[22X\u001b[11;2H--------------------------------------------------------------------------\u001b[12;3HEnable/Disable System Hooks\u001b[13;2H--------------------------------------------------------------------------\u001b[14;2H\u001b[34X\n If you would like to use the 'hooks' feature you must enable it by\u001b[16;3Hsetting this variable to TRUE (boolean).  See the user guide for details.\u001b[17;2H\u001b[73X\r\n*/\u001b[64X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'enable_hooks'\u001b[m\u000f] = FALSE;\u001b[33X\r\n\u001b[49X\n/*\u001b[22;2H--------------------------------------------------------------------------\u001b[23;3HClass Extension Prefix\u001b[30X\u001b[24;2H--------------------------------------------------------------------------\r\n| \r\n| This item allows you to set the filename/classname prefix when extending\u001b[31X\r\n| native libraries.  For more information please see the user guide:\r\n| \u001b[29;2H https://codeigniter.com/user_guide/general/core_classes.html\u001b[13X\u001b[30;3Hhttps://codeigniter.com/user_guide/general/creating_libraries.html\u001b[31;2H\u001b[74X\r\n*/\r\n\u001b[30m\u001b[103m$config['s\u001b[m\u000f\u001b[92mubclass_prefix'\u001b[m\u000f] = \u001b[92m'MY_'\u001b[m\u000f;\u001b[38X\r\n\u001b[74X\n/*\u001b[29X\u001b[36;2H--------------------------------------------------------------------------\r\n| Composer auto-loading\r\n|--------------------------------------------------------------------------\r\n|\r\n| Enabling this setting will tell CodeIgniter to look for a Composer\u001b[41;2H package auto-loader script in application/vendor/autoload.php.\u001b[11X\u001b[42;2H\u001b[13X\n       $config['composer_autoload'] = TRUE;\u001b[31X\u001b[45;3HOr if you have your vendor/ directory located somewhere else, you\u001b[6X\u001b[46;3Hcan opt to set a specific path as well:\u001b[34X\u001b[47;2H\u001b[75X\n       $config['composer_autoload'] = '/path/to/vendor/autoload.php';\u001b[49;2H\u001b[46X\u001b[50;3HFor more information about Composer, please visit http://getcomposer.org/\u001b[51;2H\u001b[44X\n Note: This will NOT disable or override the CodeIgniter-specific\u001b[53;3H      autoloading (application/config/autoload.php)\u001b[22X\r\n\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'composer_autoload'\u001b[m\u000f] = FALSE;   \u001b[59;3HAllowed URL Characters\u001b[62;8Hlets you specify which characters are permitted within your URLs.\u001b[6X\u001b[63;3HWhen someone tries to submit a URL with disallowed characters they will\u001b[64;2H get a warning message.\u001b[65;2H\u001b[53X\u001b[66;223H\u001b[0;10;7m\u000f117,1          18%\u001b[67;12H\u001b[?25h"]
