[0.001, "o", "\r\u001b[2d# Defaults: EnableMMAP On, EnableSendfile Off\u001b[K\r\u001b[3d#\u001b[K\u001b[4dEnableMMAP off\u001b[K\r\u001b[5d#EnableSendfile on\u001b[K\r\u001b[6d\u001b[K\u001b[7d#"]
[0.000, "o", " Supplemental configuration\u001b[K\r\u001b[8d#\u001b[K\u001b[9d"]
[0.000, "o", " The configuration files in the conf/extra/ directory can be\r\u001b[10d#"]
[0.000, "o", " included to add extra features or to modify the default configuration of\r\u001b[11d# the server, or you may simply copy their contents here and change as\r\u001b[12d# necessary.\u001b[K\r\u001b[13d"]
[0.000, "o", "\u001b[K\u001b[14d#"]
[0.000, "o", " Server-pool management (MPM specific)\u001b[K\r\u001b[15d"]
[0.001, "o", "Include conf/extra/httpd-mpm.conf\u001b[K\r\u001b[16d\u001b[K\u001b[17d"]
[0.000, "o", "# Multi-language error messages\r\u001b[18d"]
[0.000, "o", "Include conf/extra/httpd-multilang-errordoc.conf\u001b[K\r\u001b[19d\u001b[K\u001b[20d"]
[0.000, "o", "# Fancy directory listings\u001b[K\r\u001b[21dInclude conf/extra/httpd-autoindex.conf\u001b[K\r\u001b[22d"]
[0.000, "o", "\u001b[K\u001b[23d#"]
[0.000, "o", " Language settings\u001b[K\r\u001b[24d"]
[0.000, "o", "Include conf/extra/httpd-languages.conf\u001b[K\r\u001b[25d\u001b[K\u001b[26d# User home directories\u001b[K\r\u001b[27d"]
[0.000, "o", "Include conf/extra/httpd-userdir.conf\u001b[K\r\u001b[28d\u001b[K\u001b[29d#"]
[0.000, "o", " Real-time info on requests and configuration\u001b[K\r\u001b[30d#"]
[0.000, "o", "Include conf/extra/httpd-info.conf\u001b[K\r\u001b[31d\u001b[K\u001b[32d"]
[0.000, "o", "# Virtual hosts\u001b[K\r\u001b[33d#\u001b[30m\u001b[43mInclude conf/extra/httpd-vhosts.conf\u001b[39;49m\u001b[m\u000f\u001b[K\r\u001b[35d# Local access to the Apache HTTP Server Manual\r\u001b[36d#"]
[0.000, "o", "Include conf/extra/httpd-manual.conf\r\u001b[37d"]
[0.000, "o", "\u001b[K\u001b[38d# "]
[0.000, "o", "Distributed authoring and versioning (WebDAV)\r\u001b[39d#"]
[0.001, "o", "Include conf/extra/httpd-dav.conf\r\u001b[40d\u001b[K\u001b[41d# Various default settings\u001b[K\r\u001b[42dInclude conf/extra/httpd-default.conf\u001b[K\r\u001b[43d\u001b[K\u001b[44d# Configure mod_proxy_html to understand HTML4/XHTML1\r\u001b[45d"]
[0.000, "o", "<IfModule proxy_html_module>\r\u001b[46d"]
