[0.000, "o", "\r\u001b[2d#\u001b[3d\b# This is the main Apache HTTP server configuration file.  It contains the\r\u001b[4d# configuration directives that give the server its instructions.\r\u001b[5d# See <URL:http://httpd.apache.org/docs/2.4/> for detailed information.\r\u001b[6d# In particular, see\r\u001b[7d# <URL:http://httpd.apache.org/docs/2.4/mod/directives.html>\r\u001b[8d# for a discussion of each configuration directive.\r\u001b[9d#\u001b[10d\b# Do NOT simply read the instructions in here without understanding\r\u001b[11d# what they do.  They're here only as hints or reminders.  If you are unsure\r\u001b[12d# consult the online docs. You have been warned.\r\u001b[13d#\u001b[14d\b# Configuration and logfile names: If the filenames you specify for many\r\u001b[15d# of the server's control files begin with \"/\" (or \"drive:/\" for Win32), the\r\u001b[16d# server will use that explicit path.  If the filenames do *not* begin\r\u001b[17d"]
[0.000, "o", "# with \"/\", the value of ServerRoot is prepended -- so \"logs/access_log\"\r\u001b[18d# with ServerRoot set to \"/usr/local/apache2\" will be interpreted by the\r\u001b[19d"]
[0.000, "o", "# server as \"/usr/local/apache2/logs/access_log\", whereas \"/logs/access_log\"\r\u001b[20d"]
[0.000, "o", "# will be interpreted as '/logs/access_log'.\r\u001b[22d#\u001b[23d\b# ServerRoot: The top of the directory tree under which the server's\r\u001b[24d"]
[0.000, "o", "# configuration, error, and log files are kept.\r\u001b[25d"]
[0.000, "o", "#\u001b[26d\b"]
[0.000, "o", "# Do not add a slash at the end of the directory path.  If you point\r\u001b[27d"]
[0.000, "o", "# ServerRoot at a non-local disk, be sure to specify a local disk on the\r\u001b[28d"]
[0.000, "o", "# Mutex directive, if file-based mutexes are used.  If you wish to share the\r\u001b[29d"]
[0.001, "o", "# same ServerRoot for multiple httpd daemons, you will need to change at\r\u001b[30d"]
[0.000, "o", "# least PidFile.\r\u001b[31d#\u001b[32d\bServerRoot \"/etc/httpd\"\r\u001b[34d"]
[0.000, "o", "#\u001b[35d\b"]
[0.000, "o", "# Mutex: Allows you to set the mutex mechanism and mutex file directory\r\u001b[36d"]
[0.000, "o", "# for individual mutexes, or change the global defaults\r\u001b[37d#\u001b[38d\b"]
[0.000, "o", "# Uncomment and change the directory if mutexes are file-based and the default\r\u001b[39d# mutex file directory is not on a local disk or is not appropriate for some\r\u001b[40d# other reason.\r\u001b[41d"]
[0.000, "o", "#\u001b[42d\b"]
[0.000, "o", "# Mutex default:/run/httpd\r\u001b[44d#\u001b[45d\b"]
[0.000, "o", "# Listen: Allows you to bind Apache to specific IP addresses and/or\r\u001b[46d"]
[0.000, "o", "# ports, instead of the default. See also the <VirtualHost>\r\u001b[47d"]
[0.000, "o", "# directive.\r\u001b[48d"]
[0.000, "o", "#\u001b[49d\b"]
[0.000, "o", "# Change this to Listen on specific IP addresses as shown below to\r\u001b[50d"]
[0.000, "o", "# prevent Apache from glomming onto all bound IP addresses.\r\u001b[51d#\u001b[52d\b"]
[0.000, "o", "#Listen 12.34.56.78:80\r\u001b[53d"]
[0.000, "o", "Listen 80\r\u001b[55d"]
[0.000, "o", "#\u001b[56d\b"]
[0.000, "o", "# Dynamic Shared Object (DSO) Support\r\u001b[57d"]
[0.000, "o", "#\u001b[58d\b"]
[0.000, "o", "# To be able to use the functionality of a module which was built as a DSO you\r\u001b[59d"]
[0.000, "o", "# have to place corresponding `LoadModule' lines at this location so the\r\u001b[60d"]
[0.000, "o", "# directives contained in it are actually available _before_ they are used.\r\u001b[61d"]
[0.000, "o", "# Statically compiled modules (those listed by `httpd -l') do not need\r\u001b[62d"]
[0.000, "o", "# to be loaded here.\r\u001b[63d"]
[0.000, "o", "#\u001b[64d\b# Example:\r\u001b[2d"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[87.516, "o", "\u001b[?25l\u001b[?1c\u001b[66;18H\u001b[31X\u001b[66;49H\u001b[0;10;7m\u000fM-C\u001b[m\u000f Case Sens\u001b[69G          \u001b[86G"]
[0.000, "o", "           \u001b[0;10;7m\u000fM-B\u001b[m\u000f Backwards \u001b[66;120H\u001b[25X\u001b[66;145H\u001b[0;10;7m\u000f^P\u001b[m\u000f Older\u001b[24X\u001b[66;188H"]
