[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H"]
[0.000, "o", "\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H"]
[0.000, "o", "\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.002, "o", "\r\u001b[2d|    \u001b[2;33H'ssl_key'    - Path to the private key file\r\u001b[3d|\u001b[31X\u001b[3;33H'ssl_cert'   - Path to the public key certificate file\r\u001b[4d|\u001b[4;33H'ssl_ca'     - Path to the certificate authority file\r\u001b[5d| \u001b[5;33H'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\u001b[6;3H\u001b[30X\u001b[6;33H'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\u001b[7;3H\u001b[30X\u001b[7;33H'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\u001b[8;3H"]
[0.000, "o", "\u001b[K\u001b[9d      ['compress'] Whether or not to use client compression (MySQL only)\u001b[10;9H"]
[0.000, "o", "['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\u001b[11;3H\u001b[54X\u001b[11;57H"]
[0.000, "o", "- good for ensuring strict SQL while developing\u001b[12;3H      ['ssl_options'] "]
[0.001, "o", "Used to set various SSL options that can be used when making SSL connections.\u001b[13;9H"]
[0.000, "o", "['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[14;3H      ['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[15;3H\u001b[24X\u001b[15;33H"]
[0.000, "o", "NOTE: Disabling this will also effectively disable both\u001b[16;3H\u001b[30X\u001b[16;33H$this->db->last_query() and profiling of DB queries.\u001b[17;33H"]
[0.000, "o", "When you run a query, with this setting set to TRUE (default),\u001b[18;9H       \u001b[22G"]
[0.000, "o", "           CodeIgniter will store the SQL statement for debugging purposes.\u001b[19;9H"]
[0.000, "o", "\u001b[24X\u001b[19;33H"]
[0.000, "o", "However, this may cause high memory usage, especially if you run\u001b[20;9H\u001b[24X\u001b[20;33H"]
[0.000, "o", "a lot of SQL queries ... disable this to avoid that problem.\u001b[21;9H"]
[0.000, "o", "\u001b[K\u001b[22;3H"]
[0.000, "o", "The $active_group variable lets you choose which connection gro"]
[0.000, "o", "up to\u001b[23;3Hmake active.  By default there is only one group (th"]
[0.000, "o", "e 'default' group).\u001b[24;25H\u001b[K\u001b[25;3H"]
[0.000, "o", "The $query_builder variables lets you determine whether or not to load\u001b[K\u001b[26;3Hthe query builder class.\u001b[K\r\u001b[27d"]
[0.000, "o", "*/\u001b[K\r\u001b[28d"]
[0.000, "o", "$active_group = 'default';\u001b[K\r\u001b[29d"]
[0.000, "o", "$query_builder = TRUE;\u001b[K\r\u001b[30d"]
[0.000, "o", "\u001b[K\u001b[31d"]
[0.001, "o", "$db['default'] = array(\u001b[K\u001b[32;8H\u001b[1K "]
[0.000, "o", "'dsn'   => '',\u001b[K\u001b[33;8H\u001b[1K \u001b[30m\u001b[43m'hostname' => 'localhost'\u001b[39;49m\u001b[m\u000f,\u001b[K\u001b[34;8H\u001b[1K 'username' => 'root',\u001b[K\u001b[35;8H\u001b[1K "]
[0.000, "o", "'password' => '',\u001b[K\u001b[36;8H"]
[0.000, "o", "\u001b[1K "]
[0.000, "o", "'database' => 'arteri',\u001b[K\u001b[37;8H\u001b[1K "]
[0.000, "o", "'dbdriver' => 'mysqli',\u001b[K\u001b[38;8H\u001b[1K "]
[0.000, "o", "'dbprefix' => '',\u001b[K\u001b[39;8H\u001b[1K "]
[0.000, "o", "'pconnect' => FALSE,\u001b[K\u001b[40;8H\u001b[1K "]
[0.000, "o", "'db_debug' => (ENVIRONMENT !== 'production'),\u001b[K\u001b[41;8H\u001b[1K "]
[0.000, "o", "'cache_on' => FALSE,\u001b[K\u001b[42;8H\u001b[1K "]
[0.000, "o", "'cachedir' => '',\u001b[K\u001b[43;8H"]
[0.000, "o", "\u001b[1K "]
[0.000, "o", "'char_set' => 'utf8',\u001b[K\u001b[44;8H"]
[0.000, "o", "\u001b[1K "]
[0.000, "o", "'dbcollat' => 'utf8_unicode_ci',\u001b[45;8H\u001b[1K "]
[0.001, "o", "'swap_pre' => '',\u001b[K\u001b[46;8H\u001b[1K 'encrypt' => FALSE,\u001b[K\u001b[47;8H"]
[0.000, "o", "\u001b[1K "]
[0.000, "o", "'compress' => FALSE,\u001b[48;8H\u001b[1K "]
[0.000, "o", "'stricton' => FALSE,\u001b[K\u001b[49;8H\u001b[1K "]
[0.000, "o", "'failover' => array(),\u001b[K\u001b[50;8H"]
[0.000, "o", "\u001b[1K "]
[0.000, "o", "'save_queries' => TRUE\u001b[K\r\u001b[51d);\u001b[K\r\u001b[52d\u001b[K\u001b[53d\u001b[K\u001b[54d"]
