[0.000, "o", "Secure (SSL/TLS) connections\r\u001b[50d#Include conf/extra/httpd-ssl.conf\u001b[51;3H\u001b[K\u001b[52d"]
[0.000, "o", "Note: The following must be present to support\u001b[K\u001b[53;3H      starting without SSL on platforms with no /dev/random equivalent\u001b[54;3H      but a statically compiled-in mod_ssl"]
[0.000, "o", ".\u001b[K\r\u001b[56d"]
[0.000, "o", "<IfModule ssl_module>\u001b[K\r\u001b[57d"]
