[0.001, "o", "\u001b[2;5Hr this is empty.\u001b[K\u001b[3;3Hhttps://php.net/from\u001b[K\r\u001b[4d;from=\"john@doe.com\"\u001b[K\r\u001b[5d\u001b[K\u001b[6d; Define the User-Agent string. PHP's default setting for this is empty.\u001b[7;19Huser-agent\u001b[K\r\u001b[8d;user_agent=\"PHP\"\r\u001b[9d\u001b[K\u001b[10d; Default timeout for socket based streams (seconds)\u001b[11;3Hhttps://php.net/default-socket-timeout\u001b[K\r\u001b[12d"]
[0.000, "o", "default_socket_timeout = 60\u001b[K\r\u001b[13d\u001b[K\u001b[14d; "]
[0.000, "o", "If your scripts have to deal with files from Macintosh systems,\u001b[K\r\u001b[15d"]
[0.001, "o", "; or you are running on a Mac and need to deal with files from\u001b[16;3Hunix or win32 systems, setting this flag will cause PHP to\u001b[K\u001b[17;3Hautomatically detect the EOL character in those files so that\u001b[K\u001b[18;3H"]
[0.000, "o", "fgets() and file() will work regardless of the source of the file.\u001b[K\u001b[19;3Hhttps://php.net/auto-detect-line-endings\u001b[K\r\u001b[20d"]
[0.000, "o", ";auto_detect_line_endings = Off\r\u001b[21d\u001b[K\u001b[22d;"]
