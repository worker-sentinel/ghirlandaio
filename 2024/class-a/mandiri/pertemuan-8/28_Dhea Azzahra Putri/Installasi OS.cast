[0.005, "o", "\u001b]11;?\u0007\u001b[5n\u001b[?25l\u001b[>4;2m\u001b[m\u000f\u001b[H                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n              "]
[0.002, "o", "                                                                                                                                                  \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \r\n                                                                                                                                                                \u001b[1 q\u001b[?1002h\u001b[?1006h\u001b[H\u001b[?25h"]
[0.013, "o", "\u001b[c"]
[0.000, "o", "\u001b[?25l\u001b[m\u000f# vim:set ft=sh:\u001b[K\r\n# MODULES\u001b[K\r\n# The following modules are loaded before any boot hooks are\u001b[K\r\n# run.  Advanced users may wish to specify all system modules\u001b[K\r\n# in this array.  For instance:\u001b[K\r\n#     MODULES=(usbhid xhci_hcd)\u001b[K\r\nMODULES=()\u001b[K\r\n\u001b[K\n# BINARIES\u001b[K\r\n# This setting includes any additional binaries a given user may\u001b[K\r\n# wish into the CPIO image.  This is run last, so it may be used to\u001b[K\r\n# override the actual binaries included by a given hook\u001b[K\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\r\nBINARIES=()\u001b[K\r\n\u001b[K\n# FILES\u001b[K\r\n# This setting is similar to BINARIES above, however, files are added\u001b[K\r\n# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\r\nFILES=()\u001b[K\r\n\u001b[K\n# HOOKS\u001b[K\r\n# This is the most important setting in this file.  The HOOKS control the\u001b[K\r\n# modules and scripts added to the image, and what happens at boot time.\u001b[K\r\n# Order is important, and it is recommended that you do not change the\u001b[K\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\r\n# help on a given hook.\u001b[K\r\n# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\r\n# 'udev' is _required_ in order to automatically load modules\u001b[K\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\r\n# Examples:\u001b[K\r\n##   This setup specifies all modules in the MODULES setting above.\u001b[K\r\n##   No RAID, lvm2, or encrypted root is needed.\u001b[K\r\n#    HOOKS=(base)\u001b[K\r\n#\u001b[K\r\n##   This setup will autodetect all modules for your system and should\u001b[K\r\n##   work as a sane default\u001b[K\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup will generate a 'full' image which supports most systems.\u001b[K\r\n##   No autodetection is done.\u001b[K\r\n#    HOOKS=(base udev microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup assembles a mdadm array with an encrypted root file system.\u001b[K\r\n\u001b[0;10;7m\u000fetc/mkinitcpio.d/default.conf                                                                                                                 1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[2 q\u001b[2 q\u001b[H# vim:set ft=sh:\u001b[K\r\n# MODULES\u001b[K\r\n# The following modules are loaded before any boot hooks are\u001b[K\r\n# run.  Advanced users may wish to specify all system modules\u001b[K\r\n# in this array.  For instance:\u001b[K\r\n#     MODULES=(usbhid xhci_hcd)\u001b[K\r\nMODULES=()\u001b[K\r\n\u001b[K\n# BINARIES\u001b[K\r\n# This setting includes any additional binaries a given user may\u001b[K\r\n# wish into the CPIO image.  This is run last, so it may be used to\u001b[K\r\n# override the actual binaries included by a given hook\u001b[K\r\n# BINARIES are dependency parsed, so you may safely ignore libraries\u001b[K\r\nBINARIES=()\u001b[K\r\n\u001b[K\n# FILES\u001b[K\r\n# This setting is similar to BINARIES above, however, files are added\u001b[K\r\n# as-is and are not parsed in any way.  This is useful for config files.\u001b[K\r\nFILES=()\u001b[K\r\n\u001b[K\n# HOOKS\u001b[K\r\n# This is the most important setting in this file.  The HOOKS control the\u001b[K\r\n# modules and scripts added to the image, and what happens at boot time.\u001b[K\r\n# Order is important, and it is recommended that you do not change the\u001b[K\r\n# order in which HOOKS are added.  Run 'mkinitcpio -H <hook name>' for\u001b[K\r\n# help on a given hook.\u001b[K\r\n# 'base' is _required_ unless you know precisely what you are doing.\u001b[K\r\n# 'udev' is _required_ in order to automatically load modules\u001b[K\r\n# 'filesystems' is _required_ unless you specify your fs modules in MODULES\u001b[K\r\n# Examples:\u001b[K\r\n##   This setup specifies all modules in the MODULES setting above.\u001b[K\r\n##   No RAID, lvm2, or encrypted root is needed.\u001b[K\r\n#    HOOKS=(base)\u001b[K\r\n#\u001b[K\r\n##   This setup will autodetect all modules for your system and should\u001b[K\r\n##   work as a sane default\u001b[K\r\n#    HOOKS=(base udev autodetect microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup will generate a 'full' image which supports most systems.\u001b[K\r\n##   No autodetection is done.\u001b[K\r\n#    HOOKS=(base udev microcode modconf block filesystems fsck)\u001b[K\r\n#\u001b[K\r\n##   This setup assembles a mdadm array with an encrypted root file system.\u001b[K\r\n\u001b[0;10;7m\u000fetc/mki"]
