[0.000, "o", "\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H"]
