[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Add SameSite attribute to cookie to help mitigate Cross-Site Request Forgery (CSRF/XSRF)\r"]
