[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "session.use_only_cookies = 1\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.use-only-cookies\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; not the be-all and end-all of session hijacking defense, but it's a good start.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; session hijacking when not specifying and managing your own session id. It is\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; the session id. We encourage this operation as it's very helpful in combating\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; This option forces PHP to fetch and use a cookie for storing and maintaining\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";session.cookie_secure =\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.cookie-secure\r"]
