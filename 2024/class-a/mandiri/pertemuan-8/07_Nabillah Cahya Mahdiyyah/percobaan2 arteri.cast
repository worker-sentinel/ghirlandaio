[0.001, "o", "\r\u001b[2d; that were passed when the script was invoked. These arrays are extremely\u001b[3;3Huseful when running scripts from the command line. When this directive is\u001b[K\u001b[4;3Henabled, registering these variables consumes CPU cycles and memory each time\u001b[K\u001b[5;3Ha script is executed. For security reasons, this feature should be disabled\u001b[6;3Hfor non-CLI SAPIs"]
[0.000, "o", ".\u001b[K\u001b[7;3HNote: This directive is ignored for the CLI SAPI\u001b[8;3HThis directive is deprecated.\u001b[K\r\u001b[9d; https://php.net/register-argc-argv\r\u001b[10d;register_argc_argv = Off\r\u001b[11d\u001b[K\u001b[12d; "]
[0.000, "o", "When enabled, the ENV, REQUEST and SERVER variables are created when they'r\u001b[13;3Hfirst used (Just In Time) instead of when the script starts. If these\u001b[K\u001b[14;3Hvariables are not used within a script, having this directive on will result\u001b[15;3Hin a performance gain. The PHP directive register_argc_argv must be disabled\r\u001b[16d;"]
[0.000, "o", " for this directive to have any effect.\r\u001b[17d; https://php.net/auto-globals-jit\r\u001b[18dauto_globals_jit = On\r\u001b[19d\u001b[K\u001b[20d; Whether PHP will read the POST data.\r\u001b[21d"]
[0.000, "o", "; This option is enabled by default.\u001b[22;3HMost likely, you won't want to disable this option globally. It causes $_POST\u001b[23;3Hand $_FILES to always be empty; the only way you will be able to read the\r\u001b[24d"]
[0.000, "o", "; POST data will be through the php://input stream wrapper. This can be useful\r\u001b[25d; to proxy requests or to process the POST data in a memory efficient fashion.\u001b[26;3Hhttps://php.net/enable-post-data-reading\u001b[K\r\u001b[27d;"]
[0.000, "o", "enable_post_data_reading = Off\r\u001b[28d\u001b[K\u001b[29d; Maximum size of POST data that PHP will accept.\r\u001b[30d"]
[0.000, "o", "; Its value may be 0 to disable the limit. It is ignored if POST data reading\u001b[31;3His disabled through enable_post_data_reading.\u001b[32;19Hpost-max-size\u001b[K\r\u001b[33d\u001b[30m\u001b[43mpost_max_size\u001b[39;49m\u001b[m\u000f = 8M\u001b[K\u001b[35;3HAutomatically add\u001b[27Gbefore PHP document.\u001b[K\r\u001b[36d"]
[0.000, "o", "; https://php.net/auto-prepend-file\r\u001b[37dauto_prepend_file =\r\u001b[38d\u001b[K\u001b[39d; Automatically add files after PHP document.\r\u001b[40d;"]
[0.000, "o", " https://php.net/auto-append-file\r\u001b[41dauto_append_file =\r\u001b[42d\u001b[K\u001b[43d; By default, PHP will output a media type using the Content-Type header. To\r\u001b[44d; disable this, simply set it to be empty.\r\u001b[45d;\u001b[46d PHP's built-in default media type is set to text/html"]
[0.000, "o", ".\u001b[K\u001b[47;19Hdefault-mimetype\u001b[K\r\u001b[48ddefault_mimetype = \"text/html\"\u001b[50;3HPHP's default character set is set to UTF-8.\u001b[K\u001b[51;3Hhttps://php.net/default-charset\r\u001b[52ddefault_charset = \"UTF-8\"\r\u001b[53d\u001b[K\u001b[54d"]
[0.000, "o", "; PHP internal character encoding is set to empty.\u001b[55;3HIf empty, default_charset is used.\u001b[K\u001b[56;19Hinternal-encoding\r\u001b[57d;internal_encoding =\u001b[59;3HPHP input character encoding is set to empty.\u001b[K\u001b[60;3H"]
[0.000, "o", "If empty, default_charset is used.\u001b[K\r\u001b[61d; https://php.net/input-encoding\r\u001b[62d;input_encoding =\r\u001b[63d"]
