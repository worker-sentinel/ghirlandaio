[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
