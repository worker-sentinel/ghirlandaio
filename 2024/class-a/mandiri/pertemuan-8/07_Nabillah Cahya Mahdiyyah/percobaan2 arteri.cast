[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;\u001b[9Gcollection through a shell script, cron entry, or some other method.\r"]
