[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; foo = \"None\"  ; sets foo to the string 'None'\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; foo = None    ; sets foo to an empty string\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H; foo =\u001b[2;17H"]
[0.000, "o", "; sets foo to an empty string\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; sign, or by using the None keyword:\r;"]
[0.343, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; An empty string can be denoted by simply not writing anything after the equal\r;"]
[0.254, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; They can be turned off using the values 0, Off, False or No.\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Boolean flags can be turned on using the values 1, On, True or Yes.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; !  boolean NOT\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; ~  bitwise NOT\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; &  bitwise AND\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; ^  bitwise XOR\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; |  bitwise OR\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Expressions in the INI file are limited to bitwise operators and parentheses:\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; previously set variable or directive (e.g. ${foo})\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\r;"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\r;"]
[0.409, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\r;"]
[0.254, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; directive because it is not set or is mistyped, a default value will be used.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; There is no name validation.  If PHP can't find an expected\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Directives are variables used to configure PHP or PHP extensions.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; directive = value\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Directives are specified using the following syntax:\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
