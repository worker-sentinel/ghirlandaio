[0.000, "o", "\r\u001b[2d\u001b[K\u001b[3d; cgi.rfc2616_headers configuration option tells PHP what type of headers to\r\u001b[4d; use when sending HTTP response code. If set to 0, PHP sends Status: header that\r\u001b[5d; is supported by Apache. When this option is set to 1, PHP will send\u001b[6;4HFC2616 compliant header.\r\u001b[7d; Default is zero.\u001b[K\r\u001b[8d; https://php.net/cgi.rfc2616-headers\r\u001b[9d;cgi.rfc2616_headers = 0\u001b[K\r\u001b[10d"]
[0.000, "o", "\u001b[K\u001b[11d; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\r\u001b[12d; (shebang) at the top of the running script. This line might be needed if the\r\u001b[13d"]
[0.000, "o", "; script support running both as stand-alone script and via PHP CGI<. PHP in CGI\u001b[14;3Hmode skips this line and ignores its content if this directive is turned on.\u001b[K\u001b[15;3Hhttps://php.net/cgi.check-shebang-line\u001b[K\r\u001b[16d;cgi.check_shebang_line=1\r\u001b[17d\u001b[K\u001b[18d;"]
