[0.000, "o", "\r\u001b[2d; unless \"declare(encoding=...)\" directive appears at the top of the script.\r\u001b[3d; Only affects if zend.multibyte is set.\r\u001b[4d;zend.script_encoding =\u001b[K\r\u001b[5d\u001b[K\u001b[6d; Allows to include or exclude arguments from stack traces generated for exceptions.\r\u001b[7d; In production, it is recommended to turn this setting on to prohibit the output\r\u001b[8d; of sensitive information in stack traces\u001b[9;3HDefault Value: Off\u001b[K\u001b[10;3HDevelopment Value: Off\u001b[K\u001b[11;3HProduction Value: On\u001b[K\r\u001b[12dzend.exception_ignore_args = On\u001b[K\r\u001b[13d\u001b[K\u001b[14d; "]
[0.000, "o", "Allows setting the maximum string length in an argument of a stringified stack trace\u001b[15;3Hto a value between 0 and 1000000.\u001b[16;3HThis has no effect when zend.exception_ignore_args is enabled.\r\u001b[17d; Default Value: 15\r\u001b[18d; Development Value: 15\u001b[19;3H"]
[0.000, "o", "Production Value: 0\u001b[K\u001b[20;3HIn production, it is recommended to set this to 0 to reduce the output\r\u001b[21d; of sensitive information in stack traces.\r\u001b[22dzend.exception_string_param_max_len = 0\r\u001b[23d\u001b[K\u001b[24d;"]
[0.000, "o", ";;;;;;;;;;;;;;;;\u001b[K\r\u001b[25d; Miscellaneous ;\r\u001b[26d;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[27d\u001b[K\u001b[28;5H"]
[0.000, "o", "cides whether PHP may expose the fact that it is installed on the server\r\u001b[29d; (e.g. by adding its signature to the Web server header).  It is no security\r\u001b[30d; threat in any way, but it makes it possible to determine whether you use PHP\u001b[31;3Hon your server or not.\u001b[K\u001b[32;19Hexpose-php\u001b[K\r\u001b[33d"]
[0.000, "o", "\u001b[30m\u001b[43mexpose_php\u001b[39;49m\u001b[m\u000f = On\u001b[K\r\u001b[34d\u001b[K\u001b[35d;;;;;;;;;;;;;;;;;;;\r\u001b[36d; Resource Limits "]
[0.000, "o", ";\u001b[K\r\u001b[37d;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[38d\u001b[K\u001b[39d"]
[0.000, "o", "; Maximum execution time of each script, in seconds\u001b[40;3Hhttps://php.net/max-execution-time\u001b[K\u001b[41;3H"]
[0.000, "o", "Note: This directive is hardcoded to 0 for the CLI SAPI\u001b[K\r\u001b[42dmax_execution_time = 30\u001b[K\r\u001b[43d\u001b[K\u001b[44d; Maximum amount of time each script may spend parsing request data. It's a good\u001b[45;3Hidea to limit this time on productions servers in order to eliminate unexpectedly\u001b[46;3Hlong running scripts.\u001b[K\u001b[47;3HNote: This directive is hardcoded to -1 for the CLI SAPI\u001b[K\u001b[48;3H"]
[0.001, "o", "Default Value: -1 (Unlimited)\u001b[K\u001b[49;3HDevelopment Value: 60 (60 seconds)\u001b[K\u001b[50;3HProduction Value: 60 (60 seconds)\u001b[K\u001b[51;3Hhttps://php.net/max-input-time\u001b[K\r\u001b[52dmax_input_time = 60\u001b[K\r\u001b[53d\u001b[K\u001b[54d; Maximum input variable nesting level\u001b[55;3Hhttps://php.net/max-input-nesting-level\r\u001b[56d;"]
[0.000, "o", "max_input_nesting_level = 64\u001b[K\r\u001b[57d\u001b[K\u001b[58d; How many GET/POST/COOKIE input variables may be accepted\r\u001b[59d;"]
[0.000, "o", "max_input_vars = 1000\u001b[K\r\u001b[60d\u001b[K\u001b[61d; How many multipart body parts (combined input variable and file uploads) may\u001b[62;3Hbe accepted.\u001b[K\u001b[63;3H"]
[0.000, "o", "Default Value: -1 (Sum of max_input_vars and max_file_uploads)\u001b[K\r\u001b[64d;max_multipart_body_parts = 1500\u001b[K\r\u001b[33d"]
