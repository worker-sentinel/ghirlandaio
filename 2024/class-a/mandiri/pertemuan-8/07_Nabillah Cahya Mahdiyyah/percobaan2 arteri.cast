[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Valid values for this option are 'off', 'on', or a specific buffer size\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; Transparent output compression using the zlib library\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";url_rewriter.hosts\r"]
