[0.000, "o", "; development version only in development environments, as errors shown to\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\b\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; much more verbose when it comes to errors. We recommend using the\r;"]
