[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H"]
[0.000, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H"]
[0.000, "o", "\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H"]
[0.000, "o", "\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.000, "o", "\r\u001b[2d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\r\u001b[3d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[4d#\u001b[K\u001b[5d\b\u001b[K\u001b[6d#\u001b[K\u001b[7d"]
[0.000, "o", " MaxRanges: Maximum number of Ranges in a request before\r\u001b[8d# returning the entire resource, or one of the special\r\u001b[9d# values 'default', 'none' or 'unlimited'.\u001b[K\r\u001b[10d# Default setting is to accept 200 Ranges.\u001b[K\r\u001b[11d#"]
[0.000, "o", "MaxRanges unlimited\u001b[K\r\u001b[12d\u001b[K\u001b[13d#\u001b[K\u001b[14d"]
[0.000, "o", " EnableMMAP and EnableSendfile: On systems that support it,\r\u001b[15d# memory-mapping or the sendfile syscall may be used to deliver\r\u001b[16d# files.  This usually improves server performance, but must\u001b[K\r\u001b[17d# be turned off when serving from networked-mounted\u001b[K\r\u001b[18d#"]
[0.000, "o", " filesystems or if support for these functions is otherwise\u001b[K\r\u001b[19d# broken on your system.\u001b[K\r\u001b[20d# Defaults: EnableMMAP On, EnableSendfile Off\u001b[K\r\u001b[21d#\u001b[K\u001b[22dEnableMMAP off\u001b[K\r\u001b[23d#EnableSendfile on\u001b[K\r\u001b[24d\u001b[K\u001b[25d"]
[0.000, "o", "# Supplemental configuration\u001b[K\r\u001b[26d#\u001b[K\u001b[27d The configuration files in the conf/extra/ directory can be\r\u001b[28d#"]
[0.001, "o", " included to add extra features or to modify the default configuration of\r\u001b[29d# the server, or you may simply copy their contents here and change as\r\u001b[30d# necessary.\u001b[K\r\u001b[31d\u001b[K\u001b[32d# Server-pool management (MPM specific)\u001b[K\r\u001b[33d"]
[0.000, "o", "\u001b[30m\u001b[43mInclude conf\u001b[39;49m\u001b[m\u000f/extra/httpd-mpm.conf\u001b[K\r\u001b[34d\u001b[K\u001b[35d# Multi-language error messages\u001b[K\r\u001b[36dInclude conf/extra/httpd-multilang-errordoc.conf\r\u001b[37d\u001b[K\u001b[38d#"]
[0.000, "o", " Fancy directory listings\u001b[K\r\u001b[39dInclude conf/extra/httpd-autoindex.conf\u001b[K\r\u001b[40d\u001b[K\u001b[41d# Language settings\u001b[K\r\u001b[42d"]
[0.000, "o", "Include conf/extra/httpd-languages.conf\u001b[K\r\u001b[43d\u001b[K\u001b[44d# User home directories\u001b[K\r\u001b[45dInclude conf/extra/httpd-userdir.conf\r\u001b[46d\u001b[K\u001b[47d"]
[0.000, "o", "# Real-time info on requests and configuration\r\u001b[48d#Include conf/extra/httpd-info.conf\r\u001b[49d\u001b[K\u001b[50d# Virtual hosts\r\u001b[51d#Include conf/extra/httpd-vhosts.conf\u001b[K\r\u001b[52d\u001b[K\u001b[53d# Local access to the Apache HTTP Server Manual\u001b[K\r\u001b[54d"]
[0.000, "o", "#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[55d\u001b[K\u001b[56d# Distributed authoring and versioning (WebDAV)\u001b[K\r\u001b[57d#Include conf/extra/httpd-dav.conf\u001b[K\r\u001b[58d\u001b[K\u001b[59d# Various default settings\u001b[K\r\u001b[60d"]
[0.000, "o", "Include conf/extra/httpd-default.conf\u001b[K\r\u001b[61d\u001b[K\u001b[62d# Configure mod_proxy_html to understand HTML4/XHTML1\u001b[63;11Hproxy_html_module>\r\u001b[64dInclude conf/extra/proxy-html.conf\r\u001b[33d"]
[1.502, "o", "\u001b[?25h\u001b[?0cInclude conf\u001b[33;34H\r"]
