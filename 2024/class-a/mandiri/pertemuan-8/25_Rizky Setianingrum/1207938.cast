[0.000, "o", "\n\u001b[1;48r\u001b[45;5H#"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;5H# ScriptSock: On threaded servers, designate the path to the UNIX\u001b[45;19H"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;5H# socket used to communicate with the CGI daemon of mod_cgid.\u001b[45;19H"]
