[0.001, "o", "\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous\u001b[48;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[48;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[48;70H\u001b[0;10;7m\u000fJ\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[48;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[48;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next"]
[0.001, "o", "\r\u001b[2d</IfModule>\r\u001b[3d\u001b[K\u001b[4d# "]
[0.000, "o", "'Main' server configuration\u001b[K\u001b[5;3H\u001b[K\u001b[6d"]
[0.000, "o", "The directives in this section set up the values used by the 'main'\u001b[7;3Hserver, which responds to any requests that aren't handled by a\u001b[8;3H<VirtualHost> definition.  These values also provide defaults for\u001b[9;3Hany <VirtualHost> containers you may define later in the file.\u001b[10;3H\u001b[K\u001b[11d"]
[0.000, "o", "All of these directives may appear inside <VirtualHost> containers,\u001b[K\u001b[12;3Hin which case these default settings will be overridden for the\u001b[13;3Hvirtual host being defined.\u001b[14;3H\u001b[K\r\u001b[15d"]
[0.001, "o", "\u001b[K\u001b[16d# \u001b[K\u001b[17dServerAdmin: Your address, where problems with the server should be\u001b[K\u001b[18;3He-mailed.  This address appears on some server-generated pages, such\u001b[K\u001b[19;3Has error documents.  e.g. admin@your-domain.com\u001b[K\u001b[20;3H"]
[0.000, "o", "\u001b[K\r\u001b[21dServerAdmin you@example.com\r\u001b[22d\u001b[K\u001b[23d# \u001b[K\u001b[24d\u001b[30m\u001b[43mServerName\u001b[39;49m\u001b[m\u000f gives the name and port that the "]
[0.001, "o", "server uses to identify itself.\u001b[25;3H"]
[0.000, "o", "This can often be determined automatically, but we recommend you specify\u001b[26;3Hit explicitly to prevent problems during startup.\u001b[K\u001b[27;3H\u001b[K\u001b[28dIf your host doesn't have a registered DNS name, enter its IP address here.\u001b[29;3H\u001b[K\u001b[30d\bServerName www.example.com:80\r\u001b[31d\u001b[K\u001b[32d#\u001b[K\u001b[33d\b# Deny access to the entirety of your server's filesystem. You must\u001b[34;3Hexplicitly permit access to web content directories in other\u001b[35;3H<Directory> blocks below.\u001b[K\u001b[36;3H\u001b[K\r\u001b[37d<Directory />\r\u001b[38d    AllowOverride none\u001b[K\r\u001b[39d    Require all denied\u001b[K\r\u001b[40d</Directory>\u001b[K\r\u001b[41d\u001b[K\u001b[42d# \u001b[K\r\u001b[43d# Note that from this point forward you must specifically allow\u001b[44;3Hparticular features to be enabled - so if something's not working as\u001b[45;3Hyou might expect, make sure that you have specifically enabled it\u001b[24;3H"]
[1.502, "o", "\u001b[?25h\u001b[?0cServerName\u001b[24;78H\r# "]
