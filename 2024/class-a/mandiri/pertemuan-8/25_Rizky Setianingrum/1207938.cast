[0.000, "o", "\n\u001b[1;48r\u001b[45;5H# If you prefer a logfile with access, agent, and referer information\u001b[45;19H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;5H# (Combined Logfile Format) you can use the following directive.\u001b[45;19H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
