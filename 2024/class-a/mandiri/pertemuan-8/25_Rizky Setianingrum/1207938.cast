[0.000, "o", "\n\u001b[1;48r\u001b[45;1H# \"/srv/http/cgi-bin\" should be changed to whatever your ScriptAliased\u001b[45;19H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
