[0.001, "o", "\r\u001b[2d|\u001b[K\u001b[3d\b*/\u001b[K\r\u001b[4d$config['encryption_key'] = '';\r\u001b[5d\u001b[K\u001b[6d"]
[0.000, "o", "/*\u001b[K\u001b[7d\b--------------------------------------------------------------------------\r\u001b[8d|"]
[0.000, "o", " Session Variables\u001b[K\r\u001b[9d|"]
[0.001, "o", "--------------------------------------------------------------------------\u001b[10;3H\u001b[K\u001b[11d'sess_driver'\u001b[K\u001b[13;9HThe storage driver to use: files, database, redis, memcached\u001b[15;3H'sess_cookie_name'\u001b[K\u001b[17;3H      The session cookie name, must contain only [0-9a-z_-] characters\u001b[K\u001b[18;3H\u001b[K\u001b[19d'sess_expiration'\u001b[K\u001b[20;3H\u001b[K\u001b[21d      The number of SECONDS you want the session to last.\u001b[22;9HSetting to 0 (zero) means expire when the browser is closed.\u001b[23;3H\u001b[K\u001b[24d"]
[0.000, "o", "'\u001b[30m\u001b[43msess_save\u001b[39;49m\u001b[m\u000f_path'\u001b[K\r\u001b[26d| \u001b[9G"]
[0.000, "o", "The location to save sessions to, driver dependent.\r\u001b[27d"]
[0.000, "o", "|\u001b[K\u001b[28d\b|\u001b[9GFor the 'files' driver, it's a path to a writable directory.\r\u001b[29d"]
[0.000, "o", "| \u001b[9G"]
[0.001, "o", "WARNING: Only absolute paths are supported!\r\u001b[30d|\u001b[K\u001b[31d "]
[0.000, "o", "      For the 'database' driver, it's a table name.\r\u001b[32d|"]
[0.000, "o", "       Please read up the manual for the format with other session drivers.\u001b[34;3H"]
[0.000, "o", "      IMPORTANT: You are REQUIRED to set a valid save path!\u001b[K\u001b[35;3H"]
[0.000, "o", "\u001b[K\u001b[36d'sess_match_ip'\u001b[K\r\u001b[38d"]
[0.000, "o", "| \u001b[9G"]
[0.000, "o", "Whether to match the user's IP address when reading the session data.\r\u001b[39d|\u001b[K\u001b[40d\b|\u001b[9GWARNING: If you're using the database driver, don't forget to update\r\u001b[41d| \u001b[41;18Hyour session table's PRIMARY KEY when changing this setting.\r\u001b[42d|"]
[0.000, "o", "\u001b[K\u001b[43d "]
[0.000, "o", "'sess_time_to_update'\r\u001b[44d|\u001b[K\u001b[45;9HHow many seconds between CI regenerating the session ID.\u001b[24;4H"]
