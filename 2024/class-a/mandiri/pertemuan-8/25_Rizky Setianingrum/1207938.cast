[0.001, "o", "\r\u001b[2d<Directory />\u001b[K\r\u001b[3d    AllowOverride none\u001b[K\r\u001b[4d    Require all denied\u001b[K\r\u001b[5d</Directory>\u001b[K\r\u001b[6d"]
[0.000, "o", "\u001b[K\u001b[7d#\u001b[K\u001b[8d\b# Note that from this point forward you must specifically allow\r\u001b[9d# particular features to be enabled - so if something's not working as\r\u001b[10d"]
[0.001, "o", "# you might expect, make sure that you have specifically enabled it\r\u001b[11d# below.\u001b[K\r\u001b[12d#\u001b[K\u001b[13d\b\u001b[K\u001b[14d#"]
[0.000, "o", "\u001b[K\u001b[15d DocumentRoot: The directory out of which you will serve your\r\u001b[16d#"]
[0.000, "o", " documents. By default, all requests are taken from this directory, but\r\u001b[17d# symbolic links and aliases may be used to point to other locations.\r\u001b[18d#\u001b[K\u001b[19d\bDocumentRoot \"/srv/http\"\u001b[K\r\u001b[20d<Directory \"/srv/http\">\u001b[K\r\u001b[21d    #\u001b[K\r\u001b[22d    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[23d    # or any combination of:\u001b[K\r\u001b[24d    #   Indexes \u001b[30m\u001b[43mInclude\u001b[39;49m\u001b[m\u000fs FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[25;5H#\r\u001b[26d"]
[0.001, "o", "    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[27d    # doesn't give it to you.\r\u001b[28d    #\u001b[K\r\u001b[29d    # The Options directive is both complicated and important.  Please see\r\u001b[30d"]
[0.000, "o", "    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[31d    # for more information.\u001b[K\r\u001b[32d    #\u001b[K\r\u001b[33d    Options Indexes FollowSymLinks\u001b[K\r\u001b[34d\u001b[K\u001b[35d    #\u001b[K\r\u001b[36d"]
[0.001, "o", "    # AllowOverride controls what directives may be placed in .htaccess files.\u001b[37;5H# It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[38d    #   AllowOverride FileInfo AuthConfig Limit\u001b[39;5H#\r\u001b[40d    AllowOverride None\u001b[K\r\u001b[41d\u001b[K\u001b[42d    #\u001b[K\r\u001b[43d    # Controls who can get stuff from this server.\u001b[K\r\u001b[44d"]
