[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Transparent output compression using the zlib library\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Valid values for this option are 'off', 'on', or a specific buffer size\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; to be used for compression (default is 4KB)\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Note: Resulting chunk size may vary due to nature of compression. PHP\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;   outputs chunks that are few hundreds bytes each as a result of\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;   compression. If you prefer a larger chunk size for better\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;   performance, enable output_buffering in addition.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; Note: You need to use zlib.output_handler instead of the standard\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;   output_handler, or otherwise the output will be corrupted.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/zlib.output-compression\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1Hzlib.output_compression = Off\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/zlib.output-compression-level\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;zlib.output_compression_level = -1\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[1.140, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; You cannot specify additional output handlers if zlib.output_compression\r"]
[0.254, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; is activated here. This setting does the same as output_handler but in\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; a different order.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/zlib.output-handler\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;zlib.output_handler =\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; Implicit flush tells PHP to tell the output layer to flush itself\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; automatically after every output block.  This is equivalent to calling the\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; PHP function flush() after each and every call to print() or echo() and each\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; and every HTML block.  Turning this option on has serious performance\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; implications and is generally recommended for debugging purposes only.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/implicit-flush\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; Note: This directive is hardcoded to On for the CLI SAPI\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1Himplicit_flush = Off\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.306, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; The unserialize callback function will be called (with the undefined class'\r"]
[0.251, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; name as parameter), if the unserializer finds an undefined class\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; which should be instantiated. A warning appears if the specified function is\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; not defined, or if the function doesn't include/implement the missing class.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; So only set this entry, if you really want to implement such a\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; callback-function.\r"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1Hunserialize_callback_func =\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; The unserialize_max_depth specifies the default depth limit for unserialized\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; structures. Setting the depth limit too high may result in stack overflows\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; during unserialization. The unserialize_max_depth ini setting can be\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; overridden by the max_depth option on individual unserialize() calls.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; A value of 0 disables the depth limit.\r"]
[0.705, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;unserialize_max_depth = 4096\r"]
[0.376, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.252, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; When floats & doubles are serialized, store serialize_precision significant\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; digits after the floating point. The default value ensures that when floats\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; are decoded with unserialize, the data will remain the same.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; The value is also used for json_encode when encoding double values.\r"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; If -1 is used, then dtoa mode 0 is used which automatically select the best\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; precision.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1Hserialize_precision = -1\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; open_basedir, if set, limits all file operations to the defined directory\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; and below.  This directive makes most sense if used in a per-directory\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; or per-virtualhost web server configuration file.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Note: disables the realpath cache\r"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/open-basedir\r"]
[0.026, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;open_basedir =\r"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; This directive allows you to disable certain functions.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; It receives a comma-delimited list of function names.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/disable-functions\r"]
