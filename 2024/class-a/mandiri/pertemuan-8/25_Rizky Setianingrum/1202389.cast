[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; When enabled, the ENV, REQUEST and SERVER variables are created when they're\r"]
