[0.001, "o", "session.gc_maxlifetime to 1440 (1440 seconds = 24 minutes):\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H;\u001b[9GFor example, the following script is the equivalent of setting\r;"]
