[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; or development versions of the INIs with respect to PHP's default behavior.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Please see the actual settings later in the document for more details as to why\r"]
