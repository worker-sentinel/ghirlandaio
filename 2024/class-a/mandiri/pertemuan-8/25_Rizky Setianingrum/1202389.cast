[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;25H'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\u001b[45;17H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|"]
[0.034, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_key'    - Path to the private key file\u001b[45;17H"]
[0.024, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_cert'   - Path to the public key certificate file\u001b[45;17H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_ca'     - Path to the certificate authority file\u001b[45;17H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\u001b[45;17H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\u001b[45;17H"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\u001b[45;17H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[9G['compress'] Whether or not to use client compression (MySQL only)\u001b[45;19H"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[9G['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\u001b[45;19H"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;57H- good for ensuring strict SQL while developing\u001b[45;17H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[9G['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\u001b[45;19H"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[9G['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[45;19H"]
[0.755, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[9G['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[45;19H"]
[0.251, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33HNOTE: Disabling this will also effectively disable both\u001b[45;17H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33H$this->db->last_query() and profiling of DB queries.\u001b[45;17H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33HWhen you run a query, with this setting set to TRUE (default),\u001b[45;17H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33HCodeIgniter will store the SQL statement for debugging purposes.\u001b[45;17H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33HHowever, this may cause high memory usage, especially if you run\u001b[45;17H"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|\u001b[45;33Ha lot of SQL queries ... disable this to avoid that problem.\u001b[45;17H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H|"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\u001b[46d\b\n\u001b[1;48r\u001b[45;1H| The $active_group variable lets you choose which connection group to\u001b[45;19H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H| make active.  By default there is only one group (the 'default' group).\u001b[45;19H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\r\u001b[46d"]
