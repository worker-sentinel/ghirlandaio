[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; NOTE 1: PHP will not create this directory structure automatically.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
