[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H"]
[0.000, "o", "; After this number of seconds, stored data will be seen as 'garbage' and\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\b"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; cleaned up by the garbage collection process.\r;"]
