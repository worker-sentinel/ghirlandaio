[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "session.use_only_cookies = 1\rs"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.use-only-cookies\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H; not the be-all and end-all of session hijacking defense, but it's a good start.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; session hijacking when not specifying and managing your own session id. It is\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; the session id. We encourage this operation as it's very helpful in combating\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; This option forces PHP to fetch and use a cookie for storing and maintaining\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";session.cookie_partitioned = 0\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H; https://php.net/session.cookie-partitioned\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";session.cookie_secure =\r;"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", "; https://php.net/session.cookie-secure\r;"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "session.use_cookies = 1\rs"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H; https://php.net/session.use-cookies\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Whether to use cookies.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "session.use_strict_mode = 0\rs"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; https://wiki.php.net/rfc/strict_sessions\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; enabling it is encouraged.\r;"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; vulnerability. It is disabled by default for maximum compatibility, but\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Strict mode protects applications from session fixation via a session adoption\r;"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; regenerates the session ID if the browser sends an uninitialized session ID.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Strict session mode does not accept an uninitialized session ID, and\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Whether to use strict session mode.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.001, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";session.save_path = \"/tmp\"\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.save-path\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; does not overwrite the process's umask.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; where MODE is the octal representation of the mode. Note that this\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", ";     session.save_path = \"N;MODE;/path\"\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; You can change that by using\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; The file storage module creates files using mode 600 by default.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H;\u001b[2;11H"]
[0.000, "o", "use subdirectories for session storage\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; NOTE 2: See the section on garbage collection below if you choose to\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H;\u001b[2;11H"]
[0.000, "o", "You can use the script in the ext/session dir for that purpose.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; NOTE 1: PHP will not create this directory structure automatically.\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.002, "o", ";"]
[0.027, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; a more efficient layout for servers that handle many sessions.\r;"]
[0.026, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; your OS has problems with many files in one directory, and is\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; store the session data in those directories.  This is useful if\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; /path, what this will do is use subdirectories N-levels deep, and\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; where N is an integer.  Instead of storing all the session files in\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", ";     session.save_path = \"N;/path\"\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; The path can be defined as:\r;"]
[0.035, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", ";"]
[0.024, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; variable in order to use PHP's session functions.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; where data files are stored. Note: Windows users have to change this\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.001, "o", "; Argument passed to save_handler.  In the case of files, this is the path\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "session.save_handler = files\rs"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; https://php.net/session.save-handler\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "; Handler used to store/retrieve data.\r;"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H"]
[0.000, "o", "[Session]\r["]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b"]
[0.000, "o", "\u001bM\u001b[1;48r\u001b[2;1H"]
