[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H;\u001b[9G"]
[0.001, "o", "collection through a shell script, cron entry, or some other method.\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H;\u001b[9G"]
[0.001, "o", "happen automatically.  You will need to do your own garbage\r;"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;45r\u001b8\b\u001bM\u001b[1;48r\u001b[2;1H;\u001b[9G"]
[0.000, "o", "(see session.save_path above), then garbage collection does *not*\r;"]
