[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; TTL for user-defined php.ini files (time-to-live) in seconds. Default is 300 seconds (5 minutes)\r"]
