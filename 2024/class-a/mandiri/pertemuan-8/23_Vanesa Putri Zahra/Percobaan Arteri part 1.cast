[0.002, "o", "\r\u001b[2d#MaxRanges unlimited\r\u001b[3d\u001b[K\u001b[4d# \u001b[K\u001b[5dEnableMMAP and EnableSendfile: On systems that support it,\u001b[K\u001b[6;3Hmemory-mapping or the sendfile syscall may be used to deliver\r\u001b[7d# files.  This usually improves server performance, but must\r\u001b[8d# be turned off when serving from networked-mounted\r\u001b[9d"]
[0.000, "o", "# filesystems or if support for these functions is otherwise\r\u001b[10d# broken on your system.\u001b[K\r\u001b[11d# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[12d#\u001b[K\u001b[13d\b#EnableMMAP off\r\u001b[14d#EnableSendfile on\u001b[K\r\u001b[15d\u001b[K\u001b[16d# Supplemental configuration\r\u001b[17d#\u001b[K\u001b[18d\b"]
[0.001, "o", "# The configuration files in the conf/extra/ directory can be\r\u001b[19d# included to add extra features or to modify the default configuration of\r\u001b[20d# the server, or you may simply copy their contents here and change as\r\u001b[21d# necessary.\u001b[K\r\u001b[23d# Server-pool management (MPM specific)\r\u001b[24d\u001b[30m\u001b[43mInclude conf\u001b[39;49m\u001b[m\u000f/extra/httpd-mpm.conf\u001b[K\r\u001b[25d\u001b[K\u001b[26d# Multi-language error messages\u001b[K\r\u001b[27d"]
[0.000, "o", "Include conf/extra/httpd-multilang-errordoc.conf\r\u001b[28d\u001b[K\u001b[29d# Fancy directory listings\r\u001b[30dInclude conf/extra/httpd-autoindex.conf\r\u001b[31d\u001b[K\u001b[32d"]
[0.001, "o", "# Language settings\r\u001b[33dInclude conf/extra/httpd-languages.conf\r\u001b[34d\u001b[K\u001b[35d# User home directories\r\u001b[36dInclude conf/extra/httpd-userdir.conf\r\u001b[37d\u001b[K\u001b[38d# "]
[0.000, "o", "Real-time info on requests and configuration\r\u001b[39d#Include conf/extra/httpd-info.conf\r\u001b[40d\u001b[K\u001b[41d# Virtual hosts\u001b[K\r\u001b[42d#Include conf/extra/httpd-vhosts.conf\u001b[44;3HLocal access to the Apache HTTP Server Manual\r\u001b[45d#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[24d"]
