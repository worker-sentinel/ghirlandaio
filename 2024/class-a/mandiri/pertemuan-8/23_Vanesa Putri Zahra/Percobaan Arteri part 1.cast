[0.001, "o", "# you might expect, make sure that you have specifically enabled it\r\u001b[11d# below.\u001b[K\r\u001b[12d#\u001b[K\u001b[14d\b#\u001b[K\u001b[15d DocumentRoot: The directory out of which you will serve your\u001b[16;3Hdocuments. By default, all requests are taken from this directory, but\u001b[17;3Hsymbolic links and aliases may be used to point to other locations.\r\u001b[19dDocumentRoot \"/srv/http\"\u001b[K\r\u001b[20d"]
[0.001, "o", "<Directory \"/srv/http\">\u001b[K\r\u001b[21d    #\u001b[K\r\u001b[22d    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[23d    # or any combination of:\r\u001b[24d    #   Indexes \u001b[30m\u001b[43mInclude\u001b[39;49m\u001b[m\u000fs FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[25;5H#\r\u001b[26d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\u001b[27;5H# doesn't give it to you.\r\u001b[28d    #\u001b[K\r\u001b[29d"]
[0.001, "o", "    # The Options directive is both complicated and important.  Please see\r\u001b[30d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\u001b[K\r\u001b[31d    # for more information.\u001b[K\r\u001b[32d    #\u001b[K\r\u001b[33d    Options Indexes FollowSymLinks\u001b[K\r\u001b[34d\u001b[K\u001b[35d    #\u001b[K\r\u001b[36d    # AllowOverride controls what directives may be placed in .htaccess files.\r\u001b[37d    # It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[38d    #   AllowOverride FileInfo AuthConfig Limit\u001b[39;5H#\r\u001b[40d    AllowOverride None\r\u001b[41d"]
