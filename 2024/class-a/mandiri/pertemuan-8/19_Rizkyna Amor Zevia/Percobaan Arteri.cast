[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Use mixed LF and CRLF line separators to keep compatibility with some\r"]
