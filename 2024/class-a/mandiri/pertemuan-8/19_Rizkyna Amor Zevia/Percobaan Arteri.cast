[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; Note: output_handler must be empty if this is set 'On' !!!!\u001b[64;11H"]
