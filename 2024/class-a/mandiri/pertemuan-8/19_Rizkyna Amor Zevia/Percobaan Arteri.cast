[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; does not overwrite the process's umask.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; where MODE is the octal representation of the mode. Note that this\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", ";\b"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";     session.save_path = \"N;MODE;/path\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;\b"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; You can change that by using\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; The file storage module creates files using mode 600 by default.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";\b"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;\u001b[2;11H"]
[0.002, "o", "use subdirectories for session storage\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; NOTE 2: See the section on garbage collection below if you choose to\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;\u001b[2;11H"]
[0.002, "o", "You can use the script in the ext/session dir for that purpose.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; NOTE 1: PHP will not create this directory structure automatically.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", ";\b"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H; a more efficient layout for servers that handle many sessions.\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; your OS has problems with many files in one directory, and is\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; store the session data in those directories.  This is useful if\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; /path, what this will do is use subdirectories N-levels deep, and\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; where N is an integer.  Instead of storing all the session files in\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", ";\b"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";     session.save_path = \"N;/path\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";\b"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; The path can be defined as:\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", ";\b"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; variable in order to use PHP's session functions.\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; where data files are stored. Note: Windows users have to change this\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Argument passed to save_handler.  In the case of files, this is the path\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hsession.save_handler = files\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/session.save-handler\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Handler used to store/retrieve data.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "[Session]\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";browscap = extra/browscap.ini\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/browscap\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "[browscap]\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "bcmath.scale = 0\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/bcmath.scale\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Number of decimal digits for all bcmath functions.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "[bcmath]\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "pgsql.log_notice = 0\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/pgsql.log-notice\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; Unless pgsql.ignore_notice=0, module cannot log notice message.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; Log PostgreSQL backends Notice message or not.\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hpgsql.ignore_notice = 0\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/pgsql.ignore-notice\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; Notice message logging require a little overheads.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Ignore PostgreSQL backends Notice message or not.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
