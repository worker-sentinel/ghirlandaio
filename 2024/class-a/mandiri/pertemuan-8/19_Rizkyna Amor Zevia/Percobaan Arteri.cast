[0.001, "o", "; are specified in the same manner as the variables_order directive,\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; the order in which that data is registered. The values for this directive\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; registered into the super global array REQUEST. If so, it also determines\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; This directive determines which super global data (G,P & C) should be\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
