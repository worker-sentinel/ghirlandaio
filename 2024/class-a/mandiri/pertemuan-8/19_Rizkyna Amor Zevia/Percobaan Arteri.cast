[0.001, "o", "\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[3d\u001b[K\u001b[4d; Maximum execution time of each script, in seconds\u001b[K\u001b[5;3Hhttps://php.net/max-execution-time\u001b[K\u001b[6;3HNote: This directive is hardcoded to 0 for the CLI SAPI\r\u001b[7dmax_execution_time = 30\u001b[K\r\u001b[8d\u001b[K\u001b[9d; Maximum amount of time each script may spend parsing request data. It's a good\r\u001b[10d; idea to limit this time on productions servers in order to eliminate unexpectedly\r\u001b[11d; long running scripts.\u001b[12;3HNote: This directive is hardcoded to -1 for the CLI SAPI\u001b[K\u001b[13;3HDefault Value: -1 (Unlimited)\u001b[K\u001b[14;3HDevelopment Value: 60 (60 seconds)\u001b[K\u001b[15;3HProduction Value: 60 (60 seconds)\u001b[K\u001b[16;3Hhttps://php.net/max-input-time\u001b[K\r\u001b[17dmax_input_time = 60\u001b[K\r\u001b[18d\u001b[K\u001b[19d; Maximum input variable nesting level\u001b[20;3Hhttps://php.net/max-input-nesting-level\r\u001b[21d;max_input_nesting_level = 64\u001b[K\r\u001b[22d\u001b[K\u001b[23d; "]
[0.001, "o", "How many GET/POST/COOKIE input variables may be accepted\u001b[K\r\u001b[24d;max_input_vars = 1000\u001b[K\r\u001b[25d\u001b[K\u001b[26d; How many multipart body parts (combined input variable and file uploads) may\r\u001b[27d; be accepted.\u001b[K\r\u001b[28d; Default Value: -1 (Sum of max_input_vars and max_file_uploads)\r\u001b[29d;max_multipart_body_parts = 1500\u001b[K\r\u001b[30d\u001b[K\u001b[31d; Maximum amount of memory a script may consume\u001b[32;19Hmemory-limit\u001b[K\r\u001b[33d\u001b[30m\u001b[43mmemory_limit\u001b[39;49m\u001b[m\u000f = 128\r\u001b[34dmax_memory_limit = -1\r\u001b[35d\u001b[K\u001b[36d;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[37d; Error handling and logging ;\r\u001b[38d;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;\r\u001b[39d\u001b[K\u001b[40d; This directive informs PHP of which errors, warnings and notices you would like\r\u001b[41d; it to take action for. The recommended way of setting values for this\r\u001b[42d; directive is through the use of the error level constants and bitwise\u001b[43;3Hoperators. The error level constants are below here for convenience as well as\u001b[44;3Hsome common settings and their meanings\u001b[45;3HBy default, PHP is set to take action on all errors, notices and warnings EXCEPT\u001b[46;3Hthose related to E_NOTICE, which together cover best practices and\u001b[47;3Hrecommended coding standards in PHP. For performance reasons, this is the\r\u001b[48d; recommend error reporting setting. Your production server shouldn't be wasting\r\u001b[49d; resources complaining about best practices and coding standards. That's what\u001b[50;3Hdevelopment servers and development settings are for.\u001b[51;3HNote: The php.ini-development file has this setting as E_ALL. This\r\u001b[52d; means it pretty much reports everything which is exactly what you want during\r\u001b[53d; development and early testing.\u001b[54;3H\u001b[K\u001b[55dError Level Constants:\u001b[K\u001b[56;3HE_ALL             - All errors and warnings\r\u001b[57d; E_ERROR           - fatal run-time errors\r\u001b[58d; E_RECOVERABLE_ERROR  - almost fatal run-time errors\u001b[59;3HE_WARNING         - run-time warnings (non-fatal errors)\u001b[60;3HE_PARSE           - compile-time parse errors\u001b[61;3HE_NOTICE          - run-time notices (these are warnings which often result\r\u001b[62d;\u001b[21X\u001b[62;23Hfrom a bug in your code, but it's possible that it was\r\u001b[63d;\u001b[63;23Hintentional (e.g., using an uninitialized variable and\u001b[64;3H\u001b[20X\u001b[64;23Hrelying on the fact it is automatically initialized to an\r\u001b[33d"]
