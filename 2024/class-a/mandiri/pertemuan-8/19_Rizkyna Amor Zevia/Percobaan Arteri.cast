[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;unserialize_max_depth = 4096\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; A value of 0 disables the depth limit.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; overridden by the max_depth option on individual unserialize() calls.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; during unserialization. The unserialize_max_depth ini setting can be\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.000, "o", "; structures. Setting the depth limit too high may result in stack overflows\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; The unserialize_max_depth specifies the default depth limit for unserialized\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1Hunserialize_callback_func =\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; callback-function.\r"]
[0.252, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; So only set this entry, if you really want to implement such a\r"]
[0.251, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; not defined, or if the function doesn't include/implement the missing class.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; which should be instantiated. A warning appears if the specified function is\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; name as parameter), if the unserializer finds an undefined class\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; The unserialize callback function will be called (with the undefined class'\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "implicit_flush = Off\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; Note: This directive is hardcoded to On for the CLI SAPI\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/implicit-flush\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; implications and is generally recommended for debugging purposes only.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; and every HTML block.  Turning this option on has serious performance\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; PHP function flush() after each and every call to print() or echo() and each\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; automatically after every output block.  This is equivalent to calling the\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Implicit flush tells PHP to tell the output layer to flush itself\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H;zlib.output_handler =\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; https://php.net/zlib.output-handler\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; a different order.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; is activated here. This setting does the same as output_handler but in\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; You cannot specify additional output handlers if zlib.output_compression\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", ";zlib.output_compression_level = -1\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/zlib.output-compression-level\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "zlib.output_compression = Off\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; https://php.net/zlib.output-compression\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", ";   output_handler, or otherwise the output will be corrupted.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Note: You need to use zlib.output_handler instead of the standard\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", ";   performance, enable output_buffering in addition.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";   compression. If you prefer a larger chunk size for better\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";   outputs chunks that are few hundreds bytes each as a result of\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Note: Resulting chunk size may vary due to nature of compression. PHP\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; to be used for compression (default is 4KB)\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; Valid values for this option are 'off', 'on', or a specific buffer size\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; Transparent output compression using the zlib library\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";url_rewriter.hosts\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Production Value: \"\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Development Value: \"\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Default Value: \"\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Refer to session.trans_sid_hosts for more details.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; absolute URL rewrite, allowed hosts must be defined at RUNTIME.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; URL rewriter will not rewrite absolute URL nor form by default. To enable\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";url_rewriter.tags\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Production Value: \"form=\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Development Value: \"form=\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Default Value: \"form=\"\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; Refer to session.trans_sid_tags for usage.\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; \"form\" tag is special tag. It will add hidden input tag to pass values.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; output buffer. You can set target tags by this configuration.\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; URL rewriter function rewrites URL on the fly by using\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";output_handler =\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; https://php.net/output-handler\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";   Instead you must use zlib.output_handler.\r"]
[0.352, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Note: output_handler must be empty if this is set 'On' !!!!\r"]
[0.248, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";   and you cannot use both \"ob_gzhandler\" and \"zlib.output_compression\".\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Note: You cannot use both \"mb_output_handler\" with \"ob_iconv_handler\"\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
