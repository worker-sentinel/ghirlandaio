[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; php.ini-development is very similar to its production variant, except it is\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; recommending using the production ini in production and testing environments.\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; compatibility with older or less security-conscious applications. We\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; best practices at its core. But please be aware, these settings may break\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; php.ini-production contains settings which hold security, performance and\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; development environments.\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; in production environments and one that is recommended to be used in\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; PHP comes packaged with two INI files. One that is recommended to be used\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";;;;;;;;;;;;;;;;;;;\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; About this file ;\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", ";;;;;;;;;;;;;;;;;;;\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; you may only use these constants *after* the line that loads the extension.\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; dynamically loaded extension (either a PHP extension or a Zend extension),\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; If you use constants in your value, and these constants belong to a\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; foo = \"None\"  ; sets foo to the string 'None'\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; foo = None    ; sets foo to an empty string\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; foo =\u001b[2;17H"]
[0.001, "o", "; sets foo to an empty string\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; sign, or by using the None keyword:\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; An empty string can be denoted by simply not writing anything after the equal\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; They can be turned off using the values 0, Off, False or No.\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; Boolean flags can be turned on using the values 1, On, True or Yes.\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; !  boolean NOT\u001b[11G"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; ~  bitwise NOT\u001b[11G"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; &  bitwise AND\u001b[11G"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; ^  bitwise XOR\u001b[11G"]
[0.317, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; |  bitwise OR\u001b[11G"]
[0.255, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Expressions in the INI file are limited to bitwise operators and parentheses:\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.001, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; previously set variable or directive (e.g. ${foo})\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\u001b[2;11H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
[0.000, "o", "\u001bM\u001b[1;67r\u001b[2;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; directive because it is not set or is mistyped, a default value will be used.\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; There is no name validation.  If PHP can't find an expected\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Directives are variables used to configure PHP or PHP extensions.\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\u001b[2;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; directive = value\u001b[2;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;64r\u001b8\r\u001bM\u001b[1;67r\u001b[2;1H"]
[0.002, "o", "; Directives are specified using the following syntax:\u001b[2;11H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\r"]
