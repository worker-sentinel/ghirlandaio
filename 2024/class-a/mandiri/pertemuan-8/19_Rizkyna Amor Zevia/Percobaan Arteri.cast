[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; If -1 is used, then dtoa mode 0 is used which automatically select the best\u001b[64;11H"]
