[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Transparent output compression using the zlib library\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; Valid values for this option are 'off', 'on', or a specific buffer size\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; to be used for compression (default is 4KB)\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; Note: Resulting chunk size may vary due to nature of compression. PHP\u001b[64;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H;   outputs chunks that are few hundreds bytes each as a result of\u001b[64;11H"]
