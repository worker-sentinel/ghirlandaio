[0.001, "o", "\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[2;3HPrevent decoding of SCRIPT_FILENAME when using Apache ProxyPass or\r\u001b[3d; ProxyPassMatch. This should be used if script file paths are not stored\r\u001b[4d; in an encoded format on the file system.\r\u001b[5d; Default is 1.\u001b[K\r\u001b[6d;fastcgi.script_path_encoded = 0\r\u001b[7d\u001b[K\u001b[8d; Disable logging through FastCGI connection. PHP's default behavior is to enable\u001b[9;3Hthis feature.\u001b[K\r\u001b[10d;fastcgi.logging = 0\u001b[K\r\u001b[11d\u001b[K\u001b[12d; cgi.rfc2616_headers configuration option tells PHP what type of headers to\r\u001b[13d; use when sending HTTP response code. If set to 0, PHP sends Status: header that\u001b[14;3His supported by Apache. When this option is set to 1, PHP will send\u001b[K\u001b[15;3HRFC2616 compliant header.\u001b[K\u001b[16;3HDefault is zero.\u001b[K\u001b[17;3Hhttps://php.net/cgi.rfc2616-headers\u001b[K\r\u001b[18d;cgi.rfc2616_headers = 0\u001b[K\r\u001b[19d\u001b[K\u001b[20d; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\u001b[21;3H(shebang) at the top of the r"]
[0.001, "o", "unning script. This line might be needed if the\r\u001b[22d; script support running both as stand-alone script and via PHP CGI<. PHP in CGI\r\u001b[23d; mode skips this line and ignores its content if this directive is turned on.\u001b[24;3Hhttps://php.net/cgi.check-shebang-line\r\u001b[25d;cgi.check_shebang_line=1\u001b[K\r\u001b[26d\u001b[K\u001b[27d;;;;;;;;;;;;;;;;\u001b[28;3HFile Uploads ;\u001b[K\r\u001b[29d;;;;;;;;;;;;;;;;\u001b[K\u001b[31;3HWhether to allow HTTP file uploads.\u001b[K\u001b[32;3Hhttps://php.net/file-uploads\r\u001b[33d\u001b[30m\u001b[43mfile_uploads\u001b[39;49m\u001b[m\u000f = On\u001b[K\r\u001b[34d\u001b[K\u001b[35d; Temporary directory for HTTP uploaded files (will use system default if not\u001b[36;3Hspecified).\u001b[K\u001b[37;19Hupload-tmp-dir\r\u001b[38d;upload_tmp_dir =\u001b[K\r\u001b[39d\u001b[K\u001b[40d; Maximum allowed size for uploaded files.\r\u001b[41d; https://php.net/upload-max-filesize\r\u001b[42dupload_max_filesize = 2M\u001b[K\r\u001b[43d\u001b[K\u001b[44d; Maximum number of files that can be uploaded via a single request\r\u001b[45dmax_file_uploads = 20\u001b[K\r\u001b[46d\u001b[K\u001b[47d;;;;;;;;;;;;;;;;;;\u001b[K\u001b[48;3HFopen wrappers ;\u001b[K\r\u001b[49d;;;;;;;;;;;;;;;;;;\u001b[K\r\u001b[50d\u001b[K\u001b[51d; Whether to allow the treatment of URLs (like http:// or ftp://) as files.\u001b[52;3Hhttps://php.net/allow-url-fopen\u001b[K\r\u001b[53dallow_url_fopen = On\u001b[K\r\u001b[54d\u001b[K\u001b[55d; Whether to allow include/require to open URLs (like https:// or ftp://) as files.\u001b[56;3Hhttps://php.net/allow-url-include\u001b[K\r\u001b[57dallow_url_include = Off\u001b[K\r\u001b[58d\u001b[K\u001b[59d; Define the anonymous ftp password (your email address). PHP's default setting\u001b[60;3Hfor this is empty.\u001b[K\u001b[61;3H"]
