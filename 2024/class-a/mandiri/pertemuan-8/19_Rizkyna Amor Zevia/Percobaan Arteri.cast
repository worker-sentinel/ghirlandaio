[0.002, "o", "; reasons.\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; as it gets it. On production servers, 4096 bytes is a good setting for performance\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; emitting less packets due to buffered output versus PHP streaming the output\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001bM\u001b[1;67r\u001b[2;1H"]
[0.001, "o", "; through print or echo. You also may see performance benefits if your server is\r"]
[1.012, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;64r\u001b8\u001bM\u001b[1;67r\u001b[2;1H; You may be able to send headers and cookies after you've already sent output\r"]
