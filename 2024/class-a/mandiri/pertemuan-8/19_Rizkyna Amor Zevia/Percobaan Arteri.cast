[0.002, "o", "\u001b[65;112H\u001b[0;10;7m\u000f[ Read 96 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                    /srv/http/arteri/application/config/database.php                                                                                              \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d<?php\r\u001b[3ddefined('BASEPATH') OR exit('No direct script access allowed');\r\u001b[5d/*\r\u001b[6d| -------------------------------------------------------------------\r\u001b[7d| DATABASE CONNECTIVITY SETTINGS\r\u001b[8d| -------------------------------------------------------------------\r\u001b[9d| This file will contain the settings needed to access your database.\r\u001b[10d|\u001b[11d\b| For complete instructions please consult the 'Database Connection'\r\u001b[12d| page of the User Guide.\r\u001b[13d|\u001b[14d\b| -------------------------------------------------------------------\r\u001b[15d| EXPLANATION OF VARIABLES\r\u001b[16d| -------------------------------------------------------------------\r\u001b[17d|\u001b[18d\b|\u001b[9G['dsn']\u001b[22GThe full DSN string describe a connection to the database.\r\u001b[19d|\u001b[9G['hostname'] The hostname of your database server.\r\u001b[20d|\u001b[9G['username'] The username used to connect to the database\r\u001b[21d|\u001b[9G['password'] The password used to connect to the database\r\u001b[22d|\u001b[9G['database'] The name of the database you want to connect to\r\u001b[23d|\u001b[9G['dbdriver'] The database driver. e.g.: mysqli.\r\u001b[24d|\u001b[24;25HCurrently supported:\r\u001b[25d|\u001b[25;34Hcubrid, ibase, mssql, mysql, mysqli, oci8,\r\u001b[26d|\u001b[26;34Hodbc, pdo, postgre, sqlite, sqlite3, sqlsrv\r\u001b[27d|\u001b[9G['dbprefix'] You can add an optional prefix, which will be added\r\u001b[28d|\u001b[28;34Hto the table name when using the  Query Builder class\r\u001b[29d|\u001b[9G['pconnect'] TRUE/FALSE - Whether to use a persistent connection\r\u001b[30d|\u001b[9G['db_debug'] TRUE/FALSE - Whether database errors should be displayed.\r\u001b[31d|\u001b[9G['cache_on'] TRUE/FALSE - Enables/disables query caching\r\u001b[32d|\u001b[9G['cachedir'] The path to the folder where cache files should be stored\r\u001b[33d|\u001b[9G['char_set'] The character set used in communicating with the database\r\u001b[34d|\u001b[9G['dbcollat'] The character collation used in communicating with the database\r\u001b[35d|\u001b[35;34HNOTE: For MySQL and MySQLi databases, this setting is only used\r\u001b[36d|\u001b[36;34Has a backup if your server is running PHP < 5.2.3 or MySQL < 5.0.7\r\u001b[37d|\u001b[37;34H(and in table creation queries made with DB Forge).\r\u001b[38d|\u001b[38;34HThere is an incompatibility in PHP with mysql_real_escape_string() which\r\u001b[39d|\u001b[39;34Hcan make your site vulnerable to SQL injection if you are using a\r\u001b[40d|\u001b[40;34Hmulti-byte character set and are running versions lower than these.\r\u001b[41d|\u001b[41;34HSites using Latin-1 or UTF-8 database character set and collation are unaffected.\r\u001b[42d|\u001b[9G['swap_pre'] A default table prefix that should be swapped with the dbprefix\r\u001b[43d|\u001b[9G['encrypt']  Whether or not to use an encrypted connection.\r\u001b[44d|\u001b[45d\b|\u001b[45;25H'mysql' (deprecated), 'sqlsrv' and 'pdo/sqlsrv' drivers accept TRUE/FALSE\r\u001b[46d|\u001b[46;25H'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\r\u001b[47d|\u001b[48d\b|\u001b[48;33H'ssl_key'    - Path to the private key file\r\u001b[49d|\u001b[49;33H'ssl_cert'   - Path to the public key certificate file\r\u001b[50d|\u001b[50;33H'ssl_ca'     - Path to the certificate"]
[0.000, "o", " authority file\r\u001b[51d|\u001b[51;33H'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\r\u001b[52d|\u001b[52;33H'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\r\u001b[53d|\u001b[53;33H'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\r\u001b[54d|\u001b[55d\b|\u001b[9G['compress'] Whether or not to use client compression (MySQL only)\r\u001b[56d|\u001b[9G['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\r\u001b[57d|\u001b[57;57H- good for ensuring strict SQL while developing\r\u001b[58d|\u001b[9G['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\r\u001b[59d|\u001b[9G['failover'] array - A array with 0 or more data for connections if the main should fail.\r\u001b[60d|\u001b[9G['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\r\u001b[61d|\u001b[61;33HNOTE: Disabling this will also effectively disable both\r\u001b[62d|\u001b[62;33H$this->db->last_query() and profiling of DB queries.\r\u001b[63d|\u001b[63;33HWhen you run a query, with this setting set to TRUE (default),\r\u001b[64d|\u001b[64;33HCodeIgniter will store the SQL statement for debugging purposes.\r\u001b[2d\u001b[?25h\u001b[?0c"]
