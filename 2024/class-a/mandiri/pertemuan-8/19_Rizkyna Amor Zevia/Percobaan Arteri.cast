[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H;zlib.output_handler =\u001b[64;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Implicit flush tells PHP to tell the output layer to flush itself\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; automatically after every output block.  This is equivalent to calling the\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; PHP function flush() after each and every call to print() or echo() and each\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; and every HTML block.  Turning this option on has serious performance\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; implications and is generally recommended for debugging purposes only.\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; https://php.net/implicit-flush\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Note: This directive is hardcoded to On for the CLI SAPI\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1Himplicit_flush = Off\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; The unserialize callback function will be called (with the undefined class'\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; name as parameter), if the unserializer finds an undefined class\u001b[64;11H"]
[3.126, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; which should be instantiated. A warning appears if the specified function is\u001b[64;11H"]
[0.254, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; not defined, or if the function doesn't include/implement the missing class.\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; So only set this entry, if you really want to implement such a\u001b[64;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; callback-function.\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1Hunserialize_callback_func =\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; The unserialize_max_depth specifies the default depth limit for unserialized\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; structures. Setting the depth limit too high may result in stack overflows\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; during unserialization. The unserialize_max_depth ini setting can be\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H; overridden by the max_depth option on individual unserialize() calls.\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; A value of 0 disables the depth limit.\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d\n\u001b[1;67r\u001b[64;1H;unserialize_max_depth = 4096\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d\n\u001b[1;67r\u001b[64;1H; When floats & doubles are serialized, store serialize_precision significant\u001b[64;11H"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; digits after the floating point. The default value ensures that when floats\u001b[64;11H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; are decoded with unserialize, the data will remain the same.\u001b[64;11H"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\r\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; The value is also used for json_encode when encoding double values.\u001b[64;11H"]
