[0.001, "o", "\u001b[65;111H\u001b[0;10;7m\u000f[ Read 1875 lines ]\u001b[m\u000f\u001b[H\u001b[0;10;7m\u000f  GNU nano 9.0                                                                                                    /etc/php/php.ini                                                                                                              \u001b[1;239H\u001b[m\u000f\r\u001b[66d\u001b[0;10;7m\u000f^G\u001b[m\u000f Help\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is\u001b[52G\u001b[0;10;7m\u000f^K\u001b[m\u000f Cut\u001b[66;69H\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location\u001b[103G\u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\r\u001b[67d\u001b[0;10;7m\u000f^X\u001b[m\u000f Exit\u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace\u001b[52G\u001b[0;10;7m\u000f^U\u001b[m\u000f Paste\u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right\r\u001b[2d[PHP]\r\u001b[4d;;;;;;;;;;;;;;;;;;;\r\u001b[5d; About php.ini   ;\r\u001b[6d;;;;;;;;;;;;;;;;;;;\r\u001b[7d; PHP's initialization file, generally called php.ini, is responsible for\r\u001b[8d; configuring many of the aspects of PHP's behavior.\r\u001b[10d; PHP attempts to find and load this configuration from a number of locations.\r\u001b[11d; The following is a summary of its search order:\r\u001b[12d; 1. SAPI module specific location.\r\u001b[13d; 2. The PHPRC environment variable.\r\u001b[14d; 3. A number of predefined registry keys on Windows\r\u001b[15d; 4. Current working directory (except CLI)\r\u001b[16d; 5. The web server's directory (for SAPI modules), or directory of PHP\r\u001b[17d; (otherwise in Windows)\r\u001b[18d; 6. The directory from the --with-config-file-path compile time option, or the\r\u001b[19d; Windows directory (usually C:\\windows)\r\u001b[20d; See the PHP docs for more specific information.\r\u001b[21d; https://php.net/configuration.file\r\u001b[23d; The syntax of the file is extremely simple.  Whitespace and lines\r\u001b[24d; beginning with a semicolon are silently ignored (as you probably guessed).\r\u001b[25d; Section headers (e.g. [Foo]) are also silently ignored, even though\r\u001b[26d; they might mean something in the future.\r\u001b[28d; Directives following the section heading [PATH=/www/mysite] only\r\u001b[29d; apply to PHP files in the /www/mysite directory.  Directives\r\u001b[30d; following the section heading [HOST=www.example.com] only apply to\r\u001b[31d; PHP files served from www.example.com.  Directives set in these\r\u001b[32d; special sections cannot be overridden by user-defined INI files or\r\u001b[33d; at runtime. Currently, [PATH=] and [HOST=] sections only work under\r\u001b[34d; CGI/FastCGI.\r\u001b[35d; https://php.net/ini.sections\r\u001b[37d; Directives are specified using the following syntax:\r\u001b[38d; directive = value\r\u001b[39d; Directive names are *case sensitive* - foo=bar is different from FOO=bar.\r\u001b[40d; Directives are variables used to configure PHP or PHP extensions.\r\u001b[41d; There is no name validation.  If PHP can't find an expected\r\u001b[42d; directive because it is not set or is mistyped, a default value will be used.\r\u001b[44d; The value can be a string, a number, a PHP constant (e.g. E_ALL or M_PI), one\r\u001b[45d; of the INI constants (On, Off, True, False, Yes, No and None) or an expression\r\u001b[46d; (e.g. E_ALL & ~E_NOTICE), a quoted string (\"bar\"), or a reference to a\r\u001b[47d; previously set variable or directive (e.g. ${foo})\r\u001b[49d; Expressions in the INI file are limited to bitwise operators and parentheses:\r\u001b[50d"]
[0.000, "o", "; |  bitwise OR\r\u001b[51d; ^  bitwise XOR\r\u001b[52d; &  bitwise AND\r\u001b[53d; ~  bitwise NOT\r\u001b[54d; !  boolean NOT\r\u001b[56d; Boolean flags can be turned on using the values 1, On, True or Yes.\r\u001b[57d; They can be turned off using the values 0, Off, False or No.\r\u001b[59d; An empty string can be denoted by simply not writing anything after the equal\r\u001b[60d; sign, or by using the None keyword:\r\u001b[62d; foo =\u001b[62;17H; sets foo to an empty string\r\u001b[63d; foo = None    ; sets foo to an empty string\r\u001b[64d; foo = \"None\"  ; sets foo to the string 'None'\r\u001b[2d\u001b[?25h\u001b[?0c"]
