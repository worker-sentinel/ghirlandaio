[0.000, "o", "\r\u001b[2d# If your host doesn't have a registered DNS name, enter its IP address here.\r\u001b[3d#\u001b[K\u001b[4dServerName www.example.com:80\u001b[K\r\u001b[5d\u001b[K\u001b[6d#\u001b[K\u001b[7d Deny access to the entirety of your server's filesystem. You must\r\u001b[8d# explicitly permit access to web content directories in other\r\u001b[9d# <Directory> blocks below.\u001b[K\r\u001b[10d#\u001b[K\u001b[11d\b<Directory />\u001b[K\r\u001b[12d"]
[0.001, "o", "    AllowOverride none\u001b[K\r\u001b[13d    Require all denied\u001b[K\r\u001b[14d</Directory>\u001b[K\r\u001b[15d\u001b[K\u001b[16d#\u001b[K\u001b[17d Note that from this point forward you must specifically allow\r\u001b[18d# particular features to be enabled - so if something's not working as\r\u001b[19d# you might expect, make sure that you have specifically enabled it\r\u001b[20d# below.\u001b[K\r\u001b[21d#\u001b[K\u001b[22d\b\u001b[K\u001b[23d#\u001b[K\u001b[24d DocumentRoot: The directory out of which you will serve your\r\u001b[25d# documents. By default, all requests are taken from this directory, but\r\u001b[26d# symbolic links and aliases may be used to point to other locations.\r\u001b[27d#\u001b[K\u001b[28d\bDocumentRoot \"/srv/http\"\u001b[K\r\u001b[29d<Directory \"/srv/http\">\u001b[K\r\u001b[30d    #\u001b[K\r\u001b[31d    # Possible values for the Options directive are \"None\", \"All\",\r\u001b[32d    # or any combination of:\u001b[K\r\u001b[33d    #   Indexes \u001b[30m\u001b[43mInclude\u001b[39;49m\u001b[m\u000fs FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\u001b[34d    #\u001b[K\r\u001b[35d    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\u001b[36d    # doesn't give it to you.\u001b[K\r\u001b[37d    #\u001b[K\r\u001b[38d    # The Options directive is both complicated and important.  Please see\r\u001b[39d    # http://httpd.apache.org/docs/2.4/mod/core.html#options\r\u001b[40d"]
[0.001, "o", "    # for more information.\u001b[K\r\u001b[41d    #\u001b[K\r\u001b[42d    Options Indexes FollowSymLinks\u001b[K\r\u001b[43d\u001b[K\u001b[44d    #\u001b[K\r\u001b[45d    # AllowOverride controls what directives may be placed in .htaccess files.\r\u001b[46d    # It can be \"All\", \"None\", or any combination of the keywords:\r\u001b[47d    #   AllowOverride FileInfo AuthConfig Limit\u001b[K\r\u001b[48d    #\u001b[K\r\u001b[49d    AllowOverride None\u001b[K\r\u001b[50d\u001b[K\u001b[51d    #\u001b[K\r\u001b[52d    # Controls who can get stuff from this server.\u001b[K\r\u001b[53d    #\u001b[K\r\u001b[54d    Require all granted\u001b[K\r\u001b[55d</Directory>\u001b[K\r\u001b[56d\u001b[K\u001b[57d#\u001b[K\u001b[58d\b# DirectoryIndex: sets the file that Apache will serve if a directory\r\u001b[59d# is requested.\u001b[K\r\u001b[60d#\u001b[K\u001b[61d\b<IfModule dir_module>\u001b[K\r\u001b[62d    DirectoryIndex index.html\u001b[K\r\u001b[63d</IfModule>\u001b[K\r\u001b[64d\u001b[K\u001b[33;17H"]
