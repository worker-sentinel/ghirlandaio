[0.001, "o", "\r\u001b[2d# 1) plain text 2) local redirects 3) external redirects\r\u001b[3d#\u001b[K\u001b[4d\b# Some examples:\r\u001b[5d#ErrorDocument 500 \"The server made a boo boo.\"\u001b[K\r\u001b[6d#ErrorDocument 404 /missing.html\u001b[K\r\u001b[7d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\r\u001b[8d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[9d#\u001b[K\u001b[10d\b\u001b[K\u001b[11d#\u001b[K\u001b[12d\b# MaxRanges: Maximum number of Ranges in a request before\u001b[K\r\u001b[13d# returning the entire resource, or one of the special\r\u001b[14d# values 'default', 'none' or 'unlimited'.\r\u001b[15d# Default setting is to accept 200 Ranges.\r\u001b[16d#MaxRanges unlimited\r\u001b[17d\u001b[K\u001b[18d#\u001b[K\u001b[19d\b# EnableMMAP and EnableSendfile: On systems that support it,\u001b[K\r\u001b[20d# memory-mapping or the sendfile syscall may be used to deliver\r\u001b[21d# files.  This usually improves server performance, but must\r\u001b[22d"]
[0.001, "o", "# be turned off when serving from networked-mounted\u001b[K\r\u001b[23d# filesystems or if support for these functions is otherwise\u001b[K\r\u001b[24d# broken on your system.\r\u001b[25d# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[26d#\u001b[27d\b#EnableMMAP off\u001b[K\r\u001b[28d#EnableSendfile on\u001b[K\r\u001b[30d# Supplemental configuration\r\u001b[31d#\u001b[K\u001b[32d\b# The configuration files in the conf/extra/ directory can be\r\u001b[33d# \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000fd to add extra features or to modify the default configuration of\r\u001b[34d# the server, or you may simply copy their contents here and change as\u001b[K\r\u001b[35d# necessary.\r\u001b[36d\u001b[K\u001b[37d# Server-pool management (MPM specific)\r\u001b[38dInclude conf/extra/httpd-mpm.conf\u001b[40;3HMulti-language error messages\r\u001b[41dInclude conf/extra/httpd-multilang-errordoc.conf\u001b[K\r\u001b[42d\u001b[K\u001b[43d# Fancy directory listings\u001b[K\r\u001b[44dInclude conf/extra/httpd-autoindex.conf\r\u001b[45d\u001b[K\u001b[46d# Language settings\r\u001b[47dInclude conf/extra/httpd-languages.conf\r\u001b[48d\u001b[K\u001b[49d# User home directories\u001b[K\r\u001b[50dInclude conf/extra/httpd-userdir.conf\r\u001b[51d\u001b[K\u001b[52d# Real-time info on requests and configuration\u001b[K\r\u001b[53d#Include conf/extra/httpd-info.conf\r\u001b[54d\u001b[K\u001b[55d#"]
[0.001, "o", " Virtual hosts\u001b[K\r\u001b[56d#Include conf/extra/httpd-vhosts.conf\u001b[58;3HLocal access to the Apache HTTP Server Manual\r\u001b[59d#Include conf/extra/httpd-manual.conf\u001b[K\r\u001b[60d\u001b[K\u001b[61d# Distributed authoring and versioning (WebDAV)\r\u001b[62d#Include conf/extra/httpd-dav.conf\u001b[K\r\u001b[63d\u001b[K\u001b[64d# Various default settings\u001b[33;3H"]
