[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; Determines the size of the realpath cache to be used by PHP. This value should\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; be increased on systems where PHP opens many files to reflect the quantity of\r"]
