[0.739, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[12;29r\u001b[12;1H\u001b[6L\u001b[1;67r\u001b[2;1H    #\u001b[K\r\u001b[3d    Require all granted\r\u001b[4d</Directory>\u001b[K\u001b[7;4HirectoryIndex: sets the file that Apache will serve if a directory\u001b[8;3His requested.\u001b[K\u001b[9;3H\u001b[K\r\u001b[10d<IfModule dir_module>\r\u001b[11d    DirectoryIndex index.html\r\u001b[12d</IfModule>\r\u001b[14d#\u001b[15d\b# The following lines prevent .htaccess and .htpasswd files from being\r\u001b[16d# viewed by Web clients.\r\u001b[17d#\u001b[18d\b<Files \".ht*\">\u001b[K\u001b[20;3HFiles>\u001b[K\u001b[23;3HErrorLog: The location of the error log file.\u001b[K\u001b[24;3HIf you do not specify an ErrorLog directive within a <VirtualHost>\u001b[K\u001b[25;3Hcontainer, error messages relating to that virtual host will be\u001b[K\u001b[26;3Hlogged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[27;3Hcontainer, that host's errors will be logged there and not here.\r\u001b[28d#\u001b[29d\b"]
[0.000, "o", "ErrorLog \"/var/log/httpd/error_log\"\r\u001b[30d\u001b[K\u001b[31d"]
[0.002, "o", "#\u001b[K\u001b[32d\b# LogLevel: Control the number of messages logged to the error_log.\r\u001b[33d# Possible values \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000f: debug, info, notice, warn, error, crit,\u001b[K\r\u001b[34d# alert, emerg.\r\u001b[35d#\u001b[K\u001b[36d\bLogLevel warn\u001b[K\r\u001b[37d\u001b[K\u001b[38d<IfModule log_config_module>\u001b[K\u001b[39;7H\u001b[K\u001b[40dThe following directives define some format nicknames for use with\u001b[41;7Ha CustomLog directive (see below).\u001b[42;5H#\u001b[K\u001b[43d\bLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\" combined\u001b[44;5HLogFormat \"%h %l %u %t \\\"%r\\\" %>s %b\" common\r\u001b[45d\u001b[K\u001b[46;5H<IfModule logio_module>\u001b[K\u001b[47;5H  # You need to enable mod_logio.c to use %I and %O\u001b[48;5H  LogFormat \"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\" combinedio\u001b[49;5H</IfModule>\u001b[K\u001b[52;7HThe location and format of the access logfile (Common Logfile Format).\u001b[53;7HIf you do not define any access logfiles within a <VirtualHost>\u001b[54;5H# container, they will be logged here.  Contrariwise, if you *do*\r\u001b[55d    # define per-<VirtualHost> access logfiles, transactions will be\u001b[56;5H# logged therein and *not* in this file.\r\u001b[57d    #\r\u001b[58d    CustomLog \"/var/log/httpd/access_log\" common\u001b[K\r\u001b[59d\u001b[K\u001b[60d    #\r\u001b[61d    # If you prefer a logfile with access, agent, and referer information\u001b[62;5H# (Combined Logfile Format) you can use the following directive.\r\u001b[63d    #\u001b[K\u001b[64d\b#CustomLog \"/var/log/httpd/access_log\" combined\u001b[33;19H"]
