[0.931, "o", "\u001b[?25l\u001b[?1c\r\u001b[K\u001b[66;18H\u001b[0;10;7m\u000f^O\u001b[m\u000f Write Out     \u001b[0;10;7m\u000f^F\u001b[m\u000f Where Is      \u001b[0;10;7m\u000f^K\u001b[m\u000f Cut    \u001b[69G\u001b[0;10;7m\u000f^T\u001b[m\u000f Execute\u001b[86G\u001b[0;10;7m\u000f^C\u001b[m\u000f Location      \u001b[0;10;7m\u000fM-U\u001b[m\u000f Undo\u001b[66;120H\u001b[0;10;7m\u000fM-A\u001b[m\u000f Set Mark     \u001b[0;10;7m\u000fM-]\u001b[m\u000f To Bracket   \u001b[0;10;7m\u000fM-B\u001b[m\u000f Previous     \u001b[0;10;7m\u000f◂\u001b[m\u000f Back\u001b[66;188H\u001b[0;10;7m\u000f^◂\u001b[m\u000f Prev Word     \u001b[0;10;7m\u000f^A\u001b[m\u000f Home\u001b[66;222H\u001b[0;10;7m\u000fM-<\u001b[m\u000f Scroll Left\u001b[67;2H\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H"]
[0.001, "o", "\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\r\u001b[2d\u001b[K\u001b[3d; This option forces PHP to fetch and use a cookie for storing and maintaining\u001b[4;3Hthe session id. We encourage this operation as it's very helpful in combating\u001b[5;3Hsession hijacking when not specifying and managing your own session id. It is\u001b[6;3Hnot the be-all and end-all of session hijacking defense, but it's a good start.\u001b[7;3Hhttps://php.net/session.use-only-cookies\u001b[K\r\u001b[8dsession.use_only_cookies = 1\r\u001b[9d\u001b[K\u001b[10d; Name of the session (used as cookie name).\u001b[11;3Hhttps://php.net/session.name\r\u001b[12dsession.name = PHPSESSID\u001b[K\r\u001b[13d\u001b[K\u001b[14d; Initialize session on request startup.\u001b[K\u001b[15;3Hhttps://php.net/session.auto-start\u001b[K\r\u001b[16dsession.auto_start = 0\u001b[K\r\u001b[17d\u001b[K\u001b[18d"]
[0.001, "o", "; Lifetime in seconds of cookie or, if 0, until browser is restarted.\u001b[19;3Hhttps://php.net/session.cookie-lifetime\r\u001b[20dsession.cookie_lifetime = 0\u001b[K\r\u001b[21d\u001b[K\u001b[22d; The path for which the cookie is valid.\u001b[K\u001b[23;3Hhttps://php.net/session.cookie-path\u001b[K\r\u001b[24dsession.cookie_path = /\u001b[K\r\u001b[25d\u001b[K\u001b[26d; The domain for which the cookie is valid.\r\u001b[27d; https://php.net/session.cookie-domain\r\u001b[28dsession.cookie_domain =\u001b[K\r\u001b[29d\u001b[K\u001b[30d; Whether or not to add the httpOnly flag to the cookie, which makes it\r\u001b[31d; inaccessible to browser scripting languages such as JavaScript.\u001b[32;34Hhttponly\r\u001b[33d\u001b[30m\u001b[43msession.cookie_httponly\u001b[39;49m\u001b[m\u000f =\u001b[35;3HAdd SameSite attribute to cookie to help mitigate Cross-Site Request Forgery (CSRF/XSRF)\r\u001b[36d; Current valid values are \"Strict\", \"Lax\" or \"None\". When using \"None\",\r\u001b[37d; make sure to include the quotes, as `none` is interpreted like `false` in ini files.\u001b[38;3Hhttps://tools.ietf.org/html/draft-west-first-party-cookies-07\u001b[K\r\u001b[39dsession.cookie_samesite =\u001b[K\r\u001b[40d\u001b[K\u001b[41d; Handler used to serialize data. php is the standard serializer of PHP.\u001b[K\u001b[42;27Hserialize-handler\u001b[43;9Hserialize_handler = php\u001b[45;3HDefines the probability that the 'garbage collection' process is started on every\u001b[46;3Hsession initialization. The probability is calculated by using gc_probability/gc_divisor,\r\u001b[47d; e.g. 1/100 means there is a 1% chance that the GC process starts on each request.\r\u001b[48d; Default Value: 1\u001b[49;3HDevelopment Value: 1\u001b[K\u001b[50;3HProduction Value: 1\u001b[K\r\u001b[51d; https://php.net/session.gc-probability\r\u001b[52dsession.gc_probability = 1\r\u001b[53d\u001b[K\u001b[54d; Defines the probability that the 'garbage collection' process is started on every\r\u001b[55d; session initialization. The probability is calculated by using gc_probability/gc_divisor,\r\u001b[56d; e.g. 1/100 means there is a 1% chance that the GC process starts on each request.\u001b[57;3H"]
[0.001, "o", "For high volume production servers, using a value of 1000 is a more efficient approach.\u001b[58;3HDefault Value: 100\u001b[K\r\u001b[59d; Development Value: 1000\r\u001b[60d; Production Value: 1000\u001b[61;3Hhttps://php.net/session.gc-divisor\u001b[K\r\u001b[62dsession.gc_divisor = 1000\u001b[K\r\u001b[63d\u001b[K\u001b[64d; After this number of seconds, stored data will be seen as 'garbage' and\r\u001b[33d"]
