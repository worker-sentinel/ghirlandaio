[0.001, "o", "\u001b[0;10;7m\u000fX\u001b[m\u000f Exit  \u001b[67;18H\u001b[0;10;7m\u000f^R\u001b[m\u000f Read File     \u001b[0;10;7m\u000f^\\\u001b[m\u000f Replace       \u001b[0;10;7m\u000f^U\u001b[m\u000f Paste \u001b[67;69H\u001b[0;10;7m\u000f^J\u001b[m\u000f Justify\u001b[86G\u001b[0;10;7m\u000f^/\u001b[m\u000f Go To Line    \u001b[0;10;7m\u000fM-E\u001b[m\u000f Redo\u001b[67;120H\u001b[0;10;7m\u000fM-6\u001b[m\u000f Copy\u001b[67;137H\u001b[0;10;7m\u000f^B\u001b[m\u000f Where Was     \u001b[0;10;7m\u000fM-F\u001b[m\u000f Next\u001b[67;171H\u001b[0;10;7m\u000f▸\u001b[m\u000f Forward\u001b[67;188H\u001b[0;10;7m\u000f^▸\u001b[m\u000f Next Word     \u001b[0;10;7m\u000f^E\u001b[m\u000f End\u001b[67;222H\u001b[0;10;7m\u000fM->\u001b[m\u000f Scroll Right"]
[0.001, "o", "\u001b[2;5H#\u001b[3dAddType application/x-gzip .tgz\u001b[4;7H\u001b[K\u001b[5dAddEncoding allows you to have certain browsers uncompress\u001b[K\u001b[6;7Hinformation on the fly. Note: Not all browsers support this.\u001b[K\u001b[7;7H\u001b[K\u001b[8d\bAddEncoding x-compress .Z\u001b[K\u001b[9;6HAddEncoding x-gzip .gz .tgz\u001b[10;5H#\u001b[K\u001b[11d\b# If the AddEncoding directives above are commented-out, then you\u001b[12;7Hprobably should define those extensions to indicate media types:\u001b[13;7H\u001b[K\u001b[14d\b\bAddType application/x-compress .Z\u001b[K\u001b[15;5HAddType application/x-gzip .gz .tgz\r\u001b[16d\u001b[K\u001b[17d    #\u001b[K\u001b[18d\b# AddHandler allows you to map certain file extensions to \"handlers\":\r\u001b[19d    # actions unrelated to filetype. These can be either built into the server\u001b[20;7Hor added with the Action directive (see below)\u001b[21;7H\u001b[K\u001b[22dTo use CGI scripts outside of ScriptAliased directories:\u001b[K\u001b[23;7H(You will also need to add \"ExecCGI\" to the \"Options\" directive.)\u001b[24;7H"]
[0.000, "o", "\u001b[K\u001b[25d\bAddHandler cgi-script .cgi\u001b[K\u001b[27;7HFor type maps (negotiated resources):\u001b[28;6HAddHandler type-map var\u001b[K\r\u001b[29d"]
[0.001, "o", "\u001b[K\u001b[30;7H\u001b[K\u001b[31dFilters allow you to process content before it is sent to the client.\u001b[33;7HTo parse .shtml files for server-side \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000fs (SSI):\u001b[K\u001b[34;7H(You will also need to add \"Includes\" to the \"Options\" directive.)\u001b[35;7H\u001b[K\u001b[36d\bAddType text/html .shtml\u001b[37;5H#AddOutputFilter INCLUDES .shtml\r\u001b[38d</IfModule>\r\u001b[39d\u001b[K\u001b[40d#\u001b[K\u001b[41d\b# The mod_mime_magic module allows the server to use various hints from the\r\u001b[42d# contents of the file itself to determine its type.  The MIMEMagicFile\u001b[K\r\u001b[43d# directive tells the module where the hint definitions are located.\u001b[K\r\u001b[44d#\u001b[K\u001b[45d\b#MIMEMagicFile conf/magic\r\u001b[46d\u001b[K\u001b[47d#\u001b[48d\b# Customizable error responses come in three flavors:\r\u001b[49d# 1) plain text 2) local redirects 3) external redirects\r\u001b[50d#\u001b[K\u001b[51d\b# Some examples:\r\u001b[52d#ErrorDocument 500 \"The server made a boo boo.\"\u001b[K\r\u001b[53d#ErrorDocument 404 /missing.html\u001b[K\r\u001b[54d#ErrorDocument 404 \"/cgi-bin/missing_handler.pl\"\r\u001b[55d#ErrorDocument 402 http://www.example.com/subscription_info.html\r\u001b[56d#\u001b[K\u001b[59d MaxRanges: Maximum number of Ranges in a request before\u001b[K\u001b[60;3Hreturning the entire resource, or one of the special\u001b[61;3Hvalues 'default', 'none' or 'unlimited'.\r\u001b[62d# Default setting is to accept 200 Ranges.\r\u001b[63d#MaxRanges unlimited\u001b[K\r\u001b[64d\u001b[K\u001b[33;45H"]
