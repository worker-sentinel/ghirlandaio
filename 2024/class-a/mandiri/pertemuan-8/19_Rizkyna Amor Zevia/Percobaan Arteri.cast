[0.001, "o", "\n\u001b[1;67r\u001b[64;1H; Default timeout for socket based streams (seconds)\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;65r\u001b8\u001b[65d"]
[0.000, "o", "\n\u001b[1;67r\u001b[64;1H; https://php.net/default-socket-timeout\r"]
