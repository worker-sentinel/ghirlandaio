[358.697068, "o", "\u001b[1;6H\u001b[30m\u001b[103m \u001b[2;64H \r\n \u001b[4;3H \u001b[5;76H \u001b[6;16H \u001b[7;76H \u001b[8;2H \u001b[9;70H \u001b[10;25H \u001b[11;2H \u001b[12;28H \u001b[13;2H \u001b[14;36H \u001b[15;2H \u001b[16;74H \n \u001b[18;67H \u001b[19;66H \u001b[20;50H \u001b[21;2H \u001b[22;74H \u001b[23;55H \u001b[24;2H \n \r\n\u001b[m\u000f$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'base_url'\u001b[m\u000f] = (isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTPS'\u001b[m\u000f]) ? \u001b[92m\"https://\"\u001b[m\u000f : \u001b[92m\"http://\"\u001b[m\u000f) . $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTP_HOST'\u001b[m\u000f] . ROOT;\u001b[30m\u001b[103m \r\n \u001b[28;3H \u001b[29;76H \u001b[30;13H \u001b[31;76H \u001b[32;2H \u001b[33;74H \n \u001b[35;32H \u001b[36;2H \n \r\n\u001b[m\u000f$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'index_page'\u001b[m\u000f] = \u001b[92m'index.php'\u001b[m\u000f;\u001b[30m\u001b[103m \r\n \u001b[40;3H \u001b[41;76H \u001b[42;15H \u001b[43;76H \u001b[44;2H \u001b[45;74H \u001b[46;76H \n \u001b[48;2H \u001b[49;48H \n \u001b[51;46H \u001b[52;2H \u001b[53;76H \u001b[54;3H \r\n\u001b[m\u000f$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'uri_protocol'\u001b[m\u000f] = \u001b[92m'REQUEST_URI'\u001b[m\u000f;\u001b[30m\u001b[103m \r\n \u001b[57;3H \u001b[58;76H \u001b[59;13H \u001b[60;76H \u001b[61;2H \u001b[62;79H \u001b[63;50H \u001b[64;2H \u001b[65;55H \u001b[66;223H\u001b[0;10;7m\u000f1,6 \u001b[67;3H\u001b[?25h"]
[358.945656, "o", "\u001b[?25l\b\u001b[m\u000f \u001b[1;6H \u001b[2;64H \r\n \u001b[4;3H \u001b[5;76H \u001b[6;16H \u001b[7;76H \u001b[8;2H \u001b[9;70H \u001b[10;25H \u001b[11;2H \u001b[12;28H \u001b[13;2H \u001b[14;36H \u001b[15;2H \u001b[16;74H \n \u001b[18;67H \u001b[19;66H \u001b[20;50H \u001b[21;2H \u001b[22;74H \u001b[23;55H \u001b[24;2H \n \u001b[26;106H \r\n \u001b[28;3H \u001b[29;76H \u001b[30;13H \u001b[31;76H \u001b[32;2H \u001b[33;74H \n \u001b[35;32H \u001b[36;2H \n \u001b[38;37H \r\n \u001b[40;3H \u001b[41;76H \u001b[42;15H \u001b[43;76H \u001b[44;2H \u001b[45;74H \u001b[46;76H \n \u001b[48;2H \u001b[49;48H \n \u001b[51;46H \u001b[52;2H \u001b[53;76H \u001b[54;3H \u001b[55;41H \r\n \u001b[57;3H \u001b[58;76H \u001b[59;13H \u001b[60;76H \u001b[61;2H \u001b[62;79H \u001b[63;50H \u001b[64;2H \u001b[65;55H \u001b[66;225H\u001b[0;10;7m\u000f1\u001b[67;2H\u001b[?25h"]
