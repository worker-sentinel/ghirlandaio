[489.290214, "o", "\u001b[?25l\u001b[m\u000f<?php\u001b[K\r\n\u001b[96merror_reporting\u001b[m\u000f(0);\u001b[K\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| Base Site URL\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| URL to your CodeIgniter root. Typically this will be your base URL,\u001b[K\r\n| WITH a trailing slash:\u001b[K\r\n|\u001b[K\r\n|       http://example.com/\u001b[K\r\n|\u001b[K\r\n| WARNING: You MUST set this value!\u001b[K\r\n|\u001b[K\r\n| If it is not set, then CodeIgniter will try guess the protocol and path\u001b[K\r\n| your installation, but due to security concerns the hostname will be set\u001b[K\r\n| to $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\u001b[K\r\n| The auto-detection mechanism exists only for convenience during\u001b[K\r\n| development and MUST NOT be used in production!\u001b[K\r\n|\u001b[K\r\n| If you need to allow multiple domains, remember that this file is still\u001b[K\r\n| a PHP script and you can easily do that on your own.\u001b[K\r\n|\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'base_url'\u001b[m\u000f] = (isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTPS'\u001b[m\u000f]) ? \u001b[92m\"https://\"\u001b[m\u000f : \u001b[92m\"http://\"\u001b[m\u000f) . $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTP_HOST'\u001b[m\u000f] . ROOT;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| Index File\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| Typically this will be your index.php file, unless you've renamed it to\u001b[K\r\n| something else. If you are using mod_rewrite to remove the page set this\u001b[K\r\n| variable so that it is blank.\u001b[K\r\n|\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'index_page'\u001b[m\u000f] = \u001b[92m'index.php'\u001b[m\u000f;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| URI PROTOCOL\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| This item determines which server global should be used to retrieve the\u001b[K\r\n| URI string.  The default setting of 'REQUEST_URI' works for most servers.\u001b[K\r\n| If your links do not seem to work, try one of the other delicious flavors:\u001b[K\r\n|\u001b[K\r\n| 'REQUEST_URI'    Uses $_SERVER['REQUEST_URI']\u001b[K\r\n| 'QUERY_STRING'   Uses $_SERVER['QUERY_STRING']\u001b[K\r\n| 'PATH_INFO'      Uses $_SERVER['PATH_INFO']\u001b[K\r\n|\u001b[K\r\n| WARNING: If you set this to 'PATH_INFO', URIs will always be URL-decoded!\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'uri_protocol'\u001b[m\u000f] = \u001b[92m'REQUEST_URI'\u001b[m\u000f;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| URL suffix\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| This option allows you to add a suffix to all URLs generated by CodeIgniter.\u001b[K\r\n| For more information please see the user guide:\u001b[K\r\n|\u001b[K\r\n\u001b[0;10;7m\u000f/srv/http/arteri/application/config/config.php                                                                                                                                                                                1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H<?php\u001b[K\r\n\u001b[96merror_reporting\u001b[m\u000f(0);\u001b[K\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| Base Site URL\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| URL to your CodeIgniter root. Typically this will be your base URL,\u001b[K\r\n| WITH a trailing slash:\u001b[K\r\n|\u001b[K\r\n|       http://example.com/\u001b[K\r\n|\u001b[K\r\n| WARNING: You MUST set this value!\u001b[K\r\n|\u001b[K\r\n| If it is not set, then CodeIgniter will try guess the protocol and path\u001b[K\r\n| your installation, but due to security concerns the hostname will be set\u001b[K\r\n| to $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\u001b[K\r\n| The auto-detection mechanism exists only for convenience during\u001b[K\r\n| development and MUST NOT be used in production!\u001b[K\r\n|\u001b[K\r\n| If you need to allow multiple domains, remember that this file is still\u001b[K\r\n| a PHP script and you can easily"]
[489.291064, "o", " do that on your own.\u001b[K\r\n|\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'base_url'\u001b[m\u000f] = (isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTPS'\u001b[m\u000f]) ? \u001b[92m\"https://\"\u001b[m\u000f : \u001b[92m\"http://\"\u001b[m\u000f) . $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTP_HOST'\u001b[m\u000f] . ROOT;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| Index File\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| Typically this will be your index.php file, unless you've renamed it to\u001b[K\r\n| something else. If you are using mod_rewrite to remove the page set this\u001b[K\r\n| variable so that it is blank.\u001b[K\r\n|\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'index_page'\u001b[m\u000f] = \u001b[92m'index.php'\u001b[m\u000f;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| URI PROTOCOL\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| This item determines which server global should be used to retrieve the\u001b[K\r\n| URI string.  The default setting of 'REQUEST_URI' works for most servers.\u001b[K\r\n| If your links do not seem to work, try one of the other delicious flavors:\u001b[K\r\n|\u001b[K\r\n| 'REQUEST_URI'    Uses $_SERVER['REQUEST_URI']\u001b[K\r\n| 'QUERY_STRING'   Uses $_SERVER['QUERY_STRING']\u001b[K\r\n| 'PATH_INFO'      Uses $_SERVER['PATH_INFO']\u001b[K\r\n|\u001b[K\r\n| WARNING: If you set this to 'PATH_INFO', URIs will always be URL-decoded!\u001b[K\r\n*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'uri_protocol'\u001b[m\u000f] = \u001b[92m'REQUEST_URI'\u001b[m\u000f;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| URL suffix\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| This option allows you to add a suffix to all URLs generated by CodeIgniter.\u001b[K\r\n| For more information please see the user guide:\u001b[K\r\n|\u001b[K\r\n\u001b[0;10;7m\u000f/srv/http/arteri/application/config/config.php                                                                                                                                                                                1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
