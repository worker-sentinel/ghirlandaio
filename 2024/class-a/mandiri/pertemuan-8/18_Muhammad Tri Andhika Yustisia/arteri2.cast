[327.513273, "o", "\u001b[H<?php\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[12X\r\n\u001b[46X\n/*\u001b[5;2H--------------------------------------------------------------------------\u001b[6;2H Base Site URL\r\n|--------------------------------------------------------------------------\r\n|\u001b[28X\r\n| URL to your CodeIgniter root. Typically this will be your base URL,\r\n| WITH a trailing slash:\u001b[11;2H\u001b[74X\u001b[12;3H      http://example.com/  \u001b[13;2H\u001b[74X\n WARNING: You MUST set this value!\u001b[15;2H\u001b[67X\u001b[16;3HIf it is not set, then CodeIgniter will try guess the protocol and path  \u001b[17;2H your installation, but due to security concerns the hostname will be set\r\n| to $_SERVER['SERVER_ADDR'] if available, or localhost otherwise.\r\n| The auto-detection mechanism exists only for convenience during\r\n| development and MUST NOT be used in production!\r\n| \u001b[22;2H If you need to allow multiple domains, remember that this file is still  \u001b[23;3Ha PHP script and you can easily do that on your own.\u001b[24;2H\u001b[74X\r\n*/\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'base_url'\u001b[m\u000f] = (isset($\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTPS'\u001b[m\u000f]) ? \u001b[92m\"https://\"\u001b[m\u000f : \u001b[92m\"http://\"\u001b[m\u000f) . $\u001b[94m_SERVER\u001b[m\u000f[\u001b[92m'HTTP_HOST'\u001b[m\u000f] . ROOT;\r\n\u001b[68X\n/*\u001b[29;2H--------------------------------------------------------------------------\u001b[30;3HIndex File\u001b[56X\u001b[31;2H--------------------------------------------------------------------------\r\n| \r\n| Typically this will be your index.php file, unless you've renamed it to\r\n| something else. If you are using mod_rewrite to remove the page set this\r\n| variable so that it is blank.\u001b[36;2H\u001b[74X\r\n*/\u001b[21X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'index_page'\u001b[m\u000f] = \u001b[92m'index.php'\u001b[m\u000f;\u001b[39X\r\n \r\n/*\u001b[66X\u001b[41;2H--------------------------------------------------------------------------\u001b[42;2H URI PROTOCOL\u001b[43;2H--------------------------------------------------------------------------\u001b[45;3HThis item determines which server global should be used to retrieve the\u001b[46;3HURI string.  The default setting of 'REQUEST_URI' works for most servers.\u001b[47;2H If your links do not seem to work, try one of the other delicious flavors:\u001b[48;2H\u001b[69X\n 'REQUEST_URI'    Uses $_SERVER['REQUEST_URI']\u001b[50;3H'QUERY_STRING'   Uses $_SERVER['QUERY_STRING']\u001b[27X\u001b[51;2H 'PATH_INFO'      Uses $_SERVER['PATH_INFO']\u001b[52;2H\u001b[65X\u001b[53;3HWARNING: If you set this to 'PATH_INFO', URIs will always be URL-decoded!\u001b[55;10H\u001b[92muri_protocol'\u001b[m\u000f] = \u001b[92m'REQUEST_URI'\u001b[m\u000f;\u001b[59;3HURL suffix\u001b[12X\u001b[62;8Hoption allows you to add a suffix to all URLs generated by CodeIgniter.\u001b[63;3HFor more information please see the user guide:\u001b[24X\u001b[64;2H\u001b[23X\n https://codeigniter.com/user_guide/general/urls.html\u001b[66;224H\u001b[0;10;7m\u000f,1            Top\u001b[67;13H\u001b[?25h"]
