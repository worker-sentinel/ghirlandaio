[277.297491, "o", "\u001b[1;65r\u001b[H\u001b[14M\u001b[1;67r\u001b[12;1H$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'\r\u001b[12B\u001b[m\u000f$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'\r\u001b[17B\u001b[m\u000f$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'\r\u001b[11B\u001b[m\u000f*/\u001b[K\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'url_suffix'\u001b[m\u000f] = \u001b[92m''\u001b[m\u000f;\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n| Default Language\u001b[K\r\n|--------------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n| This determines which set of language files should be used. Make sure\u001b[K\r\n| there is an available translation if you intend to use something other\u001b[K\r\n| than english.\u001b[K\r\n|\u001b[K\r\n*/\u001b[K\r\n\u001b[30m\u001b[103m$config['l\u001b[m\u000f\u001b[92manguage'\u001b[m\u000f]     = \u001b[92m'english'\u001b[m\u000f;\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f79,1            3%\u001b[67;12H\u001b[?25h"]
