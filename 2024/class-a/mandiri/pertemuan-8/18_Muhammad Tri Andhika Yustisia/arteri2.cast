[504.313015, "o", "\u001b[H|    \r\n| This determines which character set is used by default in various methods\r\n| that require a character set to be provided.\u001b[17X\r\n|\r\n| See http://php.net/htmlspecialchars for a list of supported charsets.\u001b[6;2H\u001b[74X\r\n*/\u001b[13X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'charset'\u001b[m\u000f] = \u001b[92m'UTF-8'\u001b[m\u000f;\u001b[46X\r\n \r\n/*\u001b[67X\u001b[11;2H--------------------------------------------------------------------------\u001b[12;2H Enable/Disable System Hooks\u001b[13;2H--------------------------------------------------------------------------\u001b[15;3HIf you would like to use the 'hooks' feature you must enable it by\u001b[16;2H setting this variable to TRUE (boolean).  See the user guide for details.\u001b[17;2H\u001b[72X\r\n*/\u001b[72X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'enable_hooks'\u001b[m\u000f] = FALSE;\u001b[34X\r\n\u001b[65X\n/*\u001b[47X\u001b[22;2H--------------------------------------------------------------------------\u001b[23;3HClass Extension Prefix\u001b[49X\u001b[24;2H--------------------------------------------------------------------------\r\n\n| This item allows you to set the filename/classname prefix when extending\r\n| native libraries.  For more information please see the user guide:\u001b[37X\r\n|\r\n| https://codeigniter.com/user_guide/general/core_classes.html\u001b[30;2H https://codeigniter.com/user_guide/general/creating_libraries.html\u001b[7X\u001b[31;2H\u001b[11X\r\n*/\u001b[73X\r\n\u001b[30m\u001b[103m$config['s\u001b[m\u000f\u001b[92mubclass_prefix'\u001b[m\u000f] = \u001b[92m'MY_'\u001b[m\u000f;\r\n\u001b[73X\n/*\u001b[72X\u001b[36;2H--------------------------------------------------------------------------\u001b[37;2H Composer auto-loading\r\n|--------------------------------------------------------------------------\r\n|\u001b[35X\r\n| Enabling this setting will tell CodeIgniter to look for a Composer\r\n| package auto-loader script in application/vendor/autoload.php.\u001b[42;2H\u001b[74X\u001b[43;3H      $config['composer_autoload'] = TRUE;\u001b[44;2H\u001b[74X\n Or if you have your vendor/ directory located somewhere else, you\u001b[46;3Hcan opt to set a specific path as well:\u001b[32X\u001b[47;2H\u001b[74X\u001b[48;3H      $config['composer_autoload'] = '/path/to/vendor/autoload.php';\u001b[6X\u001b[50;3HFor more information about Composer, please visit http://getcomposer.org/\u001b[51;2H\u001b[47X\u001b[52;3HNote: This will NOT disable or override the CodeIgniter-specific\u001b[53;2H       autoloading (application/config/autoload.php)\r\n*/\u001b[73X\r\n$\u001b[94mconfig\u001b[m\u000f[\u001b[92m'composer_autoload'\u001b[m\u000f] = FALSE;\r\n\u001b[40X\n/*\r\n|--------------------------------------------------------------------------\u001b[59;2H Allowed URL Characters\u001b[51X\u001b[60;2H--------------------------------------------------------------------------\u001b[61;2H\u001b[74X\n This lets you specify which characters are permitted within your URLs.\u001b[63;3HWhen someone tries to submit a URL with disallowed characters they will\u001b[5X\u001b[64;3Hget a warning message.\u001b[25X\u001b[66;223H\u001b[0;10;7m\u000f118,1          18%\u001b[67;12H\u001b[?25h"]
