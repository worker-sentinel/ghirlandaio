[1636.837673, "o", "\u001b[58A\u001b[30m\u001b[103mo\u001b[25;4Ho\u001b[55;3H\u001b[m\u000fDynamic Shared Object (D\u001b[57;72HD\u001b[67;4H\u001b[?25h"]
