[3199.290821, "o", "\u001b[6;45H\u001b[30m\u001b[103md\u001b[9;22Hd\u001b[m\u000f an\u001b[30m\u001b[103md\u001b[m\u000f loa\u001b[30m\u001b[103md\u001b[10;46Hd\u001b[11;13Hd\u001b[13;21Hd\u001b[m\u000fefine\u001b[30m\u001b[103md\u001b[m\u000f registry keys on Win\u001b[30m\u001b[103md\u001b[14;22Hd\nd\u001b[m\u000firectory (for SAPI mo\u001b[30m\u001b[103md\u001b[m\u000fules), or \u001b[30m\u001b[103md\u001b[16;20Hd\u001b[17;10Hd\u001b[18;6Hd\u001b[m\u000fows \u001b[30m\u001b[103md\u001b[m\u000firectory (usually C:\\win\u001b[30m\u001b[103md\u001b[19;15Hd\u001b[22;61Hd\u001b[23;49Hd\u001b[m\u000f (as you probably guesse\u001b[30m\u001b[103md\u001b[24;14Hd\u001b[m\u000fers (e.g. [Foo]) are also silently ignore\u001b[30m\u001b[103md\u001b[27;39Hd\u001b[28;41Hd\u001b[29;28Hd\u001b[30;18Hd\u001b[31;36Hdd\u001b[m\u000fen by user-\u001b[30m\u001b[103md\u001b[m\u000fefine\u001b[30m\u001b[103md\u001b[32;36Hd\u001b[m\u000f [HOST=] sections only work un\u001b[30m\u001b[103md\u001b[36;26Hd\u001b[37;3Hd\u001b[38;53Hd\u001b[39;31Hd\u001b[40;24Hd\u001b[m\u000fation.  If PHP can't fin\u001b[30m\u001b[103md\u001b[m\u000f an expecte\u001b[30m\u001b[103md\u001b[41;3Hd\u001b[m\u000firective because it is not set or is mistype\u001b[30m\u001b[103md\u001b[m\u000f, a \u001b[30m\u001b[103md\u001b[m\u000fefault value will be use\u001b[30m\u001b[103md\u001b[44;57Hd\u001b[45;36Hd\u001b[46;30Hd\u001b[48;41Hd\u001b[m\u000f to bitwise operators an\u001b[30m\u001b[103md\u001b[55;29Hd\u001b[56;20Hd\u001b[58;26Hd\u001b[m\u000fenote\u001b[30m\u001b[103md\u001b[59;36Hd\u001b[65;41Hd\u001b[66;223H\u001b[0;10;7m\u000f6,45\u001b[67;3H\u001b[?25h"]
