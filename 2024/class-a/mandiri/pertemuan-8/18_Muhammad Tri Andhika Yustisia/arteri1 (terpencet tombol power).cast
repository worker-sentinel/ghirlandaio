[2921.279193, "o", "\u001b[?25l\u001b[67;230H   \u001b[1;65r\u001b[H\u001b[M\u001b[1;67r\u001b[65;1H#LoadModule watchdog_module modules/mod_watchdog.so\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f7\r\u001b[A\u001b[?25h"]
