[2934.227596, "o", "\u001b[1;65r\u001b[H\u001b[28M\u001b[1;67r\u001b[5;7Hdirect\u001b[10;16Hdirect\u001b[33;43H\u001b[30m\u001b[103mdirecto\r\u001b[5B\u001b[m\u000f    \u001b[96mRequire\u001b[m\u000f all denied\u001b[K\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Note that from this point forward you must specifically allow\u001b[K\r\n# particular features to be enabled - so if something's not working as\u001b[K\r\n# you might expect, make sure that you have specifically enabled it\u001b[K\r\n# below.\u001b[K\r\n#\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# DocumentRoot: The \u001b[30m\u001b[103mdirecto\u001b[m\u000fry out of which you will serve your\u001b[K\r\n# documents. By default, all requests are taken from this \u001b[30m\u001b[103mdirecto\u001b[m\u000fry, but\u001b[K\r\n# symbolic links and aliases may be used to point to other locations.\u001b[K\r\n#\u001b[K\r\n\u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http/arteri\"\u001b[m\u000f\u001b[K\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/arteri\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n        \u001b[96mOptions\u001b[m\u000f Indexes FollowSymLinks\u001b[K\r\n        \u001b[96mAllowOverride\u001b[m\u000f All\u001b[K\r\n        \u001b[96mRequire\u001b[m\u000f all granted\u001b[K\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[K\r\n    #\u001b[K\r\n    # Possible values for the Options directive are \"None\", \"All\",\u001b[K\r\n    # or any combination of:\u001b[K\r\n    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\u001b[K\r\n    #\u001b[K\r\n    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\u001b[K\r\n    # doesn't give it to you.\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f35,43         42\u001b[67;9H\u001b[?25h"]
