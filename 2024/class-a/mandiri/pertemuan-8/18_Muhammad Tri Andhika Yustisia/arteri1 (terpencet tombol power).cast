[2933.37653, "o", "\u001b[1;65r\u001b[H\u001b[24M\u001b[1;67r\u001b[9;12Hdir_module modules/mod_dir\u001b[13;16Hdir_module modules/mod_userdir\u001b[33;7H\u001b[30m\u001b[103mdire\u001b[38;19He\u001b[m\u000f\r\n\n\n\n\u001b[K\n#\u001b[K\r\n# ServerAdmin: Your address, where problems with the server should be\u001b[K\r\n# e-mailed.  This address appears on some server-generated pages, such\u001b[K\r\n# as error documents.  e.g. admin@your-domain.com\u001b[K\r\n#\u001b[K\r\n\u001b[96mServerAdmin\u001b[m\u000f you@\u001b[96mexample\u001b[m\u000f.com\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# ServerName gives the name and port that the server uses to identify itself.\u001b[K\r\n# This can often be determined automatically, but we recommend you specify\u001b[K\r\n# it explicitly to prevent problems during startup.\u001b[K\r\n#\u001b[K\r\n# If your host doesn't have a registered DNS name, enter its IP address here.\u001b[K\r\n#\u001b[K\r\n#ServerName www.example.com:80\u001b[K\r\n\u001b[K\n#\u001b[K\r\n# Deny access to the entirety of your server's filesystem. You must\u001b[K\r\n# explicitly permit access to web content \u001b[30m\u001b[103mdire\u001b[m\u000fctories in other \u001b[K\r\n# <Directory> blocks below.\u001b[K\r\n#\u001b[K\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f /\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n    \u001b[96mAllowOverride\u001b[m\u000f none\u001b[K\u001b[66;223H\u001b[0;10;7m\u000f207,7          36\u001b[67;6H\u001b[?25h"]
