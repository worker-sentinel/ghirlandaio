[1636.454304, "o", "\u001b[58A\u001b[30m\u001b[103mD\u001b[25;3HD\u001b[55;3HD\u001b[m\u000fynamic Shared Object (\u001b[30m\u001b[103mD\u001b[57;72HD\u001b[66;223H\u001b[0;10;7m\u000f9,3\u001b[67;3H\u001b[?25h"]
