                                              \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \r\n                                                                                                                                                                                                                                                \u001b[?8c\u001b[?1002h\u001b[?1006h\u001b[H\u001b[?25h"]
[704.558449, "o", "\u001bP+q5463;524742;73657472676266;73657472676262\u001b\\\u001b[0m\u001b[48;2;1;2;3m\u001bP$qm\u001b\\\u001b[c"]
[704.560812, "o", "\u001b[?25l\u001b[m\u000f<?php\u001b[K\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| DATABASE CONNECTIVITY SETTINGS\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| This file will contain the settings needed to access your database.\u001b[K\r\n|\u001b[K\r\n| For complete instructions please consult the 'Database Connection'\u001b[K\r\n| page of the User Guide.\u001b[K\r\n|\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| EXPLANATION OF VARIABLES\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n|       ['dsn']      The full DSN string describe a connection to the database.\u001b[K\r\n|       ['hostname'] The hostname of your database server.\u001b[K\r\n|       ['username'] The username used to connect to the database\u001b[K\r\n|       ['password'] The password used to connect to the database\u001b[K\r\n|       ['database'] The name of the database you want to connect to\u001b[K\r\n|       ['dbdriver'] The database driver. e.g.: mysqli.\u001b[K\r\n|                       Currently supported:\u001b[K\r\n|                                cubrid, ibase, mssql, mysql, mysqli, oci8,\u001b[K\r\n|                                odbc, pdo, postgre, sqlite, sqlite3, sqlsrv\u001b[K\r\n|       ['dbprefix'] You can add an optional prefix, which will be added\u001b[K\r\n|                                to the table name when using the  Query Builder class\u001b[K\r\n|       ['pconnect'] TRUE/FALSE - Whether to use a persistent connection\u001b[K\r\n|       ['db_debug'] TRUE/FALSE - Whether database errors should be displayed.\u001b[K\r\n|       ['cache_on'] TRUE/FALSE - Enables/disables query caching\u001b[K\r\n|       ['cachedir'] The path to the folder where cache files should be stored\u001b[K\r\n|       ['char_set'] The character set used in communicating with the database\u001b[K\r\n|       ['dbcollat'] The character collation used in communicating with the database\u001b[K\r\n|                                NOTE: For MySQL and MySQLi databases, this setting is only used\u001b[K\r\n|                                as a backup if your server is running PHP < 5.2.3 or MySQL < 5.0.7\u001b[K\r\n|                                (and in table creation queries made with DB Forge).\u001b[K\r\n|                                There is an incompatibility in PHP with mysql_real_escape_string() which\u001b[K\r\n|                                can make your site vulnerable to SQL injection if you are using a\u001b[K\r\n|                                multi-byte character set and are running versions lower than these.\u001b[K\r\n|                                Sites using Latin-1 or UTF-8 database character set and collation are unaffected.\u001b[K\r\n|       ['swap_pre'] A default table prefix that should be swapped with the dbprefix\u001b[K\r\n|       ['encrypt']  Whether or not to use an encrypted connection.\u001b[K\r\n|\u001b[K\r\n|                       'mysql' (deprecated), 'sqlsrv' and 'pdo/sqlsrv' drivers accept TRUE/FALSE\u001b[K\r\n|                       'mysqli' and 'pdo/mysql' drivers accept an array with the following options:\u001b[K\r\n|\u001b[K\r\n|                               'ssl_key'    - Path to the private key file\u001b[K\r\n|                               'ssl_cert'   - Path to the public key certificate file\u001b[K\r\n|                               'ssl_ca'     - Path to the certificate authority file\u001b[K\r\n|                               'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\u001b[K\r\n|                               'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\u001b[K\r\n|                               'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\u001b[K\r\n|\u001b[K\r\n|       ['compress'] Whether or not to use client compression (MySQL only)\u001b[K\r\n|       ['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\u001b[K\r\n|                                                       - good for ensuring strict SQL while developing\u001b[K\r\n|       ['ssl_options'] Used to set various SSL options that can be used when making SSL connections."]
[704.561953, "o", "\u001b[K\r\n|       ['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[K\r\n|       ['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[K\r\n|                               NOTE: Disabling this will also effectively disable both\u001b[K\r\n|                               $this->db->last_query() and profiling of DB queries.\u001b[K\r\n|                               When you run a query, with this setting set to TRUE (default),\u001b[K\r\n|                               CodeIgniter will store the SQL statement for debugging purposes.\u001b[K\r\n|                               However, this may cause high memory usage, especially if you run\u001b[K\r\n|                               a lot of SQL queries ... disable this to avoid that problem.\u001b[K\r\n\u001b[0;10;7m\u000farteri/application/config/database.php                                                                                                                                                                                        1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[?112c\u001b[?112c\u001b[H<?php\u001b[K\r\n\u001b[96mdefined\u001b[m\u000f(\u001b[92m'BASEPATH'\u001b[m\u000f) OR \u001b[0;10;1m\u000fexit\u001b[m\u000f(\u001b[92m'No direct script access allowed'\u001b[m\u000f);\u001b[K\r\n\u001b[K\n/*\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| DATABASE CONNECTIVITY SETTINGS\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| This file will contain the settings needed to access your database.\u001b[K\r\n|\u001b[K\r\n| For complete instructions please consult the 'Database Connection'\u001b[K\r\n| page of the User Guide.\u001b[K\r\n|\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n| EXPLANATION OF VARIABLES\u001b[K\r\n| -------------------------------------------------------------------\u001b[K\r\n|\u001b[K\r\n|       ['dsn']      The full DSN string describe a connection to the database.\u001b[K\r\n|       ['hostname'] The hostname of your database server.\u001b[K\r\n|       ['username'] The username used to connect to the database\u001b[K\r\n|       ['password'] The password used to connect to the database\u001b[K\r\n|       ['database'] The name of the database you want to connect to\u001b[K\r\n|       ['dbdriver'] The database driver. e.g.: mysqli.\u001b[K\r\n|                       Currently supported:\u001b[K\r\n|                                cubrid, ibase, mssql, mysql, mysqli, oci8,\u001b[K\r\n|                                odbc, pdo, postgre, sqlite, sqlite3, sqlsrv\u001b[K\r\n|       ['dbprefix'] You can add an optional prefix, which will be added\u001b[K\r\n|                                to the table name when using the  Query Builder class\u001b[K\r\n|       ['pconnect'] TRUE/FALSE - Whether to use a persistent connection\u001b[K\r\n|       ['db_debug'] TRUE/FALSE - Whether database errors should be displayed.\u001b[K\r\n|       ['cache_on'] TRUE/FALSE - Enables/disables query caching\u001b[K\r\n|       ['cachedir'] The path to the folder where cache files should be stored\u001b[K\r\n|       ['char_set'] The character set used in communicating with the database\u001b[K\r\n|       ['dbcollat'] The character collation used in communicating with the database\u001b[K\r\n|                                NOTE: For MySQL and MySQLi databases, this setting is only used\u001b[K\r\n|                                as a backup if your server is running PHP < 5.2.3 or MySQL < 5.0.7\u001b[K\r\n|                                (and in table creation queries made with DB Forge).\u001b[K\r\n|                                There is an incompatibility in PHP with mysql_real_escape_string() which\u001b[K\r\n|                                can make your site vulnerable to SQL injection if you are using a\u001b[K\r\n|                                multi-byte character set and are running versions lower than these.\u001b[K\r\n|                                Sites using Latin-1 or UTF-8 database character set and collation are unaffected.\u001b[K\r\n|       ['swap_pre'] A default table prefix that should be swapped with the dbprefix\u001b[K\r\n|       ['encrypt']  Whether or not to use an encrypted connection.\u001b[K\r\n|\u001b[K\r\n|                       'mysql' (deprecated), 'sqlsrv' and 'pdo/sqlsrv' drivers accept TRUE/FALSE\u001b[K\r\n|                       'mysqli' and 'pdo/mysql' drivers accept an array with th"]
[704.562457, "o", "e following options:\u001b[K\r\n|\u001b[K\r\n|                               'ssl_key'    - Path to the private key file\u001b[K\r\n|                               'ssl_cert'   - Path to the public key certificate file\u001b[K\r\n|                               'ssl_ca'     - Path to the certificate authority file\u001b[K\r\n|                               'ssl_capath' - Path to a directory containing trusted CA certificats in PEM format\u001b[K\r\n|                               'ssl_cipher' - List of *allowed* ciphers to be used for the encryption, separated by colons (':')\u001b[K\r\n|                               'ssl_verify' - TRUE/FALSE; Whether verify the server certificate or not ('mysqli' only)\u001b[K\r\n|\u001b[K\r\n|       ['compress'] Whether or not to use client compression (MySQL only)\u001b[K\r\n|       ['stricton'] TRUE/FALSE - forces 'Strict Mode' connections\u001b[K\r\n|                                                       - good for ensuring strict SQL while developing\u001b[K\r\n|       ['ssl_options'] Used to set various SSL options that can be used when making SSL connections.\u001b[K\r\n|       ['failover'] array - A array with 0 or more data for connections if the main should fail.\u001b[K\r\n|       ['save_queries'] TRUE/FALSE - Whether to \"save\" all executed queries.\u001b[K\r\n|                               NOTE: Disabling this will also effectively disable both\u001b[K\r\n|                               $this->db->last_query() and profiling of DB queries.\u001b[K\r\n|                               When you run a query, with this setting set to TRUE (default),\u001b[K\r\n|                               CodeIgniter will store the SQL statement for debugging purposes.\u001b[K\r\n|                               However, this may cause high memory usage, especially if you run\u001b[K\r\n|                               a lot of SQL queries ... disable this to avoid that problem.\u001b[K\r\n\u001b[0;10;7m\u000farteri/application/config/database.php                                                                                                                                                                                        1,1            Top\u001b[m\u000f\r\n\u001b[J\u001b[H\u001b[?25h\u001bP+q4D73\u001b\\"]
