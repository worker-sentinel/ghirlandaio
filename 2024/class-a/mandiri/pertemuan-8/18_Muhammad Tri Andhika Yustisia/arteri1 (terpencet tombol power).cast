[1632.970735, "o", "\u001b[?25h"]
[1633.225929, "o", "\u001b[?25lt"]
[1633.232381, "o", "\u001b[?25h"]
[1634.481458, "o", "\u001b[?25l\b \b"]
[1634.487453, "o", "\u001b[?25h"]
[1634.648436, "o", "\u001b[?25l\b \b"]
[1634.654715, "o", "\u001b[?25h"]
[1634.781522, "o", "\u001b[?25l\b \b"]
[1634.787702, "o", "\u001b[?25h"]
[1635.031762, "o", "\u001b[?25l\b \b"]
[1635.039173, "o", "\u001b[H    #\r\n    # The following directives define some format nicknames for use with  \r\n    # a CustomLog directive (see below).\u001b[25X\r\n    #\u001b[66X\r\n    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\"\"\u001b[m\u000f combined\r\n    \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b\"\u001b[m\u000f common\u001b[12X\r\n\u001b[51X\n    \u001b[0;10;1m\u000f<IfModule\u001b[m\u000f logio_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f      # You need to enable mod_logio.c to use %I and %O\u001b[12X\r\n      \u001b[96mLogFormat\u001b[m\u000f \u001b[92m\"%h %l %u %t \\\"%r\\\" %>s %b \\\"%{Referer}i\\\" \\\"%{User-Agent}i\\\" %I %O\"\u001b[m\u000f combinedio\r\n    \u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[35X\r\n \r\n    #\u001b[67X\r\n    # The location and format of the access logfile (Common Logfile Format).\r\n    # If you do not define any access logfiles within a <VirtualHost> \r\n    # container, they will be logged here.  Contrariwise, if you *do*   \r\n    # define per-<VirtualHost> access logfiles, transactions will be    \r\n    # logged therein and *not* in this file.\u001b[33X\r\n    #\u001b[39X\u001b[20;5H\u001b[96mCustomLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/access_log\"\u001b[m\u000f common\r\n \r\n    #\u001b[63X\r\n    # If you prefer a logfile with access, agent, and referer information\r\n    # (Combined Logfile Format) you can use the following directive.\r\n    #\u001b[63X\r\n    #CustomLog \"/var/log/httpd/access_log\" combined\u001b[21X\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[65X\r\n\u001b[72X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f alias_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    #\r\n    # Redirect: Allows you to tell clients about documents that used to \r\n    # exist in your server's namespace, but do not anymore. The client \r\n    # will make a new request for the \u001b[30m\u001b[103mdocument \u001b[m\u000fat its new location.\r\n    # Example:\u001b[57X\r\n    # Redirect permanent /foo http://www.example.com/bar\r\n \r\n    #\u001b[73X\r\n    # Alias: Maps web paths into filesystem paths and is used to\u001b[12X\r\n    # access content that does not live under the DocumentRoot.\r\n    # Example:\r\n    # Alias /webpath /full/filesystem/path\r\n    #\r\n    # If you include a trailing / on /webpath then the server will\r\n    # require it to be present in the URL.  You will also likely   \r\n    # need to provide a <Directory> section to allow access to\r\n    # the filesystem path.\r\n \r\n    #\u001b[62X\r\n    # ScriptAlias: This controls which directories contain server scripts. \r\n    # ScriptAliases are essentially the same as Aliases, except that\r\n    # documents in the target directory are treated as applications and\r\n    # run by the server when requested rather than as documents sent to the\r\n    # client.  The same rules about trailing \"/\" apply to ScriptAlias\r\n    # directives as to Alias.\r\n    #\u001b[32X\r\n    \u001b[96mScriptAlias\u001b[m\u000f /cgi-bin/ \u001b[92m\"/srv/http/cgi-bin/\"\u001b[m\u000f\r\n\u001b[78X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[61X\r\n\u001b[75X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f cgid_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[48X\r\n    #\u001b[15X\r\n    # ScriptSock: On threaded servers, designate the path to the UNIX\r\n    # socket used to communicate with the CGI daemon of mod_cgid.\r\n    #\u001b[37X\r\n    #Scriptsock cgisock\u001b[66;223H\u001b[0;10;7m\u000f349,39         66%\u001b[67;11H\u001b[?25h"]
[1635.064623, "o", "\u001b[?25l\b"]
[1635.072649, "o", "\u001b[H\u001b[m\u000f\u001b[96mLoadModule\u001b[m\u000f alias_module modules/mod_alias.so\r\n\u001b[96mLoadModule\u001b[m\u000f rewrite_module modules/mod_rewrite.so\u001b[24X\r\n\u001b[40X\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f#\u001b[84X\r\n# If you wish httpd to run as a different user or group, you must run\r\n# httpd as root initially and it will switch.  \r\n#\u001b[26X\r\n# User/Group: The name (or #number) of the user/group to run httpd as.\r\n# It is usually good practice to create a dedicated user and group for\u001b[25X\r\n# running httpd, as with most system services.\r\n#\r\n\u001b[96mUser\u001b[m\u000f http\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[66X\r\n\u001b[69X\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[58X\r\n\u001b[68X\n# 'Main' server configuration\u001b[15X\r\n#    \r\n# The directives in this section set up the values used by the 'main'\r\n# server, which responds to any requests that aren't handled by a\r\n# <VirtualHost> definition.  These values also provide defaults for\r\n# any <VirtualHost> containers you may define later in the file.\u001b[9X\r\n#\u001b[67X\r\n# All of these directives may appear inside <VirtualHost> containers,\r\n# in which case these default settings will be overridden for the\r\n# virtual host being defined.\r\n#\r\n\u001b[23X\n#    \r\n# ServerAdmin: Your address, where problems with the server should be   \r\n# e-mailed.  This address appears on some server-generated pages, such \r\n# as error \u001b[30m\u001b[103mdocument\u001b[m\u000fs.  e.g. admin@your-domain.com\u001b[18X\r\n#\u001b[13X\r\n\u001b[96mServerAdmin\u001b[m\u000f you@\u001b[96mexample\u001b[m\u000f.com\u001b[29X\r\n\n#    \r\n# ServerName gives the name and port that the server uses to identify itself.\r\n# This can often be determined automatically, but we recommend you specify\r\n# it explicitly to prevent problems during startup.\r\n#\u001b[41X\r\n# If your host doesn't have a registered DNS name, enter its IP address here.\r\n#\u001b[65X\r\n#ServerName www.example.com:80\u001b[34X\r\n\u001b[62X\n#\u001b[25X\r\n# Deny access to the entirety of your server's filesystem. You must\r\n# explicitly permit access to web content directories in other \r\n# <Directory> blocks below.\u001b[48X\r\n#\u001b[67X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f /\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[58X\r\n    \u001b[96mAllowOverride\u001b[m\u000f none\u001b[53X\r\n    \u001b[96mRequire\u001b[m\u000f all denied\u001b[47X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[17X\r\n\u001b[5X\n#\u001b[45X\r\n# Note that from this point forward you must specifically allow\r\n# particular features to be enabled - so if something's not working as\r\n# you might expect, make sure that you have specifically enabled it\r\n# below.\u001b[14X\r\n#    \r\n\u001b[69X\n#\u001b[64X\r\n# DocumentRoot: The directory out of which you will serve your\r\n# \u001b[30m\u001b[103mdocument\u001b[m\u000fs. By default, all requests are taken from this directory, but\u001b[66;223H\u001b[0;10;7m\u000f220,12         39\u001b[67;10H\u001b[?25h"]
