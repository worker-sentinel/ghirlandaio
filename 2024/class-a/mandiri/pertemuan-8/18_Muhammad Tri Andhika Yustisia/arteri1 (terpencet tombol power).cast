[2021.839598, "o", "\u001b[?25l\u001b[65A\u001b[96mDocumentRoot\u001b[m\u000f \u001b[92m\"/srv/http/arteri\"\u001b[m\u000f\u001b[43X\r\n\u001b[0;10;1m\u000f<Directory\u001b[m\u000f \"/srv/http/arteri\"\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[35X\r\n        \u001b[96mOptions\u001b[m\u000f FollowSymLinks\u001b[41X\r\n        \u001b[96mAllowOverride\u001b[m\u000f All\r\n        \u001b[96mRequire\u001b[m\u000f all granted\u001b[33X\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\u001b[39X\r\n    #\r\n    # Possible values for the Options directive are \"None\", \"All\", \r\n    # or any combination of:\u001b[48X\r\n    #   Indexes Includes FollowSymLinks SymLinksifOwnerMatch ExecCGI MultiViews\r\n    #\r\n    # Note that \"MultiViews\" must be named *explicitly* --- \"Options All\"\r\n    # doesn't give it to you.\u001b[47X\r\n    #\u001b[65X\r\n    # The Options directive is both complicated and important.  Please see\r\n    # http://httpd.apache.org/docs/2.4/mod/core.html#options\u001b[12X\r\n    # for more information.\u001b[50X\r\n    #\u001b[39X\u001b[20;5H\u001b[96mOptions\u001b[m\u000f Indexes FollowSymLinks\r\n \r\n    #\u001b[63X\r\n    # AllowOverride controls what directives may be placed in .htaccess files.\r\n    # It can be \"All\", \"None\", or any combination of the keywords:\r\n    #   AllowOverride FileInfo AuthConfig Limit\u001b[21X\r\n    #\u001b[67X\r\n    \u001b[96mAllowOverride\u001b[m\u000f None\u001b[54X\r\n\u001b[72X\n    #\u001b[11X\r\n    # Controls who can get stuff from this server.\r\n    #\u001b[18X\u001b[32;5H\u001b[96mRequire\u001b[m\u000f all granted\r\n\u001b[0;10;1m\u000f</Directory>\u001b[m\u000f\r\n\u001b[71X\u001b[35;2H\u001b[54X\n DirectoryIndex: sets the file that Apache will serve if a directory\u001b[37;3His requested.\u001b[63X\u001b[38;2H\u001b[75X\r\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f dir_module\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    \u001b[96mDirectoryIndex\u001b[m\u000f index.html\r\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[15X\u001b[44;3HThe following lines prevent .htaccess and .htpasswd files from being \u001b[45;3Hviewed by Web clients. \u001b[34X\u001b[46;2H\u001b[11X\r\n\u001b[0;10;1m\u000f<Files\u001b[m\u000f \".ht*\"\u001b[0;10;1m\u000f>\r\n\u001b[m\u000f    \u001b[96mRequire\u001b[m\u000f all denied\u001b[45X\r\n\u001b[0;10;1m\u000f</Files>\u001b[m\u000f\u001b[51X\r\n \n\u001b[21X\r\n# ErrorLog: The location of the error log file.\r\n# If you do not specify an ErrorLog directive within a <VirtualHost>\u001b[54;2H container, error messages relating to that virtual host will be\u001b[55;3Hlogged here.  If you *do* define an error logfile for a <VirtualHost>\u001b[56;2H container, that host's errors will be logged there and not here.\u001b[57;2H\u001b[77X\r\n\u001b[96mErrorLog\u001b[m\u000f \u001b[92m\"/var/log/httpd/error_log\"\u001b[m\u000f\u001b[37X\r\n\u001b[75X\u001b[60;2H\u001b[69X\u001b[61;3HLogLevel: Control the number of messages logged to the error_log.\u001b[62;2H Possible values include: debug, info, notice, warn, error, crit,\u001b[63;3Halert, emerg.\u001b[64;2H\u001b[41X\r\n\u001b[96mLogLevel\u001b[m\u000f warn\u001b[66;223H\u001b[0;10;7m\u000f286,1          52%\u001b[?112c\u001b[?1002h\u001b[?1006h\r\u001b[33A\u001b[?25h"]
