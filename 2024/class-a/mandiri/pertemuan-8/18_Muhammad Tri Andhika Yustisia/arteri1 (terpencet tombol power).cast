[2933.313408, "o", "\u001b[1;65r\u001b[H\u001b[27M\u001b[1;67r\u001b[6;13Hdialup_module modules/mod_di\u001b[33;12H\u001b[30m\u001b[103mdir\u001b[m\u000f_module modules/mod_\u001b[30m\u001b[103mdir\u001b[37;18Hr\u001b[m\u000f_module modules/mod_user\u001b[30m\u001b[103mdir\r\n\n\u001b[m\u000f\u001b[96mLoadModule\u001b[m\u000f rewrite_module modules/mod_rewrite.so\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f<IfModule\u001b[m\u000f unixd_module\u001b[0;10;1m\u000f>\u001b[m\u000f\u001b[K\r\n#\u001b[K\r\n# If you wish httpd to run as a different user or group, you must run\u001b[K\r\n# httpd as root initially and it will switch.  \u001b[K\r\n#\u001b[K\r\n# User/Group: The name (or #number) of the user/group to run httpd as.\u001b[K\r\n# It is usually good practice to create a dedicated user and group for\u001b[K\r\n# running httpd, as with most system services.\u001b[K\r\n#\u001b[K\r\n\u001b[96mUser\u001b[m\u000f http\u001b[K\r\n\u001b[96mGroup\u001b[m\u000f http\u001b[K\r\n\u001b[K\n\u001b[0;10;1m\u000f</IfModule>\u001b[m\u000f\u001b[K\r\n\u001b[K\n# 'Main' server configuration\u001b[K\r\n#\u001b[K\r\n# The \u001b[30m\u001b[103mdir\u001b[m\u000fectives in this section set up the values used by the 'main'\u001b[K\r\n# server, which responds to any requests that aren't handled by a\u001b[K\r\n# <VirtualHost> definition.  These values also provide defaults for\u001b[K\r\n# any <VirtualHost> containers you may define later in the file.\u001b[K\r\n#\u001b[K\r\n# All of these \u001b[30m\u001b[103mdir\u001b[m\u000fectives may appear inside <VirtualHost> containers,\u001b[K\r\n# in which case these default settings will be overridden for the\u001b[K\r\n# virtual host being defined.\u001b[K\r\n#\u001b[K\u001b[66;224H\u001b[0;10;7m\u000f83,12         31\u001b[67;5H\u001b[?25h"]
