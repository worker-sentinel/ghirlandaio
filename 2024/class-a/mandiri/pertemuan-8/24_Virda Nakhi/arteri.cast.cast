[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; interesting side-effects depending on your application and web server.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; You may be able to send headers and cookies after you've already sent output\r"]
