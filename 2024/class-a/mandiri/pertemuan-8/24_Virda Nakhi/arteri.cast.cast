[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/enable-dl\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1Henable_dl = Off\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; cgi.force_redirect is necessary to provide security running PHP as a CGI under\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; most web servers.  Left undefined, PHP turns this on by default.  You can\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; turn it off here AT YOUR OWN RISK\r"]
[4.249, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; **You CAN safely turn this off for IIS, in fact, you MUST.**\r"]
[0.360, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/cgi.force-redirect\r"]
[0.252, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;cgi.force_redirect = 1\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; if cgi.nph is enabled it will force cgi to always sent Status: 200 with\r"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; every request. PHP's default behavior is to disable this feature.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;cgi.nph = 1\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; if cgi.force_redirect is turned on, and you are not running under Apache or Netscape\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; (iPlanet) web servers, you MAY need to set an environment variable name that PHP\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; will look for to know it is OK to continue execution.  Setting this variable MAY\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; cause security issues, KNOW WHAT YOU ARE DOING FIRST.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/cgi.redirect-status-env\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;cgi.redirect_status_env =\r"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; cgi.fix_pathinfo provides *real* PATH_INFO/PATH_TRANSLATED support for CGI.  PHP's\r"]
[0.025, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; previous behaviour was to set PATH_TRANSLATED to SCRIPT_FILENAME, and to not grok\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; what PATH_INFO is.  For more information on PATH_INFO, see the cgi specs.  Setting\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; this to 1 will cause PHP CGI to fix its paths to conform to the spec.  A setting\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; of zero causes PHP to behave as before.  Default is 1.  You should fix your scripts\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.001, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; to use SCRIPT_FILENAME rather than PATH_TRANSLATED.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/cgi.fix-pathinfo\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;cgi.fix_pathinfo=1\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.034, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; if cgi.discard_path is enabled, the PHP CGI binary can safely be placed outside\r"]
[0.025, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; of the web tree and people will not be able to circumvent .htaccess security.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;cgi.discard_path=1\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; FastCGI under IIS supports the ability to impersonate\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; security tokens of the calling client.  This allows IIS to define the\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; security context that the request runs under.  mod_fastcgi under Apache\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; does not currently support this feature (03/17/2002)\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Set to 1 if running under IIS.  Default is zero.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/fastcgi.impersonate\r"]
[0.033, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;fastcgi.impersonate = 1\r"]
[1.075, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.251, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; Prevent decoding of SCRIPT_FILENAME when using Apache ProxyPass or\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; ProxyPassMatch. This should be used if script file paths are not stored\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; in an encoded format on the file system.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Default is 1.\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;fastcgi.script_path_encoded = 0\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Disable logging through FastCGI connection. PHP's default behavior is to enable\r"]
[0.032, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; this feature.\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H;fastcgi.logging = 0\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; cgi.rfc2616_headers configuration option tells PHP what type of headers to\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; use when sending HTTP response code. If set to 0, PHP sends Status: header that\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.001, "o", "\n\u001b[1;48r\u001b[45;1H; is supported by Apache. When this option is set to 1, PHP will send\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; RFC2616 compliant header.\r"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; Default is zero.\r"]
[0.028, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; https://php.net/cgi.rfc2616-headers\r"]
[0.376, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H;cgi.rfc2616_headers = 0\r"]
[0.257, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H; cgi.check_shebang_line controls whether CGI PHP checks for line starting with #!\r"]
[0.025, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; (shebang) at the top of the running script. This line might be needed if the\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H; script support running both as stand-alone script and via PHP CGI<. PHP in CGI\r"]
[0.031, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
