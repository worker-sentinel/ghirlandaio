[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;5H# Possible values for the Options directive are \"None\", \"All\",\r"]
[0.025, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
