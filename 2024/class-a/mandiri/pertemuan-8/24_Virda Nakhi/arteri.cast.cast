[0.001, "o", "\n\u001b[1;48r\u001b[45;1H#LoadModule authnz_ldap_module modules/mod_authnz_ldap.so\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H#LoadModule authnz_fcgi_module modules/mod_authnz_fcgi.so\r"]
