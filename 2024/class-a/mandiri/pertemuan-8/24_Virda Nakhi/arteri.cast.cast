[0.001, "o", "\n\u001b[1;48r\u001b[45;1H# e-mailed.  This address appears on some server-generated pages, such\r"]
[0.194, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d\n\u001b[1;48r\u001b[45;1H# as error documents.  e.g. admin@your-domain.com\r"]
