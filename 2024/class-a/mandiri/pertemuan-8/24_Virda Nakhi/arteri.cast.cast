[0.000, "o", "\n\u001b[1;48r\u001b[45;1HLoadModule authz_core_module modules/mod_authz_core.so\r"]
[0.251, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
