[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H#LoadModule authz_owner_module modules/mod_authz_owner.so\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H#LoadModule authz_dbd_module modules/mod_authz_dbd.so\r"]
[0.813, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
