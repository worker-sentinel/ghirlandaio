[0.000, "o", "\r\u001b[2d#\u001b[K\u001b[3d\b# MaxRanges: Maximum number of Ranges in a request before\r\u001b[4d# returning the entire resource, or one of the special\r\u001b[5d# values 'default', 'none' or 'unlimited'.\u001b[K\r\u001b[6d"]
[0.000, "o", "# Default setting is to accept 200 Ranges.\u001b[K\r\u001b[7d#MaxRanges unlimited\u001b[K\r\u001b[8d\u001b[K\u001b[9d"]
[0.001, "o", "#\u001b[K\u001b[10d\b# EnableMMAP and EnableSendfile: On systems that support it,\u001b[K\r\u001b[11d# memory-mapping or the sendfile syscall may be used to deliver\r\u001b[12d# files.  This usually improves server performance, but must\r\u001b[13d# be turned off when serving from networked-mounted\r\u001b[14d# filesystems or if support for these functions is otherwise\r\u001b[15d"]
[0.000, "o", "# broken on your system.\u001b[K\r\u001b[16d# Defaults: EnableMMAP On, EnableSendfile Off\r\u001b[17d#\u001b[K\u001b[18d\b#EnableMMAP off\u001b[K\r\u001b[19d#EnableSendfile on\r\u001b[20d"]
[0.000, "o", "\u001b[K\u001b[21d"]
[0.000, "o", "# Supplemental configuration\u001b[K\r\u001b[22d#\u001b[K\u001b[23d\b# The configuration files in the conf/extra/ directory can be\r\u001b[24d"]
[0.000, "o", "# \u001b[30m\u001b[43minclude\u001b[39;49m\u001b[m\u000fd to add extra features or to modify the default configuration of\r\u001b[25d"]
[0.001, "o", "# the server, or you may simply copy their contents here and change as\r\u001b[26d# necessary.\r\u001b[27d\u001b[K\u001b[28d# Server-pool management (MPM specific)\u001b[K\r\u001b[29dInclude conf/extra/httpd-mpm.conf\u001b[K\r\u001b[30d\u001b[K\u001b[31d# Multi-language error messages\r\u001b[32dInclude conf/extra/httpd-multilang-errordoc.conf\u001b[34;3HFancy directory listings\r\u001b[35dInclude conf/extra/httpd-autoindex.conf\u001b[K\r\u001b[36d\u001b[K\u001b[37d# Language settings\r\u001b[38dInclude conf/extra/httpd-languages.conf\r\u001b[39d\u001b[K\u001b[40d# User home directories\u001b[K\r\u001b[41dInclude conf/extra/httpd-userdir.conf\u001b[K\r\u001b[42d\u001b[K\u001b[43d# Real-time info on requests and configuration\r\u001b[44d#Include conf/extra/httpd-info.conf\r\u001b[45d\u001b[K\u001b[24d# "]
