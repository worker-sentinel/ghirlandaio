[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H#\b"]
[0.029, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H# Note that from this point forward you must specifically allow\r"]
[0.030, "o", "\u001b[?25l\u001b[?1c"]
[0.000, "o", "\u001b[?25h\u001b[?0c"]
[0.001, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H# particular features to be enabled - so if something's not working as\r"]
[0.495, "o", "\u001b[?25l\u001b[?1c\u001b[?25h\u001b[?0c"]
[0.000, "o", "\u001b7\u001b[2;46r\u001b8\u001b[46d"]
[0.000, "o", "\n\u001b[1;48r\u001b[45;1H# you might expect, make sure that you have specifically enabled it\r"]
